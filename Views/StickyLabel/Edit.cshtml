
@model QuickSoft.Models.StickyLabel
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Edit Labels</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("Edit", "StickyLabel", FormMethod.Post, new { role = "form", id = "editform" }))
            {
        <script type="text/javascript">
                    $('form#popupFormStickyLabelEdit').removeData("validator");
                    $('form#popupFormStickyLabelEdit').removeData("unobtrusiveValidation");
                    $.validator.unobtrusive.parse($('form#popupFormStickyLabelEdit'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        @Html.HiddenFor(model => model.Id)
        <div class="row">
            <div class="col-md-12">
                <div class="form-group">
                    @Html.LabelFor(m => m.LabelName, new { @class = "control-label" }) *
                    @Html.TextBoxFor(m => m.LabelName, new { @class = "form-control", autofocus = "autofocus", @required = "required" })
                </div>

                <div class="form-group">
                    @Html.LabelFor(m => m.LabelColor, new { @class = "control-label" }) *
                    @*@Html.TextBoxFor(m => m.LabelColor, new { @class = "form-control", autofocus = "autofocus", @required = "required" })*@
                    @Html.DropDownList("LabelColor", new List<SelectListItem>()
                         {
                            new SelectListItem(){ Text= "Green", Value = "Green"},
                            new SelectListItem(){ Text= "Red", Value = "Red"},
                            new SelectListItem(){ Text= "Blue", Value = "Blue"},
                            new SelectListItem(){ Text= "Yellow", Value = "Yellow"},
                            new SelectListItem(){ Text= "Orange", Value = "Orange"},
                            new SelectListItem(){ Text= "Purple", Value = "Purple"}
                        }, "Select Color", new { @class = "form-control", @autofocus = "autofocus", @required = "required" })
                </div>

                <div class="form-group">
                    @Html.LabelFor(model => model.Status, new { @class = "control-label" })
                    @Html.EnumDropDownListFor(model => model.Status, new { @class = "form-control" })
                </div>

            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" class="btn btn-info col-sm-offset-4" value="Update" />
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>
@section scripts{
    @Scripts.Render("~/js/jqueryval")
}

