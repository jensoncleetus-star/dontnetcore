
@{
    ViewBag.Title = "Search Stock";
    ViewBag.SubTitle = "Stock Report";
    ViewBag.Active = "Reports";
    string actData = "";
    var dtURL = "'/StockReport/GetItemWisenew'";
}
@Html.Partial("../Common/_ModalCreate")
<style>
    .select2-results__options[aria-multiselectable="true"] li {
        padding-left: 30px;
        position: relative
    }

        .select2-results__options[aria-multiselectable="true"] li:before {
            position: absolute;
            left: 8px;
            opacity: .6;
            top: 6px;
            font-family: "FontAwesome";
            content: "\f0c8";
        }

        .select2-results__options[aria-multiselectable="true"] li[aria-selected="true"]:before {
            content: "\f14a";
        }
</style>
<div class="box box-default">
    <input type="hidden" id="LastSale" value="@ViewBag.LastTransInSale" />
    <input type="hidden" id="LastPurchase" value="@ViewBag.LastTransInPurchase" />


    <input type="hidden" id="VoucherType" value="Sales" />

    <div class="box-header with-border">
        <h3 class="box-title">Price Search</h3>
    </div>
    <div class="box-body">
        @using (Html.BeginForm("ItemWise", "Item", FormMethod.Post, new { id = "search-form", target = "_new" }))
        {
            <div class="form-group row">

                <div class="form-group col-md-12">
                    @Html.Label("Material Center", null, new { @class = "control-label" })
                    @*@Html.DropDownList("ddlMC", (SelectList)ViewBag.MC, new { @class = "form-control input-sm", @multiple = "multiple", @name = "ddlMC[]" })*@
                    @Html.ListBox("ddlMC", (MultiSelectList)ViewBag.mc, new { @class = "form-control input-sm select2" })
                </div>
                @*<div class="col-md-12">
                        @Html.Label("Item", null, new { @class = "control-label col-md-12" })
                        @Html.DropDownList("ddlItem", (SelectList)ViewBag.Item, new { @class = "form-control input-sm select2", @multiple = "multiple", @name = "ddlItem[]" })
                    </div>*@
                <div class="form-group col-md-12">
                    @Html.Label("Item", null, new { @class = "control-label" })
                    @Html.ListBox("ddlItem", (MultiSelectList)ViewBag.Item, new { @class = "form-control input-sm select2" })
                </div>
                @if (@ViewBag.BCEnable == 0)
                {
                    <div class="form-group col-md-4 hidden">
                        <label class="control-label">Item BarCode</label>
                        <input type="text" class="form-control barcode" />
                    </div>
                }
                @*<div class="col-md-4 lblpadding">
                        <label class="control-label"><input type="checkbox" value="true" name="stockable" id="stockable" />  Include non-stockable Items</label>
                    </div>*@
                <div class="col-md-12 lblpadding">
                    <button type="submit" class="btn btn-info col-sm-offset-5" id="btn">Search</button>
                    <button type="button" class="btn btn-default" onclick="@("window.location.href='/Home/Index'");">Cancel</button>
                </div>
            </div>
        }

    </div>
    <div id="LastSalePur"></div>
    <div id="itemdesc"></div>
    <div class="box box-default" id="StockReport">

        <div class="box-body">
            <div class="box-body">
                @{
                    var url = Model;
                    var file = "";
                    var chk = "";

                    if (url == "'/Item/GetItemWise'")
                    {
                        file = "Stock Report (Item Wise)";
                    }
                }

                <table class="display table table-bordered table-hover" id="UserTable">
                    <thead>
                        <tr class="bg-gray">
                            <td data-priority="1">S/N</td>
                            <td data-priority="1">Item Code</td>
                            <td data-priority="1">Item Name</td>
                            <td data-priority="1">Stock Primary Unit</td>
                            <td data-priority="5">Showroom</td>
                            <td data-priority="1">Stock Secondary Unit</td>
                            <td data-priority="5">Selling Price</td>

                        </tr>
                    </thead>
                    <tbody></tbody>
              
                </table>
   

            </div>
        </div>
    </div>
</div>

<div class="row">
    <div id="answertext2"></div>
</div>
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
}
@section Scripts {
    @Scripts.Render("~/js/scaner")
    @Scripts.Render("~/js/JsBarcode")
    @Scripts.Render("~/js/bootstrap-datepicker")

    <script type="text/javascript">



        $(document).ready(function () {


            CallMC();










            $('#StockReport').hide();
            $('.headinghide').hide();
            $("#ddlItem").select2({
                placeholder: 'Search Item by Name or Code',
                minimumInputLength: 0,
              
                ajax: {
                    url: "/Item/Searchcus",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term || "",
                            page: params.page || 0

                        };
                    },
                    results: function (data) {
                        return { results: data };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 0;
                        return {
                            results: data,
                            pagination: {
                                //more: (params.page * 10) < 50
                                more: true
                            }
                        };
                    },
                    cache: true
                },

            });





        });
    </script>
    <script type="text/javascript">
        function showdatatable() {
        oTable = $('#UserTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once

            "bStateSave": true,
            "pageLength": 50,
            @*@Html.Raw(chk)*@
            "bLengthChange": false,
            "paging": true,
            stateSave: true,
            responsive: true,

            "ordering": true,

            "ajax": {
                "url":  "/Item/GetItemWisenew",
                "data": function (data) {
                    data=searchData(data);
                },
                "type": "POST",
                "datatype": "json"
            },
           "columns": [
                {
                    "data": "ItemID", "name": "ItemID",
                    "render": function (data, type, row, meta) {
                        return meta.row + meta.settings._iDisplayStart + 1;
                    }
               },

                {
                    "data": "itemcode", "name": "itemcode",
                },
                {
                    "name": "itemname", "data": function (datas) {
                       var plink = "";
                       @{

                          actData = "";
                          //actData = "datas.stcost";


                      actData += "<a  onclick=showitemdesc('+datas.ItemID+')  >'+datas.itemname+'</a> ";

                      }
                       return rest = '@Html.Raw(actData)';

                       }
               },
           
               {
                   "name": "pritotal", "data": function (data) {
                       return (data.total / data.ConFactor + " " + data.PriUnit);
                   }
               },
               {
                   "name": "MC", "data": "MC"
               },

               {
                   "name": "total", "data": function (data) {
                       return (data.total + " " + data.SubUnit);
                   }
               },
           
                { "data": "BasePrice", "name": "BasePrice", render: $.fn.dataTable.render.number(",", ".", 2) },
                
           



            ],
            buttons: [//'copy', 'csv', 'excel', 'pdf', 'print'
            'colvis',
            {
                extend: 'print',//
                exportOptions: {
                    columns: ':visible'
                },
                title: "",
                footer: true,
                filename: function () {
                    return '@file';
                },
                message: function () {
                    var head = '<table class="tblcompact table table-bordered"><thead>' +
                    ' <tr><th class="text-center"><h3 style="margin-top: 0px;">' + $('#cname').val() + '</h3>' + $('#caddress').val() + '<h4>@file</h4></th></tr>' +
                    ' <tr><th><span class="text-left"></span><span class="text-right pull-right"> </span></th></tr></thead><tbody><tr><td>';
                    return head;
                },
                customize: function (win) {
                    // $(win.document.body)
                    //.css('font-size', '10pt')
                    //.css('padding', '1px');
                    $(win.document.body).find('table, th,tr, td ')
                       // .css('border', 'inherit')
                        .css('font-size', '10pt')
                        .css('padding', '5px')
                        .addClass('compact');
                    $(win.document.body).append('</td></tr></tbody>')

                }
            }, 'copy', 'csv', //'excel',
            {
                extend: 'excel',//
                title: "",
                footer: true,
                filename: function () {
                    return '@file';
                },
                message: function () {
                    var head = '' + $('#cname').val() + '\n' +
                       '' + $('#caddress').val() + '\n' +
                       '@file';
                    return head;
                },
                pageSize: 'A4',
                exportOptions: {
                    columns: ':visible'
                },
            },
          {
              extend: 'pdf',//
              title: "",
              footer: true,
              filename: function () {
                  return '@file';
              },
              message: function () {
                  var head = '' + $('#cname').val() + '\n' +
                     '' + $('#caddress').val() + '\n' +
                     '@file';
                  return head;
              },
              pageSize: 'A4',
              exportOptions: {
                  columns: ':visible'
              },
              customize: function (doc) {
                  doc.pageMargins = [10, 10, 10, 10];
                  doc.defaultStyle.fontSize = 10;
                  doc.styles.tableHeader.fontSize = 10;
                  doc.styles.title.fontSize = 12;

                  // Header font and bg color
                  doc.styles.tableHeader.fillColor = '#d3d3d3';
                  doc.styles.tableHeader.color = 'black';
                  // Remove spaces around page title
                  doc.content[0].text = doc.content[0].text.trim();


                  doc.styles['td:nth-child(1)'] = {
                      width: '100%',
                      'max-width': '100%'
                  }

                  //doc.content[1].table.widths = [
                  //'8%',
                  //'8%',
                  //'8%',
                  //'8%',
                  //'8%',
                  //'8%',
                  //'8%',
                  //'8%',
                  //'8%',
                  //'8%',
                  //'8%',
                  //'8%',
                  //]


                  var objLayout = {};
                  // Horizontal line thickness
                  objLayout['hLineWidth'] = function (i) { return .5; };
                  // Vertikal line thickness
                  objLayout['vLineWidth'] = function (i) { return .5; };
                  //// Horizontal line color
                  //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                  //// Vertical line color
                  //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                  // Left padding of the cell
                  objLayout['paddingLeft'] = function (i) { return 4; };
                  // Right padding of the cell
                  objLayout['paddingRight'] = function (i) { return 4; };
                  // Inject the object in the document
                  doc.content[1].layout = objLayout;
                  // Footer font and bg color
                  doc.styles.tableFooter.fillColor = '#d3d3d3';
                  doc.styles.tableFooter.color = 'black';
              }


          },

            ],



            sDom: "lBfr<'datatable-scroll't>ip",
            "lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
            "footerCallback": function (row, data, start, end, display) {
                var api = this.api(), data;

                // Remove the formatting to get integer data for summation
                var intVal = function (i) {
                    return typeof i === 'string' ?
                        i.replace(/[\$,]/g, '') * 1 :
                        typeof i === 'number' ?
                        i : 0;
                };




                var table = $('#UserTable').DataTable();
                if (!table.data().any()) {
                    $('#UserTable tfoot').hide();
                } else {
                    $('#UserTable tfoot').show();
                }
            }
        });






    }
    </script>
    <script type="text/javascript">

        function searchData(data) {

            data.itemidd = $("#ddlItem").val();
            data.ddmcc = $("#ddlMC").val();
        }
        $(document).ready(function () {
            //var values = "20080,20081";
            //$.each(values.split(","), function (i, e) {
            //    $("#ddlMC option[value='" + e + "']").prop("selected", true);
            //});
            //$("#ddlMC").trigger("change");
            //values = "2,5";
            //$.each(values.split(","), function (i, e) {
            //    $("#ddlMC option[value='" + e + "']").prop("selected", false);
            //});
            //$("#ddlMC").trigger("change");
        });

        $('#UserTable tbody').on('click', 'tr', function () {
            if ($(this).hasClass('selected')) {
                $(this).removeClass('selected');
            }
            else {
                oTable.$('tr.selected').removeClass('selected');
                $(this).addClass('selected');
                $(this).addClass('dataTables_row');
            }
        });
        var flag = 0;
        $('#search-form').on('submit', function (e) {
            e.preventDefault();
            if (flag == 0) {
                showdatatable();
              
                flag = 1;
            }
            else
                oTable.draw();
            
            $('#StockReport').show();
           
        });
    </script>


}
