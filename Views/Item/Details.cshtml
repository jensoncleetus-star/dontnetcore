@using QuickSoft.Models
@model QuickSoft.ViewModel.ItemViewModel
@{
    ViewBag.Title = "Item Details";
    ViewBag.SubTitle = "Details";
    ViewBag.Active = "Master";


    string TypeNames = "";
    if (Model.ItemType == 1)
    {
        TypeNames = "General";
    }
    else if (Model.ItemType == 2)
    {
        TypeNames = "Diamond";
    }
    else if (Model.ItemType == 3)
    {
        TypeNames = "Watch";
    }
    else
    {
        TypeNames = "Object";
    }

    var WarrName = "";
    if (Model.Warranty == 1)
    {
        WarrName = "Warranteed";
    }
    else if (Model.Warranty == 2)
    {
        WarrName = "Guaranteed";
    }
    else if (Model.Warranty == 3)
    {
        WarrName = "None";
    }
}

<div class="box box-info">
    <div class="box-header">
        <h3 class="box-title">@Html.DisplayFor(m => m.ItemName)</h3>
        <div class="pull-right col-md-2">
