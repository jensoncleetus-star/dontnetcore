    else {
alert("you must select a material center")
    }
    }

    function SearchData(data) {

        data.brand = $('#ddlBrand').val();
        data.category = $('#ddlCategory').val();
        data.mc = $('#ddlMC2').val();
        data.itemWord = $('#ItemWord').val();
    }

