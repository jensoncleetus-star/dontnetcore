
@using QuickSoft.Models
@{
    string actData = "";
}
<style>
    @@media only screen and (max-width: 430px) {
    }
    #ItemWord {
        border-radius: 0px !important;
        /*height:30px!important;*/
        height: 30px !important;
    }
    .sh-aligns{
        width:1100px!important;
        margin-left:-100px!important;
    }
    
</style>
<div class="modal-header sh-aligns">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Search Item</h4>
</div>
<div class="modal-body sh-aligns">
    <form id="search-form">
        @using (Html.BeginForm("AddItemSearch", "Item", FormMethod.Post, new { id = "popupForm", target = "_new" }))
            {
            <input type="hidden" id="cname" value="@ViewBag.CName" />
            <input type="hidden" id="caddress" value="@ViewBag.CAddress" />


            <div class="row">
                <div class="form-group col-md-3">
                    @Html.Label("Item Brand", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlBrand", (SelectList)ViewBag.Brand, new { @class = "form-control input-sm select2" })
                </div>
                <div class="form-group col-md-3" id="creditsale">
                    @Html.Label("Item Category", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlCategory", (SelectList)ViewBag.Category, new { @class = "form-control input-sm select2" })
                </div>
                <div class="col-md-3 form-group">
                    @Html.Label("ItemName Contains", null, new { @class = "control-label" })
                    @Html.TextBox("ItemWord", "", "", new { @class = "form-control", @autocomplete = "off" })
                </div>
                @if (@ViewBag.EnableMCcheck == 0)
                {
                    <div class="form-group col-md-3">
                        @Html.Label("Material Center", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlMC2", (SelectList)ViewBag.MC, new { @class = "form-control input-sm select2" })
                    </div>
                }
                <div class="row box-footer col-md-12">
                    <input type="submit" class="btn btn-info col-sm-offset-5" value="Submit" />
                    <button type="button" class="btn btn-default" onclick="setItem2()">Cancel</button>
                </div>
            </div>
        }
    </form>
        <div class="box box-default" id="StockReport">



            <div class="box-body">
                <table class="display table table-bordered" id="UserTable">
                    <thead>
                        <tr class="bg-gray">
                            <td data-priority="2">S/N</td>
                            <td data-priority="4">Item code</td>
                            <td data-priority="6">Item Name</td>
                            <td data-priority="4">Current Stock</td>
                            <td>Selling Price</td>
                            <td>Purchase Price</td>
                            <td>Last Movement</td>
                            <td><input type="button" class="btn btn-danger" onclick="setItem()" value="Select" /></td>
                        </tr>
                    </thead>
                    <tbody></tbody>
                    <tfoot>
                        <tr>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                        </tr>
                    </tfoot>
                </table>
                @*<div class="row box-footer col-md-12">
                    <input type="button" class="btn btn-info col-sm-offset-5" onclick="setItem()" value="Select" />
                    <button type="button" class="btn btn-default" onclick="setItem2()">Cancel</button>
                </div>*@
            </div>
        </div>
</div>
<script type="text/javascript">
    $(document).ready(function () {

        $("#StockReport").hide();
        $("#ddlCategory").select2({
            placeholder: 'Search Item Category',
            minimumInputLength: 0,
            ajax: {
                url: "/ItemCategory/SearchCategory",
                dataType: 'json',
                type: "POST",
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term,
                        page: params.page,
                        x: "All"
                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 1;

                    return {
                        results: data
                    };
                },
                cache: true
            },
        });
        $("#ddlBrand").select2({
            placeholder: 'Search Item Brand',
            minimumInputLength: 0,
            ajax: {
                url: "/ItemBrand/SearchBrand",
                dataType: 'json',
                type: "POST",
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term,
                        page: params.page,
                        x: "all"
                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 1;

                    return {
                        results: data
                    };
                },
                cache: true
            },
        });
        var tempMC = $("#ddlMC").val();
        $('#ddlMC2 option[value=' + tempMC + ']').attr('selected', true);
        $("#ddlMC2").select2({
            placeholder: 'Select Material Center',
            minimumInputLength: 0,
            ajax: {
                url: "/MC/SearchMC",
                dataType: 'json',
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term,
                        page: params.page,
                        x: "All"
                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 1;
                    return {
                        results: data
                    };
                },
                cache: true
            },
        });

    });
    function setItem2() {
        $('.close').click();
    }
