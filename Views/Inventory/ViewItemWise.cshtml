@{
    ViewBag.Title = "View Stock";
    ViewBag.SubTitle = "Item Wise Stock Report";
    ViewBag.Active = "Reports";

}
<div class="box box-default" id="PReport">
    <div class="box-header with-border">
        <h3 class="box-title">ItemWise Stock Report</h3>
    </div>
    <div class="box-body">
        <input type="hidden" id="cname" value="@ViewBag.CName" />
        <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
        <input type="hidden" id="itemname" value="@ViewBag.ItemName" />
        <input type="hidden" id="PoNo" value="@ViewBag.PartNoCheck" />
        <input type="hidden" id="mcname" value="@ViewBag.MCSName" />

        <div class="box-body">
            <table class="display table table-bordered table-hover" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="1">S/N</td>
                        <td data-priority="1">Item</td>
                        @*<td data-priority="5" class="headeralign">Stock In</td>
                            <td data-priority="5" class="headeralign">Stock Out</td>*@
                        <td data-priority="2" class="headeralign">Stock</td>
                        <td data-priority="2" class="headeralign">Cost</td>
                        <td data-priority="2" class="headeralign">Stock Value</td>
                        <td data-priority="5" class="headeralign">Sale Rate</td>
                        <td data-priority="5" class="headeralign">Sale Value</td>
                    </tr>
                </thead>
                <tbody></tbody>
                <tfoot>
                    <tr>
                        <th>Total:</th>
                        <th></th>
                        @*<th></th>
                            <th></th>*@
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<script type="text/javascript">
    $(document).ready(function () {
                    oTable = $('#UserTable').DataTable({
                        "processing": true, // for show progress bar,
                        "language": {
                            'loadingRecords': '&nbsp;',
                            'processing': '<i class="fa fa-spinner fa-spin fa-3x fa-fw"></i><span class="sr-only">Loading..n.</span>'
                        },
                        "serverSide": false, // for process server side
                        "filter": true, // this is for disable filter (search box)
                        "orderMulti": false, // for disable multiple column at once
                        // "bStateSave": true,
                        //"deferLoading": 0, // disable default ajax loading
                        "bLengthChange": false,
                        "paging": true,
                        "pageLength": 5000,
                        "ordering": true,
                        "columnDefs": [{
                            "targets": [6],
                            "sClass": "numberright"
                        }],
                        "ajax": {
                            "url": '/Inventory/GetItemWise',
                            "data": { itemid: getQueryString1('itemid'),ddmc: getQueryString1('ddmc') },
                            "type": "POST",
                            "datatype": "json"
                        },
                        "columns": [
                             {
                                 "data": "IItemID", "name": "IItemID",
                                 "render": function (data, type, row, meta) {
                                     return meta.row + meta.settings._iDisplayStart + 1;
                                 }
                             },
                            {
                                "name": "IItemName", "data": function (data) {
                                    return data.IItemCode + " - " + data.IItemName;
                                }
                            },
                            { "data": "ITotalQty", "name": "ITotalQty", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                            { "data": "ITotalCost", "name": "ITotalCost", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                            { "data": "ITotalStockValue", "name": "ITotalStockValue", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                            { "data": "ISellingPrice", "name": "ISellingPrice", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                            {
                                "data": function (data) {
                                    if (data.IKeepStock == true) {
                                        var cfactor=data.IConFactor || 1;
                                        var total = (data.ITotalQty / cfactor) * data.ISellingPrice;
                                        return total.toFixed(2);
                                    }
                                    else
                                        return "";
                                }
                            },

                        ],
                        buttons: [//'copy', 'csv', 'excel', 'pdf', 'print'
                      {
                          extend: 'print',//
                          title: "",
                          footer: true,
                          filename: function () {
                              return 'Stock Report (Item Wise)';
                          },
                          message: function () {
                              var head = '<table class="tblcompact table table-bordered"><thead>' +
                              ' <tr><th class="text-center"><h3 style="margin-top: 0px;">' + $('#cname').val() + '</h3>' + $('#caddress').val() + '<h4>Stock Report (Item Wise)</h4></th></tr>' +
                              ' <tr><th><span class="text-left"> Item : ' + $('#itemname').val() + '</span><span class="text-right pull-right"> </span></th></tr></thead><tbody><tr><td>';
                              return head;
                          },
                          customize: function (win) {
                              // $(win.document.body)
                              //.css('font-size', '10pt')
                              //.css('padding', '1px');
                              $(win.document.body).find('table, th,tr, td ')
                                 // .css('border', 'inherit')
                                  .css('font-size', '10pt')
                                  .css('padding', '5px')
                                  .addClass('compact');
                              $(win.document.body).append('</td></tr></tbody>')

                          }
                      }, 'copy', 'csv', //'excel',
                      {
                          extend: 'excel',//
                          title: "",
                          footer: true,
                          filename: function () {
                              return 'Stock Report (Item Wise)';
                          },
                          message: function () {
                              var head = '' + $('#cname').val() + '\n' +
                                 '' + $('#caddress').val() + '\n' +
                                 ' Item : ' + $('#itemname').val() + '\n' +
                                 ' Stock Report (Item Wise) \n';
                              return head;
                          },
                          pageSize: 'A4',
                          exportOptions: {
                              columns: [0, 1, 2, 3, 4, 5, 6]
                          },
                      },
                      {
                          extend: 'pdf',//
                          title: "",
                          footer: true,
                          filename: function () {
                              return 'Stock Report (Item Wise)';
                          },
                          message: function () {
                              var head = '' + $('#cname').val() + '\n' +
                                 '' + $('#caddress').val() + '\n' +
                                 ' Item : ' + $('#itemname').val() + '\n' +
                                 ' Stock Report (Item Wise) \n';
                              return head;
                          },
                          pageSize: 'A4',
                          exportOptions: {
                              columns: [0, 1, 2, 3, 4, 5, 6]
                          },
                          customize: function (doc) {
                              doc.pageMargins = [10, 10, 10, 10];
                              doc.defaultStyle.fontSize = 10;
                              doc.styles.tableHeader.fontSize = 10;
                              doc.styles.title.fontSize = 12;
                              // Header font and bg color
                              doc.styles.tableHeader.fillColor = '#d3d3d3';
                              doc.styles.tableHeader.color = 'black';
                              // Remove spaces around page title
                              doc.content[0].text = doc.content[0].text.trim();

                              //doc.styles['td:nth-child(2)'] = {
                              //    width: '100%',
                              //    'max-width': '100%'
                              //}

                              doc.content[1].table.widths = [
                              '8%',
                              '25%',
                              '10%',
                              '14%',
                              '14%',
                              '14%',
                              '14%'
                              ]


                              var objLayout = {};
                              // Horizontal line thickness
                              objLayout['hLineWidth'] = function (i) { return .5; };
                              // Vertikal line thickness
                              objLayout['vLineWidth'] = function (i) { return .5; };
                              //// Horizontal line color
                              //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                              //// Vertical line color
                              //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                              // Left padding of the cell
                              objLayout['paddingLeft'] = function (i) { return 4; };
                              // Right padding of the cell
                              objLayout['paddingRight'] = function (i) { return 4; };
                              // Inject the object in the document
                              doc.content[1].layout = objLayout;
                              // Footer font and bg color
                              doc.styles.tableFooter.fillColor = '#d3d3d3';
                              doc.styles.tableFooter.color = 'black';
                          }


                      },
                        ],
                        sDom: "lBfr<'datatable-scroll't>ip",
                        "lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                        "footerCallback": function (row, data, start, end, display) {
                            var api = this.api(), data;

                            // Remove the formatting to get integer data for summation
                            var intVal = function (i) {
                                return typeof i === 'string' ?
                                    i.replace(/[\$,]/g, '') * 1 :
                                    typeof i === 'number' ?
                                    i : 0;
                            };

                            // Total over all pages
                            total = api
                                .column(2)
                                .data()
                                .reduce(function (a, b) {
                                    return intVal(a) + intVal(b);
                                }, 0);

                            // Total over this page
                            pageTotal = api
                                .column(2, { page: 'current' })
                                .data()
                                .reduce(function (a, b) {
                                    return intVal(a) + intVal(b);
                                }, 0);

                            // Update footer
                            $(api.column(2).footer()).html(
                                 pageTotal.toFixed(2)
                                //'$' + pageTotal + ' ( $' + total + ' total)'
                            );

                            total = api
                                .column(3)
                                .data()
                                .reduce(function (a, b) {
                                    return intVal(a) + intVal(b);
                                }, 0);

                            // Total over this page
                            pageTotal = api
                                .column(3, { page: 'current' })
                                .data()
                                .reduce(function (a, b) {
                                    return intVal(a) + intVal(b);
                                }, 0);

                            // Update footer
                            $(api.column(3).footer()).html(
                                 pageTotal.toFixed(2)
                                //'$' + pageTotal + ' ( $' + total + ' total)'
                            );

                            // Total over all pages
                            total = api
                                .column(4)
                                .data()
                                .reduce(function (a, b) {
                                    return intVal(a) + intVal(b);
                                }, 0);

                            // Total over this page
                            pageTotal = api
                                .column(4, { page: 'current' })
                                .data()
                                .reduce(function (a, b) {
                                    return intVal(a) + intVal(b);
                                }, 0);

                            // Update footer
                            $(api.column(4).footer()).html(
                                 pageTotal.toFixed(2)
                                //'$' + pageTotal + ' ( $' + total + ' total)'
                            );

                            // Total over all pages
                            total = api
                                .column(5)
                                .data()
                                .reduce(function (a, b) {
                                    return intVal(a) + intVal(b);
                                }, 0);

                            // Total over this page
                            pageTotal = api
                                .column(5, { page: 'current' })
                                .data()
                                .reduce(function (a, b) {
                                    return intVal(a) + intVal(b);
                                }, 0);

                            // Update footer
                            $(api.column(5).footer()).html(
                                 pageTotal.toFixed(2)
                                //'$' + pageTotal + ' ( $' + total + ' total)'
                            );

                            // Total over all pages
                            total = api
                                .column(6)
                                .data()
                                .reduce(function (a, b) {
                                    return intVal(a) + intVal(b);
                                }, 0);

                            // Total over this page
                            pageTotal = api
                                .column(6, { page: 'current' })
                                .data()
                                .reduce(function (a, b) {
                                    return intVal(a) + intVal(b);
                                }, 0);

                            // Update footer
                            $(api.column(6).footer()).html(
                                 pageTotal.toFixed(2)
                                //'$' + pageTotal + ' ( $' + total + ' total)'
                            );
                            //// Total over all pages
                            //total = api
                            //    .column(8)
                            //    .data()
                            //    .reduce(function (a, b) {
                            //        return intVal(a) + intVal(b);
                            //    }, 0);

                            //// Total over this page
                            //pageTotal = api
                            //    .column(8, { page: 'current' })
                            //    .data()
                            //    .reduce(function (a, b) {
                            //        return intVal(a) + intVal(b);
                            //    }, 0);

                            //// Update footer
                            //$(api.column(8).footer()).html(
                            //     pageTotal.toFixed(2)
                            //    //'$' + pageTotal + ' ( $' + total + ' total)'
                            //);
                            var table = $('#UserTable').DataTable();
                            if (!table.data().any()) {
                                $('#UserTable tfoot').hide();
                            } else {
                                $('#UserTable tfoot').show();
                            }

                        }
                    });
                    $('#UserTable tbody').on('click', 'tr', function () {
                        if ($(this).hasClass('selected')) {
                            $(this).removeClass('selected');
                        }
                        else {
                            oTable.$('tr.selected').removeClass('selected');
                            $(this).addClass('selected');
                            $(this).addClass('dataTables_row');
                        }
                    });
    });
</script>
