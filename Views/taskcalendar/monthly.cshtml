@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/bootstrap-timepicker")
}
@section Scripts {
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/num2words")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/bootstrap-timepicker")

<script type="text/javascript">
                    $('#To').datepicker({
                        format: 'dd-mm-yyyy',
                        autoclose: true,
                        allowInputToggle: true
                    });
                    $('#From').datepicker({
                        format: 'dd-mm-yyyy',
                        autoclose: true,
                        allowIngputToggle: true
                    });
                    $(document).ready(function () {

                        $("#ddldriver").select2({});
                        var date = new Date();
                        var today = new Date(date.getFullYear(), date.getMonth(), date.getDate());
                        var priordate = new Date(new Date().setDate(today.getDate()));
                        $('#To').datepicker('setDate', today);
                        if ('@ViewBag.fromdate'=='')
                            $('#From').datepicker('setDate', priordate);
                        else
                            $('#From').datepicker('setDate', '@ViewBag.fromdate');
                           if ('@ViewBag.todate'=='')
                            $('#To').datepicker('setDate', priordate);
                        else
                            $('#To').datepicker('setDate','@ViewBag.todate');
                        $('.date').datepicker({
                            format: 'dd-mm-yyyy',
                            autoclose: true,
                            allowInputToggle: true
                        });
                    });
                    var oTable = $('#UserTable').DataTable({
                        "processing": true, // for show progress bar
                        "serverSide": false, // for process server side
                        "filter": false, // this is for disable filter (search box)
                        "orderMulti": false, // for disable multiple column at once
                        "bLengthChange": false,
                        "paging": false,
                        "deferLoading": 0,
                        "ordering": false,
                        //"order": [[0, "asc"]],
              
                        sDom: "lBfr<'datatable-scroll't>ip"
                    });
</script>
