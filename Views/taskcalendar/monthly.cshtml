@using QuickSoft.Models
@model QuickSoft.Models.employeetimesheetlist

<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">Time Sheet</h3>
    </div>

    <div class="box-body">

        @using (Html.BeginForm("monthly", "taskcalendar", FormMethod.Post, new { id = "popupForm", target = "_new" }))
        {
            <div class="form-group col-md-2">
                @Html.Label("From", null, new { @class = "control-label" })
                <div class="input-group date">
                    @Html.TextBox("From", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                    <div class="input-group-addon">
                        <i class="fa fa-calendar"></i>
                    </div>
                </div>
            </div>
            <div class="form-group  col-md-2">
                @Html.Label("To", null, new { @class = "control-label" })
                <div class="input-group date">
                    @Html.TextBox("To", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                    <div class="input-group-addon">
                        <i class="fa fa-calendar"></i>
                    </div>
                </div>
            </div>
            <div class="form-group col-md-2" id="DDlItemwise">
                @Html.Label("Employee", null, new { @class = "control-label" })

                @Html.DropDownList("Employee", (SelectList)ViewBag.driver, new { id = "ddldriver", @class = "form-control select2", tabindex = 8, onchange = "calltask()" })

            </div>
            <div class="form-group col-md-2" id="DDlItemwise">
                @Html.Label("Without Total Time", null, new { @class = "control-label" })

                @Html.CheckBox("chktotal");

            </div>
            <div class="box-footer col-md-12">
                <input type="submit" class="btn btn-info col-sm-offset-5" value="Submit" />
                <button type="button" class="btn btn-default" onclick="@("window.location.href='/Home/Index'");">Cancel</button>
            </div>

        }

    </div>
</div>



@if (Model != null)
{


    if (Model.et.Any())
    {
        double totalovertime = 0;
        double totalhourtotal = 0;
        string empname = "";
        decimal va = 0;
        long totalshow = ViewBag.withtotal;
        string negative = "-";
        <div class="box-body">
            <table class="table table-bordered table-hover" id="UserTable">
                <thead>
                    @{
                        var header = Model.et.Where(o => o.EmployeeName.Contains("PRASEEB")).ToList();
                        <tr>
                            <td><strong>Employee Name</strong></td>
                            @foreach (var c in header)
                            {
                                <td><strong>@c.entrydate.Value.Day</strong></td>
                            }
                            <td><strong>Total</strong></td>
                        </tr>
                    }

                </thead>
                <tbody>
                    

                    <tr>
                        <td><strong></strong></td>
                        @foreach (var c in header)
                        {
                            <td><strong></strong></td>
                        }
                        <td><strong></strong></td>

                        @foreach (var item in Model.et)
                        {
                            if (empname != item.EmployeeName)
                            {
                                if (empname != "")
                                {
                                    <td>
                                        @{
                                            var s = (int)TimeSpan.FromHours((double)totalovertime).TotalHours;
                                            var m = TimeSpan.FromHours((double)totalovertime).Minutes;
                                            var st = (int)TimeSpan.FromHours((double)totalhourtotal).TotalHours;
                                            var mt = TimeSpan.FromHours((double)totalhourtotal).Minutes;


                                        }@s : @Math.Abs(m) (@st : @mt )

                                    </td>

                                            }

                                            totalhourtotal = 0;
                                            totalovertime = 0;
                                @Html.Raw("</tr><tr>");
                                <td>@item.EmployeeName</td>
                                                empname = item.EmployeeName;
                                            }
                    <td>
                        @if (item.totalminute < 0)
                        {@negative;
                    }@TimeSpan.FromHours((double)item.totalminute).ToString("h\\.mm")@if (totalshow == 0)
                    {
                        @Html.Raw("(");

                        @TimeSpan.FromHours((double)item.totlhour).ToString("h\\:mm")
                        @Html.Raw(")");
                    }
                    </td>

                            totalhourtotal = totalhourtotal + (double)item.totlhour;
                                    totalovertime = totalovertime + (double)item.totalminute;
                                }

                        <td>
                            @{
                                    var ss = (int)TimeSpan.FromHours((double)totalovertime).TotalHours;
                                    var mm = TimeSpan.FromHours((double)totalovertime).Minutes;
                                    var stt = (int)TimeSpan.FromHours((double)totalhourtotal).TotalHours;
                                    var mtt = TimeSpan.FromHours((double)totalhourtotal).Minutes;


                                }
                            @ss : @Math.Abs(mm) (@stt : @mtt )
                        </td>
                    </tr>
                    </tbody>
            </table>
        </div>
    }
                        }
