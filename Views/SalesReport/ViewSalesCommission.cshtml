
@{
    ViewBag.Title = "View Commission Based on Sales";
    ViewBag.SubTitle = "Sales Report";
    ViewBag.Active = "Reports";
    string actData = "";

}
<div class="box box-default" id="SReport">
    <input type="hidden" id="cname" value="@ViewBag.CName" />
    <input type="hidden" id="caddress" value="@ViewBag.CAddress" />

    <input type="hidden" id="fromdate" value="@ViewBag.fromdate" />
    <input type="hidden" id="todate" value="@ViewBag.todate" />

    <div class="box-header with-border">
        <h3 class="box-title">View Sales Commission Report:<label> @ViewBag.seltext</label> </h3>
    </div>
    <div class="box-body">
        <div class="box-body">
            <table class="table table-bordered" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td>S/N</td>
                        <td>Invoice No</td>
                        <td>Date</td>
                        <td>Employee Name</td>
                        <td class="right">Invoice With Tax</td>
                        <td class="right">Invoice Without Tax</td>
                        <td class="right">Material Cost</td>
                        <td class="right">Profit</td>
                        <td class="right">Commission</td>
                        <td class="right">Commission Amount</td>
                    </tr>
                </thead>
                <tbody></tbody>
                <tfoot>
                    <tr>
                        <th>Total:</th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
@section Scripts {
    <script type="text/javascript">
        $(document).ready(function () {
            var oTable = $('#UserTable').DataTable({
                "processing": true, // for show progress bar
                "serverSide": true, // for process server side
                "filter": false, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
                // "bStateSave": true,
                responsive: true,
                "bLengthChange": false,
                "paging": true,
                "pageLength": 5000,
                "ordering": false,
                "ajax": {
                   "url": '/SalesReport/GetSalesCommission',

                    "data": {
                        ddlemp: getQueryString1('ddlemp'), fromdate: getParameterByName('from'), todate: getParameterByName('to')
                    },
                    "type": "POST",
                    "datatype": "json"
                },
                "order": [[0, "desc"]],
                "columns": [
                    {
                    "data": "SalesId", "name": "SalesId",
                        "render": function (data, type, row, meta) {
                            return meta.row + meta.settings._iDisplayStart + 1;
                        }
                    },

                    {
                        "name": "InvoiceNo", "data": function (data) {
                            var lin = "";
                            actData = '<a class=\"details\" href=\"/CreditSale/Edit/' + data.SalesId +'\" title=\"View Sales Entry\" target=\"_new\">'+ data.SalesId +'-Details<i class=\"fa fa-lg fa-search-plus\"></i></a>';

                            return actData;
                        }
                    },

                    { "data": "SEDate", "name": "SEDate", "render": function (data) { return convertToDate(data); } },
                    { "data": "employeename", "name": "employeename" },

                    //Invoice With Tax
                    { "data": "SEGrandTotal", "name": "SEGrandTotal", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },

                    //Invoice Without Tax
                    {
                        "name": "seitemtotal", "data": function (result) {

                            return (result.SEGrandTotal - result.SETaxAmount);

                        }, render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright"

                    },

                    //Material Cost
                    {
                        "name": "seitemtotal", "data": function (result) {

                            return (result.seitemtotal);

                        }, render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright"

                    },

                    //Profit
                    {
                        "name": "seitemtotal", "data": function (result) {

                            return ((result.SEGrandTotal - result.seitemtotal) - result.SETaxAmount);

                        }, render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright"
                    },
                    //Commission
                    { "data": "CommissionVal", "name": "CommissionVal", "sClass": "numberright" },
                    ////Commission Amount
                    { "data": "commision", "name": "commision", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                ],
                buttons: [//'copy', 'csv', 'excel', 'pdf', 'print'
                'colvis',
                {
                    extend: 'print',//
                    exportOptions: {
                        columns: ':visible'
                    },
                    title: "",
                    footer: true,
                    filename: function () {
                        return 'CommisionWise-Sale';
                    },
                    message: function()
                    {
                        var head = '<table class="tblcompact table table-bordered"><thead>' +
                        ' <tr><th class="text-center"><h3 style="margin-top: 0px;">' + $('#cname').val() + '</h3>' + $('#caddress').val() + '<h4>Commission Report</h4></th></tr>' +
                        ' <tr><th><span class="text-left">Item Brand : ' + $('#brand').val() + '</span><span class="text-right pull-right"> From :  ' + $('#fromdate').val() + ' To :' + $('#todate').val() + '</span></th></tr></thead><tbody><tr><td>';
                        return head;
                    },
                    customize: function (win) {
                        // $(win.document.body)
                        //.css('font-size', '10pt')
                        //.css('padding', '1px');
                        $(win.document.body).find('table, th,tr, td ')
                           // .css('border', 'inherit')
                            .css('font-size', '10pt')
                            .css('padding', '5px')
                            .addClass('compact');
                        $(win.document.body).append('</td></tr></tbody>')

                    }
                }, 'copy', 'csv', //'excel',
                {
                    extend: 'excel',//
                    title: "",
                    footer: true,
                    filename: function () {
                        return 'CommisionWise-Sale';
                    },
                    message: function () {
                        var head = '' + $('#cname').val() + '\n' +
                         '' + $('#caddress').val() + '\n' +
                         ' Commission Report \n' +
                         'Item Brand : ' + $('#brand').val() + '\n' +
                         'From :  ' + $('#fromdate').val() + ' To :' + $('#todate').val() + '';
                        return head;
                    },
                    pageSize: 'A4',
                    exportOptions: {
                        columns: ':visible'
                    },
                },
                {
                    extend: 'pdf',//
                    title: "",
                    footer: true,
                    filename: function () {
                        return 'CommisionWise-Sale';
                    },
                    message: function () {
                        var head = '' + $('#cname').val() + '\n' +
                         '' + $('#caddress').val() + '\n' +
                         ' Commission Report \n' +
                         'Item Brand : ' + $('#brand').val() + '\n' +
                         'From :  ' + $('#fromdate').val() + ' To :' + $('#todate').val() + '';
                        return head;
                    },
                    pageSize: 'A4',
                    exportOptions: {
                        columns: ':visible'
                    },
                    customize: function (doc) {
                        doc.pageMargins = [10, 10, 10, 10];
                        doc.defaultStyle.fontSize = 10;
                        doc.styles.tableHeader.fontSize = 10;
                        doc.styles.title.fontSize = 12;
                        // Header font and bg color
                        doc.styles.tableHeader.fillColor = '#d3d3d3';
                        doc.styles.tableHeader.color = 'black';
                        // Remove spaces around page title
                        doc.content[0].text = doc.content[0].text.trim();

                        //doc.content[1].table.widths = [
                        // '5%',
                        // '7%',
                        // '15%',
                        // '15%',
                        // '8%',
                        // '10%',
                        // '15%',
                        // '10%',
                        // '15%'
                        //]

                        doc.styles['td:nth-child(2)'] = {
                            width: '100%',
                            'max-width': '100%'
                        }

                        var objLayout = {};
                        // Horizontal line thickness
                        objLayout['hLineWidth'] = function (i) { return .5; };
                        // Vertikal line thickness
                        objLayout['vLineWidth'] = function (i) { return .5; };
                        //// Horizontal line color
                        //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                        //// Vertical line color
                        //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                        // Left padding of the cell
                        objLayout['paddingLeft'] = function (i) { return 4; };
                        // Right padding of the cell
                        objLayout['paddingRight'] = function (i) { return 4; };
                        // Inject the object in the document
                        doc.content[1].layout = objLayout;
                        // Footer font and bg color
                        doc.styles.tableFooter.fillColor = '#d3d3d3';
                        doc.styles.tableFooter.color = 'black';
                    }


                },

                ],

                sDom: "lBfr<'datatable-scroll't>ip",
                "lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                "footerCallback": function (row, data, start, end, display) {
                    var api = this.api(), data;

                    // Remove the formatting to get integer data for summation
                    var intVal = function (i) {
                        return typeof i === 'string' ?
                            i.replace(/[\$,]/g, '') * 1 :
                            typeof i === 'number' ?
                            i : 0;
                    };



                    // Total over all pages
                    total = api
                        .column(9)
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Total over this page
                    pageTotal = api
                        .column(9, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update footer
                    $(api.column(9).footer()).html(
                         pageTotal.toFixed(2)
                        //'$' + pageTotal + ' ( $' + total + ' total)'
                    );





                    var table = $('#UserTable').DataTable();
                    if (!table.data().any()) {
                        $('#UserTable tfoot').hide();
                    } else {
                        $('#UserTable tfoot').show();
                    }

                    var pono = $('#PoNo').val();
                    if (pono == 'inactive') {
                        var column1 = oTable.column(3);
                        column1.visible(false);
                    } else {
                        var column1 = oTable.column(3);
                        column1.visible(true);
                    }

                }
            });
            //var type = $('#brand').val();
            //if (type != 'All') {
            //    var column1 = oTable.column(1);
            //    column1.visible(false);
            //} else {
            //    var column1 = oTable.column(1);
            //    column1.visible(true);
            //}
        });
    </script>
}
