@section Scripts {
    @Scripts.Render("~/js/bootstrap-datepicker")
    <script type="text/javascript">
        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        })
        $(document).ready(function () {
            $("#ddlsource").select2({});
            $("#ddlsourcelead").select2({});
            //for hide the data table
            $('#StockReport').hide();
            //end
            $("#divpaymethod").hide();
            $('#HireTypeDiv').hide();
            //$("#SaleType").val(1);
            $('#SaleType option:contains(POS)').remove();

            $("#SaleType").prop('selectedIndex', 0);
            //customertype();
            //customertype();
            //for set default date
            $('#To').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });
            $('#From').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });

            var date = new Date();
            var today = new Date(date.getFullYear(), date.getMonth(), date.getDate());
            var priordate = new Date(new Date().setDate(today.getDate() - 0));
            $('#To').datepicker('setDate', today);
            $('#From').datepicker('setDate', priordate);
            //---

            //GetProjectWithAll();
            //GetTaskWithAll();

            ItemSearchable();
            // Material Center
            CallRepCustomer();
            CallRepEmployee();
            $("#ddlMC").select2({
                placeholder: 'Search Material Center by Name or Code',
                minimumInputLength: 0,
                ajax: {
                    url: "/MC/SearchMCUser",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term,
                            X: "",
                            page: params.page,

                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;

                        return {
                            results: data
                        };
                    },
                    cache: true
                },
            });
            $("#ddlSalesMan,#ddltechnician").select2({
                placeholder: 'Search by Name ',
                minimumInputLength: 0,
                ajax: {
                    url: "/Employee/SearchEmployee",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term || "",
                            page: params.page || 0,
                            x: "empty"

                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 0;

                        return {
                            results: data,
                            pagination: {
                                //more: (params.page * 10) < 50
                                more: true
                            }
                        };
                    },
                    cache: true
                },
            });

        });
    $('div').on('click', '.detailsclass', function (e) {
        e.preventDefault();
        var url = $(this).attr('href');
        modalshow(url, '#modal-create');
        //datepickerInit();
    });
        $('#UserTable').on('click', 'a.details', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        })
    $("#employeehourrate").on("change", function (){
        if ($(this).prop('checked') == true) {
            $("#perhourcost").prop("readonly", false);

        }
        else {
            $("#perhourcost").prop("readonly", true);
        }
    }
    );
        function searchData(data) {

            data.seno = $('#InvoiceNo').val();
            data.customer = $('#ddlCustomer').val();
            data.SalesExecutive = $('#ddlEmployee').val();
            data.SalesMan = $('#ddlSalesMan').val();
            data.fromdate = $('#From').val();
            data.todates = $('#To').val();
            data.type = $('#ddlType').val();
            data.ddMC = $('#ddlMC').val();
            data.satype = $('#SaleType').val();
            data.htype = $('#HireType').val();
            data.hfdate = $('#FromDate').val();
            data.htdate = $('#ToDate').val();
            data.project = $('#ddlProject').val();
            data.task = $('#ddlProTask').val();
            data.srchtxt = $('#Searchtext').val();
            data.perhourcost = $('#perhourcost').val();
            data.source = $('#ddlsource').val();
            data.sourcelead = $('#ddlsourcelead').val();
            data.cached = $('#cached').prop("checked");
            data.nostocktransfer = $("#nostocktransfer").prop("checked");
            data.employeehourrate = $('#employeehourrate').prop("checked");
            data.location = $("#ddllocations").val();
            data.technician = $("#ddltechnician").val();
            data.cusage = $("#ddlage").val();

        }

    function showdatatable() {

        var oTable = $('#UserTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": false, // for process server side
            "filter": false, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            // "bStateSave": true,
            "stateSave": true,
            "bDestroy": true,
            "bLengthChange": false,
            responsive: true,
            "paging": true,
            "pageLength": 5000,
            "ordering": true,
            "createdRow": function (row, data, dataIndex) {
                if ((data.itemprice.itemprice == 0 && (data.salesrtn + data.salesrtnnote)==0) || data.itemprice.itemprice>50000) {
                    $(row).addClass('redclass');
                }



            },
            "ajax": {
                "url": '/SalesReport/GetAllSaleprofit',
                "data": function (data) {
                    data = searchData(data);
                },
                "type": "POST",
                "datatype": "json",


            },
            "order": [[0, "desc"]],
            "columns": [
                {
                    "data": "SalesEntryId", "name": "SalesEntryId",
                    "render": function (data, type, row, meta) {
                        return meta.row + meta.settings._iDisplayStart + 1;
                    }
                },
                //{ "data": "BillNo", "name": "BillNo" },
                {
                    "name": "BillNo", "data": function (data) {
                              @{
                                  actData += "'<a href=\"/CreditSale/Edit/'+ data.SalesEntryId +'\" target=\"_new\">'+ data.BillNo +'</a>' ";
                              }
                        return @Html.Raw(actData);
                    }
                },
                { "data": "SEDate", "name": "SEDate", "render": function (data) { return convertToDate(data); } },

                {  "name": "Customer",  "data": function (data) {
                              @{
                                  var dataz = "";
                                  if (User.IsInRole("Dev") || User.IsInRole("View Customer"))
                                  {
                                      dataz = "'<a href=\"/Customer/Details/'+ data.CustomerID +'\"  target=\"_new\"  target=\"_new\">'+ data.Customer +'</a>' ";
                                  }
                                  else
                                  {
                                      dataz = "data.Customer";
                                  }
                              }
                              return @Html.Raw(dataz);
                      }
                  },
                //  { "data": "SEGrandTotal", "name": "SEGrandTotal", render: $.fn.dataTable.render.number(",", ".", 2) },
                { "data": "SEGrandTotal", "name": "SEGrandTotal", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },

                //{
                //    "name": "SEGrandTotal", "data": function (result) {

                //        return (result.SEGrandTotal - result.NewExpense);

                //    }, render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright"

                //},



                //{
                //    "name": "SEGrandTotal", "data": function (data) {
                //        var datas = "";
                //        $.each(data.PaymentExpense, function (i, item) {

                //            if (item.Expense != null) {

                //                datas += data.SEGrandTotal - item.Expense;

                //            }
                //            else {

                //                datas += data.SEGrandTotal;
                //            }
                //        });
                //        return datas;
                //    }
                //},

                { "data": "SEPaidAmount", "name": "SEPaidAmount", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                { "data": "SEBalanceAmount", "name": "SEBalanceAmount", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                { "data": "Credit", "name": "Credit", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },

                //{
                //    "name": "itemprice", "data": function (result) {

                //        return (result.SEGrandTotal - result.SETaxAmount);

                //    }, render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright"

                //},
                {
                    "name": "itemprice", "data": function (result) {

                        return (result.itemprice.itemprice);

                    }, render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright"

                },

                // { "data": "NewExpense", "name": "NewExpense", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },

                {
                    "name": "NewExpense", "data": function (result) {
                        var viewsales = "";
                        if (result.discountt > 0 || result.roundoffmin > 0 || result.roundoffplus > 0) {
                            viewsales = '<br><a   class="details" href="/creditsale/details/' + result.SalesEntryId + '">View</a>';
                        }
                        if (result.salesrtn > 0) {
                            return (result.NewExpense + "<br>" + result.NewExpenselink + viewsales);
                        }
                        else {
                            return (result.NewExpense + result.discountt + "<br>" + result.NewExpenselink + viewsales);
                        }

                    }

                },



    {
        "name": "empcoste", "data": function (result) {

            return (result.empcoste);

                    }, render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright"

                },
                {
                    "name": "salesrtn", "data": function (result) {

                        return (result.salesrtn + result.salesrtnnote);

                    }, render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright"

                },
    {
                    "name": "itemprice", "data": function (result) {



            var profit = 0;
            if (result.salesrtn > 0) {
                if (result.SaleType == 1) {
                    profit = (result.Credit) - (result.itemprice.itemprice) - (result.NewExpense) - (result.empcoste) - (result.salesrtn) - (result.salesrtnnote);
                }
                else {
                    profit = ((result.SEGrandTotal - result.itemprice.itemprice) - result.SETaxAmount) - (result.NewExpense ) - (result.empcoste) - (result.salesrtn) - (result.salesrtnnote);
                }
            }
            else {
                if (result.SaleType == 1) {
                    profit = (result.Credit) - (result.itemprice.itemprice) - (result.NewExpense + result.discountt + result.roundoffmin - result.roundoffplus) - (result.empcoste) - (result.salesrtn) - (result.salesrtnnote);
