@{

    ViewBag.Title = "Search Sales Entry Comparison";
    ViewBag.SubTitle = "Sales Report Comparison";
    ViewBag.Active = "Reports Comparison";
    string actData = "";
    string actData2 = "";
    string actData3 = "";
    string actData4 = "";
    string posfun = "";

}
@*<style>
        #ddlType, #InvoiceNo{
            margin-bottom:-4px!important;
        }
    </style>*@
<style>
    .datepicker {
        border-radius: 0px !important;
        /*height:30px!important;*/
    }

    .input-sm {
        height: 30px !important;
        border-radius: 0px !important;
    }

    .fa-calendar {
        margin-left: -5px !important;
    }
</style>
<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">Search Sales Entry</h3>
    </div>

    <div class="box-body">
        <form id="search-form">
            @using (Html.BeginForm("Comparison", "SalesReport", FormMethod.Post, new { id = "popupForm", target = "_new" }))
            {


                if (@ViewBag.EnableMCcheck == 0)
                {
                    <div class="form-group col-md-2">
                        @Html.Label("Material Center From", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlMCfrom", (SelectList)ViewBag.MC, new { @class = "form-control input-sm", @requied = "required" })
                    </div>
                    <div class="form-group col-md-2">
                        @Html.Label("Material Center To", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlMCto", (SelectList)ViewBag.MC, new { @class = "form-control input-sm", @requied = "required" })
                    </div>
                }
                if (@ViewBag.ProjChk == 0)
                {

                }
                @*<div class="form-group col-md-4">
                        @Html.Label("Branch", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlBranch", (SelectList)ViewBag.Branch, new { @class = "form-control input-sm select2" })
                    </div>*@

                <div class="form-group col-md-2" id="DDlItemwise">
                    @Html.Label("Item Name/Code", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlItem", (SelectList)ViewBag.Item, new { @class = "form-control input-sm select2" })
                </div>
                <div class="form-group col-md-2" id="creditsale">
                    @Html.Label("Item Category", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlItemCategory", (SelectList)ViewBag.Category, new { @class = "form-control input-sm select2" })
                </div>
                <div class="form-group col-md-2" id="creditsale">
                    @Html.Label("Item Brand", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlItemBrand", (SelectList)ViewBag.Brand, new { @class = "form-control input-sm select2" })
                </div>
                <div class="form-group col-md-2">
                    @Html.Label("Search", null, new { @class = "control-label" })
                    @Html.TextBox("Searchtext", "", new { @class = "form-control input-sm" })
                </div>
                @*<div class="form-group col-md-2" id="execreditsale">
                        @Html.Label("Tax Type", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlTaxType", (SelectList)ViewBag.TaxType, new { @class = "form-control input-sm select2" })
                    </div>*@


                <div class="box-footer col-md-12">
                    <input type="submit" class="btn btn-info col-sm-offset-5" value="Submit" />
                    <button type="button" class="btn btn-default" onclick="@("window.location.href='/Home/Index'");">Cancel</button>
                </div>
            }
        </form>
    </div>
</div>
<div class="box box-default" id="StockReport">
    <div class="box-header with-border">
        <h3 class="box-title">View Item Comparison  Report</h3>
    </div>
    <div class="box-body">
        <input type="hidden" id="cname" value="@ViewBag.CName" />
        <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
        <input type="hidden" id="invoiceno" value="@ViewBag.InvoiceNo" />
        <input type="hidden" id="fromdate" value="@ViewBag.fromdate" />
        <input type="hidden" id="todate" value="@ViewBag.todate" />
        <input type="hidden" id="matcenter" value="@ViewBag.EnableMCcheck" />
        <input type="hidden" id="Scaffold" value="@ViewBag.BusinessType" />
        <div class="box-body">
            <table class="display table table-bordered" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="2">S/N</td>
                        <td data-priority="1">Item Code</td>
                        <td data-priority="1">Item Name</td>
                        <td data-priority="2">Mc From</td>
                        <td data-priority="2">Mc To</td>

                    </tr>
                </thead>
                <tbody></tbody>

            </table>
        </div>
    </div>
</div>
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/bootstrap-timepicker")
}
@section Scripts {
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/num2words")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/bootstrap-timepicker")
    <script src="~/Content/js/salesinvoice2.js"></script>
    <script type="text/javascript">

        $(document).ready(function () {
            /*datatable still hided before clicking the submit button*/

            $("#StockReport").hide()
            /*end*/

            //customertype();
            //customertype();
            //for set default date

            //GetProjectWithAll();
            //GetTaskWithAll();
            ItemSearchable();
            // Material Center

            $("#ddlMCfrom").select2({
                placeholder: 'Search Material Center by Name or Code',
                minimumInputLength: 0,
                ajax: {
                    url: "/MC/SearchMC",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term,
                            X: "",
                            page: params.page,

                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;

                        return {
                            results: data
                        };
                    },
                    cache: true
                },
            });
            $("#ddlMCto").select2({
                placeholder: 'Search Material Center by Name or Code',
                minimumInputLength: 0,
                ajax: {
                    url: "/MC/SearchMC",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term,
                            X: "",
                            page: params.page,

                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;

                        return {
                            results: data
                        };
                    },
                    cache: true
                },
            });
            $("#ddlItemBrand").select2({
                placeholder: 'Search Item Brand',
                minimumInputLength: 0,
                ajax: {
                    url: "/ItemBrand/SearchBrand",
                    dataType: 'json',
                    type: "POST",
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term,
                            page: params.page,
                            x: "all"
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;

                        return {
                            results: data
                        };
                    },
                    cache: true
                },
            });
            $("#ddlItemCategory").select2({
                placeholder: 'Search Item Category',
                minimumInputLength: 0,
                ajax: {
                    url: "/ItemCategory/SearchCategory",
                    dataType: 'json',
                    type: "POST",
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term,
                            page: params.page,
                            x: "All"
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;

                        return {
                            results: data
                        };
                    },
                    cache: true
                },
            });
        });
        function searchData(data) {


            data.ddMCfrom = $('#ddlMCfrom').val();
            data.ddMCto = $('#ddlMCto').val();

            data.item = $('#ddlItem').val();
            data.category = $('#ddlItemCategory').val();
            data.brand = $('#ddlItemBrand').val();
            data.srchtxt = $('#Searchtext').val();
            //data.TaxType = $('#ddlTaxType').val();

        }

        function showdatatable() {
            oTable = $('#UserTable').DataTable({
                "processing": true, // for show progress bar,
                "destroy": true,
                "language": {
                    'loadingRecords': '&nbsp;',
                    'processing': '<i class="fa fa-spinner fa-spin fa-3x fa-fw"></i><span class="sr-only">Loading..n.</span>'
                },
                "serverSide": false, // for process server side
                "filter": true, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
                // "bStateSave": true,
                //"deferLoading": 0, // disable default ajax loading
                "bLengthChange": false,
                "paging": true,
                "responsive": true,
                "pageLength": 5000,
                "timeout": 300000,
                "ordering": true,
                "columnDefs": [{
                    "targets": [4],
                    "sClass": "numberright"
                }],
                "ajax": {
                    "url": '/SalesReport/GetComparison',
                    /* calling the function for capturing the datas*/
                    "data": function (data) {
                        data = searchData(data);
                    },
                    /*end*/
                    "type": "POST",
                    "datatype": "json"

                },
                "order": [[0, "desc"]],
                "columns": [
                    {
                        "data": "ItemID", "name": "ItemID",
                        "render": function (data, type, row, meta) {
                            return meta.row + meta.settings._iDisplayStart + 1;
                        }
                    },



                    { "data": "ItemCode", "name": "ItemCode" },
                    { "data": "ItemName", "name": "ItemName" },
                    { "data": "stockfromstock", "name": "stockfromstock" },
                    { "data": "stocktostock", "name": "stocktostock" },
                ],
                buttons: [//'copy', 'csv', 'excel', 'pdf', 'print'
                    'colvis',
                    {
                        extend: 'print',//
                        title: "",
                        footer: true,
                        filename: function () {
                            return 'Item Comparison -Report';
                        },
                        columnDefs: [
                            { width: 400, targets: 2 }
                        ],
                        exportOptions: {
                            columns: ':visible'
                        },
                        message: function () {
                            var head = '<table class="tblcompact table table-bordered"><thead>' +
                                ' <tr><th class="text-center"><h3 style="margin-top: 0px;">' + $('#cname').val() + '</h3>' + $('#caddress').val() + '<h4>Item Comparison Report</h4></th></tr>';

                            return head;
                        },
                        customize: function (win) {
                            // $(win.document.body)
                            //.css('font-size', '10pt')
                            //.css('padding', '1px');
                            $(win.document.body).find('table.tblcompact tbody td').css('padding', '0px');
                            $(win.document.body).find('.dataTable,.dataTable th,.dataTable tr,table.tblcompact tbody td .dataTable td')
                                .css('font-size', '10pt')
                                .css('padding', '5px')
                                .addClass('compact');
                            $(win.document.body).find('.dataTable tr th:nth-child(3)')
                                .css('min-width', '80px');
                            //$(win.document.body).find('.tblcompact tbody td:nth- child(2)')
                            //    .css('padding', '0px');
                            $(win.document.body).append('</td></tr></tbody>')

                        }
                    }, 'copy', 'csv', //'excel',
                    //Excel
                    {
                        extend: 'excel',//
                        title: "",
                        footer: true,
                        filename: function () {
                            return 'Comparison-Report';
                        },
                        message: function () {
                            var head = '' + $('#cname').val() + '\n' +
                                '' + $('#caddress').val() + '\n' +
                                ' Sales Report \n';

                            return head;
                        },
                        pageSize: 'A4',
                        exportOptions: {
                            columns: ':visible'
                        },
                    },
                    {
                        extend: 'pdf',//
                        title: "",
                        footer: true,
                        filename: function () {
                            return 'Comparison-Report';
                        },
                        message: function () {
                            var head = '' + $('#cname').val() + '\n' +
                                '' + $('#caddress').val() + '\n' +
                                ' Sales Report \n';
                            return head;
                        },
                        pageSize: 'A4',
                        exportOptions: {
                            columns: ':visible'
                        },
                        customize: function (doc) {
                            doc.pageMargins = [10, 10, 10, 10];
                            doc.defaultStyle.fontSize = 10;
                            doc.styles.tableHeader.fontSize = 10;
                            doc.styles.title.fontSize = 12;
                            // Header font and bg color
                            doc.styles.tableHeader.fillColor = '#d3d3d3';
                            doc.styles.tableHeader.color = 'black';
                            // Remove spaces around page title
                            doc.content[0].text = doc.content[0].text.trim();


                            doc.styles['td:nth-child(2)'] = {
                                width: '100%',
                                'max-width': '100%'
                            }

                            //doc.content[1].table.widths = Array(doc.content[1].table.body[0].length + 1).join('*').split('');

                            //doc.content[1].table.widths = [
                            //'5%',
                            //'7%',
                            //'12%',
                            //'10%',
                            //'10%',
                            //'10%',
                            //'12%',
                            //'12%',
                            //'12%',
                            //'10%'
                            //]

                            //doc['header'] = (function () {
                            //    return {
                            //        columns: [
                            //			{
                            //			    alignment: 'left',
                            //			    italics: true,
                            //			    text: 'dataTables',
                            //			    fontSize: 18,
                            //			    margin: [10, 0]
                            //			},
                            //			{
                            //			    alignment: 'right',
                            //			    fontSize: 14,
                            //			    text: 'Custom PDF export with dataTables'
                            //			}
                            //        ],
                            //        margin: 20
                            //    }
                            //});
                            var objLayout = {};
                            // Horizontal line thickness
                            objLayout['hLineWidth'] = function (i) { return .5; };
                            // Vertikal line thickness
                            objLayout['vLineWidth'] = function (i) { return .5; };
                            //// Horizontal line color
                            //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                            //// Vertical line color
                            //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                            // Left padding of the cell
                            objLayout['paddingLeft'] = function (i) { return 4; };
                            // Right padding of the cell
                            objLayout['paddingRight'] = function (i) { return 4; };
                            // Inject the object in the document
                            doc.content[1].layout = objLayout;
                            // Footer font and bg color
                            doc.styles.tableFooter.fillColor = '#d3d3d3';
                            doc.styles.tableFooter.color = 'black';

                        }
                    }

                ],

                sDom: "lBfr<'datatable-scroll't>ip",
                "lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],

            });
            //for showing the datatable when click the submit button

            $('#search-form').on('submit', function (e) {

                e.preventDefault();
                oTable.draw();
                $('#SReport').show();
                $('#UserTable').show();



            });

            $('#UserTable tbody').on('click', 'tr', function () {
                if ($(this).hasClass('selected')) {
                    $(this).removeClass('selected');
                }
                else {
                    oTable.$('tr.selected').removeClass('selected');
                    $(this).addClass('selected');
                    $(this).addClass('dataTables_row');
                }
            });
        }

        var flag = 0;
        $('#search-form').on('submit', function (e) {
            e.preventDefault();
            if (flag == 0) {
                showdatatable();
                flag = 0;
            }
            else
                oTable.draw();

            $('#StockReport').show();
        });


        function reload_table() {
            oTable.clear().draw();
            oTable.ajax.reload(null, false);
        }

    </script>
}