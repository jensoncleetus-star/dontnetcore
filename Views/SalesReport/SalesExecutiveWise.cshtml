@{
    ViewBag.Title = "Search Sales Executive Wise Sale";
    ViewBag.SubTitle = "Sales Report";
    ViewBag.Active = "Reports";

}
@*for bottom scrollbar*@
<style type="text/css">
    .wrapper1, .wrapper2 {
        overflow-x: scroll;
        overflow-y: hidden;
    }

    .scroll {
        width: 1400px;
    }

    #UserTable {
        width: 10000px;
    }
</style>
@*end*@

<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">All Sales List</h3>
    </div>
    <div class="box-body">
        <form id="search-form">
            @using (Html.BeginForm("SalesExecutiveWise", "SalesReport", FormMethod.Post, new { id = "popupForm" }))
            {
                <div class="form-group col-md-4" id="creditsale" style="display:none">
                    @Html.Label("Sales Executive", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlEmployee", (SelectList)ViewBag.SalesExec, new { @class = "form-control input-sm select2" })
                </div>

                if (@ViewBag.BusinessType == "Scaffold")
                {
                    <div class="form-group col-sm-4" style="display:none">
                        @Html.Label("Type", null, new { @class = "control-label" })
                        @Html.DropDownList("SaleType", (SelectList)ViewBag.Type, new { @class = "form-control input-sm" })
                    </div>
                }
                if (@ViewBag.EnableMCcheck == 0)
                {
                    <div class="form-group col-md-4" style="display:none">
                        @Html.Label("Material Center", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlMC", (SelectList)ViewBag.MC, new { @class = "form-control input-sm" })
                    </div>
                }
                <div class="form-group col-md-4">
                    @Html.Label("From", null, new { @class = "control-label" })
                    <div class="input-group date">
                        @Html.TextBox("From", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                        <div class="input-group-addon">
                            <i class="fa fa-calendar"></i>
                        </div>
                    </div>
                </div>
                <div class="form-group col-md-4">
                    @Html.Label("To", null, new { @class = "control-label" })
                    <div class="input-group date">
                        @Html.TextBox("To", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                        <div class="input-group-addon">
                            <i class="fa fa-calendar"></i>
                        </div>
                    </div>
                </div>

                <div class="box-footer col-md-12">
                    <input type="submit" class="btn btn-info col-sm-offset-5" value="Submit" />
                    <button type="button" class="btn btn-default" onclick="@("window.location.href='/Home/Index'");">Cancel</button>
                </div>
            }
        </form>
    </div>
</div>
  @*starting datatable*@
<div class="box box-default" id="SReport">
    <div class="box-header with-border">
        <h3 class="box-title">All Sales Listh>
    </div>
    <div class="box-body">
        <div class="box-body">
            <input type="hidden" id="cname" value="@ViewBag.CName" />
            <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
            <input type="hidden" id="salesexec" value="@ViewBag.SalesExec" />
            <input type="hidden" id="fromdate" value="@ViewBag.fromdate" />
            <input type="hidden" id="todate" value="@ViewBag.todate" />
            <input type="hidden" id="Salety" value="@ViewBag.Salety" />
            <div class="scroller">
            </div>
            @*</div>*@
            <div class="wrapper2">
                <div class="scroll">
                    <table class="display table table-bordered" id="UserTable">
                        <thead>
                            <tr class="bg-gray">
                                <td>S/N</td>
                                <td>Sales </td>
                                <td >Sale Amt.</td>
                                
                            </tr>
                        </thead>
                        <tbody></tbody>
                        <tfoot>
                            <tr>
                                <th>Total:</th>
                                <th></th>
                                <th></th>
                                </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
 </div>
    </div>
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
}
@section Scripts {
    @Scripts.Render("~/js/bootstrap-datepicker")
    <script type="text/javascript">
        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        })

        $(document).ready(function () {
            //hide the datatable before pressing the submit button

            $('#SReport').hide();
            //for set default date
            $('#To').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });
            $('#From').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });

            var date = new Date();
            var today = new Date(date.getFullYear(), date.getMonth(), date.getDate());
            var priordate = new Date(new Date().setDate(today.getDate() - 30));
            $('#To').datepicker('setDate', today);
            $('#From').datepicker('setDate', priordate);
            //---
            CallRepEmployee();
            CallRepMCUser();
        });
        //for displaing the datas
        function searchData(data) {
            data.salesexec = $('#ddlEmployee').val();
            data.fromdate = $('#From').val();
            data.todate = $('#To').val();
            data.Salety = $('#SaleType').val();
            data.ddmc = $('#ddlMC').val();

        }
        //for scrolling the datas
        $(function () {
            
            $(".wrapper2").scroll(function () {

                $(".scroller")
                    .scroll($(".wrapper2").scroll());
            });
        });

        //datatable function
        jQuery(function ($) {
            //var oTable = $('#UserTable').DataTable({
            //    "processing": true, // for show progress bar
            //    "serverSide": true, // for process server side
            //    "filter": false, // this is for disable filter (search box)
            //    "orderMulti": false, // for disable multiple column at once
            //    // "bStateSave": true,
            //    "bLengthChange": false,
            //    "paging": false,
            //    "deferLoading": 0,

            //    //"autoWidth": false,
            //    //"columnDefs": [
            //    //{ "width": "70px", "targets": 4 }],
            //    "ajax": {
            //        "url": '/SalesReport/GetSalesExeWise',
            //        "data": { salesexec: getQueryString('salesexec'), fromdate: getParameterByName('from'), todate: getParameterByName('to') },
            //        "type": "POST",
            //        "datatype": "json"

            //    },
            var oTable = $('#UserTable').DataTable({
                "processing": true, // for show progress bar
                "serverSide": true, // for process server side
                "filter": false, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
                // "bStateSave": true,
                "bLengthChange": false,
                responsive: true,
                "paging": true,
                "pageLength": 5000,
                //"ordering": false,
                "ajax": {
                    "url": '/SalesReport/GetSalessummary',
                    //for capturing the datas
                    "data": function (data) {
                        data = searchData(data);
                    },
                    "type": "POST",
                    "datatype": "json"

                },


//                "order": [[0, "desc"]],
                "columns": [
                    {
                        "data": "empname", "name": "empname",
                        "render": function (data, type, row, meta) {
                            return meta.row + meta.settings._iDisplayStart + 1;
                        }
                    },
                    { "data": "empname", "name": "empname" },
                    { "data": "salesamount", "name": "salesamount" },
                   ],
                buttons: [//'copy', 'csv', 'excel', 'pdf', 'print'
                    {
                        extend: 'print',//
                        title: "",
                        footer: true,
                        filename: function () {
                            return 'Sales ExecutiveWise-Sale';
                        },
                        message: function () {
                            var head = '<table class="tblcompact table table-bordered"><thead>' +
                                ' <tr><th class="text-center"><h3 style="margin-top: 0px;">' + $('#cname').val() + '</h3>' + $('#caddress').val() + '<h4>Sales Report (Sales Executive Wise)</h4></th></tr>' +
                                ' <tr><th><span class="text-left">Sales Executive : ' + $('#salesexec').val() + '</span><span class="text-right pull-right"> From :  ' + $('#fromdate').val() + ' To :' + $('#todate').val() + '</span></th></tr></thead><tbody><tr><td>';
                            return head;
                        },
                        customize: function (win) {
                            // $(win.document.body)
                            //.css('font-size', '10pt')
                            //.css('padding', '1px');
                            $(win.document.body).find('table, th,tr, td ')
                                // .css('border', 'inherit')
                                .css('font-size', '10pt')
                                .css('padding', '5px')
                                .addClass('compact');
                            $(win.document.body).append('</td></tr></tbody>')

                        }
                    }, 'copy', 'csv', //'excel',
                    {
                        extend: 'excel',//
                        title: "",
                        footer: true,
                        filename: function () {
                            return 'Sales ExecutiveWise-Sale';
                        },
                        message: function () {
                            var head = '' + $('#cname').val() + '\n' +
                                '' + $('#caddress').val() + '\n' +
                                ' Sales Report (Sales Executive Wise) \n' +
                                'Sales Executive : ' + $('#salesexec').val() + '\n' +
                                'From :  ' + $('#fromdate').val() + ' To :' + $('#todate').val() + '';
                            return head;
                        },
                        pageSize: 'A4',
                        exportOptions: {
                            columns: [0, 1, 2, 3, 4, 5, 6]
                        },
                    },
                    {
                        extend: 'pdf',//
                        title: "",
                        footer: true,
                        filename: function () {
                            return 'Sales ExecutiveWise-Sale';
                        },
                        message: function () {
                            var head = '' + $('#cname').val() + '\n' +
                                '' + $('#caddress').val() + '\n' +
                                ' Sales Report (Sales Executive Wise) \n' +
                                'Sales Executive : ' + $('#salesexec').val() + '\n' +
                                'From :  ' + $('#fromdate').val() + ' To :' + $('#todate').val() + '';
                            return head;
                        },
                        pageSize: 'A4',
                        exportOptions: {
                            columns: [0, 1, 2, 3, 4, 5, 6]
                        },
                        customize: function (doc) {
                            doc.pageMargins = [10, 10, 10, 10];
                            doc.defaultStyle.fontSize = 10;
                            doc.styles.tableHeader.fontSize = 10;
                            doc.styles.title.fontSize = 12;
                            // Header font and bg color
                            doc.styles.tableHeader.fillColor = '#d3d3d3';
                            doc.styles.tableHeader.color = 'black';
                            // Remove spaces around page title
                            doc.content[0].text = doc.content[0].text.trim();

                            doc.content[1].table.widths = [
                                '10%',
                                '15%',
                                '15%',
                                '15%',
                                '15%',
                                '15%',
                                '15%'
                            ]

                            var objLayout = {};
                            // Horizontal line thickness
                            objLayout['hLineWidth'] = function (i) { return .5; };
                            // Vertikal line thickness
                            objLayout['vLineWidth'] = function (i) { return .5; };
                            //// Horizontal line color
                            //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                            //// Vertical line color
                            //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                            // Left padding of the cell
                            objLayout['paddingLeft'] = function (i) { return 4; };
                            // Right padding of the cell
                            objLayout['paddingRight'] = function (i) { return 4; };
                            // Inject the object in the document
                            doc.content[1].layout = objLayout;

                            // Footer font and bg color
                            doc.styles.tableFooter.fillColor = '#d3d3d3';
                            doc.styles.tableFooter.color = 'black';
                        }


                    },

                ],

                sDom: "lBfr<'datatable-scroll't>ip",
                "lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                "footerCallback": function (row, data, start, end, display) {
                    var api = this.api(), data;

                    // Remove the formatting to get integer data for summation
                    var intVal = function (i) {
                        return typeof i === 'string' ?
                            i.replace(/[\$,]/g, '') * 1 :
                            typeof i === 'number' ?
                                i : 0;
                    };


                }
            });

            //for showing the datatable when click the submit button

            $('#search-form').on('submit', function (e) {

                e.preventDefault();
                oTable.draw();
                $('#SReport').show();
            });

            $('#UserTable tbody').on('click', 'tr', function () {
                if ($(this).hasClass('selected')) {
                    $(this).removeClass('selected');
                }
                else {
                    oTable.$('tr.selected').removeClass('selected');
                    $(this).addClass('selected');
                    $(this).addClass('dataTables_row');
                }
            });
        });



    </script>
}








