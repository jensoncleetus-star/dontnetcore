<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Change Status</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("updateworkstatus", "SalesReport", FormMethod.Post, new { role = "form", id = "createform" }))
    {
        <script type="text/javascript">
            $('form#popupForm').removeData("validator");
            $('form#popupForm').removeData("unobtrusiveValidation");
        </script>
        <div class="row">
            <div class="form-group col-md-12">
                @Html.Label("Work Status", null, new { @class = "control-label" })
                @Html.DropDownList("WorkStatus", (SelectList)ViewBag.workstatuss, new { id = "ddlworkstatus", @class = "form-control" })
            </div>
            <input type="hidden" name="salesid" value="@ViewBag.salesids" />
            <input type="hidden" name="empid" value="@ViewBag.impids" />

        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" class="btn btn-info col-sm-offset-4" value="Update" />
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>



