
@model QuickSoft.ViewModel.StockJournalViewModel
@{
    ViewBag.Title = "Edit";
    ViewBag.SubTitle = "Edit StockJournal";
    ViewBag.Active = "Transactions";
}
<div class="box box-info">
    @using (Html.BeginForm("Edit", "StockJournal", FormMethod.Post, new { id = "sjeditForm", role = "form", enctype = "multipart/form-data" }))
    {
        <div class="box-header with-border">
            <h3 class="box-title">Edit StockJournal <label id="AlertEditable" class="text-red"></label></h3>
            <div class="pull-right">
                @if (@ViewBag.preEntry != 0)
                {
                    if (User.IsInRole("Dev") || User.IsInRole("Edit StockJournal"))
                    {
                        <a class="btn bg-black no-border" href="/StockJournal/Edit/@ViewBag.preEntry">
                            <i class="fa fa-step-backward"></i>
                        </a>
                    }
                }
                @if (@ViewBag.nxtEntry != 0)
                {
                    if (User.IsInRole("Dev") || User.IsInRole("Edit StockJournal"))
                    {
                        <a class="btn bg-black no-border" href="/StockJournal/Edit/@ViewBag.nxtEntry">
                            <i class="fa fa-step-forward"></i>
                        </a>
                    }
                }
                else
                {
                    if (User.IsInRole("Dev") || User.IsInRole("StockJournal Entry"))
                    {
                        <a class="btn bg-black no-border" href="/StockJournal/Create">
                            <i class="fa fa-step-forward"></i>
                        </a>
                    }
                }
                @if (User.IsInRole("Dev") || User.IsInRole("StockJournal List"))
                {
                    <a class="btn btn-success no-border" href="/StockJournal/Index">
                        <i class="fa fa-fw fa-history"></i> List
                    </a>
                }
            </div>
        </div>
        <div class="box-body">
            <div class="row">

                @Html.AntiForgeryToken()
                @Html.ValidationSummary("", new { @class = "alert alert-danger AlertDiv" })
                <input type="hidden" id="SelApprovedBy" />
                <input type="hidden" id="VoucherType" value="StockJournal" />
                <div class="col-md-12">
                    <div class="form-group col-sm-2">
                        @Html.LabelFor(m => m.Voucher, new { @class = "control-label" }) *
                        @Html.TextBoxFor(m => m.Voucher, new { @class = "form-control input-sm", autofocus = "autofocus", @required = "required" })
                    </div>
                    <div class="col-sm-2 form-group">
                        @Html.Label("Date", null, htmlAttributes: new { @class = "control-label" })*
                        <div class="input-group date">
                            <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                            @Html.TextBoxFor(m => m.SJDate, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @required = "required" })
                        </div>
                    </div>
                    <div class="col-sm-2 form-group">
                        @Html.Label("Material center from", null, new { @class = "control-label" }) *
                        @if (User.IsInRole("Dev") || User.IsInRole("Create MC"))
                        {
                            <div class="input-group input-group-sm">
                                @Html.DropDownListFor(m => m.MCFrom, (SelectList)ViewBag.MC, "", new { id = "ddlMCFrom", @class = "form-control select2", @onchange = "checkbranch()", @required = "required" })
                                <span class="input-group-btn">
                                    <button type="button" href="/MC/Create" class="modal-create btn btn-success btn-flat"><i class="fa fa-1x fa-plus-circle"></i></button>
                                </span>
                            </div>
                        }
                        else
                        {
                            @Html.DropDownListFor(m => m.MCFrom, (SelectList)ViewBag.MC, "", new { id = "ddlMCFrom", @class = "form-control select2", @required = "required" })
                        }
                    </div>
                    <div class="col-sm-2 form-group">
                        @Html.Label("Material center to", null, new { @class = "control-label" }) *
                        @if (User.IsInRole("Dev") || User.IsInRole("Create Customer"))
                        {
                            <div class="input-group input-group-sm">
                                @Html.DropDownListFor(m => m.MCTo, (SelectList)ViewBag.MC, "", new { id = "ddlMCTo", @class = "form-control select2", @onchange = "checkbranch()", @required = "required" })
                                <span class="input-group-btn">
                                    <button type="button" href="/MC/Create" class="modal-create btn btn-success btn-flat"><i class="fa fa-1x fa-plus-circle"></i></button>
                                </span>
                            </div>
                        }
                        else
                        {
                            @Html.DropDownListFor(m => m.MCTo, (SelectList)ViewBag.MC, "", new { id = "ddlMCTo", @class = "form-control select2", @required = "required" })
                        }
                    </div>
                    <div class="col-sm-2 form-group">
                        @Html.Label("Employee", null, new { @class = "control-label" })
                        @**@@if (User.IsInRole("Dev") || User.IsInRole("Create Sales Executive"))
                        {
                            <div class="input-group input-group-sm">
                                @Html.DropDownListFor(m => m.Employee, (SelectList)ViewBag.Emp, "", new { id = "ddlEmployee", @class = "form-control select2", @required = "required" })
                                <span class="input-group-btn">
                                    <button type="button" href="/SalesExecutive/AddSalesExecutive" class="modal-edit btn btn-success btn-flat"><i class="fa fa-1x fa-plus-circle"></i></button>
                                </span>
                            </div>
                        }
                        else
                        {
                            @Html.DropDownListFor(m => m.Employee, (SelectList)ViewBag.Emp, "", new { id = "ddlEmployee", @class = "form-control select2", @required = "required" })
                        }
                    </div>
                    <div class="col-sm-2 form-group ">
                        @Html.LabelFor(m => m.Description, new { @class = "control-label" })
                        @Html.TextAreaFor(model => model.Description, new { @class = "form-control", @placeholder = "Enter Descriptions here", @rows = 2 })
                    </div>
                    @if (@ViewBag.MLASJour == 0)
                {
                        <div class="form-group col-sm-2">
                            @Html.Label("Approved By", null, new { @class = "control-label" })
                            @Html.DropDownList("ddlApprovedBy", (MultiSelectList)ViewBag.ApproveBy, new { @class = "form-control select2", @name = "ddlApprovedBy[]", @multiple = "multiple" })

                        </div>
                    }
                </div>
            </div>
            <div class="row">
                @if (Model.FieldMap.Count > 0)
                {
                    for (int i = 0; i < Model.FieldMap.Count; i++)
                    {
                        var fmap = "";
                        if (Model.FieldMap[i].Field == "Ref1")
                        {
                            fmap = Model.Ref1;
                        }
                        if (Model.FieldMap[i].Field == "Ref2")
                        {
                            fmap = Model.Ref2;
                        }
                        if (Model.FieldMap[i].Field == "Ref3")
                        {
                            fmap = Model.Ref3;
                        }
                        if (Model.FieldMap[i].Field == "Ref4")
                        {
                            fmap = Model.Ref4;
                        }
                        if (Model.FieldMap[i].Field == "Ref5")
                        {
                            fmap = Model.Ref5;
                        }

                        <div class="form-group col-sm-2">
                            <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName</label>
                            <input class="form-control input-sm" id="@Model.FieldMap[i].Field" name="@Model.FieldMap[i].Field" type="text" value="@fmap">
                        </div>
                    }
                }
            </div>
            <div>
               
                <h4 class="box-title">Generated Materials</h4>
                <div class="col-md-12">
                    <div class="table-responsive bomtable">
                        <table class="table table-bordered table-hover" id="generateditem">
                            <thead>
                                <tr>
                                    <th class="text-center">S/N</th>
                                    <th class="text-center">Item<i class="text-danger">*</i></th>
                                    <th class="text-center">Unit</th>
                                    <th class="text-center">Qty</th>
                                    <th class="text-center">Price</th>
                                    <th class="text-center">Amount</th>
                                    <th class="text-center">Action</th>
                                </tr>
                            </thead>
                            <tbody id="Generated"></tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="2">
                                        Total
                                    </td>
                                    <td></td>
                                    <td><label id="GeneratedtotalQty"></label></td>
                                    <td><input type="hidden" value="" class="ItemCount" name="ItemCount" id="ItemCount"></td>
                                    <td class="text-right">
                                        <label id="GeneratedtotalAmt"></label>
                                    </td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
            <div>
                <h4 class="box-title">Consumed Materials</h4>
            </div>
            <div class="col-md-12">
                <div class="table-responsive bomtable">
                    <table class="table table-bordered table-hover ctables" id="consumeditem">
                        <thead>
                            <tr>
                                <th class="text-center">S/N</th>
                                <th class="text-center">Item<i class="text-danger">*</i></th>
                                <th class="text-center">Unit</th>
                                <th class="text-center">Qty</th>
                                <th class="text-center">Price</th>
                                <th class="text-center">Amount</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody id="Consumed"></tbody>
                        <tfoot>
                            <tr>
                                <td colspan="2">
                                    Total
                                </td>
                                <td></td>
                                <td><label id="ConsumedtotalQty"></label></td>
                                <td><input type="hidden" value="" class="C_ItemCount" name="ItemCount" id="C_ItemCount"></td>
                                <td class="text-right">
                                    <label id="ConsumedtotalAmt"></label>
                                </td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>


            <div class="col-md-12 headeralign">
                <div class="box-footer">
                    <button type="submit" id="update" class="btn btn-info">
                        Save
                    </button>
                    @*<button type="submit" id="print" class="btn btn-success">
                        Save And Print
                    </button>*@
                    <button type="button" class="btn btn-default" onclick="@("window.location.href='/StockJournal/Index'");">Cancel</button>
                </div>
            </div>

        </div>
    }
</div>


@{var Modelv = "modal-lg";}
@Html.Partial("../Common/_ModalCreate", @Modelv)
@Html.Partial("../Common/_ModalEdit", @Modelv)
@Html.Partial("../Common/_ModeItemCreate", @Modelv)

@section style{
    @Styles.Render("~/css/bootstrap-datepicker")

}
@section Scripts {
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/stockjournal")
    @Scripts.Render("~/js/bootstrap-datepicker")


    <script type="text/javascript">

        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });
        jQuery.validator.methods["date"] = function (value, element) { return true; }


        $(document).ready(function () {
            //bind to employee
            CallEmployee();
            CallApprovedBy();
            $("#SelApprovedBy").val($("#ddlApprovedBy").val());

            //bind to Material Centre
            $("#ddlMCFrom").select2({
                placeholder: 'Items Generated',
                minimumInputLength: 0,
                ajax: {
                    url: "/MC/SearchMC",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term,
                            page: params.page,
                            x: "empty"
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;

                        return {
                            results: data
                        };
                    },
                    cache: true
                },
            });

            //bind to Material Centre
            $("#ddlMCTo").select2({
                placeholder: 'Items Consumed',
                minimumInputLength: 0,
                ajax: {
                    url: "/MC/SearchMC",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term,
                            page: params.page,
                            x: "empty"
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;

                        return {
                            results: data
                        };
                    },
                    cache: true
                },
            });

            var dvid = getQueryString('');

            //item generated-ajax query
            $.ajax({
                url: '/StockJournal/GetGeneratedItems',
                dataType: 'json',
                data: { DvID: dvid },
                cache: true,
                success: function (data) {
                    $.each(data, function (i, item) {
                        addrow('Generated', item.ItemUnit, item.ItemTotalAmount, item.ItemQuantity, item.Item, item.ItemCode, item.ItemName, item.ItemUnitPrice, item.ItemWithCode, item);//10 item
                    });
                    addrow('Generated', '', "", "0.00");
                }
            });

            //item consumed-ajax query

            $.ajax({
                url: '/StockJournal/GetConsumedItems',
                dataType: 'json',
                data: { DvID: dvid },
                cache: true,
                success: function (data) {
                    $.each(data, function (i, Citem) {
                        ItemConsumed('Consumed', Citem.CItemUnit, Citem.CItemTotalAmount, Citem.CItemQuantity, Citem.Item, Citem.CItemCode, Citem.CItemName, Citem.CItemUnitPrice, Citem.CItemWithCode, Citem);//10 item
                    });
                    ItemConsumed('Consumed', '', "", "0.00");
                }
            });

            chkEditEditable("@ViewBag.ChkApp");
        });

        //On Modal Create
        $('#modal-create-lg').on('shown.bs.modal', function (e) {
            //Item Category
            ItemCategory();
            ItemBrand();
            //ItemTax();
            //ItemUnit();
            //ItemSubUnit();
            Itemtype();
            $('#KeepStock').click(function () {
                clickstock();
            });
        });

        $('body').on('change', '#ddlApprovedBy', function (e) {
            $("#SelApprovedBy").val($(this).val());
        });

        $('#sjeditForm').on('submit', function (e) {
            e.preventDefault();
            if ($("#sjeditForm").valid()) {
                var fnval = $('input[type="submit"], button[type="submit"]', this).filter(':focus').attr('id');
                var parameters = {};
                var Voucher = $('#Voucher').val();
                var SJDate = $('#SJDate').val();
                var EmployeeId = $('#ddlEmployee').val();
                var MCFrom = $('#ddlMCFrom').val();
                var MCTo = $('#ddlMCTo').val();
                var Description = $('#Description').val();
                var Items = $('#ItemCount').val();
                var ItemName = $('#item_name').val();
                var ItemUnit = $('#unit_name').val();
                var ItemQuantity = $('#item_quantity').text();
                var ItemPrice = $('#item_price').text();
                var Total = $('#total_price').text();
                var TotalQuantity = $('#GeneratedtotalQty').text();
                var TotalAmount = $('#GeneratedtotalAmt').text();
                var length = $('#ItemCount').text();
                var CItems = $('#C_ItemCount').val();
                var CItemName = $('#Citem_name').val();
                var CItemUnit = $('#C_unit_name').val();
                var CItemQuantity = $('#C_item_quantity').text();
                var CItemPrice = $('#C_item_price').text();
                var CTotal = $('#C_total_price').text();
                var dvID = getQueryString('');
                var CTotalQuantity = $('#ConsumedtotalQty').text();
                var CTotalAmount = $('#ConsumedtotalAmt').text();
                var Clength = $('#C_ItemCount').text();
                var ApprovedBy = $('#SelApprovedBy').val();

                var Ref1 = "";
                var Ref2 = "";
                var Ref3 = "";
                var Ref4 = "";
                var Ref5 = "";
                if ('@Model.FieldMap.Count' > 0) {
                    Ref1 = $('#Ref1').val();
                    Ref2 = $('#Ref2').val();
                    Ref3 = $('#Ref3').val();
                    Ref4 = $('#Ref4').val();
                    Ref5 = $('#Ref5').val();
                }
                var HTMLtbl = {
                    getData: function (table) {
                        var data = [];
                        table.find('tr').not(':first').not(':last').not('.item_').each(function (rowIndex, r) {
                            var cols = [];
                            $(this).find('input,textarea,select').each(function (colIndex, c) {
                                cols.push($(this).val());
                            });
                            data.push(cols);
                        });
                        return data;
                    }
                }

                var CHTMLtbl = {
                    getData: function (ctables) {
                        var data = [];
                        ctables.find('tr').not(':first').not(':last').not('.Citem_').each(function (rowIndex, r) {
                            var cols = [];
                            $(this).find('input,textarea,select').each(function (colIndex, c) {
                                cols.push($(this).val());
                            });
                            data.push(cols);
                        });
                        return data;
                    }
                }

                var sjEntry = [Voucher, SJDate, EmployeeId, MCFrom, MCTo, Description, TotalAmount, CTotalAmount, dvID,ApprovedBy,
                               Ref1, Ref2, Ref3, Ref4, Ref5];
                var data = HTMLtbl.getData($('#generateditem'));
                var consumeddata = CHTMLtbl.getData($('#consumeditem'));
                parameters.array = data;
                parameters.dvdata = sjEntry;
                parameters.consumedarray = consumeddata;
                parameters.action = fnval;

                $.ajax({
                    async: true,
                    cache: false,
                    dataType: "json",
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    url: "/StockJournal/UpdateStockJournal",
                    data: JSON.stringify(parameters),
                    beforeSend: function () {
                        $("button").prop('disabled', true);
                    },
                    success: function (e) {
                        if (e.status == true) {
                            //if (fnval == "print") {
                            //    PrintInvoice(e, "nobillsundry");
                            //}
                            //else {
                                $('.ajax_response', res_success).text(e.message);
                                $('.AlertDiv').prepend(res_success);
                            //}
                            window.location.href = '@Url.Action("Edit", "StockJournal"@*, new { id = "", type = "" }*@)';
                        } else {
                            $('.ajax_response', res_danger).text(e.message);
                            $('.AlertDiv').prepend(res_danger);
                            $("button").prop('disabled', false); // enable button
                        }
                    }
                });

            }
        });

        /* function for Create popup */
        $('span').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        });
        $('#modal-create').on('submit', '#createform', function (e) {
            e.preventDefault();
            var url = $('#createform')[0].action;
            var data = $('#createform').serialize();
            createajax(url, data, '#modal-create');
        });
        $('span').on('click', '.modal-edit', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-edit');
        });
        $('#modal-edit').on('submit', '#editform', function (e) {
            e.preventDefault();
            var url = $('#editform')[0].action;
            var data = $('#editform').serialize();
            createajax(url, data, '#modal-edit');
        });

        function checkbranch() {
            var to = $("#ddlMCFrom").val();
            var from = $("#ddlMCTo").val();
            if (to == from) {
                alert("Branches are same please select differnet branches");
                $("#ddlMCTo").val();
            }
        }

        AddItemPopUp();

    </script>
}

