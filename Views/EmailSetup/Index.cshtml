@model QuickSoft.Models.Company
@{
    ViewBag.Title = "Email Setup";
    Layout = "~/Views/Shared/_QuickLayout.cshtml";
    var m = Model ?? new QuickSoft.Models.Company();
}
<style>
    .es-wrap { padding: 8px 4px 28px; max-width: 920px; }
    .es-head { display:flex; align-items:center; gap:12px; margin-bottom:6px; }
    .es-head h2 { margin:0; font-size:21px; font-weight:800; color:#0f172a; }
    .es-head .ic { width:46px;height:46px;border-radius:13px;background:linear-gradient(135deg,#6366f1,#3b82f6);color:#fff;display:flex;align-items:center;justify-content:center;font-size:22px;box-shadow:0 8px 20px rgba(99,102,241,.35); }
    .es-head p { margin:2px 0 0; color:#64748b; font-size:13px; }
    .es-card { background:#fff; border:1px solid #e2e8f0; border-radius:16px; padding:22px 24px; box-shadow:0 1px 2px rgba(15,23,42,.05),0 8px 24px rgba(15,23,42,.06); margin-top:16px; }
    .es-providers { display:flex; flex-wrap:wrap; gap:10px; margin-bottom:8px; }
    .es-prov { border:1.5px solid #e2e8f0; background:#f8fafc; border-radius:11px; padding:9px 16px; font-weight:700; font-size:13px; color:#334155; cursor:pointer; transition:.15s; }
    .es-prov:hover { border-color:#c7d2fe; background:#eef2ff; color:#4f46e5; }
    .es-prov.sel { border-color:#6366f1; background:#eef2ff; color:#4f46e5; box-shadow:0 0 0 3px rgba(99,102,241,.12); }
    .es-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:16px; margin-top:14px; }
    .es-grid .full { grid-column:1 / -1; }
    .es-grid label { display:block; font-size:12px; font-weight:600; color:#475569; margin-bottom:4px; }
    .es-grid input[type=text], .es-grid input[type=email], .es-grid input[type=password], .es-grid input[type=number] { width:100%; border:1.5px solid #e2e8f0; border-radius:9px; padding:9px 11px; font-size:13.5px; }
    .es-grid input:focus { border-color:#6366f1; box-shadow:0 0 0 3px rgba(99,102,241,.12); outline:none; }
    .es-ssl { display:flex; align-items:center; gap:8px; font-size:13px; color:#334155; margin-top:24px; }
    .es-actions { display:flex; align-items:center; gap:12px; margin-top:20px; flex-wrap:wrap; }
    .es-btn { border:0; border-radius:11px; padding:11px 22px; font-weight:700; font-size:14px; cursor:pointer; }
    .es-save { background:linear-gradient(135deg,#6366f1,#4f46e5); color:#fff; box-shadow:0 6px 16px rgba(99,102,241,.3); }
    .es-test { background:#f1f5f9; color:#334155; }
    .es-msg { font-size:13px; font-weight:600; }
    .es-note { margin-top:14px; background:#fffbeb; border:1px solid #fde68a; border-radius:11px; padding:12px 14px; font-size:12.5px; color:#92400e; line-height:1.6; }
    .es-note b { color:#78350f; }
</style>

<div class="content-wrapper-inner es-wrap">
    <div class="es-head">
        <span class="ic"><i class="glyphicon glyphicon-envelope"></i></span>
        <div>
            <h2>Email Setup</h2>
            <p>Connect any email provider — Gmail, Office 365, Outlook, or your own server. Pick a provider to auto-fill the settings.</p>
        </div>
    </div>

    @Html.AntiForgeryToken()
    <div class="es-card">
        <label style="font-size:12px;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:.3px;">Quick setup — choose your provider</label>
        <div class="es-providers" id="esProviders">
            <div class="es-prov" data-host="smtp.gmail.com" data-port="587" data-ssl="1">Gmail</div>
            <div class="es-prov" data-host="smtp.office365.com" data-port="587" data-ssl="1">Office 365</div>
            <div class="es-prov" data-host="smtp-mail.outlook.com" data-port="587" data-ssl="1">Outlook.com</div>
            <div class="es-prov" data-host="smtp.mail.yahoo.com" data-port="587" data-ssl="1">Yahoo</div>
            <div class="es-prov" data-host="smtp.zoho.com" data-port="587" data-ssl="1">Zoho</div>
            <div class="es-prov" data-host="" data-port="" data-ssl="1">Custom / Other</div>
        </div>

        <div class="es-grid">
            <div>
                <label>From Email (the address emails are sent from)</label>
                <input type="email" id="SMTPEmail" value="@m.SMTPEmail" placeholder="e.g. accounts@yourcompany.com" />
            </div>
            <div>
                <label>Username (usually the same email)</label>
                <input type="text" id="SMTPUsername" value="@m.SMTPUsername" placeholder="login@yourcompany.com" />
            </div>
            <div>
                <label>Password / App Password</label>
                <input type="password" id="SMTPPassword" placeholder="@(string.IsNullOrEmpty(m.SMTPPassword) ? "Enter password" : "•••••• (saved — leave blank to keep)")" />
            </div>
            <div></div>
            <div>
                <label>SMTP Host (server)</label>
                <input type="text" id="SMTPHost" value="@m.SMTPHost" placeholder="smtp.gmail.com" />
            </div>
            <div>
                <label>Port</label>
                <input type="number" id="SMTPPort" value="@(m.SMTPPort?.ToString() ?? "")" placeholder="587" />
            </div>
            <div class="full">
                <label class="es-ssl"><input type="checkbox" id="EnableSsl" @(m.EnableSsl ? "checked" : "") /> Use SSL / TLS (recommended — keep on for Gmail, Office 365, and most providers)</label>
            </div>
        </div>

        <div class="es-actions">
            <button type="button" id="esSave" class="es-btn es-save"><i class="glyphicon glyphicon-floppy-disk"></i> Save Settings</button>
            <button type="button" id="esTest" class="es-btn es-test"><i class="glyphicon glyphicon-send"></i> Send Test Email</button>
            <span id="esMsg" class="es-msg"></span>
        </div>

        <div class="es-note">
            <b>Gmail / Yahoo:</b> turn on 2-Step Verification, then create an <b>App Password</b> and use that here (your normal password won't work).<br>
            <b>Office 365 / Outlook:</b> use your email and account password; if MFA is on, create an app password.<br>
            Standard secure port is <b>587</b> with SSL/TLS on.
        </div>
    </div>
</div>

@section scripts {
<script>
(function () {
    var token = function () { var t = document.querySelector('input[name="__RequestVerificationToken"]'); return t ? t.value : ''; };
    document.querySelectorAll('#esProviders .es-prov').forEach(function (p) {
        p.addEventListener('click', function () {
            document.querySelectorAll('#esProviders .es-prov').forEach(function (x) { x.classList.remove('sel'); });
            p.classList.add('sel');
            if (p.getAttribute('data-host')) document.getElementById('SMTPHost').value = p.getAttribute('data-host');
            if (p.getAttribute('data-port')) document.getElementById('SMTPPort').value = p.getAttribute('data-port');
            document.getElementById('EnableSsl').checked = p.getAttribute('data-ssl') === '1';
        });
    });
    function payload() {
        return {
            SMTPEmail: document.getElementById('SMTPEmail').value,
            SMTPUsername: document.getElementById('SMTPUsername').value,
            SMTPPassword: document.getElementById('SMTPPassword').value,
            SMTPHost: document.getElementById('SMTPHost').value,
            SMTPPort: document.getElementById('SMTPPort').value,
            EnableSsl: document.getElementById('EnableSsl').checked,
            __RequestVerificationToken: token()
        };
    }
    function msg(text, ok) { var m = document.getElementById('esMsg'); m.style.color = ok ? '#059669' : '#dc2626'; m.textContent = text; }
    document.getElementById('esSave').addEventListener('click', function () {
        var b = this; b.disabled = true; msg('Saving…', true); document.getElementById('esMsg').style.color = '#64748b';
        jQuery.post('@Url.Action("Save","EmailSetup")', payload(), function (r) {
            b.disabled = false; msg((r && r.message) || (r && r.success ? 'Saved.' : 'Failed.'), r && r.success);
        }).fail(function () { b.disabled = false; msg('Save request failed.', false); });
    });
    document.getElementById('esTest').addEventListener('click', function () {
        var to = window.prompt('Send a test email to which address?', document.getElementById('SMTPUsername').value || document.getElementById('SMTPEmail').value || '');
        if (to === null) return;
        var b = this; b.disabled = true; document.getElementById('esMsg').style.color = '#64748b'; document.getElementById('esMsg').textContent = 'Sending test email…';
        var p = payload(); p.toEmail = to;
        jQuery.post('@Url.Action("TestEmail","EmailSetup")', p, function (r) {
            b.disabled = false; msg((r && r.message) || (r && r.success ? 'Sent.' : 'Failed.'), r && r.success);
        }).fail(function () { b.disabled = false; msg('Test request failed.', false); });
    });
})();
</script>
}
