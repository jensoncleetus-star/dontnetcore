                        Ref3 = $('#Ref3').val();
                        Ref4 = $('#Ref4').val();
                        Ref5 = $('#Ref5').val();
                    }
                    var Layout = $('#ddlPrintlayout').val();


                    var HTMLtbl = {
                        getData: function (table) {
                            var data = [];
                            table.find('tr').not(':first').not('.item_').each(function (rowIndex, r) {
                                var cols = [];
                                $(this).find('input,textarea,select').each(function (colIndex, c) {
                                    cols.push($(this).val());
                                });
                                data.push(cols);
                            });
                            return data;
                        }
                    }
                    var HTMLtblbs = {
                        getData: function (table) {
                            var bsData = [];
                            table.find('tr').not(':first').not('.bs_').each(function (rowIndex, r) {
                                var cols = {};
                                $(this).find('input,textarea,select').each(function (colIndex, c) {
                                    itid = $(this).attr('data-name').split(' ')[0];
                                    itval = ($(this).val() != "") ? $(this).val() : $(this).text();
                                    cols[itid] = itval;

                                });
                                bsData.push(cols);
                            });
                            return bsData;
                        }
                    }
                    var bsData = HTMLtblbs.getData($('#billsundry'));
                    // batch stock

                    var HTMLtblbst = {
                        getData: function (table) {
                            var bstData = [];
                            var order = 0;
                            var lastOne = 0;
                            table.find('tr').not(':first').not('.bs_').each(function (rowIndex, r) {
                                var cols = {};
                                $(this).find('input,textarea,select').each(function (colIndex, c) {
                                    itid = $(this).attr('data-name').split(' ')[0];
                                    itval = ($(this).val() != "") ? $(this).val() : $(this).text();
                                    if (itid == "order") {
                                        if (order == 0) {
                                            order = 1;
                                            lastOne = itval;
                                        }
                                        if (lastOne != itval) {
                                            order++;
                                            lastOne = itval;
                                        }
                                        itval = order;
                                    }
                                    cols[itid] = itval;
                                });
                                if (!jQuery.isEmptyObject(cols) && cols.BatchNo != "") {
                                    bstData.push(cols);
                                }
                            });
                            return bstData;
                        }
                    }
                    var bstdata = HTMLtblbst.getData($('.batchtbl'));


                    var SREntry = [CustomerID, SalesPersonID, SRDate, SRItems, SRItemQuantity,
                    TotalTax, Discount, GrandTotal, SRSubTotal, SRTax, PaidAmount, SRNote,
                    CustomerType, CustomerName, MobileNo, fnval, saleEntryId, ReturnType,
                    BillNo, CustomerMail, Remarks, MaterialCenter, Branch, SalesType, Project, Task, ApprovedBy,SaleType,
                        Ref1, Ref2, Ref3, Ref4, Ref5, Layout, discountrate]

                    var data = HTMLtbl.getData($('#normalinvoice'));
                    var parameters = {};
                    parameters.array = data;
                    parameters.saledata = SREntry;
                    parameters.bsmodel = { 'srbsundrys': bsData };
                    parameters.bstmodel = bstdata;

                    if (fnval == "save") {
                        submitForm(fnval, parameters);
                    } else if (fnval == "print") {
                        submitForm(fnval, parameters);
                    } else if (fnval == "sendmail") {
                        if ($('#custEmailId').val() != "") {
                            submitForm(fnval, parameters);
                        } else {
                            $('.ajax_response', res_danger).text("Customer Email Address Not Found..!!");
                            $('.AlertDiv').prepend(res_danger);
                        }
                    }
                }
            }
        });

        function submitForm(fnval, parameters) {
            $.ajax({
                async: true,
                cache: false,
                dataType: "json",
                type: "POST",
                contentType: "application/json; charset=utf-8",
                url: "/CreditSaleReturnNote/CreateSalesReturn",
                data: JSON.stringify(parameters),
                beforeSend: function () {
                    $("button").prop('disabled', true); // disable button
                },
                success: function (e) {
                    if (e.status == true) {
                        if (fnval == "print") {
                            @Html.Raw(posfun)
                            //PrintInvoice(e, "", "inactive", "SalesReturn");
                        } else {
                            $('.ajax_response', res_success).text(e.message);
                            $('.AlertDiv').prepend(res_success);
                        }
                        @*window.location.href = '@Url.Action("Create", "CreditSaleReturnNote")';*@

                        if ('@ViewBag.BusinessType' != 'DeliveryManagement' || '@ViewBag.POS' != 'active' || fnval != "print") {
                            setTimeout(function () { window.location.href = '/CreditSale/Create'; }, '@TimeOut');
                        }

                    } else {
                        $('.ajax_response', res_danger).text(e.message);
                        $('.AlertDiv').prepend(res_danger);
                        $("button").prop('disabled', false); // enable button
                    }
                }
            });
        }
