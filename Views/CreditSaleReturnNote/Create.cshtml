    function updatecreditnote(obj) {
        var org = $(obj).val();
        var fir = $("#addinvoiceItem").find(".item_discount:first").val();
        var bal = fir - org;
        
        var qty = $("#addinvoiceItem").find(".quty:first").val();
        var rate = $("#addinvoiceItem").find(".totrate:first").val();
        var discvalue = parseFloat(parseFloat(qty * rate) - org) / qty;

        
        $("#addinvoiceItem").find(".item_discount:first").val(discvalue);
        $("#addinvoiceItem").find(".item_discount:first").trigger("change");
    }
