<script type="text/javascript">
        var minDate = $("#Start").val();
        var maxDate = $("#End").val();
        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true,
            startDate: new Date(minDate),
            endDate: new Date(maxDate)
        });

        jQuery.validator.methods["date"] = function (value, element) { return true; }
    $(".ref").select2({
        tags: true
    });
        $(document).ready(function () {
            $("#ReturnType").find('[value="1"]').remove()
            addrow('addinvoiceItem', 'quot', "", "0.00", "0.00", "0");
            addbillsundry('addbillsundry', '', '0.00', '', '0.00', '');
            searchItem();
            //Item Category
            ItemCategory();
            ItemBrand();
            GetBranch();
            if ("@Model.SalesEntryId" != "") {
                $("#ddlSalesEntry").append('<option value="@Model.SalesEntryId">@Model.SalesEntryId</option>');
                saleEntryChange();
            }
            
            //ItemTax();
            //ItemUnit();
            //ItemSubUnit();

            //bind to employee
            CallEmployee();
            CallMCUser();
            CallProject();
            CallTask();
            CallApprovedBy();

            $("#ddlMC").prop('selectedIndex', 0);
            $("#CustomerType").prop('selectedIndex', 0);
            $('#CustomerType option:contains(Card)').remove();
            CallCustomer();
            VatVoucherWise();

            $('#SaleType option:contains(POS)').remove();
            $('#SalesType').select2();;
            if ('@ViewBag.BusinessType' == "Scaffold") {
                $('#SaleType').select2();
            }
            SaleHireEntry(1);
            //$(".ref").select2({
            //    tags: true
            //});
        });

        /* function for Create popup */

        $('span').on('click', '.modal-create', function (e) {
            e.preventDefault();
            $(this).attr('data-target', '#modal-create');
            $(this).attr('data-toggle', 'modal');
        });
        $('#modal-create').on('submit', '#createform', function (e) {
            e.preventDefault();
            var url = $('#createform')[0].action;
            var data = $('#createform').serialize();
            createajax(url, data, '#modal-create');
        });


        $('span').on('click', '.modal-edit', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-edit');
        });
        $('#modal-edit').on('submit', '#editform', function (e) {
            e.preventDefault();
            var url = $('#editform')[0].action;
            var data = $('#editform').serialize();
            createajax(url, data, '#modal-edit');
        });
        $('span').on('click', '.modal-project', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-project');
        });

        $('body').on('change', '#ddlMC', function (e) {
            var mcval = $(this).val();
            searchItem();
        });

        $('body').on('change', '#ddlCustomer', function (e) {
            $('#ddlProject').val(null).trigger('change');
            CallProject();
            var CustId = $('#ddlCustomer').val();
            CustId = $(this).val();


            if (CustId != null) {

                //Calling function to retrieve PMaintenance details based on AmcID
                $.ajax({
                    url: '/CreditSale/GetFillDetails',
                    dataType: 'json',
                    data: { CustId: CustId },
                    cache: true,
                    success: function (data) {
                        var opt = '<option value="' + data[0].ddlEmployee + '" selected>' + data[0].ddlEmployee + '</option>'


                        $("#ddlEmployee").append(opt);
                        $("#ddlEmployee").val(data[0].ddlEmployee);
                        CallEmployee();
                    }
                });
            }







        });
        $('body').on('change', '#ddlProject', function (e) {
            $('#ddlProTask').val(null).trigger('change');
            CallTask();
        });
        function sreturntype() {
            var rettype = $('#ReturnType').val();
            if (rettype == 1) {
                $('#srbillno').hide();
            }
            if (rettype == 0) {
                $('#srbillno').show();
                $("#ddlSalesEntry").attr("required", "required");
                $("#ddlSalesEntry").attr("data-msg-required", "The Invoice No is required");
            }
            reset();
        }
        function reset() {
            $('#ddlEmployee').val("");
            $('#ddlCustomer').text("");
            $("#Discount").val("0.00");
            $("#PaidAmount").val("0.00");
            $("#GrandTotal").val("0.00");
            $("#DueAmount").val("0.00");

            $("#ddlCustomer").val(null).trigger("change");
            $("#ddlSalesEntry").val(null).trigger("change");
            $("#ddlEmployee").val(null).trigger("change");

            $(".select2 item_name").val(null).trigger('change');

