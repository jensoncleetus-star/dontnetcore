@model QuickSoft.Models.PriceCategoryPercentage
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Edit Price Category</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("Edit", "PriceCategory", FormMethod.Post, new { id = "editform" }))
    {
        <script type="text/javascript">
            $('form#popupFormSize').removeData("validator");
            $('form#popupFormSize').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#popupFormSize'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        @Html.HiddenFor(model => model.CategoryId)
        <div class="row">

            <div class="col-md-8">
                <div class="form-group">
                    @Html.Label("Category Name", null, htmlAttributes: new { @class = "control-label" })
                    <div class="input-group input-group-sm">
                        @*@Html.DropDownListFor(m => m.Category, (SelectList)ViewBag.Category, "", new { id = "ddlPricecategory", @class = "form-control select2", @required = "required" })*@


                        @Html.DropDownListFor(model => model.Category, (SelectList)ViewBag.CategoryList, "", new { id = "Category", @class = "form-control select2", @required = "required" })


                        @*<span class="input-group-btn">
                                <button type="button" href="/Category/Create" class="modal-create btn btn-success btn-flat"><i class="fa fa-1x fa-plus-circle"></i></button>
                            </span>*@
                    </div>
                </div>
            </div>
            <div class="col-md-12">
                <div class="form-group">
                    @Html.RadioButtonFor(m => m.PriceCategory, "SalesPrice")SalesPrice

                    @Html.RadioButtonFor(m => m.PriceCategory, "PurchasePrice")PurchasePrice

                </div>
            </div>
            <div class="col-md-8">
                <div class="form-group">
                    @Html.LabelFor(model => model.Percentage, htmlAttributes: new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.Percentage, new { htmlAttributes = new { @class = "form-control", autofocus = "autofocus", @placeholder = "Enter Location", @required = "required" } })

                </div>
            </div>


        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" value="Submit" class="btn btn-info col-sm-offset-4" />
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>

