@model QuickSoft.Models.Area
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Edit Area</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("Edit", "Area", FormMethod.Post, new { role = "form", id = "editform" }))
            {
        <script type="text/javascript">
                    $('form#popupFormCategory').removeData("validator");
                    $('form#popupFormCategory').removeData("unobtrusiveValidation");
                    $.validator.unobtrusive.parse($('form#popupFormCategory'));
        </script>
                @Html.AntiForgeryToken()
                @Html.ValidationSummary("", new { @class = "alert alert-danger" })
                @Html.HiddenFor(model => model.AreaId)

                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group">
                            @Html.LabelFor(m => m.AreaName, htmlAttributes: new { @class = "control-label" }) *
                            @Html.TextBoxFor(m => m.AreaName, new { @class = "form-control", autofocus = "autofocus", @required = "required" })
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12">
                        <div class="box-footer">
                            <input type="submit" class="btn btn-info col-sm-offset-4" value="Update" />
                            <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                        </div>
                    </div>
                </div>
    }
</div>
@section scripts{
    @Scripts.Render("~/js/jqueryval")
}
