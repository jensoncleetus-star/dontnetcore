@model QuickSoft.ViewModel.PipeLineDetailsViewModel
@{
    ViewBag.Title = "PipeLine Details";
    ViewBag.SubTitle = "PipeLine Details";
    ViewBag.Active = "PipeLine";
    var Loc = "";
}
@if (Model.Location != null || Model.Location != "")
{
    Loc = "<iframe src=\"" + Model.Location + "\" width=\"100%\" height=\"150\" frameborder=\"0\" style=\"border:0\" allowfullscreen></iframe>";
}
<script>
    
</script>
<div class="box box-info">
    <div class="box-header">
        <h3 class="box-title">@Html.DisplayFor(m => m.CustomerName)</h3>
        <div class="pull-right">
            @if (User.IsInRole("Dev") || User.IsInRole("PipeLine List"))
            {
                <a class="btn btn-success no-border" href="/PipeLine">
                    <i class="fa fa-fw fa-history"></i>PipeLine List
                </a>
            }
            @if (User.IsInRole("Dev") || User.IsInRole("MyPipeLine"))
            {
                <a class="btn btn-primary no-border" href="/PipeLine/MyPipeLine">
                    <i class="fa fa-fw fa-history"></i> My PipeLine
                </a>
            }
            @if (User.IsInRole("Dev") || User.IsInRole("Create PipeLine"))
            {
                <a class="btn btn-info no-border" href="/PipeLine/Create">
                    <i class="glyphicon glyphicon-plus"></i> Create PipeLine
                </a>
            }
        </div>
    </div>
    <div class="box-body">
        <section class="content">
            <div class="row">
                <div class="col-md-3">
                    <!-- Profile Image -->
                    <div class="box box-primary">
                        <div class="box-body box-profile">
                          
                            <ul class="list-group list-group-unbordered">
                               
                                <li class="list-group-item">

                                    <b>Code</b> : @Html.DisplayFor(m => m.CustomerCode)

                                </li>
                                <li class="list-group-item">

                                    <b>Level</b> : @Html.DisplayFor(m => m.LeadLevel)

                                </li>
                                <li class="list-group-item">

                                    <b>Lead Source</b> : @Html.DisplayFor(m => m.SrcLead)

                                </li>
                                <li class="list-group-item">

                                    <b>Lead Status</b> : @Html.DisplayFor(m => m.leadStausDisp)

                                </li>
                                <li class="list-group-item">
                                    <b>Assigned To</b>:
                                   @foreach (var upd in Model.LeadAssign)
                                   {
                                        @upd.Empname                                   
                                   }
                                </li>

                                    @foreach (var cre in Model.LeadCreated)
                                    {
                                        if (@cre.Converted == "Direct")
                                        {
                                        <li class="list-group-item">
                                            <b>Created By</b> : @cre.CreatedUser
                                        </li>
                                        <li class="list-group-item">
                                           <b>Created Date</b> @Convert.ToString(string.Format("{0:dd-MM-yyyy}",Convert.ToDateTime(cre.CreatedDate)))
                                        </li>
                                        }
                                    }

                              </ul>
                            <strong><i class="fa fa-map-marker margin-r-5"></i> Location : </strong>
                            @*<span class="text-muted text-right"><a href="@Model.Location">@Html.DisplayFor(m => m.Location)</a></span>*@
                            @if (Model.Location != null || Model.Location != "")
                            {
                                @Html.DisplayFor(m => m.Location) 
                               
                            }
                            <hr>
                            
                        </div>
                    </div>
                </div>
                <!-- /.col -->
                <div class="col-md-9">
                    <div class="nav-tabs-custom">
                        <ul class="nav nav-tabs">
                            <li class="active"><a href="#lead" data-toggle="tab">PipeLine Details</a></li>
                           
                            <li><a href="#attach" data-toggle="tab">Attachments</a></li>
                            @*<li><a href="#remarks" data-toggle="tab">Remarks</a></li>*@
                           
                            <li><a href="#leadchart" data-toggle="tab">Activity</a></li>
                          
                        </ul>
                        <div class="tab-content">
                           

                            <div class="active tab-pane" id="lead">
                                <div class="post">
                                    <div class="user-block">
                                        <h3 class="box-title"> @Html.DisplayFor(m => m.CustomerName)</h3>
                                        <span>Code : @Html.DisplayFor(m => m.CustomerCode)</span><br />
                                        <span>TaxRegNo : @Html.DisplayFor(m => m.TaxRegNo)</span>
                                        <hr>
                                        <div class="row">
                                            <div class="box-body">

                                                <div class="form-group col-md-4">
                                                    @Html.Label("Location :", null, new { @class = "control-label" })
                                                    @Html.DisplayFor(m => m.Location)
                                                </div>


                                            </div>
                                            <div class="box-header with-border">
                                                <h4 class="box-title">Contact Details</h4>
                                            </div>
                                            <div class="box-body">
                                                @if (Model != null)
                                                {
                                                    <div class="form-group col-md-4">
                                                        @Html.Label("Address :", null, new { @class = "control-label" })
                                                        @Html.DisplayFor(m => m.Address)
                                                    </div>
                                                    <div class="form-group col-md-4">
                                                        @Html.Label("City  :", null, new { @class = "control-label" })
                                                        @Html.DisplayFor(m => m.City)
                                                    </div>
                                                    <div class="form-group col-md-4">
                                                        @Html.Label("Emirate :", null, new { @class = "control-label" })
                                                        @Html.DisplayFor(m => m.State)
                                                    </div>
                                                    <div class="form-group col-md-4">
                                                        @Html.Label("Country :", null, new { @class = "control-label" })
                                                        @Html.DisplayFor(m => m.Country)
                                                    </div>
                                                    <div class="form-group col-md-4">
                                                        @Html.Label("Zip :", null, new { @class = "control-label" })
                                                        @Html.DisplayFor(m => m.Zip)
                                                    </div>
                                                    <div class="form-group col-md-4">
                                                        @Html.Label("Phone :", null, new { @class = "control-label" })
                                                        @Html.DisplayFor(m => m.Phone)
                                                    </div>
                                                    <div class="form-group col-md-4">
                                                        @if (Model.mobmodel != null)
                                                        {
                                                            @Html.Label("Mobile:", null, new { @class = "control-label" })
                                                            foreach (var Ext in Model.mobmodel)
                                                            {
                                                                @Html.Label(Ext.Num + ", ", new { @style = "font-weight:normal" })

                                                            }
                                                        }
                                                    </div>
                                                    <div class="form-group col-md-4">
                                                        @Html.Label("Fax :", null, new { @class = "control-label" })
                                                        @Html.DisplayFor(m => m.Fax)
                                                    </div>
                                                    <div class="form-group col-md-4">
                                                        @Html.Label("Email Id :", null, new { @class = "control-label" })
                                                        @Html.DisplayFor(m => m.EmailId)
                                                    </div>
                                                    <div class="form-group col-md-4">
                                                        @Html.Label("Reference :", null, new { @class = "control-label" })
                                                        @Html.DisplayFor(m => m.Reference)
                                                    </div>
                                                    <div class="form-group col-md-4">
                                                        @Html.Label("Contact Person :", null, new { @class = "control-label" })
                                                        @Html.DisplayFor(m => m.ContactPerson)
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="tab-pane" id="attach">
                                <h4>Documents</h4>
                                @if (Model.LeadDocuments != null)
                                {
                                    if (Model.LeadDocuments.Any())
                                    {
                                        <div class="row margin-bottom">
                                            <div class="fileupload fileupload-new" data-provides="fileupload">
                                                @foreach (var item in Model.LeadDocuments)
                                                {
                                                    var x = item.FileName.Split('.');
                                                    var extn = x[1];
                                                    var extnf = "";
                                                    if (item.FileName.Contains("resize_"))
                                                    {
                                                        var filez = item.FileName.Split('_');
                                                        extnf = filez[1];
                                                    }
                                                    else
                                                    {
                                                        extnf = item.FileName;
                                                    }

                                                    if (extn == "jpg" || extn == ".jfif" || extn == "png" || extn == "jpeg")
                                                    {

                                                        <div class="col-sm-1">
                                                            <div class="ace-thumbnails clearfix">
                                                                <a href="~/uploads/leaddocuments/@Html.DisplayFor(modelItem => item.FileName)" ID="ImgBtn1" download>
                                                                    <img width="100" height="100" alt="@Html.DisplayFor(modelItem => item.FileName)" title="Click to Open" src="~/uploads/leaddocuments/thumb_@extnf" ID="ImgBtn1" class="img-responsive img-fluid" />
                                                                </a>
                                                            </div>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="col-sm-1">
                                                            <div class="ace-thumbnails clearfix">
                                                                <a href="~/uploads/leaddocuments/@Html.DisplayFor(modelItem => item.FileName)" ID="ImgBtn1" download>
                                                                    <img width="100" height="100" alt="@Html.DisplayFor(modelItem => item.FileName)" title="Click to Open" src="~/uploads/leaddocuments/Docs-Thump.png" ID="ImgBtn1" class="img-responsive img-fluid" />
                                                                </a>
                                                            </div>
                                                        </div>
                                                    }


                                                }
                                            </div>
                                        </div>
                                    }
                                }
                                <hr />

                            </div>


                            @*<div class="tab-pane" id="remarks">
                                <div class="post">
                                    <div class="user-block">
                                        <div class="row">
                                            <div class="box-header with-border">
                                                <h4 class="box-title">Remarks</h4>
                                                <div class="form-group col-md-12">
                                                    @Html.DisplayFor(m => m.Remark)
                                                </div>
                                            </div>
                                            <div class="box-body">

                                                <table class="table table-bordered table-hover" id="RemarkInfo">
                                                    <thead>
                                                        <tr class="bg-gray">
                                                            <td data-priority="2">#</td>
                                                            <td data-priority="2">TimeStamp</td>
                                                            <td data-priority="1">Employee</td>
                                                            <td data-priority="1">Remark</td>
                                                        </tr>
                                                    </thead>
                                                    <tbody></tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>*@
                            <!-- /.tab-pane -->
                            @*timeline*@

                            <div class="tab-pane" id="leadchart">
                                @if (Model.LeadTimeLine.Any())
                                {
                                    <ul class="timeline timeline-inverse">


                                        @foreach (var upd in Model.LeadTimeLine)
                                        {
                                <!-- timeline time label -->
                                            var color = "";
                                            var updby = "";
                                            if (upd.LogType == "Created")
                                            {
                                                color = "bg-green";
                                                updby = "Created by";
                                            }
                                            else if (upd.LogType == "Updated")
                                            {
                                                color = "bg-orange";
                                                updby = "Updated by";
                                            }
                                            else if (upd.LogType == "Remark Added")
                                            {
                                                color = "bg-teal";
                                                updby = "Remark";
                                            }
                                            else if (upd.LogType == "Assigned")
                                            {
                                                color = "bg-purple";
                                                updby = "Remark";
                                            }
                                            else if (upd.LogType == "Unassigned")
                                            {
                                                color = "bg-red";
                                                updby = "Remark";
                                            }
                                            <li class="time-label">
                                                <span class="@color">
                                                    @Convert.ToString(string.Format("{0:dd-MM-yyyy }", upd.Time))

                                                </span>
                                            </li>
                                            <li>
                                                <i class="fa fa-tasks bg-blue"></i>
                                                <div class="timeline-item">
                                                    <span class="time"><i class="fa fa-clock-o"></i>@Convert.ToString(string.Format("{0:hh:mm tt}", upd.Time))</span>
                                                    <h3 class="timeline-header"><a>@upd.LogType</a></h3>
                                                    @if (upd.LogType == "Created")
                                                    {
                                                        <h3 class="timeline-header">@upd.Details  </h3>
                                                    }
                                                    else if (upd.LogType == "Updated")
                                                    {

                                                        <h3 class="timeline-header"> @upd.Details</h3>
                                                    }
                                                    else if (upd.LogType == "Remark Added")
                                                    {
                                                        <h3 class="timeline-header">@upd.Details </h3> @*by @upd.Name*@
                                                    }

                                                    else if (upd.LogType == "Assigned")
                                                    {
                                                        <h3 class="timeline-header">@upd.Details </h3> @*by @upd.Name*@
                                                    }

                                                    else if (upd.LogType == "Unassigned")
                                                    {
                                                        <h3 class="timeline-header">@upd.Details </h3> @*by @upd.Name*@
                                                    }



                                                    <div class="timeline-footer">
                                                        @if (upd.LogType == "Remark Added")
                                                        {
                                                            <span>  Added By : @upd.Name </span>
                                                        }
                                                        else if (upd.LogType == "Assigned")
                                                        {
                                                            <span>  Assigned By : @upd.Name </span>
                                                        }
                                                        else if (upd.LogType == "Unassigned")
                                                        {
                                                            <span> Un Assigned By : @upd.Name </span>
                                                        }
                                                        else
                                                        {
                                                            <span> @updby : @upd.Name </span>
                                                        }


                                                    </div>
                                                </div>
                                            </li>
                                        }
                                    </ul>
                                }
                            </div>
                        
                        </div>
                        <!-- /.tab-content -->
                    </div>
                    <!-- /.nav-tabs-custom -->
                </div>
                <!-- /.col -->
            </div>
            <!-- /.row -->

        </section>
    </div>
</div>

@{var vModel = "modal-lg";}
@Html.Partial("../Common/_ModalCreate", @vModel)
@Html.Partial("../Common/_ModalEdit")
@Html.Partial("../Common/_ModalDelete")
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/lightbox")
}
@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/lightbox")
    <script type="text/javascript">
        $(document).ready(function ()
        {
            var CustomerID = getQueryString('');

            var pTable = $('#RemarkInfo').DataTable({
                "processing": true, // for show progress bar
                "serverSide": true, // for process server side
                "filter": false, // this is for disable filter (search box)
                "orderMulti": true, // for disable multiple column at once
               "bStateSave": true,
               "pageLength": 50,
                "paging": false,
                "ajax": {
                    "url": '/Leads/GetAllRemarks',
                    "type": "POST",
                    "datatype": "json",
                    "data": { CustomerId: CustomerID }
                },
                "order": [[0, "desc"]],
                "columns": [
                     {
                         "data": "id", "name": "id",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                   { "data": "CreatedDate", "name": "CreatedDate", "render": function (data) { if (data != null) { return convertDateTime(data); } else { return "" } } },
                  { "data": "empnae", "name": "empnae" },
                  { "data": "Remark", "name": "Remark" },
                ],
            });
        });
        </script>
}


