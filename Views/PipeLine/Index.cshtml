    .dataTables_length select { border:1.5px solid #e7eaf0; border-radius:9px; padding:6px 10px; margin:0 6px; font-size:13px; }
    .dataTables_filter label { font-size:0; color:transparent; }
    .dataTables_filter input { border:1.5px solid #e7eaf0 !important; border-radius:10px; padding:8px 14px 8px 34px; min-width:220px; font-size:13.5px; background:#fff url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' fill='none' stroke='%2394a3b8' stroke-width='2'><circle cx='7' cy='7' r='5'/><path d='M11 11l4 4'/></svg>") no-repeat 11px center; }
    .dataTables_filter input:focus { border-color:#6366f1 !important; box-shadow:0 0 0 3px rgba(99,102,241,.12); outline:none; }

    #MyTable > thead > tr > td, #MyTable > thead > tr > th { background:#f8fafc !important; color:#475569; font-size:10px; font-weight:800; text-transform:uppercase; letter-spacing:.4px; padding:10px 12px; border:0 !important; border-bottom:1.5px solid #e7eaf0 !important; }
    #MyTable > tbody > tr > td { border:0 !important; border-bottom:1px solid #f1f5f9 !important; padding:9px 12px; font-size:12.5px; vertical-align:middle; }
    #MyTable > tbody > tr:hover > td { background:#f8faff; }

    .dataTables_info { color:#64748b; font-size:12.5px; }
