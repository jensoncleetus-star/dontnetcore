@{
    ViewBag.Title = " ContactType List";
    ViewBag.SubTitle = "Contact Type";
    ViewBag.Active = "Master";
    string actData = "";
    bool userRole = false;
    string delchk = "";
    string deleteBTn = "";
    if (User.IsInRole("Dev") || User.IsInRole("Delete ContactType"))
    {
        userRole = true;
        deleteBTn = "{text: 'Delete', className: 'btn-danger', action: function(e, dt, node, config) {" +
               "if ($('.checkbox:checked').length > 0) {if (confirm('Are you sure you want to delete this?')) {$('#payform').submit(); e.preventDefault();} " +
                "} else {alert('Please Select Rows..!!');e.preventDefault();}}},";
    }
}
@* BOS: Contacts-page parity restyle — scoped (this <style> only loads on /ContactType) *@
<style type="text/css">
    .box.box-info { border:1px solid #e7eaf0; border-radius:16px; box-shadow:0 1px 2px rgba(15,23,42,.04),0 14px 34px rgba(15,23,42,.07); overflow:visible; }
    .box.box-info > .box-header.with-border { border-bottom:1px solid #eef1f6; padding:13px 18px 9px; }
    .box-title { font-size:18px; font-weight:800; color:#0f172a; letter-spacing:-.2px; position:relative; padding-left:13px; }
    .box-title:before { content:""; position:absolute; left:0; top:3px; bottom:3px; width:4px; border-radius:3px; background:linear-gradient(180deg,#6366f1,#4f46e5); }
    .box-header .pull-right { margin-top:0 !important; }
    .box-header .btn-info, .box-header a.btn-info { background:linear-gradient(135deg,#6366f1,#4f46e5) !important; border:0 !important; color:#fff !important; border-radius:11px; padding:9px 20px; font-weight:700; box-shadow:0 8px 18px rgba(99,102,241,.32); }
    .box-header .btn-info:hover { filter:brightness(1.07); color:#fff !important; }
    .icon-animated-hand-pointer { display:none !important; }
    .box-body.search-box { padding-bottom:0; }

    .dataTables_wrapper { padding:2px 16px 14px; }
    .dt-buttons { display:inline-flex; flex-wrap:wrap; gap:6px; margin-bottom:12px; }
    .dt-button, button.dt-button, a.dt-button, div.dt-button { background:#fff !important; border:1.5px solid #e7eaf0 !important; border-radius:10px !important; color:#475569 !important; font-weight:600 !important; font-size:12.5px !important; padding:8px 14px !important; box-shadow:none !important; margin:0 !important; }
    .dt-button:hover { border-color:#c7d2fe !important; background:#eef2ff !important; color:#4f46e5 !important; }
    .dt-button.btn-danger { border-color:#fecaca !important; color:#dc2626 !important; background:#fff !important; }

    .dataTables_filter { float:right; }
    .dataTables_filter label { font-size:0; color:transparent; }
    .dataTables_filter input { border:1.5px solid #e7eaf0 !important; border-radius:10px; padding:9px 14px 9px 34px; min-width:240px; font-size:13.5px; margin-left:0; background:#fff url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' fill='none' stroke='%2394a3b8' stroke-width='2'><circle cx='7' cy='7' r='5'/><path d='M11 11l4 4'/></svg>") no-repeat 11px center; }
    .dataTables_filter input:focus { border-color:#6366f1 !important; box-shadow:0 0 0 3px rgba(99,102,241,.12); outline:none; }

    body .wrapper { overflow:visible; }
    table#UserTable { width:100% !important; border-collapse:separate; border-spacing:0; overflow:visible; }
    table#UserTable thead { position:sticky; top:0; z-index:6; }
    table#UserTable thead td, table#UserTable thead th { position:sticky; top:0; background:#f8fafc !important; color:#475569; font-size:10.5px; font-weight:800; text-transform:uppercase; letter-spacing:.5px; padding:11px 14px; border:0 !important; border-bottom:1.5px solid #e7eaf0 !important; white-space:nowrap; box-shadow:0 1px 0 #e7eaf0; }
    table#UserTable tbody td { padding:11px 14px; border:0 !important; border-bottom:1px solid #f1f5f9 !important; font-size:13.5px; color:#1e293b; vertical-align:middle; }
    table#UserTable tbody tr:hover td { background:#f8faff; }
    .dataTables_empty { color:#94a3b8 !important; padding:40px !important; text-align:center; }

    .qk-name { display:flex; align-items:center; gap:11px; }
    .qk-av { flex:0 0 auto; width:34px; height:34px; border-radius:9px; color:#fff; font-size:12px; font-weight:700; display:inline-flex; align-items:center; justify-content:center; }
    .qk-nm { font-weight:600; color:#0f172a; }

    table#UserTable tbody td a { display:inline-flex; align-items:center; justify-content:center; width:32px; height:32px; border-radius:9px; border:1px solid #e7eaf0; color:#64748b; margin:0 2px; text-decoration:none; transition:.13s; }
    table#UserTable tbody td a i { font-size:13px !important; }
    table#UserTable tbody td a:hover { background:#eef2ff; color:#4f46e5; border-color:#c7d2fe; }
    table#UserTable tbody td a.modal-delete:hover { background:#fef2f2; color:#dc2626; border-color:#fecaca; }

    .qk-export-btn .fa-download { margin-right:5px; }
    .qk-export-btn:after { content:""; display:inline-block; margin-left:7px; border-left:4px solid transparent; border-right:4px solid transparent; border-top:5px solid currentColor; vertical-align:middle; opacity:.55; }
    div.dt-button-collection { border:1px solid #e7eaf0 !important; border-radius:12px !important; box-shadow:0 14px 34px rgba(15,23,42,.16) !important; padding:6px !important; background:#fff !important; min-width:184px !important; }
    div.dt-button-collection .dt-button { display:block !important; width:100% !important; text-align:left !important; border:0 !important; border-radius:8px !important; margin:1px 0 !important; padding:9px 13px !important; }
    div.dt-button-collection .dt-button:hover { background:#eef2ff !important; color:#4f46e5 !important; }

    .dataTables_info { color:#64748b; font-size:12.5px; }
    .qk-foot { display:flex; align-items:center; justify-content:flex-start; gap:6px 22px; flex-wrap:wrap; padding:12px 2px 2px; }
    .qk-foot .dataTables_info, .qk-foot .dataTables_paginate { padding-top:0; margin:0; }
    .dataTables_paginate .paginate_button { border:1px solid #e7eaf0 !important; border-radius:8px !important; padding:6px 12px !important; margin:0 3px !important; color:#475569 !important; background:#fff !important; font-size:13px; }
    .dataTables_paginate .paginate_button.current, .dataTables_paginate .paginate_button.current:hover { background:#6366f1 !important; border-color:#6366f1 !important; color:#fff !important; }
    .dataTables_paginate .paginate_button:hover:not(.disabled):not(.current) { background:#eef2ff !important; border-color:#c7d2fe !important; color:#4f46e5 !important; }

    @@media (max-width:768px) {
        .dataTables_wrapper { padding:4px 10px 12px; }
        .dataTables_filter { float:none; margin:0 0 8px; }
        .dataTables_filter input { width:100%; min-width:0; box-sizing:border-box; }
        .dt-buttons { width:100%; }
        table#UserTable { min-width:0 !important; }
        table#UserTable thead { display:none; }
        table#UserTable, table#UserTable tbody { display:block; width:100%; }
        table#UserTable tbody tr { display:block; background:#fff; border:1px solid #e7eaf0 !important; border-radius:14px; margin-bottom:12px; padding:4px 13px; box-shadow:0 1px 3px rgba(15,23,42,.07); }
        table#UserTable tbody tr:hover td { background:transparent; }
        table#UserTable tbody td { display:block; width:auto !important; border:0 !important; border-top:1px solid #f3f5f9 !important; padding:10px 0 !important; }
        table#UserTable tbody td:first-child { display:none; }
        table#UserTable tbody td:nth-child(2) { border-top:0 !important; }
        table#UserTable tbody td:has(input.checkbox) { display:none; }
        table#UserTable tbody td a { width:42px; height:42px; }
    }
</style>

<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">Contact Type List</h3>
        <p class="pull-right">

            <i class="ace-icon fa fa-hand-o-right icon-animated-hand-pointer blue"></i>
            <a href="/ContactType/Create" class="btn btn-info modal-create"><i class="glyphicon glyphicon-plus"></i> Create</a>

        </p>
    </div>
    <div class="box-body search-box">
        @*<a class="btn btn-primary" id="srch">
                <i class="glyphicon glyphicon-search"></i> Advanced Search
            </a>*@


        <div class="search-body col-md-12" id="advsearch">
            <form id="search-form">
                <div class="row">
                    <div class="form-group col-md-2">
                        @Html.Label("Type", null, new { @class = "control-label" })
                        @Html.TextBox("ColName", "", new { @class = "form-control input-sm" })
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12">
                        <input type="submit" class="btn btn-submit col-sm-offset-5" value="Submit" />
                        <input type="button" class="btn btn-close" value="Close" />
                    </div>
                </div>
            </form>
        </div>
    </div>
    @using (Html.BeginForm("DeleteAll", "ContactType", FormMethod.Post, new { id = "payform", role = "form" }))
    {
        <div class="box-body">
            <table class="table table-bordered table-hover" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="2">S/N</td>
                        <td data-priority="1">Contact Type</td>
                        <td data-priority="1">Action</td>
                        <td data-priority="2"><input type="checkbox" id="select_all" /></td>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

    }
</div>
@Html.Partial("../Common/_ModalCreate")
@Html.Partial("../Common/_ModalEdit")
@Html.Partial("../Common/_ModalDelete")
@section scripts{
    @Scripts.Render("~/js/jqueryval")
    <script type="text/javascript">
        $(document).ready(function () {
            $('#advsearch').hide();
        });

        var oTable = $('#UserTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "pageLength": 50,
            responsive: false,   // mobile handled by the card layout (parity with Contacts)
            "ajax": {
                "url": '/ContactType/GetContactType',
                "data": function (data) {
                    data.ColName = $('#ColName').val();
                },
                "type": "POST",
                "datatype": "json"

            },
            "columnDefs": [{
                "targets": [2, 3],
                "orderable": false
            }],
            "columns": [
                     {
                    "data": "ContactId", "name": "ContactId",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                {
                    "data": "Type", "name": "Type", "render": function (data, type) {
                        if (type !== 'display') return data || '';
                        var nm = (data || '').toString();
                        var core = nm.replace(/[^a-zA-Z0-9]+/g, ' ').trim();
                        var parts = core.split(/\s+/).filter(function (p) { return p && !/^\d+$/.test(p); });
                        var ini = (((parts[0] || '').charAt(0)) + ((parts[1] || '').charAt(0))).toUpperCase() || (nm.replace(/[^a-zA-Z]/g, '').charAt(0) || '?').toUpperCase();
                        var pal = ['#6366f1', '#0ea5e9', '#10b981', '#f59e0b', '#ec4899', '#8b5cf6', '#14b8a6', '#ef4444'];
                        var h = 0; for (var i = 0; i < nm.length; i++) h = nm.charCodeAt(i) + ((h << 5) - h);
                        var col = pal[Math.abs(h) % pal.length];
                        return '<div class="qk-name"><span class="qk-av" style="background:' + col + '">' + ini + '</span><span class="qk-nm">' + $('<div>').text(nm).html() + '</span></div>';
                    }
                },

                    {
                        "name": "ContactId", "data": function (data) {
                            var rest = "";
                            @{

                                                      actData += "<a class=\"modal-edit\" href=\"/ContactType/Edit/'+ data.ContactId +'\" title=\"Edit ContactType\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";

                                                    actData += "<a class=\"modal-delete\" href=\"/ContactType/Delete/'+ data.ContactId +'\" title=\"Delete ContactType\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";

                                              }
                            return rest = '@Html.Raw(actData)';
                        }
                    },
                     {
                         "name": "ContactId", "data": function (data) {
                             var rest = "";
                             @{

                                         delchk = "<input class=\"checkbox\" type=\"checkbox\" name=\"bill[]\" value='+ data.ContactId +'></input>";

                                 }
                             return rest = '@Html.Raw(delchk)';
                         }
                     },
            ],
            dom: 'Bfrtip',
            buttons: [{
                extend: 'collection',
                text: '<i class="fa fa-download"></i> Export',
                className: 'qk-export-btn',
                autoClose: true,
                buttons: [
             {
                 extend: 'print',//
                 title: "",
                 footer: true,
                 exportOptions: {
                     columns: ':visible'
                 },
                 message: '<table class="tblcompact table table-bordered"><thead>' +
                     ' <tr><th class="text-center"><h3 style="margin-top: 0px;">' + '<h4>Contact Type</h4></th></tr>' +
                     ' <tr><th><span class="text-left"></span><span class="text-right pull-right"> </span></th></tr></thead><tbody><tr><td>',
                 customize: function (win) {
                     // $(win.document.body)
                     //.css('font-size', '10pt')
                     //.css('padding', '1px');
                     $(win.document.body).find('table, th,tr, td ')
                        // .css('border', 'inherit')
                         .css('font-size', '10pt')
                         .css('padding', '5px')
                         .addClass('compact');
                     $(win.document.body).append('</td></tr></tbody>')

                 }
             }, 'copy', 'csv', 'excel',
            {
                extend: 'pdf',//
                title: "Contact Type",
                footer: true,
                orientation: 'landscape',

                pageSize: 'A4',
                exportOptions: {
                    columns: ':visible'
                },
                customize: function (doc) {
                    doc.pageMargins = [10, 10, 10, 10];
                    doc.defaultStyle.fontSize = 10;
                    doc.styles.tableHeader.fontSize = 10;
                    doc.styles.title.fontSize = 12;
                    // Remove spaces around page title
                    doc.content[0].text = doc.content[0].text.trim();

                    doc.styles['td:nth-child(2)'] = {
                        width: '100%',
                        'max-width': '100%'
                    }

                    var objLayout = {};
                    // Horizontal line thickness
                    objLayout['hLineWidth'] = function (i) { return .5; };
                    // Vertikal line thickness
                    objLayout['vLineWidth'] = function (i) { return .5; };
                    //// Horizontal line color
                    //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                    //// Vertical line color
                    //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                    // Left padding of the cell
                    objLayout['paddingLeft'] = function (i) { return 4; };
                    // Right padding of the cell
                    objLayout['paddingRight'] = function (i) { return 4; };
                    // Inject the object in the document
                    doc.content[1].layout = objLayout;
                }
            }]
            }, 'colvis',
                @Html.Raw(deleteBTn)
            ],

            "drawCallback": function (settings) {
                var table = $('#UserTable').DataTable();
                if (!table.data().any()) {
                    $("#sub").hide();
                } else {
                    $("#sub").show();
                }
            }
        });
        $('#UserTable_filter input').attr('placeholder', 'Search contact types…');
        (function () {
            try {
                var $foot = $('<div class="qk-foot"></div>');
                $('#UserTable_info').before($foot);
                $foot.append($('#UserTable_info')).append($('#UserTable_paginate'));
            } catch (e) { }
        })();
        var chkcol = '@userRole';
        if (chkcol == "True") {
            var column1 = oTable.column(3);
            column1.visible(true);
            $('.dt-button.btn-danger').show();
        } else {
            var column1 = oTable.column(3);
            column1.visible(false);
            $('.dt-button.btn-danger').hide();
        }
        $('#srch, .search-box .btn-close').on('click', function (e) {
            $('#advsearch').toggle();

            if ($('#srch').hasClass('btn-primary')) {
                $('#srch').addClass('btn-danger');
                $('#srch').removeClass('btn-primary');
            }
            else if ($('#srch').hasClass('btn-danger')) {
                $('#srch').addClass('btn-primary');
                $('#srch').removeClass('btn-danger');
                //
                $('#ColName').val("");
                oTable.draw();
            }
        });
        $('#search-form').on('submit', function (e) {
            e.preventDefault();
            oTable.draw();
        });

        /* function for Create popup */

        $('div').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        });
        $('#modal-create').on('submit', '#createform', function (e) {
            e.preventDefault();
            var url = $('#createform')[0].action;
            var data = $('#createform').serialize();
            createajax(url, data, '#modal-create');
        });


        /* function for Edit popup */

        $('div').on('click', '.modal-edit', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-edit');
        });
        $('#modal-edit').on('submit', '#editform', function (e) {
            e.preventDefault();
            var url = $('#editform')[0].action;
            var data = $('#editform').serialize();
            createajax(url, data, '#modal-edit');
        });

        /* function for delete popup */
        $('#UserTable').on('click', '.modal-delete', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-delete');
        });
        $('#modal-delete').on('submit', '#deleteform', function (e) {
            e.preventDefault();
            var url = $('#deleteform')[0].action;
            var data = $('#deleteform').serialize();
            createajax(url, data, '#modal-delete');
        });
        function reload_table() {
            oTable.clear().draw();
            oTable.ajax.reload(null, false); //reload datatable ajax
            isTicked();
        }
        //select all checkboxes
        $('body').on('change', '#select_all', function () {
            $(".checkbox").prop('checked', $(this).prop("checked")); //change all ".checkbox" checked status
        });
        //".checkbox" change
        $('body').on('change', '.checkbox', function () {

            if (false == $(this).prop("checked")) { //if this Lead Typeis unchecked
                $("#select_all").prop('checked', false); //change "select all" checked status to false
            }
            isTicked();
        });
        isTicked();
    </script>
}


