@model QuickSoft.Models.UserEditDays
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>User Edit Days      </h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("Edit", "UserEditDays", FormMethod.Post, new { id = "editform" }))
    {
        <script type="text/javascript">
            $('form#createform').removeData("validator");
            $('form#createform').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#createform'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        <div class="row">
            <div class="col-md-12">
                <div class="form-group">
                    @Html.Label("Select User", null, htmlAttributes: new { @class = "control-label" }) *
                    @Html.DropDownList("userid", (SelectList)ViewBag.users, "", new { @class = "form-control select2" })

                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="form-group">
                    @Html.Label("Sales in Minutes", null, htmlAttributes: new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.days, new { htmlAttributes = new { @class = "form-control", autofocus = "autofocus", @placeholder = "Enter Days", @required = "required" } })

                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="form-group">
                    @Html.Label("Sales Item in Minutes", null, htmlAttributes: new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.seitem, new { htmlAttributes = new { @class = "form-control", autofocus = "autofocus", @placeholder = "Enter Days", @required = "required" } })

                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="form-group">
                    @Html.Label("Sales Return in Minutes", null, htmlAttributes: new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.srdays, new { htmlAttributes = new { @class = "form-control", autofocus = "autofocus", @placeholder = "Enter Days", @required = "required" } })

                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="form-group">
                    @Html.Label("Purchase in Minutes", null, htmlAttributes: new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.pedays, new { htmlAttributes = new { @class = "form-control", autofocus = "autofocus", @placeholder = "Enter Days", @required = "required" } })

                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="form-group">
                    @Html.Label("Purchase Date in Minutes", null, htmlAttributes: new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.pedate, new { htmlAttributes = new { @class = "form-control", autofocus = "autofocus", @placeholder = "Enter Days", @required = "required" } })

                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="form-group">
                    @Html.Label("Purchase Return in Minutes", null, htmlAttributes: new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.prdays, new { htmlAttributes = new { @class = "form-control", autofocus = "autofocus", @placeholder = "Enter Days", @required = "required" } })

                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="form-group">
                    @Html.Label("Stock in Days", null, htmlAttributes: new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.stkdays, new { htmlAttributes = new { @class = "form-control", autofocus = "autofocus", @placeholder = "Enter Days", @required = "required" } })

                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" value="Save" class="btn btn-info col-sm-offset-4" />
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>
@section scripts{
    @Scripts.Render("~/js/jqueryval")
}
<script>
    $(document).ready(function () {
        $("#userid").select2({});
    });
</script>



