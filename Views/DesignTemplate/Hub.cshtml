@{
    ViewBag.Title = "Custom Design";
    Layout = "~/Views/Shared/_QuickLayout.cshtml";
    var counts = ViewBag.Counts as System.Collections.Generic.Dictionary<string, int> ?? new System.Collections.Generic.Dictionary<string, int>();
    int Cnt(string d) { return counts.ContainsKey(d) ? counts[d] : 0; }
    var docs = new[] {
        new { Key = "Sale",                Title = "Sales Invoice",       Icon = "glyphicon-file",        Desc = "Tax invoices / sales bills" },
        new { Key = "Quotation",           Title = "Quotation",           Icon = "glyphicon-list-alt",    Desc = "Quotations" },
        new { Key = "Estimate",            Title = "Estimate",            Icon = "glyphicon-calculator",  Desc = "Estimates" },
        new { Key = "ProForma",            Title = "Pro Forma Invoice",   Icon = "glyphicon-file",        Desc = "Pro forma invoices" },
        new { Key = "SalesOrder",          Title = "Sales Order",         Icon = "glyphicon-shopping-cart", Desc = "Confirmed customer orders" },
        new { Key = "DeliveryNote",        Title = "Delivery Note",       Icon = "glyphicon-send",        Desc = "Goods delivery notes" },
        new { Key = "CreditNote",          Title = "Credit Note",         Icon = "glyphicon-share-alt",   Desc = "Sales returns / credit notes" },
        new { Key = "PurchaseOrder",       Title = "Purchase Order",      Icon = "glyphicon-tags",        Desc = "Orders to suppliers" },
        new { Key = "PurchaseEntry",       Title = "Purchase Entry",      Icon = "glyphicon-shopping-cart", Desc = "Supplier purchase bills" },
        new { Key = "Receipt",             Title = "Receipt Voucher",     Icon = "glyphicon-import",      Desc = "Money received vouchers" },
        new { Key = "Payment",             Title = "Payment Voucher",     Icon = "glyphicon-export",      Desc = "Money paid vouchers" },
        new { Key = "Cheque",              Title = "Cheque",              Icon = "glyphicon-credit-card", Desc = "Cheque printing layouts" },
        new { Key = "MaterialRequisition", Title = "Material Requisition", Icon = "glyphicon-inbox",      Desc = "Material request forms" },
        new { Key = "TenancyContract",     Title = "Tenancy Contract",    Icon = "glyphicon-home",        Desc = "Real estate tenancy agreements" }
    };
}

<style>
    .cd-wrap { padding: 6px 4px 24px; }
    .cd-head h2 { margin: 0; font-size: 21px; font-weight: 700; color: #0f172a; }
    .cd-head p { margin: 4px 0 22px; color: #64748b; font-size: 13.5px; max-width: 760px; }
    .cd-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 16px; }
    .cd-card { display: flex; gap: 14px; align-items: center; background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; padding: 18px; text-decoration: none; box-shadow: 0 1px 2px rgba(15,23,42,.05), 0 6px 18px rgba(15,23,42,.05); transition: box-shadow .15s, transform .15s, border-color .15s; }
    .cd-card:hover { box-shadow: 0 10px 30px rgba(99,102,241,.18); transform: translateY(-2px); border-color: #c7d2fe; text-decoration: none; }
    .cd-ic { flex: 0 0 auto; width: 52px; height: 52px; border-radius: 14px; background: linear-gradient(135deg, #6366f1, #3b82f6); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 22px; box-shadow: 0 8px 20px rgba(99,102,241,.35); }
    .cd-tx { flex: 1; min-width: 0; }
    .cd-tx .t { font-weight: 700; color: #0f172a; font-size: 15.5px; }
    .cd-tx .d { color: #64748b; font-size: 12.5px; margin-top: 1px; }
    .cd-tx .c { margin-top: 6px; }
    .cd-badge { display: inline-block; background: #eef2ff; color: #3730a3; font-size: 11px; font-weight: 700; border-radius: 20px; padding: 2px 9px; }
    .cd-arrow { color: #c7d2fe; font-size: 18px; }
</style>

<div class="content-wrapper-inner cd-wrap">
    <div class="cd-head" style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;flex-wrap:wrap;">
        <div>
            <h2><i class="glyphicon glyphicon-pencil" style="color:#6366f1;"></i> Custom Design</h2>
            <p>Design and manage the print templates for every document — drag &amp; drop your logo, fields, tables and totals.
               Pick a document type below to see its template list and create new designs. All custom-design settings live here.</p>
        </div>
        <a href="@Url.Action("PrintLog","DesignTemplate")" class="btn btn-default" title="Who printed what, and when"><i class="glyphicon glyphicon-list-alt"></i> Print Log</a>
    </div>

    <div class="cd-grid">
        @foreach (var d in docs)
        {
            <a class="cd-card" href="@Url.Action("Index", "DesignTemplate", new { docType = d.Key })">
                <span class="cd-ic"><i class="glyphicon @d.Icon"></i></span>
                <span class="cd-tx">
                    <span class="t">@d.Title</span>
                    <span class="d">@d.Desc</span>
                    <span class="c"><span class="cd-badge">@Cnt(d.Key) template@(Cnt(d.Key) == 1 ? "" : "s")</span></span>
                </span>
                <span class="cd-arrow">&rsaquo;</span>
            </a>
        }
    </div>
</div>
