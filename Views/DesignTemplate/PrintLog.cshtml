@model System.Collections.Generic.List<QuickSoft.Models.LogManager>
@{
    ViewBag.Title = "Print Log";
    Layout = "~/Views/Shared/_QuickLayout.cshtml";
    var q = (string)ViewBag.Query;
}

<style>
    .plog-wrap { padding: 6px 4px 24px; }
    .plog-head { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; margin-bottom:16px; }
    .plog-head h2 { margin:0; font-size:20px; font-weight:700; color:#0f172a; }
    .plog-head p  { margin:2px 0 0; color:#64748b; font-size:13px; }
    .plog-card { background:#fff; border:1px solid #e2e8f0; border-radius:14px; overflow:hidden; box-shadow:0 1px 2px rgba(15,23,42,.05),0 6px 18px rgba(15,23,42,.05); }
    .plog-tools { display:flex; gap:8px; align-items:center; padding:12px 14px; border-bottom:1px solid #f1f5f9; flex-wrap:wrap; }
    .plog-tools input[type=text] { border:1px solid #cbd5e1; border-radius:8px; padding:6px 10px; min-width:220px; font-size:13px; }
    table.plog { width:100%; border-collapse:collapse; font-size:13px; }
    table.plog th { text-align:left; padding:10px 14px; color:#475569; font-weight:700; background:#f8fafc; border-bottom:1px solid #e2e8f0; white-space:nowrap; }
    table.plog td { padding:9px 14px; border-bottom:1px solid #f1f5f9; color:#0f172a; vertical-align:top; }
    table.plog tr:hover td { background:#fafbff; }
    .plog-when { color:#64748b; white-space:nowrap; }
    .plog-user { font-weight:600; }
    .plog-ip { color:#94a3b8; font-size:11.5px; }
    .plog-empty { padding:28px 14px; text-align:center; color:#94a3b8; }
</style>

<div class="content-wrapper-inner plog-wrap">
    <div class="plog-head">
        <div>
            <h2><i class="glyphicon glyphicon-list-alt" style="color:#6366f1;"></i> Print Log</h2>
            <p>Every cheque, invoice and document printed through the template engine &mdash; who printed it, when, and on which template.</p>
        </div>
        <a href="@Url.Action("Hub","DesignTemplate")" class="btn btn-default"><i class="glyphicon glyphicon-arrow-left"></i> Design Templates</a>
    </div>

    <div class="plog-card">
        <form method="get" action="@Url.Action("PrintLog","DesignTemplate")" class="plog-tools">
            <input type="text" name="q" value="@q" placeholder="Search user or document…" />
            <button type="submit" class="btn btn-primary btn-sm"><i class="glyphicon glyphicon-search"></i> Search</button>
            @if (!string.IsNullOrWhiteSpace(q))
            {
                <a href="@Url.Action("PrintLog","DesignTemplate")" class="btn btn-default btn-sm">Clear</a>
            }
            <span style="margin-left:auto;color:#64748b;font-size:12px;">@ViewBag.Count entr@(((int)(ViewBag.Count ?? 0)) == 1 ? "y" : "ies") shown</span>
        </form>

        @if (Model.Count == 0)
        {
            <div class="plog-empty"><i class="glyphicon glyphicon-inbox" style="font-size:26px;"></i><br />No print activity recorded yet.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="plog">
                    <thead>
                        <tr>
                            <th>When</th>
                            <th>User</th>
                            <th>Document / Template</th>
                            <th>IP</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var l in Model)
                        {
                            <tr>
                                <td class="plog-when">@l.LogTime.ToString("dd-MM-yyyy HH:mm")</td>
                                <td class="plog-user">@l.User</td>
                                <td>@l.LogDetails</td>
                                <td class="plog-ip">@l.LogIP</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
