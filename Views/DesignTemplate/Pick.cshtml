@model System.Collections.Generic.List<QuickSoft.Models.InvoiceTemplate>
@{
    Layout = null;
    var invoiceId = ViewBag.InvoiceId;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Choose a print template</title>
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; font-family: 'Segoe UI', Arial, sans-serif; background: #070b1a; color: #e2e8f0; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 24px; }
        .card { width: 100%; max-width: 460px; background: #fff; color: #0f172a; border-radius: 18px; padding: 26px; box-shadow: 0 24px 64px rgba(0,0,0,.4); }
        h1 { font-size: 18px; margin: 0 0 4px; }
        p.sub { color: #64748b; font-size: 13px; margin: 0 0 18px; }
        .opt { display: flex; align-items: center; justify-content: space-between; gap: 12px; border: 1.5px solid #e2e8f0; border-radius: 12px; padding: 12px 14px; margin-bottom: 10px; transition: .12s; }
        .opt:hover { border-color: #6366f1; background: #f5f3ff; }
        .opt .nm { font-weight: 700; }
        .opt .mt { color: #64748b; font-size: 12px; }
        .opt .badge { background: #6366f1; color: #fff; font-size: 10px; font-weight: 700; border-radius: 20px; padding: 2px 8px; margin-left: 6px; }
        .opt a { background: linear-gradient(135deg,#6366f1,#3b82f6); color: #fff; text-decoration: none; font-weight: 600; font-size: 13px; padding: 9px 16px; border-radius: 10px; white-space: nowrap; }
    </style>
</head>
<body>
    <div class="card">
        <h1>🖨 Choose a print template</h1>
        <p class="sub">More than one invoice template exists. Pick one to print this invoice.</p>
        @foreach (var t in Model)
        {
            <div class="opt">
                <div>
                    <span class="nm">@t.Name</span>
                    @if (t.IsDefault) { <span class="badge">DEFAULT</span> }
                    <div class="mt">@t.PaperSize @t.Orientation</div>
                </div>
                <a href="/DesignTemplate/Render/@t.Id?invoiceId=@invoiceId">Print →</a>
            </div>
        }
    </div>
</body>
</html>
