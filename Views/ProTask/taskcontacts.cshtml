                                        <div class="form-group col-md-2 col-xs-12 " id="searchOptionalField2" style="display: none;">
                                            <label class="control-label temp2" for="FieldName"> @Model.FieldMap[i].FieldName</label>
                                            @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef2, "All", new { @id = "Ref2", @class = "form-control input-sm select2 ref" })
                                        </div>
                                    }
                                    if (Model.FieldMap[i].Field == "Ref3")
                                    {
                                        <div class="form-group col-md-2 col-xs-12 " id="searchOptionalField3" style="display: none;">
                                            <label class="control-label temp2" for="FieldName"> @Model.FieldMap[i].FieldName</label>
                                            @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef3, "All", new { @id = "Ref3", @class = "form-control input-sm select2 ref" })
                                        </div>
                                    }
                                    if (Model.FieldMap[i].Field == "Ref4")
                                    {
                                        <div class="form-group col-md-2 col-xs-12 " id="searchOptionalField4" style="display: none;">
                                            <label class="control-label temp2" for="FieldName"> @Model.FieldMap[i].FieldName</label>
                                            @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef4, "All", new { @id = "Ref4", @class = "form-control input-sm select2 ref" })
                                        </div>
                                    }
                                    if (Model.FieldMap[i].Field == "Ref5")
                                    {
                                        <div class="form-group col-md-2 col-xs-12 " id="searchOptionalField5" style="display: none;">
                                            <label class="control-label temp2" for="FieldName"> @Model.FieldMap[i].FieldName</label>
                                            @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef5, "All", new { @id = "Ref5", @class = "form-control input-sm select2 ref" })
                                        </div>
                                    }
                                }
                                else
                                {
                                    if (Model.FieldMap[i].Field == "Ref1")
                                    {
                                        <div class="form-group col-md-2 col-xs-12 " id="searchOptionalField1" style="display: none;">
                                            <label class="control-label temp2" for="FieldName"> @Model.FieldMap[i].FieldName</label>
                                            <input class="form-control select2" id="@Model.FieldMap[i].Field" name="@Model.FieldMap[i].Field" type="text" value="">
                                        </div>
                                    }
                                    if (Model.FieldMap[i].Field == "Ref2")
                                    {
                                        <div class="form-group col-md-2 col-xs-12 " id="searchOptionalField2" style="display: none;">
                                            <label class="control-label temp2" for="FieldName"> @Model.FieldMap[i].FieldName</label>
                                            <input class="form-control select2" id="@Model.FieldMap[i].Field" name="@Model.FieldMap[i].Field" type="text" value="">
                                        </div>
                                    }
                                    if (Model.FieldMap[i].Field == "Ref3")
                                    {
                                        <div class="form-group col-md-2 col-xs-12 " id="searchOptionalField3" style="display: none;">
                                            <label class="control-label temp2" for="FieldName"> @Model.FieldMap[i].FieldName</label>
                                            <input class="form-control select2" id="@Model.FieldMap[i].Field" name="@Model.FieldMap[i].Field" type="text" value="">
                                        </div>
                                    }
                                    if (Model.FieldMap[i].Field == "Ref4")
                                    {
                                        <div class="form-group col-md-2 col-xs-12 " id="searchOptionalField4" style="display: none;">
                                            <label class="control-label temp2" for="FieldName"> @Model.FieldMap[i].FieldName</label>
                                            <input class="form-control select2" id="@Model.FieldMap[i].Field" name="@Model.FieldMap[i].Field" type="text" value="">
                                        </div>
                                    }
                                    if (Model.FieldMap[i].Field == "Ref5")
                                    {
                                        <div class="form-group col-md-2 col-xs-12 " id="searchOptionalField5" style="display: none;">
                                            <label class="control-label temp2" for="FieldName"> @Model.FieldMap[i].FieldName</label>
                                            <input class="form-control select2" id="@Model.FieldMap[i].Field" name="@Model.FieldMap[i].Field" type="text" value="">
                                        </div>
                                    }
                                }
                            }
                        }
