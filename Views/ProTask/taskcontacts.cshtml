<div class="box box-info">
    <div class="box-header with-border">

        <div class="row ">
            <div class="col-md-8 col-xs-4">
                <div class="ribbon">
                    <div class="ribbon4"><h3 class="box-title">&nbsp;&nbsp;Task &nbsp;&nbsp;</h3></div>
                </div>
            </div>
            @*<div class="col-md-10 col-xs-12 task-name-center ">
                    <h3 class="box-title" style="font-size:x-large;">Task</h3>
                </div>*@
            <div class="col-md-4 col-xs-8 pull-right" style="padding: 0px; margin: 10px 0px 0px 0px;">
                @if (User.IsInRole("Dev") || User.IsInRole("Create ProTask"))
                {

                    <div class="col-md-4 col-xs-6 pull-right" style="padding:0px;">
                        <a class="btn btn-info no-border" @*style="background-image: linear-gradient(to bottom,#0d83dd,#325b84 ); border: none!important"*@ href="/ProTask/MyTask">
                            <i class="glyphicon glyphicon-plus" style="color: #325b84"></i> My Task
                        </a>
                    </div>
                    <div class="col-md-4 col-xs-6 pull-right" style="padding:0px;">
                        <a class="btn btn-info no-border" @*style="background-image: linear-gradient(to bottom,#0d83dd,#325b84 ); border: none!important"*@ href="/ProTask/Create">
                            <i class="glyphicon glyphicon-plus" style="color: #325b84"></i> Create
                        </a>
                    </div>

                }
            </div>
        </div>
    </div>
    <div class="col-md-2 col-xs-10 mx-auto" id="taskchecklist" style="padding:0px; margin:0px;">

        <div id="list1" class="dropdown-check-list" tabindex="100">
            <span class="anchor" style="z-index:9;">Select Fields</span>
            <ul class="items">
                <li><input type="checkbox" id="litaskname" class="liname" />Task Name </li>
                @*---------------- For Optional Fields ----------------*@
                @if (Model.FieldMap != null && Model.FieldMap.Count > 0)
                {
                    for (int i = 0; i < Model.FieldMap.Count; i++)
                    {
                        if (Model.FieldMap[i].Field == "Ref1")
                        {
                            <li><input type="checkbox" id="liOptionalField1" />@Model.FieldMap[i].FieldName</li>
                        }
                        if (Model.FieldMap[i].Field == "Ref2")
                        {
                            <li><input type="checkbox" id="liOptionalField2" />@Model.FieldMap[i].FieldName</li>
                        }
                        if (Model.FieldMap[i].Field == "Ref3")
                        {
                            <li><input type="checkbox" id="liOptionalField3" />@Model.FieldMap[i].FieldName</li>
                        }
                        if (Model.FieldMap[i].Field == "Ref4")
                        {
                            <li><input type="checkbox" id="liOptionalField4" />@Model.FieldMap[i].FieldName</li>
                        }
                        if (Model.FieldMap[i].Field == "Ref5")
                        {
                            <li><input type="checkbox" id="liOptionalField5" />@Model.FieldMap[i].FieldName</li>
                        }
                    }
                }
                <li><input type="checkbox" id="litaskstatus" />Task Status</li>
                <li><input type="checkbox" id="liOpnCls" />Open / Close</li>
                <li><input type="checkbox" id="limobile" />Mobile</li>
                <li><input type="checkbox" id="lilocation" />Location</li>
                <li><input type="checkbox" id="lifromdate" />From Date</li>
                <li><input type="checkbox" id="litodate" />To Date</li>
                <li><input type="checkbox" id="litasktype" />Task Type</li>
                <li><input type="checkbox" id="lileadpipelncust" />Lead/Pipeline/Customer</li>
                <li><input type="checkbox" id="liprojects" />Projects</li>
                <li><input type="checkbox" id="licreatedby" />Created By</li>
                <li><input type="checkbox" id="lipriority" />Priority</li>
                <li><input type="checkbox" id="lisalesperson" />Sales Person</li>
                <li><input type="checkbox" id="lireminderdate" />Reminder Date</li>
                <li><input type="checkbox" id="lireminderstatus" />Reminder Status</li>
                <li><input type="checkbox" id="lilastupdated" />Last Updated</li>
                <li><input type="checkbox" id="liassignedto" />Assigned To</li>
                <li><input type="checkbox" id="liInvnoremarks" />Invoice No / Remarks</li>
                @if (@ViewBag.BusiType == "Workshop")
                {
                    <li><input type="checkbox" id="liWorkshop" />Work Shop</li>
                }
            </ul>
        </div>
    </div>

    <div class="col-md-9 col-xs-12">

