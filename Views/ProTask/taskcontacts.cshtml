                                            @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef1, "All", new { @id = "Ref1", @class = "form-control input-sm select2 ref" })
                                        </div>
                                    }
                                    if (Model.FieldMap[i].Field == "Ref2")
