<div id="printit" class="hidden">
    <style>
        #reftable td {
            border: none important;
        }

        @@media print {
            #reftable td {
                border: none !important;
            }
        }
    </style>
    <section class="invoice print">
        <div class="row" id="header">
            <div class="col-xs-12">
                <div class="text-center" id="comHeader">
                    @if (@ViewBag.HeadCheck != 0)
                    {
                        @Html.Partial("../Common/_CompanyHeader")
                    }
                </div>
                <div class="text-center">
                    <style type="text/css">
                        @@media print {
                            body, .print {
                                border: 0px !important;
                            }

                            body, .print {
                                border: 1px !important;
                            }

                            .table-bordered td, .table-bordered th {
                                border: 1px solid #898989 !important;
                            }
                        }

                        body .print {
                            font-size: 12px;
                        }

                        .print .table-nob tr th {
                            width: 40%;
                        }
                    </style>
                    <h4>
                        <strong>RECEIPT VOUCHER</strong>
                        @*@if (@ViewBag.CTaxRegNo != null)
                            {
                                <small class="taxno">Tax RegNo رقم التسجيل الضريبي: @ViewBag.CTaxRegNo</small>
                            }*@
                    </h4>
                </div>
            </div>
        </div>
        <hr class="lbreak" />
        <div class="row invoice-info">
            <div class="col-xs-12 table-responsive">
                <table class="table table-bordered">
                    <tr>
                        <td style="border-right: 0px;">
                            <table class="table-nob noborder" style="border: 0px;width: 50%;">
                                <tr>
                                    <th>Voucher No </th>
                                    <td> <label id="lblBillNo"></label></td>
                                </tr>
                                <tr>
                                    <th>Date </th>
                                    <td> <label id="lblDate"></label></td>
                                </tr>
                                <tr>
                                    <th>Mode Of Payment</th>
                                    <td> <label id="lblmode"></label></td>
                                </tr>
                                <tr class="OnlineTransfer">
                                    <th>Bank</th>
                                    <td> <label id="lblbank"></label></td>
                                </tr>
                                <tr class="OnlineTransfer">
                                    <th>Cheque No</th>
                                    <td>: <label id="lblcheque"></label></td>
                                </tr>

                                @* field mapping *@
                                <tr id="divRef1" hidden>
                                    <th id="IblRef1"></th>
                                    <td>: <label id="IblRef1Val"></label></td>
                                </tr>
                                <tr id="divRef2" hidden>
                                    <th id="IblRef2"></th>
                                    <td>: <label id="IblRef2Val"></label></td>
                                </tr>
                                <tr id="divRef3" hidden>
                                    <th id="IblRef3"></th>
                                    <td>: <label id="IblRef3Val"></label></td>
                                </tr>
                                <tr id="divRef4" hidden>
                                    <th id="IblRef4"></th>
                                    <td>: <label id="IblRef4Val"></label></td>
                                </tr>
                                <tr id="divRef5" hidden>
                                    <th id="IblRef5"></th>
                                    <td>: <label id="IblRef5Val"></label></td>
                                </tr>
                            </table>
                        </td>
                        <td style="border: none;">
                            <table class="table-nob noborder" style="border: 0px;width: 50%;">
                                <tr id="divmopp" hidden>
                                    <th>MOPayment</th>
                                    <td>: <label id="lblMOPayment"></label></td>
                                </tr>
                                <tr id="divchqnoo" hidden>
                                    <th>Cheque No</th>
                                    <td>: <label id="lblChequeNo"></label></td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>
            </div>
        </div>
        <div class="clearfix"></div>
        <div class="row">
            <div class="col-xs-12 table-responsive">
                <table class="table table-bordered" id="itemtable">
                    <thead>
                        <tr class="bg-gray">
                            <th>S/N </th>
                            <th>Details </th>
                            <th></th>
                            <th>Amount</th>
                        </tr>
                    </thead>
                    <tbody class="noborder">


                        <tr>
                            <td>1</td>
                            <td>Cr <label id="lblcreditor"></label></td>
                            <td></td>
                            <td><label id="lblcrediamt"></label></td>
                        </tr>
                        <tr id="discountid">
                            <td>3</td>
                            <td>Dr Discount</td>
                            <td><label id="lbldiscount"></label></td>
                            <td></td>
                        </tr>

                        <tr class="border-top">
                            <td>Total مجموع: </td>
                            <td><label id="lblAmtWord"></label> </td>
                            <td><label id="lbldebitsums"></label></td>
                            <td><label id="lblcreditsum"></label></td>
                        </tr>
                        <tr class="tabletitle thead" id="Amttable">
                            <td colspan="6">
                                <b><u>Being Invoice No :</u></b>
                                <table class="table" id="reftable">
                                    <tbody></tbody>
                                </table>
                            </td>

                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="col-xs-6 table-responsive">
                @*Balance : -
                    <table class="table table-bordered" id="itemtable1"></table>*@
            </div>
            <div class="col-xs-12 table-responsive">
                <table class="table table-bordered" id="itemtable2"></table>
            </div>
        </div>
        <div class="row">
            <div class="col-xs-12 table-responsive">
                <table class="table table-bordered second-table"></table>
            </div>
        </div>

        <div class="row">
            <div class="col-xs-12">
                @if (@ViewBag.HeadCheck != 0)
                {

                    @Html.Partial("../Common/_CompanyFooter")

                }
            </div>
        </div>
    </section>
</div>
