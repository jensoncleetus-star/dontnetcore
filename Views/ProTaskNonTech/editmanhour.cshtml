@model QuickSoft.ViewModel.ProTaskViewModel
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Update Duration</h4>
</div>
<div class="modal-body">

    @using (Html.BeginForm("editmanhour", "ProTaskNonTech", FormMethod.Post, new { id = "createform" }))
    {
       
        @Html.HiddenFor(m=>m.ProTaskId)
        <input type="hidden" name="id" value="@ViewBag.empdetailid"/>
        <div class="row">
            <div class="col-md-6 form-group hidden">
                @Html.LabelFor(model => model.StartDate, htmlAttributes: new { @class = "control-label" })
                <div class="input-group date">
                    <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                    @Html.TextBoxFor(m => m.StartDate, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                </div>
            </div>
            <div class="form-group col-md-6">
                <div class="bootstrap-timepicker">
                    @Html.LabelFor(m => m.StartTime, new { @class = "control-label" })*
                    <div class="input-group">
                        @Html.TextBoxFor(m => m.StartTime, "{0:hh:mm tt}", new { @class = "form-control timepicker", @autocomplete = "off", @value = "" })
                        <div class="input-group-addon">
                            <i class="fa fa-clock-o"></i>
                        </div>
                    </div>
                </div>
            </div>

        </div>
        <div class="row">
            <div class="col-md-6 form-group hidden">
                @Html.LabelFor(model => model.EndDate, htmlAttributes: new { @class = "control-label" })
                <div class="input-group date">
                    <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                    @Html.TextBoxFor(m => m.EndDate, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                </div>
            </div>
            <div class="form-group col-md-6">
                <div class="bootstrap-timepicker">
                    @Html.LabelFor(m => m.EndTime, new { @class = "control-label" })*
                    <div class="input-group">
                        @Html.TextBoxFor(m => m.EndTime, "{0:hh:mm tt}", new { @class = "form-control timepicker", @autocomplete = "off", @value = "" })
                        <div class="input-group-addon">
                            <i class="fa fa-clock-o"></i>
                        </div>
                    </div>
                </div>
            </div>

        </div>


        <div class="form-actions no-color">
            <input type="submit" value="Save" class="btn btn-submit col-sm-offset-4" />
            <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal">
        </div>
    }
</div>


