<div class="box box-info">
    <div class="box-header with-border">
        <div class="row">
            <div class="col-md-9 col-xs-8">
                <div class="ribbon">
                    <div class="ribbon4"><h3 class="box-title">&nbsp;&nbsp;Shared Account List &nbsp;&nbsp;</h3></div>
                </div>
            </div>
            <div class="col-md-3 col-xs-4">
                <p class="pull-right">
                    <a href="/SharedAccount/Create" style="background-image: linear-gradient(to bottom,#0d83dd,#325b84 ); border: none!important" class="btn btn-info modal-create"><i class="glyphicon glyphicon-plus"></i> Create</a>
                </p>
            </div>
        </div>
    </div>
    <div class="box-body search-box">
        @*<a class="btn btn-primary" id="srch">
                <i class="glyphicon glyphicon-search"></i> Advanced Search
            </a>*@


        @*<div class="search-body col-md-12" id="advsearch">
            <form id="search-form">
                <div class="row">
