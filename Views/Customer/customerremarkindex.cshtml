<style type="text/css">
    input[type="search"] {
        border-radius: 17px;
    }

    body {
        font-family: 'Open Sans', sans-serif;
        line-height: 1.25;
    }

    .btn-primary {
        color: #fff;
        background-color: #2196f3;
        border-color: #2196f3;
        border-radius: 50%;
        width: 30px;
        height: 30px;
        border: none;
        padding: 5px;
    }

    .btn-warning {
        color: #fff;
        background-color: #f44336;
