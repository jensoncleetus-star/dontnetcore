                                                        @{


                                                            if (Model != null && Model.LstCutomerDocument != null && Model.LstCutomerDocument.Count > 0)
                                                            {
                                                                foreach (var item in Model.LstCutomerDocument.ToList())
                                                                {
                                                                    List<QuickSoft.Models.DocumentType> doclist = ViewBag.DocList;

