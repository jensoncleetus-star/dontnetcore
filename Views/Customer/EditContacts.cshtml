        //Function to check correct format for Mobile Number
        //MobileNo is not passed in fetched rows(Edit Mode Rows)
        function CheckMobileNo(MobileNo, i) {
            var Mobile;

            if (MobileNo == "") {
                Mobile = document.getElementById("Mobile[" + i + "]").value;
                Mobile = Mobile.replace(/^0+/, '');
                document.getElementById("Mobile[" + i + "]").value = Mobile;
            }
            else
                Mobile = MobileNo;

            var NumbersOnly = /[^0-9]/g;
            var NewMob = (Mobile.replace(NumbersOnly, ""));

            if (Mobile != NewMob) {
                alert("Please Select Correct Format For Mobile..(Numbers Only)");

                if (MobileNo == "") {
                    document.getElementById("Mobile[" + i + "]").value = "";
                    document.getElementById("Mobile[" + i + "]").focus();
                }
                else {
                    var opt = '<option value="" selected>5xxxxxxxx</option>'
                    $("#Mobile" + i).append(opt);
                    mobileload();
                }
            }
            else if (Mobile.length > 9) {
                alert("Only 9 numbers are allowed...")

                if (MobileNo == "") {
                    document.getElementById("Mobile[" + i + "]").value = "";
                    document.getElementById("Mobile[" + i + "]").focus();
                }
                else {
                    var opt = '<option value="" selected >5xxxxxxxx</option>'

                    $("#Mobile" + i).append(opt);
                    mobileload();
                }
            }
        }

        function loadcontact(i, obj) {
            $('.mobilenumber').select2('destroy');
            var s = $("#Mobile" + i).val();
            s = s.replace(/^0+/, '');
            var opt = '<option value="' + s + '" selected>' + s + '</option>'
            $("#Mobile" + i).append(opt);
            mobileload();
            $.ajax({
                url: "/Supplier/getcontactsbymobile",
                type: "GET",
                dataType: "JSON",
                data: { mobile: obj.value },
                success: function (result) {

                    $("#firstname" + i).val(result[0].FirstName);
                    $("#lastname" + i).val(result[0].LastName);
                    $("#Website" + i).val(result[0].Website);
                    $('.emailid').select2('destroy');
                    var opt = '<option value="' + result[0].EmailId + '" selected>' + result[0].EmailId + '</option>'
                    $("#EmailId" + i).append(opt);

                    $("#EmailId" + i).val(result[0].EmailId);

                    //$("#Mobile" + i).val(result[0].MobileNum);
                    $("#CountryID" + i).val(result[0].CountryID);
                    $("#Name" + i).val(result[0].Name + "," + result[0].Address);
                    $("#ContactTypeID" + i).val(result[0].ContactTypeID);

                    emailload();
                }
            });
            //Function to check correct format for Mobile Number
            CheckMobileNo(s, i);
        }
        function loadcontactemail(i, obj) {
            $.ajax({
                url: "/Customer/getcontactsbyemail",
                type: "GET",
