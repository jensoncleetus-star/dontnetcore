<html lang="en">
<head>

    <!-- Required meta tags -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Quicknet Computers</title>
    <!-- plugins:css -->

    <link rel="stylesheet" href="~/Content/login/fonts/font-awesome-4.7.0/css/font-awesome.min.css">

    <link rel="stylesheet" href="~/Content/css/shared/style.css">
    <!-- endinject -->
    <!-- Layout styles -->
    <link rel="stylesheet" href="~/Content/css/demo_1/style.css">
    <!-- End Layout styles -->

    <style>
        #file {
            -webkit-border-top-right-radius: 17px;
            -webkit-border-bottom-right-radius: 17px;
            -moz-border-radius-topright: 17px;
            -moz-border-radius-bottomright: 17px;
            border-top-right-radius: 17px;
            border-bottom-right-radius: 17px;
        }

        .btn.btn-fw {
            min-width: 120px;
            float: left;
            margin-bottom: .4rem;
        }

        .fa-4x {
            color: blue;
        }

        .fa-plus-circle:hover {
            color: black;
        }


        .input-group-btn .sh-align {
            height: 100% !important;
            position: absolute;
            right: -21px;
            /*bottom: 30px;*/
            font-size: 20px;
        }

        @@media only screen and (max-width: 420px) {
            .sh-align {
                position: relative;
                bottom: -2px;
                right: -50%;
                transform: scale(1.19) !important;
            }
        }
    </style>
</head>
<body>
    <div class="container-scroller">

        @using (Html.BeginForm("Edit/"+Model.CustomerID, "Customer", FormMethod.Post, new { id = "createForm", role = "form", enctype = "multipart/form-data" }))
