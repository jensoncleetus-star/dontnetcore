                    <br />
                    <label class="control-label">Price Category</label>
                    <div class="input-group">

                        @Html.DropDownListFor(m => m.Category, (SelectList)ViewBag.Categorys, "", new { @class = "form-control select2", tabindex = 12 })


                    </div>
