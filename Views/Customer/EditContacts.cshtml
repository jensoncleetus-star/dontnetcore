                                                    <div class="col-md-3">
                                                        <br />
                                                        <label class="control-label">Price Category*</label>
                                                        <div class="input-group">

                                                            @Html.DropDownListFor(m => m.Category, (SelectList)ViewBag.Categorys, "", new { id = "ddlPricecategory", @class = "form-control select2", tabindex = 14 })
                                                            <span class="input-group-btn">
