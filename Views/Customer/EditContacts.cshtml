                                                                <a class="btn bg-black no-border" href="/Customer/Edit/@ViewBag.preEntry">
                                                                    <i class="fa fa-step-backward"></i>
                                                                </a>
                                                            }
                                                        }
                                                        @if (@ViewBag.nxtEntry != 0)
                                                        {
                                                            if (User.IsInRole("Dev") || User.IsInRole("Edit Customer"))
                                                            {
                                                                <a class="btn bg-black no-border" href="/Customer/Edit/@ViewBag.nxtEntry">
                                                                    <i class="fa fa-step-forward"></i>
                                                                </a>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            if (User.IsInRole("Dev") || User.IsInRole("Create Customer"))
                                                            {
                                                                <a class="btn bg-black no-border" href="/Customer/Create">
                                                                    <i class="fa fa-step-forward"></i>
                                                                </a>
                                                            }
                                                        }

                                                        @if (User.IsInRole("Dev") || User.IsInRole("Customer"))
                                                        {
                                                            <a class="btn btn-success no-border" href="/Customer">
                                                                <i class="fa fa-fw fa-history"></i> Customer
                                                            </a>
                                                        }
                                                    </div>
                                                </h4>
                                            </div>

                                        </div>
                                    </div>

                                    <form action="#">
