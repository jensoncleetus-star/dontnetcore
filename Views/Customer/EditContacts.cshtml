                                                                @Html.EditorFor(model => model.Note, new { htmlAttributes = new { @class = "form-control", @placeholder = "Notes", tabindex = 2 } })
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <button style="width: 200px;" type="submit" class="btn btn-primary btn-rounded btn-fw  add_field_button2">Balance &ensp;<i class="fa fa-plus-circle" aria-hidden="true"></i></button>
                                                <br><br>
                                                <div class="form-group input_fields_wrap2">
                                                    <table class="table table-condensed table-hover" id="blnceTbl">

                                                        @{


                                                            if (Model != null && Model.LstSalesEntry != null && Model.LstSalesEntry.Count > 0)
