@model QuickSoft.ViewModel.CustomerViewModel
@{
    ViewBag.Title = "Create Customer";
    ViewBag.SubTitle = "Customer";
    ViewBag.Active = "Master";
    int di = 0;
    int si = 0;
    int ci = 0;
}
<html lang="en">
<head>

    @Scripts.Render("~/js/bootstrap-datepicker")
    @Styles.Render("~/css/bootstrap-datepicker")



    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">

    <link rel="stylesheet" href="~/Content/css/shared/style.css">
    <!-- endinject -->
    <!-- Layout styles -->
    <link rel="stylesheet" href="~/Content/css/demo_1/style.css">
    <!-- End Layout styles -->

    <style>
        #file {
            -webkit-border-top-right-radius: 17px;
            -webkit-border-bottom-right-radius: 17px;
            -moz-border-radius-topright: 17px;
            -moz-border-radius-bottomright: 17px;
            border-top-right-radius: 17px;
            border-bottom-right-radius: 17px;
        }

        .btn.btn-fw {
            min-width: 120px;
            float: left;
            margin-bottom: .4rem;
        }

        .iconalign {
            transform: scale(1.5) !important;
        }

        .fa-4x {
            color: blue;
        }

        .fa-plus-circle:hover {
            color: black;
        }

        /************/
        .input-group-btn .sh-align {
            height: 100% !important;
            position: absolute;
            right: -21px;
            /* bottom: 30px; */
            font-size: 13px;
        }


        .convert li {
            display: inline-block;
            padding: 5px;
            background-color: ghostwhite;
        }

        .convert ul {
            list-style: none;
        }

        @@media only screen and (max-width: 420px) {
            .sh-align {
                position: relative;
                bottom: -2px;
                right: -50%;
                transform: scale(1.19) !important;
            }
        }
    </style>
</head>
<body>
    <div class="container-scroller">
        @using (Html.BeginForm("Create", "Customer", FormMethod.Post, new { id = "creForm", role = "form", enctype = "multipart/form-data" }))
        {
            <input type="hidden" name="leadid" value="@ViewBag.leadid" />
            <!-- partial:../../partials/_navbar.html -->
            <!-- partial -->
            <div class="container-fluid page-body-wrapper">
                <!-- partial -->
                <div class="main-panel">
                    <div class="">
                        <div class="col-md-12 grid-margin stretch-card" style=" padding-top: 0.8rem;">
                            <div class="card">

                                <div class="card-body">
                                    <div class="form-group">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <h4 class="card-title">
                                                    <b>CREATE CUSTOMER</b>

                                                    @if (User.IsInRole("Dev") || User.IsInRole("Customer"))
                                                    {
                                                        <a class="btn btn-outline-primary btn-fw" style="float: right;" href="/Customer">
                                                            <i class="fa fa-fw fa-history"></i> List
                                                        </a>
                                                    }
                                                    @*<button type="button" class="btn btn-outline-primary btn-fw" style="float: right;">List</button>
                                                        <button type="button" class="btn btn-outline-primary btn-fw" style="float: right;">Contact</button>*@
                                                </h4>
                                            </div>

                                        </div>
                                    </div>

                                    <form action="#">
                                        @Html.AntiForgeryToken()
                                        @Html.ValidationSummary("", new { @class = "alert alert-danger AlertDiv" })
                                        @Html.HiddenFor(model => model.ConvertFrom)
                                        @Html.HiddenFor(model => model.CustomerID)
                                        <input type="hidden" class="form-control" id="RowCount" value="0" placeholder="">
                                        <input type="hidden" class="form-control" id="balanceRowcount" value="0" placeholder="">
                                        <input type="hidden" class="form-control" id="documentRowcount" value="0" placeholder="">
                                        @if(1==1)// (ViewBag.shortform == 0)
                                        {
                                            <style>
                                                .hidell,.hideall
                                                {
                                                    display:none;

                                                }
                                            </style>

                                        }

                                        <div class="form-group ">
                                            <div class="row">
                                                <div class="col-md-3 hidell">
                                                    <label class="control-label">Customer Code</label>
                                                    <div class="input-group">
                                                        @Html.EditorFor(model => model.CustomerCode, new { htmlAttributes = new { @class = "form-control", tabindex = 1 } })
                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="control-label">Customer Name*</label>
                                                    <div class="input-group">

                                                        @Html.DropDownListFor(model => model.CustomerName, (SelectList)ViewBag.CustName, new { @class = "form-control input-sm select2", @required = "required", @placeholder = "customer Name", tabindex = 2 })


                                                    </div>
                                                </div>
                                                <div class="col-sm-3 ">

                                                    <label class="control-label">Sales Person*</label>
                                                    <div class="input-group">
                                                        @Html.DropDownListFor(m => m.SalesPerson, (SelectList)ViewBag.Empl, "", new { id = "ddlEmployee", @class = "form-control select2", tabindex = 6, @required = "required" })

                                                        @if (@ViewBag.Employees == 0)
                                                        {
                                                            <span class="input-group-btn">
                                                                <a href="/Employee/Create" class="btn btn-flat sh-align" target="_new" title="Add SalesPerson"><i class="fa fa-4x fa-plus-circle iconalign"></i></a>

                                                            </span>
                                                        }
                                                        else
                                                        {
                                                            <span class="input-group-btn">
                                                                <a href="/SalesExecutive/Create" class="btn btn-flat sh-align" target="_new" title=" Add SalesPerson"><i class="fa fa-4x fa-plus-circle iconalign"></i></a>

                                                            </span>
                                                        }
                                                    </div>
                                                </div>
                                                <div class="col-md-1">
                                                    <a href="javascript:void(0)" onclick="triggers()">More</a>
                                                </div>
                                                <div class="col-md-3 hidell">
                                                    <label class="control-label">Customer Alias</label>
                                                    <div class="input-group">
                                                        @Html.EditorFor(model => model.Alias, new { htmlAttributes = new { @class = "form-control", tabindex = 3 } })
                                                    </div>
                                                </div>

                                                <div class="col-md-3 hidell">
                                                    <label class="control-label">Customer Print Name</label>
                                                    <div class="input-group">
                                                        @Html.EditorFor(model => model.CustomerPrintName, new { @id = "efCustmPrintName", htmlAttributes = new { @class = "form-control", tabindex = 4 } })
                                                    </div>
                                                </div>
                                            </div>
                                            </div>

                                        <div class="form-group hidell">
                                            <div class="row">
                                                <div class="col-md-3">
                                                    <label class="control-label">TAX ID TRN</label>
                                                    <div class="input-group">
                                                        @Html.EditorFor(model => model.TaxID_TRN, new { htmlAttributes = new { @type = "text", @class = "form-control", tabindex = 5 } })
                                                        @*<input type="text" class="form-control" placeholder="TAX ID TRN">*@
                                                    </div>
                                                </div>



                                               

                                                <div class="col-md-3">
                                                    <label class="control-label">Source of lead</label>
                                                    <div class="input-group">
                                                        @Html.DropDownListFor(m => m.SourceOfLead, (SelectList)ViewBag.SrcOfLead, "", new { id = "ddlSrcLead", @class = "form-control select2", tabindex = 7, @required = "required" })
                                                        <span class="input-group-btn">
                                                            <a href="/SourceOfLead/Index" class="btn btn-flat sh-align" target="_new" title="Add Source"><i class="fa fa-4x fa-plus-circle iconalign"></i></a>

                                                        </span>
                                                    </div>
                                                </div>

                                                @*//*@
                                                @if (User.IsInRole("Dev") || User.IsInRole("Customer Credit Limit Visibile"))
                                                {
                                                    <div class="col-md-3">
                                                        <label class="control-label">Credit Limit</label>
                                                        <div class="input-group">
                                                            @Html.EditorFor(model => model.CreditLimit, new { htmlAttributes = new { @type = "number", @class = "form-control", @placeholder = "Enter Credit Limit", tabindex = 8 } })
                                                            <label class="control-label">Include PDC</label>  @Html.CheckBoxFor(Model => Model.includepdc, new { @class = "checkbox" })
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>

                                        <div class="form-group hideall">
                                            <div class="row ">

                                                <div class="col-md-3">
                                                    <label class="control-label">Credit Period</label>
                                                    <div class="input-group">
                                                        @Html.EditorFor(model => model.CreditPeriod, new { htmlAttributes = new { @class = "form-control", @placeholder = "Credit Period", tabindex = 9 } })
                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="control-label">Country</label>
                                                    <div class="input-group">
                                                        @Html.DropDownListFor(m => m.CountryID, (SelectList)ViewBag.Cntry, "", new { id = "ddlCountryID", @class = "form-control select2", tabindex = 10 })
                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="control-label">Emirates/States</label>
                                                    <div class="input-group">

                                                        @Html.DropDownListFor(m => m.StateID, (SelectList)ViewBag.States, "", new { id = "ddlStateID", @class = "form-control select2", tabindex = 11 })

                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="control-label">Location</label>
                                                    <div class="input-group">

                                                        @Html.DropDownListFor(m => m.LocationID, (SelectList)ViewBag.Location, "", new { id = "ddlLocationID", @class = "form-control select2", tabindex = 12 })


                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <br />
                                                    <label class="control-label">Customer Address</label>
                                                    <div class="input-group">
                                                        @Html.TextAreaFor(model => model.Addres, new { @class = "form-control", @placeholder = "Enter Address", tabindex = 13 })
                                                    </div>
                                                </div>
                                                @*<!==================================================================================>*@

                                                @*<div class="col-md-3">
            <br />
            <label class="control-label">Price Category</label>
            <div class="input-group">
                @Html.DropDownListFor(m => m.Category, (SelectList)ViewBag.Categorys, "", new { @class = "form-control select2", tabindex = 14 })
            </div>
        </div>*@
                                                @*<!++++++++===============================================================================>*@
                                                <div class="col-md-3">
                                                    <br />
                                                    <label class="control-label">Price Category*</label>
                                                    <div class="input-group">

                                                        @Html.DropDownListFor(m => m.Category, (SelectList)ViewBag.Categorys, "", new { id = "ddlPricecategory", @class = "form-control select2", tabindex = 14, @required = "required" })
                                                        <span class="input-group-btn">
                                                            <a href="/PriceCategory/Index" class="btn btn-flat sh-align" target="_new" title="Add Price Category"><i class="fa fa-4x fa-plus-circle iconalign"></i></a>

                                                        </span>

                                                    </div>
                                                </div>
                                                @*<!+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++>*@

                                                <div class="col-md-3">
                                                    <br />
                                                    <label class="control-label">Customer Type*</label>
                                                    <div class="input-group">

                                                        @Html.DropDownListFor(m => m.CustomerType, (SelectList)ViewBag.custmertype, new { id = "ddlCustomerType", @class = "form-control select2", tabindex = 14, @required = "required" })
                                                        <span class="input-group-btn">
                                                            <a href="/Customertype/Index" class="btn btn-flat sh-align" target="_new" title="Add CustomerType"><i class="fa fa-4x fa-plus-circle iconalign"></i></a>

                                                        </span>

                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <br />
                                                    <label class="control-label">Terms and Conditions</label>
                                                    <div class="input-group">
                                                        @Html.TextAreaFor(model => model.TermsandCondition, new { @class = "form-control", @placeholder = "Enter Terms and Conditions", tabindex = 13 })
                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <br />
                                                    <label class="control-label">Lattitude</label>
                                                    <div class="input-group">
                                                        @Html.EditorFor(model => model.Lattitude, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Lattitude", tabindex = 9, @type = "number" } })
                                                    </div>
                                                </div>

                                                <div class="col-md-3">
                                                    <br />
                                                    <label class="control-label">Longitude</label>
                                                    <div class="input-group">
                                                        @Html.EditorFor(model => model.Longitude, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Longitude", tabindex = 10, @type = "number" } })
                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <br />
                                                    <label class="control-label">Create Login</label>
                                                    <div class="input-group">
                                                        @Html.CheckBoxFor(model => model.createuser)
                                                    </div>
                                                </div>
                                                <div class="col-md-2  createuser" style="display:none;">
                                                    <br />
                                                    <label class="control-label">User Name*</label>
                                                    <div class="input-group">

                                                        @Html.EditorFor(m => m.username, new { @id = "username", htmlAttributes = new { @class = "form-control", tabindex = 50 } })

                                                    </div>
                                                </div>
                                                <div class="col-md-2  createuser" style="display:none;">
                                                    <br />
                                                    <label class="control-label">Password*</label>
                                                    <div class="input-group">

                                                        @Html.EditorFor(m => m.password, new { @id = "password", htmlAttributes = new { @class = "form-control", tabindex = 51 } })

                                                    </div>
                                                </div>

                                                <div class="col-md-2">
                                                    <br />
                                                    @Html.LabelFor(model => model.bonuscheck, htmlAttributes: new { @class = "control-label" })

                                                    <div class="input-group">

                                                        @Html.CheckBoxFor(m => m.bonuscheck, new { htmlAttributes = new { @class = "form-control", tabindex = 51 } })

                                                    </div>
                                                </div>
                                                
                                                <div id="bonusblock" style="display:none" class="col-md-6">
                                                    <div class="row">
                                                        <div class="col-md-4">
                                                            <br />
                                                            @Html.LabelFor(model => model.startbonusdate, htmlAttributes: new { @class = "control-label temp2" })
                                                            <div class="input-group date">
                                                                <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                                                                @Html.TextBoxFor(m => m.startbonusdate, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm" })
                                                            </div>
                                                        </div>
                                                        <div class="col-md-4">
                                                            <br />
                                                            @Html.LabelFor(model => model.bonusbaseamount, htmlAttributes: new { @class = "control-label" })

                                                            <div class="input-group">
                                                                @Html.EnumDropDownListFor(model => model.bonusbaseamount, new { @class = "form-control", tabindex = 27 })


                                                            </div>
                                                        </div>
                                                        <div class="col-md-4">
                                                            <br />
                                                            @Html.LabelFor(model => model.bonuspercentage, htmlAttributes: new { @class = "control-label" })

                                                            <div class="input-group">

                                                                @Html.EditorFor(m => m.bonuspercentage, new { htmlAttributes = new { @class = "form-control", tabindex = 51, max = "100" } })

                                                            </div>
                                                        </div>
                                                        <div class="col-md-4">
                                                            <br />
                                                            @Html.LabelFor(model => model.bonusclimembility, htmlAttributes: new { @class = "control-label" })

                                                            <div class="input-group">

                                                                @Html.EditorFor(m => m.bonusclimembility, new { htmlAttributes = new { @class = "form-control", tabindex = 51, max = "100" } })

                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>





                                            </div>
                                        </div>

                                        <button style="width: 200px;" type="submit" class="btn btn-primary btn-rounded btn-fw add_field_button0" tabindex=15>Add Contact &ensp;<i class="fa fa-plus-circle" aria-hidden="true"></i></button>
                                        <br><br>
                                        <div class="form-group input_fields_wrap">

                                            <table class="table table-condensed table-hover" id="contactTbl">

                                                @{


                                                    if (Model != null && Model.LstContacts != null && Model.LstContacts.Count > 0)
                                                    {
                                                        List<QuickSoft.Models.Country> CountryCodelist = ViewBag.CountryCodes;

                                                        foreach (var item in Model.LstContacts.ToList())
                                                        {
                                                            <div class="row" style="margin-top: 1rem;">
                                                                <div class="col-md-2" hidden>
                                                                    <label class="control-label">id</label>
                                                                    <div class="input-group">
                                                                        <input type="text" value="@item.ContactID" name="LstContacts[@ci].ContactID" class="form-control">
                                                                    </div>
                                                                </div>
                                                                <div class="col-md-2">
                                                                    <label class="control-label">TypeOfContact </label>
                                                                    <div class="input-group">
                                                                        @*<input type="hidden" name="LstContacts[@(di)].ContactId" value="@item.ContactID" id="docu" />*@
                                                                        <select id="Type" class="form-control" name="LstContacts[@ci].ContactTypeID">
                                                                            @{
                                                                                List<QuickSoft.Models.ContactType> typelist = ViewBag.TypeList;

                                                                                foreach (var data in typelist)
                                                                                {
                                                                                    if (data.ContactId == item.ContactTypeID)
                                                                                    {
                                                                                        <option value="@data.ContactId" selected="selected">@data.Type</option>
                                                                                    }
                                                                                    else if (data.ContactId == 4)
                                                                                    {
                                                                                        <option value="@data.ContactId" selected="selected">@data.Type</option>
                                                                                    }
                                                                                    else
                                                                                    {
                                                                                        <option value="@data.ContactId">@data.Type</option>
                                                                                    }
                                                                                }
                                                                            }

                                                                        </select>
                                                                    </div>
                                                                </div>
                                                                <div class="col-md-3">

                                                                    <label class="control-label">First Name</label>'
                                                                    <div class="input-group">

                                                                        <input type="text" name="LstContacts[@ci].FirstName" class="form-control" value="@item.FirstName" required>'

                                                                    </div>

                                                                </div>
                                                                <div class="col-md-3">

                                                                    <label class="control-label">Last Name</label>
                                                                    <div class="input-group">

                                                                        <input type="text" name="LstContacts[@ci].LastName" class="form-control" value="@item.LastName">

                                                                    </div>

                                                                </div>
                                                                <div class="col-md-3">

                                                                    <label class="control-label">Company Name</label>'
                                                                    <div class="input-group">

                                                                        <input type="text" name="LstContacts[@ci].Name" class="form-control" value="@item.Name">

                                                                    </div>

                                                                </div>

                                                            </div>


                                                            <div class="row" style="margin-top: 1rem;">
                                                                <div class="col-md-2">
                                                                    <label class="control-label">Country Code</label>
                                                                    <div class="input-group">
                                                                        <select id="Type" class="form-control" name="LstContacts[@ci].CountryID">
                                                                            @{
                                                                                foreach (var data in CountryCodelist)
                                                                                {
                                                                                    if (data.CountryID == item.CountryID)
                                                                                    {
                                                                                        <option value="@data.CountryID" selected="selected">@data.CountryName (@data.CountryCode)</option>
                                                                                    }
                                                                                    else if (data.CountryID == 1)
                                                                                    {
                                                                                        <option value="@data.CountryID" selected="selected">@data.CountryName (@data.CountryCode)</option>
                                                                                    }
                                                                                    else
                                                                                    {
                                                                                        <option value="@data.CountryID">@data.CountryName (@data.CountryCode)</option>
                                                                                    }
                                                                                }
                                                                            }

                                                                        </select>
                                                                        @*<input type="text" value="@item.Country" name="LstContacts[@ci].Country" class="form-control">*@
                                                                    </div>
                                                                </div>
                                                                <div class="col-md-3">
                                                                    <label class="control-label">Mobile</label>
                                                                    <div class="input-group">
                                                                        <input type="text" value="@item.Mobile" name="LstContacts[@ci].Mobile" class="form-control">
                                                                    </div>
                                                                </div>
                                                                <div class="col-md-3">
                                                                    <label class="control-label">Email Id</label>
                                                                    <div class="input-group">
                                                                        <input type="email" value="@item.EmailId" name="LstContacts[@ci].EmailId" class="form-control">
                                                                    </div>
                                                                </div>
                                                                <div class="col-md-3">
                                                                    <label class="control-label">Website</label>
                                                                    <div class="input-group">
                                                                        <input type="text" value="@item.Website" name="LstContacts[@ci].Website" class="form-control">
                                                                    </div>
                                                                </div>
                                                                <a href="javascript:void(0);" class="remove_button"><i style="color:red; top: 1.3rem; position: relative; " class="fa fa-trash" aria-hidden="true"></i></a>
                                                            </div>

                                                            ci++;

                                                        }
                                                    }
                                                }
                                            </table>


                                        </div>
                                        <div class="form-group input_fields_wrap0">

                                        </div>

                                        <button style="width: 200px;" onclick="myFunction()" type="button" class="hideall btn btn-primary btn-rounded btn-fw" tabindex="21">More Details &ensp;<i class="fa fa-arrow-circle-o-down" aria-hidden="true"></i></button>
                                        <br><br>
                                        <div class="form-group" id="myDIV" style="display:none">
                                            <div class="row">
                                                <div class="col-md-2">
                                                    <label class="control-label">Opening Balance</label>
                                                    <div class="input-group">
                                                        @*<input type="text" name="model.OpnBalance" class="form-control" placeholder="Enter Opening Balance" required>*@
                                                        @Html.EditorFor(model => model.OpnBalance, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Opening Balance", tabindex = 0 } })
                                                        <div class="input-group-addon no-padding dcwidth">
                                                            @Html.EnumDropDownListFor(model => model.DC, new { @class = "form-control", tabindex = 27 })
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-2">
                                                    <label class="control-label">Pre Year Balance</label>
                                                    <div class="input-group">
                                                        @*<input type="text" name="model.PreYearBalance" class="form-control" placeholder="Pre year balance" required>*@
                                                        @Html.EditorFor(model => model.PreYearBalance, new { htmlAttributes = new { @class = "form-control", @placeholder = "Pre year balance", tabindex = 1 } })
                                                    </div>
                                                </div>
                                                <div class="col-md-8">
                                                    <label class="control-label">Notes</label>
                                                    <div class="input-group">
                                                        @*<input type="text" name="model => model.Note" class="form-control" placeholder="Notes" required>*@
                                                        @Html.EditorFor(model => model.Note, new { htmlAttributes = new { @class = "form-control", @placeholder = "Notes", tabindex = 2 } })
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <button style="width: 200px;" type="submit" class="btn btn-primary btn-rounded btn-fw  add_field_button2 hideall">Balance &ensp;<i class="fa fa-plus-circle" aria-hidden="true"></i></button>
                                        <br><br>
                                        <div class="form-group input_fields_wrap2">

                                        </div>



                                        <button style="width: 200px;" type="submit" class= "hideall btn btn-primary btn-rounded btn-fw add_field_button3">Documents Attach &ensp;<i class="fa fa-plus-circle" aria-hidden="true"></i></button>
                                        <br>
                                        <br>
                                        <div class="form-group input_fields_wrap3">
                                            <table class="table table-condensed table-hover" id="tblDcmnt">
                                                @{


                                                    if (Model != null && Model.LstLeadDocument != null && Model.LstLeadDocument.Count > 0)
                                                    {
                                                        foreach (var item in Model.LstLeadDocument.ToList())
                                                        {
                                                            List<QuickSoft.Models.DocumentType> doclist = ViewBag.DocList;

