                $.each(data, function (i, v1) {
                    v += "<option value=" + v1.Value + ">" + v1.Text + "</option>";
                });
                $("#ddlStateID").html(v);
            });
        });
        
        $("#bonuscheck").change(function () {
            if ($(this).is(':checked')) {
                $("#bonusblock").show();
            }
            else {
                $("#bonusblock").hide();
            }
        });
        $("#createuser").change(function () {
            if ($(this).is(':checked')) {
                $(".createuser").show();
            }
            else {
                $(".createuser").hide();
            }

        });
        $("#ddlStateID").change(function () {
            var id = $(this).val();
            $("#ddlLocationID").empty();
            $.get("Location_Bind", { state_id: id }, function (data) {
                var v = "<option value='0'>---Select---</option>";
                $.each(data, function (i, v1) {
                    v += "<option value=" + v1.Value + ">" + v1.Text + "</option>";
                });
                $("#ddlLocationID").html(v);
            });
        });
    });

    //Function to check correct format for Mobile Number
    function CheckMobileNo(MobileNo, i) {

        var NumbersOnly = /[^0-9]/g;
        var NewMob = (MobileNo.replace(NumbersOnly, ""));

        if (MobileNo != NewMob) {
            alert("Please Select Correct Format For Mobile..(Numbers Only)");

            var opt = '<option value="" selected>5xxxxxxxx</option>'

            $("#Mobile" + i).append(opt);
            mobileload();
        }
        else if (MobileNo.length > 9) {
            alert("Only 9 numbers are allowed...")
            var opt = '<option value="" selected >5xxxxxxxx</option>'

            $("#Mobile" + i).append(opt);
            mobileload();
        }
        else {

            //Replacing 0 at first position of Mobile No.
            var NwMob = MobileNo.replace(/^0+/, '');

            var opt = '<option value="' + NwMob + '" selected>' + NwMob + '</option>'

            $("#Mobile" + i).append(opt);
            mobileload();
        }
    }
</script>


