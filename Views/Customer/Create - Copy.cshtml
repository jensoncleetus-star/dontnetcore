                    '<input type="date" name="LstCutomerDocument[' + rowno + '].Expiry" class="form-control" placeholder="Expiry" required>' +
                    '</div>' +
                    '</div>' +
                    '<div class="col-md-3">' +
                    '<div class="input-group">' +
                    '<input type="text" name="LstCutomerDocument[' + rowno + '].Notes" class="form-control" placeholder="Notes" required>' +
                    ' </div>' +
                    '</div>' +
                    '<div class="col-md-3">' +
                    ' <div class="input-group">' +
                    '<input type="file" name="LstCutomerDocument[' + rowno + '].FilePath" class="form-control file-upload-info"  placeholder="Choose image" required>' +

                    '</div>' +
                    '</div>' +
                    '<a href="javascript:void(0);" class="remove_button"><i style="color:red;" class="fa fa-trash" aria-hidden="true"></i></a></div>');

                x++;

                rowno++;
                document.getElementById('documentRowcount').value = rowno;
            }
        });
        $(wrapper3).on('click', '.remove_button', function (e) {
            e.preventDefault();

            $(this).parent('div').remove(); //Remove field html
            x--; //Decrement field counter
        });
    });
</script>

