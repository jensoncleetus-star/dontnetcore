@model QuickSoft.ViewModel.EmployeeViewModel
@{
    ViewBag.Title = "Sales Executive List";
    ViewBag.SubTitle = "List Sales Executive";
    ViewBag.Active = "Settings";
    string actData = "";
    bool userRole = false;
    string delchk = "";
    if (User.IsInRole("Dev") || User.IsInRole("Delete Sales Executive"))
    {
        userRole = true;
    }
}
<style>
    .dropdown-check-list {
        display: inline-block;
    }

        .dropdown-check-list .anchor {
            position: relative;
            cursor: pointer;
            display: inline-block;
            padding: 5px 50px 5px 10px;
            border: 1px solid #ccc;
            /*  min-width:210px;*/
        }

            .dropdown-check-list .anchor:after {
                position: absolute;
                content: "";
                border-left: 2px solid black;
                border-top: 2px solid black;
                padding: 5px;
                right: 10px;
                top: 20%;
                -moz-transform: rotate(-135deg);
                -ms-transform: rotate(-135deg);
                -o-transform: rotate(-135deg);
                -webkit-transform: rotate(-135deg);
                transform: rotate(-135deg);
            }

            .dropdown-check-list .anchor:active:after {
                right: 8px;
                top: 21%;
            }

        .dropdown-check-list ul.items {
            padding: 2px;
            display: none;
            margin: 0;
            border: 1px solid #ccc;
            border-top: none;
        }

            .dropdown-check-list ul.items li {
                list-style: none;
            }

        .dropdown-check-list.visible .anchor {
            color: #0094ff;
        }

        .dropdown-check-list.visible .items {
            display: block;
            /* min-width:210px;*/
        }
</style>

<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">Sales Executive</h3>
        <div class="pull-right">
            @if (User.IsInRole("Dev") || User.IsInRole("Create Sales Executive"))
            {
                <i class="ace-icon fa fa-hand-o-right icon-animated-hand-pointer blue"></i>
                <a class="btn btn-info no-border" href="/SalesExecutive/Create">
                    <i class="glyphicon glyphicon-plus"></i> Create Sales Executive
                </a>
            }
        </div>
        <div class="row">
            <div class="col-md-2">
                <div id="list1" class="dropdown-check-list" tabindex="100">
                    <span class="anchor" style="z-index:0">Select Fields</span>
                    <ul class="items" style="position: absolute; z-index: 9999999; background-color: white;">
                        <li><input type="checkbox" id="liname" class="liname" value="Name" />Name </li>
                        <li><input type="checkbox" id="liphone" value="Phone" />Phone </li>
                        <li><input type="checkbox" id="liemail" value="Email" />Email</li>
                    </ul>
                </div>
            </div>
            <div class="col-md-12">
                <div class="box-body search-box" id="advsearchlist">
                    <div class="search-body col-md-12" style="background:none;">
                        <form id="search-form">
                            <div class="row">
                                <div class="form-group col-md-2" id="searchname">
                                    @Html.Label("Name", null, new { @class = "control-label" })
                                    @Html.DropDownList("Name", (SelectList)ViewBag.ExeName, "All", new { @class = "form-control" })
                                    @*@Html.TextBox("Name", "", new { @class = "form-control input-sm" })*@
                                </div>
                                @*<div class="form-group col-md-2">
                                            @Html.Label("Sales Executive Code", null, new { @class = "control-label" })
                                            @Html.DropDownList("Code",(SelectList)ViewBag.SalesExeCode,"All", new { @class = "form-control" })
                                    </div>*@
                                <div class="form-group col-md-2" id="searchphoneno">
                                    @Html.Label("Phone No", null, new { @class = "control-label" })
                                    @Html.TextBox("Phone", "", new { @class = "form-control input-sm" })
                                </div>
                                <div class="form-group col-md-2" id="searchemail">
                                    @Html.Label("Email", null, new { @class = "control-label" })
                                    @Html.TextBox("Email", "", new { @class = "form-control input-sm" })
                                </div>
                                <div class="form-group col-md-2" id="search">
                                    <input type="submit" class="btn btn-submit" value="Submit" />
                                </div>
                                <div class="form-group col-md-2" id="close">
                                    <input type="button" class="btn btn-close" value="Close" />
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @using (Html.BeginForm("DeleteAll", "SalesExecutive", FormMethod.Post, new { id = "payform", role = "form" }))
    {
        <div class="box-body">
            <table class="table table-bordered table-hover" id="MyTable">
                <thead>
                    <tr>
                        <td data-priority="1">#</td>
                        <td data-priority="1">Name</td>
                        <td data-priority="2">Employee Code</td>
                        <td data-priority="3">Address</td>
                        <td data-priority="4">Phone</td>
                        <td data-priority="6">Email</td>
                        @*<td data-priority="6">Branch</td>*@
                        <td data-priority="1"> Action</td>
                        <td data-priority="2"><input type="checkbox" id="select_all" /></td>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
        if (User.IsInRole("Dev") || User.IsInRole("Delete Sales Executive"))
        {
            <div class="box-footer text-right col-md-12" id="sub">
                <button type="submit" id="save" data-confirm="Are u sure want to delete?" class="btn btn-danger">Delete</button>
            </div>
        }
    }
</div>

@Html.Partial("../Common/_ModalChange")
@Html.Partial("../Common/_ModalDelete")

@section scripts{
    <script type="text/javascript">

        $(document).ready(function () {
            $('#advsearchlist').hide();
            $('[data-confirm]').click(function (e) {
                if ($('.checkbox:checked').length > 0) {
                    if (!confirm(jQuery(this).attr("data-confirm"))) {
                        e.preventDefault();
                    }
                } else {
                    alert("Please Select Rows..!!");
                    e.preventDefault();
                }
            });
        });

        var oTable = $('#MyTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "pageLength": 50,
            responsive: false,
            "ajax": {
                "url": '/SalesExecutive/GetData',
                "data": function (data) {
                    data.Name = $('#Name').val();
                    data.Email = $('#Email').val();
                    //data.Code = $('#Code').val();
                    data.Phone = $('#Phone').val();
                },
                "type": "POST",
                "datatype": "json"
            },
            "columnDefs": [{
                "targets": [6,7],
                "orderable": false
            }],
            "columns": [
                     {
                         "data": "id", "name": "id",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                 { "data": "Name", "name": "Name" },
                 { "data": "EMPCode", "name": "EMPCode" },
                 { "data": "Address", "name": "Address" },
                 { "data": "Phone", "name": "Phone" },
                 { "data": "Email", "name": "Email" },
           //      { "data": "Branch", "name": "Branch" },
                 {
                     "name": "id", "data": function (data) {
                         var rest = "";

                             @{
                                 if (User.IsInRole("Dev") || User.IsInRole("Edit Sales Executive"))
                                 {
                                     actData += "<a href=\"/SalesExecutive/Edit/'+ data.id +'\" title=\"Edit Sales Executive\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                                 }
                                 if (User.IsInRole("Dev") || User.IsInRole("Delete Sales Executive"))
                                 {
                                     actData += "<a class=\"modal-delete\" href =\"/SalesExecutive/Delete/'+ data.id +'\" title=\"Delete Sales Executive\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";
                                 }
                             }
                             rest = '@Html.Raw(actData)';

                         return rest;

                     }

                 },
                  {
                      "name": "id", "data": function (data) {
                          var rest = "";
                          @{
                              if (User.IsInRole("Dev") || User.IsInRole("Delete Sales Executive"))
                              {
                                  delchk = "<input class=\"checkbox\" type=\"checkbox\" name=\"bill[]\" value='+ data.id +'></input>";
                              }
                          }
                          return rest = '@Html.Raw(delchk)';
                      }
                  },

            ], "drawCallback": function (settings) {
                var table = $('#MyTable').DataTable();
                if (!table.data().any()) {
                    $("#sub").hide();
                } else {
                    $("#sub").show();
                }
            }
        });

        var chkcol = '@userRole';
        if (chkcol == "True") {
            var column1 = oTable.column(7);
            column1.visible(true);
            $('.dt-button.btn-danger').show();
        }
        else {
            var column1 = oTable.column(7);
            column1.visible(false);
            $('.dt-button.btn-danger').hide();
        }

      //Button Close
      $('#srch, .search-box .btn-close').on('click', function (e) {
          $('#advsearchlist').toggle();

          /*******  To uncheck all the checkboxes in the Select List  ************/
          var checkboxes = document.querySelectorAll("input[type='checkbox']");
          checkboxes.forEach(function (Checkbox) {
              Checkbox.checked = false;
          });

          if ($('#srch').hasClass('btn-primary')) {
              $('#srch').addClass('btn-danger');
              $('#srch').removeClass('btn-primary');
          }
          else {
              if ($('#srch').hasClass('btn-danger')) {
                  $('#srch').addClass('btn-primary');
                  $('#srch').removeClass('btn-danger');
              }
                //location.reload();
              $('#Name').val("").trigger("change");
              $('#Phone').val("");
              $('#Email').val("");
              oTable.draw();
          }
      });

        $('#search-form').on('submit', function (e) {
            e.preventDefault();
            oTable.draw();
        });

        /* function for view detail popup */
        $('#MyTable').on('click', 'a.details', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        })

        /* function for Create popup */

        $('div').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        });

        $('#modal-create').on('submit', '#createform', function (e) {
            e.preventDefault();
            var url = $('#createform')[0].action;
            var data = $('#createform').serialize();
            createajax(url, data, '#modal-create');
        });

        /* function for Edit popup */

        $('div').on('click', '.modal-edit', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-edit');
        });

        $('#modal-edit').on('submit', '#editform', function (e) {
            e.preventDefault();
            var url = $('#editform')[0].action;
            var data = $('#editform').serialize();
            createajax(url, data, '#modal-edit');
        });

        /* function for delete popup */
        $('#MyTable').on('click', '.modal-delete', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-delete');
        });

        $('#modal-delete').on('submit', '#deleteform', function (e) {
            e.preventDefault();
            var url = $('#deleteform')[0].action;
            var data = $('#deleteform').serialize();
            createajax(url, data, '#modal-delete');
        });

        /* chang status */
        $('.table').on('click', '.modal-change', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-change');
        });

        $('#modal-change').on('submit', '#changeform', function (e) {
            e.preventDefault();
            var url = $('#changeform')[0].action;
            var data = $('#changeform').serialize();
            createajax(url, data, '#modal-change');
        });

        function reload_table() {
            oTable.clear().draw();
            oTable.ajax.reload(null, false); //reload datatable ajax
            isTicked();
        }
        //select all checkboxes
        $('body').on('change', '#select_all', function () {
            $(".checkbox").prop('checked', $(this).prop("checked")); //change all ".checkbox" checked status
        });

        //".checkbox" change
        $('body').on('change', '.checkbox', function () {
            //uncheck "select all", if one of the listed checkbox item is unchecked
            if (false == $(this).prop("checked")) { //if this item is unchecked
                $("#select_all").prop('checked', false); //change "select all" checked status to false
            }
            isTicked();
        });
        isTicked();

       var checkList = document.getElementById('list1');

        /******* Function to list and hide dropdown checklist while clicking on 'Select Fields' *******/
        checkList.getElementsByClassName('anchor')[0].onclick = function (evt) {

        if (checkList.classList.contains('visible'))

           checkList.classList.remove('visible');
         else
                checkList.classList.add('visible');

        }

        /******* Function to hide dropdown checklist while clicking outside it *******/
        $(document).on("click", function (event) {

            var element = $("#list1");

            if (element !== event.target && !element.has(event.target).length) {
                  checkList.classList.remove('visible');
            }
        });

        $("ul li input:checkbox").click(function () {
            _show = 0;

            //Name
            if ($("#liname").prop("checked") == true) {
                $("#searchname").show();
                _show = 1;
            }
            else {
                $("#Name").val("").trigger("change");
                $("#searchname").hide();
                oTable.draw();
            }

            //Phone
            if ($("#liphone").prop("checked") == true) {
                $("#searchphoneno").show();
                _show = 1;
            }
            else {
                $("#Phone").val("");
                $("#searchphoneno").hide();
                oTable.draw();
            }

            //Email
            if ($("#liemail").prop("checked") == true) {
                $("#searchemail").show();
                _show = 1;
            }
            else {
                $("#Email").val("");
                $("#searchemail").hide();
                oTable.draw();
            }

            if (_show == 1) {
                $('#advsearchlist').show();
            }
            else {
                $('#advsearchlist').hide();
            }
        });

    </script>
}
