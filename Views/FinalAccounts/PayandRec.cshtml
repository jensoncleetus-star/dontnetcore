@{
    ViewBag.Title = "Payment and Receipt A/C";
    ViewBag.SubTitle = "Accounts";
    ViewBag.Active = "Accounts";
}
<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">Payment and Receipt A/C</h3>
    </div>
    <div class="box-body">
        @using (Html.BeginForm("GetPayandRec", "FinalAccounts", FormMethod.Post, new { id = "fileupload", @class = "form-horizontal" }))
        {
            <div class="form-group">
                <label class="control-label col-md-4">From</label>
                <div class="col-sm-4">
                    <div class="input-group date">
                        @Html.TextBox("fromdate", "", "{0:MM-yyyy}", new { @class = "form-control input-sm", @required = "required", @autocomplete = "off" })
                        <div class="input-group-addon">
                            <i class="fa fa-calendar"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="form-group">
                <label class="control-label col-md-4">To</label>
                <div class="col-sm-4">
                    <div class="input-group date">
                        @Html.TextBox("todate", "", "{0:MM-yyyy}", new { @class = "form-control input-sm", @required = "required", @autocomplete = "off" })
                        <div class="input-group-addon">
                            <i class="fa fa-calendar"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="form-group">
                <label class="control-label col-md-4">Show A/c Level Details</label>
                <div class="col-sm-4">
                    <div class="input-group">
                        <input type="checkbox" name="acinclude" id="acinclude" value="true" />
                    </div>
                </div>
            </div>
            <div class="box-footer col-md-12">
                <button type="submit" class="btn btn-info col-sm-offset-5" id="btn">Submit</button>
                <button type="button" class="btn btn-default" onclick="@("window.location.href='/Home/Index/'");">Cancel</button>
            </div>
        }
    </div>
</div>
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
}
@section Scripts {
    @Scripts.Render("~/js/bootstrap-datepicker")
    <script type="text/javascript">
        $('.date').datepicker({
            format: 'MM-yyyy',
            startView: "months",
            minViewMode: "months",
            autoclose: true,
            allowInputToggle: true
        })
        $(document).ready(function () {
            //for set default date
            $('#todate').datepicker({
                format: 'MM-yyyy',
                startView: "months",
                minViewMode: "months",
                autoclose: true,
                allowInputToggle: true
            });
            $('#fromdate').datepicker({
                format: 'MM-yyyy',
                startView: "months",
                minViewMode: "months",
                autoclose: true,
                allowInputToggle: true
            });

            var date = new Date();
            var today = new Date(date.getFullYear(), date.getMonth());
            var priordate = new Date(date.getFullYear(), date.getMonth() - 1);
            $('#todate').datepicker('setDate', today);
            $('#fromdate').datepicker('setDate', priordate);
        });
    </script>
}