@model QuickSoft.Models.CompanyHeader
@{
    ViewBag.Title = "Edit Company Header";
    ViewBag.SubTitle = "Company Header";
    ViewBag.Active = "CompanyHeader";
}
<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">Edit Company Header</h3>
        <div class="pull-right">
            <i class="ace-icon fa fa-hand-o-right icon-animated-hand-pointer blue"></i>
            <a class="btn btn-success no-border" href="/CompanyHeader/Index">
                <i class="fa fa-fw fa-history"></i> Company Header List
            </a>
        </div>
    </div>
    <div class="box-body">
            @using (Html.BeginForm("Edit", "CompanyHeader", FormMethod.Post, new { id = "popupFormEdit", enctype = "multipart/form-data" }))
            {
            @Html.ValidationSummary("", new { @class = "alert alert-danger AlertDiv" })
            @Html.AntiForgeryToken()
            <div class="row">
                <div class="form-group col-md-12">
                    @Html.LabelFor(m => m.Name, new { @class = "control-label" }) *
                    @Html.TextBoxFor(m => m.Name, new { @class = "form-control input-sm", @required = "required" })

                </div>
                <div class="form-group col-md-12">
                    @Html.LabelFor(m => m.Header, new { @class = "control-label" })*
                    @Html.TextAreaFor(m => m.Header, new { @class = "form-control input-sm", @rows = 10 , @required = "required" })
                </div>
                <div class="form-group col-md-12">
                    @Html.LabelFor(m => m.Footer, new { @class = "control-label" })
                    @Html.TextAreaFor(m => m.Footer, new { @class = "form-control input-sm", @rows = 10 })
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <div class="form-group">
                        <input type="submit" class="btn btn-info col-sm-offset-5" value="Update" />
                        <input type="button" class="btn btn-default" onclick="@("window.location.href='" + @Url.Action("Index", "CompanyHeader") + "'");" value="Cancel" data-dismiss="modal" />
                    </div>
                </div>
            </div>
        }
    </div>
</div>
@section scripts{
    @Scripts.Render("~/js/ckeditor")
    @Scripts.Render("~/js/jqueryval")

<script type="text/javascript">
        $(document).ready(function () {
            $(function () {
                CKEDITOR.replace('Header');
                CKEDITOR.replace('Footer');
            });
        });
</script>
}