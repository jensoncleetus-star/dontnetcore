            $(document).ready(function () {

                $('#From').datepicker({
                    format: 'MM-yyyy',
                    startView: "months",
                    minViewMode: "months",
                    autoclose: true,
                    allowInputToggle: true
                });
                $('#To').datepicker({
                    format: 'MM-yyyy',
                    startView: "months",
                    minViewMode: "months",
                    autoclose: true,
                    allowInputToggle: true
                });
                var date = new Date();
                var today = new Date(date.getFullYear(), date.getMonth());
                var priordate = new Date(date.getFullYear(), date.getMonth() - 1);
