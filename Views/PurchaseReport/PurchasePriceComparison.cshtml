    })

    $(document).ready(function () {
        $("a").hover(
            function () {
                var title = $(this).attr("data-title");  // extracts the title using the data-title attr applied to the 'a' tag
                $('<div/>', { // creates a dynamic div element on the fly
                    text: title,
                    class: 'boxx'
                }).appendTo(this);  // append to 'a' element
            }, function () {
                $(document).find("div.boxx").remove(); // on hover out, finds the dynamic element and removes it.
            }
        );
        /*datatable still hided before clicking the submit button*/

        $("#StockReport").hide()
        /*end*/
        $("#divpaymethod").hide();
        $('#HireTypeDiv').hide();
        //$("#SaleType").val(1);
        $('#SaleType option:contains(POS)').remove();

        $("#SaleType").prop('selectedIndex', 0);
        CallRepSupplier();
        $('#To').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });
        $('#From').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });

        var date = new Date();
        var today = new Date(date.getFullYear(), date.getMonth(), date.getDate());
        var priordate = new Date(new Date().setDate(today.getDate() - 30));
        $('#To').datepicker('setDate', today);
        $('#From').datepicker('setDate', priordate);
        //---

        //GetProjectWithAll();
        //GetTaskWithAll();
        ItemSearchable();
        // Material Center
        $("#ddlItemBrand").select2({
            placeholder: 'Search Item Brand',
            minimumInputLength: 0,
            ajax: {
                url: "/ItemBrand/SearchBrand",
                dataType: 'json',
                type: "POST",
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term,
                        page: params.page,
                        x: "all"
                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 1;

                    return {
                        results: data
                    };
                },
                cache: true
            },
        });
        $("#ddlItemCategory").select2({
            placeholder: 'Search Item Category',
            minimumInputLength: 0,
            ajax: {
                url: "/ItemCategory/SearchCategory",
                dataType: 'json',
                type: "POST",
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term,
                        page: params.page,
                        x: "All"
                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 1;

                    return {
                        results: data
                    };
                },
                cache: true
            },
        });
        

    });

    function customertype() {
        var type = $("#ddlType").val();
        if (type == 0) {
            $('#divpaymethod').hide();
        } else {
            $('#divpaymethod').show();
        }
    }


    function HType() {
        var Type = $('#SaleType').val();
        if (Type == 2) {
            $('#HireTypeDiv').show();
        }
        else {
            $('#HireTypeDiv').hide();
        }
    }
    function DateSet() {
        var ndate = $('#FromDate').val();

        $('#ToDate').datepicker({
            startDate: ndate,
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });

    }

   

