@{

    ViewBag.Title = "Search Purchase Entry";
    ViewBag.SubTitle = "Purchase Report";
    ViewBag.Active = "Reports";
    string actData = "";
    string actData2 = "";
    string actData3 = "";
    string actData4 = "";
    string posfun = "";

}
@*<style>
    #ddlType, #InvoiceNo{
        margin-bottom:-4px!important;
    }
</style>*@
<style>
    .datepicker {
        border-radius: 0px !important;
        /*height:30px!important;*/
    }

    .input-sm {
        height: 30px !important;
        border-radius: 0px !important;
    }

    .fa-calendar {
        margin-left: -5px !important;
    }
    .boxx {
        border: 1px solid green;
        position: absolute;
        color: white;
        top: 19px;
        left: 30px;
        background-color: black;
    }
</style>

<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">Search Purchase Entry</h3>
    </div>

    <div class="box-body">
        <form id="search-form">
            @using (Html.BeginForm("PurchasePriceComparison", "PurchaseReport", FormMethod.Post, new { id = "popupForm", target = "_new" }))
            {
                
                <div class="form-group col-md-2">
                    @Html.Label("Compair Steps", null, new { @class = "control-label" })
                    @Html.DropDownList("comparprices", new SelectList(new List<SelectListItem>
                        {
                            new SelectListItem() {Text = "10", Value="10"},
                            new SelectListItem() {Text = "9", Value="9"},
                            new SelectListItem() {Text = "8", Value="8"},
                            new SelectListItem() {Text = "7", Value="7"},
                            new SelectListItem() {Text = "6", Value="6"},
                            new SelectListItem() {Text = "5", Value="5"},
                            new SelectListItem() {Text = "4", Value="4"},
                            new SelectListItem() {Text = "3", Value="3"},
                            new SelectListItem() {Text = "2", Value="2"},

                        }, "Value", "Text"), new { @class = "form-control input-sm", @name = "ddlType", @onchange = "customertype()" })
                </div>


                <div class="form-group col-md-4">
                    @Html.Label("Supplier", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlSupplier", (SelectList)ViewBag.Supplier, new { @class = "form-control input-sm" })
                </div>

                <div class="form-group col-md-2">
                    @Html.Label("From", null, new { @class = "control-label" })
                    <div class="input-group date">
                        @Html.TextBox("From", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                        <div class="input-group-addon">
                            <i class="fa fa-calendar"></i>
                        </div>
                    </div>
                </div>
                <div class="form-group col-md-2">
                    @Html.Label("To", null, new { @class = "control-label" })
                    <div class="input-group date">
                        @Html.TextBox("To", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                        <div class="input-group-addon">
                            <i class="fa fa-calendar"></i>
                        </div>
                    </div>
                </div>
                <div class="form-group col-md-2" id="creditsale">
                    @Html.Label("Item Category", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlItemCategory", (SelectList)ViewBag.Category, new { @class = "form-control input-sm select2" })
                </div>
                <div class="form-group col-md-2" id="creditsale">
                    @Html.Label("Item Brand", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlItemBrand", (SelectList)ViewBag.Brand, new { @class = "form-control input-sm select2" })
                </div>
                <div class="form-group col-md-2">
                    @Html.Label("Search", null, new { @class = "control-label" })
                    @Html.TextBox("Searchtext", "", new { @class = "form-control input-sm" })
                </div>

                <div class="box-footer col-md-12">
                    <input type="submit" class="btn btn-info col-sm-offset-5" value="Submit" />
                    <button type="button" class="btn btn-default" onclick="@("window.location.href='/Home/Index'");">Cancel</button>
                </div>
            }
        </form>
    </div>
</div>
<div class="box box-default" id="StockReport">
    <div class="box-header with-border">
        <h3 class="box-title">View Purchase Entry Report</h3>
    </div>
    <div class="box-body">
        <input type="hidden" id="cname" value="@ViewBag.CName" />
        <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
        <input type="hidden" id="invoiceno" value="@ViewBag.InvoiceNo" />
        <input type="hidden" id="fromdate" value="@ViewBag.fromdate" />
        <input type="hidden" id="todate" value="@ViewBag.todate" />
        <input type="hidden" id="matcenter" value="@ViewBag.EnableMCcheck" />
        <input type="hidden" id="Scaffold" value="@ViewBag.BusinessType" />
        <div class="box-body">
            <table class="display table table-bordered" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="2">S/N</td>
                        <td data-priority="1">Item Name</td>
                        <td data-priority="2">Price 1</td>

                        <td data-priority="2">Price 2</td>
                        <td data-priority="2">Price 3</td>
                        <td data-priority="2">Price 4</td>
                        <td data-priority="2">Price 5</td>
                        <td data-priority="2">Price 6</td>
                        <td data-priority="2">Price 7</td>
                        <td data-priority="2">Price 8</td>
                        <td data-priority="2">Price 9</td>

                        <td data-priority="2">Price 10</td>
                        <td data-priority="2">Status</td>
                              </tr>
                </thead>
                <tbody></tbody>
                
            </table>
        </div>
    </div>
</div>
@section style{
