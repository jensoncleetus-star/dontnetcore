@model QuickSoft.Models.Team
@{
    ViewBag.Title = "List";
    ViewBag.SubTitle = "Team List";
    ViewBag.Active = "Settings";
    string actData = "";
}
<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">Team List</h3>
        <div class="pull-right">
            @*@if (User.IsInRole("Dev") || User.IsInRole("Create Task Team"))
                {*@
            <i class="ace-icon fa fa-hand-o-right icon-animated-hand-pointer blue"></i>
            <a class="btn btn-info no-border modal-create" href="/Team/Create">
                <i class="glyphicon glyphicon-plus"></i> Create
            </a>
            @*}*@
        </div>
    </div>
    <div class="box-body">
        <table class="table table-bordered table-hover" id="MyTable">
            <thead>
                <tr>
                    <td data-priority="1">#</td>
                    <td data-priority="2">Team Name</td>
                    <td data-priority="2">Team Lead</td>
                    <td data-priority="2">Team Members</td>
                    <td data-priority="2">Team Tag</td>
                    <td data-priority="2">Task Status </td>
                    <td data-priority="2">Lead Status</td>
                    <td data-priority="2">Amc Status</td>
                    <td data-priority="5">CreatedBy</td>
                    <td data-priority="7">Action</td>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

@Html.Partial("../Common/_ModalCreate")
@Html.Partial("../Common/_ModalEdit")
@Html.Partial("../Common/_ModalChange")
@Html.Partial("../Common/_ModalDelete")
@section scripts{
    @Scripts.Render("~/js/jqueryval")
    <script type="text/javascript">
        var oTable = $('#MyTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "pageLength": 50,
            responsive: true,

            "ajax": {
                "url": '/Team/GetTeam',
                "type": "POST",
                "datatype": "json"
            },
            "order": [[0, "desc"]],
            "columnDefs": [{ orderable: false, targets: -1 }],
            "columns": [
                     {
                         "data": "id", "name": "id",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                 { "data": "TeamName", "name": "TeamName" },
                 { "data": "TeamLead", "name": "TeamLead" },
                   {
                       "name": "TeamMembers", "data": function (data) {
                           var datas = "";
                           $.each(data.TeamMembers, function (i, item) {
                               if (datas != "") {
                                   datas += ", ";
                               }
                               datas += item.FirstName + " " + item.LastName;
                           })
                           return datas;
                       }
                   },
                 { "data": "TeamTag", "name": "TeamTag" },
                 {
                     "name": "TaskStatus", "data": function (data) {
                         var datas = "";
                         $.each(data.TaskStatus, function (i, item) {
                             if (datas != "") {
                                 datas += ", ";
                             }
                             datas += item.Name;
                         })
                         return datas;
                     }
                },

                {
                    "name": "LeadStatus", "data": function (data) {
                        var datas = "";
                        $.each(data.LeadStatus, function (i, item) {
                            if (datas != "") {
                                datas += ", ";
                            }
                            datas += item.Name;
                        })
                        return datas;
                    }
                },
                {
                    "name": "AmcStatus", "data": function (data) {
                        var datas = "";
                        $.each(data.AmcStatus, function (i, item) {
                            if (datas != "") {
                                datas += ", ";
                            }
                            datas += item.Name;
                        })
                        return datas;
                    }
                },





                 { "data": "UserName", "name": "UserName" },
                  {
                      "name": "id", "data": function (data) {
                          var rest = "";
                              @{
                                 // if (User.IsInRole("Dev") || User.IsInRole("Edit Task Team"))
                                  //{
                                      actData += "<a class=\"modal-edit\" href=\"/Team/Edit/'+ data.id +'\" title=\"Edit Task Team\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                                 /// }
                                  if (User.IsInRole("Dev") || User.IsInRole("Delete Task Team"))
                                  {
                                      actData += "<a class=\"modal-delete\" href=\"/Team/Delete/'+ data.id +'\" title=\"Delete Task Team\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";
                                  }
                              }
                          return rest = '@Html.Raw(actData)';
                      }
                  },
            ]
        });


        /* function for Create popup */

        $('div').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        });
        $('#modal-create').on('submit', '#createform', function (e) {
            e.preventDefault();
            var url = $('#createform')[0].action;
            var data = $('#createform').serialize();
            createajax(url, data, '#modal-create');
        });


        /* function for Edit popup */

        $('div').on('click', '.modal-edit', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-edit');
        });
        $('#modal-edit').on('submit', '#editform', function (e) {
            e.preventDefault();
            var url = $('#editform')[0].action;
            var data = $('#editform').serialize();
            createajax(url, data, '#modal-edit');
        });

        /* function for delete popup */
        $('#MyTable').on('click', '.modal-delete', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-delete');
        });
        $('#modal-delete').on('submit', '#deleteform', function (e) {
            e.preventDefault();
            var url = $('#deleteform')[0].action;
            var data = $('#deleteform').serialize();
            createajax(url, data, '#modal-delete');
        });

        /* chang status */
        $('.table').on('click', '.modal-change', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-change');
        });
        $('#modal-change').on('submit', '#changeform', function (e) {
            e.preventDefault();
            var url = $('#changeform')[0].action;
            var data = $('#changeform').serialize();
            createajax(url, data, '#modal-change');
        });

        function changecheckbox(obj) {
            if ($(obj).val() == true) {
                $("#TaskStatus").hide();
                $("#LeadStatus").show()

            }
            else {
                $("#TaskStatus").show();
                $("#LeadStatus").hide();
            }
        }
        



    </script>
}