@model QuickSoft.Models.Team
@{
    ViewBag.Title = "List";
    ViewBag.SubTitle = "Team List";
    ViewBag.Active = "Settings";
    string actData = "";
}
@* BOS: Contacts-page parity restyle — scoped (this <style> only loads on /Team) *@
<style type="text/css">
    .box.box-info { border:1px solid #e7eaf0; border-radius:16px; box-shadow:0 1px 2px rgba(15,23,42,.04),0 14px 34px rgba(15,23,42,.07); overflow:visible; }
    .box.box-info > .box-header.with-border { border-bottom:1px solid #eef1f6; padding:13px 18px 9px; }
    .box-title { font-size:18px; font-weight:800; color:#0f172a; letter-spacing:-.2px; position:relative; padding-left:13px; }
    .box-title:before { content:""; position:absolute; left:0; top:3px; bottom:3px; width:4px; border-radius:3px; background:linear-gradient(180deg,#6366f1,#4f46e5); }
    .box-header .pull-right { margin-top:0 !important; }
    .box-header .btn-info, .box-header a.btn-info { background:linear-gradient(135deg,#6366f1,#4f46e5) !important; border:0 !important; color:#fff !important; border-radius:11px; padding:9px 20px; font-weight:700; box-shadow:0 8px 18px rgba(99,102,241,.32); }
    .box-header .btn-info:hover { filter:brightness(1.07); color:#fff !important; }
    .icon-animated-hand-pointer { display:none !important; }

    .dataTables_wrapper { padding:2px 16px 14px; }
    .dataTables_length { padding-top:6px; color:#64748b; font-size:12.5px; }
    .dataTables_length select { border:1.5px solid #e7eaf0; border-radius:9px; padding:6px 10px; margin:0 6px; font-size:13px; }
    .dataTables_filter { float:right; }
    .dataTables_filter label { font-size:0; color:transparent; }
    .dataTables_filter input { border:1.5px solid #e7eaf0 !important; border-radius:10px; padding:9px 14px 9px 34px; min-width:240px; font-size:13.5px; margin-left:0; background:#fff url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' fill='none' stroke='%2394a3b8' stroke-width='2'><circle cx='7' cy='7' r='5'/><path d='M11 11l4 4'/></svg>") no-repeat 11px center; }
    .dataTables_filter input:focus { border-color:#6366f1 !important; box-shadow:0 0 0 3px rgba(99,102,241,.12); outline:none; }

    body .wrapper { overflow:visible; }
    table#MyTable { width:100% !important; border-collapse:separate; border-spacing:0; overflow:visible; }
    table#MyTable thead { position:sticky; top:0; z-index:6; }
    table#MyTable thead td, table#MyTable thead th { position:sticky; top:0; background:#f8fafc !important; color:#475569; font-size:10.5px; font-weight:800; text-transform:uppercase; letter-spacing:.5px; padding:11px 14px; border:0 !important; border-bottom:1.5px solid #e7eaf0 !important; white-space:nowrap; box-shadow:0 1px 0 #e7eaf0; }
    table#MyTable tbody td { padding:11px 14px; border:0 !important; border-bottom:1px solid #f1f5f9 !important; font-size:13px; color:#1e293b; vertical-align:middle; }
    table#MyTable tbody tr:hover td { background:#f8faff; }
    .dataTables_empty { color:#94a3b8 !important; padding:40px !important; text-align:center; }

    .qk-name { display:flex; align-items:center; gap:11px; }
    .qk-av { flex:0 0 auto; width:34px; height:34px; border-radius:9px; color:#fff; font-size:12px; font-weight:700; display:inline-flex; align-items:center; justify-content:center; }
    .qk-nm { font-weight:600; color:#0f172a; }
    .qk-user { display:inline-flex; align-items:center; gap:8px; }
    .qk-user-av { flex:0 0 auto; width:24px; height:24px; border-radius:50%; background:#fbeaf0; color:#993556; font-size:10px; font-weight:700; display:inline-flex; align-items:center; justify-content:center; }

    table#MyTable tbody td a { display:inline-flex; align-items:center; justify-content:center; width:32px; height:32px; border-radius:9px; border:1px solid #e7eaf0; color:#64748b; margin:0 2px; text-decoration:none; transition:.13s; }
    table#MyTable tbody td a i { font-size:13px !important; }
    table#MyTable tbody td a:hover { background:#eef2ff; color:#4f46e5; border-color:#c7d2fe; }
    table#MyTable tbody td a.modal-delete:hover { background:#fef2f2; color:#dc2626; border-color:#fecaca; }

    .dataTables_info { color:#64748b; font-size:12.5px; }
    .qk-foot { display:flex; align-items:center; justify-content:flex-start; gap:6px 22px; flex-wrap:wrap; padding:12px 2px 2px; }
    .qk-foot .dataTables_info, .qk-foot .dataTables_paginate { padding-top:0; margin:0; }
    .dataTables_paginate .paginate_button { border:1px solid #e7eaf0 !important; border-radius:8px !important; padding:6px 12px !important; margin:0 3px !important; color:#475569 !important; background:#fff !important; font-size:13px; }
    .dataTables_paginate .paginate_button.current, .dataTables_paginate .paginate_button.current:hover { background:#6366f1 !important; border-color:#6366f1 !important; color:#fff !important; }
    .dataTables_paginate .paginate_button:hover:not(.disabled):not(.current) { background:#eef2ff !important; border-color:#c7d2fe !important; color:#4f46e5 !important; }

    @@media (max-width:768px) {
        .dataTables_wrapper { padding:4px 10px 12px; }
        .dataTables_filter { float:none; margin:8px 0 0; }
        .dataTables_filter input { width:100%; min-width:0; box-sizing:border-box; }
        table#MyTable { min-width:0 !important; }
        table#MyTable thead { display:none; }
        table#MyTable, table#MyTable tbody { display:block; width:100%; }
        table#MyTable tbody tr { display:block; background:#fff; border:1px solid #e7eaf0 !important; border-radius:14px; margin-bottom:12px; padding:4px 13px; box-shadow:0 1px 3px rgba(15,23,42,.07); }
        table#MyTable tbody tr:hover td { background:transparent; }
        table#MyTable tbody td { display:block; width:auto !important; border:0 !important; border-top:1px solid #f3f5f9 !important; padding:10px 0 !important; }
        table#MyTable tbody td:first-child { display:none; }
        table#MyTable tbody td:nth-child(2) { border-top:0 !important; }
        table#MyTable tbody td:empty { display:none; }
        table#MyTable tbody td a { width:42px; height:42px; }
    }
</style>

<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">Team List</h3>
        <div class="pull-right">
            @*@if (User.IsInRole("Dev") || User.IsInRole("Create Task Team"))
                {*@
            <i class="ace-icon fa fa-hand-o-right icon-animated-hand-pointer blue"></i>
            <a class="btn btn-info no-border modal-create" href="/Team/Create">
                <i class="glyphicon glyphicon-plus"></i> Create
            </a>
            @*}*@
        </div>
    </div>
    <div class="box-body">
        <table class="table table-bordered table-hover" id="MyTable">
            <thead>
                <tr>
                    <td data-priority="1">#</td>
                    <td data-priority="2">Team Name</td>
                    <td data-priority="2">Team Lead</td>
                    <td data-priority="2">Team Members</td>
                    <td data-priority="2">Team Tag</td>
                    <td data-priority="2">Task Status </td>
                    <td data-priority="2">Lead Status</td>
                    <td data-priority="2">Amc Status</td>
                    <td data-priority="5">CreatedBy</td>
                    <td data-priority="7">Action</td>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

@Html.Partial("../Common/_ModalCreate")
@Html.Partial("../Common/_ModalEdit")
@Html.Partial("../Common/_ModalChange")
@Html.Partial("../Common/_ModalDelete")
@section scripts{
    @Scripts.Render("~/js/jqueryval")
    <script type="text/javascript">
        var oTable = $('#MyTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "pageLength": 50,
            responsive: false,   // mobile handled by the card layout (parity with Contacts)

            "ajax": {
                "url": '/Team/GetTeam',
                "type": "POST",
                "datatype": "json"
            },
            "order": [[0, "desc"]],
            "columnDefs": [{ orderable: false, targets: -1 }],
            "columns": [
                     {
                         "data": "id", "name": "id",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                 {
                     "data": "TeamName", "name": "TeamName", "render": function (data, type) {
                         if (type !== 'display') return data || '';
                         var nm = (data || '').toString();
                         var core = nm.replace(/[^a-zA-Z0-9]+/g, ' ').trim();
                         var parts = core.split(/\s+/).filter(function (p) { return p && !/^\d+$/.test(p); });
                         var ini = (((parts[0] || '').charAt(0)) + ((parts[1] || '').charAt(0))).toUpperCase() || (nm.replace(/[^a-zA-Z]/g, '').charAt(0) || '?').toUpperCase();
                         var pal = ['#6366f1', '#0ea5e9', '#10b981', '#f59e0b', '#ec4899', '#8b5cf6', '#14b8a6', '#ef4444'];
                         var h = 0; for (var i = 0; i < nm.length; i++) h = nm.charCodeAt(i) + ((h << 5) - h);
                         var col = pal[Math.abs(h) % pal.length];
                         return '<div class="qk-name"><span class="qk-av" style="background:' + col + '">' + ini + '</span><span class="qk-nm">' + $('<div>').text(nm).html() + '</span></div>';
                     }
                 },
                 { "data": "TeamLead", "name": "TeamLead" },
                   {
                       "name": "TeamMembers", "data": function (data) {
                           var datas = "";
                           $.each(data.TeamMembers, function (i, item) {
                               if (datas != "") {
                                   datas += ", ";
                               }
                               datas += item.FirstName + " " + item.LastName;
                           })
                           return datas;
                       }
                   },
                 { "data": "TeamTag", "name": "TeamTag" },
                 {
                     "name": "TaskStatus", "data": function (data) {
                         var datas = "";
                         $.each(data.TaskStatus, function (i, item) {
                             if (datas != "") {
                                 datas += ", ";
                             }
                             datas += item.Name;
                         })
                         return datas;
                     }
                },

                {
                    "name": "LeadStatus", "data": function (data) {
                        var datas = "";
                        $.each(data.LeadStatus, function (i, item) {
                            if (datas != "") {
                                datas += ", ";
                            }
                            datas += item.Name;
                        })
                        return datas;
                    }
                },
                {
                    "name": "AmcStatus", "data": function (data) {
                        var datas = "";
                        $.each(data.AmcStatus, function (i, item) {
                            if (datas != "") {
                                datas += ", ";
                            }
                            datas += item.Name;
                        })
                        return datas;
                    }
                },





                 {
                     "data": "UserName", "name": "UserName", "render": function (data, type) {
                         if (type !== 'display') return data || '';
                         var s = (data || '').toString().trim();
                         if (!s) return '';
                         return '<span class="qk-user"><span class="qk-user-av">' + s.substring(0, 2).toUpperCase() + '</span>' + $('<div>').text(s).html() + '</span>';
                     }
                 },
                  {
                      "name": "id", "data": function (data) {
                          var rest = "";
                              @{
                                 // if (User.IsInRole("Dev") || User.IsInRole("Edit Task Team"))
                                  //{
                                      actData += "<a class=\"modal-edit\" href=\"/Team/Edit/'+ data.id +'\" title=\"Edit Task Team\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                                 /// }
                                  if (User.IsInRole("Dev") || User.IsInRole("Delete Task Team"))
                                  {
                                      actData += "<a class=\"modal-delete\" href=\"/Team/Delete/'+ data.id +'\" title=\"Delete Task Team\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";
                                  }
                              }
                          return rest = '@Html.Raw(actData)';
                      }
                  },
            ]
        });
        $('#MyTable_filter input').attr('placeholder', 'Search teams…');
        (function () {
            try {
                var $foot = $('<div class="qk-foot"></div>');
                $('#MyTable_info').before($foot);
                $foot.append($('#MyTable_info')).append($('#MyTable_paginate'));
            } catch (e) { }
        })();


        /* function for Create popup */

        $('div').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        });
        $('#modal-create').on('submit', '#createform', function (e) {
            e.preventDefault();
            var url = $('#createform')[0].action;
            var data = $('#createform').serialize();
            createajax(url, data, '#modal-create');
        });


        /* function for Edit popup */

        $('div').on('click', '.modal-edit', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-edit');
        });
        $('#modal-edit').on('submit', '#editform', function (e) {
            e.preventDefault();
            var url = $('#editform')[0].action;
            var data = $('#editform').serialize();
            createajax(url, data, '#modal-edit');
        });

        /* function for delete popup */
        $('#MyTable').on('click', '.modal-delete', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-delete');
        });
        $('#modal-delete').on('submit', '#deleteform', function (e) {
            e.preventDefault();
            var url = $('#deleteform')[0].action;
            var data = $('#deleteform').serialize();
            createajax(url, data, '#modal-delete');
        });

        /* chang status */
        $('.table').on('click', '.modal-change', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-change');
        });
        $('#modal-change').on('submit', '#changeform', function (e) {
            e.preventDefault();
            var url = $('#changeform')[0].action;
            var data = $('#changeform').serialize();
            createajax(url, data, '#modal-change');
        });

        function changecheckbox(obj) {
            if ($(obj).val() == true) {
                $("#TaskStatus").hide();
                $("#LeadStatus").show()

            }
            else {
                $("#TaskStatus").show();
                $("#LeadStatus").hide();
            }
        }
        



    </script>
}