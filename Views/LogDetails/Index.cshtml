@{
    ViewBag.Title = "Log Details";
    ViewBag.SubTitle = "Log Details";
    ViewBag.Active = "Log Details";
}
<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title"><i class="fa fa-history"></i> Activity Log &amp; Audit Trail</h3>
    </div>
    <div class="box-body">
        <style>
            .qlog-tbl th { text-transform: uppercase; font-size: 11px; letter-spacing: .3px; }
            .qlog-badge { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; letter-spacing: .3px; }
            .qlog-Created { background: #dcfce7; color: #166534; }
            .qlog-Updated { background: #dbeafe; color: #1e40af; }
            .qlog-Deleted { background: #fee2e2; color: #991b1b; }
            .qlog-Logged, .qlog-Printed { background: #f1f5f9; color: #475569; }
            .qlog-details { color: #334155; }
            .qlog-when { white-space: nowrap; color: #475569; }
            .qlog-who { font-weight: 600; color: #0f172a; }
            .qlog-ip { font-family: SFMono-Regular, Consolas, monospace; font-size: 12px; color: #64748b; }
        </style>
        <table class="table table-bordered table-hover qlog-tbl" id="logTable">
            <thead>
                <tr class="bg-gray">
                    <th style="width:44px;">S/N</th>
                    <th style="width:110px;">Action</th>
                    <th>Details</th>
                    <th style="width:140px;">By</th>
                    <th style="width:120px;">IP Address</th>
                    <th style="width:190px;">Date &amp; Time</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

@section scripts{
    <script type="text/javascript">
        var TransId   = getParameterByName("TransId");
        var TransType = getParameterByName("TransType");

        function qlogEsc(s){ return (s == null ? '' : String(s)).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

        var oTable = $('#logTable').DataTable({
            "processing": true,
            "serverSide": true,
            "filter": true,
            "orderMulti": false,
            "bStateSave": true,
            "pageLength": 50,
            "ajax": {
                "url": '/LogDetails/GetData',
                "type": "POST",
                "data": function (data) {
                    data.TransId    = TransId;
                    data.TransType  = TransType;
                },
                "datatype": "json"
            },
            "order": [[0, "desc"]],
            "columnDefs": [{ orderable: false, targets: "_all" }],
            "columns": [
                {
                    "data": "id", "name": "id",
                    "render": function (data, type, row, meta) {
                        return meta.row + meta.settings._iDisplayStart + 1;
                    }
                },
                {
                    "data": "action", "name": "action",
                    "render": function (d) {
                        var a = qlogEsc(d) || 'Logged';
                        return '<span class="qlog-badge qlog-' + a + '">' + a + '</span>';
                    }
                },
                { "data": "details", "name": "details", "render": function (d) { return '<span class="qlog-details">' + qlogEsc(d) + '</span>'; } },
                { "data": "user", "name": "user", "render": function (d) { return '<span class="qlog-who">' + qlogEsc(d) + '</span>'; } },
                { "data": "ip", "name": "ip", "render": function (d) { return '<span class="qlog-ip">' + qlogEsc(d) + '</span>'; } },
                { "data": "time", "name": "time", "render": function (d) { return '<span class="qlog-when">' + qlogEsc(d) + '</span>'; } }
            ]
        })

    </script>
}
