@model QuickSoft.ViewModel.CrossHireReturnViewModel
@{
    ViewBag.Title = "Edit";
    ViewBag.SubTitle = "Edit CrossHire Return Note";
    ViewBag.Active = "Transactions";
    long? chkCust = Model.Supplier;
    var TimeOut = @ViewBag.TMOut;
    string IRateCheck = "inactive";
}
@if (User.IsInRole("Dev") || User.IsInRole("ReadOnly Item Rate"))
{
    IRateCheck = "active";
}
@using (Html.BeginForm("UpdateCrossHireReturn", "CrossHireReturn", FormMethod.Post, new { id = "dvform", role = "form" }))
{
    <div class="box box-info">
        <div class="box-header with-border">
            <h3 class="box-title">Edit CrossHire Return Note <label id="AlertEditable" class="text-red"></label></h3>
            <div class="pull-right">
                @if (@ViewBag.preEntry != 0)
                {
                    if (User.IsInRole("Dev") || User.IsInRole("Edit CrossHireReturn"))
                    {
                        <a class="btn bg-black no-border" href="/CrossHireReturn/Edit/@ViewBag.preEntry">
                            <i class="fa fa-step-backward"></i>
                        </a>
                    }
                }
                @if (@ViewBag.nxtEntry != 0)
                {
                    if (User.IsInRole("Dev") || User.IsInRole("Edit CrossHireReturn"))
                    {
                        <a class="btn bg-black no-border" href="/CrossHireReturn/Edit/@ViewBag.nxtEntry">
                            <i class="fa fa-step-forward"></i>
                        </a>
                    }
                }
                else
                {
                    if (User.IsInRole("Dev") || User.IsInRole("CrossHireReturn Entry"))
                    {
