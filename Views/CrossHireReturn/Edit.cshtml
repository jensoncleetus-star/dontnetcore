@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/print")
    <style>
        .chide {
            display: none;
        }
    </style>
}
@section scripts{
    @Scripts.Render("~/js/JsBarcode")
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/returnnote")
    @Scripts.Render("~/js/num2words")
    <script type="text/javascript">
        var getQueryString = function (field, url) {
            var href = url ? url : window.location.href;
            var id = href.substring(href.lastIndexOf('/') + 1);
            return id ? id : null;
        }
        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true,
            startDate: '01-01-2011',
            endDate: '+30d'
        });
        jQuery.validator.methods["date"] = function (value, element) { return true; }

        $(document).ready(function () {
            $('#SaleType option:contains(POS)').remove();
            DateSet();
            $("#Type").select2();
            searchItem();

            ItemCategory();
            ItemBrand();
            GetBranch();
            CallSupplier();
            CallEmployee();
            CallMCUser();
            CallProjectEmpty();
            CallApprovedBy();
            $("#SelApprovedBy").val($("#ddlApprovedBy").val());

            $('#ddlMC').attr("disabled", true);


            var dvid = getQueryString('');
            $.ajax({
                url: '/CrossHireReturn/GetCrossHrItems',
                dataType: 'json',
                data: { entryId: dvid, ItemId : null},
                cache: true,
                success: function (data) {
                    if (data != "") {
                        var qtySum = 0;
                        $('#addinvoiceItem').html('');
                            $.each(data, function (i, item) {
                                var chckv = 0;
                                var RetItemQuantity = (item.RetItemQuantity != null) ? item.RetItemQuantity : 0;
                                var DvItemQuantity = (item.DvItemQuantity != null) ? item.DvItemQuantity : 0;
                                var itmbalance = (parseFloat(DvItemQuantity) - parseFloat(RetItemQuantity)).toFixed(2);

                                $("#addinvoiceItem tr.item_" + item.Item).each(function () {
                                    var itunit = $(this).find('.units').val();
                                    if (itunit == item.ItemUnit) {
                                        chckv = 1;
                                    }
                                });

                                RetItemQuantity = RetItemQuantity - item.ItemQuantity;
                                addrow('addinvoiceItem', 'edit', item.ItemUnit, item.ItemQuantity, RetItemQuantity, DvItemQuantity, itmbalance, item.Item, item.ItemCode, item.ItemName, item.ItemWithCode, item.ItemNote, item, item.ItemDiscount, item.ReceivedQty, item.DamageQty, item.MissingQty, item.BaseQty);

                                    if (item.bundle !=null) {
                                        $.each(item.bundle, function (i, item) {
                                            var chckvs = 0;
                                            var RetItemQuantitys = (item.RetItemQuantity != null) ? item.RetItemQuantity : 0;
                                            var DvItemQuantitys = (item.DvItemQuantity != null) ? item.DvItemQuantity : 0;
                                            var itmbalances = (parseFloat(DvItemQuantitys) - parseFloat(RetItemQuantitys)).toFixed(2);

                                            $("#addinvoiceItem tr.item_" + item.Item).each(function () {
                                                var itunit = $(this).find('.units').val();
                                                if (itunit == item.ItemUnit) {
                                                    chckvs = 1;
                                                }
                                            });

                                            RetItemQuantitys = RetItemQuantitys - item.ItemQuantity;
                                            addrow('addinvoiceItem', 'edit', item.ItemUnit, item.ItemQuantity, RetItemQuantitys, DvItemQuantitys, itmbalances, item.Item, item.ItemCode, item.ItemName, item.ItemWithCode, item.ItemNote, item, item.ItemDiscount, item.ReceivedQty, item.DamageQty, item.MissingQty, item.BaseQty);

                                        });
                                    }

                                rowSubTotal(item.Item);
                                CalculatetblItemListSum();
                                HireItemTotal();
                            });

                       addrow('addinvoiceItem', '222', '', '0.00', '0.00', '0');
                    } else {
                        $('#addinvoiceItem').html('');
                        addrow('addinvoiceItem', '222', '', '0.00', '0.00', '0');
                    }
                }
            });
            chkEditEditable("@ViewBag.ChkApp");
        });


        $('body').on('change', '#ddlMC', function (e) {
            var mcval = $(this).val();
            searchItem();
        });
        $('body').on('change', '#ddlProject', function (e) {
            $('#ddlProTask').val(null).trigger('change');
            CallTask();
        });

        $('body').on('change', '#ddlApprovedBy', function (e) {
            $("#SelApprovedBy").val($(this).val());
        });

        /* function for Create popup */

        $('span').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        });
        $('#modal-create').on('submit', '#createform', function (e) {
            e.preventDefault();
            var url = $('#createform')[0].action;
            var data = $('#createform').serialize();
            createajax(url, data, '#modal-create');
        });

        $('span').on('click', '.modal-edit', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-edit');
        });
        $('#modal-edit').on('submit', '#editform', function (e) {
            e.preventDefault();
            var url = $('#editform')[0].action;
            var data = $('#editform').serialize();
            createajax(url, data, '#modal-edit');
        });
        $('span').on('click', '.modal-project', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-project');
        });
        $('body').on('change', '#ddlSupplier', function (e) {
            var cus = $(this).val();
            $('#ReturnTable').hide();
            $('#ddlProject').val(null).trigger('change');
            CallProjectEmpty();
        });
        $('body').on('change', '#ddlProject', function (e) {
            //var cus = $("#ddlCustomer").val();
           // BindInvoices(cus);
            $('#ReturnTable').hide();
        });
        ProjectPopup();

         $('#dvform').on('submit', function (e) {
            e.preventDefault();
            if ($("#dvform").valid()) {
                var fnval = $('input[type="submit"], button[type="submit"]', this).filter(':focus').attr('id');
                var parameters = {};
                var HrNo = $('#HrNo').val();
                var BillNo = $('#BillNo').val();
                var SupplierID = $('#ddlSupplier').val();
                var CashierId = $('#ddlEmployee').val();
                var Date = $('#Date').val();
                var dvID = getQueryString('');
                //pending
                var Items = $('#ItemCount').val();
                var ItemQuantity = $('#ItemQty').text();

                // var tAndc = CKEDITOR.instances.TermsCondition.getData();
                var tAndc = $('#TermsCondition').val();

                var Remarks = $('#Remarks').val();
                var MaterialCenter = $('#ddlMC').val();
                var Branch = $('#ddlBranch').val();
                //var RtType = $('#RtType').val();
                var Invoice = $('#ddlInvoice').val();
                var Project = $('#ddlProject').val();
                var Task = $('#ddlProTask').val();
                var ApprovedBy = $('#SelApprovedBy').val();

                var Ref1 = "";
                var Ref2 = "";
                var Ref3 = "";
                var Ref4 = "";
                var Ref5 = "";
                if ('@Model.FieldMap.Count' > 0) {
                    Ref1 = $('#Ref1').val();
                    Ref2 = $('#Ref2').val();
                    Ref3 = $('#Ref3').val();
                    Ref4 = $('#Ref4').val();
                    Ref5 = $('#Ref5').val();
                }
                var Layout = $('#ddlPrintlayout').val();
                var HTMLtbl = {
                    getData: function (table) {
                        var data = [];
                        table.find('tr').not(':first').not('.item_').each(function (rowIndex, r) {
                            var cols = [];
                            $(this).find('input,textarea,select').each(function (colIndex, c) {
                                cols.push($(this).val());
                            });
                            data.push(cols);
                        });
                        return data;
                    }
                }
                var dvEntry = [SupplierID, CashierId, Date, Items, ItemQuantity,
                tAndc,//5
                HrNo, BillNo, Remarks, MaterialCenter, Branch, Invoice, Project, Task,dvID, ApprovedBy,
                Ref1, Ref2, Ref3, Ref4, Ref5, Layout]


                var data = HTMLtbl.getData($('#normalinvoice'));
                parameters.array = data;
                parameters.dvdata = dvEntry;
                parameters.action = fnval;
                submitForm(fnval, parameters);
            }
        });

        function submitForm(fnval, parameters) {
            $.ajax({
                async: true,
                cache: false,
                dataType: "json",
                type: "POST",
                contentType: "application/json; charset=utf-8",
                url: "/CrossHireReturn/UpdateCrossHireReturn",
                data: JSON.stringify(parameters),
                beforeSend: function () {
                    $("button").prop('disabled', true); // disable button
                },
                success: function (e) {
                    if (e.status == true) {
                        if (fnval == "print") {
                            PrintInvoice(e, "nobillsundry", '@ViewBag.ItemDataCheck', "CrossHireReturn");
                        } else {
                            $('.ajax_response', res_success).text(e.message);
                            $('.AlertDiv').prepend(res_success);
                        }
                        setTimeout(function () { location.reload(); }, '@TimeOut');
                    }
                    else {

                        $('.ajax_response', res_danger).text(e.message);
                        $('.AlertDiv').prepend(res_danger);
                        $("button").prop('disabled', false); // enable button
                    }
                }
            });
        }

        function DateSet() {
            var ndate = $('#FromDate').val();

            $('#ToDate').datepicker({
                startDate: ndate,
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });

        }
    </script>
}
