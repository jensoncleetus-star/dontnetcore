@{
    ViewBag.Title = "Search Reminder";
    ViewBag.SubTitle = "Reminder";
    ViewBag.Active = "Reports";
    string actData = "";
}
<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">Search Reminder</h3>
    </div>
    <div class="box-body">
        <form id="search-form">
            <input type="hidden" id="cname" value="@ViewBag.CName" />
            <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
            <div class="form-group col-md-2">
                @Html.Label("Status", null, new { @class = "control-label" })
                @Html.DropDownList("Status", new SelectList(new List<SelectListItem>
                {
                    new SelectListItem() {Text = "All", Value=""},
                    new SelectListItem() {Text = "Open", Value="Open"},
                    new SelectListItem() {Text = "Close", Value="Close"},
                    new SelectListItem() {Text = "Postpone", Value="Postpone"},
                }, "Value", "Text"), new { @class = "form-control input-sm", @name = "Status" })
            </div>
            <div class="form-group col-md-2">
                @Html.Label("Type", null, new { @class = "control-label" })
                @Html.DropDownList("ddlRemType", (SelectList)ViewBag.RType, "All", new { @class = "form-control input-sm select2" })
            </div>
            <div class="form-group col-md-2">
                @Html.Label("From", null, new { @class = "control-label" })
                <div class="input-group date">
                    @Html.TextBox("From", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                    <div class="input-group-addon">
                        <i class="fa fa-calendar"></i>
                    </div>
                </div>
            </div>
            <div class="form-group col-md-2">
                @Html.Label("To", null, new { @class = "control-label" })
                <div class="input-group date">
                    @Html.TextBox("To", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                    <div class="input-group-addon">
                        <i class="fa fa-calendar"></i>
                    </div>
                </div>
            </div>
            <div class="box-footer col-md-12">
                <button type="submit" class="btn btn-info col-sm-offset-5" id="btn">Submit</button>
                <button type="button" class="btn btn-default" onclick="@("window.location.href='/Home/Index'");">Cancel</button>
            </div>
        </form>
    </div>
</div>
<div class="box box-default" id="ReminderReport">
    <div class="box-header with-border">
        <h3 class="box-title">View Reminder</h3>
    </div>
    <div class="box-body">
        <div class="box-body">
            <table class="display table table-bordered" id="UserTable">
                <thead>
                    <tr>
                        <td>SI No</td>
                        <td>Type</td>
                        <td>Note</td>
                        <td>Date</td>
                        <td>Time</td>
                        @*<td>Assigned To</td>*@
                        @*<td>Requested By</td>*@
                        <td>Created By</td>
                        <td>Status</td>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>
