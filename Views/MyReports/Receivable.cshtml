@{
    ViewBag.Title = "Outstanding";
    ViewBag.SubTitle = "Outstanding Recievable";
    ViewBag.Active = "Reports";

}
<style>
    #divnames th{
        background: #0d83dd;
        color:white;
    }
</style>
<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">Outstanding Recievable</h3>
    </div>
    <div class="box-body">
        <form id="search-form">
            @*@using (Html.BeginForm("Receivable", "MyReports", FormMethod.Post, new { id = "ReceivableForm" }))
        {*@
            @*<input type="hidden" id="cname" value="@ViewBag.CName" />
        <input type="hidden" id="caddress" value="@ViewBag.CAddress" />*@
            <div class="form-group col-md-2">
                @Html.Label("Select Type", null, new { @class = "control-label" })
                @Html.DropDownList("ddlCSType", (SelectList)ViewBag.CSType, new { @class = "form-control input-sm select2" })
            </div>

            <div class="form-group col-md-4" id="CusDiv">
                @Html.Label("Customer", null, new { @class = "control-label" })
                @Html.DropDownList("ddlCustomer", (SelectList)ViewBag.ListCust, new { @class = "form-control input-sm select2" })
            </div>
            <div class="form-group col-md-3" id="CusDiv">
                @Html.Label("Salesman", null, new { @class = "control-label" })
                @Html.DropDownList("ddlEmployee2", (SelectList)ViewBag.ListCust, new { @class = "form-control input-sm select2" })
            </div>
            <div class="form-group col-md-3" id="CusDiv">
                @Html.Label("Sales Executive", null, new { @class = "control-label" })
                @Html.DropDownList("ddlEmployee", (SelectList)ViewBag.ListCust, new { @class = "form-control input-sm select2" })
            </div>
            <div class="form-group col-md-4" id="SupDiv">
                @Html.Label("Supplier", null, new { @class = "control-label" })
                @Html.DropDownList("ddlSupplier", (SelectList)ViewBag.ListSup, new { @class = "form-control input-sm select2" })
            </div>
            <div class="form-group col-md-2">
                @Html.Label("Type", null, new { @class = "control-label" })
                @Html.DropDownList("ddlType", new SelectList(new List<SelectListItem>
                    {
                        new SelectListItem() {Text = "Date Wise", Value="0"},
                        new SelectListItem() {Text = "Ageing wise", Value="1"}
                    }, "Value", "Text"), new { @class = "form-control input-sm", @name = "ddlType" })
            </div>
            <div class="form-group col-md-4" id="ageday">
                @Html.Label("Days ", null, new { @class = "control-label" })
                <div class="input-group input-group-sm">
                    @Html.DropDownList("AgeDays", (SelectList)ViewBag.Agetype, new { @class = "form-control input-sm select2" })
                    @*<input type="text" class="form-control input-sm" value="30" id="AgeDays" />*@
                    <span class="input-group-btn">
                        <button type="button" class="btn btn-flat">Days</button>
                    </span>
                </div>
            </div>
            <div class="form-group col-md-4" id="fdate">
                @Html.Label("From", null, new { @class = "control-label" })
                <div class="input-group date">
                    @Html.TextBox("From", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                    <div class="input-group-addon">
                        <i class="fa fa-calendar"></i>
                    </div>
                </div>
            </div>
            <div class="form-group col-md-4" id="todate">
                @Html.Label("To", null, new { @class = "control-label" })
                <div class="input-group date">
                    @Html.TextBox("To", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                    <div class="input-group-addon">
                        <i class="fa fa-calendar"></i>
                    </div>
                </div>
            </div>
            <div class="box-footer col-md-12">
                <button type="submit" class="btn btn-info col-sm-offset-5" id="btn">Search</button>
                <button type="button" class="btn btn-default" onclick="@("window.location.href='/Home/Index'");">Cancel</button>
            </div>
        </form>
            @*}*@
</div>
</div>
<div class="box box-default" id="StockReport">
    <div class="box-body">
        <input type="hidden" id="cname" value="@ViewBag.CName" />
        <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
        <input type="hidden" id="itemname" value="@ViewBag.ItemName" />
        <input type="hidden" id="PoNo" value="@ViewBag.PartNoCheck" />
        <input type="hidden" id="mcname" value="@ViewBag.MCSName" />

        <div class="box-body">
            <table class="display table table-bordered table-hover" id="UserTable">
                <thead>
                    
                    <tr id="divnames">
                        <th colspan="3">Name: <span id="ShowName"></span></th>
                        <th colspan="3">From : <span id="showFrom"></span> - To : <span id="showTo"></span></th>
                    </tr>
                    <tr>
                        <td>S/N</td>
                        <td>Invoice No</td>
                        <td>Date</td>
                        <td>Customer</td>
                        <td class="headeralign">Amount</td>
                        <td>Days</td>
                    </tr>
                    @*<tr>
                        <td data-priority="1">S/N</td>
                        <td>Item Code</td>
                        <td>Item Name</td>
                        <td>Unit Price</td>
                        <td>Net Movement Qty</td>
                        <td>Current Stock Qty</td>
                        <td>1week Forecast Qty</td>
                        <td>1week Purchase Value</td>
                        <td>1month Forecast Qty</td>
                        <td>1month Purchase Value</td>
                        <td>2month Forecast Qty</td>
                        <td>2month Purchase Value</td>
                        <td>3month Forecast Qty</td>
                        <td>3month Purchase Value</td>
                        <td>1year Forecast Qty</td>
                        <td>1year Purchase Value</td>

                    </tr>*@
                </thead>
                <tbody></tbody>
                <tfoot>
                    <tr>
                        <th>Total:</th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th class="text-right"><div id="selectedtotal"></div></th>
                        <th></th>
                    </tr>
                </tfoot>

            </table>
        </div>
    </div>
</div>
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
}
@section Scripts {
    @Scripts.Render("~/js/bootstrap-datepicker")
<script type="text/javascript">
        $(document).ready(function () {

            $('#StockReport').hide();
            CSChange();
            $('#AgeDays').select2();

            $('#RReport').hide();
            $('#ageday').hide();

            //for set default date
            $('#To').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });
            $('#From').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });

            //bind to employee
            $("#ddlEmployee2").select2({
                placeholder: 'Search by Name ',
                minimumInputLength: 0,
                ajax: {
                    url: "/Employee/SearchEmployee",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term || "",
                            page: params.page || 0,
                            x: "empty"

                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 0;

                        return {
                            results: data,
                            pagination: {
                                //more: (params.page * 10) < 50
                                more: true
                            }
                        };
                    },
                    cache: true
                },
            });

            var date = new Date();
            var today = new Date(date.getFullYear(), date.getMonth(), date.getDate());
            var priordate = new Date(new Date().setDate(today.getDate() - 30));
            $('#To').datepicker('setDate', today);
            $('#From').datepicker('setDate', priordate);
        });

        $("#ddlCSType").select2();

        $('body').on('change', '#ddlType', function (e) {
            var type = $(this).val();
            if (type == 1) {
                $('#fdate').hide();
                $('#todate').hide();
                $('#ageday').show();
            }
            if (type == 0) {
                $('#fdate').show();
                $('#todate').show();
                $('#ageday').hide();
            }
        });

        CallRepMCUser();
        CallRepSupplier();
        CallRepCustomer();
        CallEmployee();
        $('body').on('change', '#ddlCSType', function (e) {
            CSChange();
        });
        $('body').on('change', '#ddlCustomer', function (e) {


        });

        function CSChange() {
            var cst = $('#ddlCSType').val();
            if (cst == "Sup") {
                $('#SupDiv').show();
                $('#CusDiv').hide();
                $('#ddlCustomer').val(0);
                $('#ddlSupplier').val(0);
            }
            else if (cst == "Cus") {
                $('#CusDiv').show();
                $('#SupDiv').hide();
                $('#ddlSupplier').val(0);
                $('#ddlCustomer').val(0);
            }
            else {
                $('#SupDiv').hide();
                $('#CusDiv').hide();
                $('#UserTable').hide()
            }
        }

        var flag = 0;
        $('#search-form').on('submit', function (e) {
            var supID = $('#ddlSupplier').val();
            var cusID = $('#ddlCustomer').val();
            var temp = $('#ddlCSType').val();
            document.getElementById("ShowName").innerHTML = "";
            e.preventDefault();

            if (flag == 0) {

                showdatatable();

                flag = 1
            }
            else {
                $('#UserTable').DataTable().destroy();

                    showdatatable();

                //oTable.draw();
            }
            $('#StockReport').show();


            if (temp == "Cus" && cusID==0) {
                $('#UserTable thead td:eq(3)').html('Customer');
            }
            else if (temp == "Sup" && supID==0) {
                $('#UserTable thead td:eq(3)').html('Supplier');
            }

        });



        function showdatatable() {
            document.getElementById("ShowName").innerHTML = "";
            var supID = $('#ddlSupplier').val();
            var cusID = $('#ddlCustomer').val();
            var temp = $('#ddlCSType').val();
