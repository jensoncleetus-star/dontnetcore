@{
    ViewBag.Title = "Search Profit";
    ViewBag.SubTitle = "Item Profit";
    ViewBag.Active = "Reports";

}
<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">Search Item Profit Report</h3>
    </div>
    <div class="box-body">
        <form id="search-form">
            <input type="hidden" id="cname" value="@ViewBag.CName" />
            <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
            <input type="hidden" id="matcenter" value="@ViewBag.EnableMCcheck" />
            <input type="hidden" id="Scaffold" value="@ViewBag.BusinessType" />
            @*<div class="form-group col-md-4">
                @Html.Label("Return Note No", null, new { @class = "control-label" })
                @Html.TextBox("BillNo", "", new { @class = "form-control input-sm" })
            </div>*@
            <div class="form-group col-md-4">
                @Html.Label("Item Code/Name", null, new { @class = "control-label" })
                @Html.TextBox("ItemCodeName", "", new { @class = "form-control input-sm" })
            </div>
            <div class="form-group col-md-4">
                @Html.Label("Category", null, new { @class = "control-label" })
                @Html.DropDownList("ddlCategory", (SelectList)ViewBag.Category, new { @class = "form-control input-sm" })
            </div>          
            

            <div class="box-footer col-md-12">
                <button type="submit" class="btn btn-info col-sm-offset-5" id="btn">Submit</button>
                <button type="button" class="btn btn-default" onclick="@("window.location.href='/Home/Index'");">Cancel</button>
            </div>
        </form>
    </div>
</div>
<div class="box box-default" id="DTaxReport">
    <div class="box-header with-border">
        <h3 class="box-title">View Profit Report</h3>
    </div>
    <div class="box-body">
        <div class="box-body">
            <table class="display table table-bordered" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td>S/N</td>
                        <td>Item</td>
                        <td>Total Sale</td>
                        <td>Total Sales Return</td>
                        <td>Total Tax</td>
                        <td>Total Discount</td>
                        <td>Purchase Amount per unit</td>
                        <td>Quantity(Sale)</td>
                        <td>Net Profit</td>
                    </tr>
                </thead>
                <tbody></tbody>
                <tfoot>
                    <tr>
                        <th>Total:</th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
}
@section Scripts {
    @Scripts.Render("~/js/bootstrap-datepicker")
    <script type="text/javascript">
        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        })


        $(document).ready(function () {
            $('#DTaxReport').hide();
            //for set default date
            $('#To').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });
            $('#From').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });

            var date = new Date();
            var today = new Date(date.getFullYear(), date.getMonth(), date.getDate());
            var priordate = new Date(new Date().setDate(today.getDate() - 30));
            $('#To').datepicker('setDate', today);
            $('#From').datepicker('setDate', priordate);
            //---

            $("#ddlCategory").select2({
                placeholder: 'Search Category',
                minimumInputLength: 0,
                ajax: {
                    url: "/ItemCategory/SearchCategory",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term,
                            page: params.page
                        };
                    },
                    results: function (data) {
                        return { results: data };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;
                        return {
                            results: data
                        };
                    },
                    cache: true
                },

            });

        });

        
        jQuery(function ($) {
            oTable = $('#UserTable').DataTable({
                "processing": true, // for show progress bar
                "serverSide": true, // for process server side
                "filter": false, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
                "bLengthChange": false,
                "paging": true,
                "pageLength": 5000,
                "deferLoading": 0,
                "ordering": false,
                "ajax": {
                    "url": '/MyReports/GetItemCatProfit',
                    "data": function (data) {
                        data.cname = $('#ItemCodeName').val();
                        data.category = $('#ddlCategory').val();
                    },
                    "type": "POST",
                    "datatype": "json"
                },
                "order": [[0, "desc"]],
                "columns": [
                     {
                         "data": "id", "name": "id",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     }, 

                { "data": "Item", "name": "Item" },
                {
                "name": "TSale", "data": function (data) {
                    
                    var TSale = (data.PriSale + data.SubSale);
                    
                    return TSale.toFixed(2);
                }

                },
                {
                    "name": "TSaleReturn", "data": function (data) {                        
                        var TSaleReturn = (data.PriSReturn + data.SubSReturn);
                        
                        return TSaleReturn.toFixed(2);
                    }
                },
                {  "name": "TTax",  "data": function (data) {                        
                    var TTax = (data.PriTax + data.SubTax);
                        
                    return TTax.toFixed(2);
                }
        },
                {
                    "name": "TDiscount", "data": function (data) {
                        var TDiscount = (data.PriDiscount + data.SubDiscount);

                        return TDiscount.toFixed(2);
                    }
                },
                {  "name": "PAmount", "data": function (data) {
                    var PurQty = (data.SubUnitId == 0) ? data.QPriPur : ((data.QPriPur * data.ConFactor) + data.QSubPur);
                    var OpStock = (data.SubUnitId == 0) ? data.OpeningStock : (data.OpeningStock * data.ConFactor);
                    var PRetQty = (data.SubUnitId == 0) ? data.QPriPReturn : ((data.QPriPReturn * data.ConFactor) + data.QSubPReturn) ;
                    var CurStock = (PurQty + OpStock) - PRetQty;
                    var PurCost = (data.PriPurchase + data.SubPurchase);
                    var PRetCoct = (data.PriPReturn + data.SubPReturn);
                    var OpStCost = data.OpStockCost;
                    var PAmount = (CurStock > 0) ? (OpStCost + PurCost - PRetCoct) / CurStock : 0;
                   // alert(PurQty +' ' +OpStock +' '+PRetQty);

                    return PAmount.toFixed(2);
                }
                },
                {
                    "name": "TQuantity", "data": function (data) {
                        var Totqty = ((data.QPriSale * data.ConFactor) + data.QSubSale) - (data.QPriSReturn + data.QSubSReturn);
                       // alert(data.QPriSale + ' ' + data.QSubSale + ' ' + data.QPriSReturn + ' ' + data.QSubSReturn);
                        if (data.SubUnit !=null)
                        {
                            var QPri = Math.floor(Totqty / data.ConFactor);
                            var QSub = Totqty % data.ConFactor;

                            Totqty = (QSub!=0)?( QPri + ' ' + data.PriUnit + ' ' + QSub +data.SubUnit ) : ( QPri + ' ' + data.PriUnit);
                        }
                        else {
                            Totqty = Totqty + ' ' + data.PriUnit;
                        }

                        return Totqty;
                    }
                },
                {
                    "name": "NetProfit", "data": function (data) {
                        var PurQty = (data.SubUnitId == 0) ? data.QPriPur : ((data.QPriPur * data.ConFactor) + data.QSubPur);
                        var OpStock = (data.SubUnitId == 0) ? data.OpeningStock : (data.OpeningStock * data.ConFactor);
                        var PRetQty = (data.SubUnitId == 0) ? data.QPriPReturn : ((data.QPriPReturn * data.ConFactor) + data.QSubPReturn);
                        var CurStock = (PurQty + OpStock) - PRetQty;
                        var PurCost = (data.PriPurchase + data.SubPurchase);
                        var PRetCoct = (data.PriPReturn + data.SubPReturn);
                        var OpStCost = data.OpStockCost;
                        var PAmount = (CurStock > 0) ? (OpStCost + PurCost - PRetCoct) / CurStock : 0;
                        var Totqty = ((data.QPriSale * data.ConFactor) + data.QSubSale) - (data.QPriSReturn + data.QSubSReturn);
                        var TSaleReturn = (data.PriSReturn + data.SubSReturn);
                        var TDiscount = (data.PriDiscount + data.SubDiscount);

                        var TSale = (data.PriSale + data.SubSale);
                        var TTax = (data.PriTax + data.SubTax);

                        var NetProfit = TSale- (TSaleReturn +TTax+TDiscount+ (PAmount * Totqty));
                        // alert(data.PriSale + ' ' + data.QSubSale + ' ' + data.QPriSReturn + ' ' + data.QSubSReturn);
                        return NetProfit.toFixed(2);
                    }
                },
                ],
                buttons: [//'copy', 'csv', 'excel', 'pdf', 'print'
                'colvis',
                {
                    extend: 'print',//
                    exportOptions: {
                        columns: ':visible'
                    },
                    title: "",
                    footer: true,
                    filename: function () {
                        return 'Item-Category-Profit-Report';
                    },
                    message: function () {
                        var head = '<table class="tblcompact table table-bordered"><thead>' +
                            ' <tr><th class="text-center"><h3 style="margin-top: 0px;">' + $('#cname').val() + '</h3>' + $('#caddress').val() + '<h4>Item Category Profit Report</h4></th></tr>' +
                            ' <tr><th><span class="text-left"></span><span class="text-right pull-right"> </span></th></tr></thead><tbody><tr><td>';
                        return head;
                    },
                    customize: function (win) {
                        // $(win.document.body)
                        //.css('font-size', '10pt')
                        //.css('padding', '1px');
                        $(win.document.body).find('table, th,tr, td ')
                           // .css('border', 'inherit')
                            .css('font-size', '10pt')
                            .css('padding', '5px')
                            .addClass('compact');
                        $(win.document.body).append('</td></tr></tbody>')

                    }
                }, 'copy', 'csv', //'excel',
                {
                    extend: 'excel',//
                    title: "",
                    footer: true,
                    filename: function () {
                        return 'Item-Category-Profit-Report';
                    },
                    message: function () {
                        var head = '' + $('#cname').val() + '\n' +
                         '' + $('#caddress').val() + '\n' +
                         ' Item Category Profit Report \n' + '';
                         //'From :  ' + $('#From').val() + ' To :' + $('#To').val() + '';
                        return head;
                    },
                    pageSize: 'A4',
                    exportOptions: {
                        columns: ':visible'
                    },
                },
            {
                extend: 'pdf',//
                title: "",
                footer: true,
                filename: function () {
                    return 'Item-Category-Profit-Report';
                },
                message: function () {
                    var head = '' + $('#cname').val() + '\n' +
                     '' + $('#caddress').val() + '\n' +
                     ' Item Category Profit Report \n' + '';
                     //'From :  ' + $('#From').val() + ' To :' + $('#To').val() + '';
                    return head;
                },
                pageSize: 'A4',
                exportOptions: {
                    columns: ':visible'
                },
                customize: function (doc) {
                    doc.pageMargins = [10, 10, 10, 10];
                    doc.defaultStyle.fontSize = 10;
                    doc.styles.tableHeader.fontSize = 10;
                    doc.styles.title.fontSize = 12;
                    // Header font and bg color
                    doc.styles.tableHeader.fillColor = '#d3d3d3';
                    doc.styles.tableHeader.color = 'black';
                    // Remove spaces around page title
                    doc.content[0].text = doc.content[0].text.trim();

                    //doc.styles['td:nth-child(2)'] = {
                    //    width: '100%',
                    //    'max-width': '100%'
                    //}
                    doc.content[1].table.widths = Array(doc.content[1].table.body[0].length + 1).join('*').split('');

                    var objLayout = {};
                    // Horizontal line thickness
                    objLayout['hLineWidth'] = function (i) { return .5; };
                    // Vertikal line thickness
                    objLayout['vLineWidth'] = function (i) { return .5; };
                    //// Horizontal line color
                    //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                    //// Vertical line color
                    //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                    // Left padding of the cell
                    objLayout['paddingLeft'] = function (i) { return 4; };
                    // Right padding of the cell
                    objLayout['paddingRight'] = function (i) { return 4; };
                    // Inject the object in the document
                    doc.content[1].layout = objLayout;
                    // Footer font and bg color
                    doc.styles.tableFooter.fillColor = '#d3d3d3';
                    doc.styles.tableFooter.color = 'black';
                    doc.content[0].text = doc.content[0].text.trim();
                    doc.content[1].table.widths = [
                         '5%',
                         '20%',
                         '10%',
                         '8%',
                         '10%',
                         '10%',
                         '13%',
                         '14%',
                         '10%'
                    ]
                }


            },

                ],

                sDom: "lBfr<'datatable-scroll't>ip",
                "lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                "footerCallback": function (row, data, start, end, display) {
                    var api = this.api(), data;

                    // Remove the formatting to get integer data for summation
                    var intVal = function (i) {
                        return typeof i === 'string' ?
                            i.replace(/[\$,]/g, '') * 1 :
                            typeof i === 'number' ?
                            i : 0;
                    };



                    // Total over all pages
                    total = api
                        .column(8)
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Total over this page
                    pageTotal = api
                        .column(8, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update footer
                    $(api.column(8).footer()).html(
                         pageTotal.toFixed(2)
                        //'$' + pageTotal + ' ( $' + total + ' total)'
                    );


                    var table = $('#UserTable').DataTable();
                    if (!table.data().any()) {
                        $('#UserTable tfoot').hide();
                    } else {
                        $('#UserTable tfoot').show();
                    }
                }


            });
            $('#search-form').on('submit', function (e) {
                e.preventDefault();
                oTable.draw();
                $('#DTaxReport').show();
            });

            $('#UserTable tbody').on('click', 'tr', function () {
                if ($(this).hasClass('selected')) {
                    $(this).removeClass('selected');
                }
                else {
                    oTable.$('tr.selected').removeClass('selected');
                    $(this).addClass('selected');
                    $(this).addClass('dataTables_row');
                }
            });

            //var matcet = $('#matcenter').val();
            //if (matcet == "inactive") {
            //    var column1 = oTable.column(8);
            //    column1.visible(false);
            //} else {
            //    var column1 = oTable.column(8);
            //    column1.visible(true);
            //}
        });


        function reload_table() {
            oTable.clear().draw();
            oTable.ajax.reload(null, false); //reload datatable ajax
        }



    </script>
}