        });
    function SaveFunction(fnval) {
        var tem = $("#ddlApprovedBy").val();
        $("#SelApprovedBy").val(tem);
            if ($("#Createform").valid()) {

                var Voucher = $('#Voucher').val();
                var Date = $('#Date').val();
                var MCFrom = $('#ddlMCFrom').val();
                var MCTo = $('#ddlMCTo').val();
                var Remarks = $('#Remarks').val();

                var TotItemCount = $('#ToItemCount').text();
                var TotItemQuantity = $('#ToItemQnt').text();
                var TotPrice = $('#ToItemPrice').text();
                var TotAmount = $('#GrandTotal').val();
                var ApprovedBy = $('#SelApprovedBy').val();
                var StockType = $('#StockType').val();
                var Ref1 = "";
                var Ref2 = "";
                var Ref3 = "";
                var Ref4 = "";
                var Ref5 = "";
                if ('@Model.FieldMap.Count' > 0)
                {
                    Ref1 = $('#Ref1').val();
                    Ref2 = $('#Ref2').val();
                    Ref3 = $('#Ref3').val();
                    Ref4 = $('#Ref4').val();
                    Ref5 = $('#Ref5').val();
                }

                var HTMLtbl = {
                    getData: function (table) {
                        var data = [];
                        table.find('tr').not(':first').not('.item_').each(function (rowIndex, r) {
                            var cols = [];
                            $(this).find('input,textarea,select').each(function (colIndex, c) {
                                cols.push($(this).val());
                            });
                            data.push(cols);
                        });
                        return data;
                    }
                }
                var HTMLtblbs = {
                    getData: function (table) {
                        var bsData = [];
                        table.find('tr').not(':first').not('.bs_').each(function (rowIndex, r) {
                            var cols = {};
                            $(this).find('input,textarea,select').each(function (colIndex, c) {
                                itid = $(this).attr('data-name').split(' ')[0];
                                itval = ($(this).val() != "") ? $(this).val() : $(this).text();
                                cols[itid] = itval;

                            });
                            bsData.push(cols);
                        });
                        return bsData;
                    }
                }
                var bsData = HTMLtblbs.getData($('#billsundry'));
                var salesEntry = [ Voucher, Date, MCFrom, MCTo, Remarks, TotItemCount,
                TotItemQuantity, TotPrice, TotAmount, ApprovedBy,StockType,
                Ref1, Ref2, Ref3, Ref4, Ref5]

                var data = HTMLtbl.getData($('#normalinvoice'));
                var parameters = {};
                parameters.array = data;
                parameters.mtdata = salesEntry;
                parameters.action = fnval;
                parameters.bsmodel = { 'sebsundrys': bsData }

                if (fnval == "save") {
                    submitForm(fnval, parameters);
                } else if (fnval == "print") {
                    submitForm(fnval, parameters);
                } else if (fnval == "sendmail") {
                    if ($('#custEmailId').val() != "") {
                        submitForm(fnval, parameters);
                    } else {
                        $('.ajax_response', res_danger).text("Party Email Address Not Found..!!");
                        $('.AlertDiv').prepend(res_danger);
                    }
                }
            }
        }

        function submitForm(fnval, parameters) {
            $.ajax({
                async: true,
                cache: false,
                dataType: "json",
                type: "POST",
                contentType: "application/json; charset=utf-8",
                url: "/Stocktransfer/Create",
                data: JSON.stringify(parameters),
                beforeSend: function () {
                    $("button").prop('disabled', true); // disable button
                },
                success: function (e) {
                    if (e.status == true) {









                        var fileUpload = $("#input-24").get(0);
                        var files = fileUpload.files;

                        // Create FormData object
                        var fileData = new FormData();

                        // Looping over all files and add it to FormData object
                        for (var i = 0; i < files.length; i++) {
                            fileData.append(files[i].name, files[i]);
                        }


                        fileData.append('id', e.STId);




                        $.ajax({
                            url: '/StockTransfer/UploadFiles',
                            type: "POST",
                            contentType: false, // Not to set any content header
                            processData: false, // Not to process data
                            data: fileData,
                            success: function (result) {
                                if (fnval == "print") {
                                    PrintStockTransferInvoice(e, "_Invoice");
                                }
                                else {
                                    $('.ajax_response', res_success).text(e.message);
                                    $('.AlertDiv').prepend(res_success);
                                    $("button").prop('disabled', false);
                                }

                                setTimeout(function () { window.location.href = '/StockTransfer/Edit/' + e.STId; }, '@TimeOut');
                            }
                            });
                            }
                    else {
                        $('.ajax_response', res_danger).text(e.message);
                        $('.AlertDiv').prepend(res_danger);
                        $("button").prop('disabled', false); //enable button
                    }
                }
                , error: function (XMLHttpRequest, textStatus, errorThrown) {
                    // alert("Status: " + textStatus);
                    //alert("Error: " + errorThrown);
                    $("button").prop('disabled', false);

                    alert("some error,check form, if empty in any fields please correct.")

                }
            });
        }
        AddItemPopUp();

        $('div').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
