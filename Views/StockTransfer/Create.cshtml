@model QuickSoft.ViewModel.StockTransferViewModel
@{ ViewBag.Title = "Create";
    ViewBag.SubTitle = "StockTransfer";
    ViewBag.Active = "Transactions";
    var TimeOut = @ViewBag.TMOut;
    string IRateCheck = "inactive"; }
@if (User.IsInRole("Dev") || User.IsInRole("ReadOnly Item Rate"))
{
    IRateCheck = "active";
}
<script>
    if (/Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent)) {
        window.location = "/StockTransfer/Createmobile";
    }
</script>
@using (Html.BeginForm("Create", "StockTransfer", FormMethod.Post, new { id = "Createform", role = "form" }))
{
    <div class="box box-info">
        <div class="box-header with-border">
            <h3 class="box-title">Create Stock Transfer</h3>
            <div class="pull-right">
                @if (@ViewBag.LastEntry != 0)
                {
                    if (User.IsInRole("Dev") || User.IsInRole("Edit StockTransfer"))
                    {
                        <a class="btn bg-black no-border" href="/StockTransfer/Edit/@ViewBag.LastEntry">
                            <i class="fa fa-step-backward"></i>
                        </a>}
                }

                @if (User.IsInRole("Dev") || User.IsInRole("StockTransfer List"))
                {
                    <a class="btn btn-success no-border" href="/StockTransfer/Index">
                        <i class="fa fa-fw fa-history"></i>List
                    </a>}
            </div>
        </div>

        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })

        <div class="box-body">
            <input type="hidden" id="ROnlyRate" value="@IRateCheck" />
            <input type="hidden" id="SelApprovedBy" />
            <input type="hidden" id="VoucherType" value="StockTransfer" />
            <input type="hidden" id="FDate" value="@Model.FinancialDate" />
            <input type="hidden" id="CDate" value="@Model.StkDate" />
            <div class="row">
                <div class="col-sm-2 col-xs-12 form-group ">
                    @Html.Label("Voucher No", null, new { @class = "control-label" }) *
                    @if (User.IsInRole("Dev") || User.IsInRole("Invoice Stock Transfer vourcher edit Permission") || User.IsInRole("Invoice Edit Permission"))
                    {
                        @Html.EditorFor(model => model.Voucher, new { htmlAttributes = new { @class = "form-control", @required = "required" } }) }
                    else
                    {
                        @Html.EditorFor(model => model.Voucher, new { htmlAttributes = new { @class = "form-control", @required = "required", @readonly = "readonly" } })}
                    @Html.HiddenFor(model => model.Voucher)
                </div>
                <div class="form-group col-md-2 col-xs-12">
                    @Html.Label("Stock Type", null, new { @class = "control-label" })
                    @Html.EnumDropDownListFor(model => model.StockType, new { @id = "StockType", @class = "form-control", tabindex = 3 })
                </div>
                <div class="col-sm-2 col-xs-12 form-group">
                    @Html.LabelFor(model => model.Date, htmlAttributes: new { @class = "control-label" })*
                    <div class="input-group date">
                        <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                        @Html.TextBoxFor(model => model.Date, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @required = "required" })
                    </div>
                </div>

                <div class="col-sm-2 col-xs-12 form-group" id="partyid">
                    @Html.Label("Material From", null, new { @class = "control-label" }) *
                    @if (User.IsInRole("Dev") || User.IsInRole("Create MC"))
                    {
                        <div class="input-group input-group-sm">
                            @Html.DropDownListFor(model => model.MCFrom, (SelectList)ViewBag.MCbag, new { id = "ddlMCFrom", @class = "form-control select2", @required = "required", @onchange = "checkbranch()" })
                            <span class="input-group-btn">
                                <a href="/MC/Create" class="btn btn-default modal-create btnpartyAdd" title="Add Party"><i class="glyphicon glyphicon-plus"></i></a>
                            </span>
                        </div> }
                    else
                    {
                        @Html.DropDownListFor(model => model.MCFrom, (SelectList)ViewBag.MCbag, "", new { id = "ddlMCFrom", @class = "form-control select2", @required = "required", @onchange = "checkbranch()" })}
                </div>
                <div class="col-sm-2 col-xs-12 form-group" id="partyid">
                    @Html.Label("Material To", null, new { @class = "control-label" }) *
                    @if (User.IsInRole("Dev") || User.IsInRole("Create MC"))
                    {
                        <div class="input-group input-group-sm">
                            @Html.DropDownListFor(model => model.MCTo, (SelectList)ViewBag.MCToBag, new { id = "ddlMCTo", @class = "form-control select2", @required = "required", @onchange = "checkbranch()" })
                            <span class="input-group-btn">
                                <a href="/MC/Create" class="btn btn-default modal-create btnpartyAdd" title="Add Party"><i class="glyphicon glyphicon-plus"></i></a>
                            </span>
                        </div> }
                    else
                    {
                        @Html.DropDownListFor(model => model.MCTo, (SelectList)ViewBag.MCToBag, "", new { id = "ddlMCTo", @class = "form-control select2", @required = "required", @onchange = "checkbranch()" })}
                </div>



                @if (@ViewBag.MLASTran == 0 && @ViewBag.StockTrnsfrUpdate == 0)
                {

                    <div class="form-group col-sm-2 col-xs-12" style="pointer-events: none;">
                        @Html.Label("Approved By", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlApprovedBy", (SelectList)ViewBag.ApproveBy, new { @class = "form-control", @name = "ddlApprovedBy[]", @multiple = "multiple" })
                    </div>
                }
                else if (@ViewBag.MLASTran == 0 && @ViewBag.StockTrnsfrUpdate != 0)
                {
                    <div class="form-group col-sm-2 col-xs-12">
                        @Html.Label("Approved By", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlApprovedBy", (SelectList)ViewBag.ApproveBy, new { @class = "form-control", @name = "ddlApprovedBy[]", @multiple = "multiple" })
                    </div>
                }

            </div>
            <div class="row">
                @if (Model.FieldMap.Count > 0)
                {
                    for (int i = 0; i < Model.FieldMap.Count; i++)
                    {
                        <div class="form-group col-sm-2 col-xs-12">
                            <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName</label>
                            <input class="form-control input-sm" id="@Model.FieldMap[i].Field" name="@Model.FieldMap[i].Field" type="text" value="">
                        </div>}
                }
            </div>


            <div class="row">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="normalinvoice">
                        <thead>
                            <tr>
                                <th class="text-center">S/N</th>
                                <th class="text-center">Item <i class="text-danger">*</i></th>
                                <th class="text-center">Unit</th>
                                <th class="text-center">Qty <i class="text-danger">*</i></th>
                                <th class="text-center">Price <i class="text-danger">*</i></th>
                                <th class="text-center">Amount</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody id="addinvoiceItem"></tbody>
                        <tfoot>
                            <tr>
                                <td> <b>Total</b> </td>
                                <td class="text-left"> <label id="ToItemCount"></label> </td>
                                <td></td>
                                <td class="text-right"> <label id="ToItemQnt"></label> </td>
                                <td class="text-right">
                                    <label id="ToItemPrice"></label>
                                </td>
                                <td class="text-right"> <label id="ToItemAmount"></label> </td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
            <div class="row">
                @*<div class="col-sm-3"></div>*@

                <div class="col-md-6 form-group">
                    @Html.Label("Remarks : ", null, new { @class = "control-label" })
                    @Html.TextAreaFor(model => model.Remarks, new { @class = "form-control", @rows = 3 })
                </div>
                <div class="form-group col-md-12">
                    @Html.Label("Documents", null, new { @class = "control-label" })
                    <div class="file-loading">
                        <input id="input-24" name="input24[]" type="file" multiple>
                    </div>
                </div>
                <div class="form-group col-md-6 no-padding pull-right">
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover" id="billsundry">
                            <thead>
                                <tr>
                                    <th class="text-center">S/N</th>
                                    <th class="text-center">Bill Sundry</th>
                                    <th class="text-center">Value</th>
                                    <th class="text-center">Type</th>
                                    <th class="text-center">Amount</th>
                                    <th class="text-center">Action</th>
                                </tr>
                            </thead>
                            <tbody id="addbillsundry"></tbody>
                        </table>
                    </div>
                </div>

            </div>
            <div class="row">
                <div class="form-group col-md-2 no-padding pull-right">
                    @Html.Label("Total Amount", null, new { @class = "control-label" })
                    @Html.TextBoxFor(model => model.TotalAmount, new { id = "GrandTotal", @class = "form-control", @readonly = "readonly" })
                </div>
            </div>
            <div class="col-md-6"></div>
            <div class="row">
                <div class="col-md-6">

                    <div class="form-group col-md-6 no-paddingleft">
                    </div>
                    <div class="form-group no-padding text-right">
                        <div class="checkbox-inline">
                            <input class="checkbox" data-val="true" id="hideheader" name="hideheader" type="checkbox" value="true">
                            <label class="control-label" for="hideheader">Hide Header In Print</label>
                        </div>
                    </div>
                    <div class="form-group pull-right">
                        <button type="submit" id="save" class="btn btn-success">
                            <span class="glyphicon glyphicon-floppy-disk"></span> Save
                        </button>
                        <button type="submit" id="print" class="btn btn-success">
                            <span class="glyphicon glyphicon-print"></span> Save And Print
                        </button>

                        @*
                               @if (@ViewBag.CheckMail == 0)
                                 {
                                    <button type="submit" id="sendmail" class="btn btn-success">
                                    <span class="glyphicon glyphicon-envelope"></span> Save And Mail
                                    </button>
                            }*@
                        <button type="button" class="btn btn-warning" onclick="window.location.href='/StockTransfer/Index'">Cancel</button>

                    </div>
                </div>
            </div>
        </div>
    </div>}


