                minimumInputLength: 0,
                ajax: {
                    //url: "/Accounts/SearchAccounts",
                    url: "/JournalV/SearchInvoiceNo",
                    dataType: 'json',

                    delay: 50,

                    data: function (params) {
                        return {
                            q: params.term || "",
                            page: params.page || 0
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 0;
                        return {
                            results: data,
                            pagination: {
                                //more: (params.page * 10) < 50
                                more: true
                            }
                        };
                    },
                    cache: true
                },
                /*templateResult: SelectToGroup,*/
                templateSelection: SelectionInvoice,
            });
        }
        function acctypecheck() {
            var acctype = $('#acctype').text();
            if (acctype != "Expense") {
                $('#invoice').html('<hr/>');
                $('.exp').hide();
                $('.sup').show();
            }
            else {
                $('#invoice').html('<hr/>');
                $('.exp').show();
                $('.sup').hide();
                grandTotal();
            }
