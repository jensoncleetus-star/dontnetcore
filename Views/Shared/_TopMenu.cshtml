<style>
    .blink {
        animation: blinker 1.5s linear infinite;
        color: red;
        font-family: sans-serif;
    }

    @@keyframes blinker {
        50% {
            opacity: 0;
        }
    }
</style>
<header class="main-header">
    <!-- Logo -->
    <a href="@Url.Action("Index", "Home", new {area="" })" class="logo">
        <span class="logo-mini"><b>BOS</b></span>
        <span class="logo-lg"><b>BOS</b></span>
    </a>
    <!-- Header Navbar: style can be found in header.less -->
    <nav class="navbar navbar-static-top">
        <!-- Sidebar toggle button-->
        <a href="#" class="sidebar-toggle" data-toggle="push-menu" role="button">
            <span class="sr-only">Toggle navigation</span>
        </a>
        <h3 class="title">
            @Html.Action("Company", "Home", new { area = "" })
        </h3>
        <div id="remainter" class="modal fade" role="dialog" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content" id="drag">
                    <div class="modal-header" id="dragheader">
                        <h4 class="modal-title"><i class="fa fa-bell" aria-hidden="true"></i> Reminders &amp; Alerts</h4>
                        <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                    </div>
                    <div class="modal-body">
                        <div class="post">
                            <div class="user-block">
                                <div class="row">
                                    <div class="box-header with-border">
                                        <h4 class="box-title">Reminders</h4>
                                        <div class="form-group col-md-12">
                                            @*@Html.DisplayFor(m => m.TaskDetails)*@
                                        </div>
                                    </div>
                                    <div class="box-body">
                                        <table class="table table-bordered table-hover" id="RemindInfoo">
                                            <thead>
                                                <tr class="bg-gray">
                                                    <td>SI No</td>

                                                    <td>Note</td>

                                                    <td>Action</td>


                                                </tr>
                                            </thead>
                                            <tbody></tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* Snooze date/time picker overlay (reminder Snooze -> hide until chosen time) *@
        <div id="snoozeOverlay" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;z-index:99999;background:rgba(15,23,42,.55);align-items:center;justify-content:center">
            <div style="background:#fff;border-radius:16px;padding:22px 24px;width:360px;max-width:92vw;box-shadow:0 24px 70px -16px rgba(0,0,0,.55)">
                <h4 style="margin:0 0 3px;font-weight:700;color:#1e293b;font-size:17px"><i class="fa fa-clock-o" style="color:#4f46e5"></i> Snooze reminder</h4>
                <p style="color:#64748b;font-size:13px;margin:0 0 12px">Hide this reminder until the date &amp; time you choose.</p>
                <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px">
                    <button type="button" class="btn btn-default btn-sm snz-preset" onclick="snoozePreset(4)">+4 hours</button>
                    <button type="button" class="btn btn-default btn-sm snz-preset" onclick="snoozePreset(24)">Tomorrow</button>
                    <button type="button" class="btn btn-default btn-sm snz-preset" onclick="snoozePreset(72)">+3 days</button>
                    <button type="button" class="btn btn-default btn-sm snz-preset" onclick="snoozePreset(168)">+1 week</button>
                </div>
                <input type="datetime-local" id="snoozeUntilInput" class="form-control" style="margin-bottom:18px" />
                <div style="text-align:right">
                    <button type="button" class="btn btn-default" onclick="closeSnooze()">Cancel</button>
                    <button type="button" class="btn btn-primary snz-go" onclick="confirmSnooze()"><i class="fa fa-bell-slash-o"></i> Snooze until this</button>
                </div>
            </div>
        </div>
        <style>
            #remainter .modal-content{border:none!important;border-radius:16px!important;overflow:hidden;box-shadow:0 24px 70px -20px rgba(15,23,42,.6)}
            #remainter .modal-header{background:linear-gradient(120deg,#4338ca,#6366f1 60%,#22d3ee)!important;padding:15px 22px!important;border:none!important;display:flex;align-items:center;justify-content:space-between}
            #remainter .modal-header .modal-title{color:#fff!important;font-weight:700;font-size:17px;margin:0}
            #remainter .modal-header .close{color:#fff!important;opacity:1;background:rgba(255,255,255,.18)!important;border-radius:8px;text-shadow:none}
            #remainter .modal-body{padding:16px 20px}
            #remainter .modal-body .box-header.with-border{display:none}
            #remainter #RemindInfoo thead td{background:#f1f5f9;color:#475569;font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:.4px;border:none;border-bottom:2px solid #e7ecf3;padding:10px 12px}
            #remainter #RemindInfoo tbody td{padding:12px;font-size:13px;border:none;border-bottom:1px solid #eef2f7;vertical-align:middle}
            #remainter #RemindInfoo tbody tr:hover td{background:#f8fafc}
            #remainter .rem-note{display:flex;gap:9px;color:#334155;line-height:1.5;align-items:flex-start}
            #remainter .rem-note-ic{color:#6366f1;margin-top:2px}
            #remainter a[onclick*="snoopthis"]{color:#b45309!important;font-weight:600}
            #remainter .dataTables_paginate .paginate_button.current{background:#4f46e5!important;color:#fff!important;border:none!important;border-radius:6px}
            #snoozeOverlay .snz-preset{border-radius:20px;font-size:12px}
            #snoozeOverlay .snz-go{background:linear-gradient(135deg,#4f46e5,#06b6d4);border:none;font-weight:700}
        </style>
