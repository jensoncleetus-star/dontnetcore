    @Html.AntiForgeryToken()
    <script>
        // Security (audit S2): attach the antiforgery token to every same-origin jQuery AJAX request.
        // MUST be registered immediately after jQuery loads — several grids (e.g. the layout's own
        // reminder table) fire their first AJAX during page parse, before document-ready. The token
        // input is read lazily at send time.
        (function () {
            if (!window.jQuery) return;
            jQuery(document).ajaxSend(function (e, xhr, settings) {
                if (settings.crossDomain) return;
                var t = document.querySelector('input[name="__RequestVerificationToken"]');
                if (t) { xhr.setRequestHeader('RequestVerificationToken', t.value); }
            });
        })();
    </script>


