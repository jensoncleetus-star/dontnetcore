                    ['a[onclick^="Reload"]', 'Reload'],
                    ['a[onclick^="logoff"]', 'Log Off']
                ];
                $.each(map, function (i, pair) {
                    var $el = $bar.find(pair[0]);
                    if ($el.length && !$el.attr('title')) $el.attr('title', pair[1]);
                });
                $bar.find('a[title]').tooltip({ container: 'body', placement: 'bottom', trigger: 'hover' });
