            // ADDITIVE (2026-06-15): hover tooltips for the top gradient-bar utility icons.
            // Sets each icon's title by a STABLE selector (no _TopMenu markup change), then inits the
            // Bootstrap tooltip plugin (loaded via the js bundle; jQuery is global). No-ops if absent.
            // Leading ';' terminates the preceding $('#calculator').on(...) statement (no trailing ;),
            // otherwise ASI would parse this IIFE as a call on the .on() result.
            ; (function () {
                if (!$.fn || !$.fn.tooltip) return;
                var $bar = $('.navbar-custom-menu');
                if (!$bar.length) return;
                var map = [
                    ['a[href="/BackUpRestore/BackUpdone"]', 'Data Backup'],
