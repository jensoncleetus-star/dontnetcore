        var _snoozeReminderId = 0;
        function snoopthis(id) {
            _snoozeReminderId = id;
            // default: tomorrow, same time (shown in the user's local time)
            var d = new Date();
            d.setDate(d.getDate() + 1);
            d.setMinutes(d.getMinutes() - d.getTimezoneOffset());
            var inp = document.getElementById('snoozeUntilInput');
            if (inp) { inp.value = d.toISOString().slice(0, 16); }
            var ov = document.getElementById('snoozeOverlay');
            if (ov) { ov.style.display = 'flex'; }
        }
        function closeSnooze() {
            var ov = document.getElementById('snoozeOverlay');
            if (ov) { ov.style.display = 'none'; }
        }
        function confirmSnooze() {
            var val = (document.getElementById('snoozeUntilInput') || {}).value || '';
            if (!val) { return; }
            $.ajax({
                url: '/Reminder/snoopthis/' + _snoozeReminderId + '?until=' + encodeURIComponent(val),
                type: "GET",
                contentType: false,
                processData: false,
                success: function (e) {
                    closeSnooze();
                    oTable1r.draw();
                }
            });
        }
        // quick-snooze presets (in hours) from the picker
        function snoozePreset(hours) {
            var d = new Date();
            d.setHours(d.getHours() + hours);
            d.setMinutes(d.getMinutes() - d.getTimezoneOffset());
            var inp = document.getElementById('snoozeUntilInput');
            if (inp) { inp.value = d.toISOString().slice(0, 16); }
        }
