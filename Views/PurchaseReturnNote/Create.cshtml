        PurchaseHireEntry(0);
        $("#SupplierType").prop('selectedIndex', 1);
    });



    $('body').on('change', '#ddlMC', function (e) {
        var mcval = $(this).val();
        searchItem();
    });

    /* function for Create popup */

    $('span').on('click', '.modal-create', function (e) {
        e.preventDefault();
        var url = $(this).attr('href');
        modalshow(url, '#modal-create');
    });
    $('#modal-create').on('submit', '#createform', function (e) {
        e.preventDefault();
        var url = $('#createform')[0].action;
        var data = $('#createform').serialize();
        createajax(url, data, '#modal-create');
    });

    $('span').on('click', '.modal-edit', function (e) {
        e.preventDefault();
        var url = $(this).attr('href');
        modalshow(url, '#modal-edit');
    });
    $('#modal-edit').on('submit', '#editform', function (e) {
        e.preventDefault();
        var url = $('#editform')[0].action;
        var data = $('#editform').serialize();
        createajax(url, data, '#modal-edit');
    });

    function preturntype() {
        var rettype = $('#ReturnType').val();
        if (rettype == 1) {
            $('#prbillno').hide();
        }
        if (rettype == 0) {
            $('#prbillno').show();
        }
        reset();
    }

    function reset() {
        $('#ddlEmployee').val("");
        $('#ddlSupplier').text("");
        $("#Discount").val("0.00");
        $("#PaidAmount").val("0.00");
        $("#GrandTotal").val("0.00");
        $("#DueAmount").val("0.00");

        $("#ddlSupplier").val(null).trigger("change");
        $("#ddlPurchaseEntry").val(null).trigger("change");
        $("#ddlEmployee").val(null).trigger("change");

        $(".select2 item_name").val(null).trigger('change');

        //   $('.item_name').select2('val', '0');
        //$(".item_name").val("").trigger("change");

        $("#ItemQty").text("");
        $("#SubTotal").text("");
        $("#total_tax_amount").text("");
        $("#total").text("");

        $("#addinvoiceItem").html("");
        addrow('addinvoiceItem', 'preturn', "", "0.00", "0.00", "0");

    }

    function purchaseEntryChange() {
        var prentry = $('#ddlPurchaseEntry').val();
        if (prentry != null) {
            $.ajax({
                url: '/PurchaseEntry/GetPurchaseEntryById',
                type: "GET",
                dataType: "JSON",
                data: { prentryId: prentry },
                success: function (result) {
                    var newOption = $('<option></option>');
                    newOption.val(result.Supplier).attr("selected", "selected");
                    newOption.html(result.SupplierName);
                    $('#ddlSupplier').append(newOption);
                    $('#ddlSupplier').val(result.Supplier).trigger("change");

                    //if (result.SupplierType == 1) {
                    //    $("[id$=SupplierType]").val(1);
                    //    //$('#amountpaid').hide();
                    //    //$('#amountdue').hide();
                    //} else {
                    //    $("[id$=SupplierType]").val(0);
                    //    //$('#amountpaid').show();
                    //    //$('#amountdue').show();
                    //}
                    $("[id$=PaidAmount]").val("0.00");
                    grandtotalcalculation();
                    paidamountcalculation();
                    //   $("[id$=PaidAmount]").val(result.PEPaidAmount.toFixed(2));
                    //  $("[id$=DueAmount]").val(result.PEDueAmount.toFixed(2));

                }
            });

            $.ajax({
                url: '/PurchaseEntry/GetPEItems',
                dataType: 'json',
                data: { PurchaseEntryID: prentry },
                cache: true,
                success: function (data) {
                    $('#addinvoiceItem').html('');
                    $.each($.parseJSON(data), function (i, item) {
                        addrow('addinvoiceItem', 'preturn', item.ItemUnit, item.ItemTax, item.ItemTotalAmount, item.ItemQuantity, item.Item, item.ItemCode, item.ItemName, item.ItemUnitPrice, item.ItemSubTotal, item.ItemWithCode, item.ItemTaxAmount, item.ItemDiscount, item.ItemNote, item);
                    });
                    addrow('addinvoiceItem', 'preturn', '', '0.00', '0.00', '0');
                }
            });


            $.ajax({
                url: '/PurchaseEntry/GetPEBillSundry',
                dataType: 'json',
                data: { PurchaseEntryID: prentry },
                cache: true,
                success: function (data) {
                    $('#addbillsundry').empty();
                    $.each(data, function (i, bs) {
                        addbillsundry('addbillsundry', 'purchase', bs.BsValue, bs.AmountType, bs.BsAmount, bs.BsType, bs.BSName, bs.BillSundry);
                    });
                    addbillsundry('addbillsundry', 'purchase', '0.00', '', '0.00', '');
                    grandtotalcalculation();
                }
            });

        }
    }

    $('body').on('change', '#ddlApprovedBy', function (e) {
        $("#SelApprovedBy").val($(this).val());
    });

    $('#purchaseform').on('submit', function (e) {

        var rettype = $('#ReturnType').val();
        var check = true;
        var invoice = $('#ddlPurchaseEntry').val();
        if (rettype == 0) {
            check = (invoice != null) ? true : false;
        }
        if (check == true) {

        e.preventDefault();
        if ($("#purchaseform").valid()) {
            //var fnval = e.originalEvent.explicitOriginalTarget.id;
            var fnval = $('input[type="submit"], button[type="submit"]', this).filter(':focus').attr('id');
            var PurchaseEntryId = $('#ddlPurchaseEntry').val();
            var BillNo = $('#BillNo').val();

            var SupplierID = $('#ddlSupplier').val();
            var EmployeeID = $('#ddlEmployee').val();
            var PRDate = $('#PRDate').val();

            //pending
            var PRItems = $('#ItemCount').val();
            var PRItemQuantity = $('#ItemQty').text();
            var PRSubTotal = $('#SubTotal').text();
            var PRTax = $('#total_tax_amount').text();

            var TotalTax = $('#total_tax_amount').text();
            var Discount = $('#ItemDisc').text();
            var GrandTotal = $('#GrandTotal').val();

            var PaidAmount = $('#PaidAmount').val();


            var PRNote = $('#PRNote').val();


            var SupplierType = $('#SupplierType').val();

            var ReturnType = $('#ReturnType').val();

            var suppEMail = $('#suppEmailId').val();
            var Remarks = $('#Remarks').val();
            var MaterialCenter = $('#ddlMC').val();
            var Branch = $('#ddlBranch').val();
            var PurchaseType = $('#PurchaseType').val();
            var ApprovedBy = $('#SelApprovedBy').val();
            //alert(fnval);

            var PurType = $('#PurType').val();

            var Ref1 = "";
            var Ref2 = "";
            var Ref3 = "";
            var Ref4 = "";
            var Ref5 = "";
            if ('@Model.FieldMap.Count' > 0) {
                Ref1 = $('#Ref1').val();
                Ref2 = $('#Ref2').val();
                Ref3 = $('#Ref3').val();
                Ref4 = $('#Ref4').val();
                Ref5 = $('#Ref5').val();
            }
            var Layout = $('#ddlPrintlayout').val();
            var HTMLtbl = {
                getData: function (table) {
                    var data = [];
                    table.find('tr').not(':first').not('.item_').each(function (rowIndex, r) {
                        var cols = [];
                        $(this).find('input,textarea,select').each(function (colIndex, c) {
                            cols.push($(this).val());
                        });
                        data.push(cols);
                    });
                    return data;
                }
            }

            var HTMLtblbs = {
                getData: function (table) {
                    var bsData = [];
                    table.find('tr').not(':first').not('.bs_').each(function (rowIndex, r) {
                        var cols = {};
                        $(this).find('input,textarea,select').each(function (colIndex, c) {
                            itid = $(this).attr('data-name').split(' ')[0];
                            itval = ($(this).val() != "") ? $(this).val() : $(this).text();
                            cols[itid] = itval;

                            //cols.push({ name: itid, index: itval });
                        });
                        bsData.push(cols);
                    });
                    return bsData;
                }
            }
            var bsData = HTMLtblbs.getData($('#billsundry'));
            // batch stock

            var HTMLtblbst = {
                getData: function (table) {
                    var bstData = [];
                    var order = 0;
                    var lastOne = 0;
                    table.find('tr').not(':first').not('.bs_').each(function (rowIndex, r) {
                        var cols = {};
                        $(this).find('input,textarea,select').each(function (colIndex, c) {
                            itid = $(this).attr('data-name').split(' ')[0];
                            itval = ($(this).val() != "") ? $(this).val() : $(this).text();
                            if (itid == "order") {
                                if (order == 0) {
                                    order = 1;
                                    lastOne = itval;
                                }
                                if (lastOne != itval) {
                                    order++;
                                    lastOne = itval;
                                }
                                itval = order;
                            }
                            cols[itid] = itval;
                        });
                        if (!jQuery.isEmptyObject(cols) && cols.BatchNo != "") {
                            bstData.push(cols);
                        }
                    });
                    return bstData;
                }
            }
            var bstdata = HTMLtblbst.getData($('.batchtbl'));

            var PREntry = [SupplierID, EmployeeID, PRDate, PRItems, PRItemQuantity,
                TotalTax, Discount, GrandTotal, PRSubTotal, PRTax, PaidAmount, PRNote,
                SupplierType, fnval, PurchaseEntryId, ReturnType, BillNo, suppEMail, Remarks, MaterialCenter, Branch, PurchaseType, ApprovedBy,
                Ref1, Ref2, Ref3, Ref4, Ref5, PurType, Layout]


            var data = HTMLtbl.getData($('#normalinvoice'));
            var parameters = {};
            parameters.array = data;
            parameters.purchasedata = PREntry;
            parameters.bsmodel = { 'prbsundrys': bsData };
            parameters.bstmodel = bstdata;



            if (fnval == "save" || fnval == "print") {
                submitForm(fnval, parameters);
            } else if (fnval == "sendmail") {
                if ($('#custEmailId').val() != "") {
                    submitForm(fnval, parameters);
                } else {
                    $('.ajax_response', res_danger).text("Customer Email Address Not Found..!!");
                    $('.AlertDiv').prepend(res_danger);
                }
            }
        }
        }
        else {
            $('.ajax_response', res_danger).text("Invoice no Required..!!");
            $('.AlertDiv').prepend(res_danger);
            //setTimeout(function () { location.reload(); }, '@TimeOut');
        }
    });
    function submitForm(fnval, parameters) {
        $.ajax({
            async: true,
            cache: false,
            dataType: "json",
            type: "POST",
            contentType: "application/json; charset=utf-8",
            url: "/PurchaseReturnNote/CreatePurchaseReturn",
            data: JSON.stringify(parameters),
            beforeSend: function () {
                $("button").prop('disabled', true); // disable button
            },
            success: function (e) {
                if (e.status == true) {
                    if (fnval == "print") {
                            @Html.Raw(posfun)
                    } else {
                        $('.ajax_response', res_success).text(e.message);
                        $('.AlertDiv').prepend(res_success);
                    }
                        if ('@ViewBag.BusinessType' != 'DeliveryManagement' || '@ViewBag.POS' != 'active' || fnval != "print") {
                            setTimeout(function () { location.reload(); }, '@TimeOut');
                        }
                } else {
                    $('.ajax_response', res_danger).text(e.message);
                    $('.AlertDiv').prepend(res_danger);
                    $("button").prop('disabled', false); // enable button
                }
            }
        });
    }
