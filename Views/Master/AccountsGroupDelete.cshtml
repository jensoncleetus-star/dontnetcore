@model QuickSoft.Models.AccountsGroup
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Delete Accounts Group</h4>
</div>
<div class="modal-body">
    @if (Model.Editable == 0)
    {
        <h3>Are you sure you want to delete this?</h3>
        using (Html.BeginForm("AccountsGroupDelete", "Master", FormMethod.Post, new { id = "deleteform" }))
        {
            @Html.AntiForgeryToken()
            <div class="form-actions no-color">
                <input type="submit" value="Delete" class="btn btn-danger col-sm-offset-4" />
                <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal">
            </div>
        }
    }
    else
    {
        <h3>Sorry, It is a Pre-defined Account Group And Cannot be Deleted.</h3>
    }
</div>