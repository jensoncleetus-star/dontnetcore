@model QuickSoft.Models.AccountsGroup
@{
    ViewBag.Title = "Expense Group List";
    ViewBag.SubTitle = "Master";
    ViewBag.Active = "Master";
    string actData = "";
    string statData = "";
}
<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">Expense Groups</h3>
        <div class="pull-right">
            @if (User.IsInRole("Dev") || User.IsInRole("Create Expense Group"))
            {
                <i class="ace-icon fa fa-hand-o-right icon-animated-hand-pointer blue"></i>
                <a class="btn btn-info no-border modal-create" href="/master/ExpenseGroupCreate">
                    <i class="glyphicon glyphicon-plus"></i> Create Expense Group
                </a>
            }
        </div>
    </div>
    <div class="box-body">
        <table class="table table-bordered table-hover" id="MyTable">
            <thead>
                <tr>
                    <td data-priority="2">#</td>
                    <td data-priority="1">Name</td>
                    <td data-priority="2">Alias</td>
                    @*<td data-priority="3">Parent Group </td>*@
                    @*<td data-priority="4">Primary</td>*@
                    <td data-priority="6"> Status</td>
                    <td data-priority="1"> Action</td>
                </tr>
            </thead>
            <tbody></tbody>
        </table>

    </div>
</div>

@Html.Partial("../Common/_ModalCreate")
@Html.Partial("../Common/_ModalEdit")
@Html.Partial("../Common/_ModalChange")
@Html.Partial("../Common/_ModalDelete")

@section scripts{
@Scripts.Render("~/js/jqueryval")
    <script type="text/javascript">
        var oTable = $('#MyTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "pageLength": 50,
            responsive: false,
            "ajax": {
                "url": '/master/ExpenseGroupGetData',
                "type": "POST",
                "datatype": "json"
            },
            "columns": [
                     {
                         "data": "id", "name": "id",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                 { "data": "Name", "name": "Name" },
                 { "data": "Alias", "name": "Alias" },
                 //{ "data": "ParentName", "name": "ParentName" },
                 //{ "data": "Primary", "name": "Primary" },
                 {

                     "name": "Status", "data": function (data) {
                         var rest = "";
                         if (data.Editable == 0) {
                             if (data.Status == 1) {
                                 @{
                                if (User.IsInRole("Dev") || User.IsInRole("Expense Group Status"))
                                {
                                    statData = "<a class=\"modal-change\" href=\"/master/ExpenseGroupStatus/'+ data.id +'/active\" title=\"Click To Active\"><i class=\"badge bg-red\" >Inactive</i></a> ";
                                }
                                          }
                                 return rest = '@Html.Raw(statData)';
                             }
                             else {
                                 @{
                                    if (User.IsInRole("Dev") || User.IsInRole("Expense Group Status"))
                                    {
                                        statData = "<a class=\"modal-change\" href=\"/master/ExpenseGroupStatus/'+ data.id +'/inactive\" title=\"Click To Inactive\"><i class=\"badge bg-green\" >Active</i></a> ";
                                    }
                                }
                                 return rest = '@Html.Raw(statData)';
                             }
                         } else {
                             return null;
                         }
                     }

                 },
                 //{
                 //    "data": "id", "name": "id", "render": function (data) {
                 //        return '<a class="modal-edit" href="/master/ExpenseGroupEdit/' + data + '" title="Edit Expense Group"><i class="fa fa-lg fa-edit" ></i></a> ' +
                 //              '<a class="modal-delete" href="/master/ExpenseGroupDelete/' + data + '" title="Delete Expense Group"><i class="fa fa-lg fa-trash" ></i></a>';
                 //    }
                 //},
                  {
                      "name": "id", "data": function (data) {
                          if (data.Editable == 0) {
                              var rest = "";
                              @{

                                  if (User.IsInRole("Dev") || User.IsInRole("Edit Expense Group"))
                                  {
                                      actData += "<a class=\"modal-edit\" href=\"/master/ExpenseGroupEdit/'+ data.id +'\" title=\"Edit Expense Group\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                                  }
                                  if (User.IsInRole("Dev") || User.IsInRole("Expense Group Delete"))
                                  {
                                      actData += "<a class=\"modal-delete\" href=\"/master/ExpenseGroupDelete/'+ data.id +'\" title=\"Delete Expense Group\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";
                                  }
                              }
                              return rest = '@Html.Raw(actData)';
                          } else {
                              return null;
                          }
                      }
                  },

            ]
        });


        /* function for Create popup */

        $('div').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        });
        $('#modal-create').on('submit', '#createform', function (e) {
            e.preventDefault();
            var url = $('#createform')[0].action;
            var data = $('#createform').serialize();
            createajax(url, data, '#modal-create');
        });


        /* function for Edit popup */

        $('div').on('click', '.modal-edit', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-edit');
        });
        $('#modal-edit').on('submit', '#editform', function (e) {
            e.preventDefault();
            var url = $('#editform')[0].action;
            var data = $('#editform').serialize();
            createajax(url, data, '#modal-edit');
        });

        /* function for delete popup */
        $('#MyTable').on('click', '.modal-delete', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-delete');
        });
        $('#modal-delete').on('submit', '#deleteform', function (e) {
            e.preventDefault();
            var url = $('#deleteform')[0].action;
            var data = $('#deleteform').serialize();
            createajax(url, data, '#modal-delete');
        });

        /* chang status */
        $('.table').on('click', '.modal-change', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-change');
        });
        $('#modal-change').on('submit', '#changeform', function (e) {
            e.preventDefault();
            var url = $('#changeform')[0].action;
            var data = $('#changeform').serialize();
            createajax(url, data, '#modal-change');
        });
    </script>
}