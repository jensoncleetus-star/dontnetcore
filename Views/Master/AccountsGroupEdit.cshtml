@model QuickSoft.Models.AccountsGroup
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Edit Accounts Group</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("AccountsGroupEdit", "Master", FormMethod.Post, new { id = "editform" }))
            {
        <script type="text/javascript">
            $('form#editform').removeData("validator");
            $('form#editform').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#editform'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        @Html.HiddenFor(model => model.AccountsGroupID)
        <input type="hidden" id="parentval" value="@Model.Parent"/>
        <div class="row">
            <div class="col-md-12">
                <div class="form-group  col-md-12">
                    @Html.Label("Name", null, new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.Name, new { htmlAttributes = new { @class = "form-control input-sm", autofocus = "autofocus", @required = "required" } })
                </div>
                <div class="form-group col-md-12">
                    @Html.Label("Alias", null, new { @class = "control-label" }) 
                    @Html.EditorFor(model => model.Alias, new { htmlAttributes = new { @class = "form-control input-sm", autofocus = "autofocus" } })
                </div>
                <div class="form-group col-md-4" style="display:none;">
                    @Html.Label("Primary", null, new { @class = "control-label" }) *
                    @Html.EnumDropDownListFor(model => model.Primary, new { @class = "form-control" })
                </div>
                <div class="form-group col-md-4">
                    @Html.Label("Parent", null, new { @class = "control-label" }) <span id="requ" hidden>*</span>
                    @Html.DropDownListFor(m => m.Parent, (SelectList)ViewBag.ParentModules, new { @class = "form-control select2" })
                </div>
                <div class="form-group col-md-4">
                    @Html.Label("Status", null, new { @class = "control-label" }) *
                    @Html.EnumDropDownListFor(model => model.Status, new { @class = "form-control" })
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" value="Update" class="btn btn-info col-sm-offset-4"  />
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>
@section scripts{
    @Scripts.Render("~/js/jqueryval")
}