@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/bootstrap-timepicker")
}
@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/bootstrap-timepicker")
<script type="text/javascript">
      var minDate = $("#Start").val();
      var maxDate = $("#End").val();

        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true,
            startDate: new Date(minDate),
            endDate: new Date(maxDate)
        });

        jQuery.validator.methods["date"] = function (value, element) { return true; }
        $(".timepicker").timepicker({
            showInputs: true,
            defaultTime: false,
            format: 'dd-mm-yyyy'
        });

        $(document).ready(function () {
            $('#searchhiretype').hide();
            $("#PurType").prop('selectedIndex', 0);
            $("#ddlMC").prop('selectedIndex', 0);
            $('#ddlMC').select2();
            $('#advsearchlist').hide();
        });

        var oTable = $('#PurchaseTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": false,
            "pageLength": 50,
            responsive: true,
            "bLengthChange": false,
            "ajax": {
                "url": '/PurchaseEntry/GetPurchaseEntryPayment',
                "data": function (data) {
                    data.BillNo = $('#BillNo').val();
                    data.FromDate = $('#FromDate').val();
                    data.ToDate = $('#ToDate').val();
                    data.supplier = $('#ddlSupplier').val();
                    data.salesperson = $('#ddlEmployee').val();
                    data.type = $('#ddlType').val();
                    data.user = $('#ddlCreatedBy').val();
                    data.Balance = $('#ddlBalance').val();
                    data.MC = $('#ddlMC').val();
                    data.appstat = $('#ApprovalStatus').val();
                    data.PurchaseType = $('#PurType').val();
                    data.HireType = $('#ddlHType').val();
                    data.PurchaseStatus = $('#ddlPurchaseStatus').val();
                    data.RefenceNo = $('#ReferenceNo').val();
                },
                "type": "POST",
                "datatype": "json"

            },
            "order": [[0, "desc"]],
            "columnDefs": [{
                "targets": [15],
                "orderable": false
            }],
            "columns": [
                     {
                         "data": "PurchaseEntryId", "name": "PurchaseEntryId",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                {  "name": "BillNo" ,"data": function (data) {
                        var rest = "";
                        @{
                            if (User.IsInRole("Dev") || User.IsInRole("View Purchase Entry"))
                            {
                                actData = "<a class=\"openpurchase\"  href=\"/PurchaseEntry/Edit/'+ data.PurchaseEntryId +'\" title=\"Edit Purchase\" target=\"_blank\">'+ data.BillNo +'</i></a> ";

                            }

                        }
                        rest = '@Html.Raw(actData)';



                        return rest;
                        // '<a class="modal-link-download" href = "/PurchaseEntry/Download/' + data + '" title="Download "><i class="fa fa-download" style="font-size: large"></i></a> ';
                        //'<a class="modal-link-document" href="" title="Send Quote"><i class="fa fa-share-square-o" style="font-size: large"></i></a>';
                    }
                },

                { "data": "PEDate", "name": "PEDate", "render": function (data) { return convertToDate(data); } },
                { "data": "Supplier", "name": "Supplier" },
                {
                    "data": "PurType", "name": "PurchaseType", "render": function (data) {
                        if (data == 1) {
                            return 'CrossHire';
                        }
                        else {
                            return 'Purchase';
                        }
                    }
                },
                 {
                     "name": "SupplierType",
                     "data": function (data) {
                         if (data.SupplierType == 0) {
                             return "Credit";
                         } else {
                             return "Cash";
                         }
                     }
                 },
                { "data": "PEGrandTotal", "name": "PEGrandTotal", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                { "data": "PEPaidAmount", "name": "PEPaidAmount", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },

                { "data": "BalanceAmt", "name": "BalanceAmt", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                { "data": "MC", "name": "MaterialCenter" },
                {
                    "data": "PurchaseStatus", "name": "PurchaseStatus",
                    "render": function (data) {
                        if (data == 0) {
                            return "Open";
                        }
                        else if (data == 1) {
                            return "Closed";
                        }
                        else {
                            return "";
                        }
                    }
                },
                { "data": "EmpName", "name": "EmpName" },
                { "data": "User", "name": "User" },

                //{ "data": "ReferenceNo", "name": "ReferenceNo" },
                 {
                     "name": "ApprovalStatus", "data": function (data, type, dataToSet) {
                         var status = "";
                         var cls = "";
                         if (data.app.length > 0 || (data.Approval == true && '@ViewBag.MLAPEntry' == 'active')) {
                             if (data.ApprovalStatus == "0") {
                                 status = '<span class="badge bg-green">Approved</span>';
                             }
                             else if (data.ApprovalStatus == "1") {
                                 status = '<span class="badge bg-red">Rejected</span>';
                             }
                             else if (data.ApprovalStatus == "2") {
                                 status = '<span class="badge bg-orange">Pending</span>';
                             }
                             else if (data.ApprovalStatus == "4") {
                                 status = '<span class="badge bg-blue">Partial Approved</span>';
                             }
                             return '<a  class="Updation" onclick="details(' + data.PurchaseEntryId + ')"  title="View Status">' + status + ' </a>';
                         } else { return null; }
                     }
                 },
                { "data": "PECreatedDate", "name": "PECreatedDate", "render": function (data) { return convertToDate(data); } },
                {
                    "name": "PurchaseEntryId", "data": function (data) {
                        var rest = "";
                        @{
                            if (User.IsInRole("Dev") || User.IsInRole("View Purchase Entry"))
                            {
                                actData = "<a class=\"modal-edit\"  href=\"/PurchaseEntry/EditStatusPayment/'+ data.PurchaseEntryId +'\" title=\"Edit Status\"><i class=\"fa fa-lg fa-refresh\" ></i></a> ";

                            }

                        }
                        rest = '@Html.Raw(actData)';



                        return rest;
                        // '<a class="modal-link-download" href = "/PurchaseEntry/Download/' + data + '" title="Download "><i class="fa fa-download" style="font-size: large"></i></a> ';
                        //'<a class="modal-link-document" href="" title="Send Quote"><i class="fa fa-share-square-o" style="font-size: large"></i></a>';
                    }
                },


            ],
            buttons: [
                'colvis',
                {
                    extend: 'print',//
                    title: "",
                    footer: true,
                    filename: function () {
                        return 'Purchase Entry';
                    },
                    columnDefs: [
                        { width: 400, targets: 2 }
                    ],
                    exportOptions: {
                        columns: ':visible'
                    },
                    message: function () {
                        var head = '<table class="tblcompact table table-bordered"><thead>' +
                        ' <tr><th class="text-center"><h3 style="margin-top: 0px;"><h4>Purchase Entry</h4></th></tr>';
                        return head;
                    },
                    customize: function (win) {
                        // $(win.document.body)
                        //.css('font-size', '10pt')
                        //.css('padding', '1px');
                        $(win.document.body).find('table.tblcompact tbody td').css('padding', '0px');
                        $(win.document.body).find('.dataTable,.dataTable th,.dataTable tr,table.tblcompact tbody td .dataTable td')
                            .css('font-size', '10pt')
                            .css('padding', '5px')
                            .addClass('compact');
                        $(win.document.body).find('.dataTable tr th:nth-child(3)')
                            .css('min-width', '80px');
                        //$(win.document.body).find('.tblcompact tbody td:nth- child(2)')
                        //    .css('padding', '0px');
                        $(win.document.body).append('</td></tr></tbody>')
                    }
                }, 'copy', 'csv', //'excel',
                {
                    extend: 'pdf',//
                    title: "",
                    footer: true,
                    filename: function () {
                        return 'Purchase Entry';
                    },
                    message: function () {
                        var head = 'Purchase Entry';
                        return head;
                    },
                    pageSize: 'A4',
                    exportOptions: {
                        columns: ':visible'
                    },
                    customize: function (doc) {
                        doc.pageMargins = [10, 10, 10, 10];
                        doc.defaultStyle.fontSize = 10;
                        doc.styles.tableHeader.fontSize = 10;
                        doc.styles.title.fontSize = 12;
                        // Header font and bg color
                        doc.styles.tableHeader.fillColor = '#d3d3d3';
                        doc.styles.tableHeader.color = 'black';
                        // Remove spaces around page title
                        doc.content[0].text = doc.content[0].text.trim();

                        doc.styles['td:nth-child(2)'] = {
                            width: '100%',
                            'max-width': '100%'
                        }

                        var objLayout = {};
                        // Horizontal line thickness
                        objLayout['hLineWidth'] = function (i) { return .5; };
                        // Vertikal line thickness
                        objLayout['vLineWidth'] = function (i) { return .5; };
                        //// Horizontal line color
                        //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                        //// Vertical line color
                        //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                        // Left padding of the cell
                        objLayout['paddingLeft'] = function (i) { return 4; };
                        // Right padding of the cell
                        objLayout['paddingRight'] = function (i) { return 4; };
                        // Inject the object in the document
                        doc.content[1].layout = objLayout;
                        // Footer font and bg color
                        doc.styles.tableFooter.fillColor = '#d3d3d3';
                        doc.styles.tableFooter.color = 'black';
                    }
                },  @Html.Raw(deleteBTn)

            ],
            sDom: "lBfr<'datatable-scroll't>ip",
            "drawCallback": function (settings) {
                //var table = $('#PurchaseTable').DataTable();
                //if (!table.data().any()) {
                //    $("#sub").hide();
                //} else {
                //    $("#sub").show();
                //}
            }
        });

        var bsns = '@ViewBag.BusinessType';
