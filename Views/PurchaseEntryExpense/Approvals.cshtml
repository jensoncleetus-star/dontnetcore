
@model QuickSoft.Models.PurchaseEntry
@{
    ViewBag.Title = "List";
    ViewBag.SubTitle = "Purchase Entry List";
    ViewBag.Active = "Transactions";
    string actData = "";
    string delchk = "";
    bool userRole = false;
    string deleteBTn = "";

    if (User.IsInRole("Dev") || User.IsInRole("Delete Purchase Entry"))
    {
        userRole = true;
        deleteBTn = "{text: 'Delete', className: 'btn-danger', action: function(e, dt, node, config) {" +
              "if ($('.checkbox:checked').length > 0) {if (confirm('Are you sure you want to delete this?')) {$('#delallform').submit(); e.preventDefault();} " +
               "} else {alert('Please Select Rows..!!');e.preventDefault();}}},";
    }
}

<style type="text/css">

    .dropdown-check-list {
        display: inline-block;
    }

        .dropdown-check-list .anchor {
            position: relative;
            cursor: pointer;
            display: inline-block;
            padding: 5px 50px 5px 10px;
            border: 1px solid #ccc;
            width: 150px;
            background: #fff;
            text-align: center;
        }

            .dropdown-check-list .anchor:after {
                position: absolute;
                content: "";
                border-left: 2px solid black;
                border-top: 2px solid black;
                padding: 5px;
                right: 10px;
                top: 20%;
                -moz-transform: rotate(-135deg);
                -ms-transform: rotate(-135deg);
                -o-transform: rotate(-135deg);
                -webkit-transform: rotate(-135deg);
                transform: rotate(-135deg);
            }

            .dropdown-check-list .anchor:active:after {
                right: 8px;
                top: 21%;
            }

        .dropdown-check-list ul.items {
            padding: 0px;
            display: none;
            margin: 0;
            border: 1px solid #ccc;
            border-top: none;
            position: absolute;
            z-index: 9999;
        }

            .dropdown-check-list ul.items li {
                list-style: none;
                background: #fff;
                padding: 5px;
            }

    .add-btn-item {
        border-radius: 23px;
        padding: 6px 20px;
    }

    .dropdown-check-list.visible .anchor {
        color: #0094ff;
    }

    .dropdown-check-list.visible .items {
        display: block;
    }

    .sh-spaan-text-style {
        font-family: sans-serif;
    }

    .sh-input-drop {
        border: 1px solid rgb(0 0 0 / 0.20);
        padding: 3px;
    }

    @@media only screen and (max-width: 400px) {
        .top3 {
            margin-top: 27px;
        }

        .adv-search-height {
            margin-left: 10px !important;
        }

        .responsive-search {
            padding: 0px 0px 0px 0px !important;
        }

        .btn-close {
            background-color: red !important;
            width: 150px !important;
        }

        .task-name-center {
            text-align: center !important;
        }

        .button-left-margin {
            margin-left: 25%;
        }

        .drop-align-center {
            position: relative !important;
            left: 60px;
        }
    }

    @@media only screen and (min-width: 800px) {
        .top3 {
            margin-top: 10px;
        }

        .adv-search-height {
            top: -10px !important;
            margin-left: 13px;
        }

        .responsive-search {
            padding: 25px 0px 0px 50px !important;
        }

        .btn-close {
            background-color: red !important;
        }
    }
</style>

<div class="box box-info">
    <div class="box-header with-border">

        <div class="row">
            <div class="col-md-10 col-xs-12 task-name-center ">
                <h3 class="box-title" style="font-size:x-large;">List Purchase Entry</h3>
            </div>
            <div class="col-md-2 col-xs-12 pull-right sh-downonSmallScreen" style="padding: 0px; margin: 10px 0px 0px 0px;">

                <div class="row">

                    <div class="col-md-10 col-xs-6 col-xs-offset-3" style="padding:0px; width:150px; ">

                        <a class="btn btn-info no-border" href="/PurchaseEntry/Create">
                            <i class="fa fa-plus"></i>&nbsp; Create
                        </a>

                    </div>
                </div>

            </div>
            <div class="col-md-2 col-xs-10 " id="taskchecklist" style="padding:0px; margin:auto;">
                <div id="list1" class="dropdown-check-list drop-align-center" tabindex="100">
                    <span class="anchor " style="z-index:0;">Select Fields</span>
                    <ul class="items">
                        <li><input type="checkbox" id="liinvoiceno" />Invoice No.</li>
                        <li><input type="checkbox" id="liPurchaseStatus" />Purchase Status</li>
                        <li><input type="checkbox" id="lifromdate" />From Date</li>
                        <li><input type="checkbox" id="litodate" />To Date</li>
                        <li><input type="checkbox" id="lipaymenttype" />Payment Type</li>
                        <li><input type="checkbox" id="lisupplier" />Supplier</li>
                        <li><input type="checkbox" id="lisalesexctve" />Sales Executive</li>
                        <li><input type="checkbox" id="licreatedby" />Created By</li>
                        <li><input type="checkbox" id="libalance" />Balance</li>
                        <li><input type="checkbox" id="limatrlcntre" />Material Center</li>
                        <li><input type="checkbox" id="liapprvlstatus" />Approval Status</li>
                        <li><input type="checkbox" id="liReferenceNo" />Reference No.</li>
                    </ul>
                </div>
            </div>
            <div class="col-md-12 col-xs-12">
                <div class="box-body search-box adv-search-height" id="advsearchlist">
                    <div class="search-body responsive-search " style="background:none;">
                        <form id="search-form">
                            <div class="row">
                                <input type="hidden" id="remId" />
                                <div class="form-group col-md-3" id="searchinvno">
                                    @Html.Label("Invoice No", null, new { @class = "control-label" })
                                    @Html.TextBox("BillNo", "", new { @class = "form-control input-sm" })
                                </div>

                                <div class="form-group col-md-3" id="searchfromdate">
                                    @Html.Label("From Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("FromDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group col-md-3" id="searchtodate">
                                    @Html.Label("To Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("ToDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group col-md-3" id="searchpaymenttype">
                                    @Html.Label("Payment Type", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlType", new SelectList(new List<SelectListItem>
                                        {
                                        new SelectListItem() {Text = "All", Value=""},
                                        new SelectListItem() {Text = "Credit", Value="0"},
                                        new SelectListItem() {Text = "Cash", Value="1"}
                                        }, "Value", "Text"), new { @class = "form-control input-sm", @name = "ddlType" })
                                </div>
                                <div class="form-group col-md-3" id="searchsupplier">
                                    @Html.Label("Supplier", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlSupplier", (SelectList)ViewBag.Supplier, new { @class = "form-control input-sm select2" })
                                </div>
                                <div class="form-group col-md-3" id="searchemployee">
                                    @Html.Label("Sales Executive", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlEmployee", (SelectList)ViewBag.SalesExecutive, new { @class = "form-control input-sm select2" })
                                </div>
                                <div class="form-group col-md-2" id="searchcreatdby">
                                    @Html.Label("Created By", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlCreatedBy", (SelectList)ViewBag.CreatedBy, "All", new { @class = "form-control input-sm select2" })
                                </div>

                                <div class="form-group col-md-3" id="searchPurchaseStatus">
                                    @Html.Label("Purchase Status", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlPurchaseStatus", new SelectList(new List<SelectListItem>
                                        {
                                        new SelectListItem() {Text = "All", Value=""},
                                        new SelectListItem() {Text = "Open", Value="0"},
                                        new SelectListItem() {Text = "Closed", Value="1"}
                                        }, "Value", "Text"), new { @class = "form-control input-sm" })
                                </div>
                                <div class="form-group col-md-3" id="searchbalance">
                                    @Html.Label("Balance", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlBalance", (SelectList)ViewBag.Balance, new { @class = "form-control input-sm select2" })
                                </div>
                                @if (@ViewBag.BusinessType == "Scaffold")
                                {
                                    <div class="form-group col-md-3" id="searchtype">
                                        @Html.Label("Type", null, new { @class = "control-label" })
                                        @Html.DropDownList("PurType", (SelectList)ViewBag.Type, new { @class = "form-control select2" })
                                    </div>
                                    <div class="form-group col-md-3" id="searchhiretype">
                                        @Html.Label("HireType", null, new { @class = "control-label" })
                                        @Html.DropDownList("HireType", (SelectList)ViewBag.HiType, "All", new { id = "ddlHType", @class = "form-control select2" })
                                    </div>
                                }
                                @if (@ViewBag.EnableMCcheck == 0)
                                {
                                    <div class="form-group col-md-3" id="searchmatcntr">
                                        @Html.Label("Material Center", null, new { @class = "control-label" })
                                        @Html.DropDownList("ddlMC", (SelectList)ViewBag.MC, "All", new { @class = "form-control input-sm" })
                                    </div>
                                }
                                @if (ViewBag.MLAPEntry == 0)
                                {
                                    <div class="form-group col-md-3" id="searchapprovalstatus">
                                        @Html.Label("Approval Status", null, new { @class = "control-label" })
                                        @Html.DropDownList("ApprovalStatus", (SelectList)ViewBag.AppStat, "All", new { id = "ApprovalStatus", @class = "form-control" })
                                    </div>
                                }
                                <div class="form-group col-md-3" id="searchRefenceno">
                                    @Html.Label("Reference No", null, new { @class = "control-label" })
                                    @Html.TextBox("ReferenceNo", "", new { @class = "form-control input-sm" })
                                </div>
                                <div class="form-group col-md-2 col-6 text-center" id="search">
                                    <input type="submit" class="btn btn-submit" value="Submit" />
                                </div>
                                <div class="form-group col-md-2 col-6 text-center" id="close">
                                    <input type="button" class="btn btn-close" value="Close" />
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <div class=" col-md-2" id="searchpagelength">

                <span class="sh-spaan-text-style">Show &nbsp;</span>@Html.DropDownList("ddlPagesize", new SelectList(new List<SelectListItem>
{
new SelectListItem() {Text = "50 Rows", Value="50"},
new SelectListItem() {Text = "All Rows", Value="10000000"},

}, "Value", "Text"), new { @class = "sh-input-drop select2" })

            </div>
        </div>
    </div>

    @using (Html.BeginForm("DeleteAllPurchase", "PurchaseEntry", FormMethod.Post, new { id = "delallform", role = "form" }))
    {
        <div class="box-body">
            <table class="table table-bordered table-hover" id="PurchaseTable">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="2">S/N</td>
                        <td data-priority="1">Invoice No</td>
                        <td data-priority="2">Date</td>
                        <td data-priority="3">Supplier</td>
                        <td data-priority="3">Purchase Type</td>
                        <td data-priority="3">Payment Type</td>
                        <td data-priority="2" class="headeralign">Total Amount</td>
                        <td data-priority="2" class="headeralign">Paid Amount</td>
                        <td data-priority="2" class="headeralign">Balance Amount</td>
                        <td data-priority="5">Material Center</td>
                        <td data-priority="4">Purchase Status</td>
                        <td data-priority="4">Executive</td>
                        <td data-priority="4">Created By</td>
                        @*<td data-priority="4">Reference No</td>*@
                        <td data-priority="3">Approval Status</td>
                        <td data-priority="3">Created Date</td>
                        <td data-priority="1">Action</td>
                        <td data-priority="2"><input type="checkbox" id="select_all" /></td>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

        <input type="hidden" value="@ViewBag.StartDate" class="Start" name="Start" id="Start">
        <input type="hidden" value="@ViewBag.EndDate" class="End" name="End" id="End">
    }

    <div id="modal-container2" class="modal fade" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-aqua">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                    <h4>Status Updation History</h4>
                </div>
                <div class="modal-body">
                    <table class="table table-bordered table-hover" id="UserTableInfo">
                        <thead>
                            <tr class="bg-aqua">
                                <td>Status</td>
                                <td>Updated By</td>
                                <td>Requested By</td>
                                <td>Date</td>
                                <td>Remarks</td>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

