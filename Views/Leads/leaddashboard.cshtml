
@model QuickSoft.ViewModel.HomeViewModel

@{
    List<QuickSoft.ViewModel.paramclass> leadstat = ViewBag.dashboard;
    List<QuickSoft.ViewModel.paramclass> leadstatexp = ViewBag.expiredlead;
}

@{var Model = "";}
@Html.Partial("../Common/_ModalCreate", @Model)
@Html.Partial("../Common/_ModalDelete")
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/bootstrap-fileinput")
    @Styles.Render("~/css/bootstrap-fileinput-rtl")
}
@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/bootstrap-fileinput")
    @Scripts.Render("~/js/bootstrap-sortable")
    @Scripts.Render("~/js/bootstrap-purify")
}
<style>
    .sh-bg1 {
        background-image: linear-gradient(to bottom right,rgba(138, 196, 238), rgb(0 148 255));
    }

    .sh-bg2 {
        background-image: linear-gradient(to bottom right,rgba(132, 243, 197), rgba(8, 176, 106));
    }

    .sh-bg3 {
        background-image: linear-gradient(to bottom right,rgba(238, 132, 187), rgba(164, 16, 138));
    }

    .sh-bg4 {
        background-image: linear-gradient(to bottom right,rgba(190, 217, 181),rgba(63, 113, 47));
    }

    .sh-bg5 {
        background-color: white;
        box-shadow: 0 8px 16px 0 rgba(0,0,0,0.2);
        border-radius: 5px;
    }

    .card-box {
        position: relative;
        color: #fff;
        padding: 20px 10px 40px;
        margin: 10px 0px;
        border-radius: 5px;
    }

        .card-box:hover {
            text-decoration: none;
            box-shadow: 5px 8px 16px 5px rgba(0,0,0,0.3);
            transform: scale(1.01);
        }

            .card-box:hover .icon i {
                font-size: 100px;
                transition: 1s;
                -webkit-transition: 1s;
            }

        .card-box .inner {
            padding: 5px 10px 0 10px;
        }

        .card-box h3 {
            font-size: 27px;
            font-weight: bold;
            margin: 0 0 8px 0;
            white-space: nowrap;
            padding: 0;
            text-align: left;
            text-shadow: 2px 2px 4px #000000;
        }

        .card-box p {
            font-size: 15px;
        }

        .card-box .icon {
            position: absolute;
            top: auto;
            bottom: 5px;
            right: 10px;
            z-index: 0;
            font-size: 72px;
            color: rgba(0, 0, 0, 0.15);
        }

        .card-box .card-box-footer {
            position: absolute;
            left: 0px;
            bottom: 0px;
            text-align: center;
            padding: 3px 0;
            color: rgba(255, 255, 255, 0.8);
            background: rgba(0, 0, 0, 0.1);
            width: 100%;
            text-decoration: none;
            border-radius: 0px 0px 5px 5px;
        }

        .card-box:hover .card-box-footer {
            background: rgba(0, 0, 0, 0.3);
        }

        .card-box .sh-title-align {
            background-image: linear-gradient(to bottom right,rgba(184, 220, 245, 1), rgb(0 148 255));
            padding: 1px 0px 1px 10px;
            margin-top: -10px !important;
            border-radius: 5px 5px 0px 0px;
        }

        .card-box h4 {
            text-shadow: 2px 2px 4px #000000;
        }

    .sh-row-design {
        background-color: white;
    }


    @@media only screen and (min-width: 800px) {
    }

    @@media only screen and (min-width: 1250px) {
    }

    @@media only screen and (max-width: 400px) {
    }
    .box.box-info
    {
        height:200px;
        overflow:scroll-y;
    }
</style>
<div class="row sh-row-design" style="margin:10px;padding:10px;">

    <h3 >Total Lead Status</h3>
    <div class="row" >
        @foreach (var da in leadstat)
        {
            <div class="col-md-2">
                <div class="box box-info top-10">
                    <h3 class="box-title"><center>@da.statusname</center></h3>
                    <div class="box-body">
                        <center>
                            <strong>
                                <a href="/Leads/modallist?leadid=@da.satusid&type=0" target="_new"> Count : @da.count</a>
                            </strong>
                        </center>
                    </div>

                </div>
            </div>
        }
    </div>
    <h3 >Lead Expired Status</h3>
    <div class="row" >
        @foreach (var da in leadstatexp)
        {
            <div class="col-md-2">
                <div class="box box-info top-10">
                    <h3 class="box-title"><center>@da.statusname</center></h3>
                    <div class="box-body">
                        <center>
                            <strong>
                                <a href="/Leads/modallist?leadid=@da.satusid&type=1" target="_new"> Count : @da.count</a>
                            </strong>
                        </center>
                    </div>

                </div>
            </div>
        }
    </div>
</div>