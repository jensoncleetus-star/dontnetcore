@model QuickSoft.Models.Customer
@{
    ViewBag.Title = "My Leads List";
    ViewBag.SubTitle = "My Leads";
    ViewBag.Active = "Master";
    string actData = "";
    string delchk = "";
    bool userRole = false;

    string deleteBTn = "";
    if (User.IsInRole("Dev") || User.IsInRole("Delete Leads"))
    {
        userRole = true;
        deleteBTn = "{text: 'Delete', className: 'btn-danger', action: function(e, dt, node, config) {" +
             "if ($('.checkbox:checked').length > 0) {if (confirm('Are you sure you want to delete this?')) {$('#payform').submit(); e.preventDefault();} " +
              "} else {alert('Please Select Rows..!!');e.preventDefault();}}},";
    }
}

<style type="text/css">
    .redclass {
        color: red;
    }
    .dropdown-check-list {
        display: inline-block;
        /*  position: absolute;*/
    }

        .dropdown-check-list .anchor {
            position: relative;
            cursor: pointer;
            display: inline-block;
            padding: 5px 50px 5px 10px;
            border: 1px solid #ccc;
            width: 150px;
            background: #fff;
            text-align: center;
        }

            .dropdown-check-list .anchor:after {
                position: absolute;
                content: "";
                border-left: 2px solid black;
                border-top: 2px solid black;
                padding: 5px;
                right: 10px;
                top: 20%;
                -moz-transform: rotate(-135deg);
                -ms-transform: rotate(-135deg);
                -o-transform: rotate(-135deg);
                -webkit-transform: rotate(-135deg);
                transform: rotate(-135deg);
            }

            .dropdown-check-list .anchor:active:after {
                right: 8px;
                top: 21%;
            }

        .dropdown-check-list ul.items {
            padding: 0px;
            display: none;
            margin: 0;
            border: 1px solid #ccc;
            border-top: none;
            position: absolute;
            z-index: 9;
        }

            .dropdown-check-list ul.items li {
                list-style: none;
                background: #fff;
                padding: 5px;
            }

    .add-btn-item {
        border-radius: 23px;
        padding: 6px 20px;
    }

    .dropdown-check-list.visible .anchor {
        color: #0094ff;
    }

    .dropdown-check-list.visible .items {
        display: block;
    }
</style>
<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">My Leads</h3>
        <div class="pull-right">
            @if (User.IsInRole("Dev") || User.IsInRole("Create Leads"))
            {
                <i class="ace-icon fa fa-hand-o-right icon-animated-hand-pointer blue"></i>
                <a class="btn btn-info no-border" href="/Leads/Create">
                    <i class="glyphicon glyphicon-plus"></i> Create Leads
                </a>
            }
            else
            {
                <i class="ace-icon fa fa-hand-o-right icon-animated-hand-pointer blue"></i>
                <a class="btn btn-info no-border" href="/Leads/Create/?format=2">
                    <i class="glyphicon glyphicon-plus"></i> Create Own Leads
                </a>
            }
            <div class="col-md-10 col-xs-4 pull-right" style="padding:0px;">
                <a class="btn btn-info no-border" href="/VehicleUPdates/entrys" target="_new">
                    <i class="glyphicon glyphicon-plus"></i> Vehicle Entry
                </a>
            </div>
        </div>
       
        <div class="row">

            <div class="col-md-2">

                <div id="list1" class="dropdown-check-list" tabindex="100">
                    <span class="anchor" style="z-index:9;">Select Fields</span>
                    <ul class="items">
                        <li><input type="checkbox" id="lileadcode" checked />Lead Code </li>
                        <li><input type="checkbox" id="lileadname" class="liname" checked />Lead Name </li>
                        <li><input type="checkbox" name="checks" id="lileadsource" />Lead Source</li>
                        <li><input type="checkbox" id="lileadstatus" checked />Current Action Lead Status</li>
                        <li><input type="checkbox" id="lileadnextdate" checked />Next Date</li>
                        <li><input type="checkbox" name="checks" id="licreatedby" />Created By</li>
                        <li><input type="checkbox" name="checks" id="lilocation" />Location</li>
                        <li><input type="checkbox" name="checks" id="lileadlevel" />Lead Level</li>
                        <li><input type="checkbox" id="limobile" checked />Mobile</li>
                        <li><input type="checkbox" name="checks" id="lifromdate" />From Date</li>
                        <li><input type="checkbox" name="checks" id="litodate" />To Date</li>
                        <li><input type="checkbox" name="checks" id="lilastupdated" />Last Updated</li>
                    </ul>
                </div>
            </div>

            <div class="col-md-12">

                <div class="box-body search-box" id="advsearchlist">

                    <div class="search-body col-md-12" style="background:none;">

                        <form id="search-form">

                            <div class="row">
                                <div class="form-group col-md-2" id="searchleadcode">
                                    @Html.Label("Lead Code", null, new { @class = "control-label" })
                                    @Html.TextBox("LeadCode", "", new { @class = "form-control input-sm" })
                                </div>
                                <div class="form-group col-md-2" id="searchleadname" hidden>
                                    @Html.Label("Lead Name", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlLeadName", (SelectList)ViewBag.LeadName, new { @class = "form-control input-sm select2" })
                                </div>
                                <div class="form-group col-md-2" id="searchleadsource" hidden>
                                    @Html.Label("Lead Source", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlLeadSource", (SelectList)ViewBag.LeadSource, new { @class = "form-control input-sm select2" })
                                </div>
                                <div class="form-group col-md-2" id="searchcreatedby" hidden>
                                    @Html.Label("CreatedBy", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlCreatedBy", (SelectList)ViewBag.CreatedBy, new { @class = "form-control input-sm select2" })
                                </div>
                                <div class="form-group col-md-2" id="searchlocation" hidden>
                                    @Html.Label("Location", null, new { @class = "control-label" })
                                    @Html.TextBox("TxtLocation", "", new { @class = "form-control input-sm", @autocomplete = "off" })
                                </div>
                                <div class="form-group col-md-2" id="searchleadstatus" style="margin-bottom:14px;">
                                    @Html.Label("Lead Status", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlLeadStatus", (SelectList)ViewBag.LeadStatus, new { @class = "form-control input-sm select2" })
                                </div>
                                <div class="form-group col-md-2" id="searchleadlevel" hidden>
                                    @Html.LabelFor(model => model.LeadLevel, htmlAttributes: new { @class = "control-label " })
                                    @Html.DropDownList("LeadLevel", new SelectList(new List<SelectListItem>
                                    {
                                       new SelectListItem(){ Text = "All", Value="All"},
                                        new SelectListItem() {Text = "Small", Value="Small"},
                                        new SelectListItem() {Text = "Medium", Value="Medium"},
                                        new SelectListItem() {Text = "High", Value="High"},
                                    }, "Value", "Text"), new { @class = "form-control input-sm", @name = "LeadLevel", @required = "required", tabindex = 7 })
                                </div>
                                <div class="form-group col-md-2" id="searchmobile" hidden style="margin-bottom:14px;">
                                    @Html.Label("Mobile", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlmobile", (SelectList)ViewBag.Mobile, new { @class = "form-control input-sm select2" })
                                </div>
                                <div class="form-group col-md-2" id="searchnextdate" hidden>
                                    @Html.Label("Next Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("NextDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group col-md-2" id="searchfromdate" hidden>
                                    @Html.Label("From Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("From", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group col-md-2" id="searchtodate" hidden>
                                    @Html.Label("To Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("To", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group col-md-2" id="searchlastupdated" hidden style="margin-bottom:14px;">
                                    @Html.Label("LastUpdated", null, new { @class = "control-label" })
                                    @Html.DropDownList("LastUpdated", new SelectList(new List<SelectListItem>
                                    {
                                       new SelectListItem(){ Text = "All", Value="0"},
                                        new SelectListItem() {Text = "1 Day Ago", Value="1"},
                                        new SelectListItem() {Text = "7 Days Ago", Value="7"},
                                        new SelectListItem() {Text = "1 Month Ago", Value="30"},
                                        new SelectListItem() {Text = "3 Months Ago", Value="90"},
                                        new SelectListItem() {Text = "6 Months Ago", Value="180"},
                                        new SelectListItem() {Text = "1 Year Ago", Value="360"},
                                    }, "Value", "Text"), new { @class = "form-control input-sm", @name = "LastUpdated", tabindex = 7 })
                                </div>

                                <div class="form-group col-md-2" id="search">
                                    <input type="submit" class="btn btn-submit" value="Submit" />
                                </div>
                                <div class="form-group col-md-2" id="close">
                                    <input type="button" class="btn btn-close" value="Close" />
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @using (Html.BeginForm("DeleteAllLeads", "Leads", FormMethod.Post, new { id = "payform", role = "form" }))
    {
        <div class="box-body">
            <table class="table table-bordered table-hover" id="MyTable">
                <thead>
                    <tr class="bg-gray">
