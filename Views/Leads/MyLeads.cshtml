<script type="text/javascript">
    var chkflag = 0;
    $(window).scroll(function (e) {
        var scroll = $(window).scrollTop();
        if (scroll >= 0) {
            $('.treeview-menu').addClass("navbar-hide");
            var i = scroll;
            $(".navbar-hide").css('margin-top', -i);

        } else {
            $(".navbar-hide").css('margin-top', 0);
            $('.treeview-menu').removeClass("navbar-hide");
        }

    });
        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        })

        $(document).ready(function () {
            //$('#advsearchlist').hide();
            $('#searchleadsource').hide();
            $('#searchcreatedby').hide();
            $('#searchlocation').hide();


            $('#searchleadlevel').hide();
            $('#searchfromdate').hide();
            //$('#searchnextdate').hide();
            $('#searchtodate').hide();
            $('#searchlastupdated').hide();

            $('[data-confirm]').click(function (e) {
                if ($('.checkbox:checked').length > 0) {
                    if (!confirm(jQuery(this).attr("data-confirm"))) {
                        e.preventDefault();
                    }
                } else {
                    alert("Please Select Rows..!!");
                    e.preventDefault();
                }
            });
        });

      /************* Function to display/hide fields while clicking on checkboxes (Select Fields) **************/
      $("ul li input:checkbox").click(function () {
          var _show = 0;
          //Lead Code
          if ($("#lileadcode").prop("checked") == true) {
              $("#searchleadcode").show();
              _show = 1;
          }
          else {
              $("#LeadCode").val("");
              $("#searchleadcode").hide();
              // oTable.draw();
          }
          //Lead Name
          if ($("#lileadname").prop("checked") == true) {
              $("#searchleadname").show();
              _show = 1;
          }
          else {
              $('#ddlLeadName').val(0).trigger("change");
              $("#searchleadname").hide();
            //  oTable.draw();
          }

          //Lead Source
          if ($("#lileadsource").prop("checked") == true) {
              $("#searchleadsource").show();
              _show = 1;
          }
          else {
              $('#ddlLeadSource').val(0).trigger("change");
              $("#searchleadsource").hide();
             // oTable.draw();
          }

          //Created By
          if ($("#licreatedby").prop("checked") == true) {
              $("#searchcreatedby").show();
              _show = 1;
          }
          else {
              $('#ddlCreatedBy').val(0).trigger("change");
              $("#searchcreatedby").hide();
              //oTable.draw();
          }

          //Location
          if ($("#lilocation").prop("checked") == true) {
              $("#searchlocation").show();
              _show = 1;
          }
          else {
              $('#TxtLocation').val("");
              $("#searchlocation").hide();
             // oTable.draw();
          }

          //Lead Status
          if ($("#lileadstatus").prop("checked") == true) {
              $("#searchleadstatus").show();
              _show = 1;
          }
          else {
              $('#ddlLeadStatus').val(0).trigger("change");
              $("#searchleadstatus").hide();
              // oTable.draw();
          }
          if ($("#lileadnextdate").prop("checked") == true) {
              $("#searchnextdate").show();
              _show = 1;
          }
          else {
              $('#lileadnextdate').val(0).trigger("change");
              $("#searchnextdate").hide();
              // oTable.draw();
          }

          //Lead Level
          if ($("#lileadlevel").prop("checked") == true) {
              $("#searchleadlevel").show();
              _show = 1;
          }
          else {
              $("#LeadLevel").val("All");
              $("#searchleadlevel").hide();
             // oTable.draw();
          }

          //Mobile
          if ($("#limobile").prop("checked") == true) {
              $("#searchmobile").show();
              _show = 1;
          }
          else {
              $('#ddlmobile').val("All").trigger("change");
              $("#searchmobile").hide();
              //oTable.draw();
          }

          //From Date
          if ($("#lifromdate").prop("checked") == true) {
              $("#searchfromdate").show();
              _show = 1;
          }
          else {
              $("#From").val("");
              $("#searchfromdate").hide();
             // oTable.draw();
          }

          //To Date
          if ($("#litodate").prop("checked") == true) {
              $("#searchtodate").show();
              _show = 1;
          } else {
              $("#To").val("");
              $("#searchtodate").hide();
            //  oTable.draw();
          }

          //last Updated
          if ($("#lilastupdated").prop("checked") == true) {
              $("#searchlastupdated").show();
              _show = 1;
          }
          else {
              $("#LastUpdated").val(0);
              $("#searchlastupdated").hide();
             // oTable.draw();
          }

          //If anyone checked, show Search division
          if (_show == 1) {
              $('#advsearchlist').show();
          }
          else {
              $('#advsearchlist').hide();
          }
      });


        var oTable = $('#MyTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "pageLength": 50,
            responsive: true,
            "createdRow": function (row, data, dataIndex) {
                if (data.color == 3 && data.appointemployee != null) {
                    $(row).addClass('redclass');
                }
                else {
                    $(row).addClass('blackclass');
                }


            },
            initComplete: function (settings, json) {

                $('body', parent.document).contents().find("#leadiframe").attr("height", $('#MyTable').height()+300);
            },
            "ajax": {
                "url": '/Leads/GetAllMyLeads',
                "data": function (data) {
                    data.LeadCode = $('#LeadCode').val();
                    data.LeadName = $('#ddlLeadName').val();
                    data.LeadSource = $('#ddlLeadSource').val();
                    data.CreatedBy = $('#ddlCreatedBy').val();
                    data.Location = $('#TxtLocation').val();
                    data.LeadStatus = $('#ddlLeadStatus').val();
                    data.LeadLevel = $('#LeadLevel').val();
                    data.Mobile = $('#ddlmobile').val();
                    data.fromdate = $('#From').val();
                    data.todate = $('#To').val();
                    data.LastUpdDays = $('#LastUpdated').val();
                    data.flag = chkflag;
                    data.nextdate = $("#NextDate").val();
                },
                "type": "POST",
                "datatype": "json"
            },
            "order": [[10, "desc"]],

            "columns": [
                {
                    "data": "id", "name": "id",
                    "render": function (data, type, row, meta) {
                        return meta.row + meta.settings._iDisplayStart + 1;
                    }
                },
                { "data": "LeadCode", "name": "LeadCode" },
                // { "data": "LeadName", "name": "LeadName" },
                {
                    "name": "LeadName", "data": function (data) {
                         @{
                             var datas = "";
                             if (User.IsInRole("Dev") || User.IsInRole("View Leads"))
                             {
                                 datas = "'<a href=\"/Leads/Details/'+ data.id +'\">'+ data.LeadName +'</a>' ";
                             }
                             else
                             {
                                 datas = "data.LeadName";
                             }
                         }
                        return @Html.Raw(datas);
                    }
                },
                {
                    "name": "TaxRegNo", "data": function (data) {
                        var str = "";
                        if (data.appointemployee != null && data.StartDate != null) {

                            str = data.appointemployee.empname + " on " + convertToDate(data.StartDate) + "  " + data.StartTime;
                        }
                        return str;
                    }
                },
           {
                      "name": "LeadName", "data": function (data) {
    if(data.custdetails!=null)
    {
                          @{
                              var datass = "";

                                  datas = "'<a href=\"/Customer/Details/'+ data.custdetails.CustomerID +'\">'+ data.custdetails.CustomerName +'</a>' ";
                              }


                          return @Html.Raw(datas);
                      }

else
    {
    return "no customer";
    }
    }

                  },

                {
                    "name": "Mobile", "data": function (data) {
                        var datas = "";
                        $.each(data.mobmodel, function (i, item) {
                            if (item.Num != null) {
                                if (datas != "") {
                                    datas += "<br> ";
                                }
                                datas += item.Name + '<br>';
                                datas += '<a href="tel:' + item.Num + '">' + item.Num + '</a>' + '<br>';
                                datas += item.emails + '<br>';
                            }
                        });
                        return datas;
                    }
                },
                { "data": "Email", "name": "Email" },
                { "data": "StatusType", "name": "StatusType" },
                {
                    "name": "assin", "data": function (data) {
                        var datas = "";
                        $.each(data.assin, function (i, item) {
                            if (datas != "") {
                                datas += ", ";
                            }
                            datas += item.FirstName;
                        })
                        return datas;
                    }
                },
                {
                    "name": "nextdate", "data": "nextdate", "render": function (data) {
                        if (data != null)
                            return convertDateTime(data);
                        else
                            return data;
                    }
                }, {
                    "name": "ldate", "data": function (data) {
                        var result = LastUpdatedIn(data.ldate);
                        return result;
                    }
                },
                {
                    "name": "id", "data": function (data) {
                        var rest = "";
                        var rest2 = "";

                         @{
                             if (User.IsInRole("Dev") || User.IsInRole("Edit Leads"))
                             {

                                 actData += "<a class=\"btn btn-icons btn-rounded btn-edit\" href=\"/Leads/Edit/'+ data.id +'\" title=\"Edit Leads\"><i class=\"fa fa-pencil\" ></i></a> ";

                             }
                             actData += "<a class=\"btn btn-icons btn-rounded btn-edit modal-create\" href=\"/Leads/AddCustomerRemark/'+ data.id +'\" title=\"Add Appointment\"><i class=\" fa fa-truck\" ></i></a> ";

                             actData += "<a class=\"btn btn-icons btn-rounded btn-edit modal-create\" href=\"/Leads/AddRemark/'+ data.id +'\" title=\"Add Remarks\"><i class=\" fa fa-plus\" ></i></a> ";
                             actData += "<a class=\"btn btn-icons btn-rounded btn-remark Updation\" onclick=\"details(' + data.id + ')\" title=\"View Remarks\"><i class=\" fa fa-eye\" ></i></a> ";
                             actData += "<a class=\"btn btn-icons btn-rounded btn-update modal-create\" href=\"/Leads/LeadModal/'+ data.id +'\" title=\"Update Status\"><i class=\"fa fa-refresh\" ></i></a> ";
                             if (User.IsInRole("Dev") || User.IsInRole("Create Customer"))
                             {
                                 actData += "<a class=\"btn btn-icons btn-rounded btn-convert\" href=\"/Customer/Create/'+ data.id+'/Lead\" title=\"Convert To Customer\"><i class=\"fa fa-exchange\" ></i></a> ";
                                 actData += "<a class=\"btn btn-icons btn-rounded btn-convert modal-create\" href=\"/Customer/assign/'+ data.id+'/Lead\" title=\"Assign To Customer\"><i class=\"fa fa-address-book \" ></i></a> ";

                             }
                             actData += "<a class=\"modal-create\" href=\"/Leads/AddamcImage/'+ data.id +'\" title=\"Add lead Document\"><i class=\"fa-lg fa fa-upload\" ></i></a> ";

                             }
                        if (data.ownlead == true) {

                             @{
                                 var restt = "";
                                 restt= "<a class=\" modal-create\" href=\"/Leads/closelead/'+ data.id +'\" title=\"Close Lead\">Close Lead</a> ";
                                }
                            rest += '@Html.Raw(restt)';
                        }
                        rest2 = '<a class=\"btn btn-icons btn-rounded btn-edit modal-create\" href=\"/Leads/DownloadDoc/' + data.id + '\" title=\"Download Entry\"><i class=\"fa-lg fa fa-download\" ></i></a> ';

                        rest += '@Html.Raw(actData)' + rest2;
                        return rest;
                     }
                 },
