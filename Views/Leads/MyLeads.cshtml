                        <td data-priority="8">Contact</td>
                        <td data-priority="9">Email</td>
                        <td data-priority="10">Curr.Status</td>
                        <td data-priority="6">Assing</td>
                        <td data-priority="10">Next Date</td>
                        <td data-priority="11">LastUpdated</td>
                        <td data-priority="11"> Action</td>
                        <td data-priority="1"><input type="checkbox" id="select_all" /></td>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
        @*if (User.IsInRole("Dev") || User.IsInRole("Delete Leads"))
            {
                <div class="box-footer text-right col-md-12" id="sub">
                    <button type="submit" id="save" data-confirm="Are u sure want to delete?" class="btn btn-danger">Delete</button>
                </div>
            }*@
    }

</div>

