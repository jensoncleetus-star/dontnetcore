@{
    ViewBag.Title = "Lead Approval";
    ViewBag.SubTitle = "";
    ViewBag.Active = "Master";
    string actData = "";
    bool userRole = false;
    string delchk = "";
    string deleteBTn = "";
    
}

<style>
    /* Popup box BEGIN */
    .hover_bkgr_fricc {
        background: rgba(0,0,0,.4);
        cursor: pointer;
        display: none;
        height: 100%;
        position: fixed;
        text-align: center;
        top: 0;
        width: 100%;
        z-index: 10000;
    }

        .hover_bkgr_fricc .helper {
            display: inline-block;
            height: 100%;
            vertical-align: middle;
        }

        .hover_bkgr_fricc > div {
            background-color: #fff;
            box-shadow: 10px 10px 60px #555;
            display: inline-block;
            height: auto;
            max-width: 325px;
            min-height: 130px;
            vertical-align: middle;
            width: 60%;
            position: relative;
            border-radius: 8px;
            padding: 15px 5%;
        }

    .popupCloseButton {
        background-color: #fff;
        border: 3px solid #999;
        border-radius: 50px;
        cursor: pointer;
        display: inline-block;
        font-family: arial;
        font-weight: bold;
        position: absolute;
        top: -20px;
        right: -20px;
        font-size: 25px;
        line-height: 30px;
        width: 30px;
        height: 30px;
        text-align: center;
    }

        .popupCloseButton:hover {
            background-color: #ccc;
        }

    .trigger_popup_fricc {
        cursor: pointer;
        font-size: 20px;
        margin: 20px;
        display: inline-block;
        font-weight: bold;
    }

    .del-btn {
        background-color: #f00;
        color: #fff;
        padding: 0.5rem 1rem;
        border-radius: 17px;
        text-decoration: none;
        float: left;
    }

    .can-btn {
        background-color: #999;
        color: #fff;
        padding: 0.5rem 1rem;
        border-radius: 17px;
        text-decoration: none;
        float:left;
    }
    /* Popup box BEGIN */
</style>

<div class="box box-info">

    @using (Html.BeginForm("DeleteAll", "ItemSize", FormMethod.Post, new { id = "payform", role = "form" }))
    {
        <div class="box-body">
            <table class="table table-bordered table-hover" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="2">S/N</td>
                        <td data-priority="1">Lead Name</td>
                        <td data-priority="2">Customer</td>
                        <td data-priority="2">Created By</td>
                        <td data-priority="2">Created Date</td>
                        <td data-priority="2">Created Date</td>
                        <td data-priority="1">Approve/Reject</td>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

    }
</div>
@Html.Partial("../Common/_ModalCreate")
@Html.Partial("../Common/_ModalEdit")
@Html.Partial("../Common/_ModalDelete")
@section scripts{
    @Scripts.Render("~/js/jqueryval")
<script type="text/javascript">
