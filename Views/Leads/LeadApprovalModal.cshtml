                                actData += "<a class=\"btn btn-icons btn-rounded btn-rounded modal-create\" href=\"/Leads/ApprovalorrejectCRM/'+ data.ID +'\" title=\"Approval Leads\" ><i class=\"fa fa-check\" ></i></a> ";
                                actData += "<a class=\"btn btn-icons btn-rounded btn-rounded  modal-delete\" href=\"/Leads/Approvalreject/'+ data.ID +'\" title=\"Reject Leads\"><i class=\"fa fa-times\" ></i></a> ";

