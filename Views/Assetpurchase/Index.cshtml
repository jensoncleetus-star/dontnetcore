@model QuickSoft.Models.AssetTransferMasters
@{
    ViewBag.Title = "Asset Purchase";
    ViewBag.SubTitle = "Asset Purchase";
    ViewBag.Active = "Utility";
    string actData = "";
    bool userRole = false;
    string delchk = "";
    string deleteBTn = "";


    userRole = true;
    deleteBTn = "{text: 'Delete', className: 'btn-danger', action: function(e, dt, node, config) {" +
        "if ($('.checkbox:checked').length > 0) {if (confirm('Are you sure you want to delete this?')) {$('#Assetpurchasetable').submit(); e.preventDefault();} " +
         "} else {alert('Please Select Rows..!!');e.preventDefault();}}},";

}
<style type="text/css">

    .dropdown-check-list {
        display: inline-block;
    }

        .dropdown-check-list .anchor {
            position: relative;
            cursor: pointer;
            display: inline-block;
            padding: 5px 50px 5px 10px;
            border: 1px solid #ccc;
            width: 150px;
            background: #fff;
            text-align: center;
        }

            .dropdown-check-list .anchor:after {
                position: absolute;
                content: "";
                border-left: 2px solid black;
                border-top: 2px solid black;
                padding: 5px;
                right: 10px;
                top: 20%;
                -moz-transform: rotate(-135deg);
                -ms-transform: rotate(-135deg);
                -o-transform: rotate(-135deg);
                -webkit-transform: rotate(-135deg);
                transform: rotate(-135deg);
            }

            .dropdown-check-list .anchor:active:after {
                right: 8px;
                top: 21%;
            }

        .dropdown-check-list ul.items {
            padding: 0px;
            display: none;
            margin: 0;
            border: 1px solid #ccc;
            border-top: none;
            position: absolute;
            z-index: 9999;
        }

            .dropdown-check-list ul.items li {
                list-style: none;
                background: #fff;
                padding: 5px;
            }

    .add-btn-item {
        border-radius: 23px;
        padding: 6px 20px;
    }

    .dropdown-check-list.visible .anchor {
        color: #0094ff;
    }

    .dropdown-check-list.visible .items {
        display: block;
    }
</style>

<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">Asset Purchase</h3>
        @if (User.IsInRole("Dev") || User.IsInRole("Create FileDocument"))
        {
            <p class="pull-right">
                <a href="/AssetPurchase/Create" class="btn btn-info modal-create"><i class="glyphicon glyphicon-plus"></i> Create</a>
            </p>
        }

        <div class="row">
            <div class="col-md-2">
                <div id="list1" class="dropdown-check-list" tabindex="100">
                    <span class="anchor" style="z-index:0;">Select Fields</span>
                    <ul class="items">

                        <li><input type="checkbox" id="Datecheckfrom" />From Date</li>
                        <li><input type="checkbox" id="Datecheckto" />To Date</li>
                    </ul>
                </div>
            </div>
            <div class="col-md-12">
                <div class="box-body search-box" id="advsearchlist">
                    <div class="search-body col-md-12" style="background:none;">
                        <form id="search-form">
                            <div class="row">

                                <div class="form-group col-md-3" id="searchfromdate">
                                    @Html.Label(" From Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("FromDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group col-md-3" id="searchtodate">
                                    @Html.Label(" To Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("ToDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>

                                @*<div class="form-group col-md-2" id="searchcreatedby">
            @Html.Label("Created By", null, new { @class = "control-label" })
            @Html.DropDownList("ddlCreatedBy", (SelectList)ViewBag.CreatedBy, "All", new { @class = "form-control input-sm select2" })
        </div>*@

                                <div class="form-group col-md-2" id="search">
                                    <input type="submit" class="btn btn-submit" value="Submit" />
                                </div>
                                <div class="form-group col-md-2" id="close">
                                    <input type="button" class="btn btn-close" value="Close" />
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    @using (Html.BeginForm("DeleteAll", "Assetpurchase", FormMethod.Post, new { id = "Assetpurchasetable", role = "form" }))
    {
        <div class="box-body">
            <table class="table table-bordered table-hover" id="DocumentList">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="1">S/N</td>
                        <td data-priority="1">Invoice No.</td>
                        <td data-priority="1">Purchase Invoice No.</td>
                        <td data-priority="1">Vendor Name</td>
                        <td data-priority="1">TotalAssetValue</td>
                        <td data-priority="1">Vat</td>
                        <td data-priority="1">Date</td>
                        <td data-priority="1">Actions</td>
                        <td data-priority="2"><input type="checkbox" id="select_all" /></td>

                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    }
    @*@if (User.IsInRole("Dev") || User.IsInRole("Delete Supplier"))
        {
        <div class="box-footer text-right col-md-12" id="sub">
            <button type="submit" id="save" data-confirm="Are u sure want to delete?" class="btn btn-danger">Delete</button>
        </div>
        }*@
</div>

@*@{var Model = "modal-lg";}*@
@Html.Partial("../Common/_ModalCreate")
@Html.Partial("../Common/_ModalEdit")
@Html.Partial("../Common/_ModalDelete")
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/bootstrap-fileinput")
    @Styles.Render("~/css/bootstrap-fileinput-rtl")
}
@section Scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/bootstrap-fileinput")
    @Scripts.Render("~/js/bootstrap-piexif")
    @Scripts.Render("~/js/bootstrap-purify")
    @Scripts.Render("~/js/bootstrap-sortable")
    <script type="text/javascript">

        $(document).ready(function () {
            $('#advsearchlist').hide();
        });

        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        })
        var oTable = $('#DocumentList').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "pageLength": 50,
            responsive: true,
            "ajax": {
                "url": '/Assetpurchase/GetAssets',
                "data": function (data) {
                    data.fromdate = $('#FromDate').val();
                    data.todate = $('#ToDate').val();

                },
                "type": "POST",
                "datatype": "json"
            },
            "order": [[0, "desc"]],
            //"columnDefs": [{ orderable: false, targets: -1 }],
            "columnDefs": [{
                "targets": [7,8],
                "orderable": false
            }],
            "columns": [
                 {
                    "data": "AssetEntryId", "name": "AssetEntryId",
                     "render": function (data, type, row, meta) {
                         return meta.row + meta.settings._iDisplayStart + 1;
                     }
                },
                { "data": "InvoiceNo", "name": "InvoiceNo" },
                { "data": "PurchaseEntry", "name": "PurchaseEntry" },
                { "data": "SupplierName", "name": "SupplierName" },
                { "data": "TotalAssetValue", "name": "TotalAssetValue" },

                { "data": "Vat", "name": "Vat" },

                    {
                        "data": "AssetEntryDate", "name": "AssetEntryDate",
                        "render": function (data) {
                            if (data == null) {
                                return "Date Not Available";
                            }
                            else {
                                return convertToDate(data);
                            }
                        }
                    },



                    {
                        "name": "Id", "data": function (data) {
                            var rest = "";
                            @{
                                if (User.IsInRole("Dev") || User.IsInRole("Edit FileDocument"))
                                {
                                    actData += "<a class=\"modal-edit\" href=\"/Assetpurchase/Edit/'+ data.AssetEntryId +'\" title=\"Edit Document Details\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                                }
                                if (User.IsInRole("Dev") || User.IsInRole("Delete FileDocument"))
                                {
                                    actData += "<a class=\"modal-delete\" href=\"/Assetpurchase/Delete/'+ data.AssetEntryId +'\" title=\"Delete Document\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";
                                }

                            }
                            return rest = '@Html.Raw(actData)';
                        }
                    },
                      {
                          "name": "AssetEntryId", "data": function (data) {
                              var rest = "";
                              @{
                                  delchk = "<input class=\"checkbox\" type=\"checkbox\" name=\"bill[]\" value='+ data.AssetEntryId +'></input>";

                              }
                              return rest = '@Html.Raw(delchk)';
                          }
                      },
            ], dom: 'Bfrtip',
            buttons: ['colvis', {
                extend: 'print',//
                title: "",
                footer: true,
                exportOptions: {
                    columns: ':visible'
                },
                message: '<table class="tblcompact table table-bordered"><thead>' +
                    ' <tr><th class="text-center"><h3 style="margin-top: 0px;">' + '<h4>Suppliers </h4></th></tr>' +
                    ' <tr><th><span class="text-left"></span><span class="text-right pull-right"> </span></th></tr></thead><tbody><tr><td>',
                customize: function (win) {
                    // $(win.document.body)
                    //.css('font-size', '10pt')
                    //.css('padding', '1px');
                    $(win.document.body).find('table, th,tr, td ')
                       // .css('border', 'inherit')
                        .css('font-size', '10pt')
                        .css('padding', '5px')
                        .addClass('compact');
                    $(win.document.body).append('</td></tr></tbody>')

                }
            }, 'copy', 'csv', 'excel',

            {
                extend: 'pdf',//
                title: "File Documents",
                footer: true,
                orientation: 'landscape',

                pageSize: 'A4',
                exportOptions: {
                    columns: ':visible'
                },
                customize: function (doc) {
                    doc.pageMargins = [10, 10, 10, 10];
                    doc.defaultStyle.fontSize = 10;
                    doc.styles.tableHeader.fontSize = 10;
                    doc.styles.title.fontSize = 12;
                    // Remove spaces around page title
                    doc.content[0].text = doc.content[0].text.trim();

                    doc.styles['td:nth-child(2)'] = {
                        width: '100%',
                        'max-width': '100%'
                    }

                    var objLayout = {};
                    // Horizontal line thickness
                    objLayout['hLineWidth'] = function (i) { return .5; };
                    // Vertikal line thickness
                    objLayout['vLineWidth'] = function (i) { return .5; };
                    //// Horizontal line color
                    //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                    //// Vertical line color
                    //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                    // Left padding of the cell
                    objLayout['paddingLeft'] = function (i) { return 4; };
                    // Right padding of the cell
                    objLayout['paddingRight'] = function (i) { return 4; };
                    // Inject the object in the document
                    doc.content[1].layout = objLayout;
                }
            },

            @Html.Raw(deleteBTn)
            ],
        })

         //Button Close
        $('#srch, .search-box .btn-close').on('click', function (e) {
            $('#advsearchlist').toggle();

            /*******  To uncheck all the checkboxes in the Select List  ************/
            var checkboxes = document.querySelectorAll("input[type='checkbox']");
            checkboxes.forEach(function (Checkbox) {
                Checkbox.checked = false;
            });

            if ($('#srch').hasClass('btn-primary')) {
                $('#srch').addClass('btn-danger');
                $('#srch').removeClass('btn-primary');
            }
            else {
                if ($('#srch').hasClass('btn-danger')) {
                    $('#srch').addClass('btn-primary');
                    $('#srch').removeClass('btn-danger');
                }
                /*******  To clear all the data entered  *********/
                //$('#ddlDoc').val(0);
                $('#Date').val(null);

                oTable.draw();
            }
        });

        $('#Date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });

        $('#CreDate').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });

        var date = new Date();
        var today = new Date(date.getFullYear(), date.getMonth(), date.getDate());
        var priordate = new Date(new Date().setDate(today.getDate() - 30));
        //$('#ToDate').datepicker('setDate', today);
        //$('#FromDate').datepicker('setDate', priordate);

        /* function for view detail popup */
        $('#UserTable').on('click', 'a.modal-image', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        })

        /* Delete Function for File Document */
        $('div').on('click', '.modal-delete', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-delete');
        });

        $('#modal-delete').on('submit', '#deleteform', function (e) {
            e.preventDefault();
            var url = $('#deleteform')[0].action;
            var data = $('#deleteform').serialize();
            createajax(url, data, '#modal-delete');
        });

        $('#search-form').on('submit', function (e) {
            e.preventDefault();
            oTable.draw();
        });
        isTicked();

        var checkList = document.getElementById('list1');
       /******* Function to list and hide dropdown checklist while clicking on 'Select Fields' *******/
       checkList.getElementsByClassName('anchor')[0].onclick = function (evt) {
           if (checkList.classList.contains('visible'))
               checkList.classList.remove('visible');
           else
               checkList.classList.add('visible');
       }

       /******* Function to show and hide fields while clicking on checkboxes in 'Select Fields' *******/
       $("ul li input:checkbox").click(function () {

           var _show = 0;

           // From Date
           if ($("#Datecheckfrom").prop("checked") == true) {
               $("#searchfromdate").show();
               _show = 1;
           }
           else {
               $("#FromDate").val(null);
               $("#searchfromdate").hide();
               oTable.draw();
           }

           // To Date
           if ($("#Datecheckto").prop("checked") == true) {
               $("#searchtodate").show();
               _show = 1;
           }
           else {
               $("#ToDate").val(null);
               $("#searchtodate").hide();
               oTable.draw();
           }

           //Created By
           if ($("#licreatedby").prop("checked") == true) {
               $("#searchcreatedby").show();
               _show = 1;
           }
           else {
               $('#ddlCreatedBy').val(null).trigger("change");
               $("#searchcreatedby").hide();
               oTable.draw();
           }

           //Status
           if ($("#listatus").prop("checked") == true) {
               $("#searchstatus").show();
               _show = 1;
           }
           else {
               $('#Status').val(null).trigger("change");
               $("#searchstatus").hide();
               oTable.draw();
           }

           if (_show == 1) {
               $('#advsearchlist').show();
           }
           else {
               $('#advsearchlist').hide();
           }
       });

       /******* Function to hide dropdown checklist while clicking outside it ********/
       $(document).on("click", function (event) {

           var element1 = $("#list1");

           if (element1 !== event.target && !element1.has(event.target).length) {
               checkList.classList.remove('visible');
           }
       });
        $('body').on('change', '#select_all', function () {
            $(".checkbox").prop('checked', $(this).prop("checked")); //change all ".checkbox" checked status
        });

        //".checkbox" change
        $('body').on('change', '.checkbox', function () {
            //uncheck "select all", if one of the listed checkbox item is unchecked
            if (false == $(this).prop("checked")) { //if this item is unchecked
                $("#select_all").prop('checked', false); //change "select all" checked status to false
            }
            isTicked();
        });
        isTicked();

    </script>
}

