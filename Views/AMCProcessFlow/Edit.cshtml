@model QuickSoft.ViewModel.AMCProcessFlowViewModel
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Edit AMC ProcessFlow</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("Edit", "AMCProcessFlow", FormMethod.Post, new { id = "editform" }))
    {
        <script type="text/javascript">
            $('form#createform').removeData("validator");
            $('form#createform').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#createform'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        <div class="row">
            @Html.HiddenFor(model => model.AmcProcessFlowId)
            <div class="col-md-12">
                <div class="form-group  col-md-6">
                    @Html.LabelFor(model => model.AmcStatus, htmlAttributes: new { @class = "control-label" })
                    @Html.DropDownListFor(m => m.AmcStatus, (SelectList)ViewBag.AmcStat, new { id = "ddlAmcStatus", @class = "form-control textwidth" })
                </div>
                <div class="form-group  col-md-6">
                    @Html.LabelFor(model => model.AssignType, htmlAttributes: new { @class = "control-label" })
                    @Html.DropDownListFor(m => m.AssignTypeAll, (MultiSelectList)ViewBag.AssignTypes, new { @class = "form-control select2 asstype textwidth", @name = "AssignTypeAll[]", @multiple = "multiple" })
                </div>
                <div class="form-group  col-md-12">
                    @Html.LabelFor(model => model.AssignedUsers, htmlAttributes: new { @class = "control-label" })
                    @Html.ListBoxFor(m => m.AssignedUsers, (MultiSelectList)ViewBag.team, new { @class = "form-control select2 assuser", @name = "AssignedUsers[]", @multiple = "multiple", @style = "width:100%" })
                </div>
                <div class="form-group  col-md-6">
                    @Html.CheckBoxFor(m => m.RemoveUpdateUser, new { @class = "checkbox" })
                    @Html.LabelFor(m => m.RemoveUpdateUser, new { @class = "control-label" })
                </div>
                <div class="form-group  col-md-6">
                    @Html.CheckBoxFor(m => m.RemoveUpdateUserTeams, new { @class = "checkbox" })
                    @Html.LabelFor(m => m.RemoveUpdateUserTeams, new { @class = "control-label" })
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <button type="submit" class="btn btn-info col-sm-offset-4">Update</button>
                    <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
        <script>
            
            $("#ddlAmcStatus").select2({
                placeholder: 'Search Amc Status',
                minimumInputLength: 0,
                ajax: {
                    url: "/AMC/SearchContractStatus",
                    dataType: 'json',
                    type: "POST",
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term,
                            page: params.page,
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;

                        return {
                            results: data
                        };
                    },
                    cache: true
                },
            });
            $(".asstype").select2({
                placeholder: 'Search Assign Type',
                minimumInputLength: 0,
                ajax: {
                    url: "/Team/SearchTeam",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term || "",
                            page: params.page || 0,
                            x: "in"
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;
                        return {
                            results: data
                        };
                    },
                    cache: true
                },
            });
            $(".assuser").select2({
                placeholder: 'Search Employees by Name',
                minimumInputLength: 0,
                ajax: {
                    url: "/Employee/SearchTeamMember",
                    dataType: 'json',
                    type: "POST",
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term,
                            page: params.page,
                            lead: $('#TeamLead').val()
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;

                        return {
                            results: data
                        };
                    },
                    cache: true
                },
            });

            $('body').on('change', '#AssignTypeAll', function (e) {

                var assign = $("#AssignTypeAll").val();
                AssignTypeChange(assign);
            });

        </script>
    }
</div>
