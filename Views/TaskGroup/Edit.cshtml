@model QuickSoft.ViewModel.TaskGroupViewModel
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Edit Task Group</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("Edit", "TaskGroup", FormMethod.Post, new { id = "editform", @class = "form-horizontal" }))
    {
        <script type="text/javascript">
            $('form#editform').removeData("validator");
            $('form#editform').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#editform'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })

        <div class="box-body">
            <div class="form-group">
                @Html.Label("Task Type", null, new { @class = "control-label col-sm-4" })
                <div class="col-sm-8">
                    @Html.EditorFor(model => model.TaskTypeName, new { htmlAttributes = new { @class = "form-control", @required = "required", @readonly = "readonly",id= "ddlTaskType" } })
                </div>
            </div>           
            <div class="form-group">
                @Html.Label("Task Status", null, new { @class = "control-label col-sm-4" })
                <div class="col-sm-8">
                    @Html.ListBoxFor(m => m.TaskStatus, (MultiSelectList)ViewBag.Employees, new { @class = "Employees form-control input-sm textwidth",id= "TaskStatus" })
                </div>
                @Html.HiddenFor(m=>m.TaskType)
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <button type="submit" class="btn btn-info col-sm-offset-4">Update</button>
                    <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    }
</div>

<script>
    $(document).ready(function () {
        TaskStatusName();
        $("#ddlTaskType").select2({});
    });
</script>

