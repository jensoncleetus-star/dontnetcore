@model QuickSoft.ViewModel.PurchaseOrderViewModel
@{
    ViewBag.Title = "Edit";
    ViewBag.SubTitle = "Edit Purchase Order";
    ViewBag.Active = "Transactions";
    var TimeOut = @ViewBag.TMOut;
    string IRateCheck = "inactive";
    string check = "";
    string strImage = "";
    string partialconfig = "";
}
@if (User.IsInRole("Dev") || User.IsInRole("ReadOnly Item Rate"))
{
    IRateCheck = "active";
}
@using (Html.BeginForm("UpdatePurchaseOrder", "PurchaseOrder", FormMethod.Post, new { id = "porderform", role = "form" }))
{
    <div class="box box-info">
        <div class="box-header with-border">
            <h3 class="box-title">Edit Purchase Order <label id="AlertEditable" class="text-red"></label></h3>
            <div class="pull-right">
                @if (@ViewBag.preEntry != 0)
                {
                    if (User.IsInRole("Dev") || User.IsInRole("Edit PurchaseOrder"))
                    {
                        <a class="btn bg-black no-border" href="/PurchaseOrder/Edit/@ViewBag.preEntry">
                            <i class="fa fa-step-backward"></i>
                        </a>
                    }
                }
                @if (@ViewBag.nxtEntry != 0)
                {
                    if (User.IsInRole("Dev") || User.IsInRole("Edit PurchaseOrder"))
                    {
                        <a class="btn bg-black no-border" href="/PurchaseOrder/Edit/@ViewBag.nxtEntry">
                            <i class="fa fa-step-forward"></i>
                        </a>
                    }
                }
                else
                {
                    if (User.IsInRole("Dev") || User.IsInRole("PurchaseOrder Entry"))
                    {
                        <a class="btn bg-black no-border" href="/PurchaseOrder/Create">
                            <i class="fa fa-step-forward"></i>
                        </a>
                    }
                }
                @if (User.IsInRole("Dev") || User.IsInRole("PurchaseOrder List"))
                {
                    <a class="btn btn-success no-border" href="/PurchaseOrder">
                        <i class="fa fa-fw fa-history"></i> List
                    </a>
                }
            </div>
        </div>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
    <div class="box-body">
        <input type="hidden" id="makecheck" value="@ViewBag.Make" />
        <input type="hidden" id="ROnlyRate" value="@IRateCheck" />
        <input type="hidden" id="procheck" value="@ViewBag.ProjChk" />
        <input type="hidden" id="SelApprovedBy" />
        <input type="hidden" id="VoucherType" value="PurchaseOrder" />

        <div class="row">
            <div class="col-sm-2 form-group ">
                @Html.Label("Purchase Order No", null, new { @class = "control-label" }) *
                @if (User.IsInRole("Dev") || User.IsInRole("Invoice Edit Permission"))
                {
                    @Html.EditorFor(model => model.BillNo, new { htmlAttributes = new { @class = "form-control", @required = "required" } })
                }
                else
                {
                    @Html.EditorFor(model => model.BillNo, new { htmlAttributes = new { @class = "form-control", @required = "required", @readonly = "readonly" } })
                }
                @Html.HiddenFor(model => model.PONo)
            </div>
            <div class="col-sm-2 form-group">
                @Html.Label("Date", null, new { @class = "control-label" }) *
                <div class="input-group date">
                    <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                    @Html.TextBoxFor(m => m.PODate, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @required = "required" })
                </div>
            </div>
            <div class="col-sm-2 form-group">
                @Html.Label("Purchase Type", null, new { @class = "control-label" }) *
                @Html.DropDownListFor(m => m.PurchaseType, new SelectList(Model.PurchaseTypes, "Id", "Name"), new { id = "PurchaseType", @class = "form-control" })

            </div>
            <div class="col-sm-2 form-group">
                @Html.Label("Sales Executive", null, new { @class = "control-label" })
                @if (User.IsInRole("Dev") || User.IsInRole("Create Sales Executive"))
                {
                    <div class="input-group input-group-sm">
                        @Html.DropDownListFor(m => m.POCashier, (SelectList)ViewBag.Cashier, "", new { id = "ddlEmployee", @class = "form-control select2" })
                        <span class="input-group-btn">
                            <button type="button" href="/SalesExecutive/AddSalesExecutive" class="modal-edit btn btn-success btn-flat"><i class="fa fa-1x fa-plus-circle"></i></button>
                        </span>
                    </div>
                }
                else
                {
                    @Html.DropDownListFor(m => m.POCashier, (SelectList)ViewBag.Cashier, "", new { id = "ddlEmployee", @class = "form-control select2" })
                }
            </div>
            <div class="col-sm-2 form-group">
                @Html.Label("Payment Type", null, new { @class = "control-label" }) *
                @Html.EnumDropDownListFor(model => model.SupplierType, new { @class = "form-control" })
            </div>

            @if (@ViewBag.EnableCurrency == 0)
            {
                <div class="form-group col-md-2 col-xs-12 col-sm-4 hide1">
                    @Html.LabelFor(model => model.Currency, new { @class = "control-label temp2" })
                    @Html.DropDownListFor(m => m.Currency, (SelectList)ViewBag.CurrencyVal, new { id = "ddlCurrency", @class = "form-control select2" })
                </div>
                <div class="form-group col-md-2 col-xs-12 col-sm-4 hide1">
                    @Html.LabelFor(model => model.ConvertionRate, new { @class = "control-label temp2" })
                    @Html.EditorFor(model => model.ConvertionRate, new { htmlAttributes = new { @class = "form-control", @onchange = "FCCalculation();" } })
                </div>
            }

            <div class="col-sm-2 form-group">
                @Html.Label("Supplier Name", null, new { @class = "control-label" }) *
                @if (User.IsInRole("Dev") || User.IsInRole("Create Supplier"))
                {
                    <div class="input-group input-group-sm">
                        @Html.DropDownListFor(m => m.Supplier, (SelectList)ViewBag.Supp, new { id = "ddlSupplier", @class = "form-control select2", @required = "required", @onchange = "GetSupplier()" })
                        <span class="input-group-btn">
                            <button type="button" href="/Supplier/AddSupplier" class="modal-create btn btn-success btn-flat"><i class="fa fa-1x fa-plus-circle"></i></button>
                        </span>
                    </div>
                }
                else
                {
                    @Html.DropDownListFor(m => m.Supplier, (SelectList)ViewBag.Supp, new { id = "ddlSupplier", @class = "form-control select2", @required = "required", @onchange = "GetSupplier()" })
                }
            </div>
            @if (@ViewBag.BranchCheck == 0)
            {
                <div class="form-group col-sm-2">
                    @Html.Label("Branch", null, new { @class = "control-label" })
                    @Html.DropDownListFor(m => m.Branch, (SelectList)ViewBag.SetBranch, new { id = "ddlBranch", @class = "form-control select2" })
                </div>
            }
            @if (@ViewBag.MLAPOrder == 0)
            {
                <div class="form-group col-sm-2">
                    @Html.Label("Approved By", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlApprovedBy", (MultiSelectList)ViewBag.ApproveBy, new { @class = "form-control select2", @name = "ddlApprovedBy[]", @multiple = "multiple" })

                </div>
            }
            @if (Model.CMReqNo != null && Model.CMReqNo != "")
            {
                <div class="form-group col-sm-2">
                    @Html.Label("MR No", null, new { @class = "control-label" })
                    @Html.EditorFor(model => model.CMReqNo, new { htmlAttributes = new { @class = "form-control", @required = "required", @readonly = "readonly" } })
                </div>
            }
            @if (Model.convertBill != null && Model.convertBill != "")
            {
                <div class="form-group col-sm-2">
                    @Html.LabelFor(m => m.convertFrom, Model.convertFrom, new { @class = "control-label" })
                    @Html.EditorFor(model => model.convertBill, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly" } })
                </div>
            }

            <div class="form-group col-sm-2">
                @Html.Label("Purchase Order Status", null, new { @class = "control-label" })
                @Html.DropDownList("PurchaseStatus", (IEnumerable<SelectListItem>)ViewBag.PurchaseStatus, new { @class = "form-control" })
            </div>
            <div class="clearfix"></div>
        </div>
        <div class="row">
            @if (Model.FieldMap.Count > 0)
            {
                for (int i = 0; i < Model.FieldMap.Count; i++)
                {

                    var fmap = "";
                    if (Model.FieldMap[i].Field == "Ref1")
                    {
                        fmap = Model.Ref1;
                    }
                    if (Model.FieldMap[i].Field == "Ref2")
                    {
                        fmap = Model.Ref2;
                    }
                    if (Model.FieldMap[i].Field == "Ref3")
                    {
                        fmap = Model.Ref3;
                    }
                    if (Model.FieldMap[i].Field == "Ref4")
                    {
                        fmap = Model.Ref4;
                    }
                    if (Model.FieldMap[i].Field == "Ref5")
                    {
                        fmap = Model.Ref5;
                    }

                    <div class="form-group col-md-2 col-xs-6 hide1">
                        <label class="control-label temp2" for="FieldName"> @Model.FieldMap[i].FieldName</label>

                        @if (Model.FieldMap[i].Type == "Dropdown")
                        {
                            if (Model.FieldMap[i].Field == "Ref1")
                            {
                                @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef1, new { @id = "Ref1", @class = "form-control input-sm select2 ref" })
                            }
                            if (Model.FieldMap[i].Field == "Ref2")
                            {
                                @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef2, new { @id = "Ref2", @class = "form-control input-sm select2 ref" })
                            }
                            if (Model.FieldMap[i].Field == "Ref3")
                            {
                                @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef3, new { @id = "Ref3", @class = "form-control input-sm select2 ref" })
                            }
                            if (Model.FieldMap[i].Field == "Ref4")
                            {
                                @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef4, new { @id = "Ref4", @class = "form-control input-sm select2 ref" })
                            }
                            if (Model.FieldMap[i].Field == "Ref5")
                            {
                                @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef5, new { @id = "Ref5", @class = "form-control input-sm select2 ref" })
                            }

                        }
                        else
                        {
                            <input class="form-control input-sm" id="@Model.FieldMap[i].Field" name="@Model.FieldMap[i].Field" type="text" value="@fmap">
                        }

                    </div>

                }
            }
        </div>

        <div>
            <div class="row">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="normalinvoice">
                        <thead>
                            <tr>
                                <th class="text-center">S/N</th>
                                <th class="text-center item-lists">Item <i class="text-danger">*</i></th>
                                <th class="text-center">Unit</th>
                                <th class="text-center">Qty <i class="text-danger">*</i></th>
                                <th class="text-center">Rate <i class="text-danger">*</i></th>
                                <th class="text-center">Sub Total</th>
                                <th class="text-center">Discount</th>
                                <th class="text-center">TAX</th>
                                <th class="text-center">Total</th>
                                @if (@ViewBag.ProjChk == 0)
                                {
                                    <th class="text-center">Project</th>
                                    <th class="text-center">Task</th>
                                }
                                @if (@ViewBag.Make == 0)
                                {
                                    <th class="text-center">Make</th>
                                }
                                <th class="text-center"></th>
                            </tr>
                        </thead>
                        <tbody id="addinvoiceItem"></tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3">
                                    Total
                                </td>
                                <td class="text-right">
                                    <label id="ItemQty"></label>
                                </td>
                                <td class="text-right"></td>
                                <td class="text-right">
                                    <label id="SubTotal"></label>
                                </td>
                                <td class="text-right">
                                    <label id="ItemDisc"></label>
                                </td>
                                <td class="text-right">
                                    <label id="total_tax_amount"></label>

                                </td>
                                <td class="text-right">
                                    <label id="total"></label>
                                </td>
                                @if (@ViewBag.ProjChk == 0)
                                {
                                    <td></td>
                                    <td></td>
                                }
                                @if (@ViewBag.Make == 0)
                                {
                                    <td></td>
                                }
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
            <div class="row">
                <div class="col-md-4">
                    @if (ViewBag.CheckMail == 0)
                    {
                        <div class="form-group">
                            @Html.Label("To", null, new { @class = "control-label" })
                            @Html.TextAreaFor(m => m.SupplierEmail, new { @class = "form-control input-sm", tabindex = 3, rows = 2 })
                            <span class="help-block" style="color:#f39c12;">Enter multiple email separated by space</span>
                        </div>
                        <div class="form-group">
                            @Html.Label("Cc", null, new { @class = "control-label" })
                            @Html.TextAreaFor(m => m.CreatedUserEmail, new { @class = "form-control input-sm", tabindex = 3, rows = 2 })
                            <span class="help-block" style="color:#f39c12;">Enter multiple email separated by space</span>
                        </div>
                    }
                </div>

                <div class="col-md-8">
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover" id="billsundry">
                            <thead>
                                <tr>
                                    <th class="text-center">S/N</th>
                                    <th class="text-center">Bill Sundry</th>
                                    <th class="text-center">Value</th>
                                    <th class="text-center">Type</th>
                                    <th class="text-center">Amount</th>
                                    <th class="text-center">Action</th>
                                </tr>
                            </thead>
                            <tbody id="addbillsundry"></tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-md-8 pull-right">
                <div class="form-group col-md-4 no-paddingleft">
                    @Html.Label("Purchase Order Validity:", null, new { @class = "control-label" })
                    <div class="input-group input-group-sm">
                        @Html.EditorFor(model => model.POValidity, new { htmlAttributes = new { @class = "form-control text-right", @placeholder = "0" } })
                        <span class="input-group-btn">
                            <button type="button" class="btn btn-flat">Days</button>
                        </span>
                    </div>
                </div>
                <div class="form-group col-md-4 no-paddingleft">
                    @*@Html.Label("Discount :", null, new { @class = "control-label" })
                    @Html.EditorFor(model => model.QuotDiscount, new { htmlAttributes = new { @id = "Discount", @onchange = "discount_change();", @class = "form-control text-right", @value = "0.00" } })*@
                </div>
                <div class="form-group col-md-4 no-padding">
                    @Html.Label("Grand Total :", null, new { @class = "control-label" })
                    @Html.EditorFor(model => model.POGrandTotal, new { htmlAttributes = new { @id = "GrandTotal", @class = "form-control text-right", @value = "0.00", @readonly = "readonly" } })
                    <input type="hidden" value="" class="ItemCount" name="ItemCount" id="ItemCount">
                </div>

                @*----------------------For File Attachment----------------------------*@
                <div class="form-group">
                    @Html.Label("Documents", null, new { @class = "control - label" })
                    <div class="file-loading">
                        <input id="input-24" name="input24[]" type="file" multiple>
                    </div>
                </div>
                @foreach (var arr in @ViewBag.Image)
                {
                    check = "\"/uploads/PurchaseOrderDocuments/" + arr.FileName + "\"";

                    strImage += check + ',';

                    partialconfig += "{ key:" + arr.DocumentID + " }" + ',';
                }
                @*---------------------------------------------------------------------*@

                <div class="form-group">
                    @Html.LabelFor(model => model.Remarks, new { @class = "control-label" })
                    @Html.TextAreaFor(model => model.Remarks, new { @class = "form-control", @placeholder = "Remarks", @rows = 2 })
                </div>
                <div class="form-group">
                    @Html.Label("Terms and Conditions", null, new { @class = "control-label" })
                    @Html.TextAreaFor(m => m.TermsCondition, new { @class = "form-control input-sm textarea", rows = 8 })
                </div>
                @if (@ViewBag.PrintLayout == 0)
                {
                    <div class="form-group col-sm-5">
                        @Html.Label("Print Layout", null, new { @class = "control-label" })
                        @Html.DropDownListFor(m => m.PrintLayout, (SelectList)ViewBag.printlay, new { id = "ddlPrintlayout", @class = "form-control select2" })
                    </div>
                }
            <div class="form-group no-padding text-right">
                <div class="form-group col-md-7 text-right temp4">
                    <div class="checkbox-inline">
                        <input class="checkbox" data-val="true" id="showzeal" name="showzeal" type="checkbox" value="false">
                        <label class="control-label" for="showzeal">Show Zeal In Print</label>
                    </div>
                </div>
                <div class="checkbox-inline">
                    <input class="checkbox" data-val="true" id="hideheader" name="hideheader" type="checkbox" value="true">
                    <label class="control-label" for="hideheader">Hide Header In Print</label>
                </div>
            </div>
                <div class="form-group pull-right">
                    <button type="submit" id="save" class="btn btn-success">
                        <span class="glyphicon glyphicon-floppy-disk"></span> Update
                    </button>
                    <button type="submit" id="print" class="btn btn-success">
                        <span class="glyphicon glyphicon-print"></span> Update And Print
                    </button>
                    @if (@ViewBag.CheckMail == 0)
                    {
                        <button type="submit" id="sendmail" class="btn btn-success">
                            <span class="glyphicon glyphicon-envelope"></span> Update And Mail
                        </button>
                    }
                    <button type="reset" class="btn btn-warning" onclick="@("window.location.href='/PurchaseOrder/Index'");">Cancel</button>
                    <input type="hidden" value="@ViewBag.StartDate" class="Start" name="Start" id="Start">
                    <input type="hidden" value="@ViewBag.EndDate" class="End" name="End" id="End">

                </div>
            </div>

        </div>
    </div>
    </div>

}
@{var Modelv = "modal-lg";}
@Html.Partial("../Common/_ModalCreate", @Modelv)
@Html.Partial("../Common/_ModalEdit", @Modelv)
@Html.Partial("../Common/_ModeItemCreate")

@Html.Action("invoice", "InvoiceLayout", new { type = "Purchase Order" })

@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/print")
    @Styles.Render("~/css/bootstrap-fileinput")
    @Styles.Render("~/css/bootstrap-fileinput-rtl")
    @Styles.Render("~/css/wysihtml5")
    @*@Styles.Render("~/css/wysihtml5")*@
}
@section scripts{
    @Scripts.Render("~/js/JsBarcode")
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/porder")
    @Scripts.Render("~/js/num2words")
    @Scripts.Render("~/js/bootstrap-fileinput")
    @Scripts.Render("~/js/bootstrap-sortable")
    @Scripts.Render("~/js/wysihtml5")
    <style>
        .itemnote {
            height: 200px !important;
        }
    </style>
    <script type="text/javascript">
        var getQueryString = function (field, url) {
            var href = url ? url : window.location.href;
            var id = href.substring(href.lastIndexOf('/') + 1);
            return id ? id : null;
        }


        var minDate = $("#Start").val();
        var maxDate = $("#End").val();
        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true,
            startDate: new Date(minDate),
            endDate: new Date(maxDate)
        });
        //$('.date').datepicker({
        //    format: 'dd-mm-yyyy',
        //    autoclose: true,
        //    allowInputToggle: true,
        //    startDate: '01-01-2011',
        //    endDate: '+30d'
        //});

        jQuery.validator.methods["date"] = function (value, element) { return true; }

        $(document).ready(function () {
            //CKEDITOR.replace('TermsCondition');
            //$(function () {
            //    $(".textarea").wysihtml5();
            //});
            searchItem();

            ItemCategory();
            ItemBrand();
            GetBranch();
            //ItemTax();
            //ItemUnit();
            //ItemSubUnit();
            CallSupplier();
            CallEmployee();
            CallApprovedBy();
            $("#SelApprovedBy").val($("#ddlApprovedBy").val());
            var poID = getQueryString('');
            $.ajax({
                url: '/PurchaseOrder/GetPOItems',
                dataType: 'json',
                data: { POrderID: poID },
                cache: true,
                success: function (data) {
                    $.each($.parseJSON(data), function (i, item) {
                        addrow('addinvoiceItem', 'purchase', item.ItemUnit, item.ItemTax, item.ItemTotalAmount, item.ItemQuantity, item.Item, item.ItemCode, item.ItemName, item.ItemUnitPrice, item.ItemSubTotal, item.ItemWithCode, item.ItemTaxAmount, item.ItemDiscount, item.ItemNote, item);
                    });

                    addrow('addinvoiceItem', 'purchase', '', '0.00', '0.00', '0');
                }
            });

            GetSupplier();

            $.ajax({
                url: '/PurchaseOrder/GetPOBillSundry',
                dataType: 'json',
                data: { POrderID: poID },
                cache: true,
                success: function (data) {
                    $.each(data, function (i, bs) {
                        addbillsundry('addbillsundry', 'purchase', bs.BsValue, bs.AmountType, bs.BsAmount, bs.BsType, bs.BSName, bs.BillSundry);
                    });
                    addbillsundry('addbillsundry', 'purchase', '0.00', '', '0.00', '');
                    grandtotalcalculation();
                }
            });

            chkEditEditable("@ViewBag.ChkApp");
        });



        function GetSupplier() {
            var SuppId = $('#ddlSupplier').val();
            if (SuppId != null) {
                $.ajax({
                    url: '/Supplier/GetSupplierEmailById',
                    type: "GET",
                    dataType: "JSON",
                    data: { SuppId: SuppId },
                    success: function (result) {
                        $("#SupplierEmail").val(result.EmailId);
                    }
                });
            }
        }


        /* function for Create popup */

        $('span').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        });
        $('#modal-create').on('submit', '#createform', function (e) {
            e.preventDefault();
            var url = $('#createform')[0].action;
            var data = $('#createform').serialize();
            createajax(url, data, '#modal-create');
        });

        $('span').on('click', '.modal-edit', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-edit');
        });
        $('#modal-edit').on('submit', '#editform', function (e) {
            e.preventDefault();
            var url = $('#editform')[0].action;
            var data = $('#editform').serialize();
            createajax(url, data, '#modal-edit');
        });

        $('body').on('change', '#ddlApprovedBy', function (e) {
            $("#SelApprovedBy").val($(this).val());
        });

        $('#porderform').on('submit', function (e) {
            e.preventDefault();
            //check if exists VAT in Bill-Sundry
            var vatexist = 0;
            $("#addbillsundry tr").each(function (e) {
                var type = parseFloat($(this).find('.bsname').val());
                if (type == "4") { vatexist++; } else { vatexist = vatexist; }
            });
            var stype = $("#PurchaseType").val();
            if (stype == 3 && vatexist == 0)//
            {
                alert("Please Select VAT in Bill-Sundry..!!");
            } else {
                if ($("#porderform").valid()) {
                    //var fnval = e.originalEvent.explicitOriginalTarget.id;
                    var fnval = $('input[type="submit"], button[type="submit"]', this).filter(':focus').attr('id');
                    var parameters = {};

                    var PONo = $('#PONo').val();
                    var BillNo = $('#BillNo').val();


                    var SupplierID = $('#ddlSupplier').val();
                    var POCashierID = $('#ddlEmployee').val();
                    var PODate = $('#PODate').val();

