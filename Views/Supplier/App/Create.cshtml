@model QuickSoft.ViewModel.SupplierViewModel
@{
    Layout = "~/Views/Shared/_AppLayout.cshtml";
    ViewBag.Title = "Create Supplier";
    ViewBag.SubTitle = "Supplier";
    ViewBag.Active = "Master";
}
<div class="box box-info">
    @using (Html.BeginForm("Create", "Supplier", FormMethod.Post, new { id = "createForm", role = "form" }))
    {
        <div class="box-header with-border">
            <h3 class="box-title">Supplier</h3>
            <div class="pull-right">
                @if (User.IsInRole("Dev") || User.IsInRole("Supplier"))
                {
                    <a class="btn btn-success no-border" href="/app/supplier/index.html">
                        <i class="fa fa-fw fa-history"></i> Supplier List
                    </a>
                }
            </div>
        </div>

            @Html.AntiForgeryToken()
            @Html.ValidationSummary("", new { @class = "alert alert-danger AlertDiv" })


            <div class="box-body">
                <div class="form-group col-md-4">
                    @Html.LabelFor(model => model.SupplierCode, htmlAttributes: new { @class = "control-label" })*
                    @Html.EditorFor(model => model.SupplierCode, new { htmlAttributes = new { @class = "form-control", @required = "required", tabindex = 1 } })
                </div>
                <div class="form-group  col-md-4">
                    @Html.LabelFor(model => model.SupplierName, htmlAttributes: new { @class = "control-label" })*
                    @Html.EditorFor(model => model.SupplierName, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Supplier Name", @required = "required", tabindex = 2 } })
                </div>
                <div class="form-group col-md-4">
                    @Html.LabelFor(model => model.TaxRegNo, htmlAttributes: new { @class = "control-label" })
                    @Html.EditorFor(model => model.TaxRegNo, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Tax RegNo", tabindex = 3 } })
                </div>
                <div class="form-group col-md-4">
                    @Html.LabelFor(model => model.CreditLimit, htmlAttributes: new { @class = "control-label" })
                    @Html.EditorFor(model => model.CreditLimit, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Credit Limit", tabindex = 4 } })
                </div>
                <div class="form-group col-md-4">
                    @Html.LabelFor(model => model.CreditPeriod, htmlAttributes: new { @class = "control-label" })
                    <div class="input-group input-group-sm">
                        @Html.EditorFor(model => model.CreditPeriod, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Credit Period", tabindex = 5 } })
                        <span class="input-group-btn">
                            <button type="button" class="btn btn-flat">Days</button>
                        </span>
                    </div>
                </div>
                <div class="form-group col-md-4">
                    @Html.LabelFor(model => model.TaxType, htmlAttributes: new { @class = "control-label" })
                    @Html.EnumDropDownListFor(model => model.TaxType, new { @class = "form-control", tabindex = 30 })
                </div>
                <div class="form-group col-md-4">
                    @Html.LabelFor(model => model.Remark, htmlAttributes: new { @class = "control-label" })
                    @Html.TextAreaFor(model => model.Remark, new { @class = "form-control", @placeholder = "Enter Remark", tabindex = 6 })
                </div>
            </div>
            <div class="box-header with-border">
                <h5 class="box-title">Contact Details</h5>
            </div>
            <div class="box-body">
                <div class="form-group col-md-4">
                    @Html.LabelFor(model => model.Address, htmlAttributes: new { @class = "control-label " })
                    @Html.TextAreaFor(model => model.Address, new { @class = "form-control", @placeholder = "Enter Address", tabindex = 7 })
                </div>
                <div class="form-group col-md-4">
                    @Html.LabelFor(model => model.City, htmlAttributes: new { @class = "control-label " })
                    @Html.EditorFor(model => model.City, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter City", tabindex = 8 } })
                </div>
                <div class="form-group col-md-4">
                    @Html.LabelFor(model => model.State, htmlAttributes: new { @class = "control-label " })
                    @Html.DropDownList("State", new SelectList(new List<SelectListItem>
                        {
                            new SelectListItem() {Text = "Abu Dhabi", Value="Abu Dhabi"},
                            new SelectListItem() {Text = "Ajman", Value="Ajman"},
                            new SelectListItem() {Text = "Dubai", Value="Dubai"},
                            new SelectListItem() {Text = "Fujairah", Value="Fujairah"},
                            new SelectListItem() {Text = "Ras al-Khaimah", Value="Ras al-Khaimah"},
                            new SelectListItem() {Text = "Sharjah", Value="Sharjah"},
                            new SelectListItem() {Text = "Umm al-Quwain", Value="Umm al-Quwain"}

                        }, "Value", "Text"), new { @class = "form-control input-sm", @name = "State", @required = "required", tabindex = 9 })
                    @*@Html.EditorFor(model => model.State, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter State", tabindex = 9 } })*@
                </div>
                <div class="form-group col-md-4">
                    @Html.LabelFor(model => model.Country, htmlAttributes: new { @class = "control-label " })
                    @Html.EditorFor(model => model.Country, new { htmlAttributes = new { @class = "form-control", @Value = "UAE", @readonly = "readonly", @placeholder = "Enter Country", tabindex = 10 } })
                </div>
                <div class="form-group col-md-4">
                    @Html.LabelFor(model => model.Zip, htmlAttributes: new { @class = "control-label " })
                    @Html.EditorFor(model => model.Zip, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Zip", tabindex = 11 } })
                </div>
                <div class="form-group col-md-4">
                    @Html.LabelFor(model => model.Phone, htmlAttributes: new { @class = "control-label " })
                    @Html.EditorFor(model => model.Phone, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Phone", tabindex = 12 } })
                </div>
                <div class="form-group col-md-4">
                    @Html.LabelFor(model => model.Mobile, htmlAttributes: new { @class = "control-label " })
                    @Html.EditorFor(model => model.Mobile, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Mobile", tabindex = 13 } })
                </div>
                <div class="form-group col-md-4">
                    @Html.LabelFor(model => model.Fax, htmlAttributes: new { @class = "control-label " })
                    @Html.EditorFor(model => model.Fax, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Fax", tabindex = 14 } })
                </div>
                <div class="form-group col-md-4">
                    @Html.LabelFor(model => model.EmailId, htmlAttributes: new { @class = "control-label " })
                    @Html.EditorFor(model => model.EmailId, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Email", tabindex = 15 } })
                </div>
                <div class="form-group col-md-4">
                    @Html.LabelFor(model => model.Reference, htmlAttributes: new { @class = "control-label " })
                    @Html.EditorFor(model => model.Reference, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Reference", tabindex = 16 } })
                </div>
                <div class="form-group col-md-4">
                    @Html.LabelFor(model => model.ContactPerson, htmlAttributes: new { @class = "control-label " })
                    @Html.EditorFor(model => model.ContactPerson, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Sales Person", tabindex = 17 } })
                </div>
                <div class="form-group col-md-4">
                    @Html.LabelFor(model => model.SalesPMob, htmlAttributes: new { @class = "control-label " })
                    @Html.EditorFor(model => model.SalesPMob, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Sales Person Mobile", tabindex = 18 } })
                </div>
            </div>
            <div class="box-header with-border">
                <h5 class="box-title">Bank Details</h5>
            </div>
            <div class="box-body">
                <div class="form-group col-md-4">
                    @Html.LabelFor(model => model.BankName, htmlAttributes: new { @class = "control-label " })
                    @Html.EditorFor(model => model.BankName, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Bank Name", tabindex = 19 } })
                </div>
                <div class="form-group col-md-4">
                    @Html.LabelFor(model => model.AccountNo, htmlAttributes: new { @class = "control-label " })
                    @Html.EditorFor(model => model.AccountNo, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Account No", tabindex = 20 } })
                </div>
                <div class="form-group col-md-4">
                    @Html.LabelFor(model => model.IbanNo, htmlAttributes: new { @class = "control-label " })
                    @Html.EditorFor(model => model.IbanNo, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Iban No", tabindex = 21 } })
                </div>
                <div class="form-group col-md-4">
                    @Html.LabelFor(model => model.BranchName, htmlAttributes: new { @class = "control-label " })
                    @Html.EditorFor(model => model.BranchName, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Branch Name", tabindex = 22 } })
                </div>
                <div class="form-group col-md-4">
                    @Html.LabelFor(model => model.Swift, htmlAttributes: new { @class = "control-label " })
                    @Html.EditorFor(model => model.Swift, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Swift", tabindex = 23 } })
                </div>
                <div class="form-group col-md-4">
                    @Html.LabelFor(model => model.OpnBalance, htmlAttributes: new { @class = "control-label " })
                    <div class="input-group">
                        @Html.EditorFor(model => model.OpnBalance, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Opening Balance Debit", tabindex = 24 } })
                        <div class="input-group-addon no-padding dcwidth">
                            @Html.EnumDropDownListFor(model => model.DC, new { @class = "form-control", tabindex = 25 })
                        </div>
                    </div>
                </div>
            </div>
                    <div class="form-group col-md-12 pull-left">
                        <div class="col-md-12">
                        </div>
                    </div>
                    <div class="box-footer clearfix text-center">
                        <button type="submit" id="save" class="btn btn-info" tabindex="26">
                            <span class="glyphicon glyphicon-floppy-disk"></span> Save
                        </button>
                    </div>
    }
</div>

