@model QuickSoft.Models.itemsizeprice
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Add Item Size Price</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("Create", "ItemSizePrice", FormMethod.Post, new { id = "createform" }))
    {
        <script type="text/javascript">
            $('form#createform').removeData("validator");
            $('form#createform').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#createform'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger AlertDiv" })
        <div class="row">
            <div class="col-md-12">
                <div class="form-group  col-md-12">
                    @Html.Label("Item", null, new { @class = "control-label" }) *
                    @Html.DropDownListFor(m => m.itemid, (SelectList)ViewBag.Items, new { id = "ddlItem", @class = "form-control input-sm select2", @required = "required" })
                </div>
                <div class="form-group col-md-12">
                    @Html.Label("Item Size", null, new { @class = "control-label" }) *
                    @Html.DropDownListFor(m => m.sizeid, (SelectList)ViewBag.ItemSizes, new { id = "ddlItemSizes", @class = "form-control input-sm select2", @required = "required"})
                </div>
                <div class="form-group col-md-12">
                    @Html.Label("Price ", null, new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.price, new { htmlAttributes = new { @class = "form-control input-sm", @placeholder = "Enter Price", @required = "required", @type = "number" } })

                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" value="Save" class="btn btn-info col-sm-offset-4" />
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>
<script>

    $("#ddlItem").select2({
        placeholder: 'Search Items by Name',
        minimumInputLength: 0,
        ajax: {
            url: "/Item/SearchItem",
            dataType: 'json',
            type: "POST",
            delay: 50,
            data: function (params) {
                return {
                    q: params.term,
                    page: params.page,
                };
            },
            processResults: function (data, params) {
                params.page = params.page || 1;

                return {
                    results: data
                };
            },
            cache: true
        },
    });

    $("#ddlItemSizes").select2({
        placeholder: 'Search Item Size',
        minimumInputLength: 0,
        ajax: {
            url: "/ItemSize/SearchItemSize",
            dataType: 'json',
            type: "POST",
            delay: 50,
            data: function (params) {
                return {
                    q: params.term,
                    page: params.page,
                };
            },
            processResults: function (data, params) {
                params.page = params.page || 1;

                return {
                    results: data
                };
            },
            cache: true
        },
    });

</script>






