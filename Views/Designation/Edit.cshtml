@model QuickSoft.Models.Designation
        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
            <h4>Edit Designation</h4>
        </div>
        <div class="modal-body">
            @using (Html.BeginForm("Edit", "Designation", FormMethod.Post, new { role = "form", id = "editform" }))
            {
                <script type="text/javascript">
                    $('form#popupFormDesignationEdit').removeData("validator");
                    $('form#popupFormDesignationEdit').removeData("unobtrusiveValidation");
                    $.validator.unobtrusive.parse($('form#popupFormDesignationEdit'));
                </script>
                @Html.AntiForgeryToken()
                @Html.ValidationSummary("", new { @class = "alert alert-danger" })
                @Html.HiddenFor(model => model.DesignationID)

                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group">
                            @Html.LabelFor(m => m.DesignationName, new { @class = "control-label" }) *
                            @Html.TextBoxFor(m => m.DesignationName, new { @class = "form-control", autofocus = "autofocus", @required = "required" })
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12 ">
                        <div class="form-group">
                            @Html.Label("Department", null, new { @class = "control-label" })
                            @Html.DropDownListFor(model => model.department, (SelectList)ViewBag.departments, new { htmlAttributes = new { @class = "form-control input-sm" } })
                        </div>
                    </div>
                </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="box-footer">
                                <input type="submit" class="btn btn-info col-sm-offset-4" value="Update" />
                                <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                            </div>
                        </div>
                    </div>
                    }
                </div>
                @section scripts{
                    @Scripts.Render("~/js/jqueryval")
                }
