@model QuickSoft.Models.routemap
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Create Location</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("Create", "routemap", FormMethod.Post, new { id = "createform" }))
    {
        <script type="text/javascript">
            $('form#popupFormSize').removeData("validator");
            $('form#popupFormSize').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#popupFormSize'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
<div class="row">

    <div class="col-md-12">
        <div class="form-group">
            @Html.Label("Location", null, htmlAttributes: new { @class = "control-label" })
            @Html.DropDownListFor(m => m.locationid, (SelectList)ViewBag.States, "", new { @class = "form-control select2" })
        </div>
    </div>
    <div class="col-md-12">
        <div class="form-group">
            @Html.Label("Nearest Location", null, htmlAttributes: new { @class = "control-label" })
            @Html.DropDownListFor(m => m.nearestlocationid, (SelectList)ViewBag.States, "", new { @class = "form-control select2" })
        </div>
    </div>
    <div class="col-md-12">
        <div class="form-group">
            @Html.Label("Order", null, htmlAttributes: new { @class = "control-label" })
            @Html.EditorFor(m => m.locationorder, new { @class = "form-control select2" })
        </div>
    </div>

</div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" value="Submit" class="btn btn-info col-sm-offset-4" />
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>
@section scripts{
    @Scripts.Render("~/js/jqueryval")
}