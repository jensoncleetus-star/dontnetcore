@model QuickSoft.ViewModel.ItemTaskViewModel
@{
    ViewBag.Title = "Create Task Items";
    ViewBag.SubTitle = "Task Items";
    ViewBag.Active = "Master";
    string actData = "";
    bool userRole = false;
    string delchk = "";
    string deleteBTn = "";

    userRole = true;
    deleteBTn = "{text: 'Delete', className: 'btn-danger', action: function(e, dt, node, config) {" +
           "if ($('.checkbox:checked').length > 0) {if (confirm('Are you sure you want to delete this?')) {$('#payform').submit(); e.preventDefault();} " +
            "} else {alert('Please Select Rows..!!');e.preventDefault();}}},";
}


<div class="box box-info">
    @using (Html.BeginForm("Create", "ItemTask", FormMethod.Post, new { id = "createform", role = "form" }))
    {
        <div class="box-header with-border">

            <input type="hidden" id="ddlMC" value="@(ViewBag.MaterialId)" />
        </div>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger AlertDiv" })
        <div class="box-body">
            <div style="display:none;">
                <div class="row">

                    <div class="col-md-12">
                            <div class="form-group">
                                @Html.Label("Task Name", null, htmlAttributes: new { @class = "control-label" })
                                @Html.DropDownListFor(model => model.taskid, (SelectList)ViewBag.TaskName, new { id = "ddlItem", @disabled = true, @class = "form-control select2", @required = "required" })

                            </div>
                            <div class="form-group">
                                @Html.Label("Material Center", null, htmlAttributes: new { @class = "control-label" })
                                @Html.DropDownListFor(model => model.MaterialId, (SelectList)ViewBag.MCbag, new { id = "ddlMC", @readonly = true, @class = "form-control select2", @required = "required" })

                            </div>
                        </div>
                   
                    <div class="col-sm-2 form-group">
                        @Html.Label("Date", null, htmlAttributes: new { @class = "control-label" })
                        <div class="input-group date">
                            <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                            @Html.TextBoxFor(m => m.TaskDate, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                        </div>
                    </div>



                </div>
            </div>
            <div class="pull-right">

                        <i class="ace-icon fa fa-hand-o-right icon-animated-hand-pointer blue"></i>
                        <a class="btn btn-info no-border" href="@Url.Action("MyTask","ProTask",new { id=ViewBag.Remind})">

                            <i class="glyphicon glyphicon-plus"></i> MY Task
                        </a>

                </div>
            <br />
            <br />
            <br />
            <br />
            <div>
                <div class="table-responsive bomtable">
                    <hr>
                    <table class="table table-bordered table-hover" id="bomtable">
                        <thead>
                            <tr>
                                <th class="text-center" style="width:5%">S/N</th>
                                <th class="text-center">Item <i class="text-danger"></i><div style="width:280px;height:10px"></div></th>
                                <th class="text-center">Unit</th>
                                <th class="text-center">Quantity <i class="text-danger"></i></th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody id="addbomitem"></tbody>
                    </table>
                </div>
            </div>

            <div class="box-footer text-center clearfix">
                @*<button type="submit" id="save" class="btn btn-info">
                    Save
                    </button>*@
                <button type="submit" id="save" class="btn btn-success" tabindex="26">
                    <span class="glyphicon glyphicon-floppy-disk"></span> Save
                </button>

                <button type="button" class="btn btn-default can-btn" tabindex="29" onclick="@("window.location.href='/ProTask/MyTask'");">Cancel</button>
                @*<button type="button" class="btn btn-default" onclick="@("window.location.href='/ProTask/'MyTask");">Cancel</button>*@
                <input type="hidden" value="@ViewBag.StartDate" class="Start" name="Start" id="Start">
                <input type="hidden" value="@ViewBag.EndDate" class="End" name="End" id="End">
            </div>
        </div>
        }

</div>
