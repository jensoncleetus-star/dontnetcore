<style type="text/css">
    .modal-lg {
        width: 90%;
    }

    .dropdown-check-list {
        display: inline-block;
    }

        .dropdown-check-list .anchor {
            position: relative;
            cursor: pointer;
            display: inline-block;
            padding: 5px 50px 5px 10px;
            border: 1px solid #ccc;
            width: 150px;
            background: #fff;
            text-align: center;
        }

            .dropdown-check-list .anchor:after {
                position: absolute;
                content: "";
                border-left: 2px solid black;
                border-top: 2px solid black;
                padding: 5px;
                right: 10px;
                top: 20%;
                -moz-transform: rotate(-135deg);
                -ms-transform: rotate(-135deg);
                -o-transform: rotate(-135deg);
                -webkit-transform: rotate(-135deg);
                transform: rotate(-135deg);
            }

            .dropdown-check-list .anchor:active:after {
                right: 8px;
                top: 21%;
            }

        .dropdown-check-list ul.items {
            padding: 0px;
            display: none;
            margin: 0;
            border: 1px solid #ccc;
            border-top: none;
            position: absolute;
            z-index: 9999;
        }

            .dropdown-check-list ul.items li {
                list-style: none;
                background: #fff;
                padding: 5px;
            }

    .add-btn-item {
        border-radius: 23px;
        padding: 6px 20px;
    }

    .dropdown-check-list.visible .anchor {
        color: #0094ff;
    }

    .dropdown-check-list.visible .items {
        display: block;
    }

    .box-header .pull-right {
        margin-top: -22px;
    }

    .col-md-3 {
        float: none;
        display: inline-block;
    }

    @@media only screen and (max-width: 400px) {
        .top3 {
            margin-top: 27px;
        }

        .adv-search-height {
            margin-left: 10px !important;
        }

        .responsive-search {
            padding: 0px 0px 0px 0px !important;
        }

        .btn-close {
            background-color: red !important;
            width: 150px !important;
        }

        .task-name-center {
            text-align: center !important;
        }
    }

    @@media only screen and (min-width: 800px) {
        .top3 {
            margin-top: 10px;
        }

        .adv-search-height {
            top: -8px !important;
            margin-left: 13px;
        }

        .responsive-search {
            padding: 20px 0px 0px 50px !important;
        }

        .btn-close {
            background-color: red !important;
        }

        .btn-h-change {
            margin: 0px !important;
        }

        .btn-up {
            margin-top: 0px !important;
        }
    }
</style>

@* BOS: Contacts-page parity restyle — scoped (this <style> only loads on /ServiceType) *@
<style type="text/css">
    .box.box-info { border:1px solid #e7eaf0; border-radius:16px; box-shadow:0 1px 2px rgba(15,23,42,.04),0 14px 34px rgba(15,23,42,.07); overflow:visible; }
    .box.box-info > .box-header.with-border { border-bottom:1px solid #eef1f6; padding:13px 18px 9px; }
    .box-title { font-size:18px; font-weight:800; color:#0f172a; letter-spacing:-.2px; position:relative; padding-left:13px; }
    .box-title:before { content:""; position:absolute; left:0; top:3px; bottom:3px; width:4px; border-radius:3px; background:linear-gradient(180deg,#6366f1,#4f46e5); }
    .box-header .pull-right { margin-top:0 !important; }
    .box-header .btn-info, .box-header a.btn-info { background:linear-gradient(135deg,#6366f1,#4f46e5) !important; border:0 !important; color:#fff !important; border-radius:11px; padding:9px 20px; font-weight:700; box-shadow:0 8px 18px rgba(99,102,241,.32); }
    .box-header .btn-info:hover { filter:brightness(1.07); }
