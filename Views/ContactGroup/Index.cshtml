@model QuickSoft.Models.ContactGroup
@{
    ViewBag.Title = "List";
    ViewBag.SubTitle = "Contact Group";
    ViewBag.Active = "Utility";
    string actData = "";
    bool userRole = false;
    string delchk = "";
    if (User.IsInRole("Dev") || User.IsInRole("Delete Contact Group"))
    {
        userRole = true;
    }
}
@* BOS: Contacts-page parity restyle — scoped (this <style> only loads on /ContactGroup) *@
<style type="text/css">
    .box.box-info { border:1px solid #e7eaf0; border-radius:16px; box-shadow:0 1px 2px rgba(15,23,42,.04),0 14px 34px rgba(15,23,42,.07); overflow:visible; }
    .box.box-info > .box-header.with-border { border-bottom:1px solid #eef1f6; padding:13px 18px 9px; }
    .box-title { font-size:18px; font-weight:800; color:#0f172a; letter-spacing:-.2px; position:relative; padding-left:13px; }
    .box-title:before { content:""; position:absolute; left:0; top:3px; bottom:3px; width:4px; border-radius:3px; background:linear-gradient(180deg,#6366f1,#4f46e5); }
    .box-header .pull-right { margin-top:0 !important; }
    .box-header .btn-info, .box-header a.btn-info { background:linear-gradient(135deg,#6366f1,#4f46e5) !important; border:0 !important; color:#fff !important; border-radius:11px; padding:9px 20px; font-weight:700; box-shadow:0 8px 18px rgba(99,102,241,.32); }
    .box-header .btn-info:hover { filter:brightness(1.07); color:#fff !important; }
    .icon-animated-hand-pointer { display:none !important; }

    /* toolbar: length + search */
    .dataTables_wrapper { padding:2px 16px 14px; }
    .dataTables_length { padding-top:6px; color:#64748b; font-size:12.5px; }
    .dataTables_length select { border:1.5px solid #e7eaf0; border-radius:9px; padding:6px 10px; margin:0 6px; font-size:13px; }
    .dataTables_filter { float:right; }
    .dataTables_filter label { font-size:0; color:transparent; }
    .dataTables_filter input { border:1.5px solid #e7eaf0 !important; border-radius:10px; padding:9px 14px 9px 34px; min-width:240px; font-size:13.5px; margin-left:0; background:#fff url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' fill='none' stroke='%2394a3b8' stroke-width='2'><circle cx='7' cy='7' r='5'/><path d='M11 11l4 4'/></svg>") no-repeat 11px center; }
    .dataTables_filter input:focus { border-color:#6366f1 !important; box-shadow:0 0 0 3px rgba(99,102,241,.12); outline:none; }

    /* table + frozen header */
    body .wrapper { overflow:visible; }
    table#GroupTable { width:100% !important; border-collapse:separate; border-spacing:0; overflow:visible; }
    table#GroupTable thead { position:sticky; top:0; z-index:6; }
    table#GroupTable thead td, table#GroupTable thead th { position:sticky; top:0; background:#f8fafc !important; color:#475569; font-size:10.5px; font-weight:800; text-transform:uppercase; letter-spacing:.5px; padding:11px 14px; border:0 !important; border-bottom:1.5px solid #e7eaf0 !important; white-space:nowrap; box-shadow:0 1px 0 #e7eaf0; }
    table#GroupTable tbody td { padding:11px 14px; border:0 !important; border-bottom:1px solid #f1f5f9 !important; font-size:13.5px; color:#1e293b; vertical-align:middle; }
    table#GroupTable tbody tr:hover td { background:#f8faff; }
    .dataTables_empty { color:#94a3b8 !important; padding:40px !important; text-align:center; }

    /* name avatar + group badge */
    .qk-name { display:flex; align-items:center; gap:11px; }
    .qk-av { flex:0 0 auto; width:34px; height:34px; border-radius:9px; color:#fff; font-size:12px; font-weight:700; display:inline-flex; align-items:center; justify-content:center; }
    .qk-nm { font-weight:600; color:#0f172a; }
    .qk-grp { display:inline-block; font-size:11px; font-weight:700; padding:3px 11px; border-radius:20px; background:#eef2ff; color:#4f46e5; }

    /* round icon action buttons */
    table#GroupTable tbody td a { display:inline-flex; align-items:center; justify-content:center; width:32px; height:32px; border-radius:9px; border:1px solid #e7eaf0; color:#64748b; margin:0 2px; text-decoration:none; transition:.13s; }
    table#GroupTable tbody td a i { font-size:13px !important; }
    table#GroupTable tbody td a:hover { background:#eef2ff; color:#4f46e5; border-color:#c7d2fe; }
    table#GroupTable tbody td a.modal-delete:hover { background:#fef2f2; color:#dc2626; border-color:#fecaca; }
    #GroupTable .checkbox, #select_all { width:16px; height:16px; cursor:pointer; }

    /* footer + pagination */
    .dataTables_info { color:#64748b; font-size:12.5px; }
    .qk-foot { display:flex; align-items:center; justify-content:flex-start; gap:6px 22px; flex-wrap:wrap; padding:12px 2px 2px; }
    .qk-foot .dataTables_info, .qk-foot .dataTables_paginate { padding-top:0; margin:0; }
    .dataTables_paginate .paginate_button { border:1px solid #e7eaf0 !important; border-radius:8px !important; padding:6px 12px !important; margin:0 3px !important; color:#475569 !important; background:#fff !important; font-size:13px; }
    .dataTables_paginate .paginate_button.current, .dataTables_paginate .paginate_button.current:hover { background:#6366f1 !important; border-color:#6366f1 !important; color:#fff !important; }
    .dataTables_paginate .paginate_button:hover:not(.disabled):not(.current) { background:#eef2ff !important; border-color:#c7d2fe !important; color:#4f46e5 !important; }

    /* bottom delete button */
    .box-footer { border-top:1px solid #eef1f6; padding:12px 18px; background:transparent; }
    .box-footer .btn-danger { background:#dc2626 !important; border:0 !important; border-radius:11px; padding:9px 22px; font-weight:700; box-shadow:0 8px 18px rgba(220,38,38,.26); }
    .box-footer .btn-danger:hover { filter:brightness(1.07); }

    /* mobile cards */
    @@media (max-width:768px) {
        .dataTables_wrapper { padding:4px 10px 12px; }
        .dataTables_filter { float:none; margin:8px 0 0; }
        .dataTables_filter input { width:100%; min-width:0; box-sizing:border-box; }
        table#GroupTable { min-width:0 !important; }
        table#GroupTable thead { display:none; }
        table#GroupTable, table#GroupTable tbody { display:block; width:100%; }
        table#GroupTable tbody tr { display:block; background:#fff; border:1px solid #e7eaf0 !important; border-radius:14px; margin-bottom:12px; padding:4px 13px; box-shadow:0 1px 3px rgba(15,23,42,.07); }
        table#GroupTable tbody tr:hover td { background:transparent; }
        table#GroupTable tbody td { display:block; width:auto !important; border:0 !important; border-top:1px solid #f3f5f9 !important; padding:10px 0 !important; }
        table#GroupTable tbody td:first-child { display:none; }
        table#GroupTable tbody td:nth-child(2) { border-top:0 !important; }
        table#GroupTable tbody td:empty { display:none; }
        table#GroupTable tbody td:has(input.checkbox) { display:none; }
        table#GroupTable tbody td a { width:42px; height:42px; }
    }
</style>

<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">Contact Group</h3>
        <div class="pull-right">
            @if (User.IsInRole("Dev") || User.IsInRole("Create Contact Group"))
            {
                <i class="ace-icon fa fa-hand-o-right icon-animated-hand-pointer blue"></i>
                <a class="btn btn-info no-border modal-create" href="/ContactGroup/Create">
                    <i class="glyphicon glyphicon-plus"></i> Create
                </a>
            }
        </div>
    </div>
    @using (Html.BeginForm("DeleteAll", "ContactGroup", FormMethod.Post, new { id = "payform", role = "form" }))
    {
        <div class="box-body">
            <table class="table table-bordered table-hover" id="GroupTable">
                <thead>
                    <tr>
                        <td data-priority="1">#</td>
                        <td data-priority="1">Name</td>
                        <td data-priority="2">Group Name</td>
                        <td data-priority="1"> Action</td>
                        <td data-priority="2"><input type="checkbox" id="select_all" /></td>
                  
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
        if (User.IsInRole("Dev") || User.IsInRole("Delete Contact Group"))
        {
            <div class="box-footer text-right col-md-12" id="sub">
                <button type="submit" id="save" data-confirm="Are u sure want to delete?" class="btn btn-danger">Delete</button>
            </div>
        }
    }
</div>
@Html.Partial("../Common/_ModalCreate")
@Html.Partial("../Common/_ModalEdit")
@Html.Partial("../Common/_ModalChange")
@Html.Partial("../Common/_ModalDelete")
@section scripts{
    @Scripts.Render("~/js/jqueryval")
    <script type="text/javascript">
        $(document).ready(function () {
            $('#advsearch').hide();
            $('[data-confirm]').click(function (e) {
                if ($('.checkbox:checked').length > 0) {
                    if (!confirm(jQuery(this).attr("data-confirm"))) {
                        e.preventDefault();
                    }
                } else {
                    alert("Please Select Rows..!!");
                    e.preventDefault();
                }
            });
        });
        ///*Bind for tax group*/
        var oTable = $('#GroupTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "pageLength": 50,
            responsive: false,
            "ajax": {
                "url": '/ContactGroup/GroupGetData',
                "type": "POST",
                "datatype": "json"
            },
            "columnDefs": [{
                "targets": [3, 4],
                "orderable": false
            }],
            "columns": [
                     {
                         "data": "id", "name": "id",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                 {
                     "data": "Name", "name": "Name", "render": function (data, type) {
                         if (type !== 'display') return data || '';
                         var nm = (data || '').toString();
                         var core = nm.replace(/[^a-zA-Z0-9]+/g, ' ').trim();
                         var parts = core.split(/\s+/).filter(Boolean);
                         var ini = (((parts[0] || '').charAt(0)) + ((parts[1] || '').charAt(0))).toUpperCase() || (nm.charAt(0) || '?').toUpperCase();
                         var pal = ['#6366f1', '#0ea5e9', '#10b981', '#f59e0b', '#ec4899', '#8b5cf6', '#14b8a6', '#ef4444'];
                         var h = 0; for (var i = 0; i < nm.length; i++) h = nm.charCodeAt(i) + ((h << 5) - h);
                         var col = pal[Math.abs(h) % pal.length];
                         return '<div class="qk-name"><span class="qk-av" style="background:' + col + '">' + ini + '</span><span class="qk-nm">' + $('<div>').text(nm).html() + '</span></div>';
                     }
                 },
                 {
                     "data": "Parent", "name": "Parent", "render": function (data, type) {
                         if (type !== 'display') return data || '';
                         var s = (data || '').toString().trim();
                         return s ? '<span class="qk-grp">' + $('<div>').text(s).html() + '</span>' : '';
                     }
                 },
                  //{
                  //    "name": "Status", "data": function (data) {
                  //        if (data.Status == 1) {
                  //            return '<a href="/ContactGroup/ContactStatus/' + data.id + '/active " class="modal-change" title="Click To Active" ><i class="badge bg-red" style="font-size: small" >Inactive</i></a>';
                  //        }
                  //        else {
                  //            return '<a href="/ContactGroup/ContactStatus/' + data.id + '/inactive" class="modal-change" title="Click To Inactive" ><i class="badge bg-green" style="font-size: small" >Active</i></a>';
                  //        }
                  //    }
                  //},
                 //{
                 //    "data": "id", "name": "id", "render": function (data) {
                 //        return '<a class="modal-edit" href="/ContactGroup/Edit/' + data + '" title="Edit Contact Group"><i class="fa fa-lg fa-edit" ></i></a> ' +
                 //              '<a class="modal-delete" href="/ContactGroup/Delete/' + data + '" title="Delete Contact Group"><i class="fa fa-lg fa-trash" ></i></a>';
                 //    }
                 //},
                  {
                      "name": "id", "data": function (data) {
                          var rest = "";
                          if (data.Editable == 0) {
                              @{
                                  if (User.IsInRole("Dev") || User.IsInRole("Edit Contact Group"))
                                  {
                                      actData += "<a class=\"modal-edit\" href=\"/ContactGroup/Edit/'+ data.id +'\" title=\"Edit ContactGroup\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                                  }
                                  if (User.IsInRole("Dev") || User.IsInRole("Delete Contact Group"))
                                  {
                                      actData += "<a class=\"modal-delete\" href=\"/ContactGroup/Delete/'+ data.id +'\" title=\"Delete ContactGroup\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";
                                  }
                              }
                              return rest = '@Html.Raw(actData)';
                          }
                          return rest;
                      }
                  },
                   {
                       "name": "id", "data": function (data) {
                           var rest = "";
                           @{
                               if (User.IsInRole("Dev") || User.IsInRole("Delete Contact Group"))
                               {
                                   delchk = "<input class=\"checkbox\" type=\"checkbox\" name=\"bill[]\" value='+ data.id +'></input>";
                               }
                           }
                           return rest = '@Html.Raw(delchk)';
                       }
                   },
            ], "drawCallback": function (settings) {
                var table = $('#GroupTable').DataTable();
                if (!table.data().any()) {
                    $("#sub").hide();
                } else {
                    $("#sub").show();
                }
            }
        });
        // parity with Contacts: clear search placeholder + compact grouped footer
        $('#GroupTable_filter input').attr('placeholder', 'Search groups…');
        (function () {
            try {
                var $foot = $('<div class="qk-foot"></div>');
                $('#GroupTable_info').before($foot);
                $foot.append($('#GroupTable_info')).append($('#GroupTable_paginate'));
            } catch (e) { }
        })();
        var chkcol = '@userRole';
        if (chkcol == "True") {
            var column1 = oTable.column(4);
            column1.visible(true);
            $('.dt-button.btn-danger').show();
        } else {
            var column1 = oTable.column(4);
            column1.visible(false);
            $('.dt-button.btn-danger').hide();
        }
        /* function for Create popup */

        $('div').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        });
        $('#modal-create').on('submit', '#createform', function (e) {
            e.preventDefault();
            var url = $('#createform')[0].action;
            var data = $('#createform').serialize();
            createajax(url, data, '#modal-create');
            Table.draw(false);
        });


        /* function for Edit popup */

        $('div').on('click', '.modal-edit', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-edit');
        });
        $('#modal-edit').on('submit', '#editform', function (e) {
            e.preventDefault();
            var url = $('#editform')[0].action;
            var data = $('#editform').serialize();
            createajax(url, data, '#modal-edit');
            Table.draw(false);
        });

        /* function for delete popup */
        $('.table').on('click', '.modal-delete', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-delete');
        });

        $('#modal-delete').on('submit', '#deleteform', function (e) {
            e.preventDefault();
            var url = $('#deleteform')[0].action;
            var data = $('#deleteform').serialize();
            createajax(url, data, '#modal-delete');
            Table.draw(false);
        });


        $('.table').on('click', '.modal-change', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-change');
        });
        $('#modal-change').on('submit', '#changeform', function (e) {
            e.preventDefault();
            var url = $('#changeform')[0].action;
            var data = $('#changeform').serialize();
            createajax(url, data, '#modal-change');
            Table.draw(false);
        });
        function reload_table() {
            oTable.clear().draw();
            oTable.ajax.reload(null, false); //reload datatable ajax
            isTicked();
        }
        //select all checkboxes
        $('body').on('change', '#select_all', function () {
            $(".checkbox").prop('checked', $(this).prop("checked")); //change all ".checkbox" checked status
        });
        //".checkbox" change
        $('body').on('change', '.checkbox', function () {
            //uncheck "select all", if one of the listed checkbox item is unchecked
            if (false == $(this).prop("checked")) { //if this item is unchecked
                $("#select_all").prop('checked', false); //change "select all" checked status to false
            }
            isTicked();
        });
        isTicked();
    </script>
}
