@model QuickSoft.Models.ContactGroup
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Add Contact Group</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("Create", "ContactGroup", FormMethod.Post, new { id = "createform" }))
            {
        <script type="text/javascript">
            $('form#createform').removeData("validator");
            $('form#createform').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#createform'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger AlertDiv" })
        <div class="row">
            <div class="col-md-12">
                <div class="form-group  col-md-12">
                    @Html.Label("Name", null, new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.Name, new { htmlAttributes = new {@id="GpName", @class = "form-control input-sm", @placeholder = "Enter Name", autofocus = "autofocus", @required = "required" } })
                </div>
                <div class="form-group col-md-12">
                    @Html.Label("Group", null, new { @class = "control-label" }) 
                    @Html.DropDownListFor(m => m.Parent, (SelectList)ViewBag.ParentModules, new { @class = "form-control input-sm" })
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" value="Save" class="btn btn-info col-sm-offset-4"/>
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>
@section scripts{
    @Scripts.Render("~/js/jqueryval")
}


