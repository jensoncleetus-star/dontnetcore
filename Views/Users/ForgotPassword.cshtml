@model QuickSoft.Models.ForgotPasswordViewModel
@{
    Layout = null;
}
    <div class="modal-dialog">
        <div class="modal-content" id="divProduct">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                <h4>Forgot your password?</h4>
            </div>
            <div class="modal-body">
                <p>Enter your e-mail address to <b>Reset Password.</b></p>
                @using (Html.BeginForm("ForgotPassword", "Users", FormMethod.Post, new { id = "popupForm", @class = "form-horizontal" }))
                {
                    <script type="text/javascript">
                        $('form#popupForm').removeData("validator");
                        $('form#popupForm').removeData("unobtrusiveValidation");
                        $.validator.unobtrusive.parse($('form#popupForm'));
                    </script>
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary("", new { @class = "alert alert-danger" })
                        <div class="form-group">
                            @Html.Label("Email  *", null, new { @class = "col-sm-2 control-label" })
                            <div class="col-sm-10">
                                @Html.TextBoxFor(m => m.Email, new { @class = "form-control", @placeholder = "Email Address", autofocus = "autofocus" })
                            </div>
                        </div>
                        <div class="form-group">
                            <input type="submit" class="btn btn-info col-sm-offset-4" value="Send Link" />
                            <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                        </div>

                }
            </div>
            <div class="modal-footer"></div>
        </div>
    </div>
