@model QuickSoft.Models.ApplicationUser
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Unban User</h4>
</div>
<div class="modal-body">
    <h3>Are you sure you want to Unban this user?</h3>
    @using (Html.BeginForm("UnBan", "Users", FormMethod.Post, new { id = "banform" }))
    {
        <div class="form-actions no-color">
            <input type="submit" value="Unban" class="btn btn-success col-sm-offset-4" />
            <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal">
        </div>
    }
</div>


