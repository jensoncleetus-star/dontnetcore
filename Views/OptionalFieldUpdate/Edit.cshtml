@model QuickSoft.ViewModel.OptionalFieldViewModel
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Update Optional Field</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("Edit2", "OptionalFieldUpdate", FormMethod.Post, new { role = "form", id = "editform" }))
    {
        <script type="text/javascript">
            $('form#popupFormUnitTypeEdit').removeData("validator");
            $('form#popupFormUnitTypeEdit').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#popupFormUnitTypeEdit'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        //@Html.HiddenFor(model => model.RefID)
        <input type="hidden" name="id" value="@Model.Ref1"/>
        <input type="hidden" name="type" value="@Model.type" />
        <input type="hidden" name="field" value="@Model.field" />
        <div class="row">
            <div class="col-md-12 col-md-12">
                <div class="form-group ">
                    @Html.LabelFor(model => model.Ref1, new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.Ref1, new { htmlAttributes = new { @class = "form-control input-sm", autofocus = "autofocus", @required = "required" } })
                </div>

            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" value="Save" class="btn btn-info col-sm-offset-4" />
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>
@section Scripts {

    @Scripts.Render("~/js/jqueryval")

}

