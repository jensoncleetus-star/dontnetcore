@model QuickSoft.Models.Quotation
@{
    ViewBag.Title = "List";
    ViewBag.SubTitle = "Quotation";
    ViewBag.Active = "Transactions";
    string actData = "";
    string delchk = "";
    bool userRole = false;
    string deleteBTn = "";
    if (User.IsInRole("Dev") || User.IsInRole("Delete Quotation"))
    {
        userRole = true;

        deleteBTn = "{text: 'Delete', className: 'btn-danger', action: function(e, dt, node, config) {" +
             "if ($('.checkbox:checked').length > 0) {if (confirm('Are you sure you want to delete this?')) {$('#delallform').submit(); e.preventDefault();} " +
              "} else {alert('Please Select Rows..!!');e.preventDefault();}}},";
    }

}
<style type="text/css">

    .dropdown-check-list {
        display: inline-block;
    }

        .dropdown-check-list .anchor {
            position: relative;
            cursor: pointer;
            display: inline-block;
            padding: 5px 50px 5px 10px;
            border: 1px solid #ccc;
            width: 150px;
            background: #fff;
            text-align: center;
        }

            .dropdown-check-list .anchor:after {
                position: absolute;
                content: "";
                border-left: 2px solid black;
                border-top: 2px solid black;
                padding: 5px;
                right: 10px;
                top: 20%;
                -moz-transform: rotate(-135deg);
                -ms-transform: rotate(-135deg);
                -o-transform: rotate(-135deg);
                -webkit-transform: rotate(-135deg);
                transform: rotate(-135deg);
            }

            .dropdown-check-list .anchor:active:after {
                right: 8px;
                top: 21%;
            }

        .dropdown-check-list ul.items {
            padding: 0px;
            display: none;
            margin: 0;
            border: 1px solid #ccc;
            border-top: none;
            position: absolute;
            z-index: 9999;
        }

            .dropdown-check-list ul.items li {
                list-style: none;
                background: #fff;
                padding: 5px;
            }

    .add-btn-item {
        border-radius: 23px;
        padding: 6px 20px;
    }

    .dropdown-check-list.visible .anchor {
        color: #0094ff;
    }

    .dropdown-check-list.visible .items {
        display: block;
    }
</style>

@* BOS safe polish: visual chrome only — every column, the advanced filter, action icons and status badges are left untouched. Scoped to /Quotation. *@
<style type="text/css">
    .box.box-info { border:1px solid #e7eaf0; border-radius:16px; box-shadow:0 1px 2px rgba(15,23,42,.04),0 14px 34px rgba(15,23,42,.07); }
    .box.box-info > .box-header.with-border { border-bottom:1px solid #eef1f6; padding:13px 18px 9px; }
    .box-title { font-size:18px; font-weight:800; color:#0f172a; position:relative; padding-left:13px; }
    .box-title:before { content:""; position:absolute; left:0; top:3px; bottom:3px; width:4px; border-radius:3px; background:linear-gradient(180deg,#6366f1,#4f46e5); }
    .box-header .btn-info, .box-header a.btn-info { background:linear-gradient(135deg,#6366f1,#4f46e5) !important; border:0 !important; color:#fff !important; border-radius:11px; padding:9px 18px; font-weight:700; box-shadow:0 8px 18px rgba(99,102,241,.32); }
    .box-header .btn-info:hover { filter:brightness(1.07); color:#fff !important; }
    .icon-animated-hand-pointer { display:none !important; }

    /* Search-first list: the search box now covers every column (see QuotationController search),
       so the advanced Filters panel + its toggle button are hidden here. */
    .bosx-filters-toggle, #advsearchlist, #srch, a[href="#advsearchlist"] { display:none !important; }
    /* Prominent, roomy search box */
    #QuotationTable_filter { float:none !important; margin:2px 0 12px !important; text-align:left; }
    #QuotationTable_filter label { width:100%; max-width:460px; font-size:0; }
    #QuotationTable_filter input { width:100% !important; max-width:460px; height:42px; margin:0 !important; border:1.5px solid #e7eaf0 !important; border-radius:11px !important;
        padding:0 14px 0 38px !important; font-size:13.5px !important;
        background:#fff url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='%236366f1' stroke-width='2' stroke-linecap='round'><circle cx='11' cy='11' r='7'/><line x1='21' y1='21' x2='16.65' y2='16.65'/></svg>") no-repeat 13px center !important; }
    #QuotationTable_filter input:focus { border-color:#a5b4fc !important; box-shadow:0 0 0 3px rgba(99,102,241,.15) !important; outline:none; }
    /* Compact rows — matches the Contacts list density */
    #QuotationTable td, #QuotationTable th { padding:7px 9px !important; font-size:12.5px; vertical-align:middle; }
    #QuotationTable td { line-height:1.3; }
    #QuotationTable thead th { padding-top:9px !important; padding-bottom:9px !important; }

    .dt-buttons { display:inline-flex; flex-wrap:wrap; gap:6px; margin-bottom:10px; }
    .dt-button, button.dt-button, a.dt-button, div.dt-button { background:#fff !important; border:1.5px solid #e7eaf0 !important; border-radius:10px !important; color:#475569 !important; font-weight:600 !important; font-size:12.5px !important; padding:8px 14px !important; box-shadow:none !important; margin:0 !important; }
    .dt-button:hover { border-color:#c7d2fe !important; background:#eef2ff !important; color:#4f46e5 !important; }
    .dt-button.btn-danger { background:#ef4444 !important; border-color:#ef4444 !important; color:#fff !important; }
    .qk-export-btn .fa-download { margin-right:5px; }
    .qk-export-btn:after { content:""; display:inline-block; margin-left:7px; border-left:4px solid transparent; border-right:4px solid transparent; border-top:5px solid currentColor; vertical-align:middle; opacity:.55; }
    div.dt-button-collection { border:1px solid #e7eaf0 !important; border-radius:12px !important; box-shadow:0 14px 34px rgba(15,23,42,.16) !important; padding:6px !important; background:#fff !important; min-width:184px !important; }
    div.dt-button-collection .dt-button { display:block !important; width:100% !important; text-align:left !important; border:0 !important; border-radius:8px !important; margin:1px 0 !important; padding:9px 13px !important; }
    div.dt-button-collection .dt-button:hover { background:#eef2ff !important; color:#4f46e5 !important; }

    .dataTables_length select { border:1.5px solid #e7eaf0; border-radius:9px; padding:6px 10px; margin:0 6px; font-size:13px; }
    .dataTables_filter label { font-size:0; color:transparent; }
    .dataTables_filter input { border:1.5px solid #e7eaf0 !important; border-radius:10px; padding:8px 14px 8px 34px; min-width:220px; font-size:13.5px; background:#fff url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' fill='none' stroke='%2394a3b8' stroke-width='2'><circle cx='7' cy='7' r='5'/><path d='M11 11l4 4'/></svg>") no-repeat 11px center; }
    .dataTables_filter input:focus { border-color:#6366f1 !important; box-shadow:0 0 0 3px rgba(99,102,241,.12); outline:none; }

    #QuotationTable > thead > tr > td, #QuotationTable > thead > tr > th { background:#f8fafc !important; color:#475569; font-size:10px; font-weight:800; text-transform:uppercase; letter-spacing:.4px; padding:10px 12px; border:0 !important; border-bottom:1.5px solid #e7eaf0 !important; }
    #QuotationTable > tbody > tr > td { border:0 !important; border-bottom:1px solid #f1f5f9 !important; padding:9px 12px; font-size:12.5px; vertical-align:middle; }
    #QuotationTable > tbody > tr:hover > td { background:#f8faff; }

    .dataTables_info { color:#64748b; font-size:12.5px; }
    .dataTables_paginate .paginate_button { border:1px solid #e7eaf0 !important; border-radius:8px !important; padding:6px 12px !important; margin:0 3px !important; color:#475569 !important; background:#fff !important; font-size:13px; }
    .dataTables_paginate .paginate_button.current, .dataTables_paginate .paginate_button.current:hover { background:#6366f1 !important; border-color:#6366f1 !important; color:#fff !important; }
    .dataTables_paginate .paginate_button:hover:not(.disabled):not(.current) { background:#eef2ff !important; border-color:#c7d2fe !important; color:#4f46e5 !important; }
</style>

<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">List Quotation</h3>
        <div class="pull-right">
            
            @if (User.IsInRole("Dev") || User.IsInRole("Quotation Entry"))
            {
                <i class="ace-icon fa fa-hand-o-right icon-animated-hand-pointer blue"></i>
                <a class="btn btn-info no-border" href="/Quotation/Create">
                    <i class="glyphicon glyphicon-plus"></i> Create
                </a>
            }
        </div>

        <div class="row">
            <div class="col-md-2">
                <div id="list1" class="dropdown-check-list" tabindex="100">
                    <span class="anchor" style="z-index:0;">Select Fields</span>
                    <ul class="items">
                        <li><input type="checkbox" id="liquotno" checked />Quotation No.</li>
                        <li><input type="checkbox" id="liquttype" />Quotation Type</li>
                        <li><input type="checkbox" id="lisertype" />Service Type</li>
                        <li><input type="checkbox" id="lifromdate" checked />From Date</li>
                        <li><input type="checkbox" id="litodate" checked />To Date</li>
                        <li><input type="checkbox" id="licustomer" checked />Customer</li>
                        <li><input type="checkbox" id="limobile" checked />Mobile</li>
                        <li><input type="checkbox" id="lisalesexctve" />Sales Executive</li>
                        <li><input type="checkbox" id="liproject" />Project</li>
                        <li><input type="checkbox" id="litask" />Task</li>
                        <li><input type="checkbox" id="livalidity" />Validity</li>
                        <li><input type="checkbox" id="listatus" />Status</li>
                        <li><input type="checkbox" id="liapprvlstatus" />Approval Status</li>
                    </ul>
                </div>
            </div>

            <div class="col-md-12">
                <div class="box-body search-box" id="advsearchlist">
                    <div class="search-body col-md-12" style="background:none;">
                        <form id="search-form">
                            <div class="row">
                                <input type="hidden" id="remId" />
                                <div class="form-group col-md-2" id="searchquotno">
                                    @Html.Label("Quotation No", null, new { @class = "control-label" })
                                    @Html.TextBox("BillNo", "", new { @class = "form-control input-sm" })
                                </div>
                                <div class="form-group col-md-2" id="searchquottype">
                                    @Html.Label("Quotation Type", null, new { @class = "control-label" })
                                    @Html.DropDownList("QuotationType", (SelectList)ViewBag.Customer, new { @class = "form-control input-sm select2" })
                                </div>
                                <div class="form-group col-md-2" id="serchsertype">
                                    @Html.Label("Service Type", null, new { @class = "control-label" })
                                    @Html.DropDownList("servicetype", (SelectList)ViewBag.Customer, new { @class = "form-control input-sm select2" })
                                </div>

                                <div class="form-group col-md-2" id="searchfromdate">
                                    @Html.Label("From Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("FromDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group col-md-2" id="searchtodate">
                                    @Html.Label("To Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("ToDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-2 col-sm-4 col-xs-12 form-group">
                                    @Html.Label("Source of lead", null, new { @class = "control-label temp2" })

                                    <div class="input-group">
                                        @Html.DropDownListFor(m => m.sourceoflead, (SelectList)ViewBag.SrcOfLead, "", new { id = "ddlSrcLead", @class = "form-control select2", tabindex = 7 })

                                    </div>
                                </div>
                                <div class="form-group col-md-2" id="searchcustomer">
                                    @Html.Label("Customer", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlCustomer", (SelectList)ViewBag.Customer, new { @class = "form-control input-sm select2" })
                                </div>

                                <div class="form-group col-md-2" id="searchmobile">
                                    @Html.Label("Mobile", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlMobile", (SelectList)ViewBag.Customer, new { @class = "form-control input-sm select2" })
                                </div>

                                @if (ViewBag.ProjCheck == 0)
                                {
                                    <div class="form-group col-md-2" id="searchproject">
                                        @Html.Label("Project", null, new { @class = "control-label" })
                                        @Html.DropDownList("ddlProject", (SelectList)ViewBag.Prjct, new { @class = "form-control input-sm select2" })
                                    </div>
                                    <div class="form-group col-md-2" id="searchtask">
                                        @Html.Label("Task", null, new { @class = "control-label" })
                                        @Html.DropDownListFor(m => m.ProTask, (SelectList)ViewBag.Prjct, "All", new { id = "ddlProTask", @class = "form-control input-sm select2" })
                                    </div>
                                }
                                <div class="form-group col-md-2" id="searchemployee">
                                    @Html.Label("Sales Executive", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlEmployee", (SelectList)ViewBag.SalesExecutive, "All", new { @class = "form-control input-sm select2" })
                                </div>
                                <div class="form-group col-md-2" id="searchcreatdby">
                                    @Html.Label("Created By", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlCreatedBy", (SelectList)ViewBag.CreatedBy, "All", new { @class = "form-control input-sm select2" })
                                </div>
                                <div class="form-group col-md-2" id="searchvalidity">
                                    @Html.Label("Validity", null, new { @class = "control-label" })
                                    @Html.TextBox("Validity", "", new { @class = "form-control input-sm" })
                                </div>
                                <div class="form-group col-md-2" id="searchstatus">
                                    @Html.Label("Status", null, new { @class = "control-label" })
                                    @Html.DropDownList("Status", (SelectList)ViewBag.ItStatus, new { @class = "form-control" })
                                </div>
                                @if (@ViewBag.BusinessType == "Scaffold")
                                {
                                    <div class="form-group col-md-2" id="searchtype">
                                        @Html.Label("Type", null, new { @class = "control-label" })
                                        @Html.DropDownList("SaleType", (SelectList)ViewBag.Type, new { @class = "form-control select2" })
                                    </div>
                                    <div class="form-group col-md-2" id="searchhiretype">
                                        @Html.Label("Hire Type", null, new { @class = "control-label" })
                                        @Html.DropDownList("HireType", (SelectList)ViewBag.HiType, "All", new { id = "ddlHType", @class = "form-control select2" })
                                    </div>
                                }
                                @if (ViewBag.MLAQuot == 0)
                                {
                                    <div class="form-group col-md-2" id="searchapprovalstatus">
                                        @Html.Label("Approval Status", null, new { @class = "control-label" })
                                        @Html.DropDownList("ApprovalStatus", (SelectList)ViewBag.AppStat, "All", new { id = "ApprovalStatus", @class = "form-control" })
                                    </div>
                                }
                                <div class="form-group col-md-2" id="search">
                                    <input type="submit" class="btn btn-submit" value="Submit" />
                                </div>
                                <div class="form-group col-md-2" id="close">
                                    <input type="button" class="btn btn-close" value="Close" />
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @using (Html.BeginForm("DeleteAllQuotation", "Quotation", FormMethod.Post, new { id = "delallform", role = "form" }))
    {
        <div class="box-body">
            <table class="table table-bordered table-hover" id="QuotationTable">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="2">S/N</td>
                        <td data-priority="1">Quote No</td>
                        <td data-priority="2">Date</td>
                        <td data-priority="4">Customer</td>
                        <td data-priority="4">Project</td>
                        <td data-priority="6">Task</td>
                        <td data-priority="2" class="headeralign">Amount</td>
                        <td data-priority="3">Validity</td>
                        <td data-priority="5">Executive</td>
                        <td data-priority="5">SaleType</td>
                        <td data-priority="5">Created By</td>
                        <td data-priority="3">Status</td>
                        <td data-priority="3">Approval Status</td>
                        <td data-priority="1">Action</td>
                        <td data-priority="1"><input type="checkbox" id="select_all" /></td>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    }

    <div id="modal-container2" class="modal fade" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-aqua">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                    <h4>Status Updation History</h4>
                </div>
                <div class="modal-body">
                    <table class="table table-bordered table-hover" id="UserTableInfo">
                        <thead>
                            <tr class="bg-aqua">
                                <td>Status</td>
                                <td>Updated By</td>
                                <td>Requested By</td>
                                <td>Date</td>
                                <td>Remarks</td>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    @* ---- Attach documents to a quotation directly from the list ---- *@
    <div id="modal-attach" class="modal fade" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header" style="background:#059669;color:#fff;">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true" style="color:#fff;opacity:.9;">&times;</button>
                    <h4><i class="fa fa-paperclip"></i> Attachments &mdash; Quotation <span id="qcAttachTitle"></span></h4>
                </div>
                <div class="modal-body">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="qcAttachId" value="" />
                    <div class="qc-attach-hint" style="font-size:12.5px;color:#6b7280;margin-bottom:10px;">
                        <i class="fa fa-cloud-upload" style="color:#059669;"></i>
                        Drag &amp; drop or browse to upload a signed quote copy, PO, or any supporting document. Files are saved immediately.
                    </div>
                    <div style="font-size:11px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:#9aa1ab;margin-bottom:6px;">Attached documents</div>
                    <div id="qcAttachList" class="qc-doc-list" style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:14px;"></div>
                    <div id="qcDropZone" class="qc-dropzone">
                        <i class="fa fa-cloud-upload"></i>
                        <div class="qc-dz-text">Drag &amp; drop files here, or <span class="qc-browse">click to browse</span></div>
                        <div class="qc-dz-hint">JPG, PNG, PDF, Word, Excel, DWG&hellip; up to a few MB each</div>
                        <input id="qcAttachInput" type="file" multiple style="display:none" />
                    </div>
                    <div id="qcSelPreview" class="qc-doc-list" style="display:flex;flex-wrap:wrap;gap:10px;margin-top:12px;"></div>
                    <div id="qcUpWrap" style="display:none;margin-top:12px;">
                        <div style="height:8px;background:#e5e7eb;border-radius:6px;overflow:hidden;">
                            <div id="qcUpBar" style="height:100%;width:0;background:#059669;transition:width .15s;"></div>
                        </div>
                    </div>
                    <div id="qcAttachProgress" style="margin-top:8px;"></div>
                </div>
            </div>
        </div>
    </div>
    <style>
        #modal-attach .qc-doc-empty { font-size:12.5px; color:#9ca3af; font-style:italic; }
        #modal-attach .qc-dropzone { border:2px dashed #cbd5e1; border-radius:12px; padding:26px 16px; text-align:center; cursor:pointer; color:#64748b; background:#f8fafc; transition:all .15s; }
        #modal-attach .qc-dropzone:hover, #modal-attach .qc-dropzone.dragover { border-color:#059669; background:#f0fdf4; color:#059669; }
        #modal-attach .qc-dropzone .fa { font-size:30px; color:#059669; margin-bottom:8px; }
        #modal-attach .qc-dz-text { font-size:14px; font-weight:600; }
        #modal-attach .qc-browse { color:#059669; text-decoration:underline; }
        #modal-attach .qc-dz-hint { font-size:11.5px; color:#9ca3af; margin-top:4px; }
        #modal-attach #qcAttachProgress { margin-top:10px; font-size:12.5px; color:#374151; }
        #modal-attach .qc-doc-item { display:flex; align-items:center; gap:10px; background:#fff; border:1px solid #e5e7eb; border-radius:10px; padding:8px 10px; min-width:240px; max-width:340px; }
        #modal-attach .qc-doc-thumb { width:40px; height:40px; object-fit:cover; border-radius:7px; flex:0 0 40px; border:1px solid #eef0f2; }
        #modal-attach .qc-doc-ico { width:40px; height:40px; flex:0 0 40px; border-radius:7px; background:#eef2ff; color:#4f46e5; display:flex; align-items:center; justify-content:center; font-size:18px; }
        #modal-attach .qc-doc-meta { flex:1 1 auto; min-width:0; line-height:1.35; }
        #modal-attach .qc-doc-name { display:block; font-size:12.5px; font-weight:600; color:#111827; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
        #modal-attach .qc-doc-meta small { color:#9ca3af; font-size:11px; }
        #modal-attach .qc-doc-actions { display:flex; gap:6px; flex:0 0 auto; }
    </style>
</div>

