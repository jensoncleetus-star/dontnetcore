    <script type="text/javascript">
        // ---- List-page attachments: open modal, list existing docs, upload new, delete ----
        (function () {
            function tok() { return $('#modal-attach input[name="__RequestVerificationToken"]').val() || $('input[name="__RequestVerificationToken"]').first().val(); }
            window.openAttach = function (qid) {
                $('#qcAttachId').val(qid);
                $('#qcAttachTitle').text('#' + qid);
                $('#qcAttachProgress').empty();
                $('#qcSelPreview').empty();
                $('#qcUpWrap').hide(); $('#qcUpBar').css('width', '0');
                $('#qcAttachInput').val('');
                loadAttachList();
                $('#modal-attach').modal('show');
            };
            function fmtSize(b) { return b > 1048576 ? (b / 1048576).toFixed(1) + ' MB' : Math.max(1, Math.round(b / 1024)) + ' KB'; }
            // Show a preview of the files the user just picked, BEFORE/while they upload.
            function renderSelected(files) {
                var $p = $('#qcSelPreview'); $p.empty();
                for (var i = 0; i < files.length; i++) {
                    var f = files[i], nm = $('<div>').text(f.name).html();
                    var isImg = /^image\//.test(f.type);
                    var icon = isImg ? ('<img src="' + URL.createObjectURL(f) + '" class="qc-doc-thumb">')
                                     : '<span class="qc-doc-ico"><i class="fa fa-file-o"></i></span>';
                    $p.append('<div class="qc-doc-item">' + icon +
                        '<div class="qc-doc-meta"><span class="qc-doc-name" title="' + nm + '">' + nm + '</span><small>' + fmtSize(f.size) + '</small></div></div>');
                }
            }
            function loadAttachList() {
                var qid = $('#qcAttachId').val();
                $.ajax({ url: '/Quotation/GetQuotationDocuments/' + qid + '?_=' + Date.now(), dataType: 'json', // id binds from the PATH in this app, not query
                  error: function (x) { $('#qcAttachList').html('<div class="qc-doc-empty">Could not load documents (status ' + x.status + ').</div>'); },
                  success: function (list) {
                    var $c = $('#qcAttachList'); $c.empty();
                    if (!list || !list.length) { $c.html('<div class="qc-doc-empty">No documents attached yet.</div>'); return; }
                    list.forEach(function (d) {
                        var name = $('<div>').text(d.fileName).html();
                        var icon = d.isImage ? ('<img src="' + d.url + '" class="qc-doc-thumb">')
                                             : '<span class="qc-doc-ico"><i class="fa fa-file-o"></i></span>';
                        $c.append('<div class="qc-doc-item" data-id="' + d.qutid + '">' + icon +
                            '<div class="qc-doc-meta"><a href="' + d.url + '" target="_blank" class="qc-doc-name" title="' + name + '">' + name + '</a><small>' + (d.created || '') + '</small></div>' +
                            '<div class="qc-doc-actions"><a href="' + d.url + '" target="_blank" class="btn btn-xs btn-default" title="View / Preview"><i class="fa fa-eye"></i></a>' +
                            '<a href="' + d.url + '" download="' + name + '" class="btn btn-xs btn-primary" title="Download"><i class="fa fa-download"></i></a>' +
                            '</div></div>'); // delete is intentionally NOT here — deletion is only allowed inside the Edit page
                    });
                  }
                });
            }
            function uploadFiles(files) {
                if (!files || !files.length) return;
                var qid = $('#qcAttachId').val();
                renderSelected(files);                       // show what is being attached
                var fd = new FormData();
                for (var i = 0; i < files.length; i++) { fd.append(files[i].name, files[i]); }
                fd.append('id', qid);
                fd.append('__RequestVerificationToken', tok()); // app uses global AutoValidateAntiforgeryToken
                $('#qcUpWrap').show(); $('#qcUpBar').css('width', '0');
                $('#qcAttachProgress').html('<span style="color:#374151;"><i class="fa fa-spinner fa-spin"></i> Uploading ' + files.length + ' file(s)…</span>');
                var xhr = new XMLHttpRequest();
                xhr.open('POST', '/Quotation/UploadFiles');
                if (xhr.upload) {
                    xhr.upload.onprogress = function (e) {
                        if (e.lengthComputable) { $('#qcUpBar').css('width', Math.round(e.loaded / e.total * 100) + '%'); }
                    };
                }
                xhr.onload = function () {
                    var ok = xhr.status >= 200 && xhr.status < 300 && !/error occurred|no files/i.test(xhr.responseText || '');
                    if (ok) {
                        $('#qcUpBar').css('width', '100%');
                        $('#qcAttachProgress').html('<span style="color:#059669;"><i class="fa fa-check"></i> Uploaded. Closing…</span>');
                        $('#qcAttachInput').val('');
                        loadAttachList();                    // show the newly saved doc in the list
                        setTimeout(function () {
                            $('#modal-attach').modal('hide');
                            try { if (typeof oTable !== 'undefined') oTable.draw(false); } catch (e) { }
                        }, 1000);                            // then close back to the list
                    } else {
                        $('#qcUpWrap').hide();
                        $('#qcAttachProgress').html('<span style="color:#dc2626;"><i class="fa fa-times"></i> Upload failed: ' + $('<div>').text((xhr.responseText || 'server error').replace(/^"|"$/g, '').slice(0, 160)).html() + '</span>');
                    }
                };
                xhr.onerror = function () { $('#qcUpWrap').hide(); $('#qcAttachProgress').html('<span style="color:#dc2626;"><i class="fa fa-times"></i> Upload failed (network/permission).</span>'); };
                xhr.send(fd);
            }
            $(document).on('click', '#qcDropZone', function (e) {
                // ignore clicks that came FROM the input itself (bubbling) — otherwise re-clicking it recurses
                if (e.target && e.target.id === 'qcAttachInput') return;
                var el = document.getElementById('qcAttachInput');
                if (el) el.click(); // native click opens the file dialog without a jQuery trigger loop
            });
            $(document).on('change', '#qcAttachInput', function () { uploadFiles(this.files); });
            $(document).on('dragover', '#qcDropZone', function (e) { e.preventDefault(); e.stopPropagation(); $(this).addClass('dragover'); });
            $(document).on('dragleave', '#qcDropZone', function (e) { e.preventDefault(); e.stopPropagation(); $(this).removeClass('dragover'); });
            $(document).on('drop', '#qcDropZone', function (e) { e.preventDefault(); e.stopPropagation(); $(this).removeClass('dragover'); uploadFiles(e.originalEvent.dataTransfer.files); });
            $(document).on('click', '.qc-attach-del', function () {
                var $item = $(this).closest('.qc-doc-item'), id = $item.data('id');
                if (!confirm('Delete this attachment permanently? This removes the file from the server.')) return;
                $.ajax({
                    url: '/Quotation/DeleteQuotationDocument', type: 'POST', data: { qutid: id, __RequestVerificationToken: tok() },
                    success: function (r) {
                        if (r && r.status) { $item.remove(); if (!$('#qcAttachList .qc-doc-item').length) $('#qcAttachList').html('<div class="qc-doc-empty">No documents attached yet.</div>'); }
                        else { alert((r && r.message) || 'Delete failed.'); }
                    },
                    error: function () { alert('Delete failed (server error).'); }
                });
            });
        })();
    </script>
}