    <script>
        // When this page is restored from the browser's back-forward cache (e.g. clicking "Back" on the print
        // page), force a fresh reload so the form loads cleanly instead of a stale/blank state.
        window.addEventListener('pageshow', function (e) { if (e.persisted) { location.reload(); } });
    </script>
    <script>
        // Hover tooltips (title=) so every icon/field on the item grid explains itself. Runs on load and
        // re-runs whenever rows are added (each new item row, popup, etc.).
        (function () {
            var TIP = [
                ['button[data-target^="#modal-item-heading"]', 'Item HEADING — a bold title printed above this item (text + photo)'],
                ['button[data-target^="#modal-item-"]:not([data-target*="heading"])', 'Item NOTE / description — printed under the item; add text, colours & photos here'],
                ['a[href*="AddItemSearch"]', 'Search & pick an item from the list'],
                ['a[href*="Item/Create"]', 'Create a brand-new item'],
                ['a[href*="Searchmodal"]', 'Search items'],
                ['a[href*="AddItemnoteSearch"]', 'Insert a saved note'],
                ['button[onclick*="deleteRow"]', 'Remove this item row'],
                ['.item_name', 'Choose the item'],
                ['.units', 'Unit of measure (PCS, LUMSUM, …)'],
                ['.quty', 'Quantity'],
                ['.totrate', 'Rate — price per unit'],
                ['.itprice', 'Rate incl. tax — price per unit'],
                ['.subtotal', 'Sub total (calculated automatically)'],
                ['.item_discount', 'Discount on this line'],
                ['.tax', 'Tax amount (calculated automatically)'],
                ['.total_price', 'Line total (calculated automatically)'],
                ['#save', 'Save this quotation'],
                ['#print', 'Save, then open the print template'],
                ['#sendmail', 'Save, then email the quotation to the customer'],
                ['#sh-cancel', 'Discard and go back to the list']
            ];
            function apply() {
                TIP.forEach(function (t) {
                    try { Array.prototype.forEach.call(document.querySelectorAll(t[0]), function (el) { if (!el.getAttribute('title')) el.setAttribute('title', t[1]); }); } catch (e) { }
                });
            }
            // MOBILE/TABLET CARD LAYOUT: the phone/tablet item-row markup (qutinvoice.js addrow2, used on real
            // touch devices) bakes each column's label as plain leading text inside the <td> (e.g. "Unit<select>").
            // Wrap that leading text in a <span class="bosx-mlbl"> (additive only — never touches the input/select
            // itself, its id, name, or DOM order) so CSS can style the label as a small caption above the control.
            function wrapMobileLabels() {
                try {
                    Array.prototype.forEach.call(document.querySelectorAll('.mobView1 table.table-item td'), function (td) {
                        if (td.__bosxWrapped) return; td.__bosxWrapped = 1;
                        var n = td.firstChild;
                        if (n && n.nodeType === 3 && n.nodeValue.trim() !== '') {
                            var span = document.createElement('span'); span.className = 'bosx-mlbl'; span.textContent = n.nodeValue.trim();
                            td.replaceChild(span, n);
                        }
                    });
                } catch (e) { }
            }
            function run() {
                apply();
                wrapMobileLabels();
                var tbl = document.querySelector('#addinvoiceItem, #normalinvoice');
                if (tbl && !tbl.__bosxTip) { tbl.__bosxTip = 1; try { new MutationObserver(function () { apply(); wrapMobileLabels(); }).observe(tbl, { childList: true, subtree: true }); } catch (e) { } }
            }
            if (document.readyState !== 'loading') run(); else document.addEventListener('DOMContentLoaded', run);
            setTimeout(run, 1500); setTimeout(run, 4000);
        })();
    </script>
