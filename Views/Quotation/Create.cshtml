@using (Html.BeginForm("CreateQuotation", "Quotation", FormMethod.Post, new { id = "quotationform", role = "form", enctype = "multipart/form-data" }))
{
    <div class="box box-info">
        <div class="box-header with-border">
            <div class="row">
                <div class="col-md-10 col-xs-12">
                    <div class="ribbon">
                        <div class="ribbon4"><h3 class="box-title">Create Quotation</h3></div>
                    </div>
                </div>

                <div class="col-md-2 col-xs-12">
                    <div class="pull-right">
                        @if (@ViewBag.LastEntry != 0)
                        {
                            if (User.IsInRole("Dev") || User.IsInRole("Edit Quotation"))
                            {
                                <a class="btn bg-black no-border" href="/Quotation/Edit/@ViewBag.LastEntry">
                                    <i class="fa fa-step-backward"></i>
                                </a>
                            }
                        }
                        @if (User.IsInRole("Dev") || User.IsInRole("Quotation List"))
                        {
                            <a class="btn btn-success no-border" href="/Quotation">
                                <i class="fa fa-fw fa-history"></i> List
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        @Html.HiddenFor(model => model.QuotationId)
        @Html.HiddenFor(model => model.ConTypeId)
        @Html.HiddenFor(model => model.ConType)
        <input type="hidden" id="VoucherType" value="Quotation" />
        @*for showing the last datas of sales and purchase*@
        @*Id's are used in saleinvoice2.js*@
        <input type="hidden" id="LastSale" value="@ViewBag.LastTransInSale" />
        <input type="hidden" id="LastPurchase" value="@ViewBag.LastTransInPurchase" />
        <input type="hidden" id="LastSaleCount" value="@Model.SaleTransCount" />
        <input type="hidden" id="LastPurchaseCount" value="@Model.PurTransCount" />
        @*end*@
        <div class="box-body">
            <input type="hidden" id="ROnlyRate" value="@IRateCheck" />
            <input type="hidden" id="SelApprovedBy" />
            <div style="text-align:right;"><a id="desclink" href="javascript:void(0)" style="color:red;font-size:12px;">Show Item Description</a></div>
            <div class="row" style="margin-top:13px;">


                @if (@ViewBag.BusinessType == "Scaffold")
                {
                    <div class="form-group col-md-2 col-sm-4 col-xs-12">
                        @Html.Label("Type *", null, new { @class = "control-label temp2" })
                        @Html.EnumDropDownListFor(model => model.SaleType, new { @class = "form-control", @onchange = "HType();", @required = "required", data_msg_required = "The Sale type field is required" })
                    </div>
                }
                <div class="col-md-1 col-sm-4 col-xs-12 form-group ">
                    @Html.Label("Quot No *", null, new { @class = "control-label temp2" })
                    <div class="input-group input-group-sm">
                        @Html.EditorFor(model => model.BillNo, new { htmlAttributes = new { @class = "form-control", @required = "required" } })
                        @Html.HiddenFor(model => model.QuotNo)
                    </div>
                </div>

                <div class="col-md-1 col-sm-4 col-xs-12 form-group hide1">
