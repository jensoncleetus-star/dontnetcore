    <script type="text/javascript">

        function nodays() {


            var date1 = $("#QuotDate").val();
            var dateParts = date1.split("-");
            var dateObject1 = new Date(+dateParts[2], dateParts[1] - 1, +dateParts[0]);
            var date2 = $("#quotationexpdate").val();
            var dateParts2 = date2.split("-");
            var dateObject2 = new Date(+dateParts2[2], dateParts2[1] - 1, +dateParts2[0]);
            //var Difference_In_Time = dateParts2.getTime() - dateObject1.getTime();


            // var Difference_In_Days = Difference_In_Time / (1000 * 3600 * 24);
            const diffTime = Math.abs(dateObject2 - dateObject1);
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
            $("#QuotValidity").val(diffDays);

        }

