@@model QuickSoft.Models.Quotation
@{
    ViewBag.Title = "Download Quotations";
}
<section class="content">
    <div class="AlertDiv">
    </div>
    <div class="box box-default">
        <div class="box-header with-border">
            <h3 class="box-title">Download Quotations</h3>
        </div>
        <div class="box-body">
            @using (Html.BeginForm("Download", "Quotation", FormMethod.Post, new { id = "popupForm" }))
            {
                @Html.AntiForgeryToken()
                <div class="form-actions no-color">
                    <input type="submit" value="Download" class="btn btn-danger col-sm-offset-4" />
                    <input type="button" class="btn btn-default" onclick="@("window.location.href='" + @Url.Action("Index", "Quotation") + "'");" value="Cancel" data-dismiss="modal">
                </div>
            }
        </div>
    </div>
</section>
