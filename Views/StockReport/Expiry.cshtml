@{
    ViewBag.Title = "Search Stock With Expiry";
    ViewBag.SubTitle = "Stock Report";
    ViewBag.Active = "Reports";
}
<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">Stock With Expiry</h3>
    </div>
    <div class="box-body">
        @using (Html.BeginForm("Expiry", "StockReport", FormMethod.Post, new { id = "popupForm" }))
        {
            <div class="row">
                <div class="form-group col-md-4">
                    @Html.Label("Item", null, new { @class = "control-label col-md-4" })
                    @Html.DropDownList("ddlItem", (SelectList)ViewBag.Category, new { @class = "form-control input-sm" })
                </div>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-info col-sm-offset-5" id="btn">Search</button>
                <button type="button" class="btn btn-default" onclick="@("window.location.href='/Home/Index'");">Cancel</button>
            </div>
        }
    </div>
</div>
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
}
@section Scripts {
    @Scripts.Render("~/js/bootstrap-datepicker")
    <script type="text/javascript">
        $(document).ready(function () {
            ItemSearchable();
        });
    </script>
}