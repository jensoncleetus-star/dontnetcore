@model QuickSoft.ViewModel.AdditionalMCViewModel

<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Add Additional Material Centre</h4>
</div>

<div class="modal-body">
   @using (Html.BeginForm("Create", "AdditionalMC", FormMethod.Post, new { id = "createform" }))
    {
        <script type="text/javascript">
            $('form#createform').removeData("validator");
            $('form#createform').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#createform'));
        </script>

        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger AlertDiv" })

        <div class="row">
            <div class="form-group col-md-12">
                @Html.Label("Material Centre", null, new { @class = "control-label" })
                @Html.DropDownListFor(m => m.McId, (SelectList)ViewBag.MCbag, new { id = "ddlMcs", @class = "form-control input-sm select2" })
            </div>
            <div class="form-group col-md-12">
                @Html.Label("Employee", null, new { @class = "control-label col-md-12" })
                @Html.DropDownListFor(m => m.Employees, (SelectList)ViewBag.Employee, new { id = "ddlEmployee", @class = "form-control input-sm ", @name = "ddlEmployee[]", @multiple = true })
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" value="Save" class="btn btn-info col-sm-offset-4" />
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>
  <script>
      $("#ddlEmployee").select2({
          placeholder: 'Search Employees by Name',
          minimumInputLength: 0,
          ajax: {
              url: "/AdditionalMC/SearchEmployee",
              dataType: 'json',
              type: "POST",
              delay: 50,
              data: function (params) {
                  return {
                      q: params.term,
                      page: params.page,
                  };
              },
              processResults: function (data, params) {
                  params.page = params.page || 1;

                  return {
                      results: data
                  };
              },
              cache: true
          },
      });
  </script>



