@Html.AntiForgeryToken()
<script>
    // Security: mobile-app page has no main layout; attach the antiforgery token to its AJAX posts.
    (function () { var t = document.querySelector('input[name="__RequestVerificationToken"]');
        if (t && window.jQuery) { jQuery(document).ajaxSend(function (e, x, s) { if (!s.crossDomain) x.setRequestHeader('RequestVerificationToken', t.value); }); } })();
</script>