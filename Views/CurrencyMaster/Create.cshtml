
@model QuickSoft.ViewModel.CurrencyMasterViewModel
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Add Currency</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("Create", "CurrencyMaster", FormMethod.Post, new { id = "createform" }))
            {
        <script type="text/javascript">
            $('form#popupFormcreateform').removeData("validator");
            $('form#popupFormcreateform').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#popupFormcreateform'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        <div class="box-body">
            <div class="row">
                <div class="form-group col-sm-6">
                    @Html.LabelFor(m => m.CurrencyCode, new { @class = "control-label" }) *
                    @Html.TextBoxFor(m => m.CurrencyCode, new { @class = "form-control input-sm", autofocus = "autofocus", @required = "required" })
                </div>
                <div class="form-group col-sm-6">
                    @Html.LabelFor(m => m.Description, new { @class = "control-label" })
                    @Html.TextBoxFor(m => m.Description, new { @class = "form-control input-sm"})
                </div>
                <div class="form-group col-sm-6">
                    @Html.Label("Convertion Rate", null, new { @class = "control-label" }) *
                    @Html.TextBoxFor(m => m.ConvertionRate, new { @class = "form-control input-sm", @required = "required", Value = 1 })
                </div>
                <div class="form-group col-sm-6">
                    @Html.LabelFor(m => m.Fraction, new { @class = "control-label" })*
                    @Html.TextBoxFor(m => m.Fraction, new { @class = "form-control input-sm" })
                </div>
                <div class="form-group col-sm-6">
                    @Html.Label("Minimum Con Rate", null, new { @class = "control-label" }) 
                    @Html.TextBoxFor(m => m.MinConvertionRate, new { @class = "form-control input-sm" })
                </div>

                <div class="form-group col-sm-6">
                    @Html.Label("Maximum Con Rate", null, new { @class = "control-label" })
                    @Html.TextBoxFor(m => m.MaxConvertionRate, new { @class = "form-control input-sm" })
                </div>                
                @if (@ViewBag.BranchCheck == 0)
                {
                    <div class="form-group col-sm-6">
                        @Html.Label("Branch", null, new { @class = "control-label" })
                        @Html.DropDownListFor(m => m.Branch, (SelectList)ViewBag.SetBranch, new { id = "ddlBranch", @class = "form-control select2" })
                    </div>
                }
                <div class="form-group col-sm-6">
                    @Html.LabelFor(m => m.Symbol, new { @class = "control-label" }) 
                    @Html.TextBoxFor(m => m.Symbol, new { @class = "form-control input-sm" })
                </div>
            </div>
        </div>        
            <div class="row">
                <div class="col-md-12">
                    <div class="box-footer">
                        <input type="submit" value="Save" class="btn btn-info col-sm-offset-4" />
                        <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                    </div>
                </div>
            </div>
    }
</div>
@section scripts{
    @Scripts.Render("~/js/jqueryval")
}
