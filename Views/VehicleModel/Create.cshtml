
@model QuickSoft.Models.VehicleModel

<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Create Model</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("Create", "VehicleModel", FormMethod.Post, new { id = "createform" }))
    {
        <script type="text/javascript">
            $('form#createform').removeData("validator");
            $('form#createform').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#createform'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        
        <div class="row">
            <div class="col-md-12">
                <div class="form-group">
                    @Html.Label("Vehicle Type", null, htmlAttributes: new { @class = "control-label" }) *
                    @Html.DropDownList("VTId", (SelectList)ViewBag.VehicleType, "", new { id = "ddlVehicleType", @class = "form-control select2" })
               </div>
            </div>
            <div class="col-md-12">
                <div class="form-group">
                    @Html.Label("Vehicle Manufacturer", null, htmlAttributes: new { @class = "control-label" }) *
                    @Html.DropDownList("MaId", (SelectList)ViewBag.VehicleManufacturer, "", new { id = "ddlVehicleManufacturer", @class = "form-control select2", @placeholder = "Select the Manufacturer"  })
                </div>
            </div>
            <div class="col-md-12">
                <div class="form-group">
                    @Html.LabelFor(model => model.Model, htmlAttributes: new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.Model, new { htmlAttributes = new { @class = "form-control", autofocus = "autofocus", @placeholder = "Enter Vehicle Model", @required = "required" } })
                </div>
            </div>
           
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" value="Save" class="btn btn-info col-sm-offset-4" />
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>
@section scripts{
    @Scripts.Render("~/js/jqueryval")
}
<script>
    $('body').on('change', '#ddlVehicleType', function (e) {

        //Clearing Current value of Manufacturer Dropdown
        $("#ddlVManufacturer").val("0");

        var VehicleTypeID = $(this).val();

        //Calling function
        SortManufacturer(VehicleTypeID);

    });

    

    $("#ddlVehicleType").select2({
        placeholder: 'Select Vehicle Type',
        minimumInputLength: 0,
        ajax: {
            url: "/VehicleModel/SearchVehicleType",
            dataType: 'json',
            delay: 50,
            data: function (params) {
                return {
                    q: params.term,
                    page: params.page,
                    x: " Select Vehicle Type"
                };
            },
            processResults: function (data, params) {
                params.page = params.page || 1;
                return {
                    results: data
                };
            },
            cache: true
        },
    });
    function SortManufacturer(VehicleTypeID) {

        $("#ddlVehicleManufacturer").select2({
            placeholder: 'Select Manufacturer',
            minimumInputLength: 0,
            ajax: {
                url: "/VehicleModel/SearchManufacturer",
                dataType: 'json',
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term,
                        page: params.page,
                        VTid: VehicleTypeID,
                        x: " Select Manufacturer"
                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 1;
                    return {
                        results: data
                    };
                },
                cache: true
            },
        });
    }
</script>

