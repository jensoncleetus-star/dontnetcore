                            "name": "ApprovalStatus", "data": function (data) {
                                var datas = "";
                                if (data.ApprovalStatus == "Approved") {
                                    datas += '<span class="badge bg-green">Approved</span>';
                                }
                                if (data.ApprovalStatus == "Rejected") {
                                    datas += '<span class="badge bg-red">Rejected</span>';
                                }
                                return datas;
                            }
                        },
