@{
    ViewBag.Title = "List";
    ViewBag.SubTitle = "PackingList";
    ViewBag.Active = "Transactions";
    string actData = "";
    string delchk = "";
    bool userRole = false;
    string deleteBTn = "";

    if (User.IsInRole("Dev") || User.IsInRole("Delete PackingList"))
    {
        userRole = true;
        deleteBTn = "{text: 'Delete', className: 'btn-danger', action: function(e, dt, node, config) {" +
              "if ($('.checkbox:checked').length > 0) {if (confirm('Are you sure you want to delete this?')) {$('#delallform').submit(); e.preventDefault();} " +
               "} else {alert('Please Select Rows..!!');e.preventDefault();}}},";
    }
}
<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">List PackingList</h3>
        <div class="pull-right">
            @if (User.IsInRole("Dev") || User.IsInRole("PackingList Create"))
            {
                <i class="ace-icon fa fa-hand-o-right icon-animated-hand-pointer blue"></i>
                <a class="btn btn-info no-border" href="/PackingList/Create">
                    <i class="glyphicon glyphicon-plus"></i> Create
                </a>
            }
        </div>
    </div>
    <div class="box-body search-box">
        <a class="btn btn-primary" id="srch">
            <i class="glyphicon glyphicon-search"></i> Advanced Search
        </a>

        <div class="search-body col-md-12" id="advsearch">
            <form id="search-form">
                <div class="row">
                    <input type="hidden" id="remId" />
                    <div class="form-group col-md-2">
                        @Html.Label("Invoice No", null, new { @class = "control-label" })
                        @Html.TextBox("InvoiceNo", "", new { @class = "form-control input-sm" })
                    </div>
                    <div class="form-group col-md-2">
                        @Html.Label("From Date", null, new { @class = "control-label" })
                        <div class="input-group date">
                            @Html.TextBox("FromDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                            <div class="input-group-addon">
                                <i class="fa fa-calendar"></i>
                            </div>
                        </div>
                    </div>

                    <div class="form-group col-md-2">
                        @Html.Label("To Date", null, new { @class = "control-label" })
                        <div class="input-group date">
                            @Html.TextBox("ToDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                            <div class="input-group-addon">
                                <i class="fa fa-calendar"></i>
                            </div>
                        </div>
                    </div>
                    <div class="form-group col-md-2">
                        @Html.Label("LPO NO", null, new { @class = "control-label" })
                        @Html.TextBox("LPO", "", new { @class = "form-control input-sm" })
                        
                    </div>
                    <div class="form-group col-md-2" id="creditsale">
                        @Html.Label("Customer", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlCustomer", (SelectList)ViewBag.Customer, new { @class = "form-control input-sm select2" })
                    </div>
                    <div class="form-group col-md-2" id="crecreditsale">
                        @Html.Label("Created By", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlCreatedBy", (SelectList)ViewBag.CreatedBy, "All", new { @class = "form-control input-sm select2" })
                    </div>
                    @if (ViewBag.MLAPList == 0)
                    {
                        <div class="form-group col-md-2">
                            @Html.Label("Approval Status", null, new { @class = "control-label" })
                            @Html.DropDownList("ApprovalStatus", (SelectList)ViewBag.AppStat, "All", new { id = "ApprovalStatus", @class = "form-control" })
                        </div>
                    }
                </div>
                <div class="row">
                    <div class="col-md-12">
                        <input type="submit" class="btn btn-submit col-sm-offset-5" value="Submit" />
                        <input type="button" class="btn btn-close" value="Close" />
                    </div>
                </div>
            </form>
        </div>
    </div>
    @using (Html.BeginForm("DeleteAllPacklist", "PackingList", FormMethod.Post, new { id = "delallform", role = "form" }))
    {
        <div class="box-body">
            <table class="table table-bordered table-hover" id="MyTable">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="1">S/N</td>
                        <td data-priority="1">Invoice No</td>
                        <td data-priority="1">LPO</td>
                        <td data-priority="1">Customer</td>
                        <td data-priority="1">Date</td>
                        <td data-priority="2">CreatedBy</td>
                        @*<td data-priority="2">Status</td>*@
                        <td data-priority="3">Approval Status</td>
                        <td data-priority="1">Action</td>
                        <td data-priority="2"><input type="checkbox" id="select_all" /></td>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
        <input type="hidden" value="@ViewBag.StartDate" class="Start" name="Start" id="Start">
        <input type="hidden" value="@ViewBag.EndDate" class="End" name="End" id="End">
    }
    <div id="modal-container2" class="modal fade" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-aqua">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                    <h4>Status Updation History</h4>
                </div>
                <div class="modal-body">
                    <table class="table table-bordered table-hover" id="UserTableInfo">
                        <thead>
                            <tr class="bg-aqua">
                                <td>Status</td>
                                <td>Updated By</td>
                                <td>Requested By</td>
                                <td>Date</td>
                                <td>Remarks</td>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
@{var Modelv = "modal-lg";}
@Html.Partial("../Common/_ModalCreate", @Modelv)
@Html.Partial("../Reminder/Index")
@Html.Partial("../Common/_ModalDelete")
@Html.Partial("../Common/_ModalEdit")

@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/bootstrap-timepicker")
}
@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/bootstrap-timepicker")
    <script type="text/javascript">
        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });
        jQuery.validator.methods["date"] = function (value, element) { return true; }
        $(".timepicker").timepicker({
            showInputs: true,
            defaultTime: false,
            format: 'dd-mm-yyyy'
        });

        CallRepCustomer();
        CallRepEmployee();
        $(document).ready(function () {
            $('#advsearch').hide();
            $('#ddlPayFrom').select2();
        });
        CallRepCustomer();
        CallRepEmployee();
        var oTable = $('#MyTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "pageLength": 50,
            responsive: true,
            "bLengthChange": false,
            "ajax": {
                "url": '/PackingList/GetPackingList',
                "data": function (data) {
                    data.InvoiceNo = $('#InvoiceNo').val();
                    data.FromDate = $('#FromDate').val();
                    data.ToDate = $('#ToDate').val();
                    data.Customer = $('#ddlCustomer').val();
                    data.user = $('#ddlCreatedBy').val();
                    data.LPO = $('#LPO').val();
                    data.appstat = $('#ApprovalStatus').val();
                },
                "type": "POST",
                "datatype": "json"
            },
            "order": [[0, "desc"]],
            "columnDefs": [{
                "targets": [6, 7],
                "orderable": false
            }],
            "columns": [
                     {
                         "data": "PackinglistId", "name": "PackinglistId",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                { "data": "Invoice", "name": "Invoice" },
                { "data": "LPO", "name": "LPO" },
                { "data": "Customer", "name": "Customer" },
                { "data": "Date", "name": "Date", "render": function (data) { return convertToDate(data); } },
                { "data": "CreatedBy", "name": "CreatedBy" },
                //{ "data": "Status", "name": "Status" },
                 {
                     "name": "ApprovalStatus", "data": function (data, type, dataToSet) {
                         var status = "";
                         var cls = "";
                         if (data.app.length > 0 || (data.Approval == true && '@ViewBag.MLAPList' == 'active')) {
                             if (data.ApprovalStatus == "0") {
                                 status = '<span class="badge bg-green">Approved</span>';
                             }
                             else if (data.ApprovalStatus == "1") {
                                 status = '<span class="badge bg-red">Rejected</span>';
                             }
                             else if (data.ApprovalStatus == "2") {
                                 status = '<span class="badge bg-orange">Pending</span>';
                             }
                             return '<a  class="Updation" onclick="details(' + data.PackinglistId + ')"  title="View Status">' + status + ' </a>';
                         } else { return null; }
                     }
                 },
                {
                    "name": "PaymentId", "data": function (data) {

                        var rest = "";
                        @{

                            actData += "<a class=\"details\" href=\"/PackingList/Details/'+ data.PackinglistId +'\" title=\"View PackingList\"><i class=\"fa fa-lg fa-search-plus\"></i></a> ";

                            if (User.IsInRole("Dev") || User.IsInRole("Edit PackingList"))
                            {
                                actData += "<a href=\"/PackingList/Edit/'+ data.PackinglistId  +'\" title=\"Edit Packinglist\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";

                            }
                            if (User.IsInRole("Dev") || User.IsInRole("Delete PackingList"))
                            {
                                actData += "<a class=\"modal-delete\" href=\"/Packinglist/Delete/'+ data.PackinglistId +'\" title=\"Delete Packinglist\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";
                            }
                            }

                        rest += '@Html.Raw(actData)';

                        if (data.Approval == true && '@ViewBag.MLAPList' == 'active') {
                            @{
                                actData = "";
                                actData = "<a class=\"modal-edit\"  href=\"/PackingList/EditStatus/'+ data.PackinglistId  +'\" title=\"Edit Status\"><i class=\"fa fa-lg fa-refresh\" ></i></a> ";

                            }
                            rest += '@Html.Raw(actData)';
                        }
                        if ("@ViewBag.Remind" == "active") {
                            @{
                                actData = "";
                                actData += "<a class=\"UpdationRe\" onclick=\"detailsRemind(' + data.PackinglistId + ')\" title=\"View Reminder\"><i class=\"fa-lg fa fa-bell\" ></i></a> ";
                                actData += "<a class=\"modal-create\" href=\"/Reminder/AddReminder/'+ data.PackinglistId +'/PKList\" title=\"Add Reminder\"><i class=\"fa-lg fa fa-sticky-note\" ></i></a> ";
                            }
                            rest += '@Html.Raw(actData)';
                        }

                        return rest;
                    }
                },
                {
                    "name": "PackinglistId", "data": function (data) {
                        var rest = "";
                        @{
                             if (User.IsInRole("Dev") || User.IsInRole("Delete PackingList"))
                            {
                                delchk = "<input class=\"checkbox\" type=\"checkbox\" name=\"bill[]\" value='+ data.PackinglistId +'></input>";
                            }
                        }
                        return rest = '@Html.Raw(delchk)';
                    }
                },
            ],
            buttons: [
                'colvis',
                {
                    extend: 'print',//
                    title: "",
                    footer: true,
                    filename: function () {
                        return 'PackingList';
                    },
                    columnDefs: [
                        { width: 400, targets: 2 }
                    ],
                    exportOptions: {
                        columns: ':visible'
                    },
                    message: function () {
                        var head = '<table class="tblcompact table table-bordered"><thead>' +
                        ' <tr><th class="text-center"><h3 style="margin-top: 0px;"><h4>PackingList</h4></th></tr>';
                        return head;
                    },
                    customize: function (win) {
                        // $(win.document.body)
                        //.css('font-size', '10pt')
                        //.css('padding', '1px');
                        $(win.document.body).find('table.tblcompact tbody td').css('padding', '0px');
                        $(win.document.body).find('.dataTable,.dataTable th,.dataTable tr,table.tblcompact tbody td .dataTable td')
                            .css('font-size', '10pt')
                            .css('padding', '5px')
                            .addClass('compact');
                        $(win.document.body).find('.dataTable tr th:nth-child(3)')
                            .css('min-width', '80px');
                        //$(win.document.body).find('.tblcompact tbody td:nth- child(2)')
                        //    .css('padding', '0px');
                        $(win.document.body).append('</td></tr></tbody>')

                    }
                }, 'copy', 'csv', //'excel',
                {
                    extend: 'pdf',//
                    title: "",
                    footer: true,
                    filename: function () {
                        return 'PackingList';
                    },
                    message: function () {
                        var head = 'PackingList';
                        return head;
                    },
                    pageSize: 'A4',
                    exportOptions: {
                        columns: ':visible'
                    },
                    customize: function (doc) {
                        doc.pageMargins = [10, 10, 10, 10];
                        doc.defaultStyle.fontSize = 10;
                        doc.styles.tableHeader.fontSize = 10;
                        doc.styles.title.fontSize = 12;
                        // Header font and bg color
                        doc.styles.tableHeader.fillColor = '#d3d3d3';
                        doc.styles.tableHeader.color = 'black';
                        // Remove spaces around page title
                        doc.content[0].text = doc.content[0].text.trim();


                        doc.styles['td:nth-child(2)'] = {
                            width: '100%',
                            'max-width': '100%'
                        }

                        var objLayout = {};
                        // Horizontal line thickness
                        objLayout['hLineWidth'] = function (i) { return .5; };
                        // Vertikal line thickness
                        objLayout['vLineWidth'] = function (i) { return .5; };
                        //// Horizontal line color
                        //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                        //// Vertical line color
                        //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                        // Left padding of the cell
                        objLayout['paddingLeft'] = function (i) { return 4; };
                        // Right padding of the cell
                        objLayout['paddingRight'] = function (i) { return 4; };
                        // Inject the object in the document
                        doc.content[1].layout = objLayout;
                        // Footer font and bg color
                        doc.styles.tableFooter.fillColor = '#d3d3d3';
                        doc.styles.tableFooter.color = 'black';

                    }
                },  @Html.Raw(deleteBTn)

            ],
            sDom: "lBfr<'datatable-scroll't>ip",
            "drawCallback": function (settings) {
                //var table = $('#MyTable').DataTable();
                //if (!table.data().any()) {
                //    $("#sub").hide();
                //} else {
                //    $("#sub").show();
                //}
            }
        });
        var chkcol = '@userRole';
        if (chkcol == "True") {
            var column1 = oTable.column(8);
            column1.visible(true);
        } else {
            var column1 = oTable.column(8);
            column1.visible(false);
        }
        var statcol = '@ViewBag.MLAPList';
        if (statcol == "active") {
            var column1 = oTable.column(6);
            column1.visible(true);
        } else {
            var column1 = oTable.column(6);
            column1.visible(false);
        }

        function reload_table() {
            oTable.clear().draw();
            oTable.ajax.reload(null, false); //reload datatable ajax
            isTicked();
        }
        //select all checkboxes
        $('body').on('change', '#select_all', function () {
            $(".checkbox").prop('checked', $(this).prop("checked")); //change all ".checkbox" checked status
        });

        //".checkbox" change
        $('body').on('change', '.checkbox', function () {
            //uncheck "select all", if one of the listed checkbox item is unchecked
            if (false == $(this).prop("checked")) { //if this item is unchecked
                $("#select_all").prop('checked', false); //change "select all" checked status to false
            }
            isTicked();
        });
        isTicked();


        /* function for view detail popup */
        $('#MyTable').on('click', 'a.details', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        })


        $('div').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
            //datepickerInit();
        });
        $('#modal-create').on('submit', '#createform', function (e) {
            e.preventDefault();
            var url = $('#createform')[0].action;
            var data = $('#createform').serialize();
            createajax(url, data, '#modal-create');
        });
        /* function for Edit popup */

        $('div').on('click', '.modal-edit', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-edit');
        });
        $('#modal-edit').on('submit', '#editform', function (e) {
            e.preventDefault();
            var url = $('#editform')[0].action;
            var data = $('#editform').serialize();
            createajax(url, data, '#modal-edit');
            detailsRemind($("#remId").val());
        });

        /* function for delete popup */
        $('div').on('click', '.modal-delete', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-delete');
        });
        $('#modal-delete').on('submit', '#deleteform', function (e) {
            e.preventDefault();
            var url = $('#deleteform')[0].action;
            var data = $('#deleteform').serialize();
            createajax(url, data, '#modal-delete');
            detailsRemind($("#remId").val());
        });

        $('#srch, .search-box .btn-close').on('click', function (e) {
            $('#advsearch').toggle();
            if ($('#srch').hasClass('btn-primary')) {

                $('#srch').addClass('btn-danger');
                $('#srch').removeClass('btn-primary');
            }
            else if ($('#srch').hasClass('btn-danger')) {
                $('#srch').addClass('btn-primary');
                $('#srch').removeClass('btn-danger');

                $('#InvoiceNo').val("");
                $('#FromDate').val("");
                $('#ToDate').val("");
                $('#ddlCustomer').val(0);
                $('#LPO').val("");
                $('#ddlCreatedBy').val(0);
                oTable.draw();
            }

            var minDate = $("#Start").val();
            var maxDate = $("#End").val();
            $('#FromDate').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true,
                startDate: new Date(minDate),
                endDate: new Date(maxDate)
            });
            $('#ToDate').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true,
                startDate: new Date(minDate),
                endDate: new Date(maxDate)
            });

            var date = new Date();
            var today = new Date(date.getFullYear(), date.getMonth(), date.getDate());
            var priordate = new Date(new Date().setDate(today.getDate() - 30));
            //$('#ToDate').datepicker('setDate', today);
            //$('#FromDate').datepicker('setDate', priordate);



        });

        $('#search-form').on('submit', function (e) {
            e.preventDefault();
            oTable.draw();
        });

        $('.table').on('click', 'a.Updation', function (e) {
            e.preventDefault();
            $(this).attr('data-target', '#modal-container2');
            $(this).attr('data-toggle', 'modal');
        });
        $('.table').on('click', '.modal-close-btn', function () {
            $('#modal-container2').modal('hide');
            $('#modal-container2').removeData('bs.modal');
        });
        $('#modal-container2').on('hidden.bs.modal', function () {
            $(this).removeData('bs.modal');
        });


