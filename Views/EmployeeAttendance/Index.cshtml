      var oTable = $('#DocumentList').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "paging": true,
            "ordering": false,
           // "pagelength": 50,
            "lengthMenu": [[50, 100, 100000], [50, 100, "All"]],
            responsive: true,
            "ajax": {
                "url": '/EmployeeAttendance/GetAttendance',
                "data": function (data) {
                    data.logout = $('#ExpDate').val();
                    data.login = $('#CreDate').val();
                    data.user = $('#ddlCreatedBy').val();
                    data.task = $('#ddlTask').val();
                    data.loggedIn = $('input[id="chkLoggedIn"]').prop('checked');
                   
                },
                "type": "POST",
                "datatype": "json"
            },
             "order": [[0, "desc"]],
            "columnDefs": [{ orderable: false, targets: -1 }],
            "columns": [
                     {
                    "data": "empattdetailsid", "name": "empattdetailsid",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                { "data": "user", "name": "user" },
                { "data": "taskname", "name": "taskname" },

                {
                    "data": "starttime", "name": "starttime",
                    "render": function (data) {
                        if (data == null) {
                            return "Date Not Available";
                        }
                        else {
                            return convertDateTimeYMD(data);
                        }
                    }
                },
                {
                    "data": "logout", "name": "logout",
                    "render": function (data) {
                        if (data == null) {
                            return "Currently logged in";
                        }
                        else {
                            return convertDateTimeYMD(data);
                        }
                    }
                },
                {
                    "name": "login duration", "data": function (data) {
                        if (data.logout == null) {
                            return '<i class="badge bg-green" style="font-size: small" >logged in</i>';
                        }
                        else {
                            var logdate = convertDateTimeYMD(data.starttime);
                            var Expdate = convertDateTimeYMD(data.logout);
                            /*Expdate = Date.parse(Expdate);*/

                        /*today = Date.parse(today);*/

                            var convertedlogdate = Date.parse(logdate);
                            var convertedexpdate = Date.parse(Expdate);

                            //---TAKING TO TWO VARIABLES AS NEW DATE OBJECT
                            dt1 = new Date(convertedlogdate);
                            dt2 = new Date(convertedexpdate);

                            function diff_minutes(dt2, dt1) {
                                if (dt1 > dt2) {
                                    return (0);
                                } else {
                                  var diff = (dt2.getTime() - dt1.getTime()) / 1000;
                                   diff /= 60;
                                    return Math.abs(Math.round(diff));
                                };
                            }
                            //---Taking Return minutes to var differranceinminutes-------
                            var differranceinminutes = (diff_minutes(dt2, dt1));

                            //--take that minutes and use display function below to convert it into hours and minutes
                            function display(a) {
                                var hours = Math.trunc(a / 60);
                                var minutes = a % 60;
                                return (hours +" Hours "+ " : " + minutes +" Minutes ");
                            }
                            return (display(differranceinminutes));
                        }
                    }
                },


                {
                    "name": "startl", "data": function (result) {

                                 @{
                    var urls2 = "";

                    urls2 = "'<a href=\"'+  result.startl +'\" target=\"_new\">'+ result.startl +'</a>' ";
                               }
                            return @Html.Raw(urls2);
                            }
                        },
                {
                    "name": "endl", "data": function (result) {

                                 @{
                    var urls = "";

                    urls = "'<a href=\"'+  result.endl +'\" target=\"_new\">'+ result.endl +'</a>' ";
                               }
                            return @Html.Raw(urls);
                            }
                },
                 {
                     "name": "empattdetailsid", "data": function (data) {
                            var rest = "";
                            @{
//if (User.IsInRole("Dev") || User.IsInRole("Edit FileDocument"))
//{
//    actData += "<a class=\"modal-edit\" href=\"/EmployeeAttendance/Edit/'+ data.empattdetailsid +'\" title=\"Edit Document Details\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
//}
//if (User.IsInRole("Dev") || User.IsInRole("Delete FileDocument"))
//{
//    actData += "<a class=\"modal-delete\" href=\"/EmployeeAttendance/Delete/'+ data.empattdetailsid +'\" title=\"Delete Document\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";
//}

                            }
                            return rest = '@Html.Raw(actData)';
                        }
                    },

           ],
        })

         //Button Close
        $('#srch, .search-box .btn-close').on('click', function (e) {
            //$('#advsearchlist').toggle();

            /*******  To uncheck all the checkboxes in the Select List  ************/
            var checkboxes = document.querySelectorAll("input[name='checks']");
            checkboxes.forEach(function (Checkbox) {
                Checkbox.checked = false;
            });

            if ($('#srch').hasClass('btn-primary')) {
                $('#srch').addClass('btn-danger');
                $('#srch').removeClass('btn-primary');
            }
            else {
                if ($('#srch').hasClass('btn-danger')) {
                    $('#srch').addClass('btn-primary');
                    $('#srch').removeClass('btn-danger');
                }
                /*******  To clear all the data entered  *********/
                //$('#ddlDoc').val(0);
                $('#ExpDate').val(null);
                $('#CreDate').val(null);
                $('#ddlCreatedBy').val(null);
                $('#ddlTask').val(null);
                $('#searchtask').hide();
                $('#searchcreatedby').hide();
                $('#searchcreateddate').hide();
                $('#searchexpirydate').hide();
                oTable.draw();
            }
        });

