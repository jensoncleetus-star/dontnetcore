                        lead: 1
                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 1;

                    return {
                        results: data
                    };
                },
                cache: true
            },
        });
        $("#ddlTask").select2({
            placeholder: 'Select task',
            minimumInputLength: 0,
            ajax: {
                url: "/EmployeeAttendance/TaskSearch",
                dataType: 'json',
                type: "POST",
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term,
