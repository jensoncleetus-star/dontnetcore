<style type="text/css">
    .date{
        height:34px!important;
        margin-bottom:0px;
    }
   
    .dropdown-check-list {
        display: inline-block;
    }

        .dropdown-check-list .anchor {
            position: relative;
            cursor: pointer;
            display: inline-block;
            padding: 5px 50px 5px 10px;
            border: 1px solid #ccc;
            width: 150px;
            background: #fff;
            text-align: center;
        }

            .dropdown-check-list .anchor:after {
                position: absolute;
                content: "";
                border-left: 2px solid black;
                border-top: 2px solid black;
                padding: 5px;
                right: 10px;
                top: 20%;
                -moz-transform: rotate(-135deg);
                -ms-transform: rotate(-135deg);
                -o-transform: rotate(-135deg);
                -webkit-transform: rotate(-135deg);
                transform: rotate(-135deg);
            }

            .dropdown-check-list .anchor:active:after {
                right: 8px;
                top: 21%;
            }

        .dropdown-check-list ul.items {
            padding: 0px;
            display: none;
            margin: 0;
            border: 1px solid #ccc;
            border-top: none;
            position: absolute;
            z-index: 9999;
        }

            .dropdown-check-list ul.items li {
                list-style: none;
                background: #fff;
                padding: 5px;
            }

    .add-btn-item {
        border-radius: 23px;
        padding: 6px 20px;
    }

    .dropdown-check-list.visible .anchor {
        color: #0094ff;
    }

    .dropdown-check-list.visible .items {
        display: block;
    }
</style>
<div class="box box-info ">
    @using (Html.BeginForm("Create", "EmployeeAttendance", FormMethod.Post, new { @class = "dropzone", id = "createform", role = "form", enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger AlertDiv" })
        <div class="box-header with-border">
            <h3 class="box-title">Daily Attendance</h3>

        </div>
        <br />
        <div class="pull-right">
            @*<a class="btn bg-aqua no-border" href="/Employeeattendance/Report">
                    <i class="fa fa-step-backward"></i>  Report
                </a>*@
            <a class="btn bg-blue no-border " href="/Employeeattendance/Create">
                <i class="glyphicon glyphicon-plus"></i> Attendance
            </a>
        </div>

        <div class="row">
            <div class="col-md-2">
                <div id="list1" class="dropdown-check-list" tabindex="100">
                    <span class="anchor" style="z-index:0;">Select Fields</span>
                    <ul class="items">
                        <li><input type="checkbox" name="checks" id="licreateddate" />From Date</li>
                        <li><input type="checkbox" name="checks" id="liexpirydate" />To Date</li>
                        <li><input type="checkbox" name="checks" id="licreatedby" />Employees</li>
                        <li><input type="checkbox" name="checks" id="litask" />Task</li>
                        <li><input type="checkbox" id="liLoggedIn" checked />Logged In</li>


                    </ul>
                </div>
            </div>
            <div class="col-md-12">
                <div class="box-body search-box" id="advsearchlist">
                    <div class="search-body col-md-12" style="background:none;">
                        <form id="search-form">
                            <div class="row">
                                <div class="form-group col-md-3" id="searchtask">
                                    @Html.Label("Task", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlTask", (SelectList)ViewBag.Task, "All", new { @class = "form-control input-sm select2" })
                                </div>
                                <div class="form-group col-md-3" id="searchcreatedby">
                                    @Html.Label("Employee Name", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlCreatedBy", (SelectList)ViewBag.CreatedBy, "All", new { @class = "form-control input-sm select2" })
                                </div>
                                <div class="form-group col-md-3" id="searchcreateddate">
                                    @Html.Label("From Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("CreDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group col-md-3" id="searchexpirydate">
                                    @Html.Label("To Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("ExpDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group col-md-2 col-xs-6" id="searchLoggedIn">
                                    @Html.Label(" ", null, new { @class = "control-label" })
                                    <label class="form-control input-sm"><input type="checkbox" value="true" name="checks" id="chkLoggedIn" />  Logged In</label>
                                </div>


                                <div class="form-group col-md-2" id="search">
                                    <input type="button" id="pullsearch" class="btn btn-submit" value="Submit" />
                                </div>
                                <div class="form-group col-md-2" id="close">
                                    <input type="button" id="tabledraw" class="btn btn-close" value="Close" />
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="box-body ">

            <table class="table table-bordered table-hover " id="DocumentList" style="margin:auto;">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="1">Id</td>
                        <td data-priority="1">User</td>
                        <td data-priority="1">Task</td>
                        <td data-priority="1">Start Time</td>
                        <td data-priority="1">Logout</td>
                        <td data-priority="1">Duration</td>
                        <td data-priority="1">Start Location</td>
                        <td data-priority="1">End Location</td>
                        <td data-priority="1">Action</td>


                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>



    }
</div>
