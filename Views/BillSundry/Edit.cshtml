<script>
    // Live "effect preview" + dynamic value suffix for the Bill Sundry form.
    // BSType: Additive=0 / Subtractive=1.  AmountType: AbsoluteAmount=0 / Percentage=1.
    // NOTE: the list page also has filter dropdowns with id BSType/AmountType, so we
    // scope every lookup to THIS form (#editform) and use classes, never bare #ids.
    (function () {
        var $form = $('#editform');
        // Collect everything that looks wrong. Nothing here BLOCKS saving — it only warns.
        function collect() {
            var typeTxt = ($form.find('.bs-type-sel option:selected').text() || '').trim();
            var amtTxt = ($form.find('.bs-amt-sel option:selected').text() || '').trim();
            var raw = parseFloat($form.find('.bs-def-inp').val());
            var hasVal = !isNaN(raw);
            var val = hasVal ? raw : 0;
            var isPct = /percent/i.test(amtTxt);
            var isSub = /subtract/i.test(typeTxt);
            var name = ($form.find('#BSName').val() || '').trim();
            var sacc = ($form.find('[name="SAccount"]').val() || '').trim();
            var pacc = ($form.find('[name="PAccount"]').val() || '').trim();
            var w = [];
            if (!name) w.push('Name is empty — give this Bill Sundry a clear name.');
            if (isPct && val > 100) w.push(val + '% is unusually high for a percentage — please confirm this is not a typo.');
            if (val < 0) w.push('A negative value is unusual — set the direction with the Type (Additive / Subtractive) instead of a minus sign.');
            if (isPct && val === 0) w.push('Percentage value is 0 — this Bill Sundry will have no effect until a value is entered.');
            if (sacc && pacc && sacc === pacc) w.push('Account in Sale and Account in Purchase are the same — confirm this is intended.');
            return { warns: w, isPct: isPct, isSub: isSub, val: val, hasVal: hasVal };
        }
        function render() {
            var c = collect();
            var verb = c.isSub ? 'Subtracts' : 'Adds';
            var prep = c.isSub ? 'from' : 'to';
            var amountStr = c.isPct ? (c.val + '% of the running subtotal')
                                    : (c.val.toFixed(2) + ' (flat amount)');
            $form.find('#bsPreview').toggleClass('is-sub', c.isSub);
            $form.find('#bsPreviewIco').html('<i class="fa fa-' + (c.isSub ? 'minus' : 'plus') + '"></i>');
            $form.find('#bsPreviewTxt').html(
                '<b>' + verb + ' ' + amountStr + ' ' + prep + ' the total</b>' +
                '<small>' + (c.isPct ? 'Recalculated on every quote/invoice from its subtotal.'
                                     : 'A fixed value applied to every quote/invoice.') + '</small>'
            );
            if (c.warns.length) {
                $form.find('#bsWarnTxt').html(c.warns.join('<br>'));
                $form.find('#bsWarn').addClass('show');
            } else {
                $form.find('#bsWarn').removeClass('show');
            }
        }
        window.changeAmtType = function () {
            var isPct = /percent/i.test(($form.find('.bs-amt-sel option:selected').text() || '').trim());
            $form.find('#bsSuffix').text(isPct ? '%' : 'Amt');
            render();
        };
        $form.find('.bs-type-sel, .bs-amt-sel, [name="SAccount"], [name="PAccount"]').on('change', render);
        $form.find('.bs-def-inp, #BSName').on('input change keyup', render);
        // Guard the save: if anything looks wrong, make the user confirm first.
        // This runs on the form element itself, so it fires before the modal's
        // delegated createajax handler; stopImmediatePropagation cancels the save.
        $form.on('submit', function (e) {
            var w = collect().warns;
            if (w.length && !window.confirm('Please double-check before saving:\n\n• ' + w.join('\n• ') + '\n\nSave anyway?')) {
                e.preventDefault();
                e.stopImmediatePropagation();
                return false;
            }
        });
        window.changeAmtType();
    })();
</script>
