@model QuickSoft.Models.BillSundry
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Create Bill Sundry</h4>
</div>
<style>
    /* ---- Beautified Bill Sundry form (scoped to .bs-form) ---- */
    .bs-form .control-label { font-weight: 600; font-size: 11.5px; color: #4b5563; text-transform: uppercase; letter-spacing: .03em; margin-bottom: 5px; }
    .bs-form .req { color: #dc2626; font-weight: 700; }
    .bs-form .form-group { margin-bottom: 16px; }
    .bs-form .form-control { border-radius: 8px; border: 1px solid #d7dbe0; box-shadow: none; transition: border-color .15s, box-shadow .15s; }
    .bs-form .form-control:focus { border-color: #059669; box-shadow: 0 0 0 3px rgba(5,150,105,.12); }
    .bs-form .input-group .form-control { border-top-right-radius: 0; border-bottom-right-radius: 0; }
    .bs-form .bs-suffix { background: #f3f4f6; border: 1px solid #d7dbe0; border-left: 0; color: #059669; font-weight: 700; min-width: 46px; text-align: center; }
    .bs-form .bs-section { font-size: 10.5px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: #9aa1ab; margin: 4px 0 10px; padding-bottom: 6px; border-bottom: 1px dashed #e5e7eb; }
    .bs-preview { display: flex; align-items: center; gap: 12px; margin: 4px 0 4px; padding: 12px 14px; border-radius: 10px; background: #f0fdf4; border: 1px solid #bbf7d0; }
    .bs-preview.is-sub { background: #fef2f2; border-color: #fecaca; }
    .bs-preview .bs-ico { width: 34px; height: 34px; flex: 0 0 34px; border-radius: 9px; display: flex; align-items: center; justify-content: center; font-size: 16px; color: #fff; background: #16a34a; }
    .bs-preview.is-sub .bs-ico { background: #dc2626; }
    .bs-preview .bs-txt { line-height: 1.35; }
    .bs-preview .bs-txt b { font-size: 14px; color: #111827; }
    .bs-preview .bs-txt small { display: block; color: #6b7280; font-size: 12px; }
    .bs-form .bs-footer { display: flex; gap: 10px; justify-content: flex-end; margin-top: 6px; padding-top: 14px; border-top: 1px solid #eef0f2; }
    .bs-form .bs-footer .btn { border-radius: 8px; padding: 8px 20px; font-weight: 600; }
    .bs-warn { display: none; align-items: flex-start; gap: 8px; margin: -8px 0 10px; padding: 9px 12px; border-radius: 8px; background: #fffbeb; border: 1px solid #fde68a; color: #92400e; font-size: 12.5px; line-height: 1.5; }
    .bs-warn.show { display: flex; }
    .bs-warn i { color: #d97706; margin-top: 2px; }
</style>
<div class="modal-body">
    @using (Html.BeginForm("Create", "BillSundry", FormMethod.Post, new { id = "createform" }))
            {
        <script type="text/javascript">
            $('form#createform').removeData("validator");
            $('form#createform').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#createform'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        <div class="bs-form">
        <div class="row">
            <div class="col-md-12">
                <div class="form-group  col-md-12">
                    @Html.Label("Name", null, new { @class = "control-label" }) <span class="req">*</span>
                    @Html.EditorFor(model => model.BSName, new { htmlAttributes = new { @class = "form-control input-sm", autofocus = "autofocus", @required = "required" } })
                </div>

                <div class="col-md-12"><div class="bs-section">How it applies</div></div>
                <div class="form-group col-md-6">
                    @Html.Label("Type", null, new { @class = "control-label" }) <span class="req">*</span>
                    @Html.EnumDropDownListFor(model => model.BSType, new { @class = "form-control bs-type-sel"})
                </div>
                @*<div class="form-group col-md-6">
                    @Html.Label("Bill Sundry Nature", null, new { @class = "control-label" }) *
                    @Html.DropDownListFor(m => m.BSNature, (SelectList)ViewBag.Nature,"", new { @class = "form-control input-sm" })
                </div>*@
                <div class="form-group col-md-6">
                    @Html.Label("Amount Type", null, new { @class = "control-label" }) <span class="req">*</span>
                    @Html.EnumDropDownListFor(model => model.AmountType, new { @class = "form-control bs-amt-sel"})
                 </div>
                <div class="form-group  col-md-6">
                    @Html.Label("Default Value", null, new { @class = "control-label" })
                    <div class="input-group input-group-sm">
                        @Html.EditorFor(model => model.DefaultValue, new { htmlAttributes = new { @class = "form-control input-sm bs-def-inp"} })
                        <span class="input-group-addon bs-suffix" id="bsSuffix">Amt</span>
                    </div>
                </div>
                <div class="form-group col-md-6">
                    @Html.Label("Status", null, new { @class = "control-label" }) <span class="req">*</span>
                    @Html.EnumDropDownListFor(model => model.Status, new { @class = "form-control" })
                </div>

                <div class="col-md-12">
                    <div class="bs-warn" id="bsWarn"><i class="fa fa-exclamation-triangle"></i> <span id="bsWarnTxt"></span></div>
                    <div class="bs-preview" id="bsPreview">
                        <div class="bs-ico" id="bsPreviewIco"><i class="fa fa-plus"></i></div>
                        <div class="bs-txt" id="bsPreviewTxt"><b>Adds to the total</b><small>Choose a type, amount type and value.</small></div>
                    </div>
                </div>

                <div class="col-md-12"><div class="bs-section">Accounting links</div></div>
                <div class="form-group col-md-6">
                    @Html.Label("Account In Sale", null, new { @class = "control-label" })
                    @Html.DropDownListFor(m => m.SAccount, (SelectList)ViewBag.SetAccount, new { @class = "form-control select2", @required = "required" })
                </div>
                <div class="form-group col-md-6">
                    @Html.Label("Account In Purchase ", null, new { @class = "control-label" })
                    @Html.DropDownListFor(m => m.PAccount, (SelectList)ViewBag.SetAccount, new { @class = "form-control select2", @required = "required" })
                </div>
                @if (@ViewBag.BranchCheck == 0)
                {
                    <div class="form-group col-md-6">
                        @Html.Label("Branch", null, new { @class = "control-label" })
                        @Html.DropDownListFor(m => m.Branch, (SelectList)ViewBag.SetBranch, new { id = "ddlBranch", @class = "form-control select2" })
                    </div>
                }

            </div>
        </div>
        <div class="bs-footer">
            <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
            <button type="submit" id="save" class="btn btn-success" tabindex="26">
                <span class="glyphicon glyphicon-floppy-disk"></span> Save
            </button>
        </div>
        </div>
    }
</div>
<script>
    $("#SAccount").select2({});
    $("#PAccount").select2({});
    // Live "effect preview" + dynamic value suffix for the Bill Sundry form.
    // BSType: Additive=0 / Subtractive=1.  AmountType: AbsoluteAmount=0 / Percentage=1.
    // Scope every lookup to THIS form (#createform) + classes — never bare #ids
    // (the list page has filter dropdowns that share id BSType/AmountType).
    (function () {
        var $form = $('#createform');
        // Collect everything that looks wrong. Nothing here BLOCKS saving — it only warns.
        function collect() {
            var typeTxt = ($form.find('.bs-type-sel option:selected').text() || '').trim();
            var amtTxt = ($form.find('.bs-amt-sel option:selected').text() || '').trim();
            var raw = parseFloat($form.find('.bs-def-inp').val());
            var hasVal = !isNaN(raw);
            var val = hasVal ? raw : 0;
            var isPct = /percent/i.test(amtTxt);
            var isSub = /subtract/i.test(typeTxt);
            var name = ($form.find('#BSName').val() || '').trim();
            var sacc = ($form.find('[name="SAccount"]').val() || '').trim();
            var pacc = ($form.find('[name="PAccount"]').val() || '').trim();
            var w = [];
            if (!name) w.push('Name is empty — give this Bill Sundry a clear name.');
            if (isPct && val > 100) w.push(val + '% is unusually high for a percentage — please confirm this is not a typo.');
            if (val < 0) w.push('A negative value is unusual — set the direction with the Type (Additive / Subtractive) instead of a minus sign.');
            if (isPct && val === 0) w.push('Percentage value is 0 — this Bill Sundry will have no effect until a value is entered.');
            if (sacc && pacc && sacc === pacc) w.push('Account in Sale and Account in Purchase are the same — confirm this is intended.');
            return { warns: w, isPct: isPct, isSub: isSub, val: val, hasVal: hasVal };
        }
        function render() {
            var c = collect();
            var verb = c.isSub ? 'Subtracts' : 'Adds';
            var prep = c.isSub ? 'from' : 'to';
            var amountStr = c.isPct ? (c.val + '% of the running subtotal')
                                    : (c.val.toFixed(2) + ' (flat amount)');
            $form.find('#bsPreview').toggleClass('is-sub', c.isSub);
            $form.find('#bsPreviewIco').html('<i class="fa fa-' + (c.isSub ? 'minus' : 'plus') + '"></i>');
            $form.find('#bsPreviewTxt').html(
                '<b>' + verb + ' ' + amountStr + ' ' + prep + ' the total</b>' +
                '<small>' + (c.isPct ? 'Recalculated on every quote/invoice from its subtotal.'
                                     : 'A fixed value applied to every quote/invoice.') + '</small>'
            );
            if (c.warns.length) {
                $form.find('#bsWarnTxt').html(c.warns.join('<br>'));
                $form.find('#bsWarn').addClass('show');
            } else {
                $form.find('#bsWarn').removeClass('show');
            }
        }
        window.changeAmtType = function () {
            var isPct = /percent/i.test(($form.find('.bs-amt-sel option:selected').text() || '').trim());
            $form.find('#bsSuffix').text(isPct ? '%' : 'Amt');
            render();
        };
        $form.find('.bs-type-sel, .bs-amt-sel, [name="SAccount"], [name="PAccount"]').on('change', render);
        $form.find('.bs-def-inp, #BSName').on('input change keyup', render);
        // Guard the save: if anything looks wrong, make the user confirm first.
        $form.on('submit', function (e) {
            var w = collect().warns;
            if (w.length && !window.confirm('Please double-check before saving:\n\n• ' + w.join('\n• ') + '\n\nSave anyway?')) {
                e.preventDefault();
                e.stopImmediatePropagation();
                return false;
            }
        });
        window.changeAmtType();
    })();
</script>
@section scripts{
    @Scripts.Render("~/js/jqueryval")
}
