                        $('#addinvoiceItempay').html('');
                        $.each(data, function (i, item) {
                            //var amt = item.Balance < item.Amount ? item.Balance : item.Amount;
                            addrowspay('addinvoiceItempay', 'edit', item.id, item.BillNo, item.Date, item.Balance, item.Amount, item.type, item.NewRefName, item.Type);
                        });
                        addrowspay('addinvoiceItempay', 'edit', '', '', '', '0.00', '0.00');
                        RowTotal();
                        cashBalance();
                        $('.radiopay').val(null).trigger('change');
                    }
                }
            });
        }
        var entry = getQueryString('');
        var payfrom1 = $("#ddlpayfrom1").val();
        var payfrom2 = $("#ddlpayfrom2").val();
        if (entry != null) {
            $.ajax({
                url: '/Receipt/GetJornalBill',
                dataType: 'json',
                data: { entry: entry,payfrom:payfrom1 },
                cache: true,
                success: function (data) {
                    if (data != "") {
                        bindinvoiceNew();
                        $('#addinvoiceItemref').html('');
                        $.each(data, function (i, item) {
                            //var amt = item.Balance < item.Amount ? item.Balance : item.Amount;
                            addrowsref('addinvoiceItemref', 'edit', item.id, item.BillNo, item.Date, item.Balance, item.Amount, item.type, item.NewRefName, item.Type);
                        });
                        addrowsref('addinvoiceItemref', 'edit', '', '', '', '0.00', '0.00');
                        RowTotal();
                        cashBalance();
                    }
                }
            });
        }
        if (entry != null) {
            $.ajax({
                url: '/Receipt/GetJornalBill',
                dataType: 'json',
                data: { entry: entry, payfrom: payfrom2 },
                cache: true,
                success: function (data) {
                    if (data != "") {
                        bindinvoiceNew2();
                        $('#addinvoiceItemref2').html('');
                        $.each(data, function (i, item) {
                            //var amt = item.Balance < item.Amount ? item.Balance : item.Amount;
                            addrowsref2('addinvoiceItemref2', 'edit', item.id, item.BillNo, item.Date, item.Balance, item.Amount, item.type, item.NewRefName, item.Type);
                        });
                        addrowsref2('addinvoiceItemref2', 'edit', '', '', '', '0.00', '0.00');
                        RowTotal();
                        cashBalance();
                    }
                }
            });
        }
        var accid = $('#ddlpayfrom1').val();
        if(accid!=0)
        chkacctype(accid);
    });

