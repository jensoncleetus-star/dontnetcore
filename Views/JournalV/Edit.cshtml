@using System.Web.Script.Serialization;
@model QuickSoft.ViewModel.JournalViewModel
@{
    ViewBag.Title = "Edit";
    ViewBag.SubTitle = "Journal";
    ViewBag.Active = "Transactions";
    JavaScriptSerializer jss = new JavaScriptSerializer();

    string output = jss.Serialize(Model.jnlitems);
    string check = "";
    string strImage = "";
    string partialconfig = "";
    //Response.Write(output);
    //Response.Flush();
    //Response.End();
}
@using (Html.BeginForm("Edit", "JournalV", FormMethod.Post, new { id = "recform", role = "form" }))
{
    <div class="box box-info">
        <div class="box-header with-border">
            <h3 class="box-title">Edit Journal Voucher</h3>
            <div class="pull-right">
                @if (@ViewBag.preEntry != 0)
                {
                    if (User.IsInRole("Dev") || User.IsInRole("Edit Journal"))
                    {
                        <a class="btn bg-black no-border" href="/JournalV/Edit/@ViewBag.preEntry">
                            <i class="fa fa-step-backward"></i>
                        </a>
                    }
                }
                @if (@ViewBag.nxtEntry != 0)
                {
                    if (User.IsInRole("Dev") || User.IsInRole("Edit Journal"))
                    {
                        <a class="btn bg-black no-border" href="/JournalV/Edit/@ViewBag.nxtEntry">
                            <i class="fa fa-step-forward"></i>
                        </a>
                    }
                }
                else
                {
                    if (User.IsInRole("Dev") || User.IsInRole("Create Journal"))
                    {
                        <a class="btn bg-black no-border" href="/JournalV/Create">
                            <i class="fa fa-step-forward"></i>
                        </a>
                    }
                }
                @if (User.IsInRole("Dev") || User.IsInRole("Journal List"))
                {
                    <a class="btn btn-success no-border" href="/JournalV">
                        <i class="fa fa-fw fa-history"></i> List
                    </a>
                }
            </div>
        </div>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        <div class="box-body">
            <div class="row">
                <input type="hidden" id="procheck" value="@ViewBag.ProjChk" />
                <input type="hidden" id="accjnlcheck" value="@ViewBag.AccJnl" />
                <input type="hidden" id="chkPdc" value='@ViewBag.chkPdc' />
                <input type="hidden" id="PdcDate" value='@Model.PDCDate' />
                <input type="hidden" id="VoucherType" value="Journal" />
                <input type="hidden" id="JournalId" value="@ViewBag.JournalID" />

                <div class="col-sm-2 form-group ">
                    @Html.LabelFor(model => model.VoucherNo, new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.VoucherNo, new { htmlAttributes = new { @class = "form-control", @required = "required", tabindex = 1 } })
                </div>
                <div class="col-sm-2 form-group">
                    @Html.LabelFor(model => model.Date, htmlAttributes: new { @class = "control-label" })*
                    <div class="input-group date">
                        <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                        @Html.TextBoxFor(m => m.Date, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @required = "required", tabindex = 2 })
                    </div>
                </div>
                <div class="form-group col-md-2">
                    @Html.LabelFor(model => model.VATNature, htmlAttributes: new { @class = "control-label " })
                    @Html.DropDownList("VATNature", new SelectList(new List<SelectListItem>
                        {
                            new SelectListItem() {Text = "Not Applicable", Value="0"},
                            new SelectListItem() {Text = "Registered Expense (B2B)", Value="1"},
                        }, "Value", "Text"), new { @class = "form-control input-sm", @name = "VATNature", tabindex = 3 })
                </div>
                <div class="col-sm-2 form-group">
                    @Html.LabelFor(model => model.MOPayment, new { @class = "control-label" }) *
                    @Html.EnumDropDownListFor(model => model.MOPayment, new { @id = "MoPay", @class = "form-control", @onchange = "modechange()", tabindex = 3 })
                </div>
                <div class="col-sm-2 form-group">
                    @Html.Label("PDC Date", null, htmlAttributes: new { @class = "control-label", @id = "PDC", })
                    @Html.Label("CDC Date", null, htmlAttributes: new { @class = "control-label", @id = "CDC", })*
                    <div class="input-group date">
                        <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                        @Html.TextBoxFor(m => m.PDCDate, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @required = "required", tabindex = 4 })
                    </div>
                </div>

                @if (User.IsInRole("Enable Invoice Expense Entry In Voucher"))
                {
                    <div class="col-sm-2 form-group ">
                        @Html.LabelFor(m => m.InvoiceNo, new { @class = "control-label" })


                        @Html.DropDownListFor(m => m.InvoiceNo, (SelectList)ViewBag.InvoiceNo, new { id = "ddlInvoiceNo", @class = "form-control select2", tabindex = 7 })

                    </div>
                }

                <div class="col-sm-2 form-group" id="checkno">
                    @Html.LabelFor(model => model.CheckNo, new { @class = "control-label" })
                    @Html.EditorFor(model => model.CheckNo, new { htmlAttributes = new { @class = "form-control", @required = "required", data_msg_required = "Check Number is Required", tabindex = 8 } })
                </div>
                <div class="form-group col-sm-2" id="bank">
                    @Html.LabelFor(model => model.Bank, new { @class = "control-label" })
                    @Html.EditorFor(model => model.Bank, new { htmlAttributes = new { @class = "form-control", tabindex = 9 } })
                </div>
                @if (@ViewBag.BranchCheck == 0)
                {
                    <div class="form-group col-sm-2">
                        @Html.Label("Branch", null, new { @class = "control-label" })
                        @Html.DropDownListFor(m => m.Branch, (SelectList)ViewBag.SetBranch, new { id = "ddlBranch", @class = "form-control select2" })
                    </div>
                }
                <div class="clearfix"></div>
            </div>
            <div class="row">
                @if (Model.FieldMap.Count > 0)
                {
                    for (int i = 0; i < Model.FieldMap.Count; i++)
                    {
                        var fmap = "";
                        if (Model.FieldMap[i].Field == "Ref1")
                        {
                            fmap = Model.Ref1;
                        }
                        if (Model.FieldMap[i].Field == "Ref2")
                        {
                            fmap = Model.Ref2;
                        }
                        if (Model.FieldMap[i].Field == "Ref3")
                        {
                            fmap = Model.Ref3;
                        }
                        if (Model.FieldMap[i].Field == "Ref4")
                        {
                            fmap = Model.Ref4;
                        }
                        if (Model.FieldMap[i].Field == "Ref5")
                        {
                            fmap = Model.Ref5;
                        }

                        <div class="form-group col-sm-2">
                            <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName</label>
                            <input class="form-control input-sm" id="@Model.FieldMap[i].Field" name="@Model.FieldMap[i].Field" type="text" value="@fmap">
                        </div>
                    }
                }
            </div>
            <div class="table-responsive">
                <table class="table table-bordered table-hover" id="normalinvoice">
                    <thead>
                        <tr>
                            <th class="text-center">S/N</th>
                            <th class="text-center">D/C</th>
                            <th class="text-center acc-lists">Account <i class="text-danger">*</i></th>
                            <th class="text-center">Debit</th>
                            <th class="text-center">Credit</th>
                            <th class="text-center">Narration</th>
                            @if (@ViewBag.ProjChk == 0)
                            {
                                <th class="text-center">Project</th>
                                <th class="text-center">Task</th>
                            }
                            <th class="text-center"></th>
                        </tr>
                    </thead>
                    <tbody id="addinvoiceItem"></tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3">
                                Total
                            </td>
                            <td class="text-right">
                                <label id="total_debit"></label>
                            </td>
                            <td class="text-right">
                                <label id="total_credit"></label>
                            </td>
                            <td></td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
            <div>
                <input type="radio" name="selpay" value="payfrom" id="radiopayfrom" class="radiopay" checked="checked" /> Pay from
                <input type="radio" name="selpay" value="payto" id="radiopayto" class="radiopay" /> Pay to

                <div class="col-sm-3 form-group" id="payfrom1">
                    @Html.LabelFor(m => m.PayFrom1, new { @class = "control-label" }) *
                    @Html.DropDownListFor(m => m.PayFrom1, (SelectList)ViewBag.Paidfrom1, new { id = "ddlpayfrom1", @class = "form-control select2", @required = "required", tabindex = 7 })
                    <div id="accbalance" class="form-group" style="display:none">
                        <label>Account Summary</label>
                        <div class="input-group input-group-sm">
                            <label class="text-danger" id="accdetails"></label>
                        </div>
                    </div>
                </div>



                <div class="table-responsive hight-250" id="invoice"><hr /></div>






                <div class="col-sm-3 form-group" id="payfrom2">
                    @Html.LabelFor(m => m.PayFrom2, new { @class = "control-label" }) *
                    @Html.DropDownListFor(m => m.PayFrom2, (SelectList)ViewBag.Paidfrom1, new { id = "ddlpayfrom2", @class = "form-control select2", tabindex = 7 })
                    <div id="accbalance" class="form-group" style="display:none">
                        <label>Account Summary</label>
                        <div class="input-group input-group-sm">
                            <label class="text-danger" id="accdetails2"></label>
                        </div>
                    </div>
                </div>
                <div class="table-responsive hight-250" id="invoice2"><hr /></div>


                <div class="col-sm-3 form-group payto" id="payto" style="display:none;">
                    @Html.LabelFor(m => m.PayTo, new { @class = "control-label" }) *
                    @Html.DropDownListFor(m => m.PayTo, (SelectList)ViewBag.PaidTo, new { id = "ddlpayto", @class = "form-control select2", tabindex = 7 })

                </div>
                <div class="table-responsive hight-250" id="invoice3" style="display:none;"><hr /></div>







                <div class="form-group col-md-6 col-md-offset-6 no-padding" style="display:none;">
                    @Html.LabelFor(model => model.GrandTotal, new { @class = "control-label" })
                    @Html.EditorFor(model => model.GrandTotal, new { htmlAttributes = new { @id = "GrandTotal", @class = "form-control text-right", @value = "0.00", @readonly = "readonly", tabindex = 10 } })
                </div>
                <div class="form-group col-md-6 col-md-offset-6 no-padding" style="display:none;">
                    @Html.LabelFor(model => model.Paying, new { @class = "control-label" })
                    @Html.EditorFor(model => model.Paying, new { htmlAttributes = new { @id = "Paying", @class = "form-control text-right", @value = "0.00", @min = "0.01", tabindex = 11 } })
                </div>
                <div class="row col-md-12">
                    @*----------------------For File Attachment----------------------------*@
                    <div class="form-group">
                        @Html.Label("Documents", null, new { @class = "control-label" })
                        <div class="file-loading">
                            <input id="input-24" name="input24[]" type="file" multiple>
                        </div>
                    </div>
                    @foreach (var arr in @ViewBag.Image)
                    {
                        check = "\"/uploads/JournalDocuments/" + arr.FileName + "\"";

                        strImage += check + ',';

                        partialconfig += "{ key:" + arr.DocumentID + " }" + ',';
                    }

                    @*-----------------------------------------------------------------*@
                    <div class="form-group">
                        @Html.TextAreaFor(model => model.Remark, new { @class = "form-control", @placeholder = "Remarks", tabindex = 9, rows = 6 })
                    </div>

                    <!--<div class="col-md-6">-->
                    @*<div class="form-group col-md-12 no-paddingleft">
                @Html.LabelFor(model => model.Paying, new { @class = "control-label" })
                @Html.EditorFor(model => model.Paying, new { htmlAttributes = new { @id = "Paying", @class = "form-control text-right", @value = "0.00", tabindex = 11 } })
            </div>*@
                    <!--</div>-->
                </div>
                <div class="form-group no-padding text-right">
                    <div class="checkbox-inline">
                        <input class="checkbox" data-val="true" id="hideheader" name="hideheader" type="checkbox" value="true">
                        <label class="control-label" for="hideheader">Hide Header In Print</label>
                    </div>
                </div>
                <div class="col-md-12">
                    <hr />
                    <div class="form-group pull-right">
                        <input type="hidden" value="" name="submittype" id="submittype" />
                        <button type="submit" id="save" class="btn btn-info" tabindex="13">
                            <span class="glyphicon glyphicon-floppy-disk"></span> Update
                        </button>
                        <button type="submit" id="print" class="btn btn-success" tabindex="14">
                            <span class="glyphicon glyphicon-print"></span> Update And Print
                        </button>
                        <button type="button" tabindex="15" class="btn btn-warning" onclick="window.location.href='/JournalV/Index'">Cancel</button>
                        <input type="hidden" value="@ViewBag.StartDate" class="Start" name="Start" id="Start">
                        <input type="hidden" value="@ViewBag.EndDate" class="End" name="End" id="End">
                    </div>
                </div>
            </div>
        </div>
    </div>
}
