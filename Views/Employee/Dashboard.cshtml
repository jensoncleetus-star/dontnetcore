@model QuickSoft.ViewModel.HomeViewModel
@{
    ViewBag.Title = "Human Resources";
    ViewBag.Active = "Dashboard";
}

<link rel="stylesheet" href="@Url.Content("~/Content/css/dashboard-futuristic.css")?v=20260630q" />
<script>
    (function () {
        try {
            document.body.classList.add('bosx-on');
            if (localStorage.getItem('bosxThemeV') !== '3') { localStorage.setItem('bosxTheme', 'light'); localStorage.setItem('bosxThemeV', '3'); }
            document.body.setAttribute('data-bostheme', localStorage.getItem('bosxTheme') || 'light');
            document.body.setAttribute('data-bosstyle', localStorage.getItem('bosxStyle') || 'aurora');
        } catch (e) { document.body.setAttribute('data-bostheme', 'light'); }
    })();
</script>

<div class="bosx-dash">
    <div class="bosx-hero">
        <div>
            <div class="bosx-hero-title">Human Resources</div>
            <div class="bosx-hero-sub"><i class="fa fa-calendar-o"></i> <span id="bosxRange">@ViewBag.lastdate &ndash; @ViewBag.today</span></div>
        </div>
        <div class="bosx-ctrls">
            <div class="bosx-seg" id="bosxPeriod" title="Period">
                <button type="button" data-p="today">Today</button>
                <button type="button" data-p="week">Week</button>
                <button type="button" data-p="month" class="on">Month</button>
                <button type="button" data-p="year">Year</button>
            </div>
            <div class="bosx-seg" id="bosxStyle" title="Style">
                <button type="button" data-s="aurora" class="on">Aurora</button>
                <button type="button" data-s="minimal">Minimal</button>
                <button type="button" data-s="vivid">Vivid</button>
            </div>
            <div class="bosx-seg" id="bosxTheme" title="Theme">
                <button type="button" data-t="light" class="on"><i class="fa fa-sun-o"></i></button>
                <button type="button" data-t="dark"><i class="fa fa-moon-o"></i></button>
            </div>
        </div>
    </div>

    <div class="bosx-kpis">
        <div class="bosx-kpi k2"><div class="bosx-kpi-ic"><i class="fa fa-user-plus"></i></div><div style="flex:1;min-width:0"><div class="bosx-kpi-l">New Joiners <span class="bosx-kpi-per">&middot; month</span></div><div class="bosx-kpi-v" id="bxV1">&mdash;</div><div class="bosx-kpi-d" id="bxD1"></div></div></div>
        <div class="bosx-kpi k3"><div class="bosx-kpi-ic"><i class="fa fa-id-badge"></i></div><div style="flex:1;min-width:0"><div class="bosx-kpi-l">New Records <span class="bosx-kpi-per">&middot; month</span></div><div class="bosx-kpi-v" id="bxV2">&mdash;</div><div class="bosx-kpi-d" id="bxD2"></div></div></div>
        <div class="bosx-kpi k1"><div class="bosx-kpi-ic"><i class="fa fa-users"></i></div><div style="flex:1;min-width:0"><div class="bosx-kpi-l">Headcount <span class="bosx-kpi-per">&middot; month</span></div><div class="bosx-kpi-v" id="bxV3">&mdash;</div><div class="bosx-kpi-d" id="bxD3"></div></div></div>
        <div class="bosx-kpi k4"><div class="bosx-kpi-ic"><i class="fa fa-check-circle-o"></i></div><div style="flex:1;min-width:0"><div class="bosx-kpi-l">Active <span class="bosx-kpi-per">&middot; month</span></div><div class="bosx-kpi-v" id="bxV4">&mdash;</div><div class="bosx-kpi-d" id="bxD4"></div></div></div>
        <div class="bosx-kpi k5"><div class="bosx-kpi-ic"><i class="fa fa-users"></i></div><div><div class="bosx-kpi-l">Total Employees</div><div class="bosx-kpi-v">@Html.DisplayFor(m => m.totCustomerCount)</div></div></div>
        <div class="bosx-kpi k6"><div class="bosx-kpi-ic"><i class="fa fa-user"></i></div><div><div class="bosx-kpi-l">Active Staff</div><div class="bosx-kpi-v">@Html.DisplayFor(m => m.totSupplierCount)</div></div></div>
    </div>

    <div class="bosx-quick">
        <a href="@Url.Action("Create", "Employee")" class="bosx-q"><span class="bosx-q-ic q1"><i class="fa fa-user-plus"></i></span><span class="bosx-q-t">New Employee</span></a>
        <a href="@Url.Action("Index", "Employee")" class="bosx-q"><span class="bosx-q-ic q5"><i class="fa fa-users"></i></span><span class="bosx-q-t">Employees</span></a>
        <a href="@Url.Action("create", "Employeeattendance")" class="bosx-q"><span class="bosx-q-ic q2"><i class="fa fa-calendar-check-o"></i></span><span class="bosx-q-t">Attendance</span></a>
        <a href="@Url.Action("Index", "Designation")" class="bosx-q"><span class="bosx-q-ic q3"><i class="fa fa-sitemap"></i></span><span class="bosx-q-t">Designations</span></a>
        <a href="@Url.Action("Index", "Department")" class="bosx-q"><span class="bosx-q-ic q6"><i class="fa fa-building-o"></i></span><span class="bosx-q-t">Departments</span></a>
        <a href="@Url.Action("Index", "Employee")" class="bosx-q"><span class="bosx-q-ic q4"><i class="fa fa-id-card-o"></i></span><span class="bosx-q-t">Directory</span></a>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="box box-info"><div class="box-header with-border"><h3 class="box-title">Hiring trend &middot; 12 months</h3></div>
                <div class="box-body"><div class="bx-chart bx-chart-lg"><canvas id="bxArea"></canvas></div></div></div>
        </div>
        <div class="col-md-4">
            <div class="box box-primary"><div class="box-header with-border"><h3 class="box-title">Joiners vs Records</h3></div>
                <div class="box-body"><div class="bx-chart bx-chart-lg"><canvas id="bxDonut"></canvas></div></div></div>
        </div>
    </div>
    <div class="row">
        <div class="col-md-8">
            <div class="box box-info"><div class="box-header with-border"><h3 class="box-title">Monthly joiners</h3></div>
                <div class="box-body"><div class="bx-chart bx-chart-md"><canvas id="bxBar"></canvas></div></div></div>
        </div>
        <div class="col-md-4">
            <div class="box box-warning"><div class="box-header with-border"><h3 class="box-title">Targets</h3></div>
                <div class="box-body" style="display:flex;justify-content:space-around;align-items:center;min-height:170px">
                    <div style="text-align:center"><div style="position:relative;width:118px;height:118px"><canvas id="bxG1"></canvas><div style="position:absolute;inset:0;display:grid;place-items:center;font-weight:600;color:#0ea5e9">88%</div></div><div style="font-size:12px;opacity:.7;margin-top:4px">Attendance</div></div>
                    <div style="text-align:center"><div style="position:relative;width:118px;height:118px"><canvas id="bxG2"></canvas><div style="position:absolute;inset:0;display:grid;place-items:center;font-weight:600;color:#10b981">71%</div></div><div style="font-size:12px;opacity:.7;margin-top:4px">Retention</div></div>
                </div></div>
        </div>
    </div>
</div>

<script src="@Url.Content("~/Content/plugins/chartjs4/chart.umd.min.js")"></script>
<script>
    (function () {
        var BXChart = window.Chart; if (!BXChart) return;
        var tl = @Html.Raw(ViewBag.trendLabels ?? "[]"), ts = @Html.Raw(ViewBag.trendSales ?? "[]"), tp = @Html.Raw(ViewBag.trendPurchase ?? "[]");
        var grid = 'rgba(127,140,170,.14)';
        function draw() {
            var ae = document.getElementById('bxArea');
            if (ae && tl.length) {
                var cx = ae.getContext('2d');
                var g1 = cx.createLinearGradient(0, 0, 0, 280); g1.addColorStop(0, 'rgba(16,185,129,.30)'); g1.addColorStop(1, 'rgba(16,185,129,0)');
                var g2 = cx.createLinearGradient(0, 0, 0, 280); g2.addColorStop(0, 'rgba(99,102,241,.18)'); g2.addColorStop(1, 'rgba(99,102,241,0)');
                new BXChart(ae, { type: 'line', data: { labels: tl, datasets: [{ label: 'Joiners', data: ts, borderColor: '#10b981', backgroundColor: g1, fill: true, tension: .4, borderWidth: 2, pointRadius: 0 }, { label: 'New Records', data: tp, borderColor: '#6366f1', backgroundColor: g2, fill: true, tension: .4, borderWidth: 2, pointRadius: 0 }] }, options: { maintainAspectRatio: false, plugins: { legend: { position: 'top', labels: { boxWidth: 10, usePointStyle: true } } }, scales: { y: { grid: { color: grid } }, x: { grid: { display: false } } } } });
            }
            var de = document.getElementById('bxDonut');
            if (de) { var sJ = ts.reduce(function (a, b) { return a + +b; }, 0), sR = tp.reduce(function (a, b) { return a + +b; }, 0); new BXChart(de, { type: 'doughnut', data: { labels: ['Joiners', 'Records'], datasets: [{ data: [sJ, sR], backgroundColor: ['#10b981', '#6366f1'], borderWidth: 0 }] }, options: { maintainAspectRatio: false, cutout: '66%', plugins: { legend: { position: 'bottom', labels: { boxWidth: 10, usePointStyle: true, padding: 14 } } } } }); }
            var be = document.getElementById('bxBar');
            if (be && tl.length) new BXChart(be, { type: 'bar', data: { labels: tl, datasets: [{ label: 'Joiners', data: ts, backgroundColor: '#10b981', borderRadius: 6 }] }, options: { maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { grid: { color: grid } }, x: { grid: { display: false } } } } });
            var gg = function (id, v, c) { var e = document.getElementById(id); if (!e) return; new BXChart(e, { type: 'doughnut', data: { datasets: [{ data: [v, 100 - v], backgroundColor: [c, grid], borderWidth: 0 }] }, options: { maintainAspectRatio: false, cutout: '78%', plugins: { legend: { display: false }, tooltip: { enabled: false } } } }); var lbl = e.parentElement.querySelector('div'); if (lbl) lbl.textContent = v + '%'; };
            var pct = function (a) { if (!a || !a.length) return 0; var last = +a[a.length - 1] || 0; var mx = Math.max.apply(null, a.map(function (x) { return +x || 0; })); return mx > 0 ? Math.round(last / mx * 100) : 0; };
            gg('bxG1', pct(ts), '#0ea5e9'); gg('bxG2', pct(tp), '#10b981');
        }
        if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', draw); } else { draw(); }
    })();
</script>

@section scripts {
    <script type="text/javascript">
        var BX_PERIOD = @Html.Raw(ViewBag.periodJson ?? "null");
        function bxInt(v) { return Math.round(+v || 0).toLocaleString(); }
        function bxSetDelta(el, d) { if (!el) return; if (d === null || d === undefined) { el.textContent = ''; el.className = 'bosx-kpi-d'; return; } var up = d >= 0; el.textContent = (up ? '▲ ' : '▼ ') + Math.abs(d).toFixed(1) + '%'; el.className = 'bosx-kpi-d ' + (up ? 'up' : 'dn'); }
        function bxApplyPeriod(p) {
            if (!BX_PERIOD || !BX_PERIOD[p]) return;
            var d = BX_PERIOD[p], g = function (id) { return document.getElementById(id); };
            if (g('bxV1')) g('bxV1').textContent = bxInt(d.joiners);
            if (g('bxV2')) g('bxV2').textContent = bxInt(d.records);
            if (g('bxV3')) g('bxV3').textContent = bxInt(d.headcount);
            if (g('bxV4')) g('bxV4').textContent = bxInt(d.active);
            bxSetDelta(g('bxD1'), d.dJoiners); bxSetDelta(g('bxD2'), d.dRecords); bxSetDelta(g('bxD3'), d.dHeadcount); bxSetDelta(g('bxD4'), d.dActive);
            Array.prototype.forEach.call(document.querySelectorAll('.bosx-kpi-per'), function (e) { e.textContent = '· ' + p; });
        }
        function bxSeg(id, attr, cb) { var c = document.getElementById(id); if (!c) return; c.addEventListener('click', function (e) { var b = e.target.closest('button'); if (!b) return; c.querySelectorAll('button').forEach(function (x) { x.classList.remove('on'); }); b.classList.add('on'); cb(b.getAttribute('data-' + attr)); }); }
        function bxSyncSeg(id, attr, val) { var c = document.getElementById(id); if (!c) return; c.querySelectorAll('button').forEach(function (x) { x.classList.toggle('on', x.getAttribute('data-' + attr) === val); }); }
        bxSeg('bosxPeriod', 'p', function (p) { bxApplyPeriod(p); });
        bxSeg('bosxStyle', 's', function (s) { document.body.setAttribute('data-bosstyle', s); try { localStorage.setItem('bosxStyle', s); } catch (e) { } });
        bxSeg('bosxTheme', 't', function (t) { document.body.setAttribute('data-bostheme', t); try { localStorage.setItem('bosxTheme', t); } catch (e) { } });
        bxSyncSeg('bosxStyle', 's', document.body.getAttribute('data-bosstyle') || 'aurora');
        bxSyncSeg('bosxTheme', 't', document.body.getAttribute('data-bostheme') || 'light');
        bxApplyPeriod('month');
    </script>
}
