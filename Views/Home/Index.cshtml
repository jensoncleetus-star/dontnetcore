    <script>
        /* ---- Period / Style / Theme controls + live KPI period switch (real data) ---- */
        var BX_PERIOD = @Html.Raw(ViewBag.periodJson ?? "null");
        function bxFmt(v) {
            v = +v || 0; var s = v < 0 ? '-' : ''; v = Math.abs(v);
            if (v >= 1e6) return s + 'AED ' + (v / 1e6).toFixed(2) + 'M';
            if (v >= 1e3) return s + 'AED ' + (v / 1e3).toFixed(0) + 'K';
            return s + 'AED ' + v.toFixed(2);
        }
        function bxSetDelta(el, d) {
            if (!el) return;
            if (d === null || d === undefined) { el.textContent = ''; el.className = 'bosx-kpi-d'; return; }
            var up = d >= 0;
            el.textContent = (up ? '▲ ' : '▼ ') + Math.abs(d).toFixed(1) + '%';
            el.className = 'bosx-kpi-d ' + (up ? 'up' : 'dn');
        }
        function bxApplyPeriod(p) {
            if (!BX_PERIOD || !BX_PERIOD[p]) return;
            var d = BX_PERIOD[p], g = function (id) { return document.getElementById(id); };
            if (g('bxV1')) g('bxV1').textContent = bxFmt(d.sales);
            if (g('bxV2')) g('bxV2').textContent = bxFmt(d.purchase);
            if (g('bxV3')) g('bxV3').textContent = bxFmt(d.receipts);
            if (g('bxV4')) g('bxV4').textContent = bxFmt(d.payments);
            bxSetDelta(g('bxD1'), d.dSales); bxSetDelta(g('bxD2'), d.dPurchase);
            bxSetDelta(g('bxD3'), d.dReceipts); bxSetDelta(g('bxD4'), d.dPayments);
            Array.prototype.forEach.call(document.querySelectorAll('.bosx-kpi-per'), function (e) { e.textContent = '· ' + p; });
        }
        function bxSeg(id, attr, cb) {
            var c = document.getElementById(id); if (!c) return;
            c.addEventListener('click', function (e) {
                var b = e.target.closest('button'); if (!b) return;
                c.querySelectorAll('button').forEach(function (x) { x.classList.remove('on'); });
                b.classList.add('on'); cb(b.getAttribute('data-' + attr));
            });
        }
        function bxSyncSeg(id, attr, val) {
            var c = document.getElementById(id); if (!c) return;
            c.querySelectorAll('button').forEach(function (x) {
                x.classList.toggle('on', x.getAttribute('data-' + attr) === val);
            });
        }
        bxSeg('bosxPeriod', 'p', function (p) { bxApplyPeriod(p); });
        bxSeg('bosxStyle', 's', function (s) { document.body.setAttribute('data-bosstyle', s); try { localStorage.setItem('bosxStyle', s); } catch (e) { } });
        bxSeg('bosxTheme', 't', function (t) { document.body.setAttribute('data-bostheme', t); try { localStorage.setItem('bosxTheme', t); } catch (e) { } });
        bxSyncSeg('bosxStyle', 's', document.body.getAttribute('data-bosstyle') || 'aurora');
        bxSyncSeg('bosxTheme', 't', document.body.getAttribute('data-bostheme') || 'light');
        bxApplyPeriod('month');
        /* legacy toggle kept for any other callers */
        function bosxToggleTheme() {
            var b = document.body, t = (b.getAttribute('data-bostheme') === 'dark') ? 'light' : 'dark';
            b.setAttribute('data-bostheme', t);
            try { localStorage.setItem('bosxTheme', t); } catch (e) { }
            bxSyncSeg('bosxTheme', 't', t);
        }
    </script>
