@model QuickSoft.ViewModel.HomeViewModel
@{
    ViewBag.Title = "Dashboard";
    ViewBag.SubTitle = "";
    ViewBag.Active = "Dashboard";
    string actData = "";
}

<link rel="stylesheet" href="@Url.Content("~/Content/css/dashboard-futuristic.css")?v=20260630q" />
<script>
    (function () {
        try {
            document.body.classList.add('bosx-on');
            /* light by default (owner's choice); one-time reset, then the Theme button still toggles. */
            if (localStorage.getItem('bosxThemeV') !== '3') { localStorage.setItem('bosxTheme', 'light'); localStorage.setItem('bosxThemeV', '3'); }
            document.body.setAttribute('data-bostheme', localStorage.getItem('bosxTheme') || 'light');
            document.body.setAttribute('data-bosstyle', localStorage.getItem('bosxStyle') || 'aurora');
        } catch (e) { document.body.setAttribute('data-bostheme', 'dark'); }
    })();
</script>

<div class="bosx-dash">
    <div class="bosx-hero">
        <div>
            <div class="bosx-hero-title">Dashboard</div>
            <div class="bosx-hero-sub"><i class="fa fa-calendar-o"></i> <span id="bosxRange">@ViewBag.lastdate &ndash; @ViewBag.today</span></div>
        </div>
        <div class="bosx-ctrls">
            <div class="bosx-seg" id="bosxPeriod" title="Period">
                <button type="button" data-p="today">Today</button>
                <button type="button" data-p="week">Week</button>
                <button type="button" data-p="month" class="on">Month</button>
                <button type="button" data-p="year">Year</button>
            </div>
            <div class="bosx-seg" id="bosxStyle" title="Style">
                <button type="button" data-s="aurora" class="on">Aurora</button>
                <button type="button" data-s="minimal">Minimal</button>
                <button type="button" data-s="vivid">Vivid</button>
            </div>
            <div class="bosx-seg" id="bosxTheme" title="Theme">
                <button type="button" data-t="light" class="on"><i class="fa fa-sun-o"></i></button>
                <button type="button" data-t="dark"><i class="fa fa-moon-o"></i></button>
            </div>
        </div>
    </div>

    <div class="bosx-kpis">
        <div class="bosx-kpi k1"><div class="bosx-kpi-ic"><i class="fa fa-shopping-bag"></i></div><div style="flex:1;min-width:0"><div class="bosx-kpi-l">Sales <span class="bosx-kpi-per">&middot; month</span></div><div class="bosx-kpi-v" id="bxV1">&mdash;</div><div class="bosx-kpi-d" id="bxD1"></div></div></div>
        <div class="bosx-kpi k2"><div class="bosx-kpi-ic"><i class="fa fa-shopping-cart"></i></div><div style="flex:1;min-width:0"><div class="bosx-kpi-l">Purchase <span class="bosx-kpi-per">&middot; month</span></div><div class="bosx-kpi-v" id="bxV2">&mdash;</div><div class="bosx-kpi-d" id="bxD2"></div></div></div>
        <div class="bosx-kpi k3"><div class="bosx-kpi-ic"><i class="fa fa-arrow-down"></i></div><div style="flex:1;min-width:0"><div class="bosx-kpi-l">Receipts <span class="bosx-kpi-per">&middot; month</span></div><div class="bosx-kpi-v" id="bxV3">&mdash;</div><div class="bosx-kpi-d" id="bxD3"></div></div></div>
        <div class="bosx-kpi k4"><div class="bosx-kpi-ic"><i class="fa fa-arrow-up"></i></div><div style="flex:1;min-width:0"><div class="bosx-kpi-l">Payments <span class="bosx-kpi-per">&middot; month</span></div><div class="bosx-kpi-v" id="bxV4">&mdash;</div><div class="bosx-kpi-d" id="bxD4"></div></div></div>
        <div class="bosx-kpi k5"><div class="bosx-kpi-ic"><i class="fa fa-users"></i></div><div><div class="bosx-kpi-l">Customers</div><div class="bosx-kpi-v">@Html.DisplayFor(m => m.totCustomerCount)</div></div></div>
        <div class="bosx-kpi k6"><div class="bosx-kpi-ic"><i class="fa fa-truck"></i></div><div><div class="bosx-kpi-l">Suppliers</div><div class="bosx-kpi-v">@Html.DisplayFor(m => m.totSupplierCount)</div></div></div>
    </div>

    <div class="bosx-quick">
        <a href="@Url.Action("Create", "CreditSale")" class="bosx-q"><span class="bosx-q-ic q1"><i class="fa fa-shopping-cart"></i></span><span class="bosx-q-t">New Sale</span></a>
        <a href="@Url.Action("Create", "PurchaseEntry")" class="bosx-q"><span class="bosx-q-ic q2"><i class="fa fa-truck"></i></span><span class="bosx-q-t">New Purchase</span></a>
        <a href="@Url.Action("Create", "Receipt")" class="bosx-q"><span class="bosx-q-ic q3"><i class="fa fa-arrow-down"></i></span><span class="bosx-q-t">New Receipt</span></a>
        <a href="@Url.Action("Create", "Payment")" class="bosx-q"><span class="bosx-q-ic q4"><i class="fa fa-arrow-up"></i></span><span class="bosx-q-t">New Payment</span></a>
        <a href="@Url.Action("Index", "Customer")" class="bosx-q"><span class="bosx-q-ic q5"><i class="fa fa-users"></i></span><span class="bosx-q-t">Customers</span></a>
        <a href="@Url.Action("Index", "Item")" class="bosx-q"><span class="bosx-q-ic q6"><i class="fa fa-cubes"></i></span><span class="bosx-q-t">Inventory</span></a>
