            // ---- pretty cell renderers: colored avatar initials, aligned amounts, status pills ----
            function bxEsc(s){ return (s==null?'':String(s)).replace(/[&<>"]/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c];}); }
            function bxAvatar(name){
                name=(name==null?'':String(name)).trim();
                var clean=name.replace(/^[0-9]+\s*[-–]\s*/,'');
                var parts=clean.split(/\s+/).filter(Boolean), ini='';
                if(parts.length>=2) ini=parts[0].charAt(0)+parts[1].charAt(0);
                else if(parts.length===1) ini=parts[0].substring(0,2);
                ini=(ini||'?').toUpperCase();
                var pal=['#6366f1','#22d3ee','#10b981','#f472b6','#8b5cf6','#0ea5e9','#fbbf24','#f43f5e'];
                var h=0,i; for(i=0;i<clean.length;i++) h=(h*31+clean.charCodeAt(i))>>>0;
                return '<span class="bx-av" style="background:'+pal[h%pal.length]+'">'+bxEsc(ini)+'</span><span class="bx-av-name">'+bxEsc(name)+'</span>';
            }
            function bxNum(v){ var n=parseFloat(v); if(isNaN(n)) return bxEsc(v); return '<span class="bx-num">'+n.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2})+'</span>'; }
            function bxBalance(v){ var n=parseFloat(v); if(!isNaN(n)&&Math.abs(n)<0.005) return '<span class="bx-pill ok">Paid</span>'; return '<span class="bx-num bx-due">'+(isNaN(n)?bxEsc(v):n.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}))+'</span>'; }
            function bxStatus(v){ var s=(v==null?'':String(v)).trim(), low=s.toLowerCase(), cls='muted';
                if(/(active|approve|cleared|paid|open|complete|success)/.test(low)) cls='ok';
                else if(/(expire|reject|cancel|overdue|fail|close)/.test(low)) cls='bad';
                else if(/(pending|hold|process|partial|due|wait)/.test(low)) cls='warn';
                return '<span class="bx-pill '+cls+'">'+bxEsc(s||'-')+'</span>'; }

