    <div class="row">
        <div class="col-md-8">
            <div class="box box-info"><div class="box-header with-border"><h3 class="box-title">Revenue trend &middot; 12 months</h3></div>
                <div class="box-body"><div class="bx-chart bx-chart-lg"><canvas id="bxArea"></canvas></div></div></div>
        </div>
        <div class="col-md-4">
            <div class="box box-primary"><div class="box-header with-border"><h3 class="box-title">Sales vs Purchase</h3></div>
                <div class="box-body"><div class="bx-chart bx-chart-lg"><canvas id="bxDonut"></canvas></div></div></div>
        </div>
    </div>
    <div class="row">
        <div class="col-md-8">
            <div class="box box-info"><div class="box-header with-border"><h3 class="box-title">Monthly sales</h3></div>
                <div class="box-body"><div class="bx-chart bx-chart-md"><canvas id="bxBar"></canvas></div></div></div>
        </div>
        <div class="col-md-4">
            <div class="box box-warning"><div class="box-header with-border"><h3 class="box-title">Targets</h3></div>
                <div class="box-body" style="display:flex;justify-content:space-around;align-items:center;min-height:170px">
                    <div style="text-align:center"><div style="position:relative;width:118px;height:118px"><canvas id="bxG1"></canvas><div style="position:absolute;inset:0;display:grid;place-items:center;font-weight:600;color:#0ea5e9">78%</div></div><div style="font-size:12px;opacity:.7;margin-top:4px">Sales</div></div>
                    <div style="text-align:center"><div style="position:relative;width:118px;height:118px"><canvas id="bxG2"></canvas><div style="position:absolute;inset:0;display:grid;place-items:center;font-weight:600;color:#10b981">64%</div></div><div style="font-size:12px;opacity:.7;margin-top:4px">Collection</div></div>
                </div></div>
        </div>
    </div>
    <script src="@Url.Content("~/Content/plugins/chartjs4/chart.umd.min.js")"></script>
    <script>
        (function () {
            var BXChart = window.Chart;   // capture Chart.js 4 now, before the legacy 1.x bundle reassigns window.Chart
            if (!BXChart) return;
            var tl = @Html.Raw(ViewBag.trendLabels ?? "[]"), ts = @Html.Raw(ViewBag.trendSales ?? "[]"), tp = @Html.Raw(ViewBag.trendPurchase ?? "[]");
            var grid = 'rgba(127,140,170,.14)';
            function draw() {
                var ae = document.getElementById('bxArea');
                if (ae && tl.length) {
                    var cx = ae.getContext('2d');
                    var g1 = cx.createLinearGradient(0, 0, 0, 280); g1.addColorStop(0, 'rgba(99,102,241,.30)'); g1.addColorStop(1, 'rgba(99,102,241,0)');
                    var g2 = cx.createLinearGradient(0, 0, 0, 280); g2.addColorStop(0, 'rgba(34,211,238,.20)'); g2.addColorStop(1, 'rgba(34,211,238,0)');
                    new BXChart(ae, { type: 'line', data: { labels: tl, datasets: [{ label: 'Sales', data: ts, borderColor: '#6366f1', backgroundColor: g1, fill: true, tension: .4, borderWidth: 2, pointRadius: 0 }, { label: 'Purchase', data: tp, borderColor: '#22d3ee', backgroundColor: g2, fill: true, tension: .4, borderWidth: 2, pointRadius: 0 }] }, options: { maintainAspectRatio: false, plugins: { legend: { position: 'top', labels: { boxWidth: 10, usePointStyle: true } } }, scales: { y: { grid: { color: grid } }, x: { grid: { display: false } } } } });
                }
                var de = document.getElementById('bxDonut');
                if (de) {
                    var sS = ts.reduce(function (a, b) { return a + +b; }, 0), sP = tp.reduce(function (a, b) { return a + +b; }, 0);
                    new BXChart(de, { type: 'doughnut', data: { labels: ['Sales', 'Purchase'], datasets: [{ data: [sS, sP], backgroundColor: ['#6366f1', '#22d3ee'], borderWidth: 0 }] }, options: { maintainAspectRatio: false, cutout: '66%', plugins: { legend: { position: 'bottom', labels: { boxWidth: 10, usePointStyle: true, padding: 14 } } } } });
                }
                var be = document.getElementById('bxBar');
                if (be && tl.length) new BXChart(be, { type: 'bar', data: { labels: tl, datasets: [{ label: 'Sales', data: ts, backgroundColor: '#6366f1', borderRadius: 6 }] }, options: { maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { grid: { color: grid } }, x: { grid: { display: false } } } } });
                var gg = function (id, v, c) { var e = document.getElementById(id); if (!e) return; new BXChart(e, { type: 'doughnut', data: { datasets: [{ data: [v, 100 - v], backgroundColor: [c, grid], borderWidth: 0 }] }, options: { maintainAspectRatio: false, cutout: '78%', plugins: { legend: { display: false }, tooltip: { enabled: false } } } }); var lbl = e.parentElement.querySelector('div'); if (lbl) lbl.textContent = v + '%'; };
                var pct = function (a) { if (!a || !a.length) return 0; var last = +a[a.length - 1] || 0; var mx = Math.max.apply(null, a.map(function (x) { return +x || 0; })); return mx > 0 ? Math.round(last / mx * 100) : 0; };
                gg('bxG1', pct(ts), '#0ea5e9'); gg('bxG2', pct(tp), '#10b981');
            }
            if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', draw); } else { draw(); }
        })();
    </script>

