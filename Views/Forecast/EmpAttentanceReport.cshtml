
@model QuickSoft.Models.EmpAttendance
@{
    ViewBag.Title = "Employee Attendance";
    ViewBag.SubTitle = "Employee Attendance";
    ViewBag.Active = "Utility";

    string actData = "";
    string actImg = "";
    string delchk = "";
    string deleteBTn = "";
    if (User.IsInRole("Dev") || User.IsInRole("Delete Delete FileDocument"))
    {
        deleteBTn = "{text: 'Delete', className: 'btn-danger', action: function(e, dt, node, config) {" +
