@section scripts{
    @Scripts.Render("~/js/jqueryval")
    <script type="text/javascript">
        var ar = new Array();
        var va = "";
        $(document).ready(function () {
            $('#advsearchlist').hide();             
            $("#Name").select2();
           
            //$('[data-confirm]').click(function (e) {
            //    if ($('.checkbox:checked').length > 0) {
            //        if (!confirm(jQuery(this).attr("data-confirm"))) {
            //            e.preventDefault();
            //        }
            //    } else {
            //        alert("Please Select Rows..!!");
            //        e.preventDefault();
            //    }
            //});
        });

        $("ul li input:checkbox").click(function () {
            var _show = 0;

            if ($("#liname").prop("checked") == true) {
                $("#searchname").show();
                _show = 1;        

            }
            else {
                $("#Name").val("").trigger("change");
                $("#searchname").hide();
            //    oTable.draw();
            }

            if ($("#liphone").prop("checked") == true) {
                $("#searchphoneno").show();
                _show = 1;
            }
            else {
                
                $("#Phone").val("");
                $("#searchphoneno").hide();
             //   oTable.draw();
            }

            if ($("#ligroup").prop("checked") == true) {
                $("#searchgroup").show();
                _show = 1;
            }
            else {
                $("#Group").val("5");
                $("#searchgroup").hide();
              //  oTable.draw();
            }

            if ($("#limobile").prop("checked") == true) {
                $("#searchmobno").show();
                _show = 1;
            }
            else {
                $("#Mobile").val("");
                $("#searchmobno").hide();
               // oTable.draw();
            }

            if ($("#liemail").prop("checked") == true) {
                $("#searchemail").show();
                _show = 1;
            }
            else {
                $("#Email").val("");
                $("#searchemail").hide();
              //  oTable.draw();
            }

            if (_show == 1) {
                $('#advsearchlist').show();
            }
            else {
                $('#advsearchlist').hide();
            }
        });

        function getUnique(array){
            var uniqueArray = [];

            // Loop through array values
            for(var value of array){
                if(uniqueArray.indexOf(value) === -1){
                    uniqueArray.push(value);
                }
            }
           return uniqueArray;
        }

        var oTable = $('#MyTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": false, // a stale saved state was forcing an empty list — always start fresh
            "pageLength": 50,
            responsive: false,
            "ajax": {
                "url": '/Contact/getContact',
                "data": function (data) {
                    data.Name = $('#Name').val();
                    data.Email = $('#Email').val();
                    data.Mobile = $('#Mobile').val();
                    data.Phone = $('#Phone').val();
                    // Only filter by Group when the user has ticked "Group" in Select Fields; otherwise show
                    // ALL contacts. (The dropdown defaults to "General" which has 0 contacts, so without this
                    // the whole list shows empty.)
                    data.Group = $('#ligroup').prop('checked') ? ($('#Group').val() || '') : '';
                    //data.Values = va;
                },
                "type": "POST",
                "datatype": "json"
            },
            "columnDefs": [{
                "targets": [7, 8],
                "orderable": false
            }],
            "columns": [
                     {
                         "data": "id", "name": "id",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                 { "data": "ContactName", "name": "ContactName", "render": function (data, type, row) {
                       if (type !== 'display') return data || '';
                       var nm = (data || '').toString();
                       var core = nm.replace(/^\s*(mr|mrs|ms|miss|dr)\.?\s+/i, '').trim();
                       var parts = core.split(/\s+/).filter(Boolean);
                       var ini = (((parts[0] || '').charAt(0)) + ((parts[1] || '').charAt(0))).toUpperCase() || (nm.charAt(0) || '?').toUpperCase();
                       var pal = ['#6366f1','#0ea5e9','#10b981','#f59e0b','#ec4899','#8b5cf6','#14b8a6','#ef4444','#0d9488','#d946ef'];
                       var h = 0; for (var i = 0; i < nm.length; i++) h = nm.charCodeAt(i) + ((h << 5) - h);
                       var col = pal[Math.abs(h) % pal.length];
                       var grp = (row && row.Group) ? '<br><span class="qk-grp">' + $('<div>').text(row.Group).html() + '</span>' : '';
                       return '<div class="qk-name"><span class="qk-av" style="background:' + col + '">' + ini + '</span><span><span class="qk-nm">' + $('<div>').text(nm).html() + '</span>' + grp + '</span></div>';
                   } },
                 { "data": "Group", "name": "Group" },
                 { "data": "Address", "name": "Address" },
                 { "data": "Phone", "name": "Phone" },
                 {
                     "name": "Mobile", "data": function (data, type) {
                         // null-guard: a null item here used to throw and abort the WHOLE table render
                         // (so no rows showed even when data was returned).
                         if (!data) return "";
                         var tel = function (n) {
                             var raw = (n || '').toString().trim();
                             if (!raw) return '';
                             var esc = $('<div>').text(raw).html();
                             if (type !== 'display') return raw;
                             return '<a class="qk-tel" href="tel:' + raw.replace(/[^0-9+]/g, '') + '">' + esc + '</a>';
                         };
                         var lines = [];
                         var m = tel(data.Mobile); if (m) lines.push(m);
                         var p = tel(data.Phone);  if (p && (data.Phone || '') !== (data.Mobile || '')) lines.push(p);
                         // legacy fallback: some rows carry numbers in mobmodel instead
                         if (!lines.length && data.mobmodel) {
                             $.each(data.mobmodel, function (i, item) {
                                 if (item && item.Num != null) { var t = tel(item.Num); if (t) lines.push(t); }
                             });
                         }
                         return lines.join('<br>');
                     }
                 },
                 { "data": "EmailId", "name": "EmailId", "render": function (data, type) {
                       if (type !== 'display' || !data) return data || '';
                       var e = $('<div>').text(data).html();
                       return '<a class="qk-mail" href="mailto:' + e + '">' + e + '</a>';
                   } },
                 //{
                 //    "name": "Status", "data": function (data) {
                 //        if (data.Status == 1) {
                 //            return '<a href="/Contact/ContactStatus/' + data.id + '/active " class="modal-change" title="Click To Active" ><i class="badge bg-red" style="font-size: small" >Inactive</i></a>';
                 //        }
                 //        else {
                 //            return '<a href="/Contact/ContactStatus/' + data.id + '/inactive" class="modal-change" title="Click To Inactive" ><i class="badge bg-green" style="font-size: small" >Active</i></a>';
                 //        }
                 //    }
                 //},
                 //{
                 //    "data": "id", "name": "id", "render": function (data) {
                 //        return '<a class="details"  href="/Contact/ViewDetails/' + data + '"  title="View User Details"><i class="fa fa-search-plus" style="font-size: large" ></i></a>&nbsp; ' +
                 //              '<a href="/Contact/Edit/' + data + '" title="Edit Contact"><i class="fa fa-edit" style="font-size: large"></i></a> ' +
                 //              '<a class="modal-delete" href="/Contact/delete/' + data + '" title="Delete Contact"><i class="fa fa-trash" style="font-size: large"></i></a>';
                 //    }
                 //},
                  {
                      "name": "id", "data": function (data) {
                          var rest = "";
                          var tmp = "";
                          @{
                              if (User.IsInRole("Dev") || User.IsInRole("View Contact"))
                              {
                                  //  actData += "<a class=\"details\" href=\"/Contact/ViewDetails/'+ data.id +'\" title=\"View Contact\"><i class=\"fa fa-lg fa-search-plus\"></i></a> ";
                                  actData += "<a class=\"btn btn-icons btn-rounded btn-primary\" href=\"/Contact/Edit/'+ data.id +'\" title=\"Edit Contact\"><i class=\"fa fa-pencil\"></i></a> ";
                                  actData += "<a class=\"btn btn-icons btn-rounded btn-delete\" href=\"javascript:void(0)\" title=\"Delete Contact\" onclick=\"ajaxDelete('+data.id+')\"><i class=\"fa fa-trash\"></i></a> ";
                              }
                           }
                         rest += '@Html.Raw(actData)';
                          if (data.EdByGroup == 0) {
                              @{
                                  //if (User.IsInRole("Dev") || User.IsInRole("View Contact"))
                                  //{
                                  //    actData += "<a class=\"details\" href=\"/Contact/ViewDetails/'+ data.id +'\" title=\"View Contact\"><i class=\"fa fa-lg fa-search-plus\"></i></a> ";
                                  //}
                                  if (User.IsInRole("Dev") || User.IsInRole("Edit Contact"))
                                  {
                                      actData += "<a href=\"/Contact/Edit/'+ data.id +'\" title=\"Edit Contact\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                                  }
                                  if (User.IsInRole("Dev") || User.IsInRole("Delete Contact"))
                                  {
                                      actData += "<a class=\"modal-delete\" href=\"/Contact/Delete/'+ data.id +'\" title=\"Delete Contact\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";
                                  }
                              }
                              return rest = '@Html.Raw(actData)';
                          }
                          return rest;
                      }
                  },
                   {
                       "name": "id", "data": function (data) {
                           var rest = "";
                           @{
                                       if (User.IsInRole("Dev") || User.IsInRole("Delete Contact"))
                                       {
                                           delchk = "<input class=\"checkbox\" type=\"checkbox\" name=\"bill[]\" value='+ data.id +'></input>";
                                       }
                                   }
                           return rest = '@Html.Raw(delchk)';
                       }
                   },
            ],
            dom: 'Bfrtip',
            buttons: [{
                extend: 'collection',
                text: '<i class="fa fa-download"></i> Export',
                className: 'qk-export-btn',
                autoClose: true,
                buttons: [{
                extend: 'print',//
                title: "",
                footer: true,
                exportOptions: {
                    columns: ':visible'
                },
                message: '<table class="tblcompact table table-bordered"><thead>' +
                    ' <tr><th class="text-center"><h3 style="margin-top: 0px;">' + '<h4>Suppliers </h4></th></tr>' +
                    ' <tr><th><span class="text-left"></span><span class="text-right pull-right"> </span></th></tr></thead><tbody><tr><td>',
                customize: function (win) {
                    // $(win.document.body)
                    //.css('font-size', '10pt')
                    //.css('padding', '1px');
                    $(win.document.body).find('table, th,tr, td ')
                       // .css('border', 'inherit')
                        .css('font-size', '10pt')
