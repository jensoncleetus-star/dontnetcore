@model QuickSoft.ViewModel.AccountsViewModel
@{
    ViewBag.Title = "Update Cash Balance";
    ViewBag.SubTitle = "Cash Balance";
    ViewBag.Active = "Settings";
}
<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">Update Cash Balance</h3>
    </div>
    <div class="box-body">
        @using (Html.BeginForm("UpdateCashBalance", "Accounts", FormMethod.Post, new { @id = "createform", role = "form" , @class = "form-horizontal" }))
        {
            @Html.HiddenFor(Model => Model.AccountsID,new { @Value="3"})
            <div class="form-group">
                <label class="control-label col-md-4">Name</label>
                <div class="col-sm-3">
                    <input type="text" readonly="readonly" class="form-control input-sm" value="Cash-In-Hand" />
                </div>
            </div>
            <div class="form-group">
                <label class="control-label col-md-4">Opening Balance</label>
                <div class="col-sm-3">
                    <div class="input-group">
                        @Html.EditorFor(model => model.OpnBalance, new { htmlAttributes = new { @class = "form-control" } })
                        <div class="input-group-addon no-padding dcwidth">
                            @Html.EnumDropDownListFor(model => model.DC, new { @class = "form-control"})
                        </div>
                    </div>
                </div>
            </div>
            <div class="box-footer col-md-12">
                <input type="submit" class="btn btn-info col-sm-offset-5" value="Update" />
                <button type="button" class="btn btn-default" onclick="@("window.location.href='" + @Url.Action("Index", "Home") + "'");">Cancel</button>
                @*<input type="button" class="btn btn-default" value="Reset" id="btnreset" />*@
            </div>
        }
    </div>
</div>

@section scripts{
    <script type="text/javascript">
        $(document).ready(function () {
        $("#DC").prop('selectedIndex', 0);
        $('#DC').prop('disabled', true);
    });
    </script>
}







