@model QuickSoft.ViewModel.HomeViewModel
@{
    ViewBag.Title = "Vendor Relation";
    ViewBag.Active = "Dashboard";
}

<link rel="stylesheet" href="@Url.Content("~/Content/css/dashboard-futuristic.css")?v=20260630q" />
<script>
    (function () {
        try {
            document.body.classList.add('bosx-on');
            if (localStorage.getItem('bosxThemeV') !== '3') { localStorage.setItem('bosxTheme', 'light'); localStorage.setItem('bosxThemeV', '3'); }
            document.body.setAttribute('data-bostheme', localStorage.getItem('bosxTheme') || 'light');
            document.body.setAttribute('data-bosstyle', localStorage.getItem('bosxStyle') || 'aurora');
        } catch (e) { document.body.setAttribute('data-bostheme', 'light'); }
    })();
</script>

<div class="bosx-dash">
    <div class="bosx-hero">
        <div>
            <div class="bosx-hero-title">Vendor Relation</div>
            <div class="bosx-hero-sub"><i class="fa fa-calendar-o"></i> <span id="bosxRange">@ViewBag.lastdate &ndash; @ViewBag.today</span></div>
        </div>
        <div class="bosx-ctrls">
            <div class="bosx-seg" id="bosxPeriod" title="Period">
                <button type="button" data-p="today">Today</button>
                <button type="button" data-p="week">Week</button>
                <button type="button" data-p="month" class="on">Month</button>
                <button type="button" data-p="year">Year</button>
            </div>
            <div class="bosx-seg" id="bosxStyle" title="Style">
                <button type="button" data-s="aurora" class="on">Aurora</button>
                <button type="button" data-s="minimal">Minimal</button>
                <button type="button" data-s="vivid">Vivid</button>
            </div>
            <div class="bosx-seg" id="bosxTheme" title="Theme">
                <button type="button" data-t="light" class="on"><i class="fa fa-sun-o"></i></button>
                <button type="button" data-t="dark"><i class="fa fa-moon-o"></i></button>
            </div>
        </div>
    </div>

    <div class="bosx-kpis">
        <div class="bosx-kpi k2"><div class="bosx-kpi-ic"><i class="fa fa-shopping-cart"></i></div><div style="flex:1;min-width:0"><div class="bosx-kpi-l">Purchases <span class="bosx-kpi-per">&middot; month</span></div><div class="bosx-kpi-v" id="bxV1">&mdash;</div><div class="bosx-kpi-d" id="bxD1"></div></div></div>
        <div class="bosx-kpi k4"><div class="bosx-kpi-ic"><i class="fa fa-arrow-up"></i></div><div style="flex:1;min-width:0"><div class="bosx-kpi-l">Payments <span class="bosx-kpi-per">&middot; month</span></div><div class="bosx-kpi-v" id="bxV2">&mdash;</div><div class="bosx-kpi-d" id="bxD2"></div></div></div>
        <div class="bosx-kpi k6"><div class="bosx-kpi-ic"><i class="fa fa-reply"></i></div><div style="flex:1;min-width:0"><div class="bosx-kpi-l">Purchase Returns <span class="bosx-kpi-per">&middot; month</span></div><div class="bosx-kpi-v" id="bxV3">&mdash;</div><div class="bosx-kpi-d" id="bxD3"></div></div></div>
        <div class="bosx-kpi k1"><div class="bosx-kpi-ic"><i class="fa fa-user-plus"></i></div><div style="flex:1;min-width:0"><div class="bosx-kpi-l">New Suppliers <span class="bosx-kpi-per">&middot; month</span></div><div class="bosx-kpi-v" id="bxV4">&mdash;</div><div class="bosx-kpi-d" id="bxD4"></div></div></div>
        <div class="bosx-kpi k3"><div class="bosx-kpi-ic"><i class="fa fa-truck"></i></div><div><div class="bosx-kpi-l">Total Suppliers</div><div class="bosx-kpi-v">@Html.DisplayFor(m => m.totSupplierCount)</div></div></div>
        <div class="bosx-kpi k5"><div class="bosx-kpi-ic"><i class="fa fa-shopping-bag"></i></div><div><div class="bosx-kpi-l">Total Purchases</div><div class="bosx-kpi-v">@Html.DisplayFor(m => m.totPurchaseEntryCount)</div></div></div>
    </div>

    <div class="bosx-quick">
        <a href="@Url.Action("Create", "PurchaseEntry")" class="bosx-q"><span class="bosx-q-ic q2"><i class="fa fa-truck"></i></span><span class="bosx-q-t">New Purchase</span></a>
        <a href="@Url.Action("Create", "Payment")" class="bosx-q"><span class="bosx-q-ic q4"><i class="fa fa-arrow-up"></i></span><span class="bosx-q-t">New Payment</span></a>
        <a href="@Url.Action("Create", "Supplier")" class="bosx-q"><span class="bosx-q-ic q1"><i class="fa fa-user-plus"></i></span><span class="bosx-q-t">New Supplier</span></a>
        <a href="@Url.Action("Index", "Supplier")" class="bosx-q"><span class="bosx-q-ic q5"><i class="fa fa-users"></i></span><span class="bosx-q-t">Suppliers</span></a>
        <a href="@Url.Action("Index", "PurchaseEntry")" class="bosx-q"><span class="bosx-q-ic q6"><i class="fa fa-shopping-bag"></i></span><span class="bosx-q-t">Purchases</span></a>
        <a href="@Url.Action("Index", "PurchaseReturn")" class="bosx-q"><span class="bosx-q-ic q3"><i class="fa fa-reply"></i></span><span class="bosx-q-t">Returns</span></a>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="box box-info"><div class="box-header with-border"><h3 class="box-title">Purchases trend &middot; 12 months</h3></div>
                <div class="box-body"><div class="bx-chart bx-chart-lg"><canvas id="bxArea"></canvas></div></div></div>
        </div>
        <div class="col-md-4">
            <div class="box box-primary"><div class="box-header with-border"><h3 class="box-title">Purchases vs Payments</h3></div>
                <div class="box-body"><div class="bx-chart bx-chart-lg"><canvas id="bxDonut"></canvas></div></div></div>
        </div>
    </div>
    <div class="row">
        <div class="col-md-8">
            <div class="box box-info"><div class="box-header with-border"><h3 class="box-title">Monthly purchases</h3></div>
                <div class="box-body"><div class="bx-chart bx-chart-md"><canvas id="bxBar"></canvas></div></div></div>
        </div>
        <div class="col-md-4">
            <div class="box box-warning"><div class="box-header with-border"><h3 class="box-title">Targets</h3></div>
                <div class="box-body" style="display:flex;justify-content:space-around;align-items:center;min-height:170px">
                    <div style="text-align:center"><div style="position:relative;width:118px;height:118px"><canvas id="bxG1"></canvas><div style="position:absolute;inset:0;display:grid;place-items:center;font-weight:600;color:#0ea5e9">72%</div></div><div style="font-size:12px;opacity:.7;margin-top:4px">Purchases</div></div>
                    <div style="text-align:center"><div style="position:relative;width:118px;height:118px"><canvas id="bxG2"></canvas><div style="position:absolute;inset:0;display:grid;place-items:center;font-weight:600;color:#10b981">66%</div></div><div style="font-size:12px;opacity:.7;margin-top:4px">Paid</div></div>
                </div></div>
        </div>
    </div>

    <div class="box box-info">
        <div class="box-header with-border">
            <h3 class="box-title">Latest Purchase Entry</h3>
            <div class="box-tools pull-right"><a href="@Url.Action("Create", "PurchaseEntry")" class="btn btn-flat btn-danger btn-sm"><i class="glyphicon glyphicon-plus"></i> Add Purchase Entry</a></div>
        </div>
        <div class="box-body"><div class="table-responsive">
            <table class="table no-margin" id="PurchaseTable">
                <thead><tr><th>Invoice</th><th>Supplier</th><th>Date</th><th>Total</th><th>Paid</th><th>Balance</th></tr></thead>
                <tbody></tbody>
            </table>
        </div></div>
        <div class="box-footer"><a href="@Url.Action("Index", "PurchaseEntry")" class="btn btn-sm btn-default btn-flat">View All Purchases</a></div>
    </div>
</div>

<script src="@Url.Content("~/Content/plugins/chartjs4/chart.umd.min.js")"></script>
<script>
    (function () {
        var BXChart = window.Chart; if (!BXChart) return;
        var tl = @Html.Raw(ViewBag.trendLabels ?? "[]"), ts = @Html.Raw(ViewBag.trendSales ?? "[]"), tp = @Html.Raw(ViewBag.trendPurchase ?? "[]");
        var grid = 'rgba(127,140,170,.14)';
        function draw() {
            var ae = document.getElementById('bxArea');
            if (ae && tl.length) {
                var cx = ae.getContext('2d');
                var g1 = cx.createLinearGradient(0, 0, 0, 280); g1.addColorStop(0, 'rgba(99,102,241,.30)'); g1.addColorStop(1, 'rgba(99,102,241,0)');
                var g2 = cx.createLinearGradient(0, 0, 0, 280); g2.addColorStop(0, 'rgba(34,211,238,.20)'); g2.addColorStop(1, 'rgba(34,211,238,0)');
                new BXChart(ae, { type: 'line', data: { labels: tl, datasets: [{ label: 'Purchases', data: ts, borderColor: '#6366f1', backgroundColor: g1, fill: true, tension: .4, borderWidth: 2, pointRadius: 0 }, { label: 'Payments', data: tp, borderColor: '#22d3ee', backgroundColor: g2, fill: true, tension: .4, borderWidth: 2, pointRadius: 0 }] }, options: { maintainAspectRatio: false, plugins: { legend: { position: 'top', labels: { boxWidth: 10, usePointStyle: true } } }, scales: { y: { grid: { color: grid } }, x: { grid: { display: false } } } } });
            }
            var de = document.getElementById('bxDonut');
            if (de) { var sP = ts.reduce(function (a, b) { return a + +b; }, 0), sPay = tp.reduce(function (a, b) { return a + +b; }, 0); new BXChart(de, { type: 'doughnut', data: { labels: ['Purchases', 'Payments'], datasets: [{ data: [sP, sPay], backgroundColor: ['#6366f1', '#22d3ee'], borderWidth: 0 }] }, options: { maintainAspectRatio: false, cutout: '66%', plugins: { legend: { position: 'bottom', labels: { boxWidth: 10, usePointStyle: true, padding: 14 } } } } }); }
            var be = document.getElementById('bxBar');
            if (be && tl.length) new BXChart(be, { type: 'bar', data: { labels: tl, datasets: [{ label: 'Purchases', data: ts, backgroundColor: '#6366f1', borderRadius: 6 }] }, options: { maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { grid: { color: grid } }, x: { grid: { display: false } } } } });
            var gg = function (id, v, c) { var e = document.getElementById(id); if (!e) return; new BXChart(e, { type: 'doughnut', data: { datasets: [{ data: [v, 100 - v], backgroundColor: [c, grid], borderWidth: 0 }] }, options: { maintainAspectRatio: false, cutout: '78%', plugins: { legend: { display: false }, tooltip: { enabled: false } } } }); var lbl = e.parentElement.querySelector('div'); if (lbl) lbl.textContent = v + '%'; };
            var pct = function (a) { if (!a || !a.length) return 0; var last = +a[a.length - 1] || 0; var mx = Math.max.apply(null, a.map(function (x) { return +x || 0; })); return mx > 0 ? Math.round(last / mx * 100) : 0; };
            gg('bxG1', pct(ts), '#0ea5e9'); gg('bxG2', pct(tp), '#10b981');
        }
        if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', draw); } else { draw(); }
    })();
</script>

@section scripts {
    <script type="text/javascript">
        $(document).ready(function () {
            function bxEsc(s) { return (s == null ? '' : String(s)).replace(/[&<>"]/g, function (c) { return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]; }); }
            function bxAvatar(name) {
                name = (name == null ? '' : String(name)).trim();
                var clean = name.replace(/^[0-9]+\s*[-–]\s*/, '');
                var parts = clean.split(/\s+/).filter(Boolean), ini = '';
                if (parts.length >= 2) ini = parts[0].charAt(0) + parts[1].charAt(0); else if (parts.length === 1) ini = parts[0].substring(0, 2);
                ini = (ini || '?').toUpperCase();
                var pal = ['#6366f1', '#22d3ee', '#10b981', '#f472b6', '#8b5cf6', '#0ea5e9', '#fbbf24', '#f43f5e'];
                var h = 0, i; for (i = 0; i < clean.length; i++) h = (h * 31 + clean.charCodeAt(i)) >>> 0;
                return '<span class="bx-av" style="background:' + pal[h % pal.length] + '">' + bxEsc(ini) + '</span><span class="bx-av-name">' + bxEsc(name) + '</span>';
            }
            function bxNum(v) { var n = parseFloat(v); if (isNaN(n)) return bxEsc(v); return '<span class="bx-num">' + n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + '</span>'; }
            function bxBalance(v) { var n = parseFloat(v); if (!isNaN(n) && Math.abs(n) < 0.005) return '<span class="bx-pill ok">Paid</span>'; return '<span class="bx-num bx-due">' + (isNaN(n) ? bxEsc(v) : n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })) + '</span>'; }
            function convertToDate(d) { if (!d) return ''; var m = /\/Date\((\d+)/.exec(d); var dt = m ? new Date(parseInt(m[1])) : new Date(d); if (isNaN(dt.getTime())) return d; var p = function (n) { return (n < 10 ? '0' : '') + n; }; return p(dt.getDate()) + '-' + p(dt.getMonth() + 1) + '-' + dt.getFullYear(); }

            $('#PurchaseTable').DataTable({
                responsive: true, "filter": false, "paging": false, "bInfo": false, "ordering": false,
                "ajax": { "url": '/Home/GetPurchaseEntry', "type": "POST", "datatype": "json" },
                "columns": [
                    { "data": "BillNo", "name": "BillNo" },
                    { "data": "Supplier", "name": "Supplier", "render": function (d) { return bxAvatar(d); } },
                    { "data": "PEDate", "name": "PEDate", "render": function (d) { return convertToDate(d); } },
                    { "data": "PEGrandTotal", "name": "PEGrandTotal", "className": "bx-amt", "render": function (d) { return bxNum(d); } },
                    { "data": "PEPaidAmount", "name": "PEPaidAmount", "className": "bx-amt", "render": function (d) { return bxNum(d); } },
                    { "data": "PEBalanceAmount", "name": "PEBalanceAmount", "className": "bx-amt", "render": function (d) { return bxBalance(d); } }
                ]
            });
        });

        /* ---- Period / Style / Theme controls + live KPI period switch ---- */
        var BX_PERIOD = @Html.Raw(ViewBag.periodJson ?? "null");
        function bxMoney(v) { v = +v || 0; var s = v < 0 ? '-' : ''; v = Math.abs(v); if (v >= 1e6) return s + 'AED ' + (v / 1e6).toFixed(2) + 'M'; if (v >= 1e3) return s + 'AED ' + (v / 1e3).toFixed(0) + 'K'; return s + 'AED ' + v.toFixed(2); }
        function bxInt(v) { return Math.round(+v || 0).toLocaleString(); }
        function bxSetDelta(el, d) { if (!el) return; if (d === null || d === undefined) { el.textContent = ''; el.className = 'bosx-kpi-d'; return; } var up = d >= 0; el.textContent = (up ? '▲ ' : '▼ ') + Math.abs(d).toFixed(1) + '%'; el.className = 'bosx-kpi-d ' + (up ? 'up' : 'dn'); }
        function bxApplyPeriod(p) {
            if (!BX_PERIOD || !BX_PERIOD[p]) return;
            var d = BX_PERIOD[p], g = function (id) { return document.getElementById(id); };
            if (g('bxV1')) g('bxV1').textContent = bxMoney(d.purchases);
            if (g('bxV2')) g('bxV2').textContent = bxMoney(d.payments);
            if (g('bxV3')) g('bxV3').textContent = bxMoney(d.returns);
            if (g('bxV4')) g('bxV4').textContent = bxInt(d.suppliers);
            bxSetDelta(g('bxD1'), d.dPurchases); bxSetDelta(g('bxD2'), d.dPayments); bxSetDelta(g('bxD3'), d.dReturns); bxSetDelta(g('bxD4'), d.dSuppliers);
            Array.prototype.forEach.call(document.querySelectorAll('.bosx-kpi-per'), function (e) { e.textContent = '· ' + p; });
        }
        function bxSeg(id, attr, cb) { var c = document.getElementById(id); if (!c) return; c.addEventListener('click', function (e) { var b = e.target.closest('button'); if (!b) return; c.querySelectorAll('button').forEach(function (x) { x.classList.remove('on'); }); b.classList.add('on'); cb(b.getAttribute('data-' + attr)); }); }
        function bxSyncSeg(id, attr, val) { var c = document.getElementById(id); if (!c) return; c.querySelectorAll('button').forEach(function (x) { x.classList.toggle('on', x.getAttribute('data-' + attr) === val); }); }
        bxSeg('bosxPeriod', 'p', function (p) { bxApplyPeriod(p); });
        bxSeg('bosxStyle', 's', function (s) { document.body.setAttribute('data-bosstyle', s); try { localStorage.setItem('bosxStyle', s); } catch (e) { } });
        bxSeg('bosxTheme', 't', function (t) { document.body.setAttribute('data-bostheme', t); try { localStorage.setItem('bosxTheme', t); } catch (e) { } });
        bxSyncSeg('bosxStyle', 's', document.body.getAttribute('data-bosstyle') || 'aurora');
        bxSyncSeg('bosxTheme', 't', document.body.getAttribute('data-bostheme') || 'light');
        bxApplyPeriod('month');
    </script>
}
