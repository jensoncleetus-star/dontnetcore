@{
    ViewBag.Title = "Restore Database";
    ViewBag.SubTitle = "Restore Database";
    ViewBag.Active = "Utility";
}
<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">Restore Database</h3>
    </div>
    <div class="box-body">
        @using (Html.BeginForm("Restore", "BackUpRestore", FormMethod.Post, new { @id = "createform", role = "form", @class = "form-horizontal"}))
        {
            <div class="form-group">
                <label class="control-label col-md-4">Enter File Path</label>
                <div class="col-sm-3">
                    @Html.TextBox("filepath", "", new { @class = "form-control" })
                </div>
            </div>
            <div class="box-footer col-md-12">
                <input type="submit" id="submit" class="btn btn-info col-sm-offset-5" value="Restore" />
                @*<input type="button" class="btn btn-default" value="Reset" id="btnreset" />*@
            </div>
        }
    </div>
</div>