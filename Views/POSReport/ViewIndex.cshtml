@{
    ViewBag.Title = "Search Sales Entry";
    ViewBag.SubTitle = "Sales Report";
    ViewBag.Active = "Reports";

}
<div class="box box-default" id="SReport">
    <input type="hidden" id="cname" value="@ViewBag.CName" />
    <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
    <input type="hidden" id="invoiceno" value="@ViewBag.InvoiceNo" />
    <input type="hidden" id="fromdate" value="@ViewBag.fromdate" />
    <input type="hidden" id="todate" value="@ViewBag.todate" />
    <div class="box-header with-border">
        <h3 class="box-title">View Sales Report</h3>
    </div>
    <div class="box-body">
        <div class="box-body">
            <table class="table table-bordered" id="UserTable">
                <thead>
                    <tr style="background-color: #d2d6de">
                        <td>SI No</td>
                        <td>Invoice No.</td>
                        <td>Date</td>
                        <td>Customer</td>
                        <td>Customer Type</td>
                        <td class="headeralign">Total Amt</td>
                        <td class="headeralign">Paid Amt</td>
                        <td class="headeralign">Balance Amt</td>
                        <td>Payment Method</td>
                        <td>Waiter</td>
                        <td>Cashier</td>
                    </tr>
                </thead>
                <tbody></tbody>
                <tfoot>
                    <tr>
                        <th>Total:</th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
@section Scripts {
    <script type="text/javascript">
        $(document).ready(function () {
            var oTable = $('#UserTable').DataTable({
                "processing": true, // for show progress bar
                "serverSide": true, // for process server side
                "filter": false, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
                // "bStateSave": true,
                responsive: true,
                "paging": true,
                "pageLength": 5000,
                "ordering": false,
                "ajax": {
                    "url": '/POSReport/GetAllSale',
                    "data": { seno: getQueryString1('seno'), customer: getParameterByName('customer'), type: getParameterByName('type'), fromdate: getParameterByName('from'), todate: getParameterByName('to'), custname: getParameterByName('custname'), ordertype: getParameterByName('ordertype'), cashier: getParameterByName('cashier'), waiter: getParameterByName('waiter'), payMethod: getParameterByName('payMethod'), custname: getParameterByName('custname'), PayMode: getParameterByName('PayMode') },
                    "type": "POST",
                    "datatype": "json"

                },
                "order": [[0, "desc"]],
                "columns": [
                     {
                         "data": "SalesEntryId", "name": "SalesEntryId",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                    { "data": "BillNo", "name": "BillNo" },
                    { "data": "SEDate", "name": "SEDate", "render": function (data) { return convertToDate(data); } },
                    {
                        "name": "Customer",
                        "data": function (data) {
                            if (data.CustomerType == 0) {
                                return data.Customer;
                            } else if (data.CustomerType == 1) {
                                return data.wCustomer;
                            } else {
                                return "";
                            }
                        }
                    },
                    {
                        "name": "CustomerType",
                        "data": function (data) {
                            if (data.CustomerType == 0) {
                                return "Cash";
                            }else {
                                return "Credit";
                            }
                        }
                    },
                    { "data": "SEGrandTotal", "name": "SEGrandTotal", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                    { "data": "SEPaidAmount", "name": "SEPaidAmount", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                    { "data": "SEBalanceAmount", "name": "SEBalanceAmount", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                    { "data": "PayMethod", "name": "PayMethod" },
                    { "data": "EmpName", "name": "EmpName" },
                    { "data": "User", "name": "User" },
                ],
                buttons: [//'copy', 'csv', 'excel', 'pdf', 'print'
                {
                    extend: 'print',//
                    title: "",
                    footer: true,
                    filename: function () {
                        return 'Sales-Report';
                    },
                    message: function () {
                        var head = '<table class="tblcompact table table-bordered"><thead>' +
						' <tr><th class="text-center"><h3 style="margin-top: 0px;">' + $('#cname').val() + '</h3>' + $('#caddress').val() + '<h4>Sales Report</h4></th></tr>' +
						' <tr><th><span class="text-left">Invoice No : ' + $('#invoiceno').val() + '</span><span class="text-right pull-right"> From :  ' + $('#fromdate').val() + ' To :' + $('#todate').val() + '</span></th></tr></thead><tbody><tr><td>';
                        return head;
                    }, customize: function (win) {
                        // $(win.document.body)
                        //.css('font-size', '10pt')
                        //.css('padding', '1px');
                        $(win.document.body).find('table, th,tr, td ')
                           // .css('border', 'inherit')
                            .css('font-size', '10pt')
                            .css('padding', '5px')
                            .addClass('compact');
                        $(win.document.body).append('</td></tr></tbody>')

                    }
                }, 'copy', 'csv', //'excel',
                //Excel
                {
                    extend: 'excel',//
                    title: "",
                    footer: true,
                    filename: function () {
                        return 'Sales-Report';
                    },
                    message: function () {
                        var head = '' + $('#cname').val() + '\n' +
                            '' + $('#caddress').val() + '\n' +
                            ' Sales Report \n' +
                            'Invoice No : ' + $('#invoiceno').val() + '\n' +
                            'From :  ' + $('#fromdate').val() + ' To :' + $('#todate').val() + '';
                        return head;
                    },
                    pageSize: 'A4',
                    exportOptions: {
                        columns: ':visible'
                    },
                }, {
              	    extend: 'pdf',//
              	    title: "",
              	    footer: true,
              	    filename: function () {
              	        return 'Sales-Report';
              	    },
              	    message: function () {
              	        var head = '' + $('#cname').val() + '\n' +
                            '' + $('#caddress').val() + '\n' +
                            ' Sales Report \n' +
                            'Invoice No : ' + $('#invoiceno').val() + '\n' +
                            'From :  ' + $('#fromdate').val() + ' To :' + $('#todate').val() + '';
              	        return head;
              	    },
              	    pageSize: 'A4',
              	    exportOptions: {
              	        columns: ':visible'
              	    },
              	    customize: function (doc) {
              	        doc.pageMargins = [10, 10, 10, 10];
              	        doc.defaultStyle.fontSize = 10;
              	        doc.styles.tableHeader.fontSize = 10;
              	        doc.styles.title.fontSize = 12;
              	        // Header font and bg color
              	        doc.styles.tableHeader.fillColor = '#d3d3d3';
              	        doc.styles.tableHeader.color = 'black';
              	        // Remove spaces around page title
              	        doc.content[0].text = doc.content[0].text.trim();

              	        doc.content[1].table.widths = [
                        '4%',
                        '10%',
                        '10%',
                        '10%',
                        '10%',
                        '10%',
                        '10%',
                        '10%',
                        '10%',
                        '8%',
                        '8%',
              	        ]

              	        //doc['header'] = (function () {
              	        //    return {
              	        //        columns: [
						//			{
						//			    alignment: 'left',
						//			    italics: true,
						//			    text: 'dataTables',
						//			    fontSize: 18,
						//			    margin: [10, 0]
						//			},
						//			{
						//			    alignment: 'right',
						//			    fontSize: 14,
						//			    text: 'Custom PDF export with dataTables'
						//			}
              	        //        ],
              	        //        margin: 20
              	        //    }
              	        //});
              	        var objLayout = {};
              	        // Horizontal line thickness
              	        objLayout['hLineWidth'] = function (i) { return .5; };
              	        // Vertikal line thickness
              	        objLayout['vLineWidth'] = function (i) { return .5; };
              	        //// Horizontal line color
              	        //objLayout['hLineColor'] = function (i) { return '#aaa'; };
              	        //// Vertical line color
              	        //objLayout['vLineColor'] = function (i) { return '#aaa'; };
              	        // Left padding of the cell
              	        objLayout['paddingLeft'] = function (i) { return 4; };
              	        // Right padding of the cell
              	        objLayout['paddingRight'] = function (i) { return 4; };
              	        // Inject the object in the document
              	        doc.content[1].layout = objLayout;
              	        // Footer font and bg color
              	        doc.styles.tableFooter.fillColor = '#d3d3d3';
              	        doc.styles.tableFooter.color = 'black';
              	    }
              	}

                ],

                sDom: "lBfr<'datatable-scroll't>ip",
                "lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                "footerCallback": function (row, data, start, end, display) {
                    var api = this.api(), data;

                    // Remove the formatting to get integer data for summation
                    var intVal = function (i) {
                        return typeof i === 'string' ?
                            i.replace(/[\$,]/g, '') * 1 :
                            typeof i === 'number' ?
                            i : 0;
                    };


                    // Total over all pages
                    total = api
                        .column(5)
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Total over this page
                    pageTotal = api
                        .column(5, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update footer
                    $(api.column(5).footer()).html(
                         pageTotal.toFixed(2)
                        //'$' + pageTotal + ' ( $' + total + ' total)'
                    );


                    // Total over all pages
                    total = api
                        .column(6)
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Total over this page
                    pageTotal = api
                        .column(6, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update footer
                    $(api.column(6).footer()).html(
                         pageTotal.toFixed(2)
                        //'$' + pageTotal + ' ( $' + total + ' total)'
                    );

                    // Total over all pages
                    total = api
                        .column(7)
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Total over this page
                    pageTotal = api
                        .column(7, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update footer
                    $(api.column(7).footer()).html(
                         pageTotal.toFixed(2)
                        //'$' + pageTotal + ' ( $' + total + ' total)'
                    );


                    var table = $('#UserTable').DataTable();
                    if (!table.data().any()) {
                        $('#UserTable tfoot').hide();
                    } else {
                        $('#UserTable tfoot').show();
                    }

                }
            });
            var type = $('#invoiceno').val();
            if (type != 'All') {
                var column1 = oTable.column(1);
                column1.visible(false);
            } else {
                var column1 = oTable.column(1);
                column1.visible(true);
            }
        });
    </script>
}


