@{

    ViewBag.Title = "Search Sales Entry";
    ViewBag.SubTitle = "Sales Report";
    ViewBag.Active = "Reports";
    string actData = "";
    string actData2 = "";
    string actData3 = "";
    string actData4 = "";
    string posfun = "";
    posfun = "PrintInvoice(e, \"sales\",\"inactive\",\"SalesEntry\");";
    @Html.Action("invoice", "InvoiceLayout", new { type = "Sale" })
}
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/bootstrap-timepicker")
}
@section Scripts {
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/num2words")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/bootstrap-timepicker")
    <script src="~/Content/js/salesinvoice2.js"></script>
    <script>
        $(document).ready(function () {
            $.ajax({
                url: '/CreditSale/downloadprint/?salesEntryId=' + @ViewBag.salesEntryId,
                type: "GET",
                contentType: false, // Not to set any content header
                processData: false, // Not to process data

                success: function (e) {


    @Html.Raw(posfun)
                    setTimeout(function () { window.location.href = '/SalesReport/Index'; }, '5000');//{ location.reload(); }, 'TimeOut');

                }


            });

        });
    </script>
    }