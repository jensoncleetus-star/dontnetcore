        // update button for price updator
        $('#modal-SettlementMode').on('submit', '#UpdateSettlement', function (e) {
            e.preventDefault();

            var TotalAmount     =   parseFloat($("#TotalAmount").val());
            var InvoiceAmount   =   parseFloat($("#InvoiceAmount").val());
            var BalanceAmount   =   parseFloat($("#BalanceAmount").val());
            var ChequeDate      =   $('#ChequeDates').val();
            var ChequeNo        =   $('#ChequeNo').val();
            var ChequeAccntYN   =   false;

            //To Find the Cheque Account is ticked or not
            $('.PymntDetails').each(function (index, element) {

                var PType = $('#PaymentType' + index).val();

                //To Set ChequeDetails ReadOnly
                if (PType == 2) {
                    var Amount = $('#Amount' + index).val();
                    if (Amount > 0) {
                        ChequeAccntYN = true;
                    }
                }
            });

            if (TotalAmount != InvoiceAmount) {
                alert("Total Amount should be equal to Invoice Amount : " + InvoiceAmount)
            }
            else if (BalanceAmount < 0) {
                alert("Balance Amount should be greater than or equal to zero..")
            }
            else if (ChequeAccntYN == true && (ChequeDate == null || ChequeDate == "")) {
                alert("Date Of Cheque should be entered..")
            }
            else if (ChequeAccntYN == true && (ChequeNo == null || ChequeNo == "")) {
                alert("Cheque Number should be entered..")
            }
            else {
                var fnval = $("#fnvalp").val();
                submitForm(fnval, "SubmitFromSettlement");
            }
        });

        $('#btnSettlementPrint').click(function () {
            PrintSettlement('@ViewBag.CName');
