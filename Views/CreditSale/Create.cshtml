        function taxinusedmat(type) {
            if (type != null) {
                if (type == 2) {
                    var TaxP = 0;
                    var tbody = $("#normalinvoiceused tbody");
                    if (tbody.children().length > 0) {
                        tbody.children("tr").each(function () {
                            var rowid = $(this).attr("id");
                            var item = $("#" + rowid + " .uitem_name").val();
                            var subtot = $("#" + rowid + " .usubtotal").val();
                            if (item != null) {
                                $("#" + rowid + " .utax_percentage").val(0);
                                $("#" + rowid + " .utax").val("0.00" + " (" + 0 + "%)");
                                $("#" + rowid + " .utot_tax").val(0);
                            }
                        });
                        // CalculatetblItemListSum();
                        // grandtotalcalculation();
                        //paidamountcalculation();
                    }
                } else {

                    var tbody = $("#normalinvoiceused tbody");
                    if (tbody.children().length > 0) {
                        tbody.children("tr").each(function () {
                            var rowid = $(this).attr("id");
                            var item = $("#" + rowid + " .uitem_name").val();
                            if (item != null) {
                                $.ajax({
                                    url: '/Item/GetItem',
                                    type: "GET",
                                    dataType: "JSON",
                                    data: { itemID: item },
                                    success: function (result) {
                                        $("#" + rowid + " .utax_percentage").val(result.Tax.toFixed(2));

                                        var quantity = $("#" + rowid + " .uquty").val();
                                        var rate = $("#" + rowid + " .utotrate").val();
                                        var subtotal = quantity * rate;
                                        $("#" + rowid + " .usubtotal").val(subtotal.toFixed(2));

                                        var itemdiscount = $("#" + rowid + " .uitem_discount").val();
                                        subtotal = subtotal - itemdiscount;

                                        var taxAmount = subtotal * (result.Tax / 100);
                                        var Total = subtotal + taxAmount;

                                        $("#" + rowid + " .utot_tax").val(taxAmount.toFixed(2));
                                        $("#" + rowid + " .utax").val(taxAmount.toFixed(2) + " (" + result.Tax + "%)");
                                    }
                                });
                            }
                        });
                    }
                }
            }
        }
        // Plain dropzone (no plugin). Files stay in #input-24 and upload after the invoice is Saved.
        (function () {
            function fmtSize(b) { return b > 1048576 ? (b / 1048576).toFixed(1) + ' MB' : Math.max(1, Math.round(b / 1024)) + ' KB'; }
            function renderSelected(files) {
                var $p = $('#qcSelPreview'); $p.empty();
                if (!files || !files.length) return;
                for (var i = 0; i < files.length; i++) {
                    var f = files[i], nm = $('<div>').text(f.name).html();
                    var isImg = /^image\//.test(f.type);
                    var icon = isImg ? ('<img src="' + URL.createObjectURL(f) + '" class="qc-doc-thumb">') : '<span class="qc-doc-ico"><i class="fa fa-file-o"></i></span>';
                    $p.append('<div class="qc-doc-item">' + icon + '<div class="qc-doc-meta"><span class="qc-doc-name" title="' + nm + '">' + nm + '</span><small>' + fmtSize(f.size) + '</small></div></div>');
                }
            }
            $(document).on('change', '#input-24', function () { renderSelected(this.files); });
            $(document).on('dragover', '#qcCreateDrop', function (e) { e.preventDefault(); e.stopPropagation(); $(this).addClass('dragover'); });
            $(document).on('dragleave', '#qcCreateDrop', function (e) { e.preventDefault(); e.stopPropagation(); $(this).removeClass('dragover'); });
            $(document).on('drop', '#qcCreateDrop', function (e) {
                e.preventDefault(); e.stopPropagation(); $(this).removeClass('dragover');
                var files = e.originalEvent.dataTransfer.files;
                try { var el = document.getElementById('input-24'); var dt = new DataTransfer(); for (var i = 0; i < files.length; i++) dt.items.add(files[i]); el.files = dt.files; } catch (err) { }
                renderSelected(files);
            });
        })();
        </script>
