@model QuickSoft.ViewModel.SalesEntryViewModel
@{
    ViewBag.Title = "Create";
    ViewBag.SubTitle = "Sales Entry";
    ViewBag.Active = "Transactions";
    ViewBag.BodyClass = "bosx-qc";   // premium overlay (CSS-only), same skin as Quotation Create/Edit
    long? chkCust = Model.Customer;
    string posfun = "";
    var TimeOut = @ViewBag.TMOut;
    string IRateCheck = "inactive";
    string sedate = "inactive";
    string SettlementMode = "inactive";
    string IBalanceCheck = "inactive";
    string OverideCLimit = "inactive";
}
<link href="~/Content/css/bosx-qc.css?v=20260702d" rel="stylesheet" />
@* rich CKEditor (formatting + "Add Image" upload) for the Terms & Conditions editor — same as Quotation *@
@Html.Partial("_BosxRichEditor")

<script>
    var crperiod = 0;
    var actualcrperiod = 0;
    var bonusclimableentry = 0;
</script>

@if (User.IsInRole("Dev") || User.IsInRole("ReadOnly Item Rate"))
{
    IRateCheck = "active";
}
@if (ViewBag.fixedsellingprice==true)
{
    IRateCheck = "active";
}
@if (User.IsInRole("Dev") || User.IsInRole("Read Only Sales Invoice Date"))
{
    sedate = "active";
}

@if (User.IsInRole("Dev") || User.IsInRole("Sales Tendering"))
{
    SettlementMode = "active";
}
@if (User.IsInRole("Dev") || User.IsInRole("Override Customer Credit Limit"))
{
    OverideCLimit = "active";
}
