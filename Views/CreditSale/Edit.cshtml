                                    GenerateSettlementMode(fnval, "Edit", EmpId, 0, taxexcept);
                                }
                                else {
                                    GenerateSettlementMode(fnval, "Edit", EmpId, @ViewBag.anothershowroom, taxexcept);

                                }

                                }
                        }
                        else {
                            submitForm(fnval, "");
                        }

                    } else if (fnval == "sendmail") {

                        if ($('#custEmailId').val() != "") {

                            //To Generate Popup For Settlement Mode
                            if ("@SettlementMode" == "active") {
                                var InvoiceAmount = $("#GrandTotal").val();
