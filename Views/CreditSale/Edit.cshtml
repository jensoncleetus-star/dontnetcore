                                //        alert("Invalid otp");
                                //    }
                                //}
                                //else {
                                //    alert("Your Superviser edit days over");
                                //}
                                $.ajax({
                                    url: '/CreditSale/confirmotp/?salesEntryId=' + SalesEntryId + '&otp=' + otp + "&purpose=" + purpose,
                                    type: "GET",
                                    contentType: false, // Not to set any content header
                                    processData: false, // Not to process data

                                    success: function (e) {
                                        if (e.status == true) {
                                            if (purpose == "Sales")
                                                setTimeout(function () { window.location.href = '/CreditSale/Edit/' + SalesEntryId; }, '0');//{ location.reload(); }, 'TimeOut');
                                            else if (purpose == "Purchase")
                                                setTimeout(function () { window.location.href = '/PurchaseEntry/Edit/' + SalesEntryId; }, '0');//{ location.reload(); }, 'TimeOut');
                                            else if (purpose == "SalesReturn")
                                                setTimeout(function () { window.location.href = '/CreditSaleReturn/Edit/' + SalesEntryId; }, '0');//{ location.reload(); }, 'TimeOut');
                                            else if (purpose == "override credit limit and credit period")
                                                return callBack(true);
                                        }
                                        else {
                                            return callBack(false);
                                        }
                                    }
                                });
                            }
                            else {

                                return callBack(false);


                            }
                        }

                        ,
                        error: function (err) {
                            return callBack(false);
                        }
                    });

                }


            else {
                alert("You can't Edit this, You have a limit of " + userEditDays / (60 * 24) + " days");
            }
