    .dataTables_filter input:focus { border-color:#6366f1 !important; box-shadow:0 0 0 3px rgba(99,102,241,.12); outline:none; }

    #SalesTable > thead > tr > td, #SalesTable > thead > tr > th { background:#f8fafc !important; color:#475569; font-size:10px; font-weight:800; text-transform:uppercase; letter-spacing:.4px; padding:10px 12px; border:0 !important; border-bottom:1.5px solid #e7eaf0 !important; }
    #SalesTable > tbody > tr > td { border:0 !important; border-bottom:1px solid #f1f5f9 !important; padding:9px 12px; font-size:12.5px; vertical-align:middle; }
