@model QuickSoft.ViewModel.TaxViewModel
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Edit Tax Group</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("GroupEdit", "Tax", FormMethod.Post, new { id = "editform" }))
            {
        <script type="text/javascript">
            $('form#editform').removeData("validator");
            $('form#editform').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#editform'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        <div class="row">
            <div class="col-md-12">
                <div class="form-group  col-md-12">
                    @Html.Label("Tax Name", null, new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.TaxName, new { htmlAttributes = new { @class = "form-control input-sm", autofocus = "autofocus" } })
                </div>
                <div class="form-group  col-md-12">
                    @Html.Label("Sub Taxs", null, new { @class = "control-label" }) *
                    @Html.DropDownListFor(m => m.child, (MultiSelectList)ViewBag.ParentModules, new { @id = "TaxSubGroup", @class = "form-control select2", @name = "TaxSubGroup[]", @multiple = "multiple" })
                </div>
                <div class="form-group  col-md-12">
                    @Html.Label("Percentage", null, new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.Percentage, new { htmlAttributes = new { @class = "form-control input-sm", autofocus = "autofocus", @readonly = "readonly" } })
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" value="Update" class="btn btn-info col-sm-offset-4"/>
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>
@section scripts{
    @Scripts.Render("~/js/jqueryval")
<script type="text/javascript">
        $(document).ready(function (){
            $('.select2').select2();
        });

        $(".select2").change(function () {
            var data = $(this).val();
            var parameters = {};
            parameters.array = data;
                var request = $.ajax({
                    async: true,
                    cache: false,
                    dataType: "json",
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    url: '/Tax/GetPercentage/',
                    data: JSON.stringify(parameters),
                    success: function (data)
                    {
                        $("[id$=Percentage]").val(data);
                    },
                });
        });
</script>
}