        public ActionResult GetCustomerbonus(long? SalesMan)
        {
            var draw = Request.Form.GetValues("draw").FirstOrDefault();
            var start = Request.Form.GetValues("start").FirstOrDefault();
            var length = Request.Form.GetValues("length").FirstOrDefault();

            int recordsTotal = 0;
            int pageSize = length != null ? Convert.ToInt32(length) : 0;
            int skip = start != null ? Convert.ToInt32(start) : 0;
            string search = Request.Form.GetValues("search[value]")[0];
            // dc.ChangeTracker.LazyLoadingEnabled = false; // if your table is relational, contain foreign key


            DateTime? fdate = null;
            DateTime? tdate = null;


            SaleType St = new SaleType();
            DateTime? hfdate = null;
            DateTime? htdate = System.DateTime.Now.Date;

            var v = (from b in db.Customers
                     join c in db.SalesEntrys on b.CustomerID equals c.Customer
                     join d in db.SalesReturns on c.SalesEntryId equals d.SalesEntryId into slrt
                     from d in slrt.DefaultIfEmpty()
                     where c.SEDate>=b.startbonusdate && c.SEDate<=htdate
                     
                     group new {b.CustomerID,b.CustomerName,c.SESubTotal,c.SEDiscount,d.SRSubTotal,d.SRDiscount} by b.CustomerID into gps
                     select new
                     {
                         CustomerID=gps.FirstOrDefault().CustomerID,
                         CustomerName=gps.FirstOrDefault().CustomerName,

                         currentbalance = gps.Sum(c=>(c.SESubTotal-c.SEDiscount))-((decimal?)gps.Sum(c=>(c.SRSubTotal==null)?0: (c.SRSubTotal - c.SRDiscount))??0) 
                        

                     });
            if (!string.IsNullOrEmpty(search) && !string.IsNullOrWhiteSpace(search))
            {
                // Apply search   
                v = v.Where(
                    p => p.CustomerName.ToString().ToLower().Contains(search.ToLower()) ||
                    p.CustomerName.ToString().ToLower().StartsWith(search.ToLower()) ||
                    p.CustomerName.ToString().ToLower().EndsWith(search.ToLower()));
            }

            v = v.OrderByDescending(o => o.currentbalance);
            var data = v.ToList();
            recordsTotal = v.Count();

            JavaScriptSerializer javaScriptSerializer = new JavaScriptSerializer();
            javaScriptSerializer.MaxJsonLength = Int32.MaxValue;
            string result = javaScriptSerializer.Serialize(new { draw = draw, recordsFiltered = recordsTotal, recordsTotal = recordsTotal, data = data });
            var results = new ContentResult
            {
                Content = result,
                ContentType = "application/json"
            };
            return results;

        }

