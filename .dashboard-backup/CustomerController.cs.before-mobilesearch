        [HttpPost]
        [QkAuthorize(Roles = "Dev,Delete Customer")]
        public ActionResult DeleteAllCustomer(long[] bill)
        {
            Int32 count = 0;
            Int32 notdel = 0;
            foreach (var arr in bill)
            {
                var chk = (DeleteCust(arr) == true) ? count++ : notdel++;
            }
            if (count > 0 && notdel > 0)
            {
                Success("Deleted " + count + " Customers, Unable to Delete " + notdel + " Customers. ", true);
            }
            else if (notdel > 0)
            {
                Danger("Unable to Delete " + notdel + " Customers.", true);
            }
            else
            {
                Success("Deleted " + count + " Customers.", true);
            }
            return RedirectToAction("Index", "Customer");
        }

        private Boolean DeleteCust(long custid)
        {
            var Msg = chkDeleteWithMsg(custid);
            if (Msg != null)
            {
                return false;
            }
            else
            {
                return DeleteFn(custid);
            }

        }
        public bool DeleteFn(long custid)
        {
            var UserId = User.Identity.GetUserId();
            Customer cust = db.Customers.Find(custid);
            if (cust != null)

            {



                var custcon = db.CustomerConversions.Where(a => a.CustomerID == custid);
                if (custcon != null)
                {
                    db.CustomerConversions.RemoveRange(db.CustomerConversions.Where(a => a.CustomerID == custid));
                    db.SaveChanges();
                }
                    Accounts acc = db.Accountss.Find(cust.Accounts);
                if (acc != null)
                {
                    db.Accountss.RemoveRange(db.Accountss.Where(a => a.AccountsID == cust.Accounts));
                    db.SaveChanges();
                }
                bool delete = com.DeleteAllAccountTransaction("Opening Balance", acc.AccountsID);
                Contact con = db.Contacts.Find(cust.Contact);
                if (con != null)
                {
                    db.Contacts.RemoveRange(db.Contacts.Where(a => a.ContactID == cust.Contact));
                    var mobile = db.Mobiles.Where(a => a.Contact == cust.Contact);
                    if (mobile != null)
                    {
                        db.Mobiles.RemoveRange(db.Mobiles.Where(a => a.Contact == cust.Contact));
                        db.SaveChanges();
                    }
                }
                var custmer = db.Customers.Where(a => a.CustomerID == custid).ToList();
                if (custmer.Any())
                {

                    db.Customers.RemoveRange(db.Customers.Where(a => a.CustomerID == custid));
                    db.SaveChanges();
                }





                com.addlog(LogTypes.Deleted, UserId, "Customer", "Customers", findip(), cust.CustomerID, "Customer Deleted Successfully");
            }
            return true;
        }
        public string chkDeleteWithMsg(long id)
        {
            string msg = null;
            Customer cust = db.Customers.Find(id);
            if (cust != null)
            {
                if (db.SalesEntrys.Any(c => c.Customer == id))
                {
                    msg = "Customer Already used in Sales Entry !!";
                }
                else if (db.SalesReturns.Any(c => c.Customer == id))
                {
                    msg = "Customer Already used in Sales Return !!";
                }
                else if (db.Quotations.Any(c => c.Customer == id))
                {
                    msg = "Customer Already used in Quotations !!";
                }
                else if (db.Deliverynotes.Any(c => c.Customer == id))
                {
                    msg = "Customer Already used in Delivery Notes !!";
                }
                else if (db.ProFormas.Any(c => c.Customer == id))
                {
                    msg = "Customer Already used in ProForma !!";
                }
                else if (db.SalesOrders.Any(c => c.Customer == id))
                {
                    msg = "Customer Already used in Sales Order !!";
                }
                else if (db.JobCards.Any(c => c.Customer == id))
                {
                    msg = "Customer Already used in JobCard !!";
                }
                else if (db.Projects.Any(c => c.Customer == id))
                {
                    msg = "Customer Already used in Project !!";
                }
                else if (db.ProTasks.Any(c => c.CustomerID == id))
                {
                    msg = "Customer Already used in Task !!";
                }
                //checking from leadcustomerrelations
                else if (db.leadcustomerrelation.Any(c => c.customerid == id))
                {
                    msg = "Customer Already used in Leads !!";
                }
                //end
                else if (db.MtFromPartys.Any(c => c.Party == cust.Accounts))
                {
                    msg = "Item Already used in Materials Received From Party Entry !!";
                }
                else if (db.MtToPartys.Any(c => c.Party == cust.Accounts))
                {
                    msg = "Item Already used in Materials Issued to Party Entry !!";
                }
                else if (db.Payments.Any(x => x.PayFrom == cust.Accounts) || db.Payments.Any(x => x.PayTo == cust.Accounts))
                {
                    msg = "Customer Already used in Payment !!";
                }
                else if (db.Receipts.Any(x => x.PayFrom == cust.Accounts) || db.Receipts.Any(x => x.PayTo == cust.Accounts))
                {
                    msg = "Customer Already used in Receipt !!";
                }
                else if (db.Journals.Any(x => x.PayFrom == cust.Accounts) || db.Journals.Any(x => x.PayTo == cust.Accounts))
                {
                    msg = "Customer Already used in Journal !!";
                }
                else if (db.HireReturns.Any(c => c.Customer == id))
                {
                    msg = "Customer Already used in HireReturn !!";
                }
                else
                {
                    msg = null;
                }
            }
            return msg;
        }

