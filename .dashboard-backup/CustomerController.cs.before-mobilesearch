                // Attach contact info to each row of the current page. The legacy code additionally INNER-joined the
                // page to "customers that have a SalesEntry/ProTask/Quotation" and then overwrote recordsTotal with
                // that filtered page count -- which truncated the customer list to only active customers (~52) for
                // every page size except 50. That filter + the recordsTotal override are dropped so the full list
                // pages correctly at any page size; recordsTotal stays the real total computed above.
                foreach (var o in data)
                    o.mobmodel = contactslist.Where(xx => xx.ID == o.id).ToList();
            }
            JavaScriptSerializer javaScriptSerializer = new JavaScriptSerializer();
            javaScriptSerializer.MaxJsonLength = Int32.MaxValue;
            string result = javaScriptSerializer.Serialize(new { draw = draw, recordsFiltered = recordsTotal, recordsTotal = recordsTotal, data = data });
