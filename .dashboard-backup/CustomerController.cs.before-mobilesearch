                                  from d in acc.DefaultIfEmpty()
                                  join j in db.Mobiles on b.Contact equals j.Contact into mobi
                                  from j in mobi.DefaultIfEmpty()
                                  where (d.Alias.ToLower().Contains(q.ToLower()) || b.CustomerName.ToLower().Contains(q.ToLower()) || b.CustomerCode.ToLower().Contains(q.ToLower()) || d.Alias.Contains(q) || b.CustomerName.Contains(q) || b.CustomerCode.Contains(q) || c.Phone.Replace(" ", "").Contains(q) || j.MobileNum.Replace(" ", "").Contains(q)
