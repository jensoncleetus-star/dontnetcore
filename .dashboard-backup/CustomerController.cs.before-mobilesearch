        public Boolean UpdateSale(ReferenceAccountViewModel arr, long CustId, string UserId, long branch)
        {
            var saleentry = db.SalesEntrys.Where(a => a.BillNo == arr.Invoice && a.Status == 0).FirstOrDefault();

            SEPayment SEpay = db.SEPayments.Where(a => a.SalesEntry == saleentry.SalesEntryId).FirstOrDefault();

            SEpay.SEBillAmount = (decimal)arr.Amount;
            db.Entry(SEpay).State = EntityState.Modified;
            db.SaveChanges();

            return true;
        }

