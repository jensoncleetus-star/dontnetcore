        public void DeleteBills(SalesEntry SEen)
        {
            var SEP = db.SEPayments.Where(a => a.SalesEntry == SEen.SalesEntryId).FirstOrDefault();
            if (SEP != null)
            {
                db.SEPayments.RemoveRange(db.SEPayments.Where(a => a.SalesEntry == SEen.SalesEntryId));
            }

            var rec = db.Receipts.Where(a => a.Reference == SEen.SalesEntryId && a.RefType == "Sales").FirstOrDefault();
            if (rec != null)
            {
                db.Receipts.RemoveRange(db.Receipts.Where(a => a.Reference == SEen.SalesEntryId && a.RefType == "Sales"));
            }

            var recbill = db.ReceiptBills.Where(a => a.InvoiceNo == SEen.SalesEntryId && a.BillType == "Sales" && a.Type == "Against Reference").ToList();
            if (recbill != null)
            {
                var recbillz = db.ReceiptBills.Where(a => a.InvoiceNo == SEen.SalesEntryId && a.BillType == "Sales" && a.Type == "Against Reference").ToList();
                recbillz.ForEach(a =>
                {
                    a.Type = "New Reference";
                    a.BillType = null;
                    a.InvoiceNo = null;
                });
                db.SaveChanges();
            }
            db.SalesEntrys.Remove(SEen);
            db.SaveChanges();
        }

