{
  // Copy this file to the deploy folder as  appsettings.Production.json  and fill in the values.
  // One copy PER BRANCH (each branch = its own database + its own Windows service + its own port).
  "ConnectionStrings": {
    // REQUIRED. Point at the branch's REAL database, using a LEAST-PRIVILEGE login (db_datareader +
    // db_datawriter + EXECUTE), never sa. The app refuses to start in Production without this.
    "DefaultConnection": "Server=YOUR_SQL_SERVER;Database=YOUR_BRANCH_DB;User Id=quicksoft_app;Password=********;MultipleActiveResultSets=true;TrustServerCertificate=True;Encrypt=False"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  // SECURITY — go-live HTTPS. Set RequireHttps to TRUE once every access path is HTTPS (Kestrel :8443
  // with the .pfx below, or TLS terminated on IIS/nginx in front). It turns on UseHttpsRedirection.
  // Leave FALSE while any plain-HTTP access still exists, or those users get redirect-looped/broken.
  // (Auth/session/antiforgery cookies are already sent Secure automatically under HTTPS.)
  "Security": {
    "RequireHttps": false
  },
  // SMTP password — the app reads it from the ENV VAR  Smtp__Password  (never hardcoded in the binary).
  // On the service host run:  setx Smtp__Password "the-new-rotated-mailbox-password" /M   then restart the
  // service. (SMTP host/username come from the company's SMTP-settings row, or the in-app fallback.)
  // OPTIONAL — serve HTTPS straight from Kestrel (skip if you terminate TLS on IIS/nginx in front).
  // Provide a .pfx and uncomment; then use  --urls https://0.0.0.0:8443  when installing the service.
  //"Kestrel": {
  //  "Certificates": {
  //    "Default": {
  //      "Path": "C:\\QuickSoft\\certs\\quicksoft.pfx",
  //      "Password": "********"
  //    }
  //  }
  //},
  // Pin to the REAL hostname(s)/IP(s) this branch is reached by (semicolon-separated). Avoid "*" in prod.
  // e.g. "AllowedHosts": "erp.yourcompany.com;192.168.35.222;localhost"
  "AllowedHosts": "*"
}
