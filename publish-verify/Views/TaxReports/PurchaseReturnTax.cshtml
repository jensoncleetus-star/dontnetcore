

@{
    ViewBag.Title = "Search Purchase Return Tax";
    ViewBag.SubTitle = "Purchase Return Tax";
    ViewBag.Active = "Tax Reports";

}
<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">Search Purchase Return Tax</h3>
    </div>
    <div class="box-body">
        <form id="search-form">
            <input type="hidden" id="cname" value="@ViewBag.CName" />
            <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
            <div class="form-group col-md-4">
                @Html.Label("Invoice No", null, new { @class = "control-label" })
                @Html.TextBox("InvoiceNo", "", new { @class = "form-control input-sm" })
            </div>
            <div class="form-group col-md-4">
                @Html.Label("Supplier Type", null, new { @class = "control-label" })
                @Html.DropDownList("ddlType", new SelectList(new List<SelectListItem>
                    {
                        new SelectListItem() {Text = "All", Value=""},
                        new SelectListItem() {Text = "Credit", Value="0"},
                        new SelectListItem() {Text = "Cash", Value="1"}
                    }, "Value", "Text"), new { @class = "form-control input-sm", @name = "ddlType", @onchange = "customertype()" })
            </div>
            <div class="form-group col-md-4">
                @Html.Label("Supplier", null, new { @class = "control-label" })
                @Html.DropDownList("ddlSupplierr", (SelectList)ViewBag.Supplier, new { @class = "form-control input-sm" })
            </div>
            @*<div class="form-group col-md-4">
                @Html.Label("Branch", null, new { @class = "control-label" })
                @Html.DropDownList("ddlBranch", (SelectList)ViewBag.Branch, new { @class = "form-control input-sm" })
            </div>*@
            <div class="form-group col-md-4">
                @Html.Label("From", null, new { @class = "control-label" })
                <div class="input-group date">
                    @Html.TextBox("From", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                    <div class="input-group-addon">
                        <i class="fa fa-calendar"></i>
                    </div>
                </div>
            </div>
            <div class="form-group col-md-4">
                @Html.Label("To", null, new { @class = "control-label" })
                <div class="input-group date">
                    @Html.TextBox("To", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                    <div class="input-group-addon">
                        <i class="fa fa-calendar"></i>
                    </div>
                </div>
            </div>
            <div class="form-group col-md-4">
                @Html.Label("Emirate", null, new { @class = "control-label" })
                @Html.DropDownList("Emirate", new SelectList(new List<SelectListItem>
                    {
                        new SelectListItem() {Text = "All", Value=""},
                        new SelectListItem() {Text = "Abu Dhabi", Value="Abu Dhabi"},
                        new SelectListItem() {Text = "Ajman", Value="Ajman"},
                        new SelectListItem() {Text = "Dubai", Value="Dubai"},
                        new SelectListItem() {Text = "Fujairah", Value="Fujairah"},
                        new SelectListItem() {Text = "Ras al-Khaimah", Value="Ras al-Khaimah"},
                        new SelectListItem() {Text = "Sharjah", Value="Sharjah"},
                        new SelectListItem() {Text = "Umm al-Quwain", Value="Umm al-Quwain"}
                    }, "Value", "Text"), new { @class = "form-control input-sm" })
            </div>
            <div class="box-footer col-md-12">
                <button type="submit" class="btn btn-info col-sm-offset-5" id="btn">Submit</button>
                <button type="button" class="btn btn-default" onclick="@("window.location.href='/Home/Index'");">Cancel</button>
            </div>
        </form>
    </div>
</div>

<div class="box box-default" id="PTaxReport">
    <div class="box-header with-border">
        <h3 class="box-title">View Purchase Return Tax Report</h3>
    </div>
    <div class="box-body">
        <div class="box-body">
            <table class="display table table-bordered" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td>S/N</td>
                        <td>Invoice No.</td>
                        <td>Date</td>
                        <td>Supplier</td>
                        <td class="headeralign">Total Amount</td>
                        <td class="headeralign">Purchase Amount</td>
                        <td class="headeralign">Discount</td>
                        <td class="headeralign">Tax Amount</td>
                    </tr>
                </thead>
                <tbody></tbody>
                <tfoot>
                    <tr>
                        <th>Total:</th>
                        <th colspan="3"></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
}
@section Scripts {
    @Scripts.Render("~/js/bootstrap-datepicker")
    <script type="text/javascript">
        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        })

        $(document).ready(function () {
            //for set default date 
            $('#To').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });
            $('#From').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });

            var date = new Date();
            var today = new Date(date.getFullYear(), date.getMonth(), date.getDate());
            var priordate = new Date(new Date().setDate(today.getDate() - 30));
            $('#To').datepicker('setDate', today);
            $('#From').datepicker('setDate', priordate);
            //---

            $('#PTaxReport').hide();
            $("#ddlSupplierr").select2({
                placeholder: 'Search Supplier by Name or Code',
                minimumInputLength: 0,
                ajax: {
                    url: "/Supplier/SearchSupplier",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term,
                            page: params.page,
                            x: "all"
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;

                        return {
                            results: data
                        };
                    },
                    cache: true
                },
            });

            $("#ddlBranch").select2({
                placeholder: 'Search Branch by Name or Code',
                minimumInputLength: 0,
                ajax: {
                    url: "/Branch/SearchBranch",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term,
                            page: params.page,
                            x: "all"
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;

                        return {
                            results: data
                        };
                    },
                    cache: true
                },
            });

        });
            jQuery(function ($) {
                oTable = $('#UserTable').DataTable({
                    "processing": true, // for show progress bar
                    "serverSide": true, // for process server side
                    "filter": false, // this is for disable filter (search box)
                    "orderMulti": false, // for disable multiple column at once
                    // "bStateSave": true,
                    "bLengthChange": false,
                    "paging": false,
                    "deferLoading": 0,
                    "ordering": false,
                    "columnDefs": [{
                        "targets": [4, 5, 6, 7],
                        "sClass": "numberright"
                    }],
                    "ajax": {
                        "url": '/TaxReports/GetPurchaseReturnTax',
                        "data": function ( data ) {
                            data.vno = $('#InvoiceNo').val();
                          //  data.branch = $('#ddlBranch').val();
                            data.supplier = $('#ddlSupplierr').val();
                            data.type = $('#ddlType').val();
                            data.fromdate = $('#From').val();
                            data.todate = $('#To').val();
                            data.emirates = $('#Emirate').val();
                        },
                        "type": "POST",
                        "datatype": "json"
                    },
                    "order": [[0, "desc"]],
                    "columns": [
                         {
                             "data": "PurchaseReturnId", "name": "PurchaseReturnId",
                             "render": function (data, type, row, meta) {
                                 return meta.row + meta.settings._iDisplayStart + 1;
                             }
                         },
                     { "data": "BillNo", "name": "BillNo" },
                     { "data": "PRDate", "name": "PRDate", "render": function (data) { return convertToDate(data); } },
                     { "data": "Supplier", "name": "Supplier" },
                     { "data": "PRSubTotal", "name": "PRSubTotal", render: $.fn.dataTable.render.number(",", ".", 2) },
                     { "data": "PRGrandTotal", "name": "PRGrandTotal", render: $.fn.dataTable.render.number(",", ".", 2) },
                     { "data": "PRDiscount", "name": "PRDiscount", render: $.fn.dataTable.render.number(",", ".", 2) },
                     { "data": "PRTaxAmount", "name": "PRTaxAmount", render: $.fn.dataTable.render.number(",", ".", 2) },
                    ],
                    buttons: [//'copy', 'csv', 'excel', 'pdf', 'print'
             {
                 extend: 'print',//
                 title: "",
                 footer: true,
                 filename: function () {
                     return 'PurchaseReturn-Tax';
                 },
                 message: function()
                 {
                     var head = '<table class="tblcompact table table-bordered"><thead>' +
                     ' <tr><th class="text-center"><h3 style="margin-top: 0px;">' + $('#cname').val() + '</h3>' + $('#caddress').val() + '<h4>Purchase Return Tax Report</h4></th></tr>' +
                     ' <tr><th><span class="text-left"></span><span class="text-right pull-right"> From :  ' + $('#From').val() + ' To :' + $('#To').val() + '</span></th></tr></thead><tbody><tr><td>';
                     return head;
                 },
                 customize: function (win) {
                     // $(win.document.body)
                     //.css('font-size', '10pt')
                     //.css('padding', '1px');
                     $(win.document.body).find('table, th,tr, td ')
                        // .css('border', 'inherit')
                         .css('font-size', '10pt')
                         .css('padding', '5px')
                         .addClass('compact');
                     $(win.document.body).append('</td></tr></tbody>')

                 }
             }, 'copy', 'csv', //'excel',
             {
                 extend: 'excel',//
                 title: "",
                 footer: true,
                 filename: function () {
                     return 'PurchaseReturn-Tax';
                 },
                 message: function () {
                     var head = '' + $('#cname').val() + '\n' +
                        '' + $('#caddress').val() + '\n' +
                        ' Purchase Return Tax Report \n' +
                        //'Invoice No : ' + $('#InvoiceNo').val() + '\n' +
                        'From :  ' + $('#From').val() + ' To :' + $('#To').val() + '';
                     return head;
                 },
                 pageSize: 'A4',
                 exportOptions: {
                     columns: [0, 1, 2, 3, 4, 5, 6, 7]
                 },
             },
             {
                 extend: 'pdf',//
                 title: "",
                 footer: true,
                 filename: function () {
                     return 'PurchaseReturn-Tax';
                 },
                 message: function () {
                     var head = '' + $('#cname').val() + '\n' +
                        '' + $('#caddress').val() + '\n' +
                        ' Purchase Return Tax Report \n' +
                        //'Invoice No : ' + $('#InvoiceNo').val() + '\n' +
                        'From :  ' + $('#From').val() + ' To :' + $('#To').val() + '';
                     return head;
                 },
                 pageSize: 'A4',
                 exportOptions: {
                     columns: [0, 1, 2, 3, 4, 5, 6, 7]
                 },
                 customize: function (doc) {
                     doc.pageMargins = [10, 10, 10, 10];
                     doc.defaultStyle.fontSize = 10;
                     // Header font and bg color
                     doc.styles.tableHeader.fillColor = '#d3d3d3';
                     doc.styles.tableHeader.color = 'black';
                     doc.styles.tableHeader.fontSize = 10;
                     doc.styles.title.fontSize = 12;
                     // Remove spaces around page title
                     doc.content[0].text = doc.content[0].text.trim();



                     doc.content[1].table.widths = [
                     '10%',
                     '10%',
                     '15%',
                     '13%',
                     '13%',
                     '13%',
                     '13%',
                     '13%'
                     ]

                     var objLayout = {};
                     // Horizontal line thickness
                     objLayout['hLineWidth'] = function (i) { return .5; };
                     // Vertikal line thickness
                     objLayout['vLineWidth'] = function (i) { return .5; };
                     //// Horizontal line color
                     //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                     //// Vertical line color
                     //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                     // Left padding of the cell
                     objLayout['paddingLeft'] = function (i) { return 4; };
                     // Right padding of the cell
                     objLayout['paddingRight'] = function (i) { return 4; };
                     // Inject the object in the document
                     doc.content[1].layout = objLayout;
                     // Footer font and bg color
                     doc.styles.tableFooter.fillColor = '#d3d3d3';
                     doc.styles.tableFooter.color = 'black';
                 }


             },

                    ],

                    sDom: "lBfr<'datatable-scroll't>ip",
                    "lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                    "footerCallback": function (row, data, start, end, display) {
                        var api = this.api(), data;

                        // Remove the formatting to get integer data for summation
                        var intVal = function (i) {
                            return typeof i === 'string' ?
                                i.replace(/[\$,]/g, '') * 1 :
                                typeof i === 'number' ?
                                i : 0;
                        };



                        // Total over all pages
                        total = api
                            .column(4)
                            .data()
                            .reduce(function (a, b) {
                                return intVal(a) + intVal(b);
                            }, 0);

                        // Total over this page
                        pageTotal = api
                            .column(4, { page: 'current' })
                            .data()
                            .reduce(function (a, b) {
                                return intVal(a) + intVal(b);
                            }, 0);

                        // Update footer
                        $(api.column(4).footer()).html(
                             pageTotal.toFixed(2)
                            //'$' + pageTotal + ' ( $' + total + ' total)'
                        );

                        // Total over all pages
                        total = api
                            .column(5)
                            .data()
                            .reduce(function (a, b) {
                                return intVal(a) + intVal(b);
                            }, 0);

                        // Total over this page
                        pageTotal = api
                            .column(5, { page: 'current' })
                            .data()
                            .reduce(function (a, b) {
                                return intVal(a) + intVal(b);
                            }, 0);

                        // Update footer
                        $(api.column(5).footer()).html(
                             pageTotal.toFixed(2)
                            //'$' + pageTotal + ' ( $' + total + ' total)'
                        );


                        // Total over all pages
                        total = api
                            .column(6)
                            .data()
                            .reduce(function (a, b) {
                                return intVal(a) + intVal(b);
                            }, 0);

                        // Total over this page
                        pageTotal = api
                            .column(6, { page: 'current' })
                            .data()
                            .reduce(function (a, b) {
                                return intVal(a) + intVal(b);
                            }, 0);

                        // Update footer
                        $(api.column(6).footer()).html(
                             pageTotal.toFixed(2)
                            //'$' + pageTotal + ' ( $' + total + ' total)'
                        );


                        // Total over all pages
                        total = api
                            .column(7)
                            .data()
                            .reduce(function (a, b) {
                                return intVal(a) + intVal(b);
                            }, 0);

                        // Total over this page
                        pageTotal = api
                            .column(7, { page: 'current' })
                            .data()
                            .reduce(function (a, b) {
                                return intVal(a) + intVal(b);
                            }, 0);

                        // Update footer
                        $(api.column(7).footer()).html(
                             pageTotal.toFixed(2)
                            //'$' + pageTotal + ' ( $' + total + ' total)'
                        );

                        var table = $('#UserTable').DataTable();
                        if (!table.data().any()) {
                            $('#UserTable tfoot').hide();
                        } else {
                            $('#UserTable tfoot').show();
                        }

                    }
                });
                $('#search-form').on('submit', function (e) {
                    e.preventDefault();
                    oTable.draw();
                    $('#PTaxReport').show();
                });

                $('#UserTable tbody').on('click', 'tr', function () {
                    if ($(this).hasClass('selected')) {
                        $(this).removeClass('selected');
                    }
                    else {
                        oTable.$('tr.selected').removeClass('selected');
                        $(this).addClass('selected');
                        $(this).addClass('dataTables_row');
                    }
                });
            });


            function reload_table() {
                oTable.clear().draw();
                oTable.ajax.reload(null, false); //reload datatable ajax
            }

    </script>
}




