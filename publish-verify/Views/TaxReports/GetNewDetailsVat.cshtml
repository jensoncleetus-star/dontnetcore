@model QuickSoft.ViewModel.VatViewModel
@{

    ViewBag.Title = "Search VAT";
    ViewBag.SubTitle = "VAT Report";
    ViewBag.Active = "Tax";
    string actData = "";
}
<div class="box box-default" id="LReport">
    <div class="box-header with-border">
        <h3 class="box-title">VAT Report</h3>
    </div>
    <div class="box-body">
        <div class="box-body">
            <input type="hidden" id="type" value="@Convert.ToString(Model.type)" />
            <input type="hidden" id="cname" value="@ViewBag.CName" />
            <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
            <input type="hidden" id="fromdate" value="@Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.from))" />
            <input type="hidden" id="todate" value="@Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.to))" />
            <table class="display table table-bordered table-hover" id="UserTable">
                <thead>
                    <tr>
                        <td colspan="7">
                            From : @Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.from))  - @Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.to))
                        </td>


                    </tr>
                    <tr class="bg-gray">
                        <td>Date</td>
                        <td>Particulars</td>
                        <td>TRN</td>
                        <td>Vch Type</td>
                        <td>Vch No</td>
                        @if (Convert.ToString(Model.type) != "Expense")
                        {
                            <td>Taxable Value</td>
                        }
                        <td>Taxable Amount</td>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Vat)
                    {
                        <tr>
                            <td>@Convert.ToString(string.Format("{0:dd-MM-yyyy}", item.Date))</td>
                            <td>@Html.DisplayFor(m => item.RAccount)</td>
                            <td>@Html.DisplayFor(m => item.TRN)</td>
                            <td>@Html.DisplayFor(m => item.Type)</td>
                            @if (item.Type == "Sale")
                            {
                                <td><a href="/CreditSale/Edit/@item.Reference" target="new">@Html.DisplayFor(m => item.Invoice)- Details</td>
                            }
                            else if (item.Type == "Sale Return")
                            {
                                <td><a href="/CreditSaleReturn/Edit/@item.Reference" target="new">@Html.DisplayFor(m => item.Invoice)- Details</td>
                            }
                            else if (item.Type == "Purchase")
                            {
                                <td><a href="/PurchaseEntry/Edit/@item.Reference" target="new">@Html.DisplayFor(m => item.Invoice)- Details</td>
                            }
                            else if (item.Type == "Purchase Return")
                            {
                                <td><a href="/PurchaseReturn/Edit/@item.Reference" target="new">@Html.DisplayFor(m => item.Invoice)- Details</td>
                            }
                            else if (item.Type.Contains("Journal Entry"))
                            {
                                <td><a href="/JournalV/Edit/@item.Reference" target="new">@Html.DisplayFor(m => item.Invoice)- Details</td>
                            }
                            else
                            {
                                <td>
                                    @Html.DisplayFor(m => item.Invoice)
                                </td>
                            }

                            @*<td>@Html.DisplayFor(m => item.Invoice)</td>*@

                            @if (item.Type != "Journal Entry")
                            {
                                <td>@Html.DisplayFor(m => item.Amount)</td>
                            }
                            <td>
                                @if (item.Credit == 0)
                                {
                                    @Html.DisplayFor(m => item.Debit)
                                }
                                @if (item.Debit == 0)
                                {
                                    @Html.DisplayFor(m => item.Credit)
                                }
                            </td>

                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td>Total</td>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td></td>
                        @if (Convert.ToString(Model.type) != "Expense")
                        {
                            <td>@Html.DisplayFor(m => m.Amount)</td>
                        }

                        <td>@Html.DisplayFor(m => m.Payable)</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

