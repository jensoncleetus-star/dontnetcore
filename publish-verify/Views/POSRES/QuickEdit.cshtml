                    type: "POST",
                    dataType: "JSON",
                    data: { itemID: dataid },
                    success: function (result) {
                        createRow(result,"sales", itemunit);
                    }
                });
            }
        });


        $(document).on('change', '#SEDate', function (event) {
            var date = $(this).val();
            if (date != null) {
