    <script type="text/javascript" src="~/Content/js/orders.js"></script>
    @*<script type="text/javascript" src="~/Content/plugins/jquery.keypad.package/jquery.plugin.js"></script>
        <script type="text/javascript" src="~/Content/plugins/jquery.keypad.package/jquery.keypad.js"></script>*@
    <script type="text/javascript">
        function changediscount(obj) {
            var t = $("#total_tax").val();
            var to = $("#total").val();
            var d = $(obj).val();
            var di = parseFloat(t) + parseFloat(to) - parseFloat(d);
            $("#total_payable").val(di);

        }
        // custom item features
        $("#customitem").click(function () {
            $(".rpos .botbuttons button").attr("disabled", true);
            $("#leftdiv").hide();
            $("#leftCustomItem").addClass("cust-active");
            //$(this).addClass("btn-primary");
            //$(this).removeClass("btn-warning");
            //$("#delivery").removeClass("btn-primary");
            //$("#dinein").removeClass("btn-primary");

        });
        $("#cust-save").click(function () {
            var check = false;
            var Custom_ItemName = $("#Custom-ItemName").val();
            if (Custom_ItemName == "") {
                alert("Please Give Item Name");
                $("#Custom-ItemName").focus();
            }
            else {
                check = custRow();
            }
            if(check) {
                customClear();
                itemTotal();
                var disc_p = parseFloat($("#disc_p").val()) || 0;
                if (disc_p != 0) {
                    discAmount();
                }
                else {
                    var disc_m = parseFloat($("#disc_m").val()) || 0;
                    if (disc_m != 0) {
                        discPerc();
                    }
                }
            }
        });
        $("#cust-cancel").click(function () {
            customClear();
        });
        $('body').on('change', '#Custom-total_tax_p,#Custom-total', function (e) {
            itemCustTotal();
        });
        function customClear() {
            $(".rpos .botbuttons button").attr("disabled", false);
            $("#leftdiv").show();
            $("#leftCustomItem .price_main").remove();
            $("#leftCustomItem").removeClass("cust-active");
            $('#Custom-total_tax_p').val("0.00");
            $("#Custom-ItemCount").val("0.00");
            $("#Custom-ItemQty").val("0.00");
            $("#Custom-total").val("0.00");
            $("#Custom-total_tax").val("0.00");
            $("#Custom-total_payable").val("0.00");
            $("#Custom-ItemName").val("");
        }

        function custRow() {
            var MainClass = '#POSForm';
            if ($("#leftCustomItem").hasClass("cust-active")) {

            }
            var count = $(MainClass + ' .price_main').length;
            count++;
            var divid = "rowitem_c-" + count;
            var qunty = 1.00;
            var quantity = 1;
            var rate = parseFloat($("#Custom-total").val());
            var subtotal = parseFloat(rate);
            var tax = parseFloat($("#Custom-total_tax_p").val());
            var taxAmount = parseFloat(subtotal) * (parseFloat(tax) / 100);
            var totalamount = subtotal + taxAmount;
            var btnadd = "<span id='c-" + count + "' class='input-group-btn qtyadd qtybtn'><i class='fa fa-1x fa-plus-circle'></i></span>";
            var btnsub = "<span id='c-" + count + "'class='input-group-btn qtysub qtybtn'><i class='fa fa-1x fa-minus-circle'></i></span>";

            var inote = "";
            var itemnote = '<div id="modal-item-' + count + '" class="modal fade" role="dialog" aria-hidden="true"><div class="modal-dialog"><div class="modal-content">' +
                           '<div class="form-group"><textarea data-name="itemNote" name="itemnote" cols="40" rows="10" class="form-control inote" id="itemnote-' + count + '" maxlength="255">' + inote + '</textarea></div>' +
                           '<div class="form-group text-center"><button class="btn btn-info" type="button" data-dismiss="modal">Save</button></div>' +
                           '</div></div></div>';
            var notbtn = "<a class='itnote' data-toggle='modal' data-target='#modal-item-" + count + "'> " + $("#Custom-ItemName").val() + "</a>";

            var exrow = "";
            var desc = "<br/>[<span class='descr' data-name='Note'>";
            var custtid = "";
            $('#leftCustomItem .price_main').each(function (i, item) {
                var citemid = $(this).find(".itemselect").val();
                var citem = $(this).find(".itnote").text();
                var quantity = $(this).find(".price_q").val();
                var cItemUnitName = $(this).find(".col-sm-1 label").text();
                desc += citem;
                desc += " - " + 1.00 + " ";
                desc += (cItemUnitName != null) ? cItemUnitName : "";
                desc += "<br/>";

                custtid += "<input type='hidden' value='" + citemid + "' name='Cust-" + count + "[]'/>";
            });
            desc += "</span>]" +custtid;

            //-----------item unit--------------------
            var selectunit = "";

            //------------------------------------------
            var additon = "";
            var totprice = parseFloat(rate);

            rowdata = '<div class="price_main" id="rowitem_c-' + count + '">' +
                            '<input type="hidden" class="itemselect" data-name="Item" value="0">' +
                            '<div class="col-sm-1">' + count + '</div>' +
                            '<div class="col-sm-3">' + notbtn + desc + '</div>' +
                            '<div class="col-sm-1">' + selectunit + '</div>' +
                            '<div class="col-sm-1"><input type="text" style="width: 100%;height: 32px;" data-name="ItemUnitPrice" class="price" value=' + totprice.toFixed(2) + ' id="c-' + count + '"></div>' +
                            '<div class="col-sm-1"><div class="input-group input-group-sm">' + btnsub + '<input name="price_q" id="qty_c-' + count + '" data-name="ItemQuantity" type="text" class="price_q" value=' + qunty.toFixed(2) + ' onchange="qtychange(this,c-' + count+')";>' + btnadd + '</div><input data-name="ItemTax" type="hidden" class="taxper" value="' + tax.toFixed(2) + '"></td><td><input data-name="ItemTaxAmount" type="hidden" class="taxamt" value="' + taxAmount.toFixed(10) + '"><input data-name="BasePrice" type="hidden" id="base_rate_0" value="0"><input data-name="ConFactor" type="hidden" id="cfactor_0" value="1"></div>' +
                            '<div class="col-sm-2"><div data-name="ItemSubTotal" class="subtot">' + totprice.toFixed(2) + '</div></div>' +
                            '<div class="col-sm-1"><i class="fa fa-trash-o rowtrash" title="Remove"></i></div>' +
                            '<div class="itdisc hidden" data-name="ItemDiscount">0.00</div>' + itemnote + //added for min stock
            '</div>';
            $('#POSForm').append(rowdata);

            return true;
        }

        function itemCustTotal() {
            var totalextax = parseFloat($('#Custom-total').val()) || 0;
            var taxP = parseFloat($('#Custom-total_tax_p').val()) || 0;
            totalTax = parseFloat(totalextax) * (parseFloat(taxP) / 100);
            var total = (totalextax + totalTax);
            $("#Custom-total").val(totalextax.toFixed(2));

            $("#Custom-total_tax").val(totalTax.toFixed(2));
            $("#Custom-total_payable").val(total.toFixed(2));

