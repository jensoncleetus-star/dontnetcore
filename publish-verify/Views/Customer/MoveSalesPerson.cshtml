@{
    ViewBag.Title = "Change SalesMan";
    ViewBag.SubTitle = "ChangeSalesMan";
    ViewBag.Active = "Reports";
    var TimeOut = @ViewBag.TMOut;
}
<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">Change Sales Person</h3>
    </div>
    <div class="box-body">
        <form id="search-form">

            <div class="form-group col-md-4">
                @Html.Label("Sales Person*", null, new { @class = "control-label" })
                @Html.DropDownList("ddlEmployee", (SelectList)ViewBag.Empl, new { @class = "form-control select2", tabindex = 6})
            </div>
            <div class="form-group col-md-4" id="creditsale">
                @Html.Label("Last Transaction In", null, new { @class = "control-label" })
                @Html.DropDownList("LastUpdated", new SelectList(new List<SelectListItem>
                            {
                      new SelectListItem() {Text = "All", Value="0"},
                                new SelectListItem() {Text = "1 Day ", Value="1"},
                                new SelectListItem() {Text = "7 Days", Value="7"},
                                new SelectListItem() {Text = "1 Month ", Value="30"},
                                new SelectListItem() {Text = "3 Months ", Value="90"},
                                new SelectListItem() {Text = "6 Months ", Value="180"},
                                new SelectListItem() {Text = "1 Year", Value="360"},
                            }, "Value", "Text"), new { @class = "form-control input-sm", @name = "LastUpdated", tabindex = 7 })
            </div>
            <div class="form-group col-md-2" id="searchcustomertype" hidden style="margin-bottom:14px;">
                @Html.Label("Customer Type", null, new { @class = "control-label" })
                @Html.DropDownList("ddlCustomerType", (SelectList)ViewBag.CustomerType, "All", new { @class = "form-control" })
            </div>
            <div class="form-group col-md-4" id="creditsale">
                @Html.Label("No Of Rows", null, new { @class = "control-label" })
                @Html.DropDownList("rows", new SelectList(new List<SelectListItem>
                            {
                      new SelectListItem() {Text = "All", Value="0"},
                                new SelectListItem() {Text = "50 Rows", Value="50"},
                                new SelectListItem() {Text = "100 Rows", Value="100"},
                                new SelectListItem() {Text = "200 Rows ", Value="200"},
                                      }, "Value", "Text"), new { @class = "form-control input-sm", @name = "LastUpdated", tabindex = 7 })
            </div>
            <div class="form-group col-md-4">
                @Html.Label("Move To*", null, new { @class = "control-label" })
                @Html.DropDownList("ddlEmployee2", (SelectList)ViewBag.Empl2, new { @class = "form-control select2", tabindex = 6, @required = "required" })
            </div>

            <div class="box-footer col-md-12">
                <input type="submit" class="btn btn-info col-sm-offset-5" value="Submit" />
                <button type="button" class="btn btn-default" onclick="@("window.location.href='/Home/Index'");">Cancel</button>
            </div>
        </form>
    </div>
</div>
<div class="box box-default" id="QReport">
    <div class="box-header with-border">
        <h3 class="box-title">View Customers</h3>
    </div>
    <div class="box-body">
        <div class="box-body">
            <table class="display table table-bordered" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td>S/N</td>
                        <td>Customer</td>
                        <td>Current Balance</td>
                        <td><input type="checkbox" id="select_all" /> Select all <input type="button" class="btn btn-danger" onclick="setItem()" value="Move" /></td>
                    </tr>
                </thead>
                <tbody></tbody>
                <tfoot>
                    <tr>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
