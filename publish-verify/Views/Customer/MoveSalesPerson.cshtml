            async: true,
            cache: false,
            dataType: "json",
            type: "POST",
            contentType: "application/json; charset=utf-8",
            url: "/Customer/ChangeSalesperson",
            data: JSON.stringify({ value: values, NewSalesman: movetoEmp }),
