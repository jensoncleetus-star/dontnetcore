@model QuickSoft.ViewModel.AddCustomerLiteviewmodel
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Create Customer</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("AddCustomerLite", "Customer", FormMethod.Post, new { id = "createform" }))
    {
        <script type="text/javascript">
            $('form#popupFormUnit').removeData("validator");
            $('form#popupFormUnit').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#popupFormUnit'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        @Html.HiddenFor(model => model.CustomerID)

<div class="row">

    <div class="form-group col-md-4">
        @Html.LabelFor(model => model.CustomerCode, htmlAttributes: new { @class = "control-label" })
        @Html.EditorFor(model => model.CustomerCode, new { htmlAttributes = new { @class = "form-control", @placeholder = "", @required = "required", tabindex = 1 } })
    </div>
    <div class="form-group  col-md-4">
        @Html.LabelFor(model => model.CustomerName, htmlAttributes: new { @class = "control-label" })
        @Html.EditorFor(model => model.CustomerName, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Customer Name", @required = "required", tabindex = 3 } })
    </div>
    <div class="form-group  col-md-4">
        @Html.LabelFor(model => model.Mobile, htmlAttributes: new { @class = "control-label" })
        @Html.EditorFor(model => model.Mobile, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Mobile", tabindex = 3 } })
    </div>
    <div class="form-group  col-md-4">
        @Html.LabelFor(model => model.Address, htmlAttributes: new { @class = "control-label" })
        @Html.TextAreaFor(model => model.Address, new { @class = "form-control", @placeholder = "Enter Adress", tabindex = 6 })
    </div>



</div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" class="btn btn-info col-sm-offset-4" value="Update" />
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>


<script>
    

</script>
@section scripts{
    @Scripts.Render("~/js/jqueryval")

}

