                {
                    <div class="input-group input-group-sm">
                        @Html.DropDownListFor(m => m.SourceOfLead, (SelectList)ViewBag.SrcLead, new { id = "ddlSrcLead", @class = "form-control select2", tabindex = 7 })
                        <span class="input-group-btn">
                            <a href="/SourceOfLead/Create" class="modal-src btn btn-default" title="Add SourceOfLead"><i class="glyphicon glyphicon-plus"></i></a>
                        </span>
                    </div>
                }
                else
                {
                    @Html.DropDownListFor(m => m.SourceOfLead, (SelectList)ViewBag.SrcLead, new { id = "ddlSrcLead", @class = "form-control select2", tabindex = 8 })
                }
            </div>

        }
        <div class="form-group col-md-4" style="display:none">
            @Html.LabelFor(model => model.CreditLimit, htmlAttributes: new { @class = "control-label" })
            @Html.EditorFor(model => model.CreditLimit, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Credit Limit", tabindex = 9 } })
        </div>
        <div class="form-group col-md-4" style="display:none">
            @Html.LabelFor(model => model.CreditPeriod, htmlAttributes: new { @class = "control-label" })
            <div class="input-group input-group-sm">
                @Html.EditorFor(model => model.CreditPeriod, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Credit Period", tabindex = 10 } })
