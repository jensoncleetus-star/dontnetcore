            <h5 class="box-title">Customer Details</h5>
        </div>*@
    <div class="box-body">
        <div class="form-group col-md-4" style="display:none">
            @Html.LabelFor(model => model.CustomerCode, htmlAttributes: new { @class = "control-label" })*
            @Html.EditorFor(model => model.CustomerCode, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Customer Code", @required = "required", tabindex = 1 } })
        </div>
        <div class="form-group  col-md-4" style="display:none">
            @Html.LabelFor(model => model.CustomerName, htmlAttributes: new { @class = "control-label" })*
            @* @Html.DropDownListFor(model => model.CustomerName, (SelectList)ViewBag.CustName, new { @id = "CustomerIDD", @class = "form-control input-sm select2", @required = "required", tabindex = 2 })*@

        </div>
        <div class="form-group  col-md-4" style="display:none">
            @Html.LabelFor(model => model.Alias, htmlAttributes: new { @class = "control-label" })
            @Html.EditorFor(model => model.Alias, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Customer Alias", tabindex = 3 } })
        </div>
        <div class="form-group  col-md-4" style="display:none">
            @Html.LabelFor(model => model.CustomerPrintName, htmlAttributes: new { @class = "control-label" })
            @Html.EditorFor(model => model.CustomerPrintName, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Customer PrintName", tabindex = 4 } })
        </div>

        <div class="form-group col-md-4" style="display:none">
            @Html.LabelFor(model => model.TaxRegNo, htmlAttributes: new { @class = "control-label" })
            @Html.EditorFor(model => model.TaxRegNo, new { @id = "efCustmPrintName", htmlAttributes = new { @class = "form-control", @placeholder = "Enter Tax RegNo", tabindex = 5 } })
        </div>
        <div class="form-group col-md-4" style="display:none">
            @Html.LabelFor(model => model.SalesPerson, htmlAttributes: new { @class = "control-label" })
            @Html.DropDownListFor(model => model.SalesPerson, (SelectList)ViewBag.Empl, "", new { id = "ddlEmployee2", @class = "form-control select2", tabindex = 6 })
        </div>
        @if (@ViewBag.EnableCRM == 0)
        {

            <div class="form-group col-md-4" style="display:none">
                @Html.LabelFor(model => model.SourceOfLead, htmlAttributes: new { @class = "control-label" })
