        <button style="width: 200px;display:none" onclick="myFunction()" type="button" class="btn btn-primary btn-rounded btn-fw">More Details &ensp;<i class="fa fa-arrow-circle-o-down" aria-hidden="true"></i></button>

        <div class="form-group" id="myDIV" style="display:none">
            <div class="row">
                <div class="col-md-2">
                    <label class="control-label">Opening Balance</label>
                    <div class="input-group">
                        @*<input type="text" name="model.OpnBalance" class="form-control" placeholder="Enter Opening Balance" required>*@
                        @Html.EditorFor(model => model.OpnBalance, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Opening Balance", tabindex = 0 } })
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="control-label">Pre Year Balance</label>
                    <div class="input-group">
                        @*<input type="text" name="model.PreYearBalance" class="form-control" placeholder="Pre year balance" required>*@
                        @Html.EditorFor(model => model.PreYearBalance, new { htmlAttributes = new { @class = "form-control", @placeholder = "Pre year balance", tabindex = 1 } })
                    </div>
                </div>
                <div class="col-md-8">
                    <label class="control-label">Notes</label>
                    <div class="input-group">
                        @*<input type="text" name="model => model.Note" class="form-control" placeholder="Notes" required>*@
                        @Html.EditorFor(model => model.Note, new { htmlAttributes = new { @class = "form-control", @placeholder = "Notes", tabindex = 2 } })
                    </div>
                </div>
            </div>
        </div>





        <div class="box-footer">
            <input type="submit" value="Submit" class="btn btn-info col-sm-offset-4" tabindex="27" />
            <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" tabindex="28" />
        </div>
    </div>
    <script>
        $("#State").select2();
        $("#ddlEmployee2").select2();
    </script>

</div>


        @Scripts.Render("~/js/Mobile")

        <script type="text/javascript">


            var Countrys = '<option value="0">--Select--</option>';






        </script>

        <script type="text/javascript">
            function callselect() {
                mobileload();
                emailload();
            }
            $(document).on("select2:opening", (e) => {
                $('.modal-body').css('overflow', 'visible');
            });
            $(document).on("select2:open", (e) => {
                $('.modal-body').css('overflow', 'auto');
            });
            function mobileload() {
                $('.mobilenumber').select2({
                    tags: true,

                    placeholder: '5xxxxxxxx',
                    minimumInputLength: 0,
                    ajax: {
                        url: "/Customer/SearchMobilecontact",
                        dataType: 'json',
                        delay: 50,
                        data: function (params) {
                            return {
                                q: params.term || "",
                                x: "All",
                                page: params.page || 0,
                            };
                        },

                        processResults: function (data, params) {

                            params.page = params.page || 1;

                            return {

                                results: data
                            };

                        },
                        cache: true
                    },
                });
            }
            function emailload() {
                $('.emailid').select2({
                    tags: true,

                    minimumInputLength: 0,
                    ajax: {
                        url: "/Customer/SearchEmailcontact",
                        dataType: 'json',
                        delay: 50,
                        data: function (params) {
                            return {
                                q: params.term || "",
                                x: "All",
                                page: params.page || 0,
                            };
                        },

                        processResults: function (data, params) {

                            params.page = params.page || 1;

                            return {

                                results: data
                            };

                        },
                        cache: true
                    },
                });
            }
            function loadcontact(i, obj) {
                ///  $('.mobilenumber').select2('destroy');
                var s = $("#Mobile" + i).val();

                s = s.replace(/^0+/, '');
                var opt = '<option value="' + s + '" selected>' + s + '</option>'
                $("#Mobile" + i).append(opt);
                //mobileload();

                $.ajax({
                    url: "/Customer/getcontactsbymobile",
                    type: "GET",
                    dataType: "JSON",
                    data: { mobile: obj.value },
                    success: function (result) {
                        $("#firstname" + i).val(result[0].FirstName);
                        $("#Website" + i).val(result[0].Website);
                        //       $('.emailid').select2('destroy');
                        var opt = '<option value="' + result[0].EmailId + '" selected>' + result[0].EmailId + '</option>'
                        $("#EmailId" + i).append(opt);


                        $("#EmailId" + i).val(result[0].EmailId);

                        // $("#Mobile" + i).val(result[0].MobileNum);
                        $("#CountryID" + i).val(result[0].CountryID);
                        $("#Name" + i).val(result[0].Name + "," + result[0].Address);
                        $("#lastname" + i).val(result[0].LastName);
                        $("#ContactTypeID" + i).val(result[0].ContactTypeID);
                        emailload();
                    }
                });

                //Function to check correct format for Mobile Number
                //CheckMobileNo(s, i);
            }
            function loadcontactemail(i, obj) {
                $.ajax({
                    url: "/Customer/getcontactsbyemail",
                    type: "GET",
                    dataType: "JSON",
                    data: { email: obj.value },
                    success: function (result) {

                        $("#firstname" + i).val(result[0].FirstName);
                        $("#Website" + i).val(result[0].Website);
                        $("#EmailId" + i).val(result[0].EmailId);
                        // $('.mobilenumber').select2('destroy');
                        var opt = '<option value="' + result[0].MobileNum + '" selected>' + result[0].MobileNum + '</option>'
                        $("#Mobile" + i).append(opt);

                        //$("#Mobile" + i).val(result[0].MobileNum);
                        $("#CountryID" + i).val(result[0].CountryID);
                        $("#Name" + i).val(result[0].Name + "," + result[0].Address);
                        $("#lastname" + i).val(result[0].LastName);
                        $("#ContactTypeID" + i).val(result[0].ContactTypeID);

                        mobileload();
                    }
                });
            }



        </script>

