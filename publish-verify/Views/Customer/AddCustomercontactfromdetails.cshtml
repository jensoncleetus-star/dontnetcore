                    <button type="button" class="btn btn-flat">Days</button>
                </span>
            </div>
        </div>
        <div class="form-group col-md-4" style="display:none">
            @Html.LabelFor(model => model.CountryID, htmlAttributes: new { @class = "control-label" })
            @Html.DropDownListFor(model => model.CountryID, (SelectList)ViewBag.Cntry, "", new { id = "ddlCountryID", @class = "form-control select2", tabindex = 11 })
        </div>
        <div class="form-group col-md-4" style="display:none">
            @Html.LabelFor(model => model.StateID, htmlAttributes: new { @class = "control-label" })

            @Html.DropDownListFor(model => model.StateID, (SelectList)ViewBag.States, "", new { id = "ddlStateID", @class = "form-control select2", tabindex = 12 })

        </div>

        <div class="form-group col-md-4" style="display:none">
            @Html.Label("Google Map Link", null, htmlAttributes: new { @class = "control-label" })
            @Html.EditorFor(model => model.Location, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Location", tabindex = 13 } })
        </div>
        <div class="form-group  col-md-4" style="display:none">
            @Html.LabelFor(model => model.Address, htmlAttributes: new { @class = "control-label" })
            @Html.TextAreaFor(model => model.Address, new { @class = "form-control", @placeholder = "Enter Adress", tabindex = 6 })
        </div>



    </div>

    <div class="box-body">
        <button style="width: 200px;" type="button" class="btn btn-primary btn-rounded btn-fw add_field_button22">Add Contact &ensp;<i class="fa fa-plus-circle" aria-hidden="true"></i></button>

