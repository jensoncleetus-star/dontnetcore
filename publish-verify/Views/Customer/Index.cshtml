        var oTable = $('#MyTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": false, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "pageLength": 50,
            "timeout": 600000,
            responsive: true,
            "ajax": {
                "url": '/Customer/GetCustomer',
                "data": function (data) {
                    data.FromDate = $('#FromDate').val();
                    data.ToDate = $('#ToDate').val();
                    data.Customer = $('#ddlCustomer').val();
                    data.TaxReg = $('#TaxReg').val();
                    data.Mobile = $('#ddlMobile').val();
                    data.Phone = $('#ddlPhone').val();
                    data.CLimit = $('#CLimit').val();
                    data.CPeriod = $('#CPeriod').val();
                    data.Employee = $('#ddlEmployee').val();
                    data.Type = $('#ddlCustomerType').val();
                    data.Source = $('#ddlsource').val();
                    data.TxType = $('#TaxType').val();
                    data.MailId = $('#MailId').val();
                    data.Alias = $('#Alias').val();
                },
                "type": "POST",
                "datatype": "json"
            },
           
            "columnDefs": [{
                "targets": [14, 15],
                "orderable": false
            }],
            "order": [13, "desc"],
            "columns": [

                {
                    "data": "id", "name": "id",
                    "render": function (data, type, row, meta) {
                        return meta.row + meta.settings._iDisplayStart + 1;
                    }
                },

                { "data": "CustomerCode", "name": "CustomerCode" },
                {
                    "name": "CustomerName", "data": function (data) {
                           @{
                               var datas = "";
                               //datas = "'<a href=\"/Customer/Details/'+ data.id +'\">'+ data.CustomerName +'</a>' ";
                               if (User.IsInRole("Dev") || User.IsInRole("View Customer"))
                               {
                                   datas = "'<div class=\"bosx-cust\"><span class=\"bosx-av\">'+ (data.CustomerName||'').substring(0,2).toUpperCase() +'</span><a href=\"/Customer/Details/'+ data.id +'\">'+ data.CustomerName +'</a></div>' ";
                               }
                               else
                               {
                                   datas = "'<div class=\"bosx-cust\"><span class=\"bosx-av\">'+ (data.CustomerName||'').substring(0,2).toUpperCase() +'</span><span class=\"bosx-c-name\">'+ data.CustomerName +'</span></div>' ";
                               }
                           }
                        return @Html.Raw(datas);
                    }
                },
                { "data": "TaxRegNo", "name": "TaxRegNo" },
                { "data": "Address", "name": "Address" },
                {
                    "name": "Phone", "data": function (data) {
                        var datas = "";
                        $.each(data.mobmodel, function (i, item) {
                            if (item.Num != null) {
                                if (i > 0) {
                                    datas += ",";
                                }
                                datas += "+971" + item.Num.replace("+971", "").replace("971", "").replace(" ", "");
                                
                            }
                        });
                        return datas;
                    }


},
                 {
                     "name": "Mobile", "data": function (data) {
                         var datas = "";
                         $.each(data.mobmodel, function (i, item) {
                             if (item.Num != null) {
                                 var numorg = "971" + item.Num.replace("+971", "").replace("971", "").replace(" ", "");
                                 var numShow = item.Num.replace("+971+971", "+971").replace("+5", "+9715");
                                 datas += '<div class="bosx-contact">';
                                 datas += '<div class="bosx-c-head">';
                                 datas += '<a class="bosx-c-wa" href="javascript:void(0)" onclick="sendwhatsap(' + numorg + ')" title="WhatsApp"><i class="fa fa-whatsapp" aria-hidden="true"></i></a>';
                                 if (item.Name != null && item.Name != "") { datas += '<span class="bosx-c-name">' + item.Name + '</span>'; }
                                 datas += '</div>';
                                 datas += '<div class="bosx-c-meta">';
                                 datas += '<a class="bosx-c-tel" href="tel:' + numShow + '"><i class="fa fa-phone"></i>' + numShow + '</a>';
                                 if (item.emails != null && item.emails != "" && item.emails != "null") { datas += '<a class="bosx-c-mail" href="mailto:' + item.emails + '" title="' + item.emails + '"><i class="fa fa-envelope-o"></i>' + item.emails + '</a>'; }
                                 if (item.Fax != "" && item.Fax != null) { datas += '<span class="bosx-c-remark">(Remark: ' + item.Fax + ')</span>'; }
                                 datas += '</div>';
                                 datas += '</div>';
                             }
                         });
                         return datas;
                     }
                 },
                { "data": "Email", "name": "Email" },
                { "data": "customertype", "name": "customertype", "render": function (d) { return (d && d.toString().replace(/\./g, '').trim()) ? '<span class="bosx-badge">' + d + '</span>' : ''; } },
