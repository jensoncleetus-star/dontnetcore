                                    @Html.Label("Tax Type", null, new { @class = "control-label" })
                                    @Html.DropDownList("TaxType", (SelectList)ViewBag.TxType, "All", new { @class = "form-control" })

                                </div>
                                <div class="form-group col-md-2" id="searchmobno" hidden style="margin-bottom:14px;">
                                    @Html.Label("Mobile No", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlMobile", (SelectList)ViewBag.Mobile, "All", new { @class = "form-control" })
                                </div>
                                <div class="form-group col-md-2" id="searchcrlimit" hidden>
                                    @Html.Label("Credit Limit", null, new { @class = "control-label" })
                                    @Html.TextBox("CLimit", "", new { @class = "form-control input-sm" })
                                </div>
                                <div class="form-group col-md-2" id="searchcrperiod" hidden>
                                    @Html.Label("Credit Period", null, new { @class = "control-label" })
                                    @Html.TextBox("CPeriod", "", new { @class = "form-control input-sm" })
                                </div>
                                <div class="form-group col-md-2" id="searchemail" hidden>
                                    @Html.Label("Email", null, new { @class = "control-label" })
                                    @Html.TextBox("MailId", "", new { @class = "form-control input-sm" })
                                </div>
                                <div class="form-group col-md-2" id="search">
                                    <label class="control-label" aria-hidden="true" style="visibility:hidden;">.</label>
                                    <input type="submit" class="btn btn-submit" value="Submit" />
                                </div>
                                <div class="form-group col-md-2" id="close">
                                    <label class="control-label" aria-hidden="true" style="visibility:hidden;">.</label>
                                    <input type="button" class="btn btn-close" value="Close" />
                                </div>
                            </div>

                        </form>
                    </div>
                </div>
            </div>
        </div>
        <div>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <div class="pull-right">

                <i class="ace-icon fa fa-hand-o-right icon-animated-hand-pointer blue"></i>
                <a class="btn btn-info no-border add-btn-item modal-create" href="/Customer/AddCustomercontact">
                    <i class="glyphicon glyphicon-plus"></i> Add Customer contact
                </a>
            </div>
        </div>
    </div>
    <br />
    <div class=" col-md-2" id="searchpagelength">

        <span class="sh-spaan-text-style">Show &nbsp;</span>@Html.DropDownList("ddlPagesize", new SelectList(new List<SelectListItem>
{
new SelectListItem() {Text = "50 Rows", Value="50"},
//new SelectListItem() {Text = "All Rows", Value="10000000"},

}, "Value", "Text"), new { @class = "sh-input-drop select2" })

    </div>

    <div class="row">

        <div class="col-md-12">
            @using (Html.BeginForm("DeleteAllCustomer", "Customer", FormMethod.Post, new { id = "payform", role = "form" }))
            {

                <table class="customer-table" id="MyTable" width="100%">
                    <thead>
                        <tr style="background-color: #acd6e9">
                            <th scope="col" width="4%" data-priority="1">S/N</th>
                            <th scope="col" width="5%" data-priority="1">Customer code</th>
                            <th scope="col" width="30%" data-priority="1">Customer Name</th>
                            <th scope="col" width="7%" data-priority="3">trn</th>
                            <th scope="col" width="18%" data-priority="3">address</th>
                            <th scope="col" width="7%" data-priority="3">phone</th>
                            <th scope="col" width="30%" data-priority="2">Contacts</th>
                            <th scope="col" width="10%" data-priority="2">Sales Person</th>
                            <th scope="col" width="7%" data-priority="3">Customer Type</th>


                            <th scope="col" width="7%" data-priority="3">credit limit</th>
                            <th scope="col" width="5%" data-priority="3">credit period</th>
                            <th scope="col" width="5%" data-priority="2">Opening balance</th>
                            <th scope="col" width="5%" data-priority="2">Current Balance</th>
                            <th scope="col" width="5%" data-priority="2">Last Updatd</th>
                            <th scope="col" width="7%" style="min-width:80px" data-priority="1">Action</th>
                            <td scope="col" width="2%">
                                <input type="checkbox" id="select_all" />
                            </td>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>
            }
        </div>
    </div>

</div>

