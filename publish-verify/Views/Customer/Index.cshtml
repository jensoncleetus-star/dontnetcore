</div>
<div class="box box-info">
    <div class="box-header with-border">

        <h3 class="box-title">Customers</h3>
        <div class="pull-right">
            @if (User.IsInRole("Dev") || User.IsInRole("Create Customer"))
            {
                <i class="ace-icon fa fa-hand-o-right icon-animated-hand-pointer blue"></i>
                <a class="btn btn-info no-border add-btn-item" href="/Customer/Create">
                    <i class="glyphicon glyphicon-plus"></i> Create
                </a>}
        </div>

        <div class="row">
            <div class="col-md-2">
                <label class="control-label">Filters</label>
                <div id="list1" class="dropdown-check-list" tabindex="100">
                    <span class="anchor" style="z-index:0;">Select Fields</span>
                    <ul class="items">
                        <li><input type="checkbox" id="liname" class="liname" checked />Customer  Name </li>
                        <li><input type="checkbox" id="lialias" />Customer Alias</li>
                        <li><input type="checkbox" id="litype" />Customer Type</li>
                        <li><input type="checkbox" id="lisource" />Source</li>
                        <li><input type="checkbox" id="litaxreg" />Tax Reg </li>
                        <li><input type="checkbox" id="liemployee" />Sales Man</li>
                        <li><input type="checkbox" id="lifromdate" />Created Date From</li>
                        <li><input type="checkbox" id="litodate" />Created Date To</li>
                        <li><input type="checkbox" id="litaxtype" />Tax Type</li>
                        <li><input type="checkbox" id="limobile" checked />Mobile  </li>
                        @*<li><input type="checkbox" id="liphone" />Phone </li>*@
                        <li><input type="checkbox" id="licrlimit" />Credit Limit</li>
                        <li><input type="checkbox" id="licrperiod" />Credit Period</li>
                        <li><input type="checkbox" id="liemail" />Email</li>

                    </ul>
                </div>
            </div>
            <div class="col-md-12">
                <div class="box-body search-box" id="advsearchlist">

                    <div class="search-body col-md-12" style="background:none;">
                        <form id="search-form">
                            <div class="row">
                                <div class="form-group col-md-2" id="searchcname" hidden>
                                    @Html.Label("Customer", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlCustomer", (SelectList)ViewBag.Cust, "All", new { @class = "form-control dlCustomer" })
                                </div>
                                <div class="form-group col-md-2" id="searchalias" hidden>
                                    @Html.Label("Customer Alias", null, new { @class = "control-label" })
                                    @Html.TextBox("Alias", "", new { @class = "form-control input-sm" })
                                </div>
                                <div class="form-group col-md-2" id="searchcustomertype" hidden style="margin-bottom:14px;">
                                    @Html.Label("Customer Type", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlCustomerType", (SelectList)ViewBag.CustomerType, "All", new { @class = "form-control" })
                                </div>
                                <div class="form-group col-md-2" id="searchsource" hidden style="margin-bottom:14px;">
                                    @Html.Label("Source", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlsource", (SelectList)ViewBag.Source, "All", new { @class = "form-control" })
                                </div>
                                <div class="form-group col-md-2" id="searchtaxreg" hidden style="min-height:53px">
                                    @Html.Label("Tax RegNo", null, new { @class = "control-label" })
                                    @Html.TextBox("TaxReg", "", new { @class = "form-control input-sm" })
                                </div>
                                <div class="form-group col-md-2" id="searchemployee" hidden style="margin-bottom:14px;">
                                    @Html.Label("Sales Man", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlEmployee", (SelectList)ViewBag.Empl, "All", new { @class = "form-control" })
                                </div>
                                <div class="form-group col-md-2 " id="searchfromdate" style="display: none;">
                                    @Html.Label("From Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("FromDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>
