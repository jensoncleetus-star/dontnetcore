        $('#saleform').on('submit', function (e) {

            e.preventDefault();

            //check if exists VAT in Bill-Sundry
            var vatexist = 0;
            $("#addbillsundry tr").each(function (e) {
                var type = parseFloat($(this).find('.bsname').val());
                if (type == "4") { vatexist++; } else { vatexist = vatexist; }
            });
            var stype = $("#SalesType").val();
            if (stype == 3 && vatexist == 0)//
            {
                alert("Please Select VAT in Bill-Sundry..!!");
            } else {

                if ($("#saleform").valid()) {

                    var fnval = $('input[type="submit"], button[type="submit"]', this).filter(':focus').attr('id');

                    if (fnval == "sreturn") {
                        var SaleEntryID = getQueryString('');
                        SaleReturnPopUp(fnval, "Edit", SaleEntryID);
                    }

                    if (fnval == "save" || fnval == "print" || fnval == "printonly" || fnval == "download") {

                        //To Generate Popup For Settlement Mode
                        if ("@SettlementMode" == "active") {
                            var InvoiceAmount = $("#GrandTotal").val();
                            if (InvoiceAmount <= 0) {
                                alert("Grand Total should be greater than 0...")
                            }
                            else {
                                var EmpId = '@ViewBag.EmployeeId';
                                GenerateSettlementMode(fnval, "Edit", EmpId);
                            }
                        }
                        else {
                            submitForm(fnval, "");
                        }

                    } else if (fnval == "sendmail") {

                        if ($('#custEmailId').val() != "") {

                            //To Generate Popup For Settlement Mode
                            if ("@SettlementMode" == "active") {
                                var InvoiceAmount = $("#GrandTotal").val();
                                if (InvoiceAmount <= 0) {
                                    alert("Grand Total should be greater than 0...")
                                }
                                else {
                                    var EmpId = '@ViewBag.EmployeeId';
                                    GenerateSettlementMode(fnval, "Edit", EmpId);
                                }
                            }
                            else {
                                submitForm(fnval, "");
                            }
                        } else {
                            $('.ajax_response', res_danger).text("Customer Email Address Not Found..!!");
                            $('.AlertDiv').prepend(res_danger);
                        }
                    }
                }
            }
        });

