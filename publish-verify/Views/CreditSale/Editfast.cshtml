@model QuickSoft.ViewModel.SalesEntryViewModel
@{
    ViewBag.Title = "Edit";
    ViewBag.SubTitle = "Edit Sales Entry";
    ViewBag.Active = "Transactions";
    var TimeOut = @ViewBag.TMOut;
    string IRateCheck = "inactive";
    string check = "";
    string strImage = "";
    string partialconfig = "";
    string SettlementMode = "inactive";

    string OverideCLimit = "inactive";
}

@if (User.IsInRole("Dev") || User.IsInRole("Sales Tendering"))
{
    SettlementMode = "active";
}
@if (User.IsInRole("Dev") || User.IsInRole("ReadOnly Item Rate"))
{
    IRateCheck = "active";
}
@if (User.IsInRole("Dev") || User.IsInRole("Sales Tendering"))
{
    SettlementMode = "active";
}
@if (User.IsInRole("Dev") || User.IsInRole("Override Customer Credit Limit"))
{

    OverideCLimit = "active";
}
<script>
    if (/Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent)) {
        var SalesEntryID = getQueryString('');
        window.location = "/CreditSale/Editmobile/" + SalesEntryID;
    }
</script>
