<section class="content hidden print" id="printit">

    <div class="hidden-print text-center">
        <a href="" class="btn btn-info" id="backBtn">Back</a>
    </div>
    <style>
        #invoice-POS {
            padding: 2mm;
            margin: 0 auto;
            width: 100%;
            background: #FFF;
            /*border: 1px solid #f0f0f0;*/
            /*max-width: 250px;*/
        }

            #invoice-POS ::selection {
                color: #FFF;
            }

            #invoice-POS ::moz-selection {
                color: #FFF;
            }

            #invoice-POS h1 {
                font-size: 1.5em;
                color: #000;
            }

            #invoice-POS h2 {
                font-size: 11px;
                margin: 0px 0;
                padding-top: 3px;
                padding-bottom: 3px;
                color: #000;
            }

            #invoice-POS h3 {
                font-size: 1.2em;
                font-weight: 600;
                line-height: 2em;
                margin-bottom: 0px !important;
                margin-top: 0px;
            }

            #invoice-POS h5 {
                font-weight: 500;
                margin-top: 0px;
            }


            #invoice-POS p {
                font-size: .9em;
                color: #000;
                line-height: 1.2em;
                margin-bottom: 1px;
            }

            #invoice-POS #top, #invoice-POS #mid, #invoice-POS #bot {
                /* Targets all id with 'col-' */
                border-bottom: 1px solid #EEE;
                margin-bottom: 5px;
            }

            /*#invoice-POS #top {
                min-height: 100px;
            }*/

            /*#invoice-POS #mid {
                min-height: 80px;
            }*/

            #invoice-POS #bot {
                min-height: 50px;
            }

            #invoice-POS #top .logo {
                max-width: 100%;
                background-size: 60px 60px;
            }

                #invoice-POS #top .logo img {
                    max-height: 100px;
                    max-width: 100%;
                }

            #invoice-POS .clientlogo {
                float: left;
                height: 60px;
                width: 60px;
                background: url() no-repeat;
                background-size: 60px 60px;
                border-radius: 50px;
            }

            #invoice-POS .info {
                display: block;
                margin-left: 0;
                margin-bottom: 5px;
            }

            #invoice-POS .title {
                float: right;
            }

                #invoice-POS .title p {
                    text-align: right;
                }

            #invoice-POS table {
                width: 100%;
                border-collapse: collapse;
                margin-bottom: 5px;
                border-bottom: 1px #898989;
                color: #000;
                font-size: 11px;
            }

            #invoice-POS .tabletitle {
                font-size: .85em;
                border-bottom: 1px solid #EEE;
            }

            #invoice-POS .service {
                border-bottom: 1px solid #EEE;
            }

            #invoice-POS .item {
                width: 24mm;
                padding-top: 3px;
                padding-bottom: 3px;
            }

            #invoice-POS .itemtext {
                font-size: .65em;
                margin-bottom: 1px;
            }

            #invoice-POS #legalcopy {
                margin-top: 1.5mm;
            }

            #invoice-POS .rate, #invoice-POS .addtax {
                text-align: right;
            }

            #invoice-POS .qty {
                text-align: center;
            }

            #invoice-POS .price {
                text-align: center;
            }

            #invoice-POS hr {
                margin: 5px 0;
            }

        .noborder th {
            border-bottom: 1px #898989;
        }

        .noborder tr {
            border: none;
        }

        .noborder td {
            border: none;
        }
    </style>
    <div id="invoice-POS">
        <center id="top">
            <div class="info">
              @if (@ViewBag.HeadCheck != 0)
                {
                ViewBag.chkLogo = "logo";
                @Html.Partial("../Common/_CompanyHeader")
                    }
            </div>
        </center><!--End InvoiceTop-->
        <div class="text-center">
            @if (ViewBag.CTaxRegNo != null)
            {
                <h4>
                    Tax Invoice
                </h4>
            }
            else
            {
                <h4>
                    Invoice
                </h4>
            }
        </div>
        <div id="mid">
            <div class="info">
                <p><span>Invoice No رقم الفاتورة:</span><label id="lblBillNo"></label></p>
                <p id="tranConvert"><span><label id="lblConvertType"></label>&nbsp;No :</span><label id="lblConvertNo"></label></p>
                <p><span>Date تاريخ:</span><label id="lblDate"></label></p>
                <p><span>Executive :</span><label id="lblEmployee"></label></p>
                <p id="LocLbl"><span>Location :</span><label id="lblLocation"></label></p>
                <p><span>Customer زبون:</span><br /><label id="lblCustomer"></label></p>
            </div>
        </div><!--End Invoice Mid-->
        <div id="bot">
            <div id="table">
                <table class="table-nob noborder" id="itemtable">
                    <thead>
                        <tr class="tabletitle thead">
                            <th class="slno"><h2>S/N</h2></th>
                            <th class="item"><h2>ITEM </h2></th>
                            <th class="qty"><h2>QTY </h2></th>
                            <th class="price"><h2>PRICE </h2></th>
                            <th class="addtax"><h2>VAT5% </h2></th>
                            <th class="addtax"><h2>TOTAL </h2></th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                    <tfoot id="posfoot" style="display: table-row-group">
                        <tr class="tabletitle">
                            <td colspan="4" class="Rate"><h2><strong>Amount كمية</strong></h2></td>
                            <td colspan="3" class="rate"><h2 id="lblAmount"></h2></td>
                        </tr>
                        <tr class="tabletitle">
                            <td colspan="4" class="Rate"><h2><strong>VAT @@5% ضريبة</strong></h2></td>
                            <td colspan="3" class="rate"><h2 id="lblTax"></h2></td>
                        </tr>
                        <tr class="tabletitle discpt">
                            <td colspan="4" class="Rate"><h2><strong>Discount Amount</strong></h2></td>
                            <td colspan="3" class="rate"><h2 id="lblDiscAmt"></h2></td>
                        </tr>
                    </tfoot>
                </table>
                <p>
                    Payment Type: <span><label id="lblpaytype"></label></span>
                </p>
            </div><!--End Table-->
            <div id="legalcopy">
                <p class="legal">
                    <strong><label id="lblTC"></label></strong>
                </p>
            </div>
            <div class="text-center">
                @Html.Partial("../Common/_CompanyFooter")
            </div>
        </div><!--End InvoiceBot-->
    </div><!--End Invoice-->
</section>
