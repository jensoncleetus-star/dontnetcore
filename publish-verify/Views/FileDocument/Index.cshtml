    <script type="text/javascript">
        $('div').on('click', 'a.ViewUpdates', function (e) {
            e.preventDefault();
            $(this).attr('data-target', '#modal-container3');
            $(this).attr('data-toggle', 'modal');
        });
        function detailsRemark(AmcId) {
            var RequisitionId = AmcId;

            //List all other remarks from table CustomerRemarks
            var oTable1 = $('#RemarkInfo').DataTable({
                "processing": true, // for show progress bar
                "serverSide": true, // for process server side
                "filter": true, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
                "bStateSave": true,
                "paging": false,
                "sortable": true,
                "ordering": true,
                "searching": true,
                "ajax": {
                    "url": '/FileDocument/GetAllRemarksadded',
                    "type": "POST",
                    "datatype": "json",
                    "data": { RequisitionId: AmcId }
                },
                "order": [[0, "desc"]],

                "columns": [
                    {
                        "data": "id", "name": "id",
                        "render": function (data, type, row, meta) {
                            return meta.row + meta.settings._iDisplayStart + 1;
                        }
                    },
                    { "data": "CreatedDate", "name": "CreatedDate", "render": function (data) { if (data != null) { return convertDateTime(data); } else { return "" } } },
                    { "data": "EmpName", "name": "EmpName" },
                    { "data": "Remarks", "name": "Remarks" },
                ],
            });

            oTable1.destroy();

        }
        $(document).ready(function () {
            $('#advsearchlistt').hide();
            $("#openclosed").show();
            $("#lidocName").click();
        });

        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        })

        var oTable = $('#DocumentList').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "pageLength": 50,
            responsive: true,
            "createdRow": function (row, data, dataIndex) {
                if (data.color == 2) {
                    $(row).addClass('yellowclass');
                }
                else if (data.color == 3) {
                    $(row).addClass('redclass');
                }
                else {
                    $(row).addClass('blackclass');
                }


            },
            "ajax": {
                "url": '/FileDocument/GetFileDocuments',
                "data": function (data) {
                    data.openclose = $("#openclosed").val();
                    data.documentName = $('#ddlName').val();
                    data.documenttype = $('#ddltype').val();
                    data.document = $('#ddlDoc').val();
                    data.expdate = $('#ExpDate').val();
                    data.reminder = $('#RemDate').val();
                    data.credate = $('#CreDate').val();
                    data.status = $('#Status').val();
                    data.user = $('#ddlCreatedBy').val();
                },
                "type": "POST",
                "datatype": "json"
            },
            "order": [0, "desc"],
            //"columnDefs": [{ orderable: false, targets: -1 }],
            "columnDefs": [{
                "targets": [10,11],
                "orderable": false
            }],
            "columns": [
                 {
                     "data": "color", "name": "color",
                     "render": function (data, type, row, meta) {
                         return meta.row + meta.settings._iDisplayStart + 1;
                     }
                 },
                { "data": "DocumentName", "name": "DocumentName" },
                { "data": "documenttype", "name": "documenttype" },

                { "data": "Note", "name": "Note" },

                {
                    "data": "ReminderDate", "name": "ReminderDate",
                    "render": function (data) {
                        if (data == null) {
                            return "";
                        }
                        else {
                            return  convertToDate(data) ;
                            }
                    }
                },

                    {
                        "data": "ExpiryDate", "name": "ExpiryDate",
                        "render": function (data) {
                            if (data == null) {
                                return "Date Not Available";
                            }
                            else {
                                return convertToDate(data);
                            }
                        }
                },

                    { "data": "CreatedDate", "name": "CreatedDate", "render": function (data) { return convertToDate(data); } },

                    { "data": "user", "name": "user" },

                     {
                         "name": "Status", "data": function (data) {
                             if (data.ExpiryDate == null) {
                                 return '<i class="badge bg-green" style="font-size: small" >Active</i>';
                             }
                             else {
                                 var t = new Date();
                                 var month = t.getMonth() + 1;
                                 var day = t.getDate();
                                 var year = t.getFullYear(); ``
                                 var today = (month < 10 ? '0' : '') + month + '-' +
                                     (day < 10 ? '0' : '') + day + '-' +
                                     (year < 13 ? '0' : '') + year;
                                 //t.getFullYear();
                                 var Expdate = convertToDateYMD(data.ExpiryDate);
                                 today = Date.parse(today);
                                 Expdate = Date.parse(Expdate);
                                 if (Expdate > today) {
                                     return '<i class="badge bg-green" style="font-size: small" >Active</i>';


                                 }
                                 else {
                                     return '<i class="badge bg-red" style="font-size: small" >Expired</i>';
                                 }

                             }
                         }
                     },
                {
                    "name": "ldate", "data": function (data) {
                        var result = "";
                        if (data.ldate != null) {
                            result = LastUpdatedIn(data.ldate);
                        }
                        return (result);
                    }
                },
                    {
                        "name": "Id", "data": function (data) {
                            var rest = "";
                            @{
                                if (User.IsInRole("Dev") || User.IsInRole("Edit FileDocument"))
                                {
                                    actData += "<a class=\"modal-edit\" href=\"/FileDocument/Edit/'+ data.Id +'\" title=\"Edit Document Details\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                                }
                                if (User.IsInRole("Dev") || User.IsInRole("Delete FileDocument"))
                                {
                                    actData += "<a class=\"modal-delete\" href=\"/FileDocument/Delete/'+ data.Id +'\" title=\"Delete Document\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";
                                }
                                if (User.IsInRole("Dev") || User.IsInRole("Download FileDocument"))
                                {
                                    actData += "<a class=\"modal-creates\" href=\"/FileDocument/Download/'+ data.Id +'\" title=\"Delete Document\"><i class=\"fa fa-lg fa-download\" ></i></a> ";
                                }
                                actData += "<a class=\"btn btn-icons btn-rounded btn-edit modal-create\" href=\"/FileDocument/AddAmcRemark/'+ data.Id +'\" title=\"Add Remarks\"><i class=\" fa fa-plus\" ></i></a> ";
                                actData += "<a class=\"btn btn-icons btn-rounded btn-remark ViewUpdates\" onclick=\"detailsRemark(' + data.Id + ')\" title=\"View Remarks\"><i class=\" fa fa-eye\" ></i></a> ";

                            }
                            return rest = '@Html.Raw(actData)';
                        }
                    },
                      {
                          "name": "id", "data": function (data) {
                              var rest = "";
                              @{
                                  if (User.IsInRole("Dev") || User.IsInRole("Delete FileDocument"))
                                  {
                                      delchk = "<input class=\"checkbox\" type=\"checkbox\" name=\"bill[]\" value='+ data.Id +'></input>";
                                  }
                              }
                              return rest = '@Html.Raw(delchk)';
                          }
                      },
            ], dom: 'Bfrtip',
            buttons: ['colvis', {
                extend: 'print',//
                title: "",
                footer: true,
                exportOptions: {
                    columns: ':visible'
                },
                message: '<table class="tblcompact table table-bordered"><thead>' +
                    ' <tr><th class="text-center"><h3 style="margin-top: 0px;">' + '<h4>Suppliers </h4></th></tr>' +
                    ' <tr><th><span class="text-left"></span><span class="text-right pull-right"> </span></th></tr></thead><tbody><tr><td>',
                customize: function (win) {

                    $(win.document.body).find('table, th,tr, td ')
                       // .css('border', 'inherit')
                        .css('font-size', '10pt')
                        .css('padding', '5px')
                        .addClass('compact');
                    $(win.document.body).append('</td></tr></tbody>')

                }
            }, 'copy', 'csv', 'excel',

            {
                extend: 'pdf',//
                title: "File Documents",
                footer: true,
                orientation: 'landscape',

                pageSize: 'A4',
                exportOptions: {
                    columns: ':visible'
                },
                customize: function (doc) {
                    doc.pageMargins = [10, 10, 10, 10];
                    doc.defaultStyle.fontSize = 10;
                    doc.styles.tableHeader.fontSize = 10;
                    doc.styles.title.fontSize = 12;
                    // Remove spaces around page title
                    doc.content[0].text = doc.content[0].text.trim();

                    doc.styles['td:nth-child(2)'] = {
                        width: '100%',
                        'max-width': '100%'
                    }

                    var objLayout = {};
                    // Horizontal line thickness
                    objLayout['hLineWidth'] = function (i) { return .5; };
                    // Vertikal line thickness
                    objLayout['vLineWidth'] = function (i) { return .5; };
                    //// Horizontal line color
                    //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                    //// Vertical line color
                    //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                    // Left padding of the cell
                    objLayout['paddingLeft'] = function (i) { return 4; };
                    // Right padding of the cell
                    objLayout['paddingRight'] = function (i) { return 4; };
                    // Inject the object in the document
                    doc.content[1].layout = objLayout;
                }
            },

            @Html.Raw(deleteBTn)
            ],
        })

         //Button Close
        $('#srch, .search-box .btn-close').on('click', function (e) {
            $('#advsearchlistt').toggle();

            /*******  To uncheck all the checkboxes in the Select List  ************/
            var checkboxes = document.querySelectorAll("input[type='checkbox']");
            checkboxes.forEach(function (Checkbox) {
                Checkbox.checked = false;
            });

            if ($('#srch').hasClass('btn-primary')) {
                $('#srch').addClass('btn-danger');
                $('#srch').removeClass('btn-primary');
            }
            else {
                if ($('#srch').hasClass('btn-danger')) {
                    $('#srch').addClass('btn-primary');
                    $('#srch').removeClass('btn-danger');
                }
                /*******  To clear all the data entered  *********/
                //$('#ddlDoc').val(0);
                $('#ddlName').val(null);
                $('#ExpDate').val(null);
                $('#RemDate').val(null);
                $('#CreDate').val(null);
                $('#Status').val(null);
                $('#ddlCreatedBy').val(null);
                $('#ddltype').val(null);
                oTable.draw();
            }
        });

