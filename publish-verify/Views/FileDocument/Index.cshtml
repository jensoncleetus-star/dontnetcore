<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">View All Documents</h3>
        @if (User.IsInRole("Dev") || User.IsInRole("Create FileDocument"))
        {
            
        }

        <div class="row">
            <div class="col-md-2">
                <div id="list1" class="dropdown-check-list" tabindex="100">
                    <span class="anchor" style="z-index:0;">Select Fields</span>
                    <ul class="items">
                        <li><input type="checkbox" id="lidocName" />Document Name</li>
                        <li><input type="checkbox" id="lidoctype" />Document type</li>
                        <li><input type="checkbox" id="liexpirydate" />Expiry Date</li>
                        <li><input type="checkbox" id="lireminderdate" />Reminder Date</li>
                        <li><input type="checkbox" id="licreateddate" />Created Date</li>
                        <li><input type="checkbox" id="licreatedby" />Created By</li>
                        @*<li><input type="checkbox" id="listatus" />Status</li>*@
                    </ul>
                </div>
            </div>
            <div class="col-md-12">
                <div class="box-body search-box" id="advsearchlistt">
                    <div class="search-body col-md-12" style="background:none;">
                        <form id="search-form">
                            <div class="row">
                                <div class="form-group col-md-3" id="searchName">
                                    @Html.Label("Document Name", null, new { @class = "control-label" })
                                    @Html.TextBox("ddlName", "", new { @class = "form-control input-sm " })
                                </div>
                                <div class="form-group col-md-3" id="searchtype">
                                    @Html.Label("documenttype", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddltype", (SelectList)ViewBag.typ, "All", new { @class = "form-control input-sm select2" })
                                </div>
                                <div class="form-group col-md-3" id="searchexpirydate">
                                    @Html.Label("Expiry Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("ExpDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group col-md-3" id="searchreminderdate">
                                    @Html.Label("Reminder Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("RemDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group col-md-3" id="searchcreateddate">
                                    @Html.Label("Created Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("CreDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group col-md-3" id="searchcreatedby">
                                    @Html.Label("Created By", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlCreatedBy", (SelectList)ViewBag.CreatedBy, "All", new { @class = "form-control input-sm select2" })
                                </div>
                                <div class="form-group col-md-3" id="searchstatus">
                                    @Html.Label("Status", null, new { @class = "control-label" })
                                    @Html.DropDownList("Status", (SelectList)ViewBag.ItStatus, new { @class = "form-control" })
                                </div>
                                <div class="col-md-4 col-xs-12 form-group" id="openclose">
                                    @Html.Label("Open/Close", null, new { @class = "control-label" })

                                    @Html.DropDownList("openclosed", (IEnumerable<SelectListItem>)ViewBag.OpnCls, new { @class = "form-control" })
                                    @*@Html.DropDownListFor(model => model.OpenClose, (SelectList)ViewBag.OpnCls, new { @class = "form-control" })*@
                                </div>

                                <div class="form-group col-md-2" id="search">
                                    <input type="submit" class="btn btn-submit" value="Submit" />
                                </div>
                                <div class="form-group col-md-2" id="close">
                                    <input type="button" class="btn btn-close" value="Close" />
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="box-body">
        <table class="table table-bordered table-hover" id="DocumentList">
            <thead>
                <tr class="bg-gray">
                    <td data-priority="1">Sl No.</td>
                    <td data-priority="1">Document Name</td>
                    <td data-priority="1">Document Type</td>
                    <td data-priority="1">Document Note</td>
                    <td data-priority="1">Reminder Date</td>
                    <td data-priority="1">Expiry Date</td>
                    <td data-priority="1">Created Date</td>
                    <td data-priority="1">Created By</td>
                    <td data-priority="1">Status</td>
                    <td data-priority="1">Last Updated</td>
                    <td data-priority="1">Actions</td>
                    <td data-priority="2"><input type="checkbox" id="select_all" /></td>

                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
