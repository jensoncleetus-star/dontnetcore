@model QuickSoft.ViewModel.CustomerViewModel
@{
    ViewBag.Title = "Create File Documents";
    ViewBag.SubTitle = "File Documents";
    ViewBag.Active = "Utility";
    string partialconfig = "";
    string check = "";
    string strImage = "";


    int di = 0;

}
<head>

    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.1.0/jquery.min.js"></script>
    <style>
        #loadingImg {
            display: none;
        }
    </style>
</head>
<div class="box box-info">
    @using (Html.BeginForm("Create", "FileDocument", FormMethod.Post, new { @class = "dropzone", id = "createform", role = "form", enctype = "multipart/form-data" }))
    {
        <div class="box-header with-border">
            <h3 class="box-title">File Document / Reminder</h3>
            <div class="pull-right">
                @if (@ViewBag.LastEntry != 0)
                {
                    if (User.IsInRole("Dev") || User.IsInRole("Edit FileDocument"))
                    {
                        <a class="btn bg-black no-border" href="/FileDocument/Edit/@ViewBag.LastEntry">
                            <i class="fa fa-step-backward"></i>
                        </a>
                    }
                }
                @if (User.IsInRole("Dev") || User.IsInRole("FileDocument List"))
                {
                    <a class="btn btn-success no-border" href="/FileDocument/Index">
                        <i class="fa fa-fw fa-history"></i> List
                    </a>
                }
            </div>
        </div>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger AlertDiv" })
        <input type="hidden" class="form-control" id="documentRowcount" value="0" placeholder="">
        <input type="hidden" class="form-control" id="MultidocumentRowcount" value="0" placeholder="">
        <div class="row">
            <button style="width: 200px;display:none;" type="submit" class="btn btn-light btn-rounded btn-fw add_field_button3">Documents details &ensp;<i class="" aria-hidden="true"></i></button>

            <div class="form-group input_fields_wrap3">

            </div>
            <br>

            <div class="form-group col-md-12">
                @Html.LabelFor(m => m.AssignedMembers, new { @class = "control-label" }) *
                @Html.ListBoxFor(m => m.AssignedMembers, (MultiSelectList)ViewBag.team, new { @id = "AssignedUsers", @class = "form-control select2 AsgnUsers", @name = "AssignedMembers[]", @multiple = "multiple" })
            </div>
            <div class="form-group col-md-12 point">
                @Html.Label("Documents", null, new { @class = "control-label" })
                <div class="file-loading">
                    <input id="input-24" name="input24[]" type="file" multiple>
                </div>
            </div>
            
                    <div class="form-group col-md-12">

                        @Html.Label("Repeate", null, htmlAttributes: new { @class = "control-label" })*
                        @Html.DropDownListFor(m => m.reminderrepeate, new SelectList(new List<SelectListItem>
                                           {
                       new SelectListItem() {Text = "On Reminder date", Value="6"},

                       new SelectListItem() {Text = "Daily", Value="0"},
                             new SelectListItem() {Text = "Saturday", Value="1"},
                                  new SelectListItem() {Text = "Sunday", Value="2"},
                                       new SelectListItem() {Text = "Weekly", Value="3"},
                                            new SelectListItem() {Text = "Monthly", Value="4"},
                                                 new SelectListItem() {Text = "Yearly", Value="5"},



                                           }, "Value", "Text"), new { @class = "form-control input-sm" })

                    </div>
         
        </div>


       




        <div class="row">
            <div class="form-group pull-right">
                <button type="submit" id="Save" class="btn btn-success">
                    <span class="glyphicon"></span> Save
                </button>
                <button type="button" class="btn btn-warning" onclick="@("window.location.href='/FileDocument/Index'");">Cancel</button>
            </div>

        </div>
    }
</div>

@Html.Partial("../Common/_ModalCreate")
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/wysihtml5")
    @Styles.Render("~/css/bootstrap-timepicker")
    @Styles.Render("~/css/bootstrap-fileinput")
    @Styles.Render("~/css/bootstrap-fileinput-rtl")
}
@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/additem")
    @Scripts.Render("~/js/wysihtml5")
    @Scripts.Render("~/js/bootstrap-timepicker")
    @Scripts.Render("~/js/bootstrap-fileinput")
    @Scripts.Render("~/js/bootstrap-sortable")
    @Scripts.Render("~/js/bootstrap-purify")
    @Scripts.Render("~/js/Mobile")


<script type="text/javascript">

       /*.........tooltip message...........*/
        $(".point").prop('title', 'Ctrl + select on Browse');


    $("#input-24").fileinput({
            maxFilePreviewSize: 10240,
            autoReplace: false,
            maxFileCount: 10,
            showUploadedThumbs: true,
            showUpload: false,
        overwriteInitial: false,
        enableResumableUpload: true,
            initialPreviewAsData: true,
            initialPreviewFileType: 'image',

            allowedFileExtensions: ["dwg ", "xlsx", "gif", "jpg", "png","csv", "jfif", "jpeg", "doc", "docx", "pdf", "dwg", "pptx", "vsdx",
                'M4A', 'FLAC', 'MP3', 'MP4', 'WAV', 'WMA', 'AAC', 'ogg', 'opus', 'mpg', 'mpeg'],
            fileActionSettings: {
                showUpload: false,
                showZoom: true,
            },
              initialPreviewConfig: [
               @partialconfig
            ],
        }).on('filesorted', function (e, params) {
            console.log('File sorted params', params);
        }).on('fileuploaded', function (e, params) {
            console.log('File uploaded params', params);
        });

    var s = '<option value="0">--Select--</option>';
    
        $.ajax({
            type: "GET",
            url: "/Customer/GetDocTypes",
            data: "{}",
            success: function (data) {
                for (var i = 0; i < data.length; i++) {
                    s += '<option value="' + data[i].ID + '">' + data[i].Name + '</option>';
                }
                $("#DocumentTypeID").append(s);
                $("#DocumentTypeID").select2({});
            }
        });
    

       
        $(document).ready(function () {
            jQuery(function () {
                jQuery(".add_field_button3").click();
                jQuery(".add_field_button4").click();
            });
            $("#AssignedUsers").select2();
            var max_fields = 2; //maximum input boxes allowed
            var wrapper3 = $(".input_fields_wrap3"); //Fields wrapper
            var add_button = $(".add_field_button3"); //Add button ID

            var x = 1; //initlal text box count
            $(add_button).click(function (e) { //on add input button click
                e.preventDefault();
                if (x < max_fields) { //max input box allowed


                    var rowno = document.getElementById('documentRowcount').value;

                    //paste here
                    $(wrapper3).append('<div class="row" style="margin-top: 1rem;">' +
                        '<div class="col-md-2">' +
                        '<label class="control-label">Document Type</label>' +
                        '<div class="input-group">' +
                        '<select class="form-control" id="DocumentTypeID" name="Lstfdocs[' + rowno + '].Documenttype" tabindex="30" required>' + s +
                        '</select>' +
                        '</div>' +
                        '</div>' +
                        '<div class="col-md-3">' +
                        '<label class="control-label">Document Name</label>' +
                        '<div class="input-group">' +
                        '<input type="text" name="Lstfdocs[' + rowno + '].DocumentName" class="form-control" placeholder="Document Name" required>' +
                        '</div>' +
                        '</div>' +
                        '<div class="col-md-2">' +
                        '<label class="control-label">Expiry</label>' +
                        '<div class="input-group">' +
                        '<input type="date" name="Lstfdocs[' + rowno + '].ExpiryDate" class="form-control" placeholder="Expiry" required>' +
                        '</div>' +
                        '</div>' +
                        '<div class="col-md-2">' +
                        '<label class="control-label">Reminder</label>' +
                        '<div class="input-group">' +
                        '<input type="date" name="Lstfdocs[' + rowno + '].ReminderDate" class="form-control" placeholder="Reminder" required>' +
                        '</div>' +
                        '</div>' +
                        '<div class="col-md-3">' +
                        '<label class="control-label">Notes</label>' +
                        '<div class="input-group">' +
                        '<input type="text" name="Lstfdocs[' + rowno + '].Note" class="form-control" placeholder="Notes" >' +
                        ' </div>' +
                        '</div>' + '</div>');

                    x++;

                    rowno++;
                    document.getElementById('documentRowcount').value = rowno;
                }
            });
        });
        $(document).ready(function () {
            var max_fields = 10; //maximum input boxes allowed
            var wrapper4 = $(".input_fields_wrap4"); //Fields wrapper
            var add_button = $(".add_field_button4"); //Add button ID

            var x = 1; //initlal text box count
            $(add_button).click(function (e) { //on add input button click
                e.preventDefault();
                if (x < max_fields) { //max input box allowed


                    var rowno = document.getElementById('MultidocumentRowcount').value;

                    //paste here
                    $(wrapper4).append('<div class="row" style="margin-top: 1rem;">' +

                        '<div class="col-md-3">' +
                        '<label class="control-label">Choose image</label>' +
                        ' <div class="input-group">' +
                        '<input type="file" name="Multidoc[' + rowno + '].Document" class="form-control file-upload-info"  placeholder="Choose image" required >' +

                        '</div>' +
                        '</div>' +
                        '<div class="col-md-4">' +
                        '<label class="control-label">Label</label>' +
                        '<div class="input-group">' +
                        '<input type="text" name="Multidoc[' + rowno + '].DocumentName" class="form-control" placeholder="Enter Name" required>' +
                        '</div>' +
                        '</div>' +

                        '<a href="javascript:void(0);" class="remove_button"><i style="color:red; margin-top:2.7rem;" class="fa fa-trash" aria-hidden="true"></i></a></div>');

                    x++;

                    rowno++;
                    document.getElementById('MultidocumentRowcount').value = rowno;
                }
            });

                $(wrapper4).on('click', '.remove_button', function (e) {
                    e.preventDefault();
                    if (x > 2) {
                        $(this).parent('div').remove(); //Remove field html
                        x--; //Decrement field counter
                    }
                })

        });
        var date = new Date();
        date.setDate(date.getDate());
        $('.date').datepicker({
            format: 'mm-dd-yyyy',
            autoclose: true,
            allowInputToggle: true
        });
        jQuery.validator.methods["date"] = function (value, element) { return true; }

      
        /* Create function for File Document */
        $('div').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        });

        $('#createform').on('submit', function (e) {
            e.preventDefault();
            if ($("#createform").valid()) {
                var url = $('#createform')[0].action;
                var formData = new FormData(this);

                $.ajax({
                    async: true,
                    cache: false,
                    dataType: "json",
                    type: "POST",
                    processData: false,
                    contentType: false,
                    url: url,
                    data: formData,//JSON.stringify(parameters),
                    beforeSend: function () {
                        $("button").prop('disabled', true); // disable button
                    },
                    success: function (e) {
                        if (e.status) {
                            $('.ajax_response', res_success).text(e.message);
                            $('.AlertDiv').prepend(res_success);
                            window.location.href = '@Url.Action("Index", "FileDocument")';
                        }
                        else {
                            $('.ajax_response', res_danger).text(e.message);
                            $('.AlertDiv').prepend(res_danger);
                            $("button").prop('disabled', false); // enable button
                        }
                    }
                });
            }
        });


        Dropzone.autoDiscover = false;
       

        Dropzone.autoDiscover = false;
        // Dropzone class:
        var myDropzone = new Dropzone(".dropzone", {
            //url: "/file/post",
            acceptedFiles: ".jpeg,.jpg,.png,.gif,.pdf",
            uploadMultiple: false,
            createImageThumbnails: true,
            addRemoveLinks: true,
            maxFiles: 10,
            maxfilesexceeded: function (file) {
                this.removeAllFiles();
                this.addFile(file);
            }, init: function () {
                this.on('error', function (file, errorMessage) {
                    var mypreview = document.getElementsByClassName('dz-error');
                    mypreview = mypreview[mypreview.length - 1];
                    mypreview.classList.toggle('dz-error');
                    mypreview.classList.toggle('dz-success');
                });
            }

        });
</script>
}