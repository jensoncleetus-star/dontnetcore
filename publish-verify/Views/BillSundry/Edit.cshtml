            addstockeachmc2(itemid);
            $("#LastPurSale2").modal({
                backdrop: 'static',
                keyboard: false
            });


    }
 
        function addstockeachmc2(ItemId) {
            if ($.fn.DataTable.isDataTable('#LPurchase2')) {
                $('#LPurchase2').DataTable().destroy();
            }



            var mcs = $("#ddlMCavailable").val();
            $('#LPurchase2 tbody').empty();

            var oTable = $('#LPurchase2').DataTable({
                "processing": true, // for show progress bar
                "serverSide": true, // for process server side
                "filter": true, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
                //"bStateSave": true,
                "sortable": true,
                "stateSave": false,
                "bDestroy": true,
                "bLengthChange": true,
                responsive: true,
                "paging": false,
                //"pageLength": 100000,
                "filter": false,
                //"ordering": true,
                "ajax": {
                    "url": '/BillSundry/GetBillSundryUsedList2',
                    "data": function (data) {

                        data.idd = ItemId;

                    },
                    "type": "POST",
                    "datatype": "json"
                },
                "columns": [
                    {
                        "data": "billNo", "name": "billNo",
                        "render": function (data, type, row, meta) {
                            return meta.row + meta.settings._iDisplayStart + 1;
                        }
                    },
                    //{
                    //    "data": "billNo", "name": "billNo",
                    //},
                    {
                        "name": "billNo", "data": function (data) {
                            var rest = "";
                            if (data.text == "Purchase Entry") {
                            @{
                                actData2 = "";
                                if (User.IsInRole("Dev") || User.IsInRole("Edit Purchase Entry"))
                                {
                                    actData2 += "<a href = \"/PurchaseEntry/Edit/' + data.id + '\" target=\"_new\" title=\"Edit Purchase Entry\">'+data.billNo+'</a> ";
                                }
                             }
                                rest += '@Html.Raw(actData2)';
                            } else if (data.text == "Purchase Return") {
                                @{
                                    actData2 = "";
                                    if (User.IsInRole("Dev") || User.IsInRole("Edit Purchase Return"))
                                    {
                                        actData2 += "<a href = \"/PurchaseReturn/Edit/' + data.id + '\" target=\"_new\" title=\"Edit Purchase Return\">'+data.billNo+'</a> ";
                                    }
                             }
                                rest += '@Html.Raw(actData2)';
                            }
                            else if (data.text == "Sales Entry") {
                                if (data.validornot == "valid") {
                                    @{
                                    actData2 = "";
                                    if (User.IsInRole("Dev") || User.IsInRole("Edit Sales Entry"))
                                    {
                                        actData2 += "<a href = \"/CreditSale/Edit/' + data.id + '\" target=\"_new\" title=\"Edit Sales Entry\">'+data.billNo+'</a> ";
                                    }
                                     }
                                    rest += '@Html.Raw(actData2)';
                                } else {
                                     @{
                                    if (User.IsInRole("Dev") || User.IsInRole("Edit Sales Entry"))
                                    {
                                        actData2 = "";
                                        actData2 += "<a href=\"#\" onclick=\"AlertFunction(' + data.userEditDays + ')\" title=\"Edit Sales Entry\">'+data.billNo+'</a> ";
                                    }
                                }
                                rest += '@Html.Raw(actData2)';
                                }

                            }
                            else if (data.text == "Sales Return") {
                                @{
                                    actData2 = "";
                                    if (User.IsInRole("Dev") || User.IsInRole("Edit Sales Return"))
                                    {
                                        actData2 += "<a href = \"/CreditSaleReturn/Edit/' + data.id + '\" target=\"_new\" title=\"Edit Sales Return\">'+data.billNo+'</a> ";
                                    }
                             }
                                rest += '@Html.Raw(actData2)';
                            }
                            else if (data.text == "Materials Received From Party Entry") {
                                @{
                                    actData2 = "";
                                    if (User.IsInRole("Dev") || User.IsInRole("Edit Sales Entry"))
                                    {
                                        actData2 += "<a href = \"/MtFromParty/Edit/' + data.id + '\" target=\"_new\" title=\"Edit Entry\">'+data.billNo+'</a> ";
                                    }
                             }
                                rest += '@Html.Raw(actData2)';
                            }
                            else if (data.text == "Materials Issued to Party Entry") {
                                @{
                                    actData2 = "";
                                    if (User.IsInRole("Dev") || User.IsInRole("Edit Sales Entry"))
                                    {
                                        actData2 += "<a href = \"/MtToParty/Edit/' + data.id + '\" target=\"_new\" title=\"Edit Entry\">'+data.billNo+'</a> ";
                                    }
                             }
                                rest += '@Html.Raw(actData2)';
                            }
                            else if (data.text == "Purchase Order") {
                                @{
                                    actData2 = "";
                                    if (User.IsInRole("Dev") || User.IsInRole("Edit PurchaseOrder"))
                                    {
                                        actData2 += "<a href = \"/PurchaseOrder/Edit/' + data.id + '\" target=\"_new\" title=\"Edit PurchaseOrder\">'+data.billNo+'</a> ";
                                    }
                             }
                                rest += '@Html.Raw(actData2)';
                            }
                            else if (data.text == "Quotation") {
                                @{
                                    actData2 = "";
                                    if (User.IsInRole("Dev") || User.IsInRole("Edit Quotation"))
                                    {
                                        actData2 += "<a href = \"/Quotation/Edit/' + data.id + '\" target=\"_new\" title=\"Edit Quotation\">'+data.billNo+'</a> ";
                                    }
                             }
                                rest += '@Html.Raw(actData2)';
                            }
                            else if (data.text == "Proforma") {
                                @{
                                    actData2 = "";
                                    if (User.IsInRole("Dev") || User.IsInRole("Edit Pro Forma"))
                                    {
                                        actData2 += "<a href = \"/ProForma/Edit/' + data.id + '\" target=\"_new\" title=\"Edit ProForma\">'+data.billNo+'</a> ";
                                    }
                             }
                                rest += '@Html.Raw(actData2)';
                            }




                            return rest;



                        }
                    },
                    {
                        "data": "text", "name": "text",
                    },

                ],
            });


        }
</script>
