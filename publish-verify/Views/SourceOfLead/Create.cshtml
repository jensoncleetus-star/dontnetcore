@model QuickSoft.Models.SourceOfLead
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Add Source Of Lead</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("Create", "SourceOfLead", FormMethod.Post, new { id = "createform" }))
            {
        <script type="text/javascript">
            $('form#createform').removeData("validator");
            $('form#createform').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#createform'));
        </script>
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        <div class="row">
            <div class="col-md-12">
                <div class="form-group">
                    @Html.LabelFor(model => model.SrcName, htmlAttributes: new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.SrcName, new { htmlAttributes = new { @class = "form-control", tabindex = 1, autofocus = "autofocus" } })

                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    @*<input type="submit" value="Submit" class="btn btn-info col-sm-offset-4" tabindex=2 />*@
                    <button type="submit" id="save" class="btn btn-success col-sm-offset-4" tabindex="26">
                        <span class="glyphicon glyphicon-floppy-disk"></span> Save
                    </button>
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>