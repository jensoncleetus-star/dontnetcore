@model QuickSoft.Models.Designation
        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
            <h4>Add Designation</h4>
        </div>
        <div class="modal-body">
            @using (Html.BeginForm("Create", "Designation", FormMethod.Post, new { id = "createform" }))
            {
                <script type="text/javascript">
                    $('form#popupFormDesignation').removeData("validator");
                    $('form#popupFormDesignation').removeData("unobtrusiveValidation");
                    $.validator.unobtrusive.parse($('form#popupFormDesignation'));
                </script>
                @Html.AntiForgeryToken()
                @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        <div class="row">
            <div class="col-md-12">
                <div class="form-group">
                    @Html.LabelFor(model => model.DesignationName, new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.DesignationName, new { htmlAttributes = new { @class = "form-control input-sm", autofocus = "autofocus", @required = "required" } })

                </div>
            </div>
            <div class="col-md-12 ">
                <div class="form-group">
                    @Html.Label("Department", null, new { @class = "control-label" })
                    @Html.DropDownListFor(model => model.department, (SelectList)ViewBag.departments, new { htmlAttributes = new { @class = "form-control input-sm" } })
                </div>
            </div>
        </div>
                
            
            <div class="row">
                <div class="col-md-12">
                    <div class="box-footer">
                        <input type="submit" value="Save" class="btn btn-info col-sm-offset-4" />
                        <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                    </div>
                </div>
            </div>
            }
        </div>
@section scripts{
    @Scripts.Render("~/js/jqueryval")
}