
@model List<QuickSoft.Models.itemtasklist>
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Delete Item Task</h4>
</div>
<div class="modal-body">
    <h3>Are you sure you want to delete this?</h3>
    @using (Html.BeginForm("Delete", "ItemTask", FormMethod.Post, new { id = "deleteform" }))
    {
        @Html.AntiForgeryToken()
        foreach(var m in Model)
                {
                    <a class="modal-delete" href="/ItemTask/Delete/@m.fieldmcid">Qty : @m.qty , Employee : @m.userid - Delete</a><br />
                }
        @*<div class="form-actions no-color">
            <input type="submit" value="Delete" class="btn btn-danger col-sm-offset-4" />
            <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal">
        </div>*@
    }
</div>