@model QuickSoft.ViewModel.UnassembleViewModel
@{
    Layout = null;
}
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Unassemble Voucher Details</h4>
</div>
<div class="modal-body">
    <div class="box box-info">
        <div class="box-body">
            <div class="row">

                <div class="col-sm-2 form-group ">
                    @Html.Label("Voucher No:", null, new { @class = "control-label" })
                    @Html.DisplayFor(m => m.VoucherNo)
                </div>
                <div class="col-sm-2 form-group ">
                    @Html.Label("Date:", null, new { @class = "control-label" })
                    @(Convert.ToDateTime(Model.PEDate).ToString("dd-MM-yyyy"))
                </div>
                <div class="col-sm-2 form-group ">
                    @Html.Label("Material center :", null, new { @class = "control-label" })
                    @Html.DisplayFor(m => m.MC)
                </div>
                <div class="col-sm-2 form-group ">
                    @Html.Label("Branch Name:", null, new { @class = "control-label" })
                    @Html.DisplayFor(m => m.BranchName)
                </div>
                @if (Model.Project != null)
                {
                    <div class="col-sm-2 form-group ">
                        @Html.Label("Project:", null, new { @class = "control-label" })
                        @Html.DisplayFor(m => m.ProjectName)
                    </div>
                }
                @if (Model.ProTask != null)
                {
                    <div class="col-sm-2 form-group ">
                        @Html.Label("Task:", null, new { @class = "control-label" })
                        @Html.DisplayFor(m => m.TaskName)
                    </div>
                }
                <div class="col-sm-12 form-group">
                    @if (Model.Emp != null && Model.Emp.Count() > 0)
                    {
                        @Html.Label("Approved By:", null, new { @class = "control-label" })
                        bool CHECK = true;
                        foreach (var Ext in Model.Emp)
                        {
                            var EmpName = "";
                            if (CHECK == true)
                            {
                                EmpName = @Ext.EmpName;
                                CHECK = false;
                            }
                            else
                            {
                                EmpName = ", " + @Ext.EmpName;
                            }

                            @Html.Label(@EmpName, new { @style = "font-weight:normal" })
                        }
                    }
                </div>
                @if (Model.FieldMap.Count > 0)
                {
                    for (int i = 0; i < Model.FieldMap.Count; i++)
                    {
                        <div class="form-group col-sm-2">

                            @if (Model.FieldMap[i].FieldName != "" && Model.FieldMap[i].Field == "Ref1")
                            {
                                <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName :</label>
                                @Html.DisplayFor(m => m.Ref1)
                            }
                            @if (Model.FieldMap[i].FieldName != "" && Model.FieldMap[i].Field == "Ref2")
                            {
                                <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName :</label>
                                @Html.DisplayFor(m => m.Ref2)
                            }
                            @if (Model.FieldMap[i].FieldName != "" && Model.FieldMap[i].Field == "Ref3")
                            {
                                <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName :</label>
                                @Html.DisplayFor(m => m.Ref3)
                            }
                            @if (Model.FieldMap[i].FieldName != "" && Model.FieldMap[i].Field == "Ref4")
                            {
                                <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName :</label>
                                @Html.DisplayFor(m => m.Ref4)
                            }
                            @if (Model.FieldMap[i].FieldName != "" && Model.FieldMap[i].Field == "Ref5")
                            {
                                <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName :</label>
                                @Html.DisplayFor(m => m.Ref5)
                            }
                        </div>
                    }
                }
                <div class="clearfix"></div>
            </div>
            <div>
                <div class="table-responsive">
                  
                        <div class="box-header with-border">
                            <h3 class="box-title">BOM :-</h3>
                            @Html.DisplayFor(m => m.ItemName)
                        </div>
                        <div class="box-header with-border">
                            <h3 class="box-title">Items Consumed</h3>
                        </div>
                        <div class="box-body">
                            <table class="table table-bordered table-hover">
                                <tr class="bg-gray">
                                    <th>Item</th>
                                    <th>Item Unit</th>
                                    <th>Quantity</th>
                                    <th>Price</th>
                                    <th>Amount</th>
                                </tr>
                                @foreach (var itemss in Model.UnasCon)
                                {
                                    <tr>
                                        <td>@itemss.ItemName</td>
                                        <td>@itemss.ItemUnit</td>
                                        <td>@itemss.Quantity</td>
                                        <td>@itemss.Price</td>
                                        <td>@itemss.Amount</td>
                                    </tr>
                                }
                            </table>
                        </div>
                        <div class="box-header with-border">
                            <h3 class="box-title">Items Generated</h3>
                        </div>
                        <div class="box-body">
                            <table class="table table-bordered table-hover">
                                <tr class="bg-gray">
                                    <th>Item</th>
                                    <th>Item Unit</th>
                                    <th>Quantity</th>
                                    <th>Price</th>
                                    <th>Amount</th>
                                </tr>
                                @foreach (var itemss in Model.UnasItemvmodel)
                                {
                                    <tr>
                                        <td>@itemss.ItemName</td>
                                        <td>@itemss.ItemUnit</td>
                                        <td>@itemss.Quantity</td>
                                        <td>@itemss.Price</td>
                                        <td>@itemss.Amount</td>
                                    </tr>
                                }
                            </table>
                        </div>
                    
                </div>
                <div class="row">
                    <div class="col-md-6">
                        @*<div class="form-group">
                            <strong>Narration </strong><br />
                            @Html.Raw(Model.Note)
                        </div>*@
                    </div>
                </div>
        </div>
    </div>
</div>
    </div>