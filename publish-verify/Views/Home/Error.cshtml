@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>Please Contact Service Provider - BOS</title>
    <!-- Tell the browser to be responsive to screen width -->
    <meta content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport">
    @Styles.Render("~/css/css")
    @Scripts.Render("~/js/modernizr")
</head>
<body class="hold-transition lockscreen">
    <!-- Automatic element centering -->
    <div class="lockscreen-wrapper">
        <div class="lockscreen-logo">
            <h1>@*<img src="../content/img/logo.svg" width="40">*@Quick <b>ERP</b></h1>
        </div>
        <!-- /.lockscreen-item -->
        <div class="help-block text-center">
            <h3><i class="fa fa-warning text-yellow"></i> We are sorry..., <br />There Is An Error In Your System</h3>
        </div>
        <div class="text-center">
            <a href="http://quicknet.me/">Please Contact Us For More Details </a><br />
            +971-02-5531474, +971-556517892, +971-556517832
        </div>
        <div class="lockscreen-footer text-center">
            <p><strong>Copyright &copy; @DateTime.Now.Year <a href="#" data-toggle="modal" data-target="#quicknet"> Quick Soft</a> All rights reserved.</strong> </p>
            <div id="quicknet" class="modal fade" role="dialog" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="attachment-block clearfix">
                            <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                            <img class="img-circle attachment-img" src="/quicknet.png" alt="Quicknet">
                            <h2>Quick Net Computers</h2>
                            <h4>The trusted IT Sales, Service and Networking partner</h4>
                            <p>Quick Net Computers is a total IT solution company that focuses solely on the computing, networking and business application needs arising in a business entity. Serving hundreds of organizations across every major industries, the company helps it’s clients achieve their business leadership objectives by lowering the cost and maximizing the performance of their information technology systems.</p>
                            <p>Quick Net provides communication background to all other network services. Data Network structures today include LAN, WAN, the Internet, Intranets, extranets and value added networks, which demands correct network design and increasing demands for safety, access, management and adding new services like IP Telephony and Video Conferencing. We design the networks for our customers by taking account of the structure of the target organization and the company processes and approaches individual components, so that together they provide maximum service availability at optimal operational cost and increased security.</p>
                            <div class="text-center">
                                <a href="http://quicknet.me/" class="btn btn-info" target="_blank">Website</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- /.center -->
    @Scripts.Render("~/js/js")
</body>
</html>

