            }
        });
        var chkcol = '@userRole';
        if (chkcol == "True") {
            var column1 = oTable.column(10);
            column1.visible(true);
        } else {
            var column1 = oTable.column(10);
            column1.visible(false);
        }
        var statcol = '@ViewBag.MLAMRNote';
        if (statcol == "active") {
            var column1 = oTable.column(8);
