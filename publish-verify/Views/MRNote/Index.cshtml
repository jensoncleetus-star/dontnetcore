@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/bootstrap-timepicker")
}

@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/bootstrap-timepicker")
    <script type="text/javascript">

        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });
        jQuery.validator.methods["date"] = function (value, element) { return true; }
        $(".timepicker").timepicker({
            showInputs: true,
            defaultTime: false,
            format: 'dd-mm-yyyy'
        });

        $(document).ready(function () {
            $('#advsearch').hide();
        });
        var oTable = $('#PoTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "pageLength": 50,
            responsive: true,
            "bLengthChange": false,
            "ajax": {
                "url": '/MRNote/GetMRNote',
                "data": function (data) {
                    data.BillNo = $('#BillNo').val();
                    data.FromDate = $('#FromDate').val();
                    data.ToDate = $('#ToDate').val();
                    data.supplier = $('#ddlSupplier').val();
                    data.salesperson = $('#ddlEmployee').val();
                    data.type = $('#Type').val();
                    data.user = $('#ddlCreatedBy').val();
                    data.appstat = $('#ApprovalStatus').val();
                },
                "type": "POST",
                "datatype": "json"

            },
            "order": [[0, "desc"]],
            "columnDefs": [{
                "targets": [9, 10],
                "orderable": false
            }],
            "columns": [
                     {
                         "data": "MRId", "name": "MRId",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                { "data": "BillNo", "name": "BillNo" },
                { "data": "MRDate", "name": "MRDate", "render": function (data) { return convertToDate(data); } },
                { "data": "Supplier", "name": "Supplier" },
                { "data": "RequestedDate", "name": "RequestedDate", "render": function (data) { if (data != null) { return convertToDate(data); } else { return "" } } },
                { "data": "EmpName", "name": "EmpName" },
                {
                    "name": "Type", "data": function (data) {
                        if (data.Type == "0") {
                            return 'Against PO';
                        }
                        else {
                            return 'Direct';
                        }
                    }
                },
                { "data": "user", "name": "user" },
                {
                    "name": "ApprovalStatus", "data": function (data, type, dataToSet) {
                        var status = "";
                        var cls = "";
                        if (data.app.length > 0 || (data.Approval == true && '@ViewBag.MLAMRNote' == 'active')) {
                            if (data.ApprovalStatus == "0") {
                                status = '<span class="badge bg-green">Approved</span>';
                            }
                            else if (data.ApprovalStatus == "1") {
                                status = '<span class="badge bg-red">Rejected</span>';
                            }
                            else if (data.ApprovalStatus == "2") {
                                status = '<span class="badge bg-orange">Pending</span>';
                            }
                            return '<a  class="Updation" onclick="details(' + data.MRId + ')"  title="View Status">' + status + ' </a>';
                        } else { return null; }
                    }
                },
                {
                    "name": "MRId", "data": function (data) {
                        var rest = "";
                        @{
                            string bosMrPrint = "";
                            if (User.IsInRole("Dev") || User.IsInRole("Invoice Template"))
                            {
                                bosMrPrint = "<a href=\"/InvoiceTemplate/Print?invoiceId='+ data.MRId +'&docType=MaterialRequisition\" target=\"_blank\" title=\"Print with a custom template\"><i class=\"fa fa-lg fa-print\" style=\"color:#6366f1\"></i></a> ";
                            }
                        }
                        rest += '@Html.Raw(bosMrPrint)';
                        @{
                            if (User.IsInRole("Dev") || User.IsInRole("View MRNote"))
                            {
                                actData += "<a class=\"details\" href=\"/MRNote/Details/'+ data.MRId +'\" title=\"View MRNote\"><i class=\"fa fa-lg fa-search-plus\"></i></a> ";
                            }
                            //if (User.IsInRole("Dev") || User.IsInRole("Edit MRNote"))
                            //{
                            //    actData += "<a href=\"/MRNote/Edit/'+ data.MRId +'\" title=\"Edit MRNote\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                            //}
                            if (User.IsInRole("Dev") || User.IsInRole("Delete MRNote"))
                            {
                                actData += "<a class=\"modal-delete\" href=\"/MRNote/Delete/'+ data.MRId +'\" title=\"Delete MRNote\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";
                            }
                            if (User.IsInRole("Dev") || User.IsInRole("Download MRNote"))
                            {
                                actData += "<a class=\"modal-link-download\" href=\"/MRNote/Download/'+ data.MRId +'\" title=\"Download MRNote\"><i class=\"fa-lg fa fa-download\" ></i></a> ";
                            }
                        }
                        rest += '@Html.Raw(actData)';
                        //Convert To Purchase
                        if (data.ApprovalStatus == "0" && data.PEConvert == "Purchase" && data.MRNotetToPEntry == true) {
                            @{
                                actData = "";
                                if (User.IsInRole("Dev") || User.IsInRole("Purchase Entry"))
                                {

                                    actData += "<a href=\"/PurchaseEntry/Create/'+ data.MRId+'/MRNote\" title=\"Convert To Purchase Entry\" class=\"text-red\"><i class=\"fa-lg fa fa-exchange\" ></i></a> ";
                                }
                            }
                            rest += '@Html.Raw(actData)';
                        }
                        else {
                            if (data.ApprovalStatus == "0" && data.MRNotetToPEntry == true) {
                            @{
                                actData = "";
                                if (User.IsInRole("Dev") || User.IsInRole("Purchase Entry"))
                                {
                                    actData += "<a href=\"/PurchaseEntry/Create/'+ data.MRId+'/MRNote\" title=\"Convert To Purchase Entry\"><i class=\"fa-lg fa fa-exchange\" ></i></a> ";
                                }
                            }
                                rest += '@Html.Raw(actData)';
                            }
                        }
                        @*if (data.ApprovalStatus != "1" && data.PEConvert == "Purchase" && data.MRNotetToPEntry == true) {
                            @{
                                actData = "";
                                if (User.IsInRole("Dev") || User.IsInRole("Purchase Entry"))
                                {

                                    actData += "<a href=\"/PurchaseEntry/Create/'+ data.MRId+'/MRNote\" title=\"Convert To Purchase Entry\" class=\"text-red\"><i class=\"fa-lg fa fa-exchange\" ></i></a> ";
                                }
                            }
                            rest += '@Html.Raw(actData)';
                        }
                        else {
                            if (data.ApprovalStatus != "1" && data.MRNotetToPEntry == true) {
                            @{
                                actData = "";
                                if (User.IsInRole("Dev") || User.IsInRole("Purchase Entry"))
                                {
                                    actData += "<a href=\"/PurchaseEntry/Create/'+ data.MRId+'/MRNote\" title=\"Convert To Purchase Entry\"><i class=\"fa-lg fa fa-exchange\" ></i></a> ";
                                }
                            }
                                rest += '@Html.Raw(actData)';
                            }
                        }*@
                        @*if (data.app.length > 0 || (data.Approval == true && '@ViewBag.MLAMRNote' == 'active')) {
                            if (data.ApprovalStatus != "0") {*@
                                    @{
                                if (User.IsInRole("Dev") || User.IsInRole("Edit MRNote")) {

                                actData = "";
                                actData += "<a href=\"/MRNote/Edit/'+ data.MRId +'\" title=\"Edit MRNote\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                                }
                                }
                                 rest += '@Html.Raw(actData)';
                        //    }
                        //}

                        if (data.Approval == true && '@ViewBag.MLAMRNote' == 'active') {
                            @{
                                actData = "";
                                actData = "<a class=\"modal-edit\"  href=\"/MRNote/EditStatus/'+  data.MRId +'\" title=\"Edit Status\"><i class=\"fa fa-lg fa-refresh\" ></i></a> ";
                            }
                            rest += '@Html.Raw(actData)';
                        }

                        if ("@ViewBag.Remind" == "active") {
                            @{
                                    actData = "";
                                    actData += "<a class=\"UpdationRe\" onclick=\"detailsRemind(' + data.MRId + ')\" title=\"View Reminder\"><i class=\"fa-lg fa fa-bell\" ></i></a> ";
                                    actData += "<a class=\"modal-create\" href=\"/Reminder/AddReminder/'+ data.MRId +'/MRNote\" title=\"Add Reminder\"><i class=\"fa-lg fa fa-sticky-note\" ></i></a> ";
                                }
                            rest += '@Html.Raw(actData)';
                        }
                        return rest;
                    }
                },
                 {
                     "name": "MRId", "data": function (data) {
                         var rest = "";
                         @{
                             if (User.IsInRole("Dev") || User.IsInRole("Delete MRNote"))
                             {
                                 delchk = "<input class=\"checkbox\" type=\"checkbox\" name=\"bill[]\" value='+ data.MRId +'></input>";
                             }
                         }
                         return rest = '@Html.Raw(delchk)';
                     }
                 },
            ],
            buttons: [
               'colvis',
               {
                   extend: 'print',//
                   title: "",
                   footer: true,
                   filename: function () {
                       return 'Material Receive Note';
                   },
                   columnDefs: [
                       { width: 400, targets: 2 }
                   ],
                   exportOptions: {
