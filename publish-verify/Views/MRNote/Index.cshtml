@model QuickSoft.Models.MaterialReceiveNote
@{
    ViewBag.Title = "List";
    ViewBag.SubTitle = "Material Receive Note";
    ViewBag.Active = "Transactions";
    string actData = "";
    string delchk = "";
    bool userRole = false;
    string deleteBTn = "";
    if (User.IsInRole("Dev") || User.IsInRole("Delete MRNote"))
    {
        userRole = true;
        deleteBTn = "{text: 'Delete', className: 'btn-danger', action: function(e, dt, node, config) {" +
              "if ($('.checkbox:checked').length > 0) {if (confirm('Are you sure you want to delete this?')) {$('#delallform').submit(); e.preventDefault();} " +
               "} else {alert('Please Select Rows..!!');e.preventDefault();}}},";
    }
}
<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">List Material Receive Note</h3>
        <div class="pull-right">
            @if (User.IsInRole("Dev") || User.IsInRole("Invoice Template"))
            {
                <a class="btn btn-default no-border" href="/InvoiceTemplate/Index?docType=MaterialRequisition" title="Design / manage material-requisition print templates">
                    <i class="glyphicon glyphicon-duplicate"></i> Design Templates
                </a>
            }
            @if (User.IsInRole("Dev") || User.IsInRole("MRNote Entry"))
            {
                <i class="ace-icon fa fa-hand-o-right icon-animated-hand-pointer blue"></i>
                <a class="btn btn-info no-border" href="/MRNote/Create">
                    <i class="glyphicon glyphicon-plus"></i> Create
                </a>
            }
        </div>
    </div>

    <div class="box-body search-box">
        <a class="btn btn-primary" id="srch">
            <i class="glyphicon glyphicon-search"></i> Advanced Search
        </a>

        <div class="search-body col-md-12" id="advsearch" style="display:block;position:relative">
            <form id="search-form">
                <div class="row">
                    <input type="hidden" id="remId" />
                    <div class="form-group col-md-2">
                        @Html.Label("MRNote No", null, new { @class = "control-label" })
                        @Html.TextBox("BillNo", "", new { @class = "form-control input-sm" })
                    </div>
                    <div class="form-group col-md-2">
                        @Html.Label("From Date", null, new { @class = "control-label" })
                        <div class="input-group date">
                            @Html.TextBox("FromDate", "01-09-2023", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                            <div class="input-group-addon">
                                <i class="fa fa-calendar"></i>
                            </div>
                        </div>
                    </div>
                    <div class="form-group col-md-2">
                        @Html.Label("To Date", null, new { @class = "control-label" })
                        <div class="input-group date">
                            @Html.TextBox("ToDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                            <div class="input-group-addon">
                                <i class="fa fa-calendar"></i>
                            </div>
                        </div>
                    </div>
                    <div class="form-group col-md-2" id="creditsale">
                        @Html.Label("Supplier", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlSupplier", (SelectList)ViewBag.Supplier, new { @class = "form-control input-sm select2" })
                    </div>
                    <div class="form-group col-md-2" id="execreditsale">
                        @Html.Label("Requested By", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlEmployee", (SelectList)ViewBag.SalesExecutive, new { @class = "form-control input-sm select2" })
                    </div>
                    <div class="form-group col-md-2" id="crecreditsale">
                        @Html.Label("Created By", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlCreatedBy", (SelectList)ViewBag.CreatedBy, "All", new { @class = "form-control input-sm select2" })
                    </div>
                    <div class="form-group col-md-2" id="valcreditsale">
                        @Html.Label("Validitys", null, new { @class = "control-label" })
                        @Html.TextBox("Validity", "", new { @class = "form-control input-sm" })
                    </div>
                    <div class="form-group col-md-2">
                        @Html.Label("Type", null, new { @class = "control-label" })
                        @Html.DropDownList("Type", (SelectList)ViewBag.MRType, new { @class = "form-control" })
                    </div>
                    @if (ViewBag.MLAMRNote == 0)
                    {
                        <div class="form-group col-md-2">
                            @Html.Label("Approval Status", null, new { @class = "control-label" })
                            @Html.DropDownList("ApprovalStatus", (SelectList)ViewBag.AppStat, "All", new { id = "ApprovalStatus", @class = "form-control" })
                        </div>
                    }
                </div>
                <div class="row">
                    <div class="col-md-12">
                        <input type="submit" class="btn btn-submit col-sm-offset-5" value="Submit" />
                        <input type="button" class="btn btn-close" value="Close" />
                    </div>
                </div>
            </form>
        </div>
    </div>

    @using (Html.BeginForm("DeleteAllMRNote", "MRNote", FormMethod.Post, new { id = "delallform", role = "form" }))
    {
        <div class="box-body">
            <table class="table table-bordered table-hover" id="PoTable">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="2">S/N</td>
                        <td data-priority="1">MR Note No</td>
                        <td data-priority="2">Date</td>
                        <td data-priority="4">Supplier</td>
                        <td data-priority="3">Requested Date</td>
                        <td data-priority="5">Requested By</td>
                        <td data-priority="3">Type</td>
                        <td data-priority="5">Created By</td>
                        <td data-priority="3">Approval Status</td>
                        <td data-priority="2">Action</td>
                        <td data-priority="2"><input type="checkbox" id="select_all" /></td>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>

        </div>
    }
    <div id="modal-container2" class="modal fade" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-aqua">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                    <h4>Status Updation History</h4>
                </div>
                <div class="modal-body">
                    <table class="table table-bordered table-hover" id="UserTableInfo">
                        <thead>
                            <tr class="bg-aqua">
                                <td>Status</td>
                                <td>Updated By</td>
                                <td>Requested By</td>
                                <td>Date</td>
                                <td>Remarks</td>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>


@{var Model = "modal-lg";}
