                },
            });
        });

        //Account Group
        $("#AccGroup").select2({
            placeholder: 'Search Account Group Name ',
            minimumInputLength: 0,
            ajax: {
                url: "/Accounts/SearchGroup",
                dataType: 'json',
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term || "",
                        page: params.page || 0,
                        x: "All"
                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 0;

                    return {
