@section style{
    @Styles.Render("~/css/jstree")
}
@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/bootstrap-timepicker")
    @Scripts.Render("~/js/bootstrap-fileinput")
    @Scripts.Render("~/js/bootstrap-sortable")
    <script type="text/javascript">

        $(document).ready(function () {
           
            $('#advsearchlist').show();
            CallCustomer();
            $("#searchstatus").show();

            $("#searchalias").hide();
            $("#searchaccntname").hide();
            $("#searchTRNno").hide();
            _show = 1;

            $("#AssignedUsers").select2({
                placeholder: 'Search Employees by Name',
                minimumInputLength: 0,
                ajax: {
                    url: "/Employee/SearchEmployee",
                    dataType: 'json',
                    type: "POST",
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term,
                            page: params.page,
                            x: "all"
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;

                        return {
                            results: data
                        };
                    },
                    cache: true
                },
            });

        });
            var oTable = $('#MyTable').DataTable({
                "processing": true, // for show progress bar
                "serverSide": true, // for process server side
                "filter": true, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
                "bStateSave": true,
                "pageLength": 50,
                responsive: true,
                "ajax": {
                    "url": '/Password/GetData',
                    "data": function (data) {

                        data.AccGroup = $('#ddlCustomer').val();
                        data.empid = $("#AssignedUsers").val();
                    },
                    "type": "POST",
                    "datatype": "json"
                },
                "order": [[0, "desc"]],

                "columns": [
                         {
                        "data": "PasswordDataId", "name": "PasswordDataId",
                             "render": function (data, type, row, meta) {
                                 return meta.row + meta.settings._iDisplayStart + 1;
                             }
                         },
                    { "data": "Title", "name": "Title" },
                    { "data": "customers", "name": "customers" },
                    { "data": "UserName", "name": "UserName" },
               
                    { "data": "Password", "name": "Password" },

                    { "data": "Url", "name": "Url" },
                    { "data": "Notes", "name": "Notes" },
                    {
                        "name": "AssignedTo", "data": function (data) {
                            var datas = "";
                            $.each(data.AssignedTo, function (i, item) {
                                if (datas != "") {
                                    datas += ", ";
                                }
                                datas += item.FirstName + " " + item.LastName;
                            })
                            return datas;
                        }
                    },
                      {
                          "name": "PasswordDataId", "data": function (data) {
                              rest = '';
                              if (1==1) {
                                  rest += '@Html.Raw(actData)';
                                  @{
                                      action = "";
                                      action += "<a class=\"detailss\" href=\"/LogDetails/?TransId='+ data.PasswordDataId +'&TransType='+ 'Passwords' +'\" title=\"View Password Entry\" target=\"new\"><i class=\"fa fa-lg fa-history\"></i></a> ";


                                      action += "<a class=\"modal-edits\" href=\"/Password/Edit/' + data.PasswordDataId + '\"title=\"Edit Password\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                                      action += "<a class=\"modal-delete\" href=\"/Password/Delete/' + data.PasswordDataId + '\"title=\"Delete Password\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";


                                      if (User.IsInRole("Dev") || User.IsInRole("Edit Password"))
                                      {

                                      }
                                      if (User.IsInRole("Dev") || User.IsInRole("Delete Password`"))
                                      {

                                      }
                               }
                                  rest = '@Html.Raw(action)';
                              }
                              else {
                                  @{
                                  action = "";
                                  action = "<a class=\"modal-edit\" href=\"/Accounts/Edit/' + data.id + '\"title=\"Edit Accounts\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";

                              }
                                  rest = '@Html.Raw(action)';
                              }
                              return rest;
                          }
                      },

                ],
                dom: 'Bfrtip',
                buttons: ['colvis', {
                    extend: 'print',//
                    title: "",
                    footer: true,
                    exportOptions: {
                        columns: ':visible'
                    },
                    message: '<table class="tblcompact table table-bordered"><thead>' +
                        ' <tr><th class="text-center"><h3 style="margin-top: 0px;">' + '<h4>Accounts </h4></th></tr>' +
                        ' <tr><th><span class="text-left"></span><span class="text-right pull-right"> </span></th></tr></thead><tbody><tr><td>',
                    customize: function (win) {
                        // $(win.document.body)
                        //.css('font-size', '10pt')
                        //.css('padding', '1px');
                        $(win.document.body).find('table, th,tr, td ')
                           // .css('border', 'inherit')
                            .css('font-size', '10pt')
                            .css('padding', '5px')
                            .addClass('compact');
                        $(win.document.body).append('</td></tr></tbody>')
                    }
                }, 'copy', 'csv', 'excel',

                {
                    extend: 'pdf',//
                    title: "Accounts",
                    footer: true,
                    orientation: 'landscape',

                    pageSize: 'A4',
                    exportOptions: {
                        columns: ':visible'
                    },
                    customize: function (doc) {
                        doc.pageMargins = [10, 10, 10, 10];
                        doc.defaultStyle.fontSize = 10;
                        doc.styles.tableHeader.fontSize = 10;
                        doc.styles.title.fontSize = 12;
                        // Remove spaces around page title
                        doc.content[0].text = doc.content[0].text.trim();

                        doc.styles['td:nth-child(2)'] = {
                            width: '100%',
                            'max-width': '100%'
                        }

                        var objLayout = {};
                        // Horizontal line thickness
                        objLayout['hLineWidth'] = function (i) { return .5; };
                        // Vertikal line thickness
                        objLayout['vLineWidth'] = function (i) { return .5; };
                        //// Horizontal line color
                        //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                        //// Vertical line color
                        //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                        // Left padding of the cell
                        objLayout['paddingLeft'] = function (i) { return 4; };
                        // Right padding of the cell
                        objLayout['paddingRight'] = function (i) { return 4; };
                        // Inject the object in the document
                        doc.content[1].layout = objLayout;
                    }
                },

                  @Html.Raw(deleteBTn)

                ],

                "drawCallback": function (settings) {
                    var table = $('#MyTable').DataTable();
                    if (!table.data().any()) {
                        $("#sub").hide();
                    } else {
                        $("#sub").show();
                    }
                }
            })

            //Button Close
            $('#srch, .search-box .btn-close').on('click', function (e) {
                $('#advsearchlist').toggle();

                /*******  To uncheck all the checkboxes in the Select List  ************/
                var checkboxes = document.querySelectorAll("input[type='checkbox']");
                checkboxes.forEach(function (Checkbox) {
                    Checkbox.checked = false;
                });

                if ($('#srch').hasClass('btn-primary')) {

                    $('#srch').addClass('btn-danger');
                    $('#srch').removeClass('btn-primary');
                }
                else {
                    if ($('#srch').hasClass('btn-danger')) {
                        $('#srch').addClass('btn-primary');
                        $('#srch').removeClass('btn-danger');
                    }

                    /*******  To clear all the data entered  *********/
                    $('#ddlAccounts').val(0).trigger("change");
                    $('#Alias').val("");
                    $('#AccGroup').val(0).trigger("change");
                    $('#Status').val(null);
                    $('#TRNNo').val(null).trigger("change");
                    oTable.draw();
                }
            });

            $('#search-form').on('submit', function (e) {
                e.preventDefault();
                oTable.draw();
            });
        $('#ddlPagesize').on('change', function (e) {

            let pagedroplength = $('#ddlPagesize').val();
            oTable.page.len(pagedroplength).draw();
        });
