@{
    ViewBag.Title = "Payment Register";
    ViewBag.SubTitle = "Payment";
    ViewBag.Active = "Registers";
}
<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">Search Payment Registers</h3>
    </div>
    <div class="box-body">
        <form id="search-form">
            <input type="hidden" id="cname" value="@ViewBag.CName" />
            <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
            <div class="form-group col-md-4">
                @Html.Label("Voucher Number", null, new { @class = "control-label" })
                @Html.TextBox("VoucherNumber", "", new { @class = "form-control input-sm" })
            </div>
            <div class="form-group col-md-4">
                @Html.Label("Pay From", null, new { @class = "control-label" })
                @Html.DropDownList("ddlPayFrom", (SelectList)ViewBag.Paidfrom, "All", new { @class = "form-control select2" })
            </div>
            <div class="form-group col-md-4">
                @Html.Label("Pay To", null, new { @class = "control-label" })
                @Html.DropDownList("ddlPayTo", (SelectList)ViewBag.PaidTo, new { @class = "form-control select2" })
            </div>
            <div class="form-group col-sm-4">
                @Html.Label("Mode Of Payment", null, new { @class = "control-label" })
                @Html.DropDownList("MOPayment", new SelectList(new List<SelectListItem>
                            {
                           new SelectListItem() {Text = "CASH", Value="1"},
                           new SelectListItem() {Text = "PDC", Value="2"},
                           new SelectListItem() {Text = "CDC", Value="3"},
                            }, "Value", "Text"), new { multiple = "multiple", @class = "form-control input-sm", @name = "MOPayment" })
            </div>
            <div class="form-group col-md-4">
                @Html.Label("From", null, new { @class = "control-label" })
                <div class="input-group date">
                    @Html.TextBox("From", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                    <div class="input-group-addon">
                        <i class="fa fa-calendar"></i>
                    </div>
                </div>
            </div>
            <div class="form-group col-md-4">
                @Html.Label("To", null, new { @class = "control-label" })
                <div class="input-group date">
                    @Html.TextBox("To", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                    <div class="input-group-addon">
                        <i class="fa fa-calendar"></i>
                    </div>
                </div>
            </div>
            <div class="box-footer col-md-12">
                <button type="submit" class="btn btn-info col-sm-offset-5" id="btn">Submit</button>
                <button type="button" class="btn btn-default" onclick="@("window.location.href='/Home/Index'");">Cancel</button>
                <input type="hidden" value="@ViewBag.StartDate" class="Start" name="Start" id="Start">
                <input type="hidden" value="@ViewBag.EndDate" class="End" name="End" id="End">
            @*<button class="btn btn-default" type="Reset" id="btnreset">Reset</button>*@
            </div>
        </form>
    </div>
</div>

<div class="box box-default" id="PaymentReport">
    <div class="box-header with-border">
        <h3 class="box-title">View Payment Register</h3>
    </div>
    <div class="box-body">
        <div class="box-body">
            <table class="table table-bordered" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="1">S/N</td>
                        <td data-priority="2">Date</td>
                        <td data-priority="1">Particulars</td>                                          
                        <td data-priority="3">Voucher Type</td>
                        <td data-priority="4">Voucher No</td>
                        <td data-priority="5">Debit Amount</td>
                        <td data-priority="4">Credit Amount</td>
                    </tr>
                </thead>
                <tbody></tbody>                
            </table>
        </div>
    </div>
</div>

@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
}
@section Scripts {
    @Scripts.Render("~/js/bootstrap-datepicker")
    <script type="text/javascript">
        var minDate = $("#Start").val();
        var maxDate = $("#End").val();
        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true,
            startDate: new Date(minDate),
            endDate: new Date(maxDate)
        });

        //$('.date').datepicker({
        //    format: 'dd-mm-yyyy',
        //    autoclose: true,
        //    allowInputToggle: true
        //})

        $(document).ready(function () {
            var minDate = $("#Start").val();
            var maxDate = $("#End").val();

            //for set default date
            $('#To').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });
            $('#From').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });

            var date = new Date();
            var today = new Date(date.getFullYear(), date.getMonth(), date.getDate());
            var priordate = new Date(new Date().setDate(today.getDate() - 30));
            $('#To').datepicker('setDate', today);
            $('#From').datepicker('setDate', priordate);
            //---


            $('#PaymentReport').hide();
            $('#ddlPayFrom').select2();
            $('#MOPayment').select2();
            $("#ddlPayTo").select2({
                placeholder: 'Search Account By Code or name',
                minimumInputLength: 0,
                ajax: {
                    //url: "/Accounts/SearchAccounts",
                    url: "/Accounts/SearchAccountsPayTo",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term || "",
                            page: params.page || 0,
                            x: "All"
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 0;
                        return {
                            results: data,
                            pagination: {
                                //more: (params.page * 10) < 50
                                more: true
                            }
                        };
                    },
                    cache: true
                },
                templateResult: SelectToGroup,
                templateSelection: ToSetFormatSelection,
            });

        });
        jQuery(function ($) {
            oTable = $('#UserTable').DataTable({
                "processing": true, // for show progress bar
                "serverSide": true, // for process server side
                "filter": false, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
                // "bStateSave": true,
                "bLengthChange": false,
                "paging": true,
                "pageLength": 5000,
                "deferLoading": 0,
                "ordering": false,
                "ajax": {
                    "url": '/Registers/GetPayment',
                    "data": function (data) {
                        data.vno = $('#VoucherNumber').val();
                        data.payfrom = $('#ddlPayFrom').val();
                        data.payto = $('#ddlPayTo').val();
                        data.fromdate = $('#From').val();
                        data.todate = $('#To').val();
                        data.MOPay = $('#MOPayment').val();
                    },
                    "type": "POST",
                    "datatype": "json"
                },
                "order": [[0, "desc"]],
                "columns": [
                     {
                         "data": "ReceiptId", "name": "ReceiptId",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                     { "data": "Date", "name": "Date", "render": function (data) { return convertToDate(data); } },
                     {
                         "name": "Particulars", data: { Payer: "PayTo", Reciever: "PayFrom", DiscountAc: "DiscountAc", Discount: "Discount", Details: "Details" },
                         mRender: function (data, type, full) {
                             var str = "";
                             $.each(data.Details, function (i, item) {
                                 var strnew = '<div><span class="pull-left"> &nbsp;&nbsp;&nbsp;&nbsp;'
                                                + item.RefType + ' ' + item.Reference + '</span> <span class="pull-right">' + item.Amount + ' Dr' + "<span></div>";
                                 str = str + '<br/>' + strnew;
                             });
                             var disc = (data.Discount == 0) ? '' : (data.DiscountAc + ' </span> <span class="pull-right">' + data.Discount + ' Cr' + '</b>');
                             var tax=(data.Tax==0)?'':'Tax' + ' <span class="pull-right">' + data.Tax + ' Dr' + '</b><br/><b>';
                             var rslt = '<div>' + '<b>' + data.Reciever + '</b>'
                                        + str + '<br/>' + '<b>'
                                        + data.Payer + ' <span class="pull-right">' + data.Paying + ' Cr' + '</b><br/><b>'
                                        +tax + disc  + "<span></div>";
                             return rslt;
                         }
                     },
                     { "data": "modeofpay", "name": "VoucherType" },
                     { "data": "VoucherNo", "name": "VoucherNo" },
                     { "data": "Paying", "name": "DebitAmount", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                     { "data": "crdtAmt", "name": "CreditAmount" },//null
                ],
                buttons: [//'copy', 'csv', 'excel', 'pdf', 'print'
            'colvis',
                {
                    extend: 'print',//
                    exportOptions: {
                        columns: ':visible',
                        //stripNewlines: false
                        stripHtml: false
                    },
                    title: "",
                    footer: true,
                    filename: function () {
                        return 'Payment-Register';
                    },
                    message: function () {
                        var head = '<table class="tblcompact table table-bordered"><thead>' +
                            ' <tr><th class="text-center"><h3 style="margin-top: 0px;">' + $('#cname').val() + '</h3>' + $('#caddress').val() + '<h4>Payment Register</h4></th></tr>' +
                            ' <tr><th><span class="text-left"></span><span class="text-right pull-right"> From :  ' + $('#From').val() + ' To :' + $('#To').val() + '</span></th></tr></thead><tbody><tr><td>';
                        return head;
                    },
                    customize: function (win) {
                        // $(win.document.body)
                        //.css('font-size', '10pt')
                        //.css('padding', '1px');
                        $(win.document.body).find('table, th,tr, td ')
                           // .css('border', 'inherit')
                            .css('font-size', '10pt')
                            .css('padding', '5px')
                            .addClass('compact');
                        $(win.document.body).append('</td></tr></tbody>')

                    }
                }, 'copy', 'csv', //'excel',
                {
                    extend: 'excel',//
                    title: "",
                    footer: true,
                    filename: function () {
                        return 'Payment-Register';
                    },
                    message: function () {
                        var head = '' + $('#cname').val() + '\n' +
                         '' + $('#caddress').val() + '\n' +
                         ' Payment Register \n' +
                      //   'Voucher Number : ' + $('#VoucherNumber').val() + '\n' +
                         'From :  ' + $('#From').val() + ' To :' + $('#To').val() + '';
                        return head;
                    },
                    pageSize: 'A4',
                    exportOptions: {
                        columns: ':visible'
                    },
                },
                {
                    extend: 'pdf',//
                    title: "",
                    footer: true,
                    filename: function () {
                        return 'Payment-Register';
                    },
                    message: function () {
                        var head = '' + $('#cname').val() + '\n' +
                         '' + $('#caddress').val() + '\n' +
                         ' Payment Register \n' +
                      //   'Voucher Number : ' + $('#VoucherNumber').val() + '\n' +
                         'From :  ' + $('#From').val() + ' To :' + $('#To').val() + '';
                        return head;
                    },
                    pageSize: 'A4',
                    exportOptions: {
                        columns: ':visible'
                    },
                    customize: function (doc) {
                        doc.pageMargins = [10, 10, 10, 10];
                        doc.defaultStyle.fontSize = 10;
                        doc.styles.tableHeader.fontSize = 10;
                        doc.styles.title.fontSize = 12;
                        // Header font and bg color
                        doc.styles.tableHeader.fillColor = '#d3d3d3';
                        doc.styles.tableHeader.color = 'black';
                        // Remove spaces around page title
                        doc.content[0].text = doc.content[0].text.trim();



                        doc.content[1].table.widths = [
                        '5%',
                        '8%',
                        '11%',
                        '8%',
                        '11%',
                        '8%',
                        '15%',
                        '10%',
                        '10%',
                        '14%'
                        ]

                        var objLayout = {};
                        // Horizontal line thickness
                        objLayout['hLineWidth'] = function (i) { return .5; };
                        // Vertikal line thickness
                        objLayout['vLineWidth'] = function (i) { return .5; };
                        //// Horizontal line color
                        //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                        //// Vertical line color
                        //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                        // Left padding of the cell
                        objLayout['paddingLeft'] = function (i) { return 4; };
                        // Right padding of the cell
                        objLayout['paddingRight'] = function (i) { return 4; };
                        // Inject the object in the document
                        doc.content[1].layout = objLayout;
                        // Footer font and bg color
                        doc.styles.tableFooter.fillColor = '#d3d3d3';
                        doc.styles.tableFooter.color = 'black';
                    }


                },

                ],

                sDom: "lBfr<'datatable-scroll't>ip",
                "lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                "footerCallback": function (row, data, start, end, display) {
                    var api = this.api(), data;

                    // Remove the formatting to get integer data for summation
                    var intVal = function (i) {
                        return typeof i === 'string' ?
                            i.replace(/[\$,]/g, '') * 1 :
                            typeof i === 'number' ?
                            i : 0;
                    };

                    
                    var table = $('#UserTable').DataTable();
                    if (!table.data().any()) {
                        $('#UserTable tfoot').hide();
                    } else {
                        $('#UserTable tfoot').show();
                    }
                }
            });
            $('#search-form').on('submit', function (e) {
                e.preventDefault();
                oTable.draw();
                $('#PaymentReport').show();
            });
        });


        function reload_table() {
            oTable.clear().draw();
            oTable.ajax.reload(null, false); //reload datatable ajax
        }

    </script>
}
