@using QuickSoft.Models
@model QuickSoft.Models.employeetimesheetlist

<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">Time Sheet</h3>
    </div>

    <div class="box-body">

        @using (Html.BeginForm("Index", "taskcalendar", FormMethod.Post, new { id = "popupForm", target = "_new" }))
        {
            <div class="form-group col-md-2">
                @Html.Label("From", null, new { @class = "control-label" })
                <div class="input-group date">
                    @Html.TextBox("From", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                    <div class="input-group-addon">
                        <i class="fa fa-calendar"></i>
                    </div>
                </div>
            </div>
            <div class="form-group col-md-20" style="display:none;">
                @Html.Label("To", null, new { @class = "control-label" })
                <div class="input-group date">
                    @Html.TextBox("To", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                    <div class="input-group-addon">
                        <i class="fa fa-calendar"></i>
                    </div>
                </div>
            </div>
            <div class="form-group col-md-2" id="DDlItemwise">
                @Html.Label("Employee", null, new { @class = "control-label" })

                @Html.DropDownList("Employee", (SelectList)ViewBag.driver, new { id = "ddldriver", @class = "form-control select2", tabindex = 8 })

            </div>
            <div class="box-footer col-md-12">
                <input type="submit" class="btn btn-info col-sm-offset-5" value="Submit" />
                <button type="button" class="btn btn-default" onclick="@("window.location.href='/Home/Index'");">Cancel</button>
            </div>

        }

    </div>
</div>



@if (Model != null)
{


    if (Model.et.Any())
    {
        int? hour = 0;
        int? minutes = 0;
        string empname = "";

        <div class="box-body">
            <table class="table table-bordered table-hover" id="UserTable">
                <thead>
                    <tr></tr>
                    <tr></tr>
                    <tr></tr>
                    <tr></tr>
                    <tr></tr>
                    <tr></tr>
                    <tr></tr>
                    <tr></tr>
                    <tr></tr>
                    <tr></tr>
                </thead>
                <tbody>
                    <tr>


                        @foreach (var item in Model.et)
                        {
                            if (empname != item.EmployeeName)
                            {
                                if (empname != "")
                                {
                                    hour = hour + minutes / 60;
                                    minutes = minutes % 60;
                                <td>@hour (H)</td>
                                <td>@minutes (M)</td>
                                }

                                hour = 0;
                                minutes = 0;
                                @Html.Raw("</tr><tr>");
                                <td>@item.EmployeeName</td>
                                empname = item.EmployeeName;
                            }
                            <td><a href="/Protask/Details/@item.protaskid" target="_blank">@item.servocedatefrom.Value.TimeOfDay - @item.servocedateto.Value.TimeOfDay</a></td>
                            <td>@item.endtime</td>
                            hour = hour + item.hours;
                            minutes = minutes+ item.minute;
                        }
                        @{

                            hour = hour + minutes / 60;
                            minutes = minutes % 60;
                        }
                        <td>@hour (H)</td>
                        <td>@minutes (M)</td>
                    </tr>
                </tbody>
            </table>
           </div>
            }
            }
