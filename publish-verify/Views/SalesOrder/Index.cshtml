        var checkList = document.getElementById('list1');
       /******* Function to list and hide dropdown checklist while clicking on 'Select Fields' *******/
       checkList.getElementsByClassName('anchor')[0].onclick = function (evt) {
           if (checkList.classList.contains('visible'))
               checkList.classList.remove('visible');
           else
               checkList.classList.add('visible');
       }

       /******* Function to show and hide fields while clicking on checkboxes in 'Select Fields' *******/
       $("ul li input:checkbox").click(function () {

           var _show = 0;

           //Order No.
           if ($("#liorderno").prop("checked") == true) {
               $("#searchorderno").show();
               _show = 1;
           }
           else {
               $('#InvoiceNo').val("");
               $("#searchorderno").hide();
               oTable.draw();
           }

           //From Date
           if ($("#lifromdate").prop("checked") == true) {
               $("#searchfromdate").show();
               _show = 1;
           }
           else {
               $("#FromDate").val("");
               $("#searchfromdate").hide();
               oTable.draw();
           }

           //To Date
           if ($("#litodate").prop("checked") == true) {
               $("#searchtodate").show();
               _show = 1;
           }
           else {
               $("#ToDate").val("");
               $("#searchtodate").hide();
               oTable.draw();
           }

           //Customer
           if ($("#licustomer").prop("checked") == true) {
               $("#searchcustomer").show();
               _show = 1;
           }
           else {
               $('#ddlCustomer').val(0).trigger("change");
               $("#searchcustomer").hide();
               oTable.draw();
           }

           //Sales Executive
           if ($("#lisalesexctve").prop("checked") == true) {
               $("#searchemployee").show();
               _show = 1;
           }
           else {
               $('#ddlEmployee').val(0).trigger("change");
               $("#searchemployee").hide();
               oTable.draw();
           }

           //Created By
           if ($("#licreatedby").prop("checked") == true) {
