@model QuickSoft.Models.SalesOrder
@{
    ViewBag.Title = "List";
    ViewBag.SubTitle = "Sales Order";
    ViewBag.Active = "Transactions";
    string actData = "";
    string delchk = "";
    bool userRole = false;
    string deleteBTn = "";
    if (User.IsInRole("Dev") || User.IsInRole("Delete SalesOrder"))
    {
        userRole = true;
        deleteBTn = "{text: 'Delete', className: 'btn-danger', action: function(e, dt, node, config) {" +
            "if ($('.checkbox:checked').length > 0) {if (confirm('Are you sure you want to delete this?')) {$('#delallform').submit(); e.preventDefault();} " +
             "} else {alert('Please Select Rows..!!');e.preventDefault();}}},";
    }
}
<style type="text/css">

    .dropdown-check-list {
        display: inline-block;
    }

        .dropdown-check-list .anchor {
            position: relative;
            cursor: pointer;
            display: inline-block;
            padding: 5px 50px 5px 10px;
            border: 1px solid #ccc;
            width: 150px;
            background: #fff;
            text-align: center;
        }

            .dropdown-check-list .anchor:after {
                position: absolute;
                content: "";
                border-left: 2px solid black;
                border-top: 2px solid black;
                padding: 5px;
                right: 10px;
                top: 20%;
                -moz-transform: rotate(-135deg);
                -ms-transform: rotate(-135deg);
                -o-transform: rotate(-135deg);
                -webkit-transform: rotate(-135deg);
                transform: rotate(-135deg);
            }

            .dropdown-check-list .anchor:active:after {
                right: 8px;
                top: 21%;
            }

        .dropdown-check-list ul.items {
            padding: 0px;
            display: none;
            margin: 0;
            border: 1px solid #ccc;
            border-top: none;
            position: absolute;
            z-index: 9999;
        }

            .dropdown-check-list ul.items li {
                list-style: none;
                background: #fff;
                padding: 5px;
            }

    .add-btn-item {
        border-radius: 23px;
        padding: 6px 20px;
    }

    .dropdown-check-list.visible .anchor {
        color: #0094ff;
    }

    .dropdown-check-list.visible .items {
        display: block;
    }
</style>

<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">List Sales Order</h3>
        <div class="pull-right">
            @if (User.IsInRole("Dev") || User.IsInRole("Invoice Template"))
            {
                <a class="btn btn-default no-border" href="/InvoiceTemplate/Index?docType=SalesOrder" title="Design / manage sales-order print templates">
                    <i class="glyphicon glyphicon-duplicate"></i> Design Templates
                </a>
            }
            @if (User.IsInRole("Dev") || User.IsInRole("SalesOrder Entry"))
            {
                <i class="ace-icon fa fa-hand-o-right icon-animated-hand-pointer blue"></i>
                <a class="btn btn-info no-border" href="/SalesOrder/Create">
                    <i class="glyphicon glyphicon-plus"></i> Create
                </a>
            }
        </div>
        <div class="row">
            <div class="col-md-2">
                <div id="list1" class="dropdown-check-list" tabindex="100">
                    <span class="anchor" style="z-index:0;">Select Fields</span>
                    <ul class="items">
                        <li><input type="checkbox" id="liorderno" />Order No.</li>
                        <li><input type="checkbox" id="lifromdate" />From Date</li>
                        <li><input type="checkbox" id="litodate" />To Date</li>
                        <li><input type="checkbox" id="licustomer" />Customer</li>
                        <li><input type="checkbox" id="lisalesexctve" />Sales Executive</li>
                        <li><input type="checkbox" id="licreatedby" />Created By</li>
                        <li><input type="checkbox" id="livalidity" />Validity</li>
                        <li><input type="checkbox" id="listatus" />Status</li>
                        <li><input type="checkbox" id="liapprvlstatus" />Approval Status</li>
                    </ul>
                </div>
            </div>
            <div class="col-md-12">
                <div class="box-body search-box" id="advsearchlist">
                    <div class="search-body col-md-12" style="background:none;">
                        <form id="search-form">
                            <div class="row">
                                <input type="hidden" id="remId" />
                                <div class="form-group col-md-2" id="searchorderno">
                                    @Html.Label("Order No", null, new { @class = "control-label" })
                                    @Html.TextBox("InvoiceNo", "", new { @class = "form-control input-sm" })
                                </div>
                                <div class="form-group col-md-2" id="searchfromdate">
                                    @Html.Label("From Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("FromDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group col-md-2" id="searchtodate">
                                    @Html.Label("To Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("ToDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group col-md-2" id="searchcustomer">
                                    @Html.Label("Customer", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlCustomer", (SelectList)ViewBag.Customer, new { @class = "form-control input-sm select2" })
                                </div>
                                <div class="form-group col-md-2" id="searchemployee">
                                    @Html.Label("Sales Executive", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlEmployee", (SelectList)ViewBag.SalesExecutive, new { @class = "form-control input-sm select2" })
                                </div>
                                <div class="form-group col-md-2" id="searchcreatdby">
                                    @Html.Label("Created By", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlCreatedBy", (SelectList)ViewBag.CreatedBy, "All", new { @class = "form-control input-sm select2" })
                                </div>
                                <div class="form-group col-md-2" id="searchvalidity">
                                    @Html.Label("Validity", null, new { @class = "control-label" })
                                    @Html.TextBox("Validity", "", new { @class = "form-control input-sm" })
                                </div>
                                <div class="form-group col-md-2" id="searchstatus">
                                    @Html.Label("Status", null, new { @class = "control-label" })
                                    @Html.DropDownList("Status", (SelectList)ViewBag.ItStatus, new { @class = "form-control" })
                                </div>
                                @if (@ViewBag.BusinessType == "Scaffold")
                                {
                                    <div class="form-group col-md-2" id="searchtype">
                                        @Html.Label("Type", null, new { @class = "control-label" })
                                        @Html.DropDownList("SaleType", (SelectList)ViewBag.Type, new { @class = "form-control select2" })
                                    </div>

                                    <div class="form-group col-md-2" id="searchhiretype">
                                        @Html.Label("HireType", null, new { @class = "control-label" })
                                        @Html.DropDownList("HireType", (SelectList)ViewBag.HiType, "All", new { id = "ddlHType", @class = "form-control select2" })
                                    </div>
                                }
                                @if (ViewBag.MLASOrder == 0)
                                {
                                    <div class="form-group col-md-2" id="searchapprovalstatus">
                                        @Html.Label("Approval Status", null, new { @class = "control-label" })
                                        @Html.DropDownList("ApprovalStatus", (SelectList)ViewBag.AppStat, "All", new { id = "ApprovalStatus", @class = "form-control" })
                                    </div>
                                }
                                @if (@ViewBag.ProjChk == 0)
                                {
                                    <div class="form-group col-md-2" id="searchproject">
                                        @Html.LabelFor(m => m.Project, new { @class = "control-label" })
                                        @Html.DropDownListFor(m => m.Project, (SelectList)ViewBag.getProj, "All", new { id = "ddlProject", @class = "form-control select2" })
                                    </div>
                                    <div class="form-group col-md-2" id="searchtask">
                                        @Html.Label("Task", null, new { @class = "control-label" })
                                        @Html.DropDownListFor(m => m.ProTask, (SelectList)ViewBag.getProTask, "All", new { id = "ddlProTask", @class = "form-control select2" })
                                    </div>
                                }
                                <div class="form-group col-md-2" id="search">
                                    <input type="submit" class="btn btn-submit" value="Submit" />
                                </div>
                                <div class="form-group col-md-2" id="close">
                                    <input type="button" class="btn btn-close" value="Close" />
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @using (Html.BeginForm("DeleteAllSalesOrder", "SalesOrder", FormMethod.Post, new { id = "delallform", role = "form" }))
    {
        <div class="box-body">
            <table class="table table-bordered table-hover" id="SalesOrderTable">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="1">S/N</td>
                        <td data-priority="1">Order No</td>
                        <td data-priority="1">Date</td>
                        <td data-priority="4">Customer</td>
                        <td data-priority="2" class="headeralign">Amount</td>
                        <td data-priority="3">Validity</td>
                        <td data-priority="5">Executive</td>
                        <td data-priority="5">SaleType</td>
                        <td data-priority="5">Created By</td>
                        <td data-priority="3">Status</td>
                        <td data-priority="3">Approval Status</td>
                        <td data-priority="6">Project Name</td>
                        <td data-priority="7">Task</td>
                        <td data-priority="1">Action</td>
                        <td data-priority="1"><input type="checkbox" id="select_all" /></td>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
        <input type="hidden" value="@ViewBag.StartDate" class="Start" name="Start" id="Start">
        <input type="hidden" value="@ViewBag.EndDate" class="End" name="End" id="End">
    }

    <div id="modal-container2" class="modal fade" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-aqua">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                    <h4>Status Updation History</h4>
                </div>
                <div class="modal-body">
                    <table class="table table-bordered table-hover" id="UserTableInfo">
                        <thead>
                            <tr class="bg-aqua">
                                <td>Status</td>
                                <td>Updated By</td>
                                <td>Requested By</td>
                                <td>Date</td>
                                <td>Remarks</td>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@{var Model = "modal-lg";}
@Html.Partial("../Common/_ModalCreate", @Model)
@Html.Partial("../Reminder/Index")
@Html.Partial("../Common/_ModalEdit")
@Html.Partial("../Common/_ModalChange")
@Html.Partial("../Common/_ModalDelete")

@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/bootstrap-timepicker")
}

@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/bootstrap-timepicker")
    <script type="text/javascript">
      var minDate = $("#Start").val();
      var maxDate = $("#End").val();

        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true,
            startDate: new Date(minDate),
            endDate: new Date(maxDate)
        });

        jQuery.validator.methods["date"] = function (value, element) { return true; }
        $(".timepicker").timepicker({
            showInputs: true,
            defaultTime: false,
            format: 'dd-mm-yyyy'
        });

        $(document).ready(function () {
            $('#advsearchlist').toggle();
            $('#searchhiretype').hide();
        });

        var oTable = $('#SalesOrderTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "pageLength": 50,
            responsive: true,
            "bLengthChange": false,
            "ajax": {
                "url": '/SalesOrder/GetSalesOrder',
                "data": function (data) {
                    data.InvoiceNo = $('#InvoiceNo').val();
                    data.FromDate = $('#FromDate').val();
                    data.ToDate = $('#ToDate').val();
                    data.customer = $('#ddlCustomer').val();
                    data.salesperson = $('#ddlEmployee').val();
                    data.Stats = $('#Status').val();
                    data.user = $('#ddlCreatedBy').val();
                    data.Validity = $('#Validity').val();
                    data.Saletype = $('#SaleType').val();
                    data.HireType = $('#ddlHType').val();
                    data.appstat = $('#ApprovalStatus').val();
                    data.ProjectName = $('#ddlProject').val();
                    data.Task = $('#ddlProTask').val();
                },
                "type": "POST",
                "datatype": "json"
            },
            "order": [[0, "desc"]],
            "columnDefs": [{
                "targets": [13, 14],
                "orderable": false
            }],
            "columns": [
                     {
                         "data": "SalesOrderId", "name": "SalesOrderId",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                { "data": "BillNo", "name": "BillNo" },
                { "data": "SODate", "name": "SODate", "render": function (data) { return convertToDate(data); } },
                { "data": "Customer", "name": "Customer" },
                { "data": "SOGrandTotal", "name": "SOGrandTotal", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                { "data": "validity", "name": "validity" },
                { "data": "EmpName", "name": "EmpName" },
                {
                    "data": "SaleType", "name": "SaleType", "render": function (data) {
                        if (data == 2) {
                            return 'Hire';
                        }
                        else {
                            return 'Sale';
                        }
                    }
                },
                { "data": "user", "name": "user" },
                {
                    "name": "validity", "data": function (data) {
                        if (data.validity == "Expired") {
                            return '<i class="badge bg-red" style="font-size: small" >Expired</i>';
                        }
                        else {
                            return '<i class="badge bg-green" style="font-size: small" >Active</i></a>';
                        }
                    }
                },
                  {
                      "name": "ApprovalStatus", "data": function (data, type, dataToSet) {
                          var status = "";
                          var cls = "";
                          if (data.app.length > 0 || (data.Approval == true && '@ViewBag.MLASOrder' == 'active')) {
                              if (data.ApprovalStatus == "0") {
                                  status = '<span class="badge bg-green">Approved</span>';
                              }
                              else if (data.ApprovalStatus == "1") {
                                  status = '<span class="badge bg-red">Rejected</span>';
                              }
                              else if (data.ApprovalStatus == "2") {
                                  status = '<span class="badge bg-orange">Pending</span>';
                              }
                              return '<a  class="Updation" onclick="details(' + data.SalesOrderId + ')"  title="View Status">' + status + ' </a>';
                          } else { return null; }
                      }
                  },
                { "data": "ProjectName", "name": "ProjectName" },
                { "data": "Task", "name": "Task" },
                {
                    "data": "SalesOrderId", "data": function (data) {
                        var rest = "";
                        @{
                            // BOS custom designer — per-row "Print (Custom Template)" (additive, role-gated, APPEND list).
                            string bosSoPrint = "";
                            if (User.IsInRole("Dev") || User.IsInRole("Invoice Template"))
                            {
                                bosSoPrint = "<a href=\"/InvoiceTemplate/Print?invoiceId='+ data.SalesOrderId +'&docType=SalesOrder\" target=\"_blank\" title=\"Print with a custom template\"><i class=\"fa fa-lg fa-print\" style=\"color:#6366f1\"></i></a> ";
                            }
                        }
                        rest += '@Html.Raw(bosSoPrint)';
                        @{
                            if (User.IsInRole("Dev") || User.IsInRole("View SalesOrder"))
                            {
                                actData += "<a class=\"details\" href=\"/SalesOrder/Details/'+ data.SalesOrderId +'\" title=\"View Sales Order\"><i class=\"fa fa-lg fa-search-plus\"></i></a> ";
                            }
                            if (User.IsInRole("Dev") || User.IsInRole("Edit SalesOrder"))
                            {
                                actData += "<a href=\"/SalesOrder/Edit/'+ data.SalesOrderId +'\" title=\"Edit Sales Order\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                            }
                            if (User.IsInRole("Dev") || User.IsInRole("Delete SalesOrder"))
                            {
                                actData += "<a class=\"modal-delete\" href=\"/SalesOrder/Delete/'+ data.SalesOrderId +'\" title=\"Delete Sales Order\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";
                            }
                            if (User.IsInRole("Dev") || User.IsInRole("Download SalesOrder"))
                            {
                                actData += "<a class=\"modal-link-download\" href=\"/SalesOrder/Download/'+ data.SalesOrderId +'\" title=\"Download Sales Order\"><i class=\"fa-lg fa fa-download\" ></i></a> ";
                            }
                            //if (User.IsInRole("Dev") || User.IsInRole("Sales Entry"))
                            //{
                            //    actData += "<a href=\"/CreditSale/Create/'+ data.SalesOrderId +'/SOrder\" title=\"Convert To Sales\"><i class=\"fa-lg fa fa-exchange\" ></i></a> ";
                            //}
                            //if (User.IsInRole("Dev") || User.IsInRole("Pro Forma Entry"))
                            //{
                            //    actData += "<a href=\"/ProForma/Create/'+ data.SalesOrderId +'/SOrder\" title=\"Convert To Pro Forma\"><i class=\"fa-lg fa fa-arrows-h\" ></i></a> ";
                            //}
                            //if (User.IsInRole("Dev") || User.IsInRole("Deliverynote Entry"))
                            //{
                            //    actData += "<a href=\"/Deliverynote/Create/'+ data.SalesOrderId +'/SOrder\" title=\"Convert To Deliverynote\"><i class=\"fa-lg fa fa-refresh\" ></i></a> ";
                            //}
                        }
                        rest += '@Html.Raw(actData)';
                        //Convert To Sales
                        if (data.ApprovalStatus != "1" && data.SaleConvert == "Sale" && data.SOrderToSale == true) {
                            @{
                                actData = "";
                                if (User.IsInRole("Dev") || User.IsInRole("Sales Entry"))
                                {
                                    actData += "<a href=\"/CreditSale/Create/'+ data.SalesOrderId +'/SOrder\" title=\"Convert To Sales\" class=\"text-red\"><i class=\"fa-lg fa fa-exchange\" ></i></a> ";
                                }
                            }
                            rest += '@Html.Raw(actData)';
                        }
                        else {
                            if (data.ApprovalStatus != "1" && data.SOrderToSale == true) {
                                @{
                                    actData = "";
                                    if (User.IsInRole("Dev") || User.IsInRole("Sales Entry"))
                                    {
                                        actData += "<a href=\"/CreditSale/Create/'+ data.SalesOrderId +'/SOrder\" title=\"Convert To Sales\"><i class=\"fa-lg fa fa-exchange\" ></i></a> ";
                                    }
                                }
                                rest += '@Html.Raw(actData)';
                            }
                        }

                        // Convert To Proforma
                        if (data.ApprovalStatus != "1" && data.PFAConvert == "ProForma" && data.SOrderToPF == true) {
                            @{
                                actData = "";
                                if (User.IsInRole("Dev") || User.IsInRole("Pro Forma Entry"))
                                {
                                    actData += "<a href=\"/ProForma/Create/'+ data.SalesOrderId +'/SOrder\" title=\"Convert To Pro Forma\" class=\"text-red\"><i class=\"fa-lg fa fa-arrows-h\" ></i></a> ";
                                }
                            }
                            rest += '@Html.Raw(actData)';
                        }
                        else {
                            if (data.ApprovalStatus != "1" && data.SOrderToPF == true) {
                                @{
                                    actData = "";
                                    if (User.IsInRole("Dev") || User.IsInRole("Pro Forma Entry"))
                                    {
                                        actData += "<a href=\"/ProForma/Create/'+ data.SalesOrderId +'/SOrder\" title=\"Convert To Pro Forma\"><i class=\"fa-lg fa fa-arrows-h\" ></i></a> ";
                                    }
                                }
                                rest += '@Html.Raw(actData)';
                            }
                        }

                        // Convert To Delivery Note
                        if ("@ViewBag.BusinessType" == "ProjectBasedBusiness") {
                            if (data.ApprovalStatus != "1" && data.DVNConvert == "DVNote" && data.SOrderToDvNote == true) {
                                @{
                                actData = "";
                                if (User.IsInRole("Dev") || User.IsInRole("Deliverynote Entry"))
                                {
                                    actData += "<a href=\"/Deliverynote/Create/'+ data.SalesOrderId +'/SOrder\" title=\"Convert To Deliverynote\" class=\"text-red\"><i class=\"fa-lg fa fa-refresh\" ></i></a> ";
                                }
                            }
                                rest += '@Html.Raw(actData)';
                            }
                            else {
                                if (data.ApprovalStatus != "1" && data.SOrderToDvNote == true) {
                                    @{
                                    actData = "";
                                    if (User.IsInRole("Dev") || User.IsInRole("Deliverynote Entry"))
                                    {
                                        actData += "<a href=\"/Deliverynote/Create/'+ data.SalesOrderId +'/SOrder\" title=\"Convert To Deliverynote\"><i class=\"fa-lg fa fa-refresh\" ></i></a> ";
                                    }
                                }
                                    rest += '@Html.Raw(actData)';
                                }
                            }
                        }
                        if (data.Approval == true && '@ViewBag.MLASOrder' == 'active') {
                            @{
                                actData = "";
                                actData = "<a class=\"modal-edit\"  href=\"/SalesOrder/EditStatus/'+ data.SalesOrderId +'\" title=\"Edit Status\"><i class=\"fa fa-lg fa-refresh\" ></i></a> ";
                            }
                            rest += '@Html.Raw(actData)';
                        }
                        if ("@ViewBag.Remind" == "active") {
                            @{
                                   actData = "";
                                   actData += "<a class=\"UpdationRe\" onclick=\"detailsRemind(' + data.SalesOrderId + ')\" title=\"View Reminder\"><i class=\"fa-lg fa fa-bell\" ></i></a> ";
                                   actData += "<a class=\"modal-create\" href=\"/Reminder/AddReminder/'+ data.SalesOrderId +'/SOrder\" title=\"Add Reminder\"><i class=\"fa-lg fa fa-sticky-note\" ></i></a> ";
                               }
                            rest += '@Html.Raw(actData)';
                        }
                        return rest;
                    }
                },
                 {
                     "name": "SalesOrderId", "data": function (data) {
                         var rest = "";
                         @{
                             if (User.IsInRole("Dev") || User.IsInRole("Delete SalesOrder"))
                             {
                                 delchk = "<input class=\"checkbox\" type=\"checkbox\" name=\"bill[]\" value='+ data.SalesOrderId +'></input>";
                             }
                         }
                         return rest = '@Html.Raw(delchk)';
                     }
                 },
            ],
            buttons: [
               'colvis',
               {
                   extend: 'print',//
                   title: "",
                   footer: true,
                   filename: function () {
                       return 'Sales Order';
                   },
                   columnDefs: [
                       { width: 400, targets: 2 }
                   ],
                   exportOptions: {
                       columns: ':visible'
                   },
                   message: function () {
                       var head = '<table class="tblcompact table table-bordered"><thead>' +
                       ' <tr><th class="text-center"><h3 style="margin-top: 0px;"><h4>Sales Order</h4></th></tr>';
                       return head;
                   },
                   customize: function (win) {
                       // $(win.document.body)
                       //.css('font-size', '10pt')
                       //.css('padding', '1px');
                       $(win.document.body).find('table.tblcompact tbody td').css('padding', '0px');
                       $(win.document.body).find('.dataTable,.dataTable th,.dataTable tr,table.tblcompact tbody td .dataTable td')
                           .css('font-size', '10pt')
                           .css('padding', '5px')
                           .addClass('compact');
                       $(win.document.body).find('.dataTable tr th:nth-child(3)')
                           .css('min-width', '80px');
                       //$(win.document.body).find('.tblcompact tbody td:nth- child(2)')
                       //    .css('padding', '0px');
                       $(win.document.body).append('</td></tr></tbody>')
                   }
               }, 'copy', 'csv', //'excel',
               {
                   extend: 'pdf',//
                   title: "",
                   footer: true,
                   filename: function () {
                       return 'Sales Order';
                   },
                   message: function () {
                       var head = 'Sales Order';
                       return head;
                   },
                   pageSize: 'A4',
                   exportOptions: {
