               _show = 1;
           }
           else {
               $('#ddlCreatedBy').val("").trigger("change");
               $("#searchcreatdby").hide();
               oTable.draw();
           }

           //Validity
           if ($("#livalidity").prop("checked") == true) {
               $("#searchvalidity").show();
               _show = 1;
           }
           else {
               $("#Validity").val(null);
               $("#searchvalidity").hide();
               oTable.draw();
           }

           //Status
           if ($("#listatus").prop("checked") == true) {
               $("#searchstatus").show();
               _show = 1;
           }
           else {
               $('#Status').val(null).trigger("change");
               $("#searchstatus").hide();
               oTable.draw();
           }

           //Approval Status
           if ($("#liapprvlstatus").prop("checked") == true) {
               $("#searchapprovalstatus").show();
               _show = 1;
           }
           else {
               $('#ApprovalStatus').val("").trigger("change");
               $("#searchapprovalstatus").hide();
               oTable.draw();
           }

           if (_show == 1) {
               $('#advsearchlist').show();
           }
           else {
               $('#advsearchlist').hide();
           }
       });

       /******* Function to hide dropdown checklist while clicking outside it ********/
       $(document).on("click", function (event) {

           var element1 = $("#list1");

           if (element1 !== event.target && !element1.has(event.target).length) {
