@section scripts{
    @Scripts.Render("~/js/JsBarcode")
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")

    <script type="text/javascript">
        //change cofactor
        function coFactorChange() {
            if ($("#ItemUnitID").prop('selectedIndex') > 0 && $("#SubUnitId").prop('selectedIndex') > 0) {
                $('#ConFactor').prop('readonly', false);

                var pry = $("#ItemUnitID").val();
                var sec = $("#SubUnitId").val();

                if (pry == sec) {
                    $("#ConFactor").val(1);
                    $('#ConFactor').prop('readonly', true);
                } else {
                    $('#ConFactor').prop('readonly', false);
                }
            } else {
                $('#ConFactor').prop('readonly', true);
            }
        }
        //primary unit change
        function prunitchange() {
            var unitID = $("#ItemUnitID").val();
            $("#SubUnitId").val('');
            $('#SubUnitId option[value=' + unitID + ']').prop('selected', true);
            if ($("#ItemUnitID").prop('selectedIndex') > 0) {
                $('#SubUnitId').prop('disabled', false);
                var textvalue = $("#ItemUnitID option:selected").text();
                $(".prim").text(textvalue);
                $(".primU").text("1 " + textvalue + "=");
                $(".sec").text(textvalue);
            } else {
                $("#SubUnitId").prop('selectedIndex', 0);
                $('#SubUnitId').prop('disabled', false);
                $(".prim").text("");
                $(".primU").text("");
            }
            coFactorChange();
        }
        //sec unit change
        function seunitchange() {
            var textvalue = $("#SubUnitId option:selected").text();
            $(".sec").text(textvalue);
            coFactorChange();
        }

        //keep stock change
        $('#KeepStock').click(function () {
            clickstock();
        });
        $("#chkpricing").change(function () {
            if ($('#chkpricing').prop('checked') == true) {
                $("#SellingPrice").prop("readonly", true);

                $("#PurchasePrice").prop("readonly", true);
                $("#BasePrice").prop("readonly", true);
                $("#MRP").prop("readonly", true);
                //$("#pricingstatagytype").hide();
                //$("#amounttype").hide();
                //$("#amount").hide();
                $(".prcstg").show();
            }
            else {
                $("#SellingPrice").prop("readonly", false);

                $("#PurchasePrice").prop("readonly", false);
                $("#BasePrice").prop("readonly", false);
                $("#MRP").prop("readonly", false);
                //$("#pricingstatagytype").show();
                //$("#amounttype").show();
                //$("#amount").show();
                $(".prcstg").hide();

            }
        });
        function calcprice() {
            if ($("#chkpricing").prop("checked") == true) {
                $.ajax({
                    url: '/PurchaseEntry/GetPrice',
                    type: "GET",
                    dataType: "JSON",
                    data: { itemid: getQueryString(''), pcategory: $("#pricingstatagytype").val(), amounttype: $("#amounttype").val(), amount: $("#amount").val() },
                    success: function (data) {
                        $("#SellingPrice").val(data.salprice);
                        $("#PurchasePrice").val(data.purprice);
                        if ($("#pricingstatagytype").val() == 3) {
                            $("#amounttype").prop("disabled", true);
                            $("#SellingPrice").val($("#amount").val());
                        }
                        else {
                            $("#SellingPrice").val(data.salprice);
                            $("#amounttype").prop("disabled", false);
                        }

                    }
                });
                
            }
            else {
                $("#SellingPrice").val(@Model.SellingPrice);
                $("#PurchasePrice").val(@Model.PurchasePrice);

            }
           
        }
        $(document).ready(function () {
            $("#accountid").select2({});
            $("#ddlItem").select2({
                placeholder: 'Search Item by Name or Code',
                minimumInputLength: 0,
                ajax: {
                    url: "/Item/Search",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term || "",
                            page: params.page || 0,
                            x: "All"
                        };
                    },
                    results: function (data) {
                        return { results: data };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 0;
                        return {
                            results: data,
                            pagination: {
                                //more: (params.page * 10) < 50
                                more: true
                            }
                        };
                    },
                    cache: true
                },

            });  
            clickstock();
            var textvalue = $("#ItemUnitID option:selected").text();
            $(".prim").text(textvalue);
            $(".primU").text("1 " + textvalue + "=");
            var textvalue1 = $("#SubUnitId option:selected").text();
            $(".sec").text(textvalue1);
            coFactorChange();

            ItemCategory();
            ItemBrand();
            GetBranch();
            Itemtype();
            ChangeCurrency();

            $("#ddlCusupplier").select2({
                placeholder: 'Search Supplier by Name or Code',
                minimumInputLength: 0,
                ajax: {
                    url: "/Supplier/SearchSupplier",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term || "",
                            page: params.page || 0,
                            x: "empty"

                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 0;
                        return {
                            results: data,
                            pagination: {
                                //more: (params.page * 10) < 50
                                more: true
                            }
                        };
                    },
                    cache: true
                },
            });

            //chk item exists
            if ('@ViewBag.ItemExist' == 1) {
                $('#ItemUnitID').prop('disabled', false);
                $('#SubUnitId').prop('disabled', false);
                $('#ConFactor').prop('readonly', false);
            }
            else {
                $('#ItemUnitID').prop('disabled', false);
                $('#SubUnitId').prop('disabled', false);
                $('#ConFactor').prop('readonly', false);
            }

            // batch stock initialize
            var BatchEnable = $("#batchcheck").val();
            if (BatchEnable == "active") {
                $.ajax({
                    url: '/Item/GetItemEdit',
                    type: "GET",
                    dataType: "JSON",
                    data: { itId: getQueryString('') },
                    success: function (data) {
                        // batch stock updates
                        if (BatchEnable == "active" && data.KeepStock == true) {
                            $.each(data.batch, function (i, bst) {
                                addSBITRow(1, 0, bst);
                            });
                        }
                        addSBITRow(1, 0);
                    }
                });
            }
        });
        function clickstock() {
            if ($('#KeepStock').prop('checked') == true) {
                $('.StockSection').show();
            }
            else {
                $('.StockSection').hide();
            }
        }
