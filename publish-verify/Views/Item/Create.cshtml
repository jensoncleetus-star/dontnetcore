        //Function to add row
        function AddDocs() {
            //To show the label for division
            $("#ImageLabel").show();

            //Adding class only on button click function....(for setting the style while adding rows)
            $("#Images").addClass('borderclass');

            if (RowNo < MaxRow) {
                var html = '<div class = "row FileSet input-group input-group-sm" >' +
                                '<div class="form-group col-md-12">' +
                                    '<input id = "Image_'+ RowNo +'" style="padding-top: 0.5rem; margin-top: 10px;" type="file" accept=".jpg" class="form-control Image" name="LstAdditionalImages[' + RowNo + '].FileName" onchange ="ValidateFileType('+RowNo+')">' +
                                '</div>' +
                                 '<a href="javascript:void(0);" class="remove_button" style="padding-top: 1rem; margin-left:5px;"><i style="color:red;" onclick="removeDoc(this)" class="fa fa-trash" aria-hidden="true"></i></a>' +
                            '</div > ';

                $(html).appendTo($("#Images"));
                RowNo++;
            }
        }

        //function to reset Index of rows
        function resetMbbtn() {
            var i = 0;

            $('.FileSet').each(function (index, element) {

                var inputMb = $(this).find('.Image');

                //To update the index value of name & Id of each rows while appending or deleting
                inputMb.attr('name', 'LstAdditionalImages[' + i + '].FileName');

                i++;
            });
        }

        function removeDoc(_this) {
            $(_this).parent().parent().remove();
            RowNo--;

            //Calling function to reset the index
            resetMbbtn();

            if (RowNo == 0) {
                $("#ImageLabel").hide();
                $("#Images").removeClass('borderclass');
            }
        }

        //Function to validate the type of file
        function ValidateFileType(RowNo)
        {
            var FileName    =   $("#Image_" + RowNo).val();
            var idxDot      =   FileName.lastIndexOf(".") + 1;
            var extFile     =   FileName.substr(idxDot, FileName.length).toLowerCase();

            if (extFile != "jpg") {
                alert("Only jpg files are allowed...!");
                $("#Image_" + RowNo).val("");
            }
        }
