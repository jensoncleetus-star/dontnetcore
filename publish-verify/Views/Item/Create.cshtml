@using QuickSoft.Models
@model QuickSoft.ViewModel.ItemViewModel
@{
    ViewBag.Title = "Item";
    ViewBag.SubTitle = "Item";
    ViewBag.Active = "Master";
    var bsclass = ViewBag.BatchWiseStock == Status.inactive ? " hidden" : "";
}
@* setting the class 'borderclass' only on the button click *@
<style type="text/css">
    .borderclass {
        border: 1px solid #ccc;
    }

    .hideSecUnit {
        display: none !important;
    }

    .ShowSecUnit {
        display: block !important;
    }

    .bg1 {
        background-color: gainsboro;
    }
</style>

<div class="box box-info">
    @using (Html.BeginForm("Create", "Item", FormMethod.Post, new { id = "fileupload", role = "form", enctype = "multipart/form-data" }))
    {
        <div class="box-header with-border">
            <h3 class="box-title">Item</h3>
            <div class="pull-right">
                @if (@ViewBag.LastEntry != 0)
                {
                    if (User.IsInRole("Dev") || User.IsInRole("Edit Item"))
                    {
                        <a class="btn bg-black no-border" href="/Item/Edit/@ViewBag.LastEntry">
                            <i class="fa fa-step-backward"></i>
                        </a>
                    }
                }
                @if (User.IsInRole("Dev") || User.IsInRole("Item"))
                {
                    <a class="btn btn-success no-border" href="/Item">
                        <i class="fa fa-fw fa-history"></i> List
                    </a>
                }
            </div>
        </div>
        <div class="box-body">
            @Html.AntiForgeryToken()
            @Html.ValidationSummary("", new { @class = "alert alert-danger" })
            <input type="hidden" id="cname" value="@ViewBag.CName" />
            <input type="hidden" id="batchcheck" value="@ViewBag.BatchWiseStock" />
            <div class="row">

                @if (@ViewBag.PreCheck == 0)
                {

                    <div class="form-group col-sm-2">
                        @Html.Label("Prefix", null, new { @class = "control-label" }) *
                        <div class="input-group input-group-sm">
                            @Html.DropDownListFor(m => m.Prefix, (SelectList)ViewBag.Prefix, new { id = "ddlprefix", @class = "form-control select2", @onchange = "PrefixChange();" })
                            <span class="input-group-btn">
                                <a href="/PrefixMaster/Create" class="btn btn-default btnprefixAdd modal-create" tabindex="6" title="Add Prefix"><i class="glyphicon glyphicon-plus"></i></a>
                            </span>
                        </div>
                    </div>
                    <div class="form-group col-sm-2">
                        @Html.LabelFor(m => m.ItemCode, new { @class = "control-label" }) *
                        @Html.TextBoxFor(m => m.ItemCode, new { @readonly = "readonly", @class = "form-control input-sm", tabindex = 1, autofocus = "autofocus" })
                    </div>
                }
                else
                {
                    <div class="form-group col-sm-2">
                        @Html.LabelFor(m => m.ItemCode, new { @class = "control-label" }) *
                        @*@Html.TextBoxFor(m => m.ItemCode, new { @class = "form-control input-sm", tabindex = 1, autofocus = "autofocus" })*@
                        @Html.DropDownListFor(model => model.ItemCode, (SelectList)ViewBag.itemnc, new { @class = "form-control input-sm select2", @required = "required", @placeholder = "Item Code", tabindex = 2 })

                    </div>
                }

                @if (@ViewBag.PartNoCheck == 0)
                {
                    <div class="form-group col-sm-2">
                        @Html.LabelFor(m => m.ItemName, new { @class = "control-label" }) *
                        @*@Html.TextBoxFor(m => m.ItemName, new { @class = "form-control input-sm select2", tabindex = 2 })*@
                        @Html.DropDownListFor(model => model.ItemName, (SelectList)ViewBag.itemn, new { @class = "form-control input-sm select2", @required = "required", @placeholder = "Item Name", tabindex = 2 })



                    </div>
                    <div class="form-group col-sm-2">
                        @Html.LabelFor(m => m.ItemArabic, new { @class = "control-label" })
                        @Html.TextBoxFor(m => m.ItemArabic, new { @class = "form-control input-sm rtl", tabindex = 3 })
                    </div>

                }
                else
                {
                    <div class="form-group col-sm-4">
                        @Html.LabelFor(m => m.ItemName, new { @class = "control-label" }) *
                        @*@Html.TextBoxFor(m => m.ItemName, new { @class = "form-control input-sm", tabindex = 2 })*@
                        @Html.DropDownListFor(model => model.ItemName, (SelectList)ViewBag.itemn, new { @class = "form-control input-sm select2", @required = "required", @placeholder = "Item Name", tabindex = 2 })

                    </div>
                    <div class="form-group col-sm-4">
                        @Html.LabelFor(m => m.ItemArabic, new { @class = "control-label" })
                        @Html.TextBoxFor(m => m.ItemArabic, new { @class = "form-control input-sm rtl", tabindex = 3 })
                    </div>

                }
                <div class="form-group col-sm-2">
                    @Html.Label("Part Number", null, new { @class = "control-label" })
                    @Html.TextBoxFor(m => m.PartNumber, new { @class = "form-control input-sm", tabindex = 4 })
                </div>
                @if (@ViewBag.BCEnable == 0)
                {
                    if (@ViewBag.PreCheck == 0)
                    {
                        <div class="form-group col-sm-2">
                            @Html.LabelFor(m => m.Barcode, new { @class = "control-label" })
                            @Html.TextBoxFor(m => m.Barcode, new { @readonly = "readonly", @class = "form-control input-sm", tabindex = 4 })
                        </div>
                    }
                    else
                    {
                        <div class="form-group col-sm-2">
                            @Html.LabelFor(m => m.Barcode, new { @class = "control-label" })
                            @Html.TextBoxFor(m => m.Barcode, new { @class = "form-control input-sm", tabindex = 4 })
                        </div>
                    }
                }
                @if (@ViewBag.jew == 0)
                {
                    <div class="form-group col-sm-2">
                        @Html.LabelFor(m => m.Barcode, new { @class = "control-label" })
                        @Html.TextBoxFor(m => m.Barcode, new { @class = "form-control input-sm", tabindex = 4 })
                    </div>
                }
                <div class="form-group col-sm-4">
                    @Html.Label("Category", null, new { @class = "control-label" }) *
                    @if (User.IsInRole("Dev") || User.IsInRole("Create Item Category"))
                    {
                        <div class="input-group input-group-sm">
                            @Html.DropDownListFor(m => m.ItemCategoryID, (SelectList)ViewBag.ItemCategory, new { id = "ddlItemCategory", @class = "form-control select2" })
                            <span class="input-group-btn">
                                <a href="/ItemCategory/Create" class="btn btn-default btncategoryAdd" tabindex="6" title="Add Category"><i class="glyphicon glyphicon-plus"></i></a>
                            </span>
                        </div>
                    }
                    else
                    {
                        @Html.DropDownListFor(m => m.ItemCategoryID, (SelectList)ViewBag.ItemCategory, "", new { id = "ddlItemCategory", @class = "form-control select2" })
                    }
                </div>
                <div class="form-group col-sm-2">
                    @Html.LabelFor(m => m.SellingPrice, new { @class = "control-label" }) *
                    @Html.TextBoxFor(m => m.SellingPrice, new { @class = "form-control input-sm", tabindex = 7 })
                </div>
                <div class="form-group col-sm-2">
                    @Html.LabelFor(m => m.PurchasePrice, new { @class = "control-label" }) *
                    @Html.TextBoxFor(m => m.PurchasePrice, new { @class = "form-control input-sm", tabindex = 8 })
                </div>
                <div class="form-group col-sm-2">
                    @Html.LabelFor(m => m.BasePrice, new { @class = "control-label" })
                    @Html.TextBoxFor(m => m.BasePrice, new { @class = "form-control input-sm", tabindex = 9 })
                </div>
                <div class="form-group col-sm-2">
                    @Html.LabelFor(m => m.MRP, new { @class = "control-label" }) *
                    @Html.TextBoxFor(m => m.MRP, new { @class = "form-control input-sm", tabindex = 10 })
                </div>
                <div class="form-group col-sm-2">
                    @Html.LabelFor(m => m.cashprice, new { @class = "control-label" }) *
                    @Html.TextBoxFor(m => m.cashprice, new { @class = "form-control input-sm", tabindex = 10 })
                </div>
                <div class="form-group col-sm-2">
                    @Html.LabelFor(m => m.creditprice, new { @class = "control-label" }) *
                    @Html.TextBoxFor(m => m.creditprice, new { @class = "form-control input-sm", tabindex = 10 })
                </div>
                @if (ViewBag.BusinessType == "Scaffold")
                {
                    var tabi = 27;
                    for (int i = 0; i < Model.HireType.Count; i++)
                    {
                        <div class="form-group col-sm-2">
                            <label class="control-label" for="SellingPrice">Hire Rate @Model.HireType[i].Name</label>
                            <input type="hidden" name="HireTypes[@i].type" value="@Model.HireType[i].HireTypeId" />
                            <input type="hidden" name="HireTypes[@i].Period" value="@Model.HireType[i].Period" />
                            <input type="hidden" name="HireTypes[@i].PeriodType" value="@Model.HireType[i].PeriodType" />
                            <input class="form-control input-sm" id="HireRate@i" name="HireTypes[@i].Rate" data-val="true" data-val-number="Hire Rate must be a number." data-val-required="Hire Rate is required." tabindex="@tabi" type="text" value="0">
                        </div>
                        tabi++;
                    }
                }
                <div class="form-group col-sm-4">
                    @Html.Label("Brand", null, new { @class = "control-label" }) *
                    @if (User.IsInRole("Dev") || User.IsInRole("Create Item Brand"))
                    {
                        <div class="input-group input-group-sm">
                            @Html.DropDownListFor(m => m.ItemBrandID, (SelectList)ViewBag.ItemBrand, new { id = "ddlItemBrand", @class = "form-control select2", tabindex = 11 })
                            <span class="input-group-btn">
                                <a href="/ItemBrand/Create" class="btn btn-default btnbrandAdd" tabindex="12" title="Add Brand"><i class="glyphicon glyphicon-plus"></i></a>
                            </span>
                        </div>
                    }
                    else
                    {
                        @Html.DropDownListFor(m => m.ItemBrandID, (SelectList)ViewBag.ItemBrand, "", new { id = "ddlItemBrand", @class = "form-control select2", tabindex = 11 })
                    }
                </div>
                <div class="form-group col-sm-4">
                    @Html.Label("Auto Item Name", null, new { @class = "control-label" })
                    @Html.CheckBox("autoitemname", new { @class = "", tabindex = 1, autofocus = "autofocus", @onchange = "createitemname()" })
                </div>
                <div class="form-group col-sm-2">
                    @Html.Label("Size", null, new { @class = "control-label" })
                    @if (User.IsInRole("Dev") || User.IsInRole("Create Item Size"))
                    {
                        <div class="input-group input-group-sm">
                            @Html.DropDownListFor(m => m.ItemSizeID, new SelectList(Model.ItemSizes, "ItemSizeID", "ItemSizeName"), "Select Size", new { @class = "form-control", tabindex = 13 })
                            <span class="input-group-btn">
                                <a href="/ItemSize/Create" class="btn btn-default btnsizeAdd" title="Add Size" tabindex="14"><i class="glyphicon glyphicon-plus"></i></a>
                            </span>
                        </div>
                    }
                    else
                    {
                        @Html.DropDownListFor(m => m.ItemSizeID, new SelectList(Model.ItemSizes, "ItemSizeID", "ItemSizeName"), "Select Size", new { @class = "form-control", tabindex = 13 })

                    }
                </div>
                <div class="form-group  col-sm-3">
                    @Html.Label("Tax", null, new { @class = "control-label" }) *
                    @if (User.IsInRole("Dev") || User.IsInRole("Create Tax"))
                    {
                        <div class="input-group input-group-sm">
                            @Html.DropDownListFor(m => m.TaxID, new SelectList(Model.Taxs, "TaxID", "TaxName"), new { @class = "form-control", tabindex = 15 })
                            <span class="input-group-btn">
                                <a href="/Tax/Create" class="btn btn-default btntaxAdd" title="Add Tax" tabindex="16"><i class="glyphicon glyphicon-plus"></i></a>
                            </span>
                        </div>
                    }
                    else
                    {
                        @Html.DropDownListFor(m => m.TaxID, new SelectList(Model.Taxs, "TaxID", "TaxName"), new { @class = "form-control", tabindex = 15 })

                    }
                </div>
                <div class="form-group col-sm-2">
                    @Html.Label("Color", null, new { @class = "control-label" })
                    @if (User.IsInRole("Dev") || User.IsInRole("Create Item Color"))
                    {
                        <div class="input-group input-group-sm">
                            @Html.DropDownListFor(m => m.ItemColorID, new SelectList(Model.ItemColors, "ItemColorID", "ItemColorName"), "Select Color", new { @class = "form-control", tabindex = 17 })
                            <span class="input-group-btn">
                                <a href="/ItemColor/Create" class="btn btn-default btncolorAdd" title="Add Color" tabindex="18"><i class="glyphicon glyphicon-plus"></i></a>
                            </span>
                        </div>
                    }
                    else
                    {
                        @Html.DropDownListFor(m => m.ItemColorID, new SelectList(Model.ItemColors, "ItemColorID", "ItemColorName"), "Select Color", new { @class = "form-control", tabindex = 17 })

                    }
                </div>
            </div>
            <div class="row">
                <div class="col-sm-3 form-group">
                    @Html.Label("Show Secondary Unit", null, new { @class = "control-label" })
                    @Html.CheckBoxFor(m => m.ShowSecUnits, new { @class = "checkbox", @Id = "ShowSecondaryUnit", @onchange = "ShowSecUnit()" })
                </div>
                <div class="form-group col-sm-3 show1" style="pointer-events:none;">
                    @Html.Label("Primary Unit", null, new { @class = "control-label" })
                    @if (User.IsInRole("Dev") || User.IsInRole("Create Item Unit"))
                    {
                        <div class="input-group input-group-sm">
                            @Html.DropDownListFor(m => m.ItemUnitID, new SelectList(Model.ItemUnits, "ItemUnitID", "ItemUnitName"), "Select Unit", new { @class = "form-control bg1", @onchange = "prunitchange();", tabindex = 19 })
                            <span class="input-group-btn">
                                <a href="/ItemUnit/Create" id="pryUnit" class="btn btn-default btnunitAdd" tabindex="20" title="Add Unit"><i class="glyphicon glyphicon-plus"></i></a>
                            </span>
                        </div>
                    }
                    else
                    {
                        @Html.DropDownListFor(m => m.ItemUnitID, new SelectList(Model.ItemUnits, "ItemUnitID", "ItemUnitName"), "Select Unit", new { @class = "form-control bg1", @onchange = "prunitchange();", tabindex = 19 })

                    }
                </div>
                <div class="form-group col-sm-3 SecUnit hideSecUnit" style="pointer-events:none;">
                    @Html.Label("Secondary Unit", null, new { @class = "control-label" })
                    @if (User.IsInRole("Dev") || User.IsInRole("Create Item Unit"))
                    {
                        <div class="input-group input-group-sm">
                            @Html.DropDownListFor(m => m.SubUnitId, new SelectList(Model.ItemUnits, "ItemUnitID", "ItemUnitName"), "Select Unit", new { @class = "form-control bg1", @onchange = "seunitchange();", tabindex = 21 })
                            <span class="input-group-btn">
                                <a href="/ItemUnit/Create" id="subUnit" tabindex="22" class="btn btn-default btnunitAdd" title="Add Unit"><i class="glyphicon glyphicon-plus"></i></a>
                            </span>
                        </div>
                    }
                    else
                    {
                        @Html.DropDownListFor(m => m.SubUnitId, new SelectList(Model.ItemUnits, "ItemUnitID", "ItemUnitName"), "Select Unit", new { @class = "form-control bg1", @onchange = "seunitchange();", tabindex = 21 })

                    }
                </div>
                <div class="form-group col-sm-3">
                    @Html.LabelFor(m => m.ConFactor, new { @class = "control-label" }) *
                    <div class="input-group">
                        <span class="input-group-addon prefix primU"></span>
                        @Html.TextBoxFor(m => m.ConFactor, new { @class = "form-control input-sm", @Value = "1", @readonly = "readonly", tabindex = 23 })
                        <span class="input-group-addon suffix sec"></span>
                    </div>
                </div>
            </div>
            <div class="row">
                @if (@ViewBag.BranchCheck == 0)
                {
                    <div class="form-group col-sm-4">
                        @Html.Label("Branch", null, new { @class = "control-label" })
                        @Html.DropDownListFor(m => m.Branch, (SelectList)ViewBag.SetBranch, new { id = "ddlBranch", @class = "form-control select2" })
                    </div>
                }
                @if (@ViewBag.JewCheck == 0)
                {
                    <div class="form-group col-sm-2">
                        @Html.LabelFor(m => m.ItemType, new { @class = "control-label" })
                        @Html.DropDownListFor(m => m.ItemType, (SelectList)ViewBag.ItemType, new { @class = "form-control input-sm", @onchange = "Itemtype();" })
                    </div>
                }
                else
                {
                    if (ViewBag.BusinessType == "Scaffold")
                    {
                        @Html.HiddenFor(m => m.ItemType, new { @Value = "5" })
                    }
                    else
                    {
                        @Html.HiddenFor(m => m.ItemType, new { @Value = "1" })
                    }
                }
                @if (@ViewBag.EnableCurrency == 0)
                {
                    <div class="form-group col-sm-2">
                        @Html.Label("Currency", null, htmlAttributes: new { @class = "control-label" })
                        @Html.DropDownListFor(m => m.Currency, (SelectList)ViewBag.NCurrency, new { id = "ddlCurrency", @class = "form-control select2", @onchange = "ChangeCurrency();" })
                    </div>
                    <div class="form-group col-sm-2">
                        @Html.Label("Conversion Rate", null, htmlAttributes: new { @class = "control-label" })
                        @Html.TextBoxFor(m => m.ConRate, new { @class = "form-control input-sm" })
                    </div>
                }
                <div class="col-sm-2 form-group">
                    @Html.Label("Supplier", null, new { @class = "control-label" })
                    @Html.DropDownListFor(m => m.Supplier, (SelectList)ViewBag.Supp, new { id = "ddlCusupplier", @class = "form-control select2" })
                </div>
                <div class="col-sm-2 form-group">
                    @Html.Label("Supplier Ref", null, htmlAttributes: new { @class = "control-label" })
                    @Html.TextBoxFor(m => m.SupplierRef, new { @class = "form-control input-sm" })
                </div>
                <div class="col-sm-2 form-group">
                    @Html.Label("Pricing Strategy", null, new { @class = "control-label" })
                    @Html.CheckBoxFor(m => m.pricingstatagy, new { @class = "checkbox", @Id = "chkpricing", @onchange = "calcprice()" })
                </div>
                <div class="prcstg">
                    <div class="col-sm-2 form-group">
                        @Html.Label("Lock Price", null, new { @class = "control-label" })
                        @Html.CheckBoxFor(m => m.lockprice, new { @class = "checkbox", @Id = "chklockprice", @onchange = "calcprice()" })

                    </div>
                    <div class="col-sm-2 form-group">
                        @Html.Label("Pricing Strategy Type", null, new { @class = "control-label" })
                        @Html.EnumDropDownListFor(model => model.pricingstatagytype, new { @class = "form-control", @onchange = "calcprice()" })
                    </div>
                    <div class="col-sm-2 form-group">
                        @Html.Label("Amount Type", null, new { @class = "control-label" })
                        @Html.EnumDropDownListFor(model => model.amounttype, new { @class = "form-control", @onchange = "calcprice()" })
                    </div>
                    <div class="col-sm-2 form-group">
                        @Html.Label("Value", null, new { @class = "control-label" })
                        @Html.TextBoxFor(m => m.amount, new { @class = "form-control input-sm", @onchange = "calcprice()" })

                    </div>
                </div>

                @if (ViewBag.BusinessType == "Scaffold")
                {
                    <div class="col-sm-2 form-group">
                        @Html.Label("Weight (In Kg)", null, htmlAttributes: new { @class = "control-label" })
                        @Html.TextBoxFor(m => m.SCWeight, new { @class = "form-control input-sm", @Value = "0.00", })
                    </div>
                    <div class="col-sm-2 form-group">
                        @Html.Label("CBM", null, htmlAttributes: new { @class = "control-label" })
                        @Html.TextBoxFor(m => m.CBM, new { @class = "form-control input-sm", @Value = "0.00", })
                    </div>
                }
                <div class="clearfix"></div>

                <div class="col-sm-4" id="itemimgs">
                    <div class="form-group col-sm-12 no-padding">
                        @Html.Label("Item Image", null, new { @class = "control-label" })
                        <div class="input-group input-group-sm ">
                            @Html.TextBoxFor(m => m.ItemImage, new { type = "file", multiple = "multiple", tabindex = 24 })
                            <span class="input-group-btn">
                                <a onclick="AddDocs()" class="btn btn-default" tabindex="20" title="Add Additional Images">
                                    <i class="glyphicon glyphicon-plus"></i>
                                </a>
                            </span>
                        </div>
                    </div>

                    @***********************Add Attachment ********************@
                    <div id="ImageLabel">
                        <label class=" control-label">Additional Images</label>
                    </div>

                    <div class="form-group col-sm-12 no-padding" id="Images">

                    </div>
                    @**********************************************************@

                    <div class="form-group col-sm-12 no-padding">
                        @Html.Label("Item Document", null, new { @class = "control-label" })
                        @Html.TextBoxFor(m => m.ItemDocument, new { type = "file", multiple = "multiple", tabindex = 25 })
                    </div>
                    <div class="checkbox-inline">
                        @Html.CheckBoxFor(m => m.KeepStock, new { @class = "checkbox", tabindex = 26 })
                        @Html.LabelFor(m => m.KeepStock, new { @class = "control-label" })
                    </div>
                    <div class="checkbox-inline">
                        @Html.CheckBoxFor(m => m.slreq, new { @class = "checkbox", tabindex = 26 })
                        @Html.LabelFor(m => m.slreq, new { @class = "control-label" })
                    </div>
                    <div class="checkbox-inline" style="display:none">
                        @Html.CheckBoxFor(m => m.accmap, new { @class = "checkbox", tabindex = 26 })
                        @Html.LabelFor(m => m.accmap, new { @class = "control-label" })
                    </div>
                    <div class="form-group col-md-6">
                        @Html.Label("Account ", null, new { @class = "control-label" })
                        @Html.DropDownListFor(m => m.accountid, (SelectList)ViewBag.SetAccount, new { @class = "form-control select2", @required = "required" })
                    </div>
                    <div class="col-sm-4 form-group">
                        @Html.Label("No Of Days Expiry", null, htmlAttributes: new { @class = "control-label" })
                        @Html.TextBoxFor(m => m.daysexpirty, new { @class = "form-control input-sm" })
                    </div>
                    <div class="box-body hiden StockSection" id="StockSection">
                        <div class="form-group col-sm-12 no-padding">
                            @Html.Label("Opening Stock", null, new { @class = "control-label" })
                            <div class="input-group input-group-sm">
                                @Html.TextBoxFor(m => m.OpeningStock, new { @class = "form-control input-sm", @Value = "0", tabindex = 27 })
                                <span class="input-group-btn">
                                    <button type="button" class="btn btn-flat prim"></button>
                                </span>
                            </div>
                        </div>
                        @if (ViewBag.mcminstockwise == 0)
                        {
                            <div class="form-group col-sm-12 no-padding">
                                @Html.Label("Minimun Stock", null, new { @class = "control-label" })
                                <div class="input-group input-group-sm">
                                    @Html.TextBoxFor(m => m.MinStock, new { @class = "form-control input-sm", @Value = "0", tabindex = 28, @readonly = "readonly" })
                                    <span class="input-group-btn">
                                        <button type="button" class="btn btn-flat prim"></button>
                                    </span>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="form-group col-sm-12 no-padding">
                                @Html.Label("Minimun Stock", null, new { @class = "control-label" })
                                <div class="input-group input-group-sm">
                                    @Html.TextBoxFor(m => m.MinStock, new { @class = "form-control input-sm", @Value = "0", tabindex = 28 })
                                    <span class="input-group-btn">
                                        <button type="button" class="btn btn-flat prim"></button>
                                    </span>
                                </div>
                            </div>
                        }
                        <div class="form-group col-sm-12 no-padding">
                            @Html.Label("Stock value", null, new { @class = "control-label" })
                            <div class="input-group input-group-sm">
                                @Html.TextBoxFor(m => m.StockValue, new { @class = "form-control input-sm", @Value = "0", tabindex = 28 })
                            </div>
                        </div>
                    </div>
