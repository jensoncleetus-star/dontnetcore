            dataType: 'json',
            data: { PurchEntryId: PEEntryId, ItemId: ItemId },
            cache: true,
            success: function (data) {

                //To Set the RowCount For Appending Rows
                RowCount = data[0].Quantity;

                //Setting The Values
                $("#ExpiryDate").val(data[0].ExpiryDate);
                $("#MfgDate").val(data[0].MfgDate);
                $("#Unit").val(data[0].UnitId);

                $('.input_fields_wrap2').html('');

                //To Fill The Serial Number Details(Appending Rows According To Quantity)
                FillData()
            }
        });
    }
    else {
        $("#SerialNo").focus();
    }

     //To Fill The Serial Number Details in Create Mode
    function FillData() {

        var Date1   =   $("#ExpiryDate").val();
        var Date2   =   $("#MfgDate").val();

        //To Set value of Expiry Date
        var ExpDate = GetDateFormat(Date1);

        //To Set value of Manufactured Date
        var MfgDate = GetDateFormat(Date2);

        var wrapper2 = $(".input_fields_wrap2"); //Fields wrapper
        var SlNo = 1;
        for (var rowno = 0; rowno < RowCount; rowno++) {

            $(wrapper2).append('<div class="row" style="margin-top: 1rem;">' +

                                    '<div class="col-md-1" style="margin-right:-65px">' +
                                        '<label class="control-label"></label>' +
                                        '<div class="input-group" style="margin-top:8px">' +
                                            SlNo +
                                       '</div>'+
                                     '</div>'+

                                    '<div class="col-md-7">' +
                                        '<label class="control-label">Serial Number</label>' +
                                        '<div class="input-group">' +
                                            '<input type="text" Id = "SerialNo" name="SerialNoObjs[' + rowno + '].SerialNo" class="form-control" tabindex = 2>' +
                                        '</div>' +
                                    '</div>' +

                                    '<div class="col-md-2">' +
                                        '<label class="control-label">Manufacture Date</label>' +
                                        '<div class="input-group">' +
                                            '<input type="date" name="SerialNoObjs[' + rowno + '].MfgDate" value="' + MfgDate + '" class="form-control datepicker" required tabindex = 3>' +
                                        '</div>' +
                                    '</div>' +

                                    '<div class="col-md-2">' +
                                        '<label class="control-label">Expiry Date</label>' +
                                        '<div class="input-group">' +
                                            '<input type="date" name="SerialNoObjs[' + rowno + '].ExpiryDate" value="' + ExpDate + '" class="form-control datepicker" required tabindex = 4>' +
                                        '</div>' +
                                    '</div>' +
                                 '</div > '
            );
            SlNo++
        }
        $("#SerialNo").focus();
     }

    // Saving
    $('#createform').on('submit', function (e) {

             $.ajax({
                 async: true,
                 cache: false,
