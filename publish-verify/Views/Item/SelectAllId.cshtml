    function calcprice(i) {
            if ($("#chkpricing"+i).prop("checked") == true) {
                $.ajax({
                    url: '/PurchaseEntry/GetPrice',
                    type: "GET",
                    dataType: "JSON",
                    data: { itemid: $("#ItemID" + i).val(), pcategory: $("#pricingstatagytype"+i).val(), amounttype: $("#amounttype"+i).val(), amount: $("#amount"+i).val() },
                    success: function (data) {
                        $("#SellingPrice"+i).val(data.salprice);
                        $("#PurchasePrice"+i).val(data.purprice);
                        if ($("#pricingstatagytype"+i).val() == 3) {
                            $("#amounttype"+i).prop("disabled", true);
                            $("#SellingPrice"+i).val($("#amount"+i).val());
                        }
                        else {
                            $("#SellingPrice"+i).val(data.salprice);
                            $("#amounttype"+i).prop("disabled", false);
                        }

                    }
                });

            }
            else {
                var tags = @Html.Raw(Json.Encode(Model.itemUpdatess));
                $("#SellingPrice" + i).val(tags[i].SellingPrice);
                $("#PurchasePrice" + i).val(tags[i].PurchasePrice);

            }


        }



