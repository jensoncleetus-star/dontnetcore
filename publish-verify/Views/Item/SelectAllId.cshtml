@using (Html.BeginForm("BulkPriceUpdate", "Item", FormMethod.Post, new { id = "createform", autocomplete = "off", @enctype = "multipart/form-data" }))
{
<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">Bulk Price Update</h3>
    </div>

    @Html.AntiForgeryToken()
    @Html.ValidationSummary("", new { @class = "alert alert-danger" })
    @Html.HiddenFor(model => model.PurchaseEntryId)
    @Html.HiddenFor(model => model.Unit)
    @Html.HiddenFor(model => model.MfgDate)
    @Html.HiddenFor(model => model.ExpiryDate)
    <div class="form-group col-md-2">
        @Html.Label("Offer From", null, new { @class = "control-label" })
        <div class="input-group date">
            @Html.TextBoxFor(m=>m.MFG, "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
            <div class="input-group-addon">
                <i class="fa fa-calendar"></i>
            </div>
        </div>
    </div>
    <div class="form-group col-md-2">
        @Html.Label("Offer To", null, new { @class = "control-label" })
        <div class="input-group date">
            @Html.TextBoxFor(m=>m.EXP, "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
            <div class="input-group-addon">
                <i class="fa fa-calendar"></i>
            </div>
        </div>
    </div>
    <div class="box-body">
        <div class="row">
            <div class="col-md-12 col-xs-12 col-sm-12">
                @{
                    if (Model != null && Model.itemUpdatess != null && Model.itemUpdatess.Count > 0)
                    {
                        foreach (var item in Model.itemUpdatess.ToList())
                        {

                            <div class="row" style="margin-top: 1rem;">
                                <div class="col-md-1 col-xs-12 col-sm-6" style="margin-right:-30px">
                                    <label class="control-label temp2"></label>
                                    <div class="input-group" style="margin-top:8px">
                                        @SlNo
                                    </div>
                                </div>
                                @Html.HiddenFor(m => m.itemUpdatess[ci].ItemID, new { @id = "ItemID" + @ci })
                            <div class="col-md-11 col-xs-12 col-sm-12" style="border: 1px solid #ccc; padding-top: 10px !important; border-radius: 4px; ">
                                <div class="col-md-2 col-xs-12 col-sm-6 form-group">
                                    @Html.Label("Item Name", null, new { @class = "control-label temp2" })
                                    @Html.TextBoxFor(m => m.itemUpdatess[ci].ItemName, new { @id = "ItemName" + @ci, @class = "form-control input-sm" })
                                </div>
                                <div class="col-md-2 col-xs-12 col-sm-6 form-group hide1" style="height:46px!important;">
                                    <div class="input-group" style="height:25px!important;border:1px solid #ccc;border-radius:4px;margin-top:21px;">
                                        <span class="input-group-addon">
                                            @Html.CheckBoxFor(m => m.itemUpdatess[ci].status)
                                        </span>
                                        @Html.Label("Item Active ?", null, new { @class = "control-label", @style = "padding-top:4px!important;padding-left:4px!important;" })
                                    </div>
                                </div>
                                <div class="col-md-2 col-xs-12 col-sm-6 form-group">
                                    @Html.Label("Current Stock", null, new { @class = "control-label temp2" })
                                    @Html.TextBoxFor(m => m.itemUpdatess[ci].currstock, new { @id = "currstock" + @ci, @class = "form-control input-sm", @readonly = "readonly" })
                                </div>
                                <div class="col-md-2 col-xs-12 col-sm-6 form-group" style="margin-top:1px!important;">
                                    <a href="javascript:void(0)" onclick="LastSalePurList(@Model.itemUpdatess[ci].ItemID,1)" class="temp2">Selling Price</a>
                                    @Html.TextBoxFor(m => m.itemUpdatess[ci].SellingPrice, new { @id = "SellingPrice" + @ci, @class = "form-control input-sm" })
                                </div>
                                <div class="col-md-2 col-xs-12 col-sm-6 form-group" style="margin-top:1px!important;">
                                    @Html.Label("Offer Price", null, new { @class = "control-label temp2" })
                                    @Html.TextBoxFor(m => m.itemUpdatess[ci].offerprice, new { @id = "PurchasePrice" + @ci, @class = "form-control input-sm" })
                                </div>
                                <div class="col-md-2 col-xs-12 col-sm-6 form-group" style="margin-top:1px!important;">
                                    <a href="javascript:void(0)" onclick="LastSalePurList(@Model.itemUpdatess[ci].ItemID,2)" class="temp2">Purchase Price</a>
                                    @Html.TextBoxFor(m => m.itemUpdatess[ci].PurchasePrice, new { @id = "PurchasePrice" + @ci, @class = "form-control input-sm" })
                                </div>

                                <div class="col-md-2 col-xs-12 col-sm-6 form-group hide1" style="height:46px!important;">
                                    <div class="input-group" style="height: 25px !important; border: 1px solid #ccc; border-radius: 4px; margin-top: 21px;">
                                        <span class="input-group-addon">
                                            @Html.CheckBoxFor(m => m.itemUpdatess[ci].pricingstatagy, new { @class = "checkbox", @Id = "chkpricing" + @ci, @onchange = "calcprice(" + ci + "); calcprice2(" + ci + "); " })
                                        </span>
                                        @Html.Label("Pricing Strategy", null, new { @class = "control-label", @style = "padding-top:4px!important;padding-left:4px!important;" })
                                    </div>
                                </div>
                                <div class="col-md-2 col-xs-12 col-sm-6 form-group" style="height:46px!important;">
                                    <div class="input-group" style="height: 25px !important; border: 1px solid #ccc; border-radius: 4px; margin-top: 21px;">
                                        <span class="input-group-addon">
                                            @Html.CheckBoxFor(m => m.itemUpdatess[ci].lockprice, new { @class = "checkbox", @Id = "chklockprice" + @ci, @onchange = "calcprice(" + ci + ")" })
                                        </span>
                                        @Html.Label("Lock Price", null, new { @class = "control-label", @style = "padding-top:4px!important;padding-left:4px!important;" })
                                    </div>
                                </div>
                                <div class='prcstg-@ci'>
                                    <div class="col-md-2 col-xs-12 col-sm-6 form-group">
                                        @Html.Label("Pricing Strategy Type", null, new { @class = "control-label temp2" })
                                        @Html.EnumDropDownListFor(m => m.itemUpdatess[ci].pricingstatagytype, new { @id = "pricingstatagytype" + @ci, @class = "form-control", @onchange = "calcprice(" + ci + ")" })
                                    </div>
                                    <div class="col-md-2 col-xs-12 col-sm-6 form-group">
                                        @Html.Label("Amount Type", null, new { @class = "control-label temp2" })
                                        @Html.EnumDropDownListFor(m => m.itemUpdatess[ci].amounttype, new { @id = "amounttype" + @ci, @class = "form-control", @onchange = "calcprice(" + ci + ")" })
                                    </div>
                                    <div class="col-md-2 col-xs-12 col-sm-6 form-group">
                                        @Html.Label("Value", null, new { @class = "control-label temp2" })
                                        @Html.TextBoxFor(m => m.itemUpdatess[ci].amount, new { @Id = "amount" + @ci, @class = "form-control input-sm", @onchange = "calcprice(" + ci + ")" })
                                    </div>
                                </div>
                            </div>

                            </div>
                            ci++;
                            SlNo++;
                        }
                    }
                }


            </div>
        </div>

        <div class="row text-center" style="margin-top:10px!important;">
            <button type="submit" id="save" class="btn btn-success" tabindex="5">
                <span class="glyphicon glyphicon-floppy-disk"></span> Save
            </button> &ensp;
            <button type="button" class="btn btn-default can-btn" tabindex="6" onclick="@("window.location.href='/item/BulkPriceUpdate'");">Cancel</button>
        </div>
    </div>
</div>
    <div id="LastSalePur"></div>
}
