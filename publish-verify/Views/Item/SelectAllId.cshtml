@model QuickSoft.ViewModel.SerialNoViewModel
@{
    ViewBag.Title = "BulkPriceUpdate";
    ViewBag.SubTitle = "Bulk Price Update";
    var TimeOut = @ViewBag.TMOut;
    int ci = 0;
    int SlNo = 1;


}
<style>
