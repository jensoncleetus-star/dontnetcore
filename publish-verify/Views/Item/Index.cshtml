    ViewBag.Title = "Item List";
    ViewBag.SubTitle = "Item";
    ViewBag.Active = "Master";
    string actData = "";
    string delchk = "";
    bool userRole = false;
    string deleteBTn = "";
    if (User.IsInRole("Dev") || User.IsInRole("Delete Item"))
    {
        userRole = true;
        deleteBTn = "{text: 'Delete', className: 'btn-danger', action: function(e, dt, node, config) {" +
            "if (confirm('Are you sure you want to delete this?')) {$('#payform').submit()};}},";
    }
}
<style type="text/css">

    .dropdown-check-list {
        display: inline-block;
    }

        .dropdown-check-list .anchor {
            position: relative;
            cursor: pointer;
            display: inline-block;
            padding: 5px 50px 5px 10px;
            border: 1px solid #ccc;
            width: 150px;
            background: #fff;
            text-align: center;
        }

            .dropdown-check-list .anchor:after {
                position: absolute;
                content: "";
                border-left: 2px solid black;
                border-top: 2px solid black;
                padding: 5px;
                right: 10px;
                top: 20%;
                -moz-transform: rotate(-135deg);
                -ms-transform: rotate(-135deg);
                -o-transform: rotate(-135deg);
                -webkit-transform: rotate(-135deg);
                transform: rotate(-135deg);
            }

            .dropdown-check-list .anchor:active:after {
                right: 8px;
                top: 21%;
            }

        .dropdown-check-list ul.items {
            padding: 0px;
            display: none;
            margin: 0;
            border: 1px solid #ccc;
            border-top: none;
            position: absolute;
            z-index: 9999;
        }

            .dropdown-check-list ul.items li {
                list-style: none;
                background: #fff;
                padding: 5px;
            }

        /*  .add-btn-item {
        border-radius: 23px;
        padding: 6px 20px;
    }*/

        .dropdown-check-list.visible .anchor {
            color: #0094ff;
        }

        .dropdown-check-list.visible .items {
            display: block;
        }

    .sh-spaan-text-style {
        font-family: sans-serif;
    }

    .sh-input-drop {
        border: 1px solid rgb(0 0 0 / 0.20);
        padding: 3px;
    }

    @@media only screen and (max-width: 400px) {
        .top3 {
            margin-top: 27px;
        }

        .adv-search-height {
            margin-left: 10px !important;
        }

        .responsive-search {
            padding: 0px 0px 0px 0px !important;
        }

        .btn-close {
            background-color: red !important;
            width: 150px !important;
        }

        .task-name-center {
            text-align: center !important;
        }

        .button-left-margin {
            margin-left: 25%;
        }

        .drop-align-center {
            position: relative !important;
            left: 60px;
        }
    }

    @@media only screen and (min-width: 800px) {
        .top3 {
            margin-top: 10px;
        }

        .adv-search-height {
            top: -10px !important;
            margin-left: 13px;
        }

        .responsive-search {
            padding: 25px 0px 0px 50px !important;
        }

        .btn-close {
            background-color: red !important;
        }
    }
</style>

<div class="box box-info">
    <div class="box-header with-border">

        <div class="row">
            <div class="col-md-10 col-xs-12 task-name-center ">
                <h3 class="box-title" style="font-size:x-large;">Items</h3>
            </div>
            <div class="col-md-2 col-xs-12 pull-right sh-downonSmallScreen" style="padding: 0px; margin: 10px 0px 0px 0px;">

                <div class="row">

                    <div class="col-md-10 col-xs-6 col-xs-offset-3" style="padding:0px; width:150px; ">
                        @if (User.IsInRole("Dev") || User.IsInRole("Create Item"))
                        {

                            <a class="btn btn-info no-border" href="/Item/create">
                                <i class="fa fa-plus"></i> &nbsp; Create
                            </a>
                        }
                        @if (@ViewBag.BulkUpload == 0 && (User.IsInRole("Dev") || User.IsInRole("Create Item")))
                        {
                            <a class="btn btn-info no-border" href="/Item/BulkUpload">
                                <i class="fa fa-file-excel-o"></i> Excel Upload
                            </a>
                        }


                    </div>
                </div>

            </div>
            <div class="col-md-2 col-xs-10 " id="taskchecklist" style="padding:0px; margin:auto;">
                <div id="list1" class="dropdown-check-list drop-align-center" tabindex="100">
                    <span class="anchor" style="z-index:0;">Select Fields</span>
                    <ul class="items">
                        <li><input type="checkbox" id="liitem" />Item</li>
                        <li><input type="checkbox" id="liitemtype" />Item Type</li>
                        <li><input type="checkbox" id="lipartnumber" />Part Number</li>
                        <li><input type="checkbox" id="licategory" />Category</li>
                        <li><input type="checkbox" id="librand" />Brand</li>
                        <li><input type="checkbox" id="liunit" />Unit</li>
                        <li><input type="checkbox" id="lisize" />Size</li>
                        <li><input type="checkbox" id="licolor" />Color</li>
                        <li><input type="checkbox" id="litax" />Tax</li>
                        <li><input type="checkbox" id="lisupplier" />Supplier</li>
                        <li><input type="checkbox" id="lisupplierref" />Supplier Ref</li>
                        <li><input type="checkbox" id="listatus" />Active/Inactive</li>
                        <li><input type="checkbox" id="likeepstock" />Keep Stock</li>
                    </ul>
                </div>
            </div>

            <div class="col-md-12 col-xs-12">
                <div class="box-body search-box adv-search-height" id="advsearchlist">
                    <div class="search-body responsive-search " style="background:none;">
                        <form id="search-form">
                            <div class="row">
                                <div class="form-group col-md-2" id="searchitem">
                                    @Html.Label("Item", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlItem", (SelectList)ViewBag.ItemSrch, new { @class = "form-control select2" })
                                </div>
                                @if (@ViewBag.JewCheck == 0)
                                {
                                    <div class="form-group col-md-2" id="searchitemtype">
                                        @Html.Label("ItemType", null, new { @class = "control-label" })
                                        @Html.DropDownList("ItemType", (SelectList)ViewBag.ItemType, new { @class = "form-control select2" })
                                    </div>
                                }
                                @if (@ViewBag.PartNoCheck == 0)
                                {
                                    <div class="form-group col-md-2" id="searchpartno">
                                        @Html.Label("Part Number", null, new { @class = "control-label" })
                                        @Html.TextBox("PartNo", "", new { @class = "form-control input-sm" })
                                    </div>
                                }
                                <div class="form-group col-md-2" id="searchcategory">
                                    @Html.Label("Category", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlCategory", (SelectList)ViewBag.ItemCatg, new { @class = "form-control select2" })
                                </div>



                                <div class="form-group col-md-2" id="searchbrand">
                                    @Html.Label("Brand", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlBrand", (SelectList)ViewBag.ItmBrand, new { @class = "form-control select2" })
                                </div>

                                <div class="form-group col-md-2" id="searchunit">
                                    @Html.Label("Unit", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlPUnit", (SelectList)ViewBag.PUnit, new { @class = "form-control select2" })
                                </div>
                                <div class="form-group col-md-2" id="searchsize">
                                    @Html.Label("Size", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlItemSize", (SelectList)ViewBag.ItemSize, "All", new { @class = "form-control input-sm" })
                                </div>

                                <div class="form-group col-md-2" id="searchcolor">
                                    @Html.Label("Color", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlColor", (SelectList)ViewBag.ItemColor, "All", new { @class = "form-control select2" })
                                </div>
                                <div class="form-group col-md-2" id="searchtax">
                                    @Html.Label("Tax", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlTax", (SelectList)ViewBag.ItemTax, "All", new { @class = "form-control input-sm" })
                                </div>

                                <div class="form-group col-md-2" id="searchsupplier">
                                    @Html.Label("Supplier", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlSupplier", (SelectList)ViewBag.Supp, new { @class = "form-control select2" })
                                </div>
                                <div class="form-group col-md-2" id="searchsupplierref">
                                    @Html.Label("Supplier Ref", null, new { @class = "control-label" })
                                    @Html.TextBox("SupplierRef", "", new { @class = "form-control input-sm" })
                                </div>
                                <div class="form-group col-md-2" id="searchstatus">
                                    @Html.Label("Status", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlStatus", (SelectList)ViewBag.ItStatus, new { @class = "form-control" })
                                </div>
                                <div class="form-group col-md-2" id="searchkeepstock">
                                    @Html.Label("Keep Stock", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlKeepStock", (SelectList)ViewBag.KStock, new { @class = "form-control" })
                                </div>
                                <div class="form-group col-md-2 col-6 text-center" id="search">
                                    <input type="submit" class="btn btn-submit" value="Submit" />
                                </div>
                                <div class="form-group col-md-2 col-6 text-center" id="close">
                                    <input type="button" class="btn btn-close" value="Close" />
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <div class=" col-md-2" id="searchpagelength">

                <span class="sh-spaan-text-style">Show &nbsp;</span>@Html.DropDownList("ddlPagesize", new SelectList(new List<SelectListItem>
{
new SelectListItem() {Text = "50 Rows", Value="50"},
new SelectListItem() {Text = "All Rows", Value="10000000"},

}, "Value", "Text"), new { @class = "sh-input-drop select2" })

            </div>
        </div>
    </div>

    @using (Html.BeginForm("DeleteAllItem", "Item", FormMethod.Post, new { id = "payform", role = "form" }))
    {
        <div class="box-body">
            <input type="hidden" id="PaNo" value="@ViewBag.PartNoCheck" />
            <input type="hidden" id="Jewel" value="@ViewBag.JewCheck" />
            <input type="hidden" id="Scaf" value="@ViewBag.BusinessType" />
            <table class="table table-bordered table-hover" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="1">S/N</td>
                        <td data-priority="1">Code</td>
                        <td data-priority="1">Name</td>
                        <td data-priority="5">Item Image</td>
                        <td data-priority="6">Item Type</td>
                        <td data-priority="7">Part Number</td>
                        <td data-priority="6">Barcode</td>
                        <td data-priority="8">Description</td>
                        <td data-priority="2">Selling Price</td>
                        <td data-priority="2">Purchase Price</td>
                        <td data-priority="6">Base Price</td>
                        <td data-priority="6">MRP</td>
                        <td data-priority="1">Category</td>
                        <td data-priority="2">Brand</td>
                        <td data-priority="4">Color</td>
                        <td data-priority="2">Tax</td>
                        <td data-priority="4">Size</td>
                        <td data-priority="7">Supplier</td>
                        <td data-priority="7">Supplier Ref</td>
                        <td data-priority="3">Primary Unit</td>
                        <td data-priority="7">Secondary Unit</td>
                        <td data-priority="3">Opening Stock</td>
                        <td data-priority="7">Weight</td>
                        <td data-priority="7">CBM</td>
                        <td data-priority="5">Status</td>
                        <td data-priority="5">Approvals</td>
                        <td data-priority="1">Action</td>
                        <td data-priority="1"><input type="checkbox" id="select_all" /></td>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    }

    <div id="modal-container" class="modal fade" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
            </div>
        </div>
    </div>

    <div id="modal-container2" class="modal fade" role="dialog" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
            </div>
        </div>
    </div>

</div>
@{var Model = "modal-lg";}
@Html.Partial("../Common/_ModalCreate", @Model)
@Html.Partial("../Common/_ModalEdit")
@Html.Partial("../Common/_ModalDelete")
@Html.Partial("../Common/_ModalChange")
@Html.Partial("../Common/_ModalCreate")

@section scripts{
    <script type="text/javascript">

        $(document).ready(function () {
            $('#advsearchlist').hide();

            $('[data-confirm]').click(function (e) {
                if ($('.checkbox:checked').length > 0) {
                    if (!confirm(jQuery(this).attr("data-confirm"))) {
                        e.preventDefault();
                    }
                } else {
                    alert("Please Select Rows..!!");
                    e.preventDefault();
                }
            });
        });

        CallRepSupplier();
        //CallRepSupplier();
        ItemSearchableinactive();

        jQuery(function ($) {

            var oTable = $('#UserTable').DataTable({
                "processing": true, // for show progress bar
                "serverSide": true, // for process server side
                "filter": true, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
                "bStateSave": false,
                'pageLength': 50,
                responsive: true,

                "ajax": {
                    "url": '/Item/GetItem',
                    "data": function (data) {
                        data.Item = $('#ddlItem').val();
                        data.ItemType = $('#ItemType').val();
                        data.PartNo = $('#PartNo').val();
                        data.PUnit = $('#ddlPUnit').val();
                        data.Brand = $('#ddlBrand').val();
                        data.Category = $('#ddlCategory').val();
                        data.ItemSize = $('#ddlItemSize').val();
                        data.Color = $('#ddlColor').val();
                        data.Tax = $('#ddlTax').val();
                        data.ddlSupplier = $('#ddlSupplier').val();
                        data.SuppRef = $('#SupplierRef').val();
                        data.Stats = $('#ddlStatus').val();
                        data.KpStock = $('#ddlKeepStock').val();
                    },
                    "type": "POST",
                    "datatype": "json"

                },
                "order": [[0, "asc"]],
                "columnDefs": [{
                    "targets": [-1, -2, -3],
                    "orderable": false
                }],
                "columns": [
                     {
                         "data": "ItemID", "name": "ItemID",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                    { "data": "ItemCode", "name": "ItemCode" },
                    //{ "data": "ItemName", "name": "ItemName" },
                    {
                        "data": "ItemName", "data": function (data) {
                            @{
                                    var datas = "";
                                    //if (User.IsInRole("Dev") || User.IsInRole("View Item"))
                                    //{
                                    datas = "'<a href=\"/Item/Details/'+ data.ItemID +'\">'+ data.ItemName +'</a>' ";
                                //}
                                //else
                                //{
                                //    datas = "data.ItemName";
                                //}
                            }
                            return @Html.Raw(datas);
                        }
                    },
                    {
                        "name": "ItemArabic", "data":function(data) {
                           return '<img height="100"  class=""   src="/uploads/itemimages/' + data.ItemID + '/' + data.FileName + '"/>';

                        }
                },
                    {
                        "data": "ItemType", "name": "ItemType", "render": function (data) {
                            if (data == 2) {
                                return 'Diamond';
                            }
                            else if (data == 3) {
                                return 'Watch';
                            }
                            else if (data == 4) {
                                return 'Object';
                            }
                            else {
                                return 'General';
                            }

                        }
                    },
                    { "data": "PartNumber", "name": "PartNumber" },

                    { "data": "Barcode", "name": "Barcode" },
                      {
                          "data": "ItemDescription", "name": "ItemDescription", "render": function (data) {
                              if (data != null && data.length > 50) {
                                  return data.substr(0, 50) + '...';
                              }
                              else {
                                  return data;
                              }
                          }
                      },
                    { "data": "SellingPrice", "name": "SellingPrice", render: $.fn.dataTable.render.number(",", ".", 2) },
                    { "data": "PurchasePrice", "name": "PurchasePrice", render: $.fn.dataTable.render.number(",", ".", 2) },
                    { "data": "BasePrice", "name": "BasePrice", render: $.fn.dataTable.render.number(",", ".", 2) },
                    { "data": "MRP", "name": "MRP", render: $.fn.dataTable.render.number(",", ".", 2) },
                    { "data": "Category", "name": "Category" },
                    { "data": "Brand", "name": "Brand" },
                    { "data": "Color", "name": "Color" },
                    { "data": "Tax", "name": "Tax" },
                    { "data": "Size", "name": "Size" },
                    { "data": "Supplier", "name": "Supplier" },
                    { "data": "SupplierRef", "name": "SupplierRef" },
                    { "data": "PUnit", "name": "PUnit" },
                    { "data": "SUnit", "name": "SUnit" },
                    {
                        "name": "OpeningStock", "data": function (data) {
                            if (data.KeepStock) {
                                return data.OpeningStock + " " + (data.PUnit||"");
                            }
                            else {
                                return "";
                            }
                        }
                    },
                    { "data": "Weight", "name": "Weight" },
                    { "data": "CBM", "name": "CBM" },
                      {
                          "name": "Status", "data": function (data) {
                              if (data.Status == 1) {
                                  return '<a href="/Item/ChangeStatus/' + data.ItemID + '/active" class="modal-change" title="Click To Active" ><i class="badge bg-red" style="font-size: small" >Inactive</i></a>';
                              }
                              else {
                                  return '<a href="/Item/ChangeStatus/' + data.ItemID + '/inactive" class="modal-change" title="Click To Inactive" ><i class="badge bg-green" style="font-size: small" >Active</i></a>';
                              }
                          }
                    },
                       {
                     "name": "ApprovalStatus", "data": function (data, type, dataToSet) {
                         var status = "";
                         var cls = "";
                         if (data.app.length > 0 || data.Approval == true ) {
                             if (data.ApprovalStatus == "0") {
                                 status = '<span class="badge bg-green">Approved</span>';
                             }
                             else if (data.ApprovalStatus == "1") {
                                 status = '<span class="badge bg-red">Rejected</span>';
                             }
                             else if (data.ApprovalStatus == "2") {
                                 status = '<span class="badge bg-orange">Pending</span>';
                             }
                             return '<a  class="Updation"  title="View Status">' + status + ' </a>';
                         } else { return null; }
                     }
                 },

                {
                    "name": "ItemID", "data": function (data) {
                        var rest = "";

                        @{
                            if (User.IsInRole("Dev") || User.IsInRole("View Item"))
                            {
                                actData += "<a href=\"/Item/Details/'+ data.ItemID +'\" title=\"View Item\"><i class=\"fa fa-lg fa-search-plus\"></i></a> ";
                            }
                            if (User.IsInRole("Dev") || User.IsInRole("Edit Item"))
                            {
                                actData += "<a class=\"modal-link-edit\" href=\"/Item/Edit/'+ data.ItemID +'\" title=\"Edit Item\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                                actData += "<a class=\" btn-icons modal-create\" href=\"/Item/AddItemRemark/'+ data.ItemID +'\" title=\"Add Remarks\"><i class=\" fa fa-plus\" ></i></a> ";
                                //actData += "<a class=\" btn-icons Updation\" onclick=\"details(' + data.ItemID + ')\" title=\"View Remarks\"><i class=\" fa fa-history\" ></i></a> ";
                            }
                            if (User.IsInRole("Dev") || User.IsInRole("Delete Item"))
                            {
                                actData += "<a class=\"modal-delete\" href=\"/Item/Delete/'+ data.ItemID +'\" title=\"Delete Item\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";
                            }

                            actData += "<a class=\"detailss\" href=\"/LogDetails/?TransId='+ data.ItemID +'&TransType='+ 'Item' +'\" title=\"View Item Updation\" target=\"new\"><i class=\"fa fa-lg fa-history\"></i></a> ";
                            if (User.IsInRole("Dev") || User.IsInRole("View Item Image"))
                            {
                                actData += "<a class=\"modal-link-images\" href=\"/Item/ImageAddstr/'+ data.ItemID +'\" title=\"add Item Images\" target=\"blank\"><i class=\"fa fa-lg fa-file-image-o\" ></i></a> ";
                            }
                            //if (User.IsInRole("Dev") || User.IsInRole("View Item Document"))
                            //{
                            //    actData += "<a class=\"modal-link-document\" href=\"/Item/Document/'+ data.ItemID +'\" title=\"View Item Documents\"><i class=\"fa fa-lg fa-file-pdf-o\" ></i></a> ";
                            //}
}
                        rest = '@Html.Raw(actData)';

                                if (data.Approval == true ) {
                            @{
                                actData = "";

                                actData += "<a class=\"modal-edit\"  href=\"/Item/EditStatus/'+ data.ItemID +'\" title=\"Edit Status\"><i class=\"fa fa-lg fa-refresh\" ></i></a> ";

                           }
                               rest += '@Html.Raw(actData)';
                        }
                        return rest;
                    }
                },
                 {
                     "name": "ItemID", "data": function (data) {
                         var rest = "";
                         @{
                            if (User.IsInRole("Dev") || User.IsInRole("Delete Item"))
                            {
                                delchk = "<input class=\"checkbox\" type=\"checkbox\" name=\"bill[]\" value='+ data.ItemID +'></input>";
                            }
                        }
                         return rest = '@Html.Raw(delchk)';
                     }
                 },
                ],
                dom: 'Bfrtip',
               buttons: ['colvis',
                 {
                    extend: 'print',//
                    title: "",
                    footer: true,
                    exportOptions: {
                        columns: ':visible'
                    },
                    message: '<table class="tblcompact table table-bordered"><thead>' +
                        ' <tr><th class="text-center"><h3 style="margin-top: 0px;">' + '<h4>Items </h4></th></tr>' +
                        ' <tr><th><span class="text-left"></span><span class="text-right pull-right"> </span></th></tr></thead><tbody><tr><td>',
                    customize: function (win) {
                        // $(win.document.body)
                        //.css('font-size', '10pt')
                        //.css('padding', '1px');
                        $(win.document.body).find('table, th,tr, td ')
                           // .css('border', 'inherit')
                            .css('font-size', '10pt')
                            .css('padding', '5px')
                            .addClass('compact');
                        $(win.document.body).append('</td></tr></tbody>')

                    }
                 }, 'copy', 'csv', 'excel',
                {
                    extend: 'pdf',//
                    title: "Items",
                    footer: true,
                    orientation: 'landscape',

                    pageSize: 'A4',
                    exportOptions: {
                        columns: ':visible'
                    },
                    customize: function (doc) {
                        doc.pageMargins = [10, 10, 10, 10];
                        doc.defaultStyle.fontSize = 10;
                        doc.styles.tableHeader.fontSize = 10;
                        doc.styles.title.fontSize = 12;
                        // Remove spaces around page title
                        doc.content[0].text = doc.content[0].text.trim();

                        doc.styles['td:nth-child(2)'] = {
                            width: '100%',
                            'max-width': '100%'
                        }

                        var objLayout = {};
                        // Horizontal line thickness
                        objLayout['hLineWidth'] = function (i) { return .5; };
                        // Vertikal line thickness
                        objLayout['vLineWidth'] = function (i) { return .5; };
                        //// Horizontal line color
                        //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                        //// Vertical line color
                        //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                        // Left padding of the cell
                        objLayout['paddingLeft'] = function (i) { return 4; };
                        // Right padding of the cell
                        objLayout['paddingRight'] = function (i) { return 4; };
                        // Inject the object in the document
                        doc.content[1].layout = objLayout;
                    }
                },
                    @Html.Raw(deleteBTn)
               ],
                "drawCallback": function (settings) {
                    var table = $('#UserTable').DataTable();
                    if (!table.data().any()) {
                        $("#sub").hide();
