@using QuickSoft.Models
@model QuickSoft.Models.mergeitem
@{
    ViewBag.Title = "Item Merge";
    ViewBag.SubTitle = "Item Merge";
    ViewBag.Active = "Master";

}

<div class="box box-info">
    @using (Html.BeginForm("createmergeitem", "Item", FormMethod.Post, new { id = "createmergeitem", role = "form", enctype = "multipart/form-data" }))
    {
        <div class="box-header with-border">
            <h3 class="box-title">Merge Item</h3>
            <h4 style="color:red">Note :-Take Backup Before This Process </h4>
        </div>
        <div class="box-body">
            @Html.AntiForgeryToken()
            @Html.ValidationSummary("", new { @class = "alert alert-danger" })

            <div class="row">

                <div class="form-group col-sm-4">
                    @Html.Label("Primary Item", null, new { @class = "control-label" }) *
                    <div class="input-group input-group-sm">
                        @Html.DropDownListFor(m => m.pritemid, (SelectList)ViewBag.itemn, new { id = "ddlItem", @class = "form-control select2" })

                    </div>
                </div>
                <div class="col-md-1"><span>&lt;===</span></div>
                <div class="form-group col-sm-4">
                    @Html.Label("Secondary Item", null, new { @class = "control-label" }) *
                    <div class="input-group input-group-sm">
                        @Html.DropDownListFor(m => m.secitemid, (SelectList)ViewBag.itemn, new { id = "ddlItem2", @class = "form-control select2" })
                        <br />
                        <strong style="color:red">This Item Will Disable After Merge</strong>
                    </div>
                </div>
                <div class="form-group col-sm-2">
                    <button type="submit" id="save" class="btn btn-success" tabindex="32">
                        <span class="glyphicon glyphicon-floppy-disk"></span> Merge
                    </button>
                </div>


            </div>
        </div>
    }
    @section scripts{
       
        @Scripts.Render("~/js/jqueryval")
    <script>
        $(document).ready(function () {
            $("#ddlItem").select2({
                placeholder: 'Search Item by Name or Code',
                minimumInputLength: 0,
                ajax: {
                    url: "/Item/Search",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term || "",
                            page: params.page || 0,
                            x: "All"
                        };
                    },
                    results: function (data) {
                        return { results: data };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 0;
                        return {
                            results: data,
                            pagination: {
                                //more: (params.page * 10) < 50
                                more: true
                            }
                        };
                    },
                    cache: true
                },

            });
            $("#ddlItem2").select2({
                placeholder: 'Search Item by Name or Code',
                minimumInputLength: 0,
                ajax: {
                    url: "/Item/Search",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term || "",
                            page: params.page || 0,
                            x: "All"
                        };
                    },
                    results: function (data) {
                        return { results: data };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 0;
                        return {
                            results: data,
                            pagination: {
                                //more: (params.page * 10) < 50
                                more: true
                            }
                        };
                    },
                    cache: true
                },

            });
        });

        </script>
       
}