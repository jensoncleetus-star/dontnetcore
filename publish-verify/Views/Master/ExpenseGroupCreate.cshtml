@model QuickSoft.Models.AccountsGroup
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Create Expense Group</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("ExpenseGroupCreate", "Master", FormMethod.Post, new { id = "createform" }))
            {
        <script type="text/javascript">
            $('form#createform').removeData("validator");
            $('form#createform').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#createform'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        <div class="row">
            <div class="col-md-12">
                <div class="form-group  col-md-12">
                    @Html.Label("Name", null, new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.Name, new { htmlAttributes = new { @class = "form-control input-sm", autofocus = "autofocus" , @required = "required" } })
                    @Html.HiddenFor(model => model.Parent)
                </div>
                <div class="form-group col-md-12">
                    @Html.Label("Alias", null, new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.Alias, new { htmlAttributes = new { @class = "form-control input-sm", autofocus = "autofocus", @required = "required" } })
                </div>
                @*<div class="form-group col-md-4">
                    @Html.Label("Primary", null, new { @class = "control-label" }) *
                    @Html.EnumDropDownListFor(model => model.Primary, new { @class = "form-control" })
                </div>*@
                <div class="form-group col-md-4">
                    @Html.Label("Status", null, new { @class = "control-label" }) *
                    @Html.EnumDropDownListFor(model => model.Status, new { @class = "form-control" })
                </div>
            </div>
        </div>
                <div class="row">
                    <div class="col-md-12">
                        <div class="box-footer">
                            <input type="submit" value="Save" class="btn btn-info col-sm-offset-4" />
                            <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                        </div>
                    </div>
                </div>
    }
</div>
@section scripts{
    @Scripts.Render("~/js/jqueryval")
}
