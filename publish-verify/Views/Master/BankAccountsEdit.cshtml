@model QuickSoft.ViewModel.BankViewModel

<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Edit Bank Accounts</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("BankAccountsEdit", "Master", FormMethod.Post, new { id = "editform" }))
            {
        <script type="text/javascript">
            $('form#editform').removeData("validator");
            $('form#editform').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#editform'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        @Html.HiddenFor(model => model.BankId)
        <div class="row">
            <div class="col-md-12">
                <div class="form-group  col-md-6">
                    @Html.Label("Bank Name", null, new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.Name, new { htmlAttributes = new { @class = "form-control input-sm", autofocus = "autofocus" } })
                </div>
                <div class="form-group  col-md-6">
                    @Html.LabelFor(model => model.AccountNo, htmlAttributes: new { @class = "control-label" })*
                    @Html.EditorFor(model => model.AccountNo, new { htmlAttributes = new { @class = "form-control input-sm", autofocus = "autofocus" } })
                </div>
                <div class="form-group col-md-6">
                    @Html.Label("Alias", null, new { @class = "control-label" })
                    @Html.EditorFor(model => model.Alias, new { htmlAttributes = new { @class = "form-control input-sm", autofocus = "autofocus" } })
                </div>
                @*<div class="form-group col-md-6">
                    @Html.Label("OB Debit", null, new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.OpnBalance, new { htmlAttributes = new { @class = "form-control input-sm", tabindex = 1, autofocus = "autofocus" } })
                </div>
                <div class="form-group col-md-6">
                    @Html.Label("OB Credit", null, new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.OpnBalanceCr, new { htmlAttributes = new { @class = "form-control input-sm", tabindex = 1, autofocus = "autofocus" } })
                </div>*@
                <div class="form-group col-md-6">
                    @Html.LabelFor(model => model.IbanNo, htmlAttributes: new { @class = "control-label" })
                    @Html.EditorFor(model => model.IbanNo, new { htmlAttributes = new { @class = "form-control input-sm", autofocus = "autofocus" } })
                </div>
                <div class="form-group col-md-6">
                    @Html.LabelFor(model => model.BranchName, htmlAttributes: new { @class = "control-label" })
                    @Html.EditorFor(model => model.BranchName, new { htmlAttributes = new { @class = "form-control input-sm", autofocus = "autofocus" } })
                </div>
                <div class="form-group col-md-6">
                    @Html.Label("Swift", null, new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.Swift, new { htmlAttributes = new { @class = "form-control input-sm", autofocus = "autofocus" } })
                </div>
                <div class="form-group col-md-6">
                    @Html.LabelFor(model => model.OpnBalance, htmlAttributes: new { @class = "control-label " })
                    <div class="input-group">
                        @Html.EditorFor(model => model.OpnBalance, new { htmlAttributes = new { @class = "form-control" } })
                        <div class="input-group-addon no-padding dcwidth">
                            @Html.EnumDropDownListFor(model => model.DC, new { @class = "form-control" })
                        </div>
                    </div>
                </div>

                <div class="form-group col-md-6">
                    @Html.Label("Note", null, new { @class = "control-label" })
                    @Html.TextAreaFor(model => model.Note, new { @class = "form-control input-sm", autofocus = "autofocus", Rows = "5" })
                </div>

                @if (@ViewBag.BranchCheck == 0)
                {                    
                        <div class="form-group col-sm-6">
                            @Html.Label("Branch", null, new { @class = "control-label" })
                            @Html.DropDownListFor(m => m.Branch, (SelectList)ViewBag.SetBranch, new { id = "ddlBranch", @class = "form-control select2" })
                        </div>                    
                }
                <div class="form-group col-md-6">
                    @Html.Label("Status", null, new { @class = "control-label" })
                    @Html.EnumDropDownListFor(model => model.Status, new { @class = "form-control" })
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" value="Update" class="btn btn-info col-sm-offset-4"  />
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>



