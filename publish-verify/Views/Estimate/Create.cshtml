        function GetCustomer() {
            var CustomerId = $('#ddlCustomer').val();
            if (CustomerId != null) {
                $.ajax({
                    url: '/Customer/GetCustomerEmailById',
                    type: "GET",
                    dataType: "JSON",
                    data: { CustID: CustomerId },
                    success: function (result) {
                        $("#CustomerEmail").val(result.EmailId);
                    }
                });
            }
        }
        function Getlead() {
            var CustomerId = $('#ddlCustomer').val();
            if (CustomerId != null) {
                $.ajax({
                    url: '/Customer/getlead',
                    type: "GET",
                    dataType: "JSON",
                    data: { CustID: CustomerId },
                    success: function (result) {
                        $("#ddlcustomer").val(result.customerid);
                    }
                });
            }
        }
        $('body').on('change', '#ddlApprovedBy', function (e) {
            $("#SelApprovedBy").val($(this).val());
        });

        $('#Estimateform').on('submit', function (e) {
            e.preventDefault();

            if ($("#Estimateform").valid() ) {
                var url = $('#Estimateform')[0].action;
                var formData = new FormData(this);
                var fnval = $('input[type="submit"], button[type="submit"]', this).filter(':focus').attr('id');
                if (fnval == "print" && $("#ddlApprovedBy").val() != "") {
                    alert("Print available after approval");
                    return true;
                }
                if (fnval == "save" || fnval == "print") {
                    formData.append('fnval', fnval);
                    $.ajax({
                        async: true,
                        cache: false,
                        dataType: "json",
                        type: "POST",
                        processData: false,
                        contentType: false,
                        url: url,
                        data: formData,//$('#createlandlordForm').serialize(), //formData,//JSON.stringify(parameters),
                        beforeSend: function () {
                            $("button").prop('disabled', true); // disable button
                        },
                        success: function (e) {
                            if (e.status) {
                                $('.ajax_response', res_success).text(e.message);
                                $('.AlertDiv').prepend(res_success);
                                if (fnval == "save") {
                                    window.location.href = '@Url.Action("Create", "Estimate")';
                                }
                                if (fnval == "print") {
                                    printestimate(e); window.location.href = '@Url.Action("Create", "Estimate")';
                                }

                            }
                            else {
                                $('.ajax_response', res_danger).text(e.message);
                                $('.AlertDiv').prepend(res_danger);
                                $("button").prop('disabled', false); // enable button
                            }
                        }
                    });


                }

            }

        });


        function printestimate(e) {
            var dat = convertToDate(e.data.EsttDate);


            $("#lblinvdate").text(dat);

            $("#lblbilno").text(e.data.BillNo);

            $("#lblqtn").text(e.data.quoteref);
            $("#lbljoborderno").text(e.data.joborderno);
            $("#lblsite").text(e.data.siteno);

            $("#lblbuilding").text(e.data.buildingno);
            $("#lblflat").text(e.data.flatno);

            $("#lbltask").text(e.data.TaskName);
            $("#grandtotal").text(e.data.QuotGrandTotal);

            

            var adcount = 1;
            $.each(e.estitems, function (i, item) {
                var dat2 = convertToDate(item.invdate);
                var str = '<tr>';
                str += '<td>' + dat2 + '</td>';
                str += '<td>' + item.invno + '</td>';
                str += '<td>' + item.description + '</td>';
                str += '<td>' + item.amount + '</td>';
                str += '</tr>';
                adcount++;
                $('#addfield').append(str);
            });
            var amttable = bindSundry(e);
            var dcount = 1;
            $('#billsundrybottom').append(amttable);
            








            var originalpage = document.body.innerHTML;
            var printContent = $('#printit').html();
            $('title').html("Estimate - " );
            $('body').html(printContent);
            window.print();
        }
















