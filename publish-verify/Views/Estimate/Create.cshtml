@model QuickSoft.ViewModel.EstimateViewModel
@{
    ViewBag.Title = "Create";
    ViewBag.SubTitle = "Estimate";
    ViewBag.Active = "Transactions";
    var TimeOut = @ViewBag.TMOut;
    string IRateCheck = "inactive";

}
@if (User.IsInRole("Dev") || User.IsInRole("ReadOnly Item Rate"))
{
    IRateCheck = "active";
}
@using (Html.BeginForm("CreateEstimate", "Estimate", FormMethod.Post, new { id = "Estimateform", role = "form", enctype = "multipart/form-data" }))
{
<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">Create Estimate</h3>
        <div class="pull-right">
            @if (@ViewBag.LastEntry != 0)
            {
                if (User.IsInRole("Dev") || User.IsInRole("Edit Quotation"))
                {
                    <a class="btn bg-black no-border" href="/Estimate/Edit/@ViewBag.LastEntry">
                        <i class="fa fa-step-backward"></i>
                    </a>
                }
            }
            @if (User.IsInRole("Dev") || User.IsInRole("Quotation List"))
            {
                <a class="btn btn-success no-border" href="/Estimate/Index">
                    <i class="fa fa-fw fa-history"></i> List
                </a>
            }
        </div>
    </div>
    @Html.AntiForgeryToken()
    @Html.ValidationSummary("", new { @class = "alert alert-danger" })
    @Html.HiddenFor(model => model.EstimateId)

    <input type="hidden" id="VoucherType" value="Quotation" />
    <div class="box-body">
        <input type="hidden" id="ROnlyRate" value="@IRateCheck" />
        <input type="hidden" id="SelApprovedBy" />
        <div class="row">

            <div class="col-sm-1 form-group ">
                @Html.Label("Estimate No", null, new { @class = "control-label" }) *
                @Html.EditorFor(model => model.BillNo, new { htmlAttributes = new { @class = "form-control", @required = "required" } })
                @Html.HiddenFor(model => model.QuotNo)
            </div>

            <div class="col-sm-2 form-group">
                @Html.Label("Date", null, new { @class = "control-label" }) *
                <div class="input-group date">
                    <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                    @Html.TextBoxFor(m => m.EsttDate, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @required = "required" })
                </div>
            </div>



            <div class="col-sm-2 form-group">
                @Html.Label("Customer Name", null, new { @class = "control-label" }) *
                @if (User.IsInRole("Dev") || User.IsInRole("Create Customer"))
                {
                    <div class="input-group input-group-sm">
                        @Html.DropDownListFor(m => m.Customer, (SelectList)ViewBag.Custer, "", new { id = "ddlCustomer", @class = "form-control select2", @required = "required", @onchange = "GetCustomer()" })
                        <span class="input-group-btn">
                            <button type="button" href="/Customer/AddCustomer" class="modal-create btn btn-success btn-flat"><i class="fa fa-1x fa-plus-circle"></i></button>
                        </span>
                    </div>
                }
                else
                {
                    @Html.DropDownListFor(m => m.Customer, (SelectList)ViewBag.Custer, new { id = "ddlCustomer", @class = "form-control select2", @required = "required", @onchange = "GetCustomer()" })
                }
            </div>

            <div class="form-group col-sm-2">
                @Html.Label("Project", null, new { @class = "control-label" })
                @if (User.IsInRole("Dev") || User.IsInRole("Create Project"))
                {
                    <div class="input-group input-group-sm">
                        @Html.DropDownListFor(m => m.Project, (SelectList)ViewBag.Proj, new { id = "ddlProject", @class = "form-control select2" })
                        <span class="input-group-btn">
                            <a href="/Project/AddProject" class="modal-project btn btn-success btn-flat" title="Add Project"><i class="fa fa-1x fa-plus-circle"></i></a>
                        </span>
                    </div>
                }
                else
                {
                    @Html.DropDownListFor(m => m.Project, (SelectList)ViewBag.Proj, new { id = "ddlProject", @class = "form-control select2" })
                }
            </div>
            <div class="form-group col-sm-2">
                @Html.LabelFor(m => m.ProTask, new { @class = "control-label" })
                @Html.DropDownListFor(m => m.ProTask, (SelectList)ViewBag.getProTask, "", new { id = "ddlProTask", @class = "form-control select2" })
            </div>
           
                <div class="form-group col-sm-2">
                    @Html.Label("Approved By", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlApprovedBy", (SelectList)ViewBag.ApproveBy, "", new { @class = "form-control select2", @name = "ddlApprovedBy[]", @multiple = "multiple" })
                </div>
          
        </div>

        <div class="row">
            <div class="col-sm-1 form-group ">
                @Html.Label("Job order no", null, new { @class = "control-label" }) *
                @Html.EditorFor(model => model.joborderno, new { htmlAttributes = new { @class = "form-control" } })

            </div>
            <div class="col-sm-1 form-group ">
                @Html.Label("Building No", null, new { @class = "control-label" }) *
                @Html.EditorFor(model => model.buildingno, new { htmlAttributes = new { @class = "form-control" } })

            </div>
            <div class="col-sm-1 form-group ">
                @Html.Label("Site No", null, new { @class = "control-label" }) *
                @Html.EditorFor(model => model.siteno, new { htmlAttributes = new { @class = "form-control" } })

            </div>
            <div class="col-sm-1 form-group ">
                @Html.Label("Flat No", null, new { @class = "control-label" }) *
                @Html.EditorFor(model => model.flatno, new { htmlAttributes = new { @class = "form-control" } })

            </div>
            <div class="col-sm-1 form-group ">
                @Html.Label("Quot Ref No", null, new { @class = "control-label" }) *
                @Html.EditorFor(model => model.quoteref, new { htmlAttributes = new { @class = "form-control" } })

            </div>
        </div>
        <div>
            <div class="table-responsive">
                <table class="table table-bordered table-hover" id="normalinvoice">
                    <thead>
                        <tr>
                            <th class="text-center">S/N</th>
                            <th class="text-center item-lists">Date <i class="text-danger">*</i></th>
                            <th class="text-center item-lists">Invoice No <i class="text-danger">*</i></th>
                            <th class="text-center">Description</th>
                            <th class="text-center">Amount <i class="text-danger">*</i></th>

                        </tr>
                    </thead>
                    <tbody id="addinvoiceItem"></tbody>
                    <tfoot>
                        <tr>
                            <td colspan="4">
                                Total
                            </td>
                            <td class="text-right">
                                <input type="text" id="total" readonly class="form-control" style="text-align: right;" name="QuotGrandTotals" />

                            </td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>

        </div>
    </div>

 

    <div class="form-group">
        <div class="row">
        
            <div class="row">
            <div class="form-group col-md-4 no-padding">
                @Html.TextAreaFor(model => model.Remarks, new { @class = "form-control", @placeholder = "Remarks", @rows = 2 })
                @Html.Label("Grand Total :", null, new { @class = "control-label" })
                @Html.EditorFor(model => model.QuotGrandTotal, new { htmlAttributes = new { @id = "GrandTotal", @class = "form-control text-right", @value = "0.00", @readonly = "readonly" } })
                <input type="hidden" value="" class="ItemCount" name="ItemCount" id="ItemCount">

            </div>
            <div class="col-md-6">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="billsundry">
                        <thead>
                            <tr>
                                <th class="text-center">S/N</th>
                                <th class="text-center">Bill Sundry</th>
                                <th class="text-center">Value</th>
                                <th class="text-center">Type</th>
                                <th class="text-center">Amount</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody id="addbillsundry"></tbody>
                    </table>
                </div>
            </div>
                </div>
        </div>
        
       
        <div class="form-group pull-right">
            <button type="submit" id="save" class="btn btn-success">
                <span class="glyphicon glyphicon-floppy-disk"></span> Save
            </button>

            <button type="submit" id="print" class="btn btn-success">
                <span class="glyphicon glyphicon-print"></span> Save And Print
            </button>


            <button type="button" class="btn btn-warning" onclick="@("window.location.href='/Estimate/Index'");">Cancel</button>

        </div>
        <br />

        <br />
    </div>


</div>



}

