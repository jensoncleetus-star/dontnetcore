@{
    ViewBag.Title = "Search Trial Balance";
    ViewBag.SubTitle = "Account Wise Trial Balance Report";
    ViewBag.Active = "Accounts";
}
<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">Search Account Wise Trial Balance</h3>
    </div>
    <div class="box-body">
        @using (Html.BeginForm("GetTrialBalanceAC2", "BalanceSheet", FormMethod.Post, new { id = "fileupload", @class = "form-horizontal" }))
        {
            <div class="form-group" >
                <label class="control-label col-md-4">From Date</label>
                <div class="col-sm-4">
                    <div class="input-group date">
                        @Html.TextBox("fromdate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @required = "required", @autocomplete = "off" })
                        <div class="input-group-addon">
                            <i class="fa fa-calendar"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="form-group">
                <label class="control-label col-md-4">To Date</label>
                <div class="col-sm-4">
                    <div class="input-group date">
                        @Html.TextBox("todate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @required = "required", @autocomplete = "off" })
                        <div class="input-group-addon">
                            <i class="fa fa-calendar"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="box-footer col-md-12">
                <button type="submit" class="btn btn-info col-sm-offset-5" id="btn">Submit</button>
                <button class="btn btn-default" type="Reset" id="btnreset">Reset</button>
            </div>
        }
    </div>
</div>
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
}
@section Scripts {
    @Scripts.Render("~/js/bootstrap-datepicker")
    <script type="text/javascript">
        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        })
        $(document).ready(function () {
            //for set default date
            $('#todate').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });
            $('#fromdate').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });


            var date = new Date();
            var today = new Date(date.getFullYear(), date.getMonth(), date.getDate());
            var priordate = new Date(new Date().setDate(today.getDate() - 30));

            var date = new Date();
            var today = new Date(new Date().getFullYear(), 11, 31);
            var priordate = new Date(new Date().getFullYear() , 0, 1);
            $('#todate').datepicker('setDate', today);
            $('#fromdate').datepicker('setDate', priordate);

        });
    </script>
}

