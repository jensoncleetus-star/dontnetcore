
@model QuickSoft.ViewModel.HomeViewModel


@Html.Partial("../Common/_ModalCreate")
@Html.Partial("../Common/_ModalEdit")
@Html.Partial("../Common/_ModalDelete")
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/bootstrap-fileinput")
    @Styles.Render("~/css/bootstrap-fileinput-rtl")
}
@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/bootstrap-fileinput")
    @Scripts.Render("~/js/bootstrap-sortable")
    @Scripts.Render("~/js/bootstrap-purify")
}
<style>
    .ribbon4 {
        width: auto;
        position: absolute;
        left: -10px !important;
        top: -5px;
        padding: 5px 20px 5px 10px;
        background-image: linear-gradient(to bottom,#55a8e7,#0d83dd);
        box-shadow: -1px 2px 3px rgba(0,0,0,.3);
        color: white;
        border-radius: 0 4px 4px 0;
        text-transform: uppercase;
    }

        .ribbon4:before, .ribbon4:after {
            content: "";
            position: absolute;
        }

        .ribbon4:before {
            width: 10px;
            height: 117%;
            top: 0;
            left: -6.5px;
            padding: 0 0 7px;
            background-image: linear-gradient(to bottom,#55a8e7,#0d83dd);
            border-radius: 6px 0 0 5px;
        }

        .ribbon4:after {
            width: 10px;
            height: 8px;
            bottom: -8px;
            left: -5px;
            background: #095b9a;
            border-radius: 5px 0 0 5px;
        }

    .sh-bg1 {
        background-image: linear-gradient(to bottom right,rgba(138, 196, 238), rgb(0 148 255));
    }

    .sh-bg2 {
        background-image: linear-gradient(to bottom right,rgba(132, 243, 197), rgba(8, 176, 106));
    }

    .sh-bg3 {
        background-image: linear-gradient(to bottom right,rgba(238, 132, 187), rgba(164, 16, 138));
    }

    .sh-bg4 {
        background-image: linear-gradient(to bottom right,rgba(190, 217, 181),rgba(63, 113, 47));
    }

    .sh-bg5 {
        background-color: white;
        box-shadow: 0 8px 16px 0 rgba(0,0,0,0.2);
        border-radius: 5px;
    }

    .card-box {
        position: relative;
        color: #fff;
        padding: 20px 10px 40px;
        margin: 10px 0px;
        border-radius: 5px;
    }

        .card-box:hover {
            text-decoration: none;
            box-shadow: 5px 8px 16px 5px rgba(0,0,0,0.3);
            transform: scale(1.01);
        }

            .card-box:hover .icon i {
                font-size: 100px;
                transition: 1s;
                -webkit-transition: 1s;
            }

        .card-box .inner {
            padding: 5px 10px 0 10px;
        }

        .card-box h3 {
            font-size: 27px;
            font-weight: bold;
            margin: 0 0 8px 0;
            white-space: nowrap;
            padding: 0;
            text-align: left;
            text-shadow: 2px 2px 4px #000000;
        }

        .card-box p {
            font-size: 15px;
        }

        .card-box .icon {
            position: absolute;
            top: auto;
            bottom: 5px;
            right: 10px;
            z-index: 0;
            font-size: 72px;
            color: rgba(0, 0, 0, 0.15);
        }

        .card-box .card-box-footer {
            position: absolute;
            left: 0px;
            bottom: 0px;
            text-align: center;
            padding: 3px 0;
            color: rgba(255, 255, 255, 0.8);
            background: rgba(0, 0, 0, 0.1);
            width: 100%;
            text-decoration: none;
            border-radius: 0px 0px 5px 5px;
        }

        .card-box:hover .card-box-footer {
            background: rgba(0, 0, 0, 0.3);
        }

        .card-box .sh-title-align {
            background-image: linear-gradient(to bottom right,rgba(184, 220, 245, 1), rgb(0 148 255));
            padding: 1px 0px 1px 10px;
            margin-top: -10px !important;
            border-radius: 5px 5px 0px 0px;
        }

        .card-box h4 {
            text-shadow: 2px 2px 4px #000000;
        }

    .sh-row-design {
        background-color: white;
    }


    @@media only screen and (min-width: 800px) {
    }

    @@media only screen and (min-width: 1250px) {
    }

    @@media only screen and (max-width: 400px) {
    }
</style>
<div class="row sh-row-design">
    <div class="box-header with-border">
        <div class="row">
            <div class="col-md-9 col-xs-12">
                <div class="ribbon">
                    <div class="ribbon4"><h3 class="box-title">DASHBOARD</h3></div>
                </div>
            </div>
            <div class="col-md-3 col-xs-12">
                <div class="pull-right">

                    @*<i class="ace-icon fa fa-hand-o-right icon-animated-hand-pointer blue"></i>*@
                    <a href="/ParticularParty/Index" class="btn btn-info" target="_blank"><i class="glyphicon glyphicon-plus"></i> Exclude Parties</a>
                </div>
            </div>
        </div>


    </div>
    <div class="col-md-6">
        @if (User.IsInRole("Dev") || User.IsInRole("Sales Entry List") || User.IsInRole("Sales Summary"))
        {
            <div class="col-md-4 col-sm-6">
                <div class="card-box sh-bg2">
                    <div class="inner">
                        <span>AED</span><h3>@Html.DisplayFor(m => m.todaySales) </h3>
                        <p>Today Sales</p>
                    </div>
                    <div class="icon">
                        <i class="fa fa-shopping-bag" aria-hidden="true"></i>
                    </div>
                    <a href="@Url.Action("DailySummary", "SalesReport")" class="card-box-footer">View more <i class="fa fa-arrow-circle-right"></i></a>
                </div>
            </div>
        }
        @if (User.IsInRole("Dev") || User.IsInRole("Sales Entry List") || User.IsInRole("Sales Summary"))
        {
            <div class="col-md-4 col-sm-6">
                <div class="card-box sh-bg3">
                    <div class="inner">
                        <span>AED</span><h3>@Html.DisplayFor(m => m.ThisMonthSales) </h3>
                        <p>This Month Sales</p>
                    </div>
                    <div class="icon">
                        <i class="fa fa-shopping-cart" aria-hidden="true"></i>
                    </div>
                    <a href="@Url.Action("MonthlySale", "SalesReport")" class="card-box-footer">View more <i class="fa fa-arrow-circle-right"></i></a>
                </div>
            </div>
        }
        @if (User.IsInRole("Dev") || User.IsInRole("Sales Entry List") || User.IsInRole("Sales Summary"))
        {
            <div class="col-md-4 col-sm-6">
                <div class="card-box sh-bg4">
                    <div class="inner">
                        <span>AED</span><h3>@Html.DisplayFor(m => m.SalesCredit) </h3>
                        <p>This Year Sales</p>
                    </div>
                    <div class="icon">
                        <i class="fa fa-money" aria-hidden="true"></i>
                    </div>
                    <a href="@Url.Action("Index", "CreditSale")" class="card-box-footer">View All Sales <i class="fa fa-arrow-circle-right"></i></a>
                </div>
            </div>
        }
        @if (User.IsInRole("Dev") || User.IsInRole("Sales Month Wise") || User.IsInRole("Sales Summary"))
        {
            <div class="col-md-12">
                <div class="card-box sh-bg5">
                    <div class="sh-title-align">
                        <h4>Sales Summary</h4>
                    </div>

                    <canvas id="myChart" style="width:100%;"></canvas>

                </div>
            </div>
        }
    </div>
    <div class="col-md-6">
        <div class="col-md-4 col-sm-6">
            <div class="card-box sh-bg4">
                <div class="inner">
                    <span>AED</span><h3>@Html.DisplayFor(m => m.dailySalesrtn) </h3>
                    <p>Daily Sales Return</p>
                </div>
                <div class="icon">
                    <i class="fa fa-university" aria-hidden="true"></i>
                </div>
                <a href="@Url.Action("Index", "CreditSaleReturn")" class="card-box-footer">View More <i class="fa fa-arrow-circle-right"></i></a>
            </div>
        </div>
        <div class="col-md-4 col-sm-6">
            <div class="card-box sh-bg2">
                <div class="inner">
                    <span>AED</span><h3>@Html.DisplayFor(m => m.ThismnthSalesRtn) </h3>
                    <p>This Month Sales Return</p>
                </div>
                <div class="icon">
                    <i class="fa fa-free-code-camp" aria-hidden="true"></i>
                </div>
                <a href="@Url.Action("Index", "CreditSaleReturn")" class="card-box-footer">View More <i class="fa fa-arrow-circle-right"></i></a>
            </div>
        </div>
        <div class="col-md-4 col-sm-6">
            <div class="card-box sh-bg4">
                <div class="inner">
                    <span>AED</span><h3>@Html.DisplayFor(m => m.ThisYearSalesRtn) </h3>
                    <p>This Year Sales Return</p>
                </div>
                <div class="icon">
                    <i class="fa fa-grav" aria-hidden="true"></i>
                </div>
                <a href="@Url.Action("Index", "CreditSaleReturn")" class="card-box-footer">View More <i class="fa fa-arrow-circle-right"></i></a>
            </div>
        </div>
        @if (User.IsInRole("Dev") || User.IsInRole("Sales Entry List") || User.IsInRole("POS List"))
        {
            <div class="col-md-12">
                <div class="card-box sh-bg5">
                    <div class="sh-title-align">
                        <h4>Sales Return Summary</h4>
                    </div>

                    <canvas id="myChart2" style="width:100%;"></canvas>
                </div>

            </div>
        }
    </div>






</div>
<script>
    $('div').on('click', '.modal-create', function (e) {
        e.preventDefault();
        var url = $(this).attr('href');
        modalshow(url, '#modal-create');
    });
</script>
<script src="~/Content/js/BarGraph.js"></script>
<script>
    var xValues = ["@ViewBag.mnth2", "@ViewBag.mnth3", "@ViewBag.mnth4", "@ViewBag.mnth5", "@ViewBag.mnth6", "@ViewBag.mnth7"];
    var yValues = [@Html.DisplayFor(m => m.LastFiveMonthSales), @Html.DisplayFor(m => m.LastFourMonthSales), @Html.DisplayFor(m => m.LastThreeMonthSales), @Html.DisplayFor(m => m.LastTwoMonthSales),@Html.DisplayFor(m => m.LastMonthSales),@Html.DisplayFor(m => m.ThisMonthSales),0];
    var barColors = ["red", "green", "blue", "orange", "brown","yellow"];

    new Chart("myChart", {
        type: "bar",
        data: {
            labels: xValues,
            datasets: [{
                backgroundColor: barColors,
                data: yValues
            }]
        },
        options: {
            legend: { display: false },
            title: {
                display: true,
                text: "Last Six Months Sales"
            }
        }
    });
</script>
<script>
    var xValues2 = ["@ViewBag.mnth2", "@ViewBag.mnth3", "@ViewBag.mnth4", "@ViewBag.mnth5", "@ViewBag.mnth6", "@ViewBag.mnth7"];
    var yValues2 = [@Html.DisplayFor(m => m.LastFiveMonthSalesrtn), @Html.DisplayFor(m => m.LastFourMonthSalesrtn), @Html.DisplayFor(m => m.LastThreeMonthSalesrtn), @Html.DisplayFor(m => m.LastTwoMonthSalesrtn),@Html.DisplayFor(m => m.LastMonthSalesrtn),@Html.DisplayFor(m => m.ThismnthSalesRtn),0];
    var barColors2 = ["red", "green", "blue", "orange", "brown", "yellow"];

    new Chart("myChart2", {
        type: "bar",
        data: {
            labels: xValues2,
            datasets: [{
                backgroundColor: barColors2,
                data: yValues2
            }]
        },
        options: {
            legend: { display: false },
            title: {
                display: true,
                text: "Last Six Months Sales Return"
            }
        }
    });
</script>

