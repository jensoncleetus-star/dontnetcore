@{

    ViewBag.Title = "BRS List";
    ViewBag.SubTitle = "BRS";
    ViewBag.Active = "Master";
    var sl = 0;
    string balance = "";
    var colspan = 10;
    string actData = "";
    string delchk = "";
    string Withdrawal = "";
    string Deposit = "";
    string BankAmount = "";
}


<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">Bank Reconciliation</h3>
    </div>
    <div class="box-body">
        @using (Html.BeginForm("GetBRS", "BRS", FormMethod.Post, new { id = "fileupload", @class = "form-horizontal" }))
        {
            <div class="form-group">
                <label class="control-label col-md-4">Select Bank Account</label>
                <div class="col-sm-4">
                    @Html.DropDownList("Account", (SelectList)ViewBag.AccName, "Select Bank Account", new { id = "ddlbank", @class = "form-control select2", @required = "required", data_msg_required = "The Bank Account field is required" })
                </div>
            </div>
            <div class="form-group">
                <label class="control-label col-md-4">Type of Entry</label>
                <div class="col-sm-4">
                    @Html.DropDownList("ShowType", (SelectList)ViewBag.ItemType, new { @class = "form-control select2", @onchange = "Itemtype();" })
                </div>
            </div>
            <div class="form-group">
                <label class="control-label col-md-4">From</label>
                <div class="col-sm-4">
                    <div class="input-group date">
                        @Html.TextBox("FromDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @required = "required", @autocomplete = "off" })
                        <div class="input-group-addon">
                            <i class="fa fa-calendar"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="form-group">
                <label class="control-label col-md-4">To</label>
                <div class="col-sm-4">
                    <div class="input-group date">
                        @Html.TextBox("ToDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @required = "required", @autocomplete = "off" })
                        <div class="input-group-addon">
                            <i class="fa fa-calendar"></i>
                        </div>
                    </div>
                </div>
            </div>
                    <div class="box-footer col-md-12">
                        <button type="submit" class="btn btn-info col-sm-offset-5" id="btn">Submit</button>
                        <button type="button" class="btn btn-default" onclick="@("window.location.href='/Home/Index'");">Cancel</button>
                        <input type="hidden" value="@ViewBag.StartDate" class="Start" name="Start" id="Start">
                        <input type="hidden" value="@ViewBag.EndDate" class="End" name="End" id="End">
                    </div>
        }
    </div>
</div>

@Html.Partial("../Common/_ModalEdit")
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/sweetalert2")
}
@section Scripts {
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/sweetalert2")
    <script type="text/javascript">
        var minDate = $("#Start").val();
        var maxDate = $("#End").val();
        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
