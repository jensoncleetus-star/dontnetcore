        $(document).ready(function () {
            var minDate = new Date($("#Start").val());
            var maxDate = new Date($("#End").val()); //alert(maxDate+' d '+minDate);
            $("#ClearDate").datepicker();
            $("#ddlbank").select2();
            $('#Tabledata').hide();
            $("#ShowType").select2();
            $('#ToDate').datepicker({
                format: 'dd-mm-yyyy',
