                                @{
                                    //if (User.IsInRole("Dev") || User.IsInRole("View Receipt"))
                                    {
                                        actData += "<a class=\"details\" href=\"/PaymentApproval/Details/'+ data.PaymentId +'\" title=\"View Payment Entry\"><i class=\"fa fa-lg fa-search-plus\"></i></a> ";
                                    }

                                    if (User.IsInRole("Dev") || User.IsInRole("Edit Payment"))
                                    {
                                        actData += "<a href = \"/Payment/Edit/' + data.PaymentId + '\" title=\"Edit Receipt\"  target=\"_blank\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
