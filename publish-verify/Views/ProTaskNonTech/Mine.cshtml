@model QuickSoft.ViewModel.ProTaskViewModel
@{
    ViewBag.Title = "My Tasks";
    ViewBag.SubTitle = "My Tasks";
    ViewBag.Active = "Master";
    string actData = "";
    string actDatas = "";
    string actStatus = "";
    string actImg = "";
    string chk = "";
    string nameclass = "";
    var rowCount1 = 18;
    var rowCount2 = 19;

    var Ref1 = 0;
    var Ref2 = 0;
    var Ref3 = 0;
    var Ref4 = 0;
    var Ref5 = 0;
    if (Model.FieldMap != null && Model.FieldMap.Count > 0)
    {
        for (int i = 0; i < Model.FieldMap.Count; i++)
        {
            if (@Model.FieldMap[i].Field == "Ref1")
            {
                Ref1 = 1;
                rowCount1 = rowCount1 + 1;
                rowCount2 = rowCount2 + 1;
            }
            if (@Model.FieldMap[i].Field == "Ref2")
            {
                Ref2 = 1;
                rowCount1 = rowCount1 + 1;
                rowCount2 = rowCount2 + 1;
            }
            if (@Model.FieldMap[i].Field == "Ref3")
            {
                Ref3 = 1;
                rowCount1 = rowCount1 + 1;
                rowCount2 = rowCount2 + 1;
            }
            if (@Model.FieldMap[i].Field == "Ref4")
            {
                Ref4 = 1;
                rowCount1 = rowCount1 + 1;
                rowCount2 = rowCount2 + 1;
            }
            if (@Model.FieldMap[i].Field == "Ref5")
            {
                Ref5 = 1;
                rowCount1 = rowCount1 + 1;
                rowCount2 = rowCount2 + 1;
            }
        }
    }
    string refreshBTn = "{text: 'Refresh', className: 'btn-primary', action: function(e, dt, node, config) {" +
               " $('#UserTable').DataTable().ajax.reload();" +
                " }},";
}
<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">My Tasks</h3>
        <div class="pull-right">
            @if (User.IsInRole("Dev") || User.IsInRole("Create ProTask"))
            {
                <a class="btn btn-info no-border" href="/ProTask/Create/MyTask">
                    <i class="glyphicon glyphicon-plus"></i> Create Task
                </a>
            }
        </div>
    </div>
    <div class="box-body search-box">
        <a class="btn btn-primary" id="srch">
            <i class="glyphicon glyphicon-search"></i> Advanced Search
        </a>
        <div class="search-body col-md-12" id="advsearch">
            <form id="search-form">
                <div class="row">
                    <input type="hidden" id="protaskId" />
                    <div class="form-group col-md-2">
                        @Html.Label("Task Name", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlTaskName", (SelectList)ViewBag.TaskName, new { @class = "form-control input-sm select2" })
                    </div>
                    <div class="form-group col-md-2">
                        @Html.Label("Task Status", null, new { @class = "control-label" })
                        @Html.DropDownList("TaskStatus", (SelectList)ViewBag.TStat, new { @class = "form-control input-sm select2" })
                    </div>
                    <div class="form-group col-md-2">
                        @Html.Label("Mobile", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlmobile", (SelectList)ViewBag.Mobile, new { @class = "form-control input-sm select2" })
                    </div>
                    <div class="form-group col-md-2 select2-box">
                        @Html.Label("Location", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlLocation", (SelectList)ViewBag.Locat, new { @class = "form-control input-sm select2" })
                    </div>
                    <div class="form-group col-md-2">
                        @Html.Label("From Date", null, new { @class = "control-label" })
                        <div class="input-group date">
                            @Html.TextBox("From", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                            <div class="input-group-addon">
                                <i class="fa fa-calendar"></i>
                            </div>
                        </div>
                    </div>
                    <div class="form-group col-md-2">
                        @Html.Label("To Date", null, new { @class = "control-label" })
                        <div class="input-group date">
                            @Html.TextBox("To", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                            <div class="input-group-addon">
                                <i class="fa fa-calendar"></i>
                            </div>
                        </div>
                    </div>
                    <div class="form-group col-md-2">
                        @Html.Label("Task Type", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlTaskType", (SelectList)ViewBag.TaskType, new { @class = "form-control input-sm select2" })
                    </div>
                    <div class="form-group col-md-2" id="creditsale">
                        @Html.Label("Lead/Pipeline/Customer", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlCustomer", (SelectList)ViewBag.Customer, new { @class = "form-control input-sm select2" })
                    </div>
                    <div class="form-group col-md-2">
                        @Html.Label("Projects", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlProject", (SelectList)ViewBag.Projects, new { @class = "form-control input-sm select2" })
                    </div>
                    <div class="form-group col-md-2">
                        @Html.Label("Created By", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlCreatedBy", (SelectList)ViewBag.User, new { @class = "form-control input-sm select2" })
                    </div>

                    <div class="form-group col-md-2">
                        @Html.Label("Priority", null, new { @class = "control-label" })
                        @Html.DropDownList("Priority", new SelectList(new List<SelectListItem>
                    {
                     new SelectListItem() {Text = "All", Value="0"},
                        new SelectListItem() {Text = "Low", Value="1"},
                        new SelectListItem() {Text = "Medium", Value="2"},
                        new SelectListItem() {Text = "High", Value="3"}
                    }, "Value", "Text"), new { @class = "form-control input-sm", @name = "Priority" })
                    </div>
                    <div class="form-group col-md-2" id="execreditsale">
                        @Html.Label("Sales Person", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlEmployee", (SelectList)ViewBag.SalesExecutive, new { @class = "form-control input-sm select2" })
                    </div>
                    <div class="form-group col-md-2">
                        @Html.Label("Reminder Date", null, new { @class = "control-label" })
                        <div class="input-group date">
                            @Html.TextBox("ReminderDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                            <div class="input-group-addon">
                                <i class="fa fa-calendar"></i>
                            </div>
                        </div>
                    </div>
                    <div class="form-group col-md-2">
                        @Html.Label("Reminder Status", null, new { @class = "control-label" })
                        @Html.DropDownList("RemStatus", new SelectList(new List<SelectListItem>
                        {
                        new SelectListItem() {Text = "All", Value="0"},
                        new SelectListItem() {Text = "Upcoming", Value="Upcoming"},
                        new SelectListItem() {Text = "Expired", Value="Expired"},
                    }, "Value", "Text"), new { @class = "form-control input-sm", @name = "RemStatus" })
                    </div>
                    <div class="form-group col-md-2">
                        @Html.Label("Last Updated", null, new { @class = "control-label" })
                        @Html.DropDownList("LastUpdated", new SelectList(new List<SelectListItem>
                    {
                       new SelectListItem(){ Text = "All", Value="0"},
                        new SelectListItem() {Text = "1 Day Ago", Value="1"},
                        new SelectListItem() {Text = "7 Days Ago", Value="7"},
                        new SelectListItem() {Text = "1 Month Ago", Value="30"},
                        new SelectListItem() {Text = "3 Months Ago", Value="90"},
                        new SelectListItem() {Text = "6 Months Ago", Value="180"},
                        new SelectListItem() {Text = "1 Year Ago", Value="360"},
                    }, "Value", "Text"), new { @class = "form-control input-sm", @name = "LastUpdated", tabindex = 7 })
                    </div>
                    <div class="form-group col-md-2 select2-box">
                        @Html.Label("Assigned To", null, new { @class = "control-label" })
                        @Html.DropDownListFor(m => m.AssignedMembers, (SelectList)ViewBag.Employee, new { @id = "AssignedUsers", @class = "form-control select2 porder" })
                    </div>
                </div>

                <div class="row">
                    @if (Model.FieldMap.Count > 0)
                    {
                        for (int i = 0; i < Model.FieldMap.Count; i++)
                        {
                            <div class="form-group col-md-2">
                                <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName</label>
                                <input class="form-control" id="@Model.FieldMap[i].Field" name="@Model.FieldMap[i].Field" type="text" value="">
                            </div>
                        }
                    }
                </div>

                <div class="row">
                    <div class="col-md-12">
                        <input type="submit" class="btn btn-submit col-sm-offset-5" value="Submit" />
                        <input type="button" class="btn btn-close" value="Close" />
                    </div>
                </div>
            </form>
        </div>
    </div>
    <div class="box-body">
        <table class="table table-bordered table-hover table-grid" id="UserTable">
            <thead>
                <tr class="bg-gray">
                    <td data-priority="1" class="test">Sl No</td>
                    <td data-priority="1">Task Name</td>
                    <td data-priority="2">Task Type</td>
                    <td data-priority="4">Customer</td>
                    <td data-priority="4">Mobile</td>
                    <td data-priority="4">Location</td>
                    <td data-priority="5">Start Time</td>
                    <td data-priority="6">Sales Person</td>
                    <td data-priority="2">Task Status</td>
                    <td data-priority="6">Priority</td>
                    <td data-priority="1">Last Updated</td>
                    <td data-priority="7">Task Details</td>
                    @if (Model.FieldMapAll != null && Model.FieldMapAll.Count > 0)
                    {
                        for (int i = 0; i < Model.FieldMapAll.Count; i++)
                        {
                            <td data-priority="7">@Model.FieldMapAll[i].FieldName</td>
                        }
                    }
                    <td data-priority="2">Action</td>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>

    <div id="modal-container2" class="modal fade" role="dialog" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                    <h4>Remarks</h4>
                </div>
                <div class="modal-body">
                    <div class="box-body" id="modelview">
                        <table class="table table-bordered table-hover " id="RemarkInfo">
                            <thead>
                                <tr class="bg-gray">
                                    <td>#</td>
                                    <td>Date & times</td>
                                    <td>Employee</td>
                                    <td>Remark</td>
                                    <td>Task Status</td>
                                    <td>Details</td>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="modal-containerCheck" class="modal fade" role="dialog" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                    <h4>Checklist</h4>
                </div>
                <div class="modal-body">
                    <div class="box-body" id="notemodelview">
                        <table class="table table-bordered table-hover " id="NoteInfo">
                            <thead>
                                <tr class="bg-gray">
                                    <td>#</td>
                                    <td>Check List Name</td>
                                    <td>Note</td>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="margin-bottom" id="checklist">
    </div>

</div>
@{var vModel = "modal-lg";}
@Html.Partial("../Common/_ModalCreate", @vModel)
@Html.Partial("../Reminder/Index")
@Html.Partial("../Common/_ModalDelete")
@Html.Partial("../Common/_ModalEdit")


@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/bootstrap-timepicker")
    @Styles.Render("~/css/bootstrap-fileinput")
    @Styles.Render("~/css/bootstrap-fileinput-rtl")
    @Styles.Render("~/css/lightbox")
}
@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/bootstrap-timepicker")
    @Scripts.Render("~/js/bootstrap-fileinput")
    @Scripts.Render("~/js/bootstrap-sortable")
    @Scripts.Render("~/js/bootstrap-purify")
    @Scripts.Render("~/js/lightbox")

    <script type="text/javascript">
        var date = new Date();
        date.setDate(date.getDate());
        $('.date').datepicker({
            startDate: date,
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });
        jQuery.validator.methods["date"] = function (value, element) { return true; }
        $(".timepicker").timepicker({
            showInputs: true,
            defaultTime: false,
            format: 'dd-mm-yyyy'
        });

        $(document).ready(function () {
            TaskStatusName();
            SearchTaskMobile();
            $('#advsearch').hide();

            $('#To').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });
            $('#From').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });
            $('#ReminderDate').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });

            CallEmployee();
            CallLeadPipeCustAll();
            CallProject();
            CallTaskName();
            CallTaskType();
            CallSearchUser();
            GetProLocation();
            setTimeout(function () {
                if (typeof oTable != 'undefined')
                    oTable.ajax.reload();
            }, 100000);

            $("#AssignedUsers").select2({
                placeholder: 'Search Employees by Name',
                minimumInputLength: 0,
                ajax: {
                    url: "/Employee/SearchEmployee",
                    dataType: 'json',
                    type: "POST",
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term,
                            page: params.page,
                            x: "all"
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;

                        return {
                            results: data
                        };
                    },
                    cache: true
                },
            });
        });
        var loctype = 1;
        var oTable = $('#UserTable').DataTable({
            "processing": true,
            "serverSide": true,
            "filter": true,
            "orderMulti": false,
            "bStateSave": true,
            "pageLength": 100,
            responsive: {
                details: {
                    display: $.fn.dataTable.Responsive.display.childRowImmediate
                }
            },
            "ajax": {
                "url": '/ProTask/GetAllTasks',
                "data": function (data) {
                    data.taskname = $('#ddlTaskName').val();
                    data.tasktype = $('#ddlTaskType').val();
                    data.customer = $('#ddlCustomer').val();
                    data.projects = $('#ddlProject').val();
                    data.assignedto = $('#ddlEmployee').val();
                    data.createdby = $('#ddlCreatedBy').val();
                    data.status = $('#Status').val();
                    data.priority = $('#Priority').val();
                    data.fromdate = $('#From').val();
                    data.todate = $('#To').val();
                    data.taskstat = $('#TaskStatus').val();
                    data.empl = $('#ddlEmployee').val();
                    data.ref1 = $('#Ref1').val();
                    data.ref2 = $('#Ref2').val();
                    data.ref3 = $('#Ref3').val();
                    data.ref4 = $('#Ref4').val();
                    data.ref5 = $('#Ref5').val();
                    data.remdate = $('#ReminderDate').val();
                    data.remstatus = $('#RemStatus').val();
                    data.local = $('#ddlLocation').val();
                    data.Mobile = $('#ddlmobile').val();
                    data.LastUpdDays = $('#LastUpdated').val();
                    data.AssTo = $('#AssignedUsers').val();
                },
                "type": "POST",
                "datatype": "json"
            },
            "order": [[10, "desc"]],
            "columnDefs": [{ className: "not-mobile", "targets": [5] }, { orderable: false, "targets": [17] }],
            "columns": [
                         {
                             "data": "ProTaskId", "name": "ProTaskId",
                             "render": function (data, type, row, meta) {
                                 return meta.row + meta.settings._iDisplayStart + 1;
                             }
                         },
                         {
                             "name": "TaskName","className":"myname", "data": function (data) {
                                 var myclass = '';
                                 if (data.Priority == "High") {
                                     myclass = 'text-red';
                                 }
                                 else if (data.Priority == "Medium") {
                                     myclass = 'text-orange';
                                 }
                                 @{
                                     if(User.IsInRole("Dev") || User.IsInRole("View ProTask"))
                                     {
                                         actData += "'<a href=\"/ProTask/Details/'+ data.ProTaskId +'\" class=\"'+myclass+'\">'+ data.TaskName +'</a>' ";
                                     }
                                     else
                                     {
                                         actData += "data.TaskName";
                                     }
                                 }
                                 return @Html.Raw(actData);
                             }
                         },
                        { "data": "TypeName", "name": "TypeName" },
                          {
                              "name": "CustomerName", "data": function (data) {
                                  if (data.CustomerName != "No Customer") {
                                      @{
                                          var dataz = "";
                                          if (User.IsInRole("Dev") || User.IsInRole("View Customer"))
                                          {
                                              dataz = "'<a href=\"/Customer/Details/'+ data.CustomerID +'\">'+ data.CustomerName +'</a>' ";
                                          }
                                          else
                                          {
                                              dataz = "data.CustomerName";
                                          }
                                      }
                                      return @Html.Raw(dataz);
                                  }
                                  return "-";
                              }
                          },
                          {
                              "name": "Mobile", "data": function (data) {
                                  var datas = "";
                                  $.each(data.mobmodel, function (i, item) {
                                      if (item.Num != null) {
                                          if (datas != "") {
                                              datas += ", ";
                                          }
                                          datas += '<a href="tel:' + item.Num + '">' + item.Num + '</a>';
                                      }
                                  });
                                  return datas;
                              }
                          },
                         { "data": "Location", "name": "Location" },
                          {
                              "name": "StartTime",
                              "data": function (data) {
                                  if (data.StartTime != null) {
                                      return convertDateTime(data.StartTime);
                                  } else if (data.StartDate != null) {
                                      return convertToDate(data.StartDate);
                                  } else { return "";}
                              }
                          },
                        { "data": "EmpName", "name": "EmpName" },
                        { "data": "TaskStat", "name": "TaskStat" },
                        {
                            "name": "Priority", "data": function (data) {
                                var datas = "";
                                if (data.Priority == "Low") {
                                    datas = "<span class='text-blue'>LOW</span>";
                                }
                                else if (data.Priority == "Medium") {
                                    datas = "<span class='text-orange'>MEDIUM</span>";
                                }
                                else {
                                    datas = "<span class='text-red'>HIGH</span>";
                                }
                                return datas;
                            }
                        },
                      {
                          "name": "ldate", "data": function (data) {
                              var result = "";
                              if (data.ldate != null) {
                                  result = LastUpdatedIn(data.ldate);
                              }
                              return (result);
                          }
                      },
                      {
                          "data": "TaskDetails", "name": "TaskDetails", "render": function (data) {
                              if (data != null && data.length > 200) {
                                  return data.substr(0, 200) + '...';
                              }
                              else {
                                  return data;
                              }
                          }
                      },
                        { "data": "Ref1", "name": "Ref1" },
                        { "data": "Ref2", "name": "Ref2" },
                        { "data": "Ref3", "name": "Ref3" },
                        { "data": "Ref4", "name": "Ref4" },
                        { "data": "Ref5", "name": "Ref5" },
                        {
                            "name": "ProTaskId", "data": function (data) {

                                var rest = "";
                                if (((data.devcheck == true || data.editcheck == true) && data.allcheck == true) || (data.CreatedBy == data.UserId)) {
                                    @{
                                        actData = "";
                                        actData += "<a href=\"/ProTask/Edit/'+ data.ProTaskId +'/MyTask\" title=\"Edit Task\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                                    }
                                    rest += '@Html.Raw(actData)';
                                }
                                @{
                                    actData = "";

                                    actData += "<a class=\"modal-create\" href=\"/ProTask/AddRemark/'+ data.ProTaskId +'\" title=\"Add Task Update\"><i class=\"fa-lg fa fa-refresh\" ></i></a> ";
                                    actData += "<a class=\"Updation\" onclick=\"detailsRemark(' + data.ProTaskId + ')\" title=\"View Task Update\"><i class=\"fa-lg fa fa-calendar\" ></i></a> ";

                                }

                                rest += '@Html.Raw(actData)';
                                if ("@ViewBag.Remind" == "active") {
                                    @{
                                        actData = "";
                                        actData += "<a class=\"UpdationRe\" onclick=\"detailsRemind(' + data.ProTaskId + ')\" title=\"View Reminder\"><i class=\"fa-lg fa fa-bell\" ></i></a> ";
                                        actData += "<a class=\"modal-create\" href=\"/Reminder/AddReminder/'+ data.ProTaskId +'/Task\" title=\"Add Reminder\"><i class=\"fa-lg fa fa-sticky-note\" ></i></a> ";
                                    }
                                    rest += '@Html.Raw(actData)';
                                }
                                return rest;
                            }
                        },
            ],
            dom: 'Bfrtip',
            buttons: ['colvis',
        {
            extend: 'print',//
            title: "",
            footer: true,
            filename: function () {
                return 'Task';
            },
            columnDefs: [
                { width: 400, targets: 2 }
            ],
            exportOptions: {
                columns: ':visible'
            },
            message: function () {
                var head = '<table class="tblcompact table table-bordered"><thead>' +
                ' <tr><th class="text-center"><h3 style="margin-top: 0px;"><h4>Task</h4></th></tr>';
                return head;
            },
            customize: function (win) {
                $(win.document.body).find('table.tblcompact tbody td').css('padding', '0px');
                $(win.document.body).find('.dataTable,.dataTable th,.dataTable tr,table.tblcompact tbody td .dataTable td')
                    .css('font-size', '10pt')
                    .css('padding', '5px')
                    .addClass('compact');
                $(win.document.body).find('.dataTable tr th:nth-child(3)')
                    .css('min-width', '80px');
                $(win.document.body).append('</td></tr></tbody>')

            }
        }, 'copy', 'csv', //'excel',
                 //Excel
                 {
                     extend: 'excel',//
                     title: "",
                     footer: true,
                     filename: function () {
                         return 'Task';
                     },
                     message: function () {
                         var head = 'Task';
                         return head;
                     },
                     pageSize: 'A4',
                     exportOptions: {
                         columns: ':visible'
                     },
                 },
                 {
                     extend: 'pdf',//
                     title: "",
                     footer: true,
                     filename: function () {
                         return 'Task';
                     },
                     message: function () {
                         var head = 'Task';
                         return head;
                     },
                     pageSize: 'A4',
                     exportOptions: {
                         columns: ':visible'
                     },
                     customize: function (doc) {
                         doc.pageMargins = [10, 10, 10, 10];
                         doc.defaultStyle.fontSize = 10;
                         doc.styles.tableHeader.fontSize = 10;
                         doc.styles.title.fontSize = 12;
                         // Header font and bg color
                         doc.styles.tableHeader.fillColor = '#d3d3d3';
                         doc.styles.tableHeader.color = 'black';
                         // Remove spaces around page title
                         doc.content[0].text = doc.content[0].text.trim();


                         doc.styles['td:nth-child(2)'] = {
                             width: '100%',
                             'max-width': '100%'
                         }

                         var objLayout = {};
                         // Horizontal line thickness
                         objLayout['hLineWidth'] = function (i) { return .5; };
                         // Vertikal line thickness
                         objLayout['vLineWidth'] = function (i) { return .5; };
                         objLayout['paddingLeft'] = function (i) { return 4; };
                         // Right padding of the cell
                         objLayout['paddingRight'] = function (i) { return 4; };
                         // Inject the object in the document
                         doc.content[1].layout = objLayout;
                         // Footer font and bg color
                         doc.styles.tableFooter.fillColor = '#d3d3d3';
                         doc.styles.tableFooter.color = 'black';

                     }
