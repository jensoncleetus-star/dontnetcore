@model QuickSoft.ViewModel.CustomerMergeViewModel
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Customer Merge</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("Create", "CustomerMerge", FormMethod.Post, new { id = "createform", @class = "form-horizontal" }))
    {
        <script type="text/javascript">
            $('form#createform').removeData("validator");
            $('form#createform').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#createform'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
<div class="box-body">


    <div class="form-group">
        @Html.LabelFor(m => m.OldCurstomerIds, new { @class = "control-label col-sm-4" })
        <div class="col-sm-8">
            @Html.ListBoxFor(m => m.OldCurstomerIds, (SelectList)ViewBag.cust, new { @class = "form-control textwidth" })
        </div>
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.CustomerId, new { @class = "control-label col-sm-4" })
        <div class="col-sm-8">
            @Html.DropDownListFor(m => m.CustomerId, (SelectList)ViewBag.cust, "Select Team Lead", new { @class = "form-control select2 textwidth", @required = "required" })
        </div>
    </div>
    
</div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <button type="submit" class="btn btn-info col-sm-offset-4">Save</button>
                    <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
        <script>

            $("#OldCurstomerIds").select2({
                placeholder: 'Search Customer by Name or Code',
                minimumInputLength: 0,
                dropdownAutoWidth: true,
                ajax: {
                    url: "/Customer/SearchCustomer",
                    dataType: 'json',
                    delay: 50,

                    data: function (params) {
                        return {
                            q: params.term || "",
                            page: params.page || 0,
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 0;

                        return {
                            results: data,
                            pagination: {
                                //more: (params.page * 10) < 50
                                more: true
                            }
                        };
                    },
                    cache: true
                },
            });
            $("#CustomerId").select2({
                placeholder: 'Search Customer by Name or Code',
                minimumInputLength: 0,
                dropdownAutoWidth: true,
                ajax: {
                    url: "/Customer/SearchCustomer",
                    dataType: 'json',
                    delay: 50,

                    data: function (params) {
                        return {
                            q: params.term || "",
                            page: params.page || 0,
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 0;

                        return {
                            results: data,
                            pagination: {
                                //more: (params.page * 10) < 50
                                more: true
                            }
                        };
                    },
                    cache: true
                },
            });

           
        </script>
    }
</div>
