@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/bootstrap-timepicker")


}

@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/bootstrap-timepicker")
    <script type="text/javascript">
        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });

        jQuery.validator.methods["date"] = function (value, element) { return true; }
        $(".timepicker").timepicker({
            showInputs: true,
            defaultTime: false,
            format: 'dd-mm-yyyy'
        });

        $(document).ready(function () {
            $('#advsearchlist').hide();
        });

        var oTable = $('#PurchaseQuotationTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "pageLength": 50,
            responsive: true,
            "bLengthChange": false,
            "ajax": {
                "url": '/PurchaseQuotation/GetPurchaseQuotation',
                "data": function (data) {
                    data.BillNo = $('#BillNo').val();
                    data.FromDate = $('#FromDate').val();
                    data.ToDate = $('#ToDate').val();
                    data.Supplier = $('#ddlSupplier').val();
                    data.salesperson = $('#ddlEmployee').val();
                    data.project = $('#ddlProject').val();
                    data.Stats = $('#Status').val();
                    data.user = $('#ddlCreatedBy').val();
                    data.Validity = $('#Validity').val();
                    data.appstat = $('#ApprovalStatus').val();
                    data.ProjectName = $('#ddlProject').val();
                    data.Task = $('#ddlProTask').val();
                },
                "type": "POST",
                "datatype": "json"
            },
            "order": [[0, "desc"]],
            "columnDefs": [{
                "targets": [13,14],
                "orderable": false
            }],
            "columns": [
                     {
                         "data": "PQuotationId", "name": "PQuotationId",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                { "data": "BillNo", "name": "BillNo" },
                { "data": "PQuotDate", "name": "PQuotDate", "render": function (data) { return convertToDate(data); } },
                { "data": "Supplier", "name": "Supplier" },
                { "data": "ProjectName", "name": "ProjectName" },
                { "data": "Task", "name": "Task" },
                { "data": "MRNo", "name": "MRNo" },
                { "data": "PQuotGrandTotal", "name": "PQuotGrandTotal", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                { "data": "validity", "name": "validity" },
                { "data": "EmpName", "name": "EmpName" },

                { "data": "user", "name": "user" },
                {
                    "name": "validity", "data": function (data) {
                        if (data.validity == "Expired") {
                            return '<i class="badge bg-red" style="font-size: small" >Expired</i>';
                        }
                        else {
                            return '<i class="badge bg-green" style="font-size: small" >Active</i></a>';
                        }
                    }
                },
                 {
                     "name": "ApprovalStatus", "data": function (data, type, dataToSet) {
                         var status = "";
                         var cls = "";
                         if (data.app.length > 0 || (data.Approval == true && '@ViewBag.MLAPQuot' == 'active')) {
                             if (data.ApprovalStatus == "0") {
                                 status = '<span class="badge bg-green">Approved</span>';
                             }
                             else if (data.ApprovalStatus == "1") {
                                 status = '<span class="badge bg-red">Rejected</span>';
                             }
                             else if (data.ApprovalStatus == "2") {
                                 status = '<span class="badge bg-orange">Pending</span>';
                             }
                             return '<a  class="Updation" onclick="details(' + data.PQuotationId + ')"  title="View Status">' + status + ' </a>';
                         } else { return null; }
                     }
                 },
                {
                    "name": "PQuotationId", "data": function (data) {

                        var rest = "";
                        @{  if (User.IsInRole("Dev") || User.IsInRole("View PurchaseQuotation"))
                            {
                                actData += "<a class=\"details\" href=\"/PurchaseQuotation/Details/'+ data.PQuotationId +'\" title=\"View PurchaseQuotation\"><i class=\"fa fa-lg fa-search-plus\"></i></a> ";
                            }
                            //if (User.IsInRole("Dev") || User.IsInRole("Edit PurchaseQuotation"))
                            //{
                            //    actData += "<a href=\"/PurchaseQuotation/Edit/'+ data.PQuotationId +'\" title=\"Edit PurchaseQuotation\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                            //}
                            if(User.IsInRole("Dev") || User.IsInRole("Delete PurchaseQuotation"))
                            {
                                actData += "<a class=\"modal-delete\" href=\"/PurchaseQuotation/Delete/'+ data.PQuotationId +'\" title=\"Delete PurchaseQuotation\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";
                            }
                            if (User.IsInRole("Dev") || User.IsInRole("Delete PurchaseQuotation"))
                            {
                                actData += "<a class=\"modal-link-download\" href=\"/PurchaseQuotation/Download/'+ data.PQuotationId +'\" title=\"Download PurchaseQuotation\"><i class=\"fa-lg fa fa-download\" ></i></a> ";
                            }
                            actData += "<a href=\"/PurchaseEntry/Create/'+ data.PQuotationId+'/PQuote\" title=\"Convert To Purchase Entry\"><i class=\"fa-lg fa fa-exchange\" ></i></a> ";


                          }
                        rest += '@Html.Raw(actData)';


                        if (data.app.length > 0 || (data.Approval == true && '@ViewBag.MLAPQuot' == 'active')) {
                            if (data.ApprovalStatus != "0") {
                            @{
                                actData = "";

                                if (User.IsInRole("Dev") || User.IsInRole("Edit PurchaseQuotation"))
                                {
                                    actData += "<a href=\"/PurchaseQuotation/Edit/'+ data.PQuotationId +'\" title=\"Edit PurchaseQuotation\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                                }

                         }
                                rest += '@Html.Raw(actData)';
                            }
                        }
                           if (data.Approval == true && '@ViewBag.MLAPQuot' == 'active') {
                            @{
                             actData = "";

                             actData = "<a class=\"modal-edit\"  href=\"/PurchaseQuotation/EditStatus/'+  data.PQuotationId+'\" title=\"Edit Status\"><i class=\"fa fa-lg fa-refresh\" ></i></a> ";

                         }
                            rest += '@Html.Raw(actData)';
                        }
                        //Convert To Purchase
                            if (data.ApprovalStatus == "0" && data.POConvert == "POrder" && data.PQuotToPOrder == true) {
                            @{
                                actData = "";
                                if (User.IsInRole("Dev") || User.IsInRole("Purchase Order"))
                                {

                                    actData += "<a href=\"/PurchaseOrder/Create/'+ data.PQuotationId +'/PQuote\" title=\"Convert To Purchase Order\" class=\"text-red\"><i class=\"fa-lg fa fa-exchange\" ></i></a> ";
                                }
                                //if (User.IsInRole("Dev") || User.IsInRole("Purchase Entry"))
                                //{

                                //    actData += "<a href=\"/PurchaseEntry/Create/'+ data.PQuotationId +'/PQuote\" title=\"Convert To Purchase Entry\" class=\"text-red\"><i class=\"fa-lg fa fa-exchange\" ></i></a> ";
                                //}
                               }
                            rest += '@Html.Raw(actData)';
                        }
                        else {
                            if (data.ApprovalStatus == "0" && data.PQuotToPOrder == true) {
                                @{
                                actData = "";
                                if (User.IsInRole("Dev") || User.IsInRole("Purchase Order"))
                                {

                                    actData += "<a href=\"/PurchaseOrder/Create/'+ data.PQuotationId +'/PQuote\" title=\"Convert To Purchase Order\"><i class=\"fa-lg fa fa-exchange\" ></i></a> ";
                                }
                                //if (User.IsInRole("Dev") || User.IsInRole("Purchase Entry"))
                                //{
                                //    actData += "<a href=\"/PurchaseEntry/Create/'+ data.PQuotationId+'/PQuote\" title=\"Convert To Purchase Entry\"><i class=\"fa-lg fa fa-exchange\" ></i></a> ";
                                //}

                               }
                                rest += '@Html.Raw(actData)';
                            }
                        }
                        if ("@ViewBag.Remind" == "active") {
                            @{
                                    actData = "";
                                    actData += "<a class=\"UpdationRe\" onclick=\"detailsRemind(' + data.PQuotationId + ')\" title=\"View Reminder\"><i class=\"fa-lg fa fa-bell\" ></i></a> ";
                                    actData += "<a class=\"modal-create\" href=\"/Reminder/AddReminder/'+ data.PQuotationId +'/PQuot\" title=\"Add Reminder\"><i class=\"fa-lg fa fa-sticky-note\" ></i></a> ";
                                }
                            rest += '@Html.Raw(actData)';
                        }

                        return rest;
                    }
                },
                 {
                     "name": "PQuotationId", "data": function (data) {
                         var rest = "";
                         @{

                                 delchk = "<input class=\"checkbox\" type=\"checkbox\" name=\"bill[]\" value='+ data.PQuotationId +'></input>";

                         }
                         return rest = '@Html.Raw(delchk)';
                     }
                 },
            ],
            buttons: [
              'colvis',
              {
                  extend: 'print',//
                  title: "",
                  footer: true,
                  filename: function () {
                      return 'Purchase Quotation';
                  },
                  columnDefs: [
                      { width: 400, targets: 2 }
                  ],
