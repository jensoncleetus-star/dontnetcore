<section class="content hidden print" id="printKOT">
    <style>
        #invoice-POS {
            padding: 2mm;
            margin: 0 auto;
            width: 100%;
            background: #FFF;
            /*border: 1px solid #f0f0f0;*/
            /*max-width: 250px;*/
        }

            #invoice-POS ::selection {
                color: #FFF;
            }

            #invoice-POS ::moz-selection {
                color: #FFF;
            }

            #invoice-POS h1 {
                font-size: 1.5em;
                color: #222;
            }

            #invoice-POS h2 {
                font-size: 1em;
                margin: 0px 0;
                padding-top: 3px;
                padding-bottom: 3px;
            }

            #invoice-POS h3 {
                font-size: 1.2em;
                font-weight: 300;
                line-height: 2em;
            }

            #invoice-POS p {
                font-size: .9em;
                color: #666;
                line-height: 1.2em;
                margin-bottom: 1px;
            }

            #invoice-POS #top, #invoice-POS #mid, #invoice-POS #bot {
                /* Targets all id with 'col-' */
                border-bottom: 1px solid #EEE;
                margin-bottom: 5px;
            }

            /*#invoice-POS #top {
                min-height: 100px;
            }*/

            /*#invoice-POS #mid {
                min-height: 80px;
            }*/

            #invoice-POS #bot {
                min-height: 50px;
            }

            #invoice-POS #top .logo {
                height: 60px;
                width: 60px;
                background-size: 60px 60px;
            }

            #invoice-POS .clientlogo {
                float: left;
                height: 60px;
                width: 60px;
                background: url() no-repeat;
                background-size: 60px 60px;
                border-radius: 50px;
            }

            #invoice-POS .info {
                display: block;
                margin-left: 0;
                margin-bottom: 5px;
            }

            #invoice-POS .title {
                float: right;
            }

                #invoice-POS .title p {
                    text-align: right;
                }

            #invoice-POS table {
                width: 100%;
                border-collapse: collapse;
                margin-bottom: 5px;
                border-bottom: 1px #898989;
            }

            #invoice-POS .tabletitle {
                font-size: .85em;
                border-bottom: 1px solid #EEE;
            }

            #invoice-POS .service {
                border-bottom: 1px solid #EEE;
            }

            #invoice-POS .item {
                width: 24mm;
                padding-top: 3px;
                padding-bottom: 3px;
            }

            #invoice-POS .itemtext {
                font-size: .65em;
                margin-bottom: 1px;
            }

            #invoice-POS #legalcopy {
                margin-top: 5mm;
            }

            #invoice-POS .rate {
                text-align: right;
            }

            #invoice-POS .qty {
                text-align: center;
            }

            #invoice-POS .price {
                text-align: center;
            }

            #invoice-POS hr {
                margin: 5px 0;
            }

        .noborder th {
            border-bottom: 1px #898989;
        }

        .noborder tr {
            border: none;
        }

        .noborder td {
            border: none;
        }
    </style>
    <div id="invoice-POS">

        <center id="top">

            @if (@ViewBag.CLogo != null)
            {
                <div class="logo"><img class="img-responsive" src="../uploads/company/@ViewBag.CLogo" /></div>
            }
            @if (@ViewBag.CTaxRegNo != null)
            {
                <div class="info"><h2>@ViewBag.CName <br /><small>(Tax RegNo: @ViewBag.CTaxRegNo)</small></h2></div>

            }
            else
            {
                <div class="info"><h3>@ViewBag.CName</h3></div>
            }
            <h4 style="margin-bottom: 1px;">
                <strong>KOT</strong>
            </h4>
        </center><!--End InvoiceTop-->

        <div id="mid">
            <div class="info">
                <p><span>Order No :</span><label id="lblOrderNo"></label></p>
                <p><span>Date تاريخ:</span><label id="lblKotDate"></label></p>
                <p><span>Order Type :</span><label id="lblOrderType"></label></p>
            </div>
        </div><!--End Invoice Mid-->

        <div id="bot">
            <div id="table">
                <table class="table-nob noborder" id="itemtablekot" style="font-size: 12px;">
                    <thead>
                        <tr class="tabletitle thead">
                            <th class="item"><h2>Item بند</h2></th>
                            <th class="qty"><h2>Qty كمية</h2></th>
                            @*<th class="price"><h2>Unit Price السعر</h2></th>
                            <th class="rate"><h2>Amount كمية</h2></th>*@
                        </tr>
                    </thead>
                    @*<tbody></tbody>*@
                </table>
            </div><!--End Table-->
        </div><!--End InvoiceBot-->
    </div><!--End Invoice-->
</section>

