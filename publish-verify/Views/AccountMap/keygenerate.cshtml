@model QuickSoft.Models.keytableview
@{
    ViewBag.Title = "Key Generate";
    ViewBag.SubTitle = "Contact";
    ViewBag.Active = "Utility";
}

<style>
    .remove_button {
        position: absolute;
        right: 1rem;
    }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">

<link rel="stylesheet" href="~/Content/css/shared/style.css">
<!-- endinject -->
<!-- Layout styles -->
<link rel="stylesheet" href="~/Content/css/demo_1/style.css">
<!-- End Layout styles -->
<div class="box box-info">
    @using (Html.BeginForm("keygenerate", "accountmap", FormMethod.Post, new { id = "createForm", role = "form", enctype = "multipart/form-data" }))
    {
        <div class="box-header with-border">
            <h3 class="box-title">Create Key</h3>
       
        </div>
        <div class="box-body">
            @Html.AntiForgeryToken()
            @Html.ValidationSummary("", new { @class = "alert alert-danger AlertDiv" })

            <div class="row">
                <div class="form-group col-md-3">
                    <label class="control-label">Purpose</label>

                    @Html.DropDownListFor(modal=>modal.purpose, new SelectList(new List<SelectListItem>
                                {
                                 new SelectListItem() {Text = "Allow Sales Price Below Purchse Price", Value="Below Purchase"}
                                ,
                                }, "Value", "Text"), new { @class = "form-control input-sm", @name = "pupose" })

                </div>
                <div class="form-group col-md-3">
                    <label class="control-label">KeyValue</label><i class="text-danger">*</i>
                    @Html.EditorFor(model => model.keyvalue, new { htmlAttributes = new { @class = "form-control", @required = "required" } })
                </div>
                <div class="form-group col-md-3">
                    <label class="control-label">Expire Miniute</label><i class="text-danger">*</i>
                    @Html.EditorFor(model => model.expire, new { htmlAttributes = new { @class = "form-control", @required = "required" } })
                </div>
                <div class="form-group col-md-3">
                    <label class="control-label"> Employee</label><i class="text-danger">*</i>
                    @Html.DropDownListFor(model => model.employeeid, (SelectList)ViewBag.Empl, new { id = "ddlEmployee", @class = "form-control input-sm "})
                </div>

              

            </div>



            @*******************************Add Attachment ********************************@
 

      

            </div>

     

        <div class="box-footer clearfix">
            @*<input type="submit" class="btn btn-success" id="btnSubmit"><span class="glyphicon glyphicon-floppy-disk"></span>Save </button>&ensp;*@
            <button type="submit" id="save" class="btn btn-success" tabindex="28">
                <span class="glyphicon glyphicon-floppy-disk"></span> Save
            </button> &ensp;
            <input type="button" class="btn btn-default" value="Cancel" onclick="@("window.location.href='/Contact/Index'");" />
        </div>
        <div id="divmobile">
        </div>
    }
</div>
@Html.Partial("../Common/_ModalCreate")

@section style{
    @Styles.Render("~/css/bootstrap-datepicker")

}

@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/Mobile")
    @Scripts.Render("~/js/bootstrap-datepicker")
    <script type="text/javascript">

      var rowno = 0;//count of existing rowno;

      $(document).ready(function () {

          CallEmployee();

    });

    </script>
}

