@model QuickSoft.ViewModel.AssetTransferViewModel
@{
    ViewBag.Title = "Edit";
    ViewBag.SubTitle = "Edit AssetTransfers";
    ViewBag.Active = "Transactions";
    var TimeOut = @ViewBag.TMOut;
    string IRateCheck = "inactive";
}
@if (User.IsInRole("Dev") )
{
    IRateCheck = "active";
}
@using (Html.BeginForm("Edit", "AssetTransfers", FormMethod.Post, new { id = "Editform", role = "form" }))
{
    <div class="box box-info">
        <div class="box-header with-border">
            <h3 class="box-title">Edit AssetTransfers <label id="AlertEditable" class="text-red"></label></h3>
            <div class="pull-right">
                @if (@ViewBag.preEntry != 0)
                {
                    if (User.IsInRole("Dev") )
                    {
                        <a class="btn bg-black no-border" href="/AssetTransfers/Edit/@ViewBag.preEntry">
                            <i class="fa fa-step-backward"></i>
                        </a>
                    }
                }
                @if (@ViewBag.nxtEntry != 0)
                {
                    if (User.IsInRole("Dev") )
                    {
                        <a class="btn bg-black no-border" href="/AssetTransfers/Edit/@ViewBag.nxtEntry">
                            <i class="fa fa-step-forward"></i>
                        </a>
                    }
                }
                else
                {
                    if (User.IsInRole("Dev") )
                    {
                        <a class="btn bg-black no-border" href="/AssetTransfers/Create">
                            <i class="fa fa-step-forward"></i>
                        </a>
                    }
                }

                @if (User.IsInRole("Dev") )
                {
                    <a class="btn btn-success no-border" href="/AssetTransfers/Index">
                        <i class="fa fa-fw fa-history"></i>List
                    </a>
                }
            </div>
        </div>

        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })

        <div class="box-body">
            <input type="hidden" id="ROnlyRate" value="@IRateCheck" />
            <input type="hidden" id="SelApprovedBy" />
            <input type="hidden" id="VoucherType" value="StockTransfer" />

            <div class="row">
                <div class="col-sm-2 form-group ">
                    @Html.Label("Invoice No", null, new { @class = "control-label" }) *
                    @if (User.IsInRole("Dev"))
                    {
                        @Html.EditorFor(model => model.InvoiceNo, new { htmlAttributes = new { @class = "form-control", @required = "required" } })
                    }
                    else
                    {
                        @Html.EditorFor(model => model.InvoiceNo, new { htmlAttributes = new { @class = "form-control", @required = "required", @readonly = "readonly" } })
                    }
                    @Html.HiddenFor(Model => Model.InvoiceNo)
                </div>

                <div class="col-sm-2 form-group">
                    @Html.Label("AssetEntry Date", null, htmlAttributes: new { @class = "control-label" })*
                    <div class="input-group date">
                        <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                        @Html.TextBoxFor(model => model.AssetEntryDate, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @required = "required" })
                    </div>
                </div>

               




                
            </div>



            <div class="row">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="normalinvoice">
                        <thead>
                            <tr>
                                <th class="text-center">S/N</th>
                                <th class="text-center">Item <i class="text-danger">*</i></th>
                                <th class="text-center">Barcode</th>
                                <th class="text-center">Unit</th>
                                <th class="text-center">Qty <i class="text-danger">*</i></th>
                                <th class="text-center">Price <i class="text-danger">*</i></th>
                                <th class="text-center">Total Price</th>
                                <th class="text-center">Depreciation%<i class="text-danger">*</i></th>
                                <th class="text-center">Asset Accounts<i class="text-danger">*</i></th>
                                <th class="text-center">Depreciation Accounts<i class="text-danger">*</i></th>

                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody id="addinvoiceItem"></tbody>
                        <tfoot>
                            <tr>
                                <td> <b>Total</b> </td>
                                <td class="text-left"> <label id="ToItemCount"></label> </td>
                                <td></td>
                                <td></td>
                                <td class="text-right"> <label id="ToItemQnt"></label> </td>
                                <td class="text-right">
                                    <label id="ToItemPrice"></label>
                                </td>
                                <td class="text-right"> <label id="ToItemAmount"></label> </td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
            <div class="row">
                @*<div class="col-sm-3"></div>*@




            </div>

            <div class="col-md-6"></div>
            <div class="row">
                <div class="col-md-6">

                    <div class="form-group col-md-6 no-paddingleft">
                    </div>
                    @*<div class="form-group no-padding text-right">
                        <div class="checkbox-inline">
                            <input class="checkbox" data-val="true" id="hideheader" name="hideheader" type="checkbox" value="true">
                            <label class="control-label" for="hideheader">Hide Header In Print</label>
                        </div>
                    </div>*@
                    <div class="form-group pull-right">
                        <button type="submit" id="save" class="btn btn-success">
                            <span class="glyphicon glyphicon-floppy-disk"></span> Save
                        </button>
                        @*<button type="submit" id="print" class="btn btn-success">
                            <span class="glyphicon glyphicon-print"></span> Update And Print
                        </button>*@
                        @if (@ViewBag.CheckMail == 0)
                        {
                            <button type="submit" id="sendmail" class="btn btn-success">
                                <span class="glyphicon glyphicon-envelope"></span> Save And Mail
                            </button>
                        }
                        <button type="button" class="btn btn-warning" onclick="@(" window.location.href='/AssetTransfers/Index' ");">Cancel</button>

                    </div>
                </div>
            </div>
        </div>
    </div>
}


