@model QuickSoft.Models.StockVerification
@{
    ViewBag.Title = "Stock Verification List";
    ViewBag.SubTitle = "Stock Verification";
    ViewBag.Active = "Transaction";
    string actData = "";
}
<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">Stock Verification</h3>
        <div class="pull-right">
            <i class="ace-icon fa fa-hand-o-right icon-animated-hand-pointer blue"></i>
     
            <a class="btn btn-info no-border" href="/StockVerification/Create">
                <i class="glyphicon glyphicon-plus"></i> Create StockVerification
            </a>
            
        </div>
    </div>
    <div class="box-body">
        <table class="table table-bordered table-hover" id="StkTable">
            <thead>
                <tr class="bg-gray">
                    <td data-priority="1">SI No</td>
                    <td data-priority="1">Voucher No</td>
                    <td data-priority="2">Date</td>
                   
                    <td data-priority="5">Created By</td>
                    <td data-priority="2">Action</td>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>
@{var Modelv = "modal-lg";}
@Html.Partial("../Common/_ModalCreate", @Modelv)
@Html.Partial("../Common/_ModalDelete")
@section scripts{
    <script type="text/javascript">
        var oTable = $('#StkTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "pageLength": 50,
            responsive: true,
            "ajax": {
                "url": '/StockVerification/GetData',
                "type": "POST",
                "datatype": "json"

            },
            "order": [[0, "desc"]],
            "columnDefs": [{ orderable: false, targets: -1 }],
            "columns": [
                     {
                         "data": "StockVerificationId", "name": "StockVerificationId",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                { "data": "VoucherNo", "name": "VoucherNo" },
                { "data": "Date", "name": "Date", "render": function (data) { return convertToDate(data); } },
                    { "data": "UserName", "name": "UserName" },
                    {
                        "name": "StockVerificationId", "data": function (data) {
                            var rest = "";
                            @{
                               
                                    actData += "<a class=\"details\" href=\"/StockVerification/Details/'+ data.StockVerificationId +'\" title=\"View Stock Verification\"><i class=\"fa fa-lg fa-search-plus\"></i></a> ";
                               
                               
                                    actData += "<a href=\"/StockVerification/Edit/'+ data.StockVerificationId +'\" title=\"Edit StockVerificationId\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                               
                               
                                    actData += "<a class=\"modal-delete\" href=\"/StockVerification/Delete/'+ data.StockVerificationId +'\" title=\"Delete StockVerification\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";
                               
                            }
                            return rest = '@Html.Raw(actData)';
                        }
                    }

            ]
        })

        /* function for view detail popup */
        $('#StkTable').on('click', 'a.details', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        })

        /* function for Create popup */

        $('div').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
            //datepickerInit();
        });
        $('#modal-create').on('submit', '#createform', function (e) {
            e.preventDefault();
            var url = $('#createform')[0].action;
            var data = $('#createform').serialize();
            createajax(url, data, '#modal-create');
        });


        /* function for Edit popup */

        $('div').on('click', '.modal-edit', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-edit');
        });
        $('#modal-edit').on('submit', '#editform', function (e) {
            e.preventDefault();
            var url = $('#editform')[0].action;
            var data = $('#editform').serialize();
            createajax(url, data, '#modal-edit');
        });

        /* function for delete popup */
        $('#StkTable').on('click', '.modal-delete', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-delete');
        });
        $('#modal-delete').on('submit', '#deleteform', function (e) {
            e.preventDefault();
            var url = $('#deleteform')[0].action;
            var data = $('#deleteform').serialize();
            createajax(url, data, '#modal-delete');
        });
    </script>
}