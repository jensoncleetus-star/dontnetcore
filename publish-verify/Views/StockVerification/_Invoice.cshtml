<div id="printit" class="hidden">
    <!-- Main content -->
    <section class="invoice print">
        <!-- title row -->
        <div class="row" id="header">
            <div class="col-xs-12">
                <div class="text-center">
                    @{ ViewBag.chkLogo = "logo";}
                    @Html.Partial("../Common/_CompanyHeader")
                    <h4>
                        <strong>Stock Verification</strong>
                       
                    </h4>
                </div>
            </div>
            <!-- /.col -->
        </div>
        <div class="row invoice-info">
            <div class="col-xs-12 table-responsive">
                <table class="table table-bordered" style="margin-bottom:0px !important;">
                    <tr>
                        <th>Voucher No رقم القسيمة</th>
                        <td><label id="lblBillNo"></label></td>
                    </tr>
                    <tr>
                        <th>Date تاريخ</th>
                        <td><label id="lblDate"></label></td>
                    </tr>
                </table>
            </div>
        </div>
        <div class="clearfix"></div>
        <!-- Table row -->
        <div class="row">
            <div class="col-xs-12">
                <table class="table table-bordered" id="itemtable" style="margin-bottom:0px !important;">
                    <thead>
                        <tr class="chkhead">
                            <th class="text-center" rowspan="2">S.N.</th>
                            <th class="text-center" rowspan="2">Code</th>
                            <th class="text-center item-lists" rowspan="2">Item <i class="text-danger">*</i></th>
                            <th class="text-center" rowspan="2">Unit</th>
                            <th class="text-center" colspan="2">Computer Stock</th>
                            <th class="text-center" colspan="2">Physical Stock</th>
                            <th class="text-center" colspan="2">Stock Difference</th>
                        </tr>
                        <tr class="chkhead">
                            <th class="text-center">Pcs</th>
                            <th class="text-center">Quantity</th>
                            <th class="text-center">Pcs</th>
                            <th class="text-center">Quantity</th>
                            <th class="text-center">Pcs</th>
                            <th class="text-center">Quantity</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
            <div class="col-xs-12">
                <table class="table table-bordered" id="itemtable1" style="margin-bottom:0px !important;">
                    <tbody></tbody>
                </table>
            </div>
        </div>
        @*<div class="row" id="footer">
            <div class="col-xs-12 table-responsive">
                <table class="table table-bordered">
                    <tr>
                        <td rowspan="3" style="width:50%;">
                            Receiver's Signature :<br />
                            توقيع المتلقي

                        </td>
                        <td colspan="3" rowspan="3">
                            For @ViewBag.CName
                        </td>
                    </tr>
                </table>
            </div>
        </div>*@
        <div class="row">
            <div class="col-xs-12">
                @Html.Partial("../Common/_CompanyFooter")
            </div>
        </div>
    </section>
</div>




