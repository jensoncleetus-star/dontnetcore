@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/bootstrap-timepicker")
}

@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/bootstrap-timepicker")
<script type="text/javascript">



        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });
        jQuery.validator.methods["date"] = function (value, element) { return true; }
        $(".timepicker").timepicker({
            showInputs: true,
            defaultTime: false,
            format: 'dd-mm-yyyy'
        });

        $(document).ready(function () {
            $('#advsearchlist').hide();

            $(".ref").select2({});

            CallEmployee();
            CallSearchUser();
            CallProjectAll();
            CallTaskForProject();
        });

        $('body').on('change', '#ddlProject', function (e) {
            $('#ddlProTask').val(null).trigger('change');
            CallTaskForProject();
        });

        var oTable = $('#PoTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "pageLength": 50,
            responsive: true,
            "bLengthChange": false,
            "ajax": {
                "url": '/MaterialRequisition/GetMaterialRequisitionApproval',
                "data": function (data) {
                    data.BillNo = $('#BillNo').val();
                    data.FromDate = $('#FromDate').val();
                    data.ToDate = $('#ToDate').val();
                    data.supplier = $('#ddlSupplier').val();
                    data.RequestedBy = $('#ddlEmployee').val();
                    data.Stats = $('#Status').val();
                    data.user = $('#ddlCreatedBy').val();
                    data.Validity = $('#Validity').val();
                    data.appstat = $('#ApprovalStatus').val();
                    data.ProjectName = $('#ddlProject').val();
                    data.Task = $('#ddlProTask').val();
                    data.RemndrDate = $('#RemndToDate').val();
                    data.ref1 = $('#Ref1').val();
                    data.ref2 = $('#Ref2').val();
                    data.ref3 = $('#Ref3').val();
                    data.ref4 = $('#Ref4').val();
                    data.ref5 = $('#Ref5').val();
                },
                "type": "POST",
                "datatype": "json"

            },
            "order": [[0, "desc"]],
            "columnDefs": [{
                "targets": [12],
                "orderable": false
            }],
            "columns": [
                     {
                         "data": "MaterialRequisitionId", "name": "MaterialRequisitionId",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                { "data": "BillNo", "name": "BillNo" },
                { "data": "MRDate", "name": "MRDate", "render": function (data) { return convertToDate(data); } },
                { "data": "MRValidity", "name": "MRValidity", "render": function (data) { return convertToDate(data); } },
                { "data": "EmpName", "name": "EmpName" },
                //{
                //    "data": "ReminderDate", "name": "ReminderDate",
                //    "render": function (data)
                //    { return convertToDate(data); }
                //},
                {
                    "data": "ReminderDate", "name": "ReminderDate",
                    "render": function (data) {
                        if (data != null)
                            return convertToDate(data);
                        else
                            return "";
                    }
                },
                { "data": "user", "name": "user" },
                {
                    "name": "validity", "data": function (data) {
                        if (data.validity == "Expired") {
                            return '<i class="badge bg-red" style="font-size: small" >Expired</i>';
                        }
                        else {
                            return '<i class="badge bg-green" style="font-size: small" >Active</i></a>';
                        }
                    }
                },

                {
                    "name": "ApprovalStatus", "data": function (data, type, dataToSet) {
                        var status = "";
                        var cls = "";
                        if (data.app.length > 0 || (data.Approval == true && '@ViewBag.MLAMc' == 'active')) {
                            if (data.ApprovalStatus == "0") {
                                status = '<span class="badge bg-green">Approved</span>';
                            }
                            else if (data.ApprovalStatus == "1") {
                                status = '<span class="badge bg-red">Rejected</span>';
                            }
                            else if (data.ApprovalStatus == "2") {
                                status = '<span class="badge bg-orange">Pending</span>';
                            }
                            return '<a  class="Updation" onclick="details(' + data.MaterialRequisitionId + ')"  title="View Status">' + status + ' </a>';
                        } else { return null; }
                    }
