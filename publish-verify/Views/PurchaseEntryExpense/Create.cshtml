@model QuickSoft.ViewModel.PurchaseEntryViewModel
@{
    ViewBag.Title = "Create";
    ViewBag.SubTitle = "Purchase Entry";
    ViewBag.Active = "Transactions";
    long? chkSupp = Model.Supplier;
    var jewschk = ViewBag.JewCheck;
    var TimeOut = @ViewBag.TMOut;
    string IRateCheck = "inactive";
    string posfun = "";

}
<style>
    input[name="dltcheck"] {
        visibility: hidden !important;
    }

    .date {
        height: 34px !important;
    }
</style>
@if (User.IsInRole("Dev") || User.IsInRole("ReadOnly Item Rate"))
{
    IRateCheck = "active";
}
@using (Html.BeginForm("CreatePurchase", "PurchaseEntryExpense", FormMethod.Post, new { id = "purchaseform", role = "form" }))
{
<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">Create Purchase Entry</h3>
        <div class="pull-right">
            @if (@ViewBag.LastEntry != 0)
            {
                if (User.IsInRole("Dev") || User.IsInRole("Edit Purchase Entry"))
                {
                    <a class="btn bg-black no-border" href="/PurchaseEntryExpense/Edit/@ViewBag.LastEntry">
                        <i class="fa fa-step-backward"></i>
                    </a>
                }
            }
            <a class="btn bg-black no-border" style="display:none" href="javascript:void(0)" onclick="pullsales()">
                Pull Sales
            </a>
            @if (User.IsInRole("Dev") || User.IsInRole("Purchase List"))
            {
                <a class="btn btn-success no-border" href="/PurchaseEntryExpense">
                    <i class="fa fa-fw fa-history"></i>List
                </a>
            }
        </div>
    </div>
    @Html.AntiForgeryToken()
    @Html.ValidationSummary("", new { @class = "alert alert-danger" })
    @Html.HiddenFor(model => model.ConTypeId)
    @Html.HiddenFor(model => model.ConType)
    <input type="hidden" id="chkexcel" value="false" />
    <input type="hidden" id="SuperUserEdit" value="@ViewBag.SuperUserEditvalue" />
    <input type="hidden" id="procheck" value="@ViewBag.ProjChk" />
    <input type="hidden" id="LastSale" value="active" />
    <input type="hidden" id="LastPurchase" value="active" />
    <input type="hidden" id="LastSaleCount" value="" />
    <input type="hidden" id="LastPurchaseCount" value="" />
    <input type="hidden" id="VoucherType" value="Purchase" />
    <input type="hidden" id="batchcheck" value="@ViewBag.BatchWiseStock" />
    <input type="hidden" id="rackcheck" value="@ViewBag.RackWiseStock" />
    <div class="box-body">
        <input type="hidden" id="ROnlyRate" value="@IRateCheck" />
        <input type="hidden" id="SelApprovedBy" />
        <div class="row">
            @if (@ViewBag.BusinessType == "Scaffold")
            {
                <div class="form-group col-sm-2">
                    @Html.Label("Type", null, new { @class = "control-label" }) *
                    @Html.EnumDropDownListFor(model => model.PurchaseHireType, new { @class = "form-control", @onchange = "HType();", @required = "required", data_msg_required = "The Purchase Hire type field is required" })
                </div>
            }
            <div class="col-sm-2 form-group ">
                @Html.LabelFor(model => model.BillNo, new { @class = "control-label" }) *
                @Html.EditorFor(model => model.BillNo, new { htmlAttributes = new { @class = "form-control", @required = "required" } })
                @Html.HiddenFor(model => model.PENo)
            </div>
            <div class="col-sm-2 form-group col-xs-12">
                @Html.Label("Reference No", null, new { @class = "control-label" })
                @Html.Editor("ReferenceNo", new { htmlAttributes = new { @class = "form-control" } })

            </div>
            <div class="col-sm-2 form-group">
                @Html.LabelFor(model => model.PEDate, htmlAttributes: new { @class = "control-label" })*
                <div class="input-group date">
                    <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                    @Html.TextBoxFor(m => m.PEDate, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @required = "required" })
                </div>
            </div>
            @if (@ViewBag.EnableMCcheck == 0)
            {
                <div class="form-group col-md-2">
                    @Html.Label("Material Center", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlMC", (SelectList)ViewBag.MC, new { @class = "form-control input-sm", @onchange = "getAprovalby()" })
                </div>
            }
            <div class="col-sm-2 form-group">
                @Html.Label("Purchase Type", null, new { @class = "control-label" }) *
                @Html.DropDownListFor(m => m.PurchaseType, new SelectList(Model.PurchaseTypes, "Id", "Name"), new { id = "PurchaseType", @class = "form-control" })

            </div>
            <div class="col-sm-2 form-group">
                @Html.Label("Sales Executive", null, new { @class = "control-label" })
                @if (User.IsInRole("Dev") || User.IsInRole("Create Sales Executive"))
                {
                    <div class="input-group input-group-sm">
                        @if (Model.PECashier != null)
                        {
                            @Html.DropDownListFor(m => m.PECashier, (SelectList)ViewBag.Cashier, new { id = "ddlEmployee", @class = "form-control select2" })
                        }
                        else
                        {
                            @Html.DropDownListFor(m => m.PECashier, (SelectList)ViewBag.Cashier, "", new { id = "ddlEmployee", @class = "form-control select2" })

                        }
                        <span class="input-group-btn">
                            <button type="button" href="/SalesExecutive/AddSalesExecutive" class="modal-edit btn btn-success btn-flat"><i class="fa fa-1x fa-plus-circle"></i></button>
                        </span>
                    </div>
                }
                else
                {
                    if (Model.PECashier != null)
                    {
                        @Html.DropDownListFor(m => m.PECashier, (SelectList)ViewBag.Cashier, new { id = "ddlEmployee", @class = "form-control select2" })
                    }
                    else
                    {
                        @Html.DropDownListFor(m => m.PECashier, (SelectList)ViewBag.Cashier, "", new { id = "ddlEmployee", @class = "form-control select2" })
                    }
                }
            </div>
            <div class="col-sm-2 form-group">
                @Html.Label("Payment Type", null, new { @class = "control-label" }) *
                @Html.EnumDropDownListFor(model => model.SupplierType, new { @class = "form-control" }) @*, @onchange = "suppliertype()*@
            </div>
            @*<div class="clearfix"></div>*@
            <div class="col-sm-2 form-group">
                @Html.Label("Supplier Name", null, new { @class = "control-label" }) *
                @if (User.IsInRole("Dev") || User.IsInRole("Create Supplier"))
                {
                    <div class="input-group input-group-sm">
                        @if (chkSupp.GetValueOrDefault() != 0)
                        {
                            @Html.DropDownListFor(m => m.Supplier, (SelectList)ViewBag.Supp, new { id = "ddlSupplier", @class = "form-control select2", @required = "required", @onchange = "GetSupplierMail()" })
                        }
                        else
                        {
                            @Html.DropDownListFor(m => m.Supplier, (SelectList)ViewBag.Supp, "", new { id = "ddlSupplier", @class = "form-control select2", @required = "required", @onchange = "GetSupplierMail()" })
                        }
                        <span class="input-group-btn">
                            <button type="button" href="/Supplier/AddSupplier" class="modal-create btn btn-success btn-flat"><i class="fa fa-1x fa-plus-circle"></i></button>
                        </span>
                    </div>
                }
                else
                {
                    if (chkSupp.GetValueOrDefault() != 0)
                    {
                        @Html.DropDownListFor(m => m.Supplier, (SelectList)ViewBag.Supp, new { id = "ddlSupplier", @class = "form-control select2", @required = "required", @onchange = "GetSupplierMail()" })
                    }
                    else
                    {
                        @Html.DropDownListFor(m => m.Supplier, (SelectList)ViewBag.Supp, "", new { id = "ddlSupplier", @class = "form-control select2", @required = "required", @onchange = "GetSupplierMail()" })
                    }
                }
            </div>
            <div class="col-sm-2 form-group">
                @Html.Label("Email Address", null, new { @class = "control-label" })
                @Html.TextBoxFor(m => m.suppEmailId, new { @class = "form-control" })
            </div>



            @if (@ViewBag.BranchCheck == 0)
            {
                <div class="form-group col-sm-2">
                    @Html.Label("Branch", null, new { @class = "control-label" })
                    @Html.DropDownListFor(m => m.Branch, (SelectList)ViewBag.SetBranch, new { id = "ddlBranch", @class = "form-control select2" })
                </div>
            }
            @if (@ViewBag.EnableCurrency == 0)
            {
                <div class="form-group col-sm-2">
                    @Html.LabelFor(model => model.Currency, new { @class = "control-label" })
                    @Html.DropDownListFor(m => m.Currency, (SelectList)ViewBag.CurrencyVal, new { id = "ddlCurrency", @class = "form-control select2" })
                </div>
                <div class="form-group col-sm-2">
                    @Html.LabelFor(model => model.ConvertionRate, new { @class = "control-label" })
                    @Html.EditorFor(model => model.ConvertionRate, new { htmlAttributes = new { @class = "form-control", @onchange = "FCCalculation();" } })
                </div>
            }
            @if (@ViewBag.MLAPEntry == 0 && @ViewBag.StockTrnsfrUpdate == 0)
            {
                <div class="form-group col-sm-2" style="pointer-events: none;">
                    @Html.Label("Approved By", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlApprovedBy", (SelectList)ViewBag.ApproveBy, "", new { @class = "form-control select2", @name = "ddlApprovedBy[]", @multiple = "multiple" })
                </div>
            }
            else if (@ViewBag.MLAPEntry == 0 && @ViewBag.StockTrnsfrUpdate != 0)
            {
                <div class="form-group col-sm-2">
                    @Html.Label("Approved By", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlApprovedBy", (SelectList)ViewBag.ApproveBy, "", new { @class = "form-control select2", @name = "ddlApprovedBy[]", @multiple = "multiple" })
                </div>
            }

            @if (Model.CMRNoteNo != null && Model.CMRNoteNo != 0)
            {
                <div class="form-group col-sm-2">
                    @Html.Label("MR Note No", null, new { @class = "control-label" })
                    @Html.EditorFor(model => model.CMRNoteNo, new { htmlAttributes = new { @class = "form-control", @required = "required", @readonly = "readonly" } })
                </div>
            }
            @if (Model.CPorderNo != null && Model.CPorderNo != 0)
            {
                <div class="form-group col-sm-2">
                    @Html.Label("Purchase Order", null, new { @class = "control-label" })
                    @Html.EditorFor(model => model.CPorderNo, new { htmlAttributes = new { @class = "form-control", @required = "required", @readonly = "readonly" } })
                </div>
            }
            @if (Model.CPQuotNo != null && Model.CPQuotNo != 0)
            {
                <div class="form-group col-sm-2">
                    @Html.Label("Purchase Quotation No", null, new { @class = "control-label" })
                    @Html.EditorFor(model => model.CPQuotNo, new { htmlAttributes = new { @class = "form-control", @required = "required", @readonly = "readonly" } })
                </div>
            }
            @if (Model.CMReqNo != null && Model.CMReqNo != 0)
            {
                <div class="form-group col-sm-2">
                    @Html.Label("MR No", null, new { @class = "control-label" })
                    @Html.EditorFor(model => model.CMReqNo, new { htmlAttributes = new { @class = "form-control", @required = "required", @readonly = "readonly" } })
                </div>
            }
            @if (@ViewBag.BusinessType == "Scaffold")
            {
                <div id="HireType">
                    <div class="form-group col-sm-2">
                        @Html.LabelFor(m => m.CrossHireType, new { @class = "control-label" }) *
                        @Html.DropDownListFor(m => m.CrossHireType, (SelectList)ViewBag.HiType, new { id = "ddlHType", @class = "form-control select2", @required = "required", data_msg_required = "The Hire type field is required" })
                    </div>
                    <div class="form-group col-md-2">
                        @Html.Label("From Date", null, new { @class = "control-label" }) *
                        <div class="input-group date">
                            @Html.TextBoxFor(m => m.FromDate, "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off", @onchange = "DateSet();", @required = "required", data_msg_required = "The Start Date field is required" })
                            <div class="input-group-addon">
                                <i class="fa fa-calendar"></i>
                            </div>
                        </div>
                    </div>
                    <div class="form-group col-md-2">
                        @Html.Label("To Date", null, new { @class = "control-label" }) *
                        <div class="input-group date">
                            @Html.TextBoxFor(m => m.ToDate, "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off", @required = "required", data_msg_required = "The End Date field is required" })
                            <div class="input-group-addon">
                                <i class="fa fa-calendar"></i>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                @Html.HiddenFor(model => model.PurchaseHireType, new { @class = "form-control hidden" })
            }

            @if (Model.convertBill != null && Model.convertBill != "")
            {
                <div class="form-group col-sm-2">
                    @Html.LabelFor(m => m.convertFrom, Model.convertFrom, new { @class = "control-label" })
                    @Html.EditorFor(model => model.convertBill, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly" } })
                </div>
            }
            <div class="col-md-3 col-xs-12 form-group top-10">
                <input type="file" id="excelfile" />
                <div class="pull-right info">
                    <i class="fa fa-question-circle" aria-hidden="true"></i>
                    <div class="callout callout-danger info-msg">
                        <ul>
                            <li>Maximum Number of Item on an Excel Sheet is '100'</li>
                            <li>Item Name or Code is Mandatory</li>
                            <li>Predefined Units on system are Gms., Kgs., Metre, Pcs. and Box</li>
                            <li>For Item With Vat - 5% mention Tax as 5 other wise it will take tax as "Zero Rated" </li>
                            <li>All Fields Are Case Sensitive</li>
                        </ul>
                    </div>

                </div>
                <input type="button" id="upexcel" class="btn btn-primary btn-xs" value="Item Excel Upload" onclick="ExportToTable()" />
                <input type="button" id="dwformat" class="btn btn-default btn-xs" value="Download Format" />
            </div>
            <div class="col-md-3 col-xs-12">
                @Html.Label("Purchase Status", null, new { @class = "control-label" })
                <div class="input-group">


                    @Html.DropDownList("PurchaseStatus", new SelectList(new List<SelectListItem>
                           {
                            new SelectListItem() {Text = "Open", Value="0"},
                            new SelectListItem() {Text = "Closed", Value="1"},
                           }, "Value", "Text"), new { @class = "form-control input-sm", @name = "Emirate" })
                </div>

            </div>
        </div>
        <div class="row">
            @if (Model.FieldMap.Count > 0)
            {
                for (int i = 0; i < Model.FieldMap.Count; i++)
                {
                    <div class="form-group col-sm-2 col-xs-12 hide1">
                        <label class="control-label temp2" for="FieldName">
                            @Model.FieldMap[i].FieldName
                            @if (i == 0)
                            {
                                @*<a href="/OptionalFieldUpdate/" target="_new"><i class="fa fa-lg fa-edit"></i></a>*@
                            }

                        </label>
                        @if (Model.FieldMap[i].Type == "Dropdown")
                        {
                            if (Model.FieldMap[i].Field == "Ref1")
                            {
                                @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef1, new { @id = "Ref1", @class = "form-control input-sm select2 ref" })

                            }
                            if (Model.FieldMap[i].Field == "Ref2")
                            {
                                @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef2, new { @id = "Ref2", @class = "form-control input-sm select2 ref" })
                            }
                            if (Model.FieldMap[i].Field == "Ref3")
                            {
                                @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef3, new { @id = "Ref3", @class = "form-control input-sm select2 ref" })
                            }
                            if (Model.FieldMap[i].Field == "Ref4")
                            {
                                @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef4, new { @id = "Ref4", @class = "form-control input-sm select2 ref" })
                            }
                            if (Model.FieldMap[i].Field == "Ref5")
                            {
                                @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef5, new { @id = "Ref5", @class = "form-control input-sm select2 ref" })
                            }
                        }
                        else
                        {
                            <input class="form-control select2" id="@Model.FieldMap[i].Field" name="@Model.FieldMap[i].Field" type="text" value="">
                        }
                        @*<label class="control-label small-standalone-label" for="FieldName"> @Model.FieldMap[i].FieldName</label>*@
                    </div>
                }
            }
        </div>
        <div>
         
            @if (@ViewBag.DisPercheck == 0)
            {
                <div class="row">
                    <div class="form-group col-md-8"></div>
                    <div class="form-group col-md-2">
                        @Html.LabelFor(model => model.DisPercent, new { @class = "control-label" })
                        @Html.EditorFor(model => model.DisPercent, new { htmlAttributes = new { @class = "form-control" } })
                    </div>
                    <div class="form-group col-md-2">
                        @Html.LabelFor(model => model.DiscAmount, new { @class = "control-label" })
                        @Html.EditorFor(model => model.DiscAmount, new { htmlAttributes = new { @class = "form-control" } })
                    </div>
                </div>
            }
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        @Html.LabelFor(model => model.Remarks, new { @class = "control-label" })
                        @Html.TextAreaFor(model => model.Remarks, new { @class = "form-control", @placeholder = "Remarks", @rows = 2 })
                    </div>
                    <div class="form-group">
                        @Html.TextAreaFor(model => model.PENote, new { @class = "form-control", @placeholder = "Terms And Conditions", @rows = 4 })
                    </div>
                    @if (@ViewBag.PrintLayout == 0)
                    {
                        <div class="form-group col-sm-5">
                            @Html.Label("Print Layout", null, new { @class = "control-label" })
                            @Html.DropDownListFor(m => m.PrintLayout, (SelectList)ViewBag.printlay, new { id = "ddlPrintlayout", @class = "form-control select2" })
                        </div>
                    }
                </div>
                <div class="col-md-6">
                    <div class="row">
                        <div class="col-md-12">
                          Taxable Amount  <input type="text" id="totaltxt" value="0.00" onchange="updatetotal(this)"/>
                        </div>
                        <label id="total" style="display:none;"/>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover" id="billsundry">
                            <thead>
                                <tr>
                                    <th class="text-center">S/N</th>
                                    <th class="text-center">Bill Sundry</th>
                                    <th class="text-center">Value</th>
                                    <th class="text-center">Type</th>
                                    <th class="text-center">Amount</th>
                                    <th class="text-center">Action</th>
                                </tr>
                            </thead>
                            <tbody id="addbillsundry"></tbody>
                        </table>
                    </div>
                </div>
                <div class="col-md-6"></div>
                <div class="col-md-6">

                    @if (@ViewBag.EnableCurrency == 0)
                    {
                        <div class="form-group col-md-6 no-padding">
                            <div class="form-group col-md-6 no-padding">
                                @Html.Label("FC:", null, new { @class = "control-label" })
                                @Html.EditorFor(model => model.FCTotal, new { htmlAttributes = new { @id = "FCTotal", @class = "form-control text-right", @readonly = "readonly" } })
                            </div>
                        </div>
                    }
                    <div class="form-group col-md-6 no-paddingleft"></div>
                    <div class="form-group col-md-6 no-padding">
                        @Html.Label("Grand Total :", null, new { @class = "control-label" })
                        @Html.EditorFor(model => model.PEGrandTotal, new { htmlAttributes = new { @id = "GrandTotal", @class = "form-control text-right", @value = "0.00", @readonly = "readonly" } })
                    </div>
                    <div class="form-group col-md-6 hidden no-paddingleft" id="amountpaid">
                        @Html.Label("Paid Amount:", null, new { @class = "control-label" })
                        @Html.EditorFor(model => model.PEPaidAmount, new { htmlAttributes = new { @id = "PaidAmount", @onkeyup = "paidamount_change();", @class = "form-control text-right", @value = "0", @placeholder = "0.00" } })

                    </div>
                    <div class="form-group col-md-6 hidden no-padding" id="amountdue">
                        @Html.Label("Due :", null, new { @class = "control-label" })
                        @Html.EditorFor(model => model.PEDueAmount, new { htmlAttributes = new { @id = "DueAmount", @class = "form-control text-right", @value = "0.00", @readonly = "readonly" } })
                        <input type="hidden" value="" class="ItemCount" name="ItemCount" id="ItemCount">
                    </div>

                    <div class="form-group col-md-12">
                        @Html.Label("Documents", null, new { @class = "control-label" })
                        <div class="file-loading">
                            <input id="input-24" name="input24[]" type="file" multiple>
                        </div>
                    </div>
                </div>
                <div class="form-group no-padding text-right">
                    <div class="checkbox-inline">
                        <input class="checkbox" data-val="true" id="hideheader" name="hideheader" type="checkbox" value="true">
                        <label class="control-label" for="hideheader">Hide Header In Print</label>
                    </div>
                </div>
                <div class="col-md-6"></div>
                <div class="col-md-6">
                    <div class="form-group pull-right">
                        <button type="submit" id="save" class="btn btn-success">
                            <span class="glyphicon glyphicon-floppy-disk"></span> Save
                        </button>
                        <button type="submit" id="print" class="btn btn-success">
                            <span class="glyphicon glyphicon-print"></span> Save And Print
                        </button>
                        @if (@ViewBag.CheckMail == 0)
                        {
                            <button type="submit" id="sendmail" class="btn btn-success">
                                <span class="glyphicon glyphicon-envelope"></span> Save And Mail
                            </button>
                        }
                        <button type="button" class="btn btn-warning" onclick="@("window.location.href='/PurchaseEntryExpense/Index'");">Cancel</button>
                        <input type="hidden" value="@ViewBag.StartDate" class="Start" name="Start" id="Start">
                        <input type="hidden" value="@ViewBag.EndDate" class="End" name="End" id="End">
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
    <div id="cont" class="hidden">
        <svg id="barcode"></svg>
    </div>
    <span class="hidden" id="cname">@ViewBag.CName</span>
    <div id="RackStock"></div>
    <div id="batchStock"></div>
    <div id="LastSalePur"></div>
}


@{
    var Modelv = "modal-large";
    if (@ViewBag.ItemPriceInPurchase == 0)
    {
        @Html.Partial("../Common/_ItemPriceUpdater")
    }
}
@Html.Partial("../Common/_ModalCreate", @Modelv)
@Html.Partial("../Common/_ModalEdit", @Modelv)
@Html.Partial("../Common/_ModeItemCreate")
@Html.Partial("_printBarcode")

@if (ViewBag.POS == 0 && ViewBag.BusinessType == "DeliveryManagement")
{
    posfun = "PrintPOSInvoice(e, \"POSInvoice1\");";
    @Html.Action("POSInvoice", "InvoiceLayout", new { type = "Purchase" })
}
else
{
    posfun = "PrintInvoice(e, \"sales\",\"inactive\",\"PurchaseEntry\");";
    @*@Html.Partial("_Invoice")*@
    @Html.Action("invoice", "InvoiceLayout", new { type = "Purchase" })
}

@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/bootstrap-fileinput")
    @Styles.Render("~/css/bootstrap-fileinput-rtl")
    @if (!(ViewBag.POS == 0 && ViewBag.BusinessType == "DeliveryManagement"))
    {
        @Styles.Render("~/css/print")
    }
}
