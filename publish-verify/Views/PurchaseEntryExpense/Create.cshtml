        $('#purchaseform').on('submit', function (e) {
            e.preventDefault();
            //check if exists VAT in Bill-Sundry
            var vatexist = 0;
            $("#addbillsundry tr").each(function (e) {
                var type = parseFloat($(this).find('.bsname').val());
                if (type == "4") { vatexist++; } else { vatexist = vatexist; }
            });
            var stype = $("#PurchaseType").val();
            if (stype == 3 && vatexist == 0)//
            {
                alert("Please Select VAT in Bill-Sundry..!!");
            } else {


                if ($("#purchaseform").valid()) {
                    var CSEmail = $('#suppEmailId').val();
                    var chkexcel = $("#chkexcel").val();

                    var fnval = $('input[type="submit"], button[type="submit"]', this).filter(':focus').attr('id');
                    if (fnval == "sendmail" && CSEmail == "") {
                        $('.ajax_response', res_danger).text("Customer Email Address Not Found..!!");
                        $('.AlertDiv').prepend(res_danger);
                    }
                    else {
                        if (ItemPriceInPurchase == "active" && chkexcel == "false") {
                            submitForm(fnval);
                        }
                        else {
                            submitForm(fnval);
                        }
                    }
                }
            }
        });


    function GeneratePriceTablenew(fnval) {
