@{
    ViewBag.Title = "Search Purchase Entry";
    ViewBag.SubTitle = "Purchase Reports";
    ViewBag.Active = "Reports";
    string actData = "";
}
<div class="box box-default" id="PReport">
    <input type="hidden" id="cname" value="@ViewBag.CName" />
    <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
    <input type="hidden" id="invoiceno" value="@ViewBag.InvoiceNo" />
    <input type="hidden" id="fromdate" value="@ViewBag.fromdate" />
    <input type="hidden" id="todate" value="@ViewBag.todate" />
    <input type="hidden" id="matcenter" value="@ViewBag.EnableMCcheck" />
    <div class="box-header with-border">
        <h3 class="box-title">View Purchase Report</h3>
    </div>
    <div class="box-body">
        <div class="box-body">
            <table class="display table table-bordered" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td>S/N</td>
                        <td>Invoice No.</td>
                        <td>PO No.</td>
                        <td>Date</td>
                        <td>Supplier</td>
                        @*<td>TRN</td>*@
                        <td class="text-right">Taxable amount</td>

                        <td class="text-right">Discount</td>
                        <td class="text-right">Roundoff(-)</td>
                        <td class="text-right">Roundoff(+)</td>
                        <td class="text-right">Tax</td>
                        <td class="text-right">Grand Total</td>
                        @*<td class="headeralign">Total Amt</td>
                            <td class="headeralign">Paid Amt</td>
                            <td class="headeralign">Balance Amt</td>*@
                        <td>Sales Executive</td>
                        <td id="matcol">Material Center</td>
                    </tr>
                </thead>
                <tbody></tbody>
                <tfoot>
                    <tr>
                        <th>Total:</th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
@section Scripts {
    <script type="text/javascript">
        $(document).ready(function () {
            var oTable = $('#UserTable').DataTable({
                "processing": true, // for show progress bar
                "serverSide": true, // for process server side
                "filter": false, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
                // "bStateSave": true,
                responsive: true,
                "paging": true,
                "pageLength": 25000,
                "bLengthChange": false,
                "ordering": false,
                "ajax": {
                    "url": '/PurchaseReport/GetAllpur',
                    "data": {
                        supplier: getQueryString1('ddlSupplier'), peno: getParameterByName('InvoiceNo'),
                        SalesExecutive: getParameterByName('ddlEmployee'), type: getParameterByName('ddlType'),
                        fromdate: getParameterByName('From'), todate: getParameterByName('To'), ddlMC: getParameterByName('ddlMC'), Taxtype: getParameterByName('ddlTaxType'),
                    },
                    "type": "POST",
                    "datatype": "json"

                },
                "order": [[0, "desc"]],
                "columns": [
                     {
                         "data": "PurchaseEntryId", "name": "PurchaseEntryId",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                    { "data": "BillNo", "name": "BillNo" },
                    //{
                    //    "name": "PONo",
                    //     "data": function (data) {
                    //         if (data.PONo == 0) {
                    //             return " ";
                    //         } else {
                    //             return data.PONo;
                    //         }
                    //     }, "sClass": "numberleft"
                    // },
                    {
                        "name": "PONo", "data": function (data) {
                            if (data.PONo == 0) {
                                return " ";
                            } else {
                                @{
                                 actData += "'<a href=\"/PurchaseEntry/Edit/'+ data.PurchaseEntryId +'\" target=\"_new\">'+ data.PONo +'</a>' ";
                             }
                            }
                            return @Html.Raw(actData);
                        }
                    },
                    { "data": "PEDate", "name": "PEDate", "render": function (data) { return convertToDate(data); } },
                    { "data": "Supplier", "name": "Supplier" },
                    //{ "data": "TaxRegNo", "name": "TaxRegNo" },
                    //{
                     //    "name": "SupplierType",
                     //    "data": function (data) {
                     //        if (data.SupplierType == 0) {
                     //            return "Credit";
                     //        } else {
                     //            return  "Cash";
                     //        }
                     //    }
                     //},
                     { "data": "taxableAmt", "name": "taxableAmt", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },

                    { "data": "discount", "name": "discount", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                    { "data": "roundoffmin", "name": "roundoffmin", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                    { "data": "roundoffplus", "name": "roundoffplus", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                    { "data": "Debit", "name": "Debit", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                    { "data": "PEGrandTotal", "name": "PEGrandTotal", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                    //{ "data": "PEPaidAmount", "name": "PEPaidAmount", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                    //{ "data": "PEBalanceAmount", "name": "PEBalanceAmount", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },


                //{ "data": "lastpaydate", "name": "lastpaydate", "render": function (data) { return convertToDate(data); } },
                   { "data": "EmpName", "name": "EmpName" },
                   { "data": "MCName", "name": "MCName" },
                   //{ "data": "User", "name": "User" },
                   // { "data": "Branch", "name": "Branch" }
                ],
                buttons: [//'copy', 'csv', 'excel', 'pdf', 'print'
                'colvis',
                    {
                        extend: 'print',//
                        exportOptions: {
                            columns: ':visible'
                        },
                        title: "",
                        footer: true,
                        filename: function () {
                            return 'Purchase Report';
                        },
                        message: function()
                        {
                            var head = '<table class="tblcompact table table-bordered"><thead>' +
                            ' <tr><th class="text-center"><h3 style="margin-top: 0px;">' + $('#cname').val() + '</h3>' + $('#caddress').val() + '<h4>Purchase Report</h4></th></tr>' +
                            ' <tr><th><span class="text-left">Invoice No : ' + $('#invoiceno').val() + ' </span><span class="text-right pull-right"> From :  ' + $('#fromdate').val() + ' To :' + $('#todate').val() + '</span></th></tr></thead><tbody><tr><td>';
                            return head;
                        },
                        customize: function (win) {
                            // $(win.document.body)
                            //.css('font-size', '10pt')
                            //.css('padding', '1px');
                            $(win.document.body).find('table, th,tr, td ')
                               // .css('border', 'inherit')
                                .css('font-size', '10pt')
                                .css('padding', '5px')
                                .addClass('compact');
                            $(win.document.body).append('</td></tr></tbody>')

                        }
                    }, 'copy', 'csv', //'excel',
                    {
                        extend: 'excel',//
                        title: "",
                        footer: true,
                        filename: function () {
                            return 'Purchase Report';
                        },
                        message: function () {
                            var head = '' + $('#cname').val() + '\n' +
                             '' + $('#caddress').val() + '\n' +
                             ' Purchase Report \n' +
                             'Invoice No : ' + $('#invoiceno').val() + '\n' +
                             'From :  ' + $('#fromdate').val() + ' To :' + $('#todate').val() + '';
                            return head;
                        },
                        pageSize: 'A4',
                        exportOptions: {
                            columns: ':visible'
                        },
                    },
                    {
                        extend: 'pdf',//
                        title: "",
                        orientation: 'landscape',
                        footer: true,
                        filename: function () {
                            return 'Purchase Report';
                        },
                        message: function () {
                            var head = '' + $('#cname').val() + '\n' +
                             '' + $('#caddress').val() + '\n' +
                             ' Purchase Report \n' +
                             'Invoice No : ' + $('#invoiceno').val() + '\n' +
                             'From :  ' + $('#fromdate').val() + ' To :' + $('#todate').val() + '';
                            return head;
                        },
                        pageSize: 'A4',
                        exportOptions: {
                            columns: ':visible'
                        },
                        customize: function (doc) {
                            doc.pageMargins = [10, 10, 10, 10];
                            doc.defaultStyle.fontSize = 10;
                            doc.styles.tableHeader.fontSize = 10;
                            doc.styles.title.fontSize = 12;
                            // Header font and bg color
                            doc.styles.tableHeader.fillColor = '#d3d3d3';
                            doc.styles.tableHeader.color = 'black';
                            // Remove spaces around page title
                            doc.content[0].text = doc.content[0].text.trim();

                            doc.styles['td:nth-child(2)'] = {
                                width: '100%',
                                'max-width': '100%'
                            }
                            //doc.content[1].table.widths = Array(doc.content[1].table.body[0].length + 1).join('*').split('');

                          //  doc.content[1].table.widths = [
                          //'10%',
                          //'10%',
                          //'10%',
                          //'10%',
                          //'15%',
                          //'10%',
                          //'10%',
                          //'10%',
                          //'15%'
                          //  ]

                            var objLayout = {};
                            // Horizontal line thickness
                            objLayout['hLineWidth'] = function (i) { return .5; };
                            // Vertikal line thickness
                            objLayout['vLineWidth'] = function (i) { return .5; };
                            //// Horizontal line color
                            //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                            //// Vertical line color
                            //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                            // Left padding of the cell
                            objLayout['paddingLeft'] = function (i) { return 4; };
                            // Right padding of the cell
                            objLayout['paddingRight'] = function (i) { return 4; };
                            // Inject the object in the document
                            doc.content[1].layout = objLayout;
                            // Footer font and bg color
                            doc.styles.tableFooter.fillColor = '#d3d3d3';
                            doc.styles.tableFooter.color = 'black';
                        }


                    },

                ],
                sDom: "lBfr<'datatable-scroll't>ip",
                "lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                "footerCallback": function (row, data, start, end, display) {
                    var api = this.api(), data;

                    // Remove the formatting to get integer data for summation
                    var intVal = function (i) {
                        return typeof i === 'string' ?
                            i.replace(/[\$,]/g, '') * 1 :
                            typeof i === 'number' ?
                            i : 0;
                    };

                    // Total over all pages
                    total = api
                        .column(7)
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Total over this page
                    pageTotal = api
                        .column(7, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update footer
                    $(api.column(7).footer()).html(
                         pageTotal.toFixed(2)
                        //'$' + pageTotal + ' ( $' + total + ' total)'
                    );




                    total = api
                        .column(8)
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Total over this page
                    pageTotal = api
                        .column(8, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update footer
                    $(api.column(8).footer()).html(
                        pageTotal.toFixed(2)
                        //'$' + pageTotal + ' ( $' + total + ' total)'
                    );



                    total = api
                        .column(9)
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Total over this page
                    pageTotal = api
                        .column(9, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update footer
                    $(api.column(9).footer()).html(
                        pageTotal.toFixed(2)
                        //'$' + pageTotal + ' ( $' + total + ' total)'
                    );




                    total = api
                        .column(10)
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Total over this page
                    pageTotal = api
                        .column(10, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update footer
                    $(api.column(10).footer()).html(
                        pageTotal.toFixed(2)
                        //'$' + pageTotal + ' ( $' + total + ' total)'
                    );




                    // Total over all pages
                    total = api
                        .column(5)
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Total over this page
                    pageTotal = api
                        .column(5, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update footer
                    $(api.column(5).footer()).html(
                         pageTotal.toFixed(2)
                        //'$' + pageTotal + ' ( $' + total + ' total)'
                    );

                    // Total over all pages
                    total = api
                        .column(6)
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Total over this page
                    pageTotal = api
                        .column(6, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update footer
                    $(api.column(6).footer()).html(
                         pageTotal.toFixed(2)
                        //'$' + pageTotal + ' ( $' + total + ' total)'
                    );

                    var table = $('#UserTable').DataTable();
                    if (!table.data().any()) {
                        $('#UserTable tfoot').hide();
                    } else {
                        $('#UserTable tfoot').show();
                    }
                }

            });
            var type = $('#invoiceno').val();
            if (type != 'All') {
                var column1 = oTable.column(1);
                column1.visible(false);
            } else {
                var column1 = oTable.column(1);
                column1.visible(true);
            }

            var matcet = $('#matcenter').val();
            if (matcet == "inactive") {
                var column1 = oTable.column(9);
                column1.visible(false);
            } else {
                var column1 = oTable.column(9);
                column1.visible(true);
            }

            $('#UserTable tbody').on('click', 'tr', function () {
                if ($(this).hasClass('selected')) {
                    $(this).removeClass('selected');
                }
                else {
                    oTable.$('tr.selected').removeClass('selected');
                    $(this).addClass('selected');
                    $(this).addClass('dataTables_row');
                }
            });

            //re direct to purchase edit
            $('#UserTable tbody').on('dblclick', 'tr', function (e) {
                var data = oTable.row(this).data();
                var url = "/PurchaseEntry/Edit/" + data.PurchaseEntryId + "";
                $(location).attr('href', url);
            });

        });
    </script>
}