@model QuickSoft.Models.InvoiceField
@{
    ViewBag.Title = "Edit Invoice Field";
    ViewBag.SubTitle = "Invoice Field";
    ViewBag.Active = "Settings";
}
<div class="box box-info">
    @using (Html.BeginForm("Edit", "InvoiceLayout", FormMethod.Post, new { id = "createForm", role = "form" }))
    {
        <div class="box-header with-border">
            <h3 class="box-title">Edit Invoice Field</h3>
            <div class="pull-right">
                <a class="btn btn-success no-border" href="/InvoiceLayout">
                    <i class="fa fa-fw fa-history"></i> Invoice Field
                </a>
            </div>
        </div>
        <div class="box-body">
            @Html.AntiForgeryToken()
            @Html.ValidationSummary("", new { @class = "alert alert-danger AlertDiv" })

            <div class="form-group col-md-4">
                @Html.LabelFor(model => model.Type, htmlAttributes: new { @class = "control-label" })*
                @Html.EditorFor(model => model.Type, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Type", @required = "required" } })
            </div>
            <div class="form-group col-md-4">
                @Html.LabelFor(model => model.Section, htmlAttributes: new { @class = "control-label " })
                @Html.EditorFor(model => model.Section, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Section" } })
            </div>
            <div class="form-group col-md-4">
                @Html.LabelFor(model => model.Position, htmlAttributes: new { @class = "control-label " })
                @Html.EditorFor(model => model.Position, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Position" } })
            </div>
            <div class="form-group col-md-4">
                @Html.LabelFor(model => model.Value, htmlAttributes: new { @class = "control-label " })
                @Html.EditorFor(model => model.Value, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Value" } })
            </div>
            <div class="form-group col-md-4">
                @Html.LabelFor(model => model.Order, htmlAttributes: new { @class = "control-label " })
                @Html.EditorFor(model => model.Order, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Order" } })
            </div>
            <div class="form-group col-md-4">
                @Html.LabelFor(model => model.Lang, htmlAttributes: new { @class = "control-label " })
                @Html.EditorFor(model => model.Lang, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Language" } })
            </div>
            <div class="form-group col-md-4">
                @Html.LabelFor(model => model.Status, htmlAttributes: new { @class = "control-label" })
                @Html.EnumDropDownListFor(model => model.Status, new { @class = "form-control" })
            </div>
            <div class="form-group col-md-12 pull-left">
                <div class="col-md-12">
                </div>
            </div>
        </div>
            <div class="box-footer clearfix">
                <input type="submit" class="btn btn-info col-sm-offset-5" value="Save" id="btnSubmit" />
                <input type="button" class="btn btn-default" value="Cancel" onclick="@("window.location.href='/InvoiceLayout/Index'");" />
            </div>
    }

</div>
