@model QuickSoft.ViewModel.PackinglistViewModel
@{
    Layout = null;
}
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Packing List Details</h4>
</div>
<div class="modal-body">
    <div class="box box-info">
        <div class="box-body">
            <div class="row">
                <div class="col-sm-2 form-group">
                    @Html.Label("Bill No :", null, new { @class = "control-label" })
                    @Html.DisplayFor(m => m.BillNo)
                </div>
                <div class="col-sm-2 form-group ">
                    @Html.Label("LPO :", null, new { @class = "control-label" })
                    @Html.DisplayFor(m => m.LPO)
                </div>
                <div class="col-sm-2 form-group">
                    @Html.Label("Date :", null, new { @class = "control-label" })
                    @Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.PLDate))
                </div>
                <div class="col-sm-2 form-group">
                    @Html.Label("Sales Executive :", null, new { @class = "control-label" })
                    @Html.DisplayFor(m => m.EmployeeName)
                </div>
                <div class="col-sm-2 form-group">
                    @Html.Label("Customer Name :", null, new { @class = "control-label" })
                    @Html.DisplayFor(m => m.CustomerName)
                </div>
                <div class="col-sm-2 form-group">
                    @Html.Label("HSCode :", null, new { @class = "control-label" })
                    @Html.DisplayFor(m => m.HSCode)
                </div>
                <div class="col-sm-12 form-group">
                    @if (Model.Emp != null && Model.Emp.Count() > 0)
                    {
                        @Html.Label("Approved By:", null, new { @class = "control-label" })
                        bool CHECK = true;
                        foreach (var Ext in Model.Emp)
                        {
                            var EmpName = "";
                            if (CHECK == true)
                            {
                                EmpName = @Ext.EmpName;
                                CHECK = false;
                            }
                            else
                            {
                                EmpName = ", " + @Ext.EmpName;
                            }

                            @Html.Label(@EmpName, new { @style = "font-weight:normal" })
                        }
                    }
                </div>
                @if (Model.FieldMap.Count > 0)
                {
                    for (int i = 0; i < Model.FieldMap.Count; i++)
                    {
                        <div class="form-group col-sm-2">

                            @if (Model.FieldMap[i].FieldName != "" && Model.FieldMap[i].Field == "Ref1")
                            {
                                <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName :</label>
                                @Html.DisplayFor(m => m.Ref1)
                            }
                            @if (Model.FieldMap[i].FieldName != "" && Model.FieldMap[i].Field == "Ref2")
                            {
                                <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName :</label>
                                @Html.DisplayFor(m => m.Ref2)
                            }
                            @if (Model.FieldMap[i].FieldName != "" && Model.FieldMap[i].Field == "Ref3")
                            {
                                <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName :</label>
                                @Html.DisplayFor(m => m.Ref3)
                            }
                            @if (Model.FieldMap[i].FieldName != "" && Model.FieldMap[i].Field == "Ref4")
                            {
                                <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName :</label>
                                @Html.DisplayFor(m => m.Ref4)
                            }
                            @if (Model.FieldMap[i].FieldName != "" && Model.FieldMap[i].Field == "Ref5")
                            {
                                <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName :</label>
                                @Html.DisplayFor(m => m.Ref5)
                            }
                        </div>
                    }
                }
                @if (Model.FieldMap.Count > 0)
                {
                    for (int i = 0; i < Model.FieldMap.Count; i++)
                    {
                        <div class="form-group col-sm-2">
                            <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName :</label>
                            @if (Model.FieldMap[i].Field == "Ref1")
                            {
                                @Html.DisplayFor(m => m.Ref1)
                            }
                            @if (Model.FieldMap[i].Field == "Ref2")
                            {
                                @Html.DisplayFor(m => m.Ref2)
                            }
                            @if (Model.FieldMap[i].Field == "Ref3")
                            {
                                @Html.DisplayFor(m => m.Ref3)
                            }
                            @if (Model.FieldMap[i].Field == "Ref4")
                            {
                                @Html.DisplayFor(m => m.Ref4)
                            }
                            @if (Model.FieldMap[i].Field == "Ref5")
                            {
                                @Html.DisplayFor(m => m.Ref5)
                            }
                        </div>
                    }
                }
                <div class="clearfix"></div>
            </div>
            <div>
                <div class="table-responsive">
                        <div class="box-header with-border">
                            <h3 class="box-title">Items</h3>
                        </div>
                        <div class="box-body">
                            <table class="table table-bordered table-hover">
                                <tr class="bg-gray">
                                    @if (@ViewBag.PartNoCheck == 0)
                                    {
                                        <th>Part No</th>
                                    }
                                    <th>Item</th>
                                    <th>Unit</th>
                                    <th>Quantity</th>
                                    <th>Packet</th>
                                    <th>Min Qty</th>
                                </tr>
                                @foreach (var plitems in Model.PLItems)
                                {
                                    var itemnote = "";
                                    if (@plitems.ItemNote != "")
                                    {
                                        itemnote = "<br /><small>" + @plitems.ItemNote + "</small>";
                                    }
                                    <tr>
                                        @if (@ViewBag.PartNoCheck == 0)
                                        {
                                            <td>@plitems.PartNumber</td>
                                        }
                                        <td>@plitems.ItemCode - @plitems.ItemName @Html.Raw(itemnote.Replace(Environment.NewLine, "<br/>"))</td>
                                        <td>@plitems.ItemUnit</td>
                                        <td>@plitems.ItemQuantity</td>
                                        <td>@plitems.Packet</td>
                                        <td>@plitems.MinQty</td>
                                    </tr>
                                        if (@plitems.subitem != null && @plitems.subitem.Count() > 0)
                                        {
                                            foreach (var splitems in @plitems.subitem)
                                            {
                                                <tr>
                                                    <td>@splitems.ItemCode - @splitems.ItemName</td>
                                                    <td>@splitems.ItemUnit</td>
                                                    <td>@splitems.ItemQuantity</td>
                                                    <td>@splitems.Packet</td>
                                                    <td>@splitems.MinQty</td>
                                                </tr>

                                            }
                                        }
                                   }
                            </table>
                        </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <strong>Remarks </strong><br />
                            @Html.Raw(Model.Remarks)
                        </div>
                        <div class="form-group">
                            <strong>Terms And Conditions </strong><br />
                            @Html.Raw(Model.TermsCondition)
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
