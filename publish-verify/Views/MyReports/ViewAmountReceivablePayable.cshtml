<script type="text/javascript">
        function prntsoa(data,i) {
            var originalpage = document.body.innerHTML;
            $("#lblParty").html(data[i].particulars);
            const today = new Date();
            const formattedDate = today.toLocaleDateString('en-GB'); // e.g., "03/02/2026"
            const dd_mm_yyyy = formattedDate.replace(/\//g, '-'); // Replaces all slashes with hyphens


            $("#lblDate").html(dd_mm_yyyy);
            $("#outstanding").html(data[i].Amount);
            $("#lblParty2").html(data[i].particulars);
            var printContent = $('#printit').html();

            $('body').html(printContent);
            window.print();
            $('body').html(originalpage);
        }
        $(document).ready(function () {
            var date = new Date();
            date.setDate(date.getDate());
            $('.date').datepicker({
                format: 'dd-mm-yyyy',

                autoclose: true,
                allowInputToggle: true,

            });
            $('#modal-create').on('submit', '#createForm', function (e) {
                e.preventDefault();
                var url = $('#createForm')[0].action;
                var data = $('#createForm').serialize();
                createajaxnew(url, data, '#modal-create');
            });

            function createajaxnew(url, data, modal) {
                $.ajax({
                    type: "POST",
                    url: url,
                    data: data,
                    success: function (data) {
                        if (data.status) {
                            $(modal).modal('hide');
                            //$(modal + ' .modal-content').empty();
                            $(modal + ' .modal-content').html('');
                            $('.ajax_response', res_success).text(data.message);
                            $('.AlertDiv').prepend(res_success);

                        }
                        else {
                            ////for (var i = 0; i < data.errors.length; i++) {
                            //    $('.ajax_response', res_danger).text(data.error[0]);
                            //    $('.AlertDiv').prepend(res_danger);
                            ////}

                            $('.ajax_response', res_danger).text(data.message);
                            $('.AlertDiv').prepend(res_danger);
                        }
                        fadeAlert();
                    }
                })
            }

            $('#modal-create').on('submit', '#createForm', function (e) {
                e.preventDefault();
                //oTable.draw();
            });
            $('#search-form').on('submit', function (e) {
                e.preventDefault();
                oTable.draw();
            });

            $('#UserTable tbody').on('click', 'tr', function () {
                if ($(this).hasClass('selected')) {
                    $(this).removeClass('selected');
                }
                else {
                    oTable.$('tr.selected').removeClass('selected');
                    $(this).addClass('selected');
                    $(this).addClass('dataTables_row');
                }
            });

            $('#UserTable tbody').on('dblclick', 'tr', function (e) {
                var data = oTable.row(this).data();
                var url = "/MyReports/UnPaidInvoices?particular=" + data.AccountsID + "";
                $(location).attr('href', url);
            });
        });

        /* function for Create popup */
        $('div').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');

