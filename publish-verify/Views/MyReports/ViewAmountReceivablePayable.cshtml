@{
    ViewBag.Title = "Amount Receivable & Payable";
    ViewBag.SubTitle = "Amount Receivable & Payable";
    ViewBag.Active = "Reports";
    var type = ViewBag.Type == 0 ? "Cr" : "Dr";
    string actData = "";
}

<div class="box box-default" id="RReport">
    <div class="box-header with-border">
        <h3 class="box-title">Customer Outstanding</h3>
    </div>
    <br />
    <form id="search-form">
        <div class="row">
            <div class="box-body search-box" id="advsearchlist">

                <div class="search-body col-md-12" style="background:none;">
                    <div class="form-group col-md-2 ">
                        @Html.Label("Next Date", null, new { @class = "control-label", @style = "font-weight:bold;" })
                        <div class="input-group date">
                            @Html.TextBox("nextdate", "", "{0:dd-MM-yyyy}", new { id = "nextdate", @class = "form-control input-sm", @autocomplete = "off" })
                            <div class="input-group-addon">
                                <i class="fa fa-calendar"></i>
                            </div>
                        </div>
                    </div>
                    <div class="form-group col-md-2" id="search">
                        <input type="button" class="btn btn-submit" value="search" onclick="searchform()">
                    </div>
                </div>

            </div>
        </div>
    </form>
    <div class="box-body">
        <input type="hidden" id="cname" value="@ViewBag.CName" />
        <input type="hidden" id="caddress" value="@ViewBag.CAddress" />

        <div class="box-body">
            <table class="display table table-bordered table-hover" id="UserTable">
                <thead>
                    <tr>
                        <td colspan="11">Salese Man : @ViewBag.salesman</td>
                    </tr>
                    <tr class="bg-gray">
                        <td>S/N</td>
                        <td>Particulars</td>
                        <td>Next Date & Time</td>


                        <td>Amount</td>
                        <td>Exp. Amt</td>
                        <td>Priority</td>
                        <td>Sales Executive</td>
                        <td>Invoice</td>
                        <td>Last Updated</td>
                        <td>Action</td>
                        <td></td>

                    </tr>
                </thead>
                <tbody></tbody>
                <tfoot>
                    <tr>
                        <th>Total:</th>
                        <th></th>
                        <th></th>


                        <th id="total"></th>
                        <th id="expected"></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>

                        <th></th>

                    </tr>
                </tfoot>
            </table>

        </div>
    </div>
</div>

<div id="modal-container2" class="modal fade" role="dialog" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                <h4>Remarks</h4>
            </div>
            <table class="table table-bordered table-hover" id="contactinfo">
                <thead>
                    <tr class="bg-gray">
                        <td>#</td>
                        <td>Contact Name</td>
                        <td>Mobile</td>

                    </tr>
                </thead>
                <tbody></tbody>
            </table>
            <div class="modal-body">
                <div class="box-body" id="modelview">
                    <table class="table table-bordered table-hover" id="RemarkInfo">
                        <thead>
                            <tr class="bg-gray">
                                <td>#</td>
                                <td>Date & Time</td>
                                <td>Employees</td>
                                <td>Remarks</td>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="modal-container3" class="modal fade" role="dialog" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                @*<h4>Terms and Conditions</h4>*@
            </div>
            <div class="modal-body">
                <div class="box-body">
                    <table class="table table-bordered table-hover" id="Terms">
