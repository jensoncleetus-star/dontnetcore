
@{
    ViewBag.Title = "Outstanding";
    ViewBag.SubTitle = "Outstanding Recievable";
    ViewBag.Active = "Reports";

}
<style>
    #divnames th {
        background: #0d83dd;
        color: white;
    }
</style>
<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">Outstanding Recievable</h3>
    </div>
    <div class="box-body">

        @*}*@
    </div>
</div>

<div class="box box-default" id="StockReport">
    <div class="box-body">
        <input type="hidden" id="cname" value="@ViewBag.CName" />
        <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
        <input type="hidden" id="itemname" value="@ViewBag.ItemName" />
        <input type="hidden" id="PoNo" value="@ViewBag.PartNoCheck" />
        <input type="hidden" id="mcname" value="@ViewBag.MCSName" />

        <div class="box-body">
            <table class="display table table-bordered table-hover" id="UserTable">
                <thead>

                    <tr id="divnames">
                        <th colspan="3">Name: <span id="ShowName"></span></th>
                        <th colspan="7">From : <span id="showFrom"></span> - To : <span id="showTo"></span></th>
                    </tr>
                    <tr>
                        <td>S/N</td>
                        <td>Invoice No</td>
                        <td>LPO Number</td>
                        <td style="width:100px !important;">Reciept No</td>
                        <td>Date</td>
                        <td>Customer</td>
                        <td class="headeralign">Bill Amount</td>
                        <td class="headeralign">Paid</td>
                        <td class="headeralign">Balance To Pay</td>
                        <td>Days</td>

                    </tr>
                </thead>
                <tbody></tbody>
                <tfoot>
                    <tr>
                        <th>Total:</th>

                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th class="text-right"><div id="selectedtotal"></div></th>
                        <th class="text-right"><div id="PaidAmount"></div></th>
                        <th></th>
                        <th class="text-right"><div id="balancetopay"></div></th>
                        <th></th>

                    </tr>
                </tfoot>

            </table>
        </div>
    </div>
</div>
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
}
@section Scripts {
    @Scripts.Render("~/js/bootstrap-datepicker")
    <script type="text/javascript">
        $(document).ready(function () {
            //showdatatable();
            $("#showFrom").html(getQueryString1("From"));
            $("#showTo").html(getQueryString1("To"));
            CSChange();
            $('#AgeDays').select2();

            $('#RReport').hide();
            $('#ageday').hide();

            //for set default date
            $('#To').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });
            $('#From').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });

            var date = new Date();
            var today = new Date(date.getFullYear(), date.getMonth(), date.getDate());
            var priordate = new Date(new Date().setDate(today.getDate() - 30));
            $('#To').datepicker('setDate', today);
            $('#From').datepicker('setDate', priordate);
        });

        $("#ddlCSType").select2();

        $('body').on('change', '#ddlType', function (e) {
            var type = $(this).val();
            if (type == 1) {
                $('#fdate').hide();
                $('#todate').hide();
                $('#ageday').show();
            }
            if (type == 0) {
                $('#fdate').show();
                $('#todate').show();
                $('#ageday').hide();
            }
        });

        CallRepMCUser();
        CallRepSupplier();
        CallRepCustomer();
        CallEmployee();
        $('body').on('change', '#ddlCSType', function (e) {
            CSChange();
        });
        $('body').on('change', '#ddlCustomer', function (e) {


        });

        function CSChange() {
            var cst = $('#ddlCSType').val();
            if (cst == "Sup") {
                $('#SupDiv').show();
                $('#CusDiv').hide();
                $('#ddlCustomer').val(0);
                $('#ddlSupplier').val(0);
            }
            else if (cst == "Cus") {
                $('#CusDiv').show();
                $('#SupDiv').hide();
                $('#ddlSupplier').val(0);
                $('#ddlCustomer').val(0);
            }
            else {
                $('#SupDiv').hide();
                $('#CusDiv').hide();

            }
        }

        var flag = 0;
        $('#search-form').on('submit', function (e) {
            var supID = $('#ddlSupplier').val();
            var cusID = $('#ddlCustomer').val();
            var temp = $('#ddlCSType').val();
            document.getElementById("ShowName").innerHTML = "";
            e.preventDefault();

            if (flag == 0) {

                showdatatable();

                flag = 1
            }
            else {
                $('#UserTable').DataTable().destroy();

                    showdatatable();

                //oTable.draw();
            }



            if (temp == "Cus" && cusID==0) {
                $('#UserTable thead td:eq(3)').html('Customer');
            }
            else if (temp == "Sup" && supID==0) {
                $('#UserTable thead td:eq(3)').html('Supplier');
            }

        });




            document.getElementById("ShowName").innerHTML = "";
            var supID = $('#ddlSupplier').val();
            var cusID = $('#ddlCustomer').val();
            var temp = $('#ddlCSType').val();


                jQuery(function ($) {
                    var oTable = $('#UserTable').DataTable({
                        "processing": true, // for show progress bar
                        "serverSide": true, // for process server side
                        "filter": true, // this is for disable filter (search box)
                        "orderMulti": false, // for disable multiple column at once
                        "paging": true,
                        "ordering": true,
                        "orientation": 'landscape',
                        // "bStateSave": true,
                        "bLengthChange": false,
                        "pageLength": 5000,
                        //"deferLoading": 0,
                        Responsive: true,
                        "ajax": {
                            "url": '/MyReports/GetReceivableLedger',
                            "data": function (data) {
                                data.CSType = 'Cus';
                                data.Sups = '1';
                                data.Cuss = getQueryString1('Cuss');
                                data.fromdate = getQueryString1('From');
                                data.todate = getQueryString1('To');
                                data.agedays = '1';
                                data.TTtype = '0';
                                data.empp = '0';
                            },

                            "type": "POST",
                            "datatype": "json",

                        },
                        "order": [[0, "desc"]],
                        "columns": [
                            {

                                "data": "", "name": "",
                                "render": function (data, type, row, meta) {
                                    return meta.row + meta.settings._iDisplayStart + 1;
                                }
                            },
                            {
                                "name": "Invoice", "data": function (result) {


                                    if (result.Ctyp == "Cus") {


                                    @{

                                    var urls = "";

                                        urls = "'<a href=\"/CreditSale/Edit/'+  result.id +'\" target=\"_new\">'+ result.Invoice +'</a>' ";
                            }
                                        return @Html.Raw(urls);
                                    }
                                    else {
                                        return result.Invoice;
                                    }
                                }
                            },
                            {
                                "name": "LPO", "data": "LPO"
                            },
                            {
                                "name": "recieptid", "data": function (result) {


                                    if (result.recieptid != "0") {


                                    @{

                                    var urls3 = "";

                                        urls3 = "'<a href=\"/Receipt/Edit/'+  result.recieptid +'\" target=\"_blank\">'+ result.recieptno +'</a>' ";
                            }
                                        return @Html.Raw(urls3);
                                    }
                                    else {
                                        return "";
                                    }
                                }
                            },
                            { "data": "Date", "name": "Date", "render": function (data) { return convertToDate(data); } },
                            {
                                "name": "Name","data": function (result) {

                                                       @{



                                        urls = "'<a href=\"/Customer/Details/'+  result.CustomerId +'\" target=\"_new\">'+ result.Name +'</a>' ";
                            }
                                    return @Html.Raw(urls);

                                }
                            },

                        { "data": "total", "name": "total", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                        { "data": "paid", "name": "paid", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },

                            {
                                "name": "Amount", "data": function (data) {
                                    if (data.Amount < 0)
                                        return "0";
                                    else
                                        return data.Amount;

                                },    render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright"
                                },
                        { "data": "Days", "name": "Days" },

                    ],
                    buttons: [
                        'colvis',
                   {
                       extend: 'print',//
                       title: "",
                       footer: true,
                       filename: function () {
                           return 'Receivable Outstanding-Report';
                       },
                       exportOptions: {
                           columns: ':visible'//[0, 1, 2, 3, 4]
                       },

                       message: function () {
                           var head = '<table class="tblcompact table table-bordered"><thead>' +
                           ' <tr><th class="text-center"><h3 style="margin-top: 0px;">' + $('#cname').val() + '</h3>' + $('#caddress').val() + '<h4>Receivable Outstanding </h4></th></tr>' +
                               ' <tr><th><span class="text-left"></span><span class="text-right pull-right"> From :  ' + getQueryString1("From") + ' To :' + getQueryString1("To") + '</span></th></tr></thead><tbody><tr><td>';
                           return head;
                       },
                       customize: function (win) {
                           // $(win.document.body)
                           //.css('font-size', '10pt')
                           //.css('padding', '1px');
                           $(win.document.body).find('table, th,tr, td ')
                              // .css('border', 'inherit')
                               .css('font-size', '10pt')
                               .css('padding', '5px')
                               .addClass('compact');
                           $(win.document.body).append('</td></tr></tbody>')

                       }
                   }, 'copy', 'csv', //'excel',
                   {
                       extend: 'excel',//
                       title: "",
                       footer: true,
                       filename: function () {
                           return 'Receivable Outstanding-Report';
                       },
                       message: function () {
                           var head = '' + $('#cname').val() + '\n' +
                           '' + $('#caddress').val() + '\n' +
                           ' Receivable Outstanding \n' +
                          // 'Account Name : ' + $('#ddlAccountName').text() + '\n' +
                           'From :  ' + $('#From').val() + ' To :' + $('#To').val() + '';
                           return head;
                       },
                       pageSize: 'A4',
                       exportOptions: {
                           columns: ':visible'
                       },
                   },
                   {
                       extend: 'pdf',//
                       title: "",
                       footer: true,
                       filename: function () {
                           return 'Receivable Outstanding-Report';
                       },
                       message: function () {
                           var head = '' + $('#cname').val() + '\n' +
                           '' + $('#caddress').val() + '\n' +
                           ' Receivable Outstanding \n' +
                          // 'Account Name : ' + $('#ddlAccountName').text() + '\n' +
                               'From :  ' + getQueryString1("From") + ' To :' + getQueryString1("To") + '';
                           return head;
                       },
                       pageSize: 'A4',
                       exportOptions: {
                           columns: ':visible'
                       },
                       customize: function (doc) {

                           doc.pageMargins = [10, 10, 10, 10];
                           doc.defaultStyle.fontSize = 10;
                           doc.styles.tableHeader.fontSize = 10;
                           doc.styles.title.fontSize = 12;
                           // Header font and bg color
                           doc.styles.tableHeader.fillColor = '#d3d3d3';
                           doc.styles.tableHeader.color = 'black';
                           // Remove spaces around page title
                           doc.content[0].text = doc.content[0].text.trim();

                           //doc.styles['td:nth-child(2)'] = {
                           //    width: '100%',
                           //    'max-width': '100%'
                           //}

                           doc.content[1].table.widths = Array(doc.content[1].table.body[0].length + 1).join('*').split('');


                           //doc.content[1].table.widths = [
                           //'15%',
                           //'18%',
                           //'18%',
                           //'25%',
                           //'20%',
                           //]

                           var objLayout = {};
                           // Horizontal line thickness
                           objLayout['hLineWidth'] = function (i) { return .5; };
                           // Vertikal line thickness
                           objLayout['vLineWidth'] = function (i) { return .5; };
                           //// Horizontal line color
                           //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                           //// Vertical line color
                           //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                           // Left padding of the cell
                           objLayout['paddingLeft'] = function (i) { return 4; };
                           // Right padding of the cell
                           objLayout['paddingRight'] = function (i) { return 4; };
                           // Inject the object in the document
                           doc.content[1].layout = objLayout;
                           // Footer font and bg color
                           doc.styles.tableFooter.fillColor = '#d3d3d3';
                           doc.styles.tableFooter.color = 'black';
                       }


                   },

                    ],



                    sDom: "lBfr<'datatable-scroll't>ip",
                    "lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                    "footerCallback": function (row, data, start, end, display) {
                        var api = this.api(), data;

                        // Remove the formatting to get integer data for summation
                        var intVal = function (i) {
                            return typeof i === 'string' ?
                                i.replace(/[\$,]/g, '') * 1 :
                                typeof i === 'number' ?
                                i : 0;
                        };



                        // Total over all pages
                        total = api
                            .column(5)
                            .data()
                            .reduce(function (a, b) {
                                return intVal(a) + intVal(b);
                            }, 0);

                        // Total over this page
                        pageTotal = api
                            .column(5, { page: 'current' })
                            .data()
                            .reduce(function (a, b) {
                                return intVal(a) + intVal(b);
                            }, 0);


                        //$(api.column(4).footer()).html(
                        //     pageTotal.toFixed(2)
                        //    //'$' + pageTotal + ' ( $' + total + ' total)'
                        //);

                        $('#selectedtotal').html(pageTotal);
                        $('#initialtotal').html(pageTotal);
                        total = api
                            .column(6)
                            .data()
                            .reduce(function (a, b) {
                                return intVal(a) + intVal(b);
                            }, 0);

                        $('#PaidAmount').html(total);
                        total = api
                            .column(8)
                            .data()
                            .reduce(function (a, b) {
                                return intVal(a) + intVal(b);
                            }, 0);

                        $('#balancetopay').html(total);


                    },
                    createdRow: function (row, data, dataIndex) {
                        $(row).addClass('bgtable');
                    }
                });
                });



    $('div').on('click', '.modal-delete', function (e) {
        e.preventDefault();
        var url = $(this).attr('href');
        modalshow(url, '#modal-delete');
    });

    $('#modal-delete').on('submit', '#deleteform', function (e) {
        e.preventDefault();
        var url = $('#deleteform')[0].action;
        var data = $('#deleteform').serialize();
        createajax(url, data, '#modal-delete');
        detailsRemind($("#remId").val());
    });

    </script>
}

