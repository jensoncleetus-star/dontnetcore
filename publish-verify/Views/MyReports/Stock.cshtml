

@{
    ViewBag.Title = "Search Stock";
    ViewBag.SubTitle = "Stock Report";
    ViewBag.Active = "Reports";

}
<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">Search Stock Report</h3>
    </div>
    <div class="box-body">
        <form id="search-form">
            <input type="hidden" id="cname" value="@ViewBag.CName" />
            <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
            <div class="form-group col-md-4">
                @Html.Label("Item Code/Name", null, new { @class = "control-label" })
                @Html.TextBox("ItemCodeName", "", new { @class = "form-control input-sm" })
            </div>
            <div class="form-group col-md-4">
                @Html.Label("Item Category", null, new { @class = "control-label" })
                @Html.DropDownList("ddlCategory", (SelectList)ViewBag.Category, new { @class = "form-control input-sm select2" })
            </div>
            <div class="box-footer col-md-12">
                <button type="submit" class="btn btn-info col-sm-offset-5" id="btn">Submit</button>
                <button type="button" class="btn btn-default" onclick="@("window.location.href='/Home/Index'");">Cancel</button>
            </div>
        </form>
    </div>
</div>
<div class="box box-default" id="StockReport">
    <div class="box-header with-border">
        <h3 class="box-title">View Stock Report</h3>
    </div>
    <div class="box-body">
        <div class="box-body">
            <table class="table table-bordered table-hover" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="1">S/N</td>
                        <td data-priority="1">Item Name</td>
                        <td data-priority="4">Category</td>
                        <td data-priority="5" class="headeralign">Purchase</td>
                        <td data-priority="5" class="headeralign">Sale</td>
                        <td data-priority="5" class="headeralign">Purchase Return</td>
                        <td data-priority="5" class="headeralign">Sale Return</td>
                        <td data-priority="5" class="headeralign">Opening Stock</td>
                        <td data-priority="2" class="headeralign">Stock</td>
                        @*<td data-priority="3">Branch</td>*@
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
}
@section Scripts {
    @Scripts.Render("~/js/bootstrap-datepicker")
    <script type="text/javascript">
        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        })

        $(document).ready(function () {
            $('#StockReport').hide();

            $("#ddlCategory").select2({
                placeholder: 'Search Category',
                minimumInputLength: 0,
                ajax: {
                    url: "/ItemCategory/SearchCategory",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term,
                            page: params.page
                        };
                    },
                    results: function (data) {
                        return { results: data };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;
                        return {
                            results: data
                        };
                    },
                    cache: true
                },

            });
        });

        jQuery(function ($) {
            oTable = $('#UserTable').DataTable({
                "processing": true, // for show progress bar
                "serverSide": true, // for process server side
                "filter": false, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
                // "bStateSave": true,
                "deferLoading": 0, // disable default ajax loading
                responsive: true,
                "bLengthChange": false,
                "paging": true,
                "pageLength": 5000,
                "columnDefs": [{
                    "targets": [3, 4, 5, 6, 7, 8],
                    "sClass": "numberright"
                }],
                "ajax": {
                    "url": '/MyReports/GetStock',
                    "data": function (data) {
                        data.cname = $('#ItemCodeName').val();
                        data.category = $('#ddlCategory').val();
                    },
                    "type": "POST",
                    "datatype": "json"
                },
                "columns": [
                     {
                         "data": "ItemID", "name": "ItemID",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                    { "data": "ItemName", "name": "ItemName" },
                    { "data": "categoryname", "name": "categoryname" },
                    {
                        "name": "purchase", "data": function (data) {
                            if (data.ItemUnitID != data.SubUnitId && data.ItemUnitID != null && data.SubUnitId != null) {
                                if ((data.SubPurchase == 0))
                                    return data.PriPurchase + " " + data.PriUnit;
                                else
                                    return data.PriPurchase + " " + data.PriUnit + ", " + data.SubPurchase + " " + data.SubUnit
                            }
                            else
                                return data.PriPurchase + " " + data.PriUnit;
                        }
                    },
                    {
                        "name": "sale", "data": function (data) {
                            if (data.ItemUnitID != data.SubUnitId && data.ItemUnitID != null && data.SubUnitId != null) {
                                if ((data.SubSale == 0))
                                    return data.PriSale + " " + data.PriUnit;
                                else
                                    return data.PriSale + " " + data.PriUnit + ", " + data.SubSale + " " + data.SubUnit
                            }
                            else
                                return data.PriSale + " " + data.PriUnit;
                        }
                    },
                    {
                        "name": "purchaseReturn", "data": function (data) {
                            if (data.ItemUnitID != data.SubUnitId && data.ItemUnitID != null && data.SubUnitId != null) {
                                if ((data.SubPReturn == 0))
                                    return data.PriPReturn + " " + data.PriUnit;
                                else
                                    return data.PriPReturn + " " + data.PriUnit + ", " + data.SubPReturn + " " + data.SubUnit
                            }
                            else
                                return data.PriPReturn + " " + data.PriUnit;
                        }
                    },
                    {
                        "name": "salesReturn", "data": function (data) {
                            if (data.ItemUnitID != data.SubUnitId && data.ItemUnitID != null && data.SubUnitId != null) {
                                if ((data.SubSReturn == 0))
                                    return data.PriSReturn + " " + data.PriUnit;
                                else
                                    return data.PriSReturn + " " + data.PriUnit + ", " + data.SubSReturn + " " + data.SubUnit
                            }
                            else
                                return data.PriSReturn + " " + data.PriUnit;
                        }
                    },
                    {
                        "name": "OpeningStock", "data": function (data) {
                            return data.OpeningStock + " " + data.PriUnit
                        }
                    },
                    {
                        "data": function (data) {
                            var total;
                            var primary = (data.total / data.ConFactor);
                            if (data.total % data.ConFactor == 0) {
                                total = (data.total / data.ConFactor) + " " + data.PriUnit;
                            }
                            else {
                                var prim = (Math.floor((data.total / data.ConFactor) * 100) / 100).toFixed(0);
                                var sub = (data.total % data.ConFactor).toFixed(0);
                                total = prim + " " + data.PriUnit + ", " + sub + " " + data.SubUnit
                            }
                            if (primary <= data.MinStock) {
                                return '<font color="red"><label>' + total + '</label></font>';
                            } else {
                                return '<label>' + total + '</label>';
                            }
                        }
                    },
                    //{ "data": "branchname", "name": "branchname" },
                ],
                buttons: [//'copy', 'csv', 'excel', 'pdf', 'print'
                'colvis',
                    {
                        extend: 'print',//
                        exportOptions: {
                            columns: ':visible'
                        },
                        title: "",
                        footer: true,
                        filename: function () {
                            return 'Stock-Report';
                        },
                        message: function()
                        {
                            var head = '<table class="tblcompact table table-bordered"><thead>' +
                            ' <tr><th class="text-center"><h3 style="margin-top: 0px;">' + $('#cname').val() + '</h3>' + $('#caddress').val() + '<h4>Stock Report</h4></th></tr>' +
                            ' <tr><th><span class="text-left">ItemCode/Name : ' + $('#ItemCodeName').val() + '</span><span class="text-right pull-right"> </span></th></tr></thead><tbody><tr><td>';
                            return head;
                        },
                        customize: function (win) {
                            // $(win.document.body)
                            //.css('font-size', '10pt')
                            //.css('padding', '1px');
                            $(win.document.body).find('table, th,tr, td ')
                               // .css('border', 'inherit')
                                .css('font-size', '10pt')
                                .css('padding', '5px')
                                .addClass('compact');
                            $(win.document.body).append('</td></tr></tbody>')

                        }
                    }, 'copy', 'csv', //'excel',
                    {
                        extend: 'excel',//
                        title: "",
                        footer: true,
                        filename: function () {
                            return 'Stock-Report';
                        },
                        message: function () {
                            var head = '' + $('#cname').val() + '\n' +
                             '' + $('#caddress').val() + '\n' +
                             ' Stock Report \n' +
                             'ItemCode/Name : ' + $('#ItemCodeName').val() + '\n';
                            //'From :  ' + $('#From').val() + ' To :' + $('#To').val() + ''
                            return head;
                        },
                        pageSize: 'A4',
                        exportOptions: {
                            columns: ':visible'
                        },
                    },
                    {
                        extend: 'pdf',//
                        title: "",
                        footer: true,
                        filename: function () {
                            return 'Stock-Report';
                        },
                        message: function () {
                            var head = '' + $('#cname').val() + '\n' +
                             '' + $('#caddress').val() + '\n' +
                             ' Stock Report \n' +
                             'ItemCode/Name : ' + $('#ItemCodeName').val() + '\n';
                            //'From :  ' + $('#From').val() + ' To :' + $('#To').val() + ''
                            return head;
                        },
                        pageSize: 'A4',
                        exportOptions: {
                            columns: ':visible'
                        },
                        customize: function (doc) {
                            doc.pageMargins = [10, 10, 10, 10];
                            doc.defaultStyle.fontSize = 10;
                            doc.styles.tableHeader.fontSize = 10;
                            doc.styles.title.fontSize = 12;
                            // Header font and bg color
                            doc.styles.tableHeader.fillColor = '#d3d3d3';
                            doc.styles.tableHeader.color = 'black';
                            // Remove spaces around page title
                            doc.content[0].text = doc.content[0].text.trim();



                            doc.content[1].table.widths = [
                            '10%',
                            '10%',
                            '10%',
                            '10%',
                            '15%',
                            '10%',
                            '10%',
                            '10%',
                            '15%'
                            ]


                            var objLayout = {};
                            // Horizontal line thickness
                            objLayout['hLineWidth'] = function (i) { return .5; };
                            // Vertikal line thickness
                            objLayout['vLineWidth'] = function (i) { return .5; };
                            //// Horizontal line color
                            //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                            //// Vertical line color
                            //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                            // Left padding of the cell
                            objLayout['paddingLeft'] = function (i) { return 4; };
                            // Right padding of the cell
                            objLayout['paddingRight'] = function (i) { return 4; };
                            // Inject the object in the document
                            doc.content[1].layout = objLayout;
                            // Footer font and bg color
                            doc.styles.tableFooter.fillColor = '#d3d3d3';
                            doc.styles.tableFooter.color = 'black';
                        }


                    },

                ],



                sDom: "lBfr<'datatable-scroll't>ip",
                "lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]]
            });

            //$('#btn').click(function () { //button filter event click
            //    alert($('#ItemCodeName').val());
            //    alert($('#ddlCategory').val());
            //    oTable.ajax.reload();
            //    // oTable1.api().ajax.reload();
            //    $('#StockReport').show();

            //});
            $('#search-form').on('submit', function (e) {
                e.preventDefault();
                //alert($('#ItemCodeName').val());
                //alert($('#ddlCategory').val());
                oTable.draw();
                $('#StockReport').show();
            });
        });
        function reload_table() {
            oTable.clear().draw();
            oTable.ajax.reload(null, false); //reload datatable ajax
        }

    </script>
}
