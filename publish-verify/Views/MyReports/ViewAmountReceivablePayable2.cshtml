@{
    ViewBag.Title = "Amount Receivable & Payable";
    ViewBag.SubTitle = "Amount Receivable & Payable";
    ViewBag.Active = "Reports";
    var type = ViewBag.Type == 0 ? "Cr" : "Dr";
    string actData = "";
}
<div class="box box-default" id="RReport">
    <div class="box-header with-border">
        <h3 class="box-title">Amount Receivable & Payable</h3>
    </div>
    @Html.Partial("../Common/_ModalCreate")
    <div id="modal-container2" class="modal fade" role="dialog" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                    <h4>Remarks</h4>
                </div>
       
                <div class="modal-body">
                    <div class="box-body" id="modelview">
                        <table class="table table-bordered table-hover" id="RemarkInfo">
                            <thead>
                                <tr class="bg-gray">
                                    <td>#</td>
                                    <td>Date & Time</td>
                                    <td>Employees</td>
                                    <td>Remarks</td>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="box-body">
        <input type="hidden" id="cname" value="@ViewBag.CName" />
        <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
        <div class="box-body">
            <table class="display table table-bordered table-hover" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td>S/N</td>
                        <td>Particulars</td>
                        <td>Amount</td>
                        <td>Amount</td>
                        <td>Action</td>
                    </tr>
                </thead>
                <tbody></tbody>
                <tfoot>
                    <tr>
                        <th>Total:</th>
                        <th></th>
                        <th id="total"></th>
                        <th></th>
                        <th></th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script type="text/javascript">
        $('.table').on('click', 'a.Updation', function (e) {
            e.preventDefault();
            $(this).attr('data-target', '#modal-container2');
            $(this).attr('data-toggle', 'modal');
        });
        $('div').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');

        });

        $('#modal-create').on('submit', '#createForm', function (e) {
            e.preventDefault();
            var url = $('#createForm')[0].action;
            var data = $('#createForm').serialize();
            createajaxnew(url, data, '#modal-create');
        });

        function createajaxnew(url, data, modal) {
            $.ajax({
                type: "POST",
                url: url,
                data: data,
                success: function (data) {
                    if (data.status) {
                        $(modal).modal('hide');
                        //$(modal + ' .modal-content').empty();
                        $(modal + ' .modal-content').html('');
                        $('.ajax_response', res_success).text(data.message);
                        $('.AlertDiv').prepend(res_success);

                    }
                    else {
                        ////for (var i = 0; i < data.errors.length; i++) {
                        //    $('.ajax_response', res_danger).text(data.error[0]);
                        //    $('.AlertDiv').prepend(res_danger);
                        ////}

                        $('.ajax_response', res_danger).text(data.message);
                        $('.AlertDiv').prepend(res_danger);
                    }
                    fadeAlert();
                }
            })
        }

        function details(d) {
            var CustomerId = d;
            //List all other remarks from table CustomerRemarks
            var oTable1 = $('#RemarkInfo').DataTable({
                "processing": true, // for show progress bar
                "serverSide": true, // for process server side
                "filter": true, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
                "bStateSave": true,
                "paging": false,
                "sortable": true,
                "ordering": true,
                "searching": true,
                "ajax": {
                    "url": '/MyReports/GetAllRemarksaccount',
                    "type": "POST",
                    "datatype": "json",
                    "data": { CustomerId: CustomerId }
                },
                "order": [[0, "desc"]],

                "columns": [
                    {
                        "data": "id", "name": "id",
                        "render": function (data, type, row, meta) {
                            return meta.row + meta.settings._iDisplayStart + 1;
                        }
                    },
                    { "data": "CreatedDate", "name": "CreatedDate", "render": function (data) { if (data != null) { return convertDateTime(data); } else { return "" } } },
                    { "data": "EmpName", "name": "EmpName" },
                    { "data": "Remarks", "name": "Remarks" },
                ],
            });
         
            oTable1.destroy();
        }
        $(document).ready(function () {
            var oTable = $('#UserTable').DataTable({
                "processing": true, // for show progress bar
                "serverSide": true, // for process server side
                "filter": false, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
                // "bStateSave": true,
                "bLengthChange": false,
                responsive: true,
                "paging": true,
                "pageLength": 5000,
                "ordering": true,
                "ajax": {
                    "url": '/MyReports/GetAmountReceivablePayable2',
                    "data": {
                        ddlType: getQueryString1('ddlType'),
                        pdc: getQueryString1('pdc'),
                        fromdate: getQueryString1('fromdate'),
                        todate: getQueryString1('todate'),
                    },
                    "type": "POST",
                    "datatype": "json"

                },
                "order": [[0, "desc"]],
                "columnDefs": [
                    {
                        "targets": [ 3 ],
                        "visible": false,
                    }],
                "columns": [
                     {
                         "data": "", "name": "",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                    {
                        "name": "particulars",
                        "data": function (data) {
                            var link = "<a href='/MyReports/GetLedger?AccId=" + data.AccountsID + "&fromdate=01-01-2023&todate=11-12-2026&AccGroup=null&pdc=true' target='_blank'>" + data.particulars +"</a>"
                            return link;
                        } },
                     {
                        "name": "Amount",
                        "data": function (data) {
                            return data.Amount + " " + data.DrCr;
                        }
                     },
                     {
                         "name": "Amount",
                         "data": function (data) {
                             if (data.DrCr == '@type') {
                                 return data.Amount;
                             } else {
                                 return data.Amount * -1;
                             }
                         }
                    },
                    {
                        "name": "particulars", "data": function (data) {
                        var rest = "";

                        @{
                            actData += "<a class=\"btn btn-icons btn-rounded btn-edit modal-create\" href=\"/MyReports/AddAccountRemark/'+ data.AccountsID +'\" title=\"Add Remarks\"><i class=\" fa fa-plus\" ></i></a> ";
                            actData += "<a class=\"btn btn-icons btn-rounded btn-remark Updation\" onclick=\"details(' + data.AccountsID + ')\" title=\"View Remarks\"><i class=\" fa fa-eye\" ></i></a> ";

                            //actData += "<a class=\"btn \" onclick=\"prntsoa(data)\" title=\"Print soa\">SOA</a> ";

                            }

                   
                            rest = '@Html.Raw(actData)';
                        return rest;
                    }
                    },
                ],
                buttons: [//'copy', 'csv', 'excel', 'pdf', 'print'
                'colvis',
                {
                    extend: 'print',//
                    exportOptions: {
                        columns: ':visible'
                    },
                    title: "",
                    footer: true,
                    filename: function () {
                        return 'Amount Receivable & Payable';
                    },
                    message: function () {
                        var head = '<table class="tblcompact table table-bordered"><thead>' +
                             '<tr><th class="text-center"><h3 style="margin-top: 0px;">' + $('#cname').val() + '</h3>' + $('#caddress').val() + '<h4>Amount Receivable & Payable</h4></th></tr>' +
                             '<tr><th><span class="text-left"></span><span class="text-right pull-right"></span></th></tr></thead><tbody><tr><td>';
                        return head;
                    },
                    customize: function (win) {
                        $(win.document.body).find('table, th,tr, td ')
                        // .css('border', 'inherit')
                        .css('font-size', '10pt')
                        .css('padding', '5px')
                        .addClass('compact');
                        $(win.document.body).append('</td></tr></tbody>')

                    }
                }, 'copy', 'csv', //'excel',
                {
                    extend: 'excel',//
                    title: "",
                    footer: true,
                    filename: function () {
                        return 'Amount Receivable & Payable';
                    },
                    message: function () {
                        var head = '' + $('#cname').val() + '\n' +
                        '' + $('#caddress').val() + '\n' +
                        ' Amount Receivable & Payable \n';

                        return head;
                    },
                    pageSize: 'A4',
                    exportOptions: {
                        columns: ':visible'
                    },
                },
                        {
                            extend: 'pdf',//
                            title: "",
                            footer: true,
                            filename: function () {
                                return 'Amount Receivable & Payable';
                            },
                            message: function () {
                                var head = '' + $('#cname').val() + '\n' +
                                '' + $('#caddress').val() + '\n' +
                                ' Amount Receivable & Payable \n';

                                return head;
                            },
                            pageSize: 'A4',
                            exportOptions: {
                                columns: ':visible'
                            },
                            customize: function (doc) {
                                doc.pageMargins = [10, 10, 10, 10];
                                doc.defaultStyle.fontSize = 10;
                                doc.styles.tableHeader.fontSize = 10;
                                doc.styles.title.fontSize = 12;
                                // Header font and bg color
                                doc.styles.tableHeader.fillColor = '#d3d3d3';
                                doc.styles.tableHeader.color = 'black';
                                // Remove spaces around page title
                                doc.content[0].text = doc.content[0].text.trim();

                                doc.styles['td:nth-child(2)'] = {
                                    width: '100%',
                                    'max-width': '100%'
                                }

                                //doc.content[1].table.widths = [
                                //'5%',
                                //'15%',
                                //'8%',
                                //'8%',
                                //'8%',
                                //'8%',
                                //'8%',
                                //'10%',
                                //'10%',
                                //'10%',
                                //'10%'
                                //]

                                var objLayout = {};
                                // Horizontal line thickness
                                objLayout['hLineWidth'] = function (i) { return .5; };
                                // Vertikal line thickness
                                objLayout['vLineWidth'] = function (i) { return .5; };
                                //// Horizontal line color
                                //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                                //// Vertical line color
                                //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                                // Left padding of the cell
                                objLayout['paddingLeft'] = function (i) { return 4; };
                                // Right padding of the cell
                                objLayout['paddingRight'] = function (i) { return 4; };
                                // Inject the object in the document
                                doc.content[1].layout = objLayout;
                                // Footer font and bg color
                                doc.styles.tableFooter.fillColor = '#d3d3d3';
                                doc.styles.tableFooter.color = 'black';
                            }


                        },

                ],

                sDom: "lBfr<'datatable-scroll't>ip",
                "lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                "footerCallback": function (row, data, start, end, display) {
                    var api = this.api(), data;

                    // Remove the formatting to get integer data for summation
                    var intVal = function (i) {
                        return typeof i === 'string' ?
                        i.replace(/[\$,]/g, '') * 1 :
                        typeof i === 'number' ?
                            i : 0;
                    };

                    // Total over all pages
                    total = api
                    .column(3)
                    .data()
                    .reduce(function (a, b) {
                        return intVal(a) + intVal(b);
                    }, 0);

                    // Total over this page
                    pageTotal = api
                    .column(3, { page: 'current' })
                    .data()
                    .reduce(function (a, b) {
                        return intVal(a) + intVal(b);
                    }, 0);

                    var type = '@type';
                    $("#total").text(pageTotal.toFixed(2) + " " + type);

                    var table = $('#UserTable').DataTable();
                    if (!table.data().any()) {
                        $('#UserTable tfoot').hide();
                    } else {
                        $('#UserTable tfoot').show();
                    }

                }
            });

            $('#UserTable tbody').on('click', 'tr', function () {
                if ($(this).hasClass('selected')) {
                    $(this).removeClass('selected');
                }
                else {
                    oTable.$('tr.selected').removeClass('selected');
                    $(this).addClass('selected');
                    $(this).addClass('dataTables_row');
                }
            });

            $('#UserTable tbody').on('dblclick', 'tr', function (e) {
                var data = oTable.row(this).data();
                var url = "/MyReports/UnPaidInvoices?particular=" + data.AccountsID + "";
                $(location).attr('href', url);
            });
        });

    </script>
}
