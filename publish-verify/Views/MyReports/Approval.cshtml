@{
    ViewBag.Title = "Search Approval Report";
    ViewBag.SubTitle = "Approval Report";
    ViewBag.Active = "Utility";
    string actData = "";
}
<style type="text/css">

    .dropdown-check-list {
        display: inline-block;
    }

        .dropdown-check-list .anchor {
            position: relative;
            cursor: pointer;
            display: inline-block;
            padding: 5px 50px 5px 10px;
            border: 1px solid #ccc;
            width: 150px;
            background: #fff;
            text-align: center;
        }

            .dropdown-check-list .anchor:after {
                position: absolute;
                content: "";
                border-left: 2px solid black;
                border-top: 2px solid black;
                padding: 5px;
                right: 10px;
                top: 20%;
                -moz-transform: rotate(-135deg);
                -ms-transform: rotate(-135deg);
                -o-transform: rotate(-135deg);
                -webkit-transform: rotate(-135deg);
                transform: rotate(-135deg);
            }

            .dropdown-check-list .anchor:active:after {
                right: 8px;
                top: 21%;
            }

        .dropdown-check-list ul.items {
            padding: 0px;
            display: none;
            margin: 0;
            border: 1px solid #ccc;
            border-top: none;
            position: absolute;
            z-index: 9999;
        }

            .dropdown-check-list ul.items li {
                list-style: none;
                background: #fff;
                padding: 5px;
            }

    .add-btn-item {
        border-radius: 23px;
        padding: 6px 20px;
    }

    .dropdown-check-list.visible .anchor {
        color: #0094ff;
    }

    .dropdown-check-list.visible .items {
        display: block;
    }
</style>

<div class="box box-info">
    <div class="row">
        <div class="col-md-2">
            <div id="list1" class="dropdown-check-list" tabindex="100">
                <span class="anchor" style="z-index:0;">Select Fields</span>
                <ul class="items">
                    <li><input type="checkbox" id="liinvoiceno" />Invoice No.</li>
                    <li><input type="checkbox" id="litype" />Type</li>
                    <li><input type="checkbox" id="liapprvlstatus" />Approval Status</li>
                    <li><input type="checkbox" id="lifromdate" />From Date</li>
                    <li><input type="checkbox" id="litodate" />To Date</li>
                </ul>
            </div>
        </div>

        <div class="col-md-12">
            <div class="box-body search-box" id="advsearchlist">
                <div class="search-body col-md-12" style="background:none;">
                    <form id="search-form">
                        <div class="row">
                            <input type="hidden" id="cname" value="@ViewBag.CName" />
                            <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
                            <div class="form-group col-md-2" id="searchinvoiceno">
                                @Html.Label("Invoice Number", null, new { @class = "control-label" })
                                @Html.TextBox("InvoiceNumber", "", new { @class = "form-control input-sm" })
                            </div>
                            <div class="form-group col-md-2" id="searchtype">
                                @Html.Label("Type", null, new { @class = "control-label" })
                                @Html.DropDownList("ddlType", (SelectList)ViewBag.Types, new { @class = "form-control input-sm select2" })
                            </div>
                            <div class="form-group col-md-2" id="searchapprovalstatus">
                                @Html.Label("Approval Status", null, new { @class = "control-label" })
                                @Html.DropDownList("ApprovalStatus", (SelectList)ViewBag.AppStat, new { @class = "form-control input-sm" })
                            </div>
                            <div class="form-group col-md-2" id="searchfromdate">
                                @Html.Label("From Date", null, new { @class = "control-label" })
                                <div class="input-group date">
                                    @Html.TextBox("FromDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                    <div class="input-group-addon">
                                        <i class="fa fa-calendar"></i>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group col-md-2" id="searchtodate">
                                @Html.Label("To Date", null, new { @class = "control-label" })
                                <div class="input-group date">
                                    @Html.TextBox("ToDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                                    <div class="input-group-addon">
                                        <i class="fa fa-calendar"></i>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group col-md-2" id="search">
                                <input type="submit" class="btn btn-submit" value="Submit" />
                            </div>
                            <div class="form-group col-md-2" id="close">
                                <input type="button" class="btn btn-close" value="Close" />
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="box box-default">
        <div class="box-header with-border">
            <h3 class="box-title">View Approval Report</h3>
        </div>
        <form role="form" method="post" id="fform">
        @Html.AntiForgeryToken()
            <div class="box-body">
                <table class="table table-bordered" id="UserTable">
                    <thead>
                        <tr class="bg-gray">
                            @*<td>S/N</td>*@
                            <td>Invoice No</td>
                            <td>Date</td>
                            <td>Type</td>
                            <td>Status</td>
                            <td>Action</td>
                        </tr>
                    </thead>
                    <tbody></tbody>
                    <tfoot>
                        <tr>
                            <th>Total:</th>
                            @*<th></th>*@
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </form>
    </div>
</div>
@Html.Partial("../Common/_ModalEdit")
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
}
@section Scripts {
    @Scripts.Render("~/js/bootstrap-datepicker")
    <script type="text/javascript">

        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });

        $(document).ready(function () {
            $('#advsearchlist').hide();

            $('#ToDate').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });

            $('#FromDate').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });
            //var date = new Date();
            //var today = new Date(date.getFullYear(), date.getMonth(), date.getDate());
            //var priordate = new Date(new Date().setDate(today.getDate() - 30));
            //$('#ToDate').datepicker('setDate', today);
            //$('#FromDate').datepicker('setDate', priordate);
        });

        //Type
        $("#ddlType").select2({
            placeholder: 'Search Type',
            minimumInputLength: 0,
            ajax: {
                url: "/MyReports/SearchAllType",
                dataType: 'json',
                type: "POST",
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term,
                        page: params.page,
                        x: "all"
                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 1;
                    return {
                        results: data
                    };
                },
                cache: true
            },
        });

        var oTable = $('#UserTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "pageLength": 50,
            "bLengthChange": false,
             responsive: true,

            "ajax": {
                "url": '/MyReports/GetApproval',
                "data": function (data) {
                    data.FromDate = $('#FromDate').val();
                    data.ToDate = $('#ToDate').val();
                    data.invoice = $('#InvoiceNumber').val();
                    data.type = $('#ddlType').val();
                    data.appstat = $('#ApprovalStatus').val();
                    data.sortfive = false;
                },
                "type": "POST",
                "datatype": "json"

            },
            "order": [[1, "desc"]],
            "columnDefs": [{
                "targets": [3,4],
                "orderable": false
            }],
            "columns": [
                 //{
                 //    "fnRowCallback": function (nRow, aData, iDisplayIndex) {
                 //        $("td:first", nRow).html(iDisplayIndex + 1);
                 //        return nRow;
                 //    },
                 //},
            { "data": "BillNo", "name": "BillNo" },
            {
                "data": "SDate", "name": "SDate",
                "render": function (data) {
                    var date = convertToDate(data);
                    return date.toString();
                }
            },
            { "data": "Type", "name": "Type" },
            {
                "name": "ApprovalStatus", "data": function (data, type, dataToSet) {
                    var status = "";
                    if (data.ApprovalStatus == "0") {
                        status = '<span class="badge bg-green">Approved</span>';
                    }
                    else if (data.ApprovalStatus == "1") {
                        status = '<span class="badge bg-red">Rejected</span>';
                    }
                    else if (data.ApprovalStatus == "2") {
                        status = '<span class="badge bg-orange">PendingApproval</span>';
                    }
                    return '<a  class="Updation"   title="View Status">' + status + ' </a>';//onclick="details(' + data.ProFormaId + ')"
                }
            },
             {
                 "name": "Id", "data": function (data) {
                     var rest = "";
                     if (data.Approval == true && data.StatPer == 1) {
                         @{
                            actData = "";
                            actData = "<a class=\"modal-edit\"  href=\"/MyReports/EditStatus/'+ data.Id +'/'+ data.Type +'\" title =\"Edit Status\"><i class=\"fa fa-lg fa-refresh\" ></i></a> ";
                        }
                         rest += '@Html.Raw(actData)';
                     }
                     if (data.EditPer == true) {
                         @{
                             actData = "";
                             actData += "<a href=\"/'+ data.Editpath +'/Edit/'+ data.Id +'\" title=\"Edit '+ data.Type +' \"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                        }
                         rest += '@Html.Raw(actData)';
                     }

                     return rest;
                 }
             },
            ],
            buttons: [//'copy', 'csv', 'excel', 'pdf', 'print'
            'colvis',
            {
                extend: 'print',//
                exportOptions: {
                    columns: ':visible'
                },
                title: "",
                footer: true,
                filename: function () {
                    return 'Approval Report';
                },
                message: function () {
                    var head = '<table class="tblcompact table table-bordered"><thead>' +
                        ' <tr><th class="text-center"><h3 style="margin-top: 0px;">' + $('#cname').val() + '</h3>' + $('#caddress').val() + '<h4>Approval Report</h4></th></tr>';
                        //' <tr><th><span class="text-left"></span><span class="text-right pull-right"> From :  ' + $('#From').val() + ' To :' + $('#To').val() + '</span></th></tr></thead><tbody><tr><td>';
                    return head;
                },
                customize: function (win) {
                    // $(win.document.body)
                    //.css('font-size', '10pt')
                    //.css('padding', '1px');
                    $(win.document.body).find('table, th,tr, td ')
                       // .css('border', 'inherit')
                        .css('font-size', '10pt')
                        .css('padding', '5px')
                        .addClass('compact');
                    $(win.document.body).append('</td></tr></tbody>')

                }
            }, 'copy', 'csv', //'excel',
            {
                extend: 'excel',//
                title: "",
                footer: true,
                filename: function () {
                    return 'Approval Report';
                },
                message: function () {
                    var head = '' + $('#cname').val() + '\n' +
                     '' + $('#caddress').val() + '\n' +
                     ' Approval Report \n';
                    // 'From :  ' + $('#From').val() + ' To :' + $('#To').val() + '';
                    return head;
                },
                pageSize: 'A4',
                exportOptions: {
                    columns: ':visible'
                },
            },
          {
              extend: 'pdf',//
              title: "",
              footer: true,
              filename: function () {
                  return 'Approval Report';
              },
              message: function () {
                  var head = '' + $('#cname').val() + '\n' +
                   '' + $('#caddress').val() + '\n' +
                   ' Approval Report \n';
                  // 'From :  ' + $('#From').val() + ' To :' + $('#To').val() + '';
                  return head;
              },
              pageSize: 'A4',
              exportOptions: {
                  columns: ':visible'
              },
              customize: function (doc) {
                  doc.pageMargins = [10, 10, 10, 10];
                  doc.defaultStyle.fontSize = 10;
                  doc.styles.tableHeader.fontSize = 10;
                  doc.styles.title.fontSize = 12;
                  // Header font and bg color
                  doc.styles.tableHeader.fillColor = '#d3d3d3';
                  doc.styles.tableHeader.color = 'black';
                  // Remove spaces around page title
                  doc.content[0].text = doc.content[0].text.trim();
                  doc.styles['td:nth-child(2)'] = {
                      width: '100px',
                      'max-width': '100px'
                  }
                  //doc.content[1].table.widths = [
                  //'10%',
                  //'10%',
                  //'15%',
                  //'10%',
                  //'15%',
                  //'15%',
                  //'15%',
                  //'10%'
                  //]

                  var objLayout = {};
                  // Horizontal line thickness
                  objLayout['hLineWidth'] = function (i) { return .5; };
                  // Vertikal line thickness
                  objLayout['vLineWidth'] = function (i) { return .5; };
                  //// Horizontal line color
                  //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                  //// Vertical line color
                  //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                  // Left padding of the cell
                  objLayout['paddingLeft'] = function (i) { return 4; };
                  // Right padding of the cell
                  objLayout['paddingRight'] = function (i) { return 4; };
                  // Inject the object in the document
                  doc.content[1].layout = objLayout;
                  // Footer font and bg color
                  doc.styles.tableFooter.fillColor = '#d3d3d3';
                  doc.styles.tableFooter.color = 'black';
              }
          },
            ],
            sDom: "lBfr<'datatable-scroll't>ip",
            "lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
            "footerCallback": function (row, data, start, end, display) {
                var api = this.api(), data;

                // Remove the formatting to get integer data for summation
                var intVal = function (i) {
                    return typeof i === 'string' ?
                        i.replace(/[\$,]/g, '') * 1 :
                        typeof i === 'number' ?
                        i : 0;
                };

                var table = $('#UserTable').DataTable();
                if (!table.data().any()) {
                    $('#UserTable tfoot').hide();
                } else {
                    $('#UserTable tfoot').show();
                }
            }
        });

        function reload_table() {
            oTable.clear().draw();
            oTable.ajax.reload(null, false); //reload datatable ajax
        }

        //Button Close
        $('#srch, .search-box .btn-close').on('click', function (e) {
            $('#advsearchlist').toggle();

            /*******  To uncheck all the checkboxes in the Select List  ************/
            var checkboxes = document.querySelectorAll("input[type='checkbox']");
            checkboxes.forEach(function (Checkbox) {
                Checkbox.checked = false;
            });

            if ($('#srch').hasClass('btn-primary')) {

                $('#srch').addClass('btn-danger');
                $('#srch').removeClass('btn-primary');
            }
            else {
                if ($('#srch').hasClass('btn-danger')) {
                    $('#srch').addClass('btn-primary');
                    $('#srch').removeClass('btn-danger');
                }

                /*******  To clear all the data entered  *********/
                $('#InvoiceNumber').val("");
                $('#ddlType').val(0).trigger("change");
                $('#ApprovalStatus').val("");
                $('#FromDate').val("");
                $('#ToDate').val("");
                oTable.draw();
            }
        });

        //var minDate = $("#Start").val();
        //var maxDate = $("#End").val();
        //$('#FromDate').datepicker({
        //    format: 'dd-mm-yyyy',
        //    autoclose: true,
        //    allowInputToggle: true,
        //    startDate: new Date(minDate),
        //    endDate: new Date(maxDate)
        //});

        //$('#ToDate').datepicker({
        //    format: 'dd-mm-yyyy',

        //    autoclose: true,
        //    allowInputToggle: true,
        //    startDate: new Date(minDate),
        //    endDate: new Date(maxDate)
        //});

        $('#search-form').on('submit', function (e) {
            e.preventDefault();
            oTable.draw();
        });

        /* function for Edit popup */
        $('div').on('click', '.modal-edit', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-edit');
        });

        $('#modal-edit').on('submit', '#editform', function (e) {
            e.preventDefault();
            var url = $('#editform')[0].action;
            var data = $('#editform').serialize();
            createajax(url, data, '#modal-edit');
        });

       var checkList = document.getElementById('list1');
       /******* Function to list and hide dropdown checklist while clicking on 'Select Fields' *******/
       checkList.getElementsByClassName('anchor')[0].onclick = function (evt) {
           if (checkList.classList.contains('visible'))
               checkList.classList.remove('visible');
           else
               checkList.classList.add('visible');
       }

       /******* Function to show and hide fields while clicking on checkboxes in 'Select Fields' *******/
       $("ul li input:checkbox").click(function () {

           var _show = 0;

           //Invoice No.
           if ($("#liinvoiceno ").prop("checked") == true) {
               $("#searchinvoiceno").show();
               _show = 1;
           }
           else {
               $('#InvoiceNumber').val("");
               $("#searchinvoiceno").hide();
               oTable.draw();
           }

           //Type
           if ($("#litype").prop("checked") == true) {
               $("#searchtype").show();
               _show = 1;
           }
           else {
               $('#ddlType').val(0).trigger("change");
               $("#searchtype").hide();
               oTable.draw();
           }

           //Approval Status
           if ($("#liapprvlstatus").prop("checked") == true) {
               $("#searchapprovalstatus").show();
               _show = 1;
           }
           else {
              $('#ApprovalStatus').val("").trigger("change");
               $("#searchapprovalstatus").hide();
               oTable.draw();
           }

           //From Date
           if ($("#lifromdate").prop("checked") == true) {
               $("#searchfromdate").show();
               _show = 1;
           }
           else {
               $("#FromDate").val("");
               $("#searchfromdate").hide();
               oTable.draw();
           }

           //To Date
           if ($("#litodate").prop("checked") == true) {
               $("#searchtodate").show();
               _show = 1;
           }
           else {
               $("#ToDate").val("");
               $("#searchtodate").hide();
               oTable.draw();
           }

           if (_show == 1) {
               $('#advsearchlist').show();
           }
           else {
               $('#advsearchlist').hide();
           }
       });

       /******* Function to hide dropdown checklist while clicking outside it ********/
       $(document).on("click", function (event) {

           var element1 = $("#list1");

           if (element1 !== event.target && !element1.has(event.target).length) {
               checkList.classList.remove('visible');
           }
       });

    </script>
}
