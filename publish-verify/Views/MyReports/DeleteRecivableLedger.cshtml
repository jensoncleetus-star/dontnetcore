
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Allocate Bill</h4>
</div>
<div class="modal-body">
    <h3>Are you sure you want to Allocate this?</h3>
    @using (Html.BeginForm("DeleteRecivableLedger", "MyReports", FormMethod.Post, new { id = "deleteform" }))
    {
        @Html.AntiForgeryToken()
        <input type="hidden" name="salesentryid" value="@ViewBag.salesentry" />
        <div class="form-actions no-color">
            <input type="submit" value="Allocate" class="btn btn-danger col-sm-offset-4" />
            <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal">
        </div>
    }
</div>