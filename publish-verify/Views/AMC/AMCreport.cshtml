<script type="text/javascript">

    //$('#advsearchlist').hide();

    $('.date').datepicker({
        format: 'dd-mm-yyyy',
        autoclose: true,
        allowInputToggle: true
    });

    jQuery.validator.methods["date"] = function (value, element) { return true; }
    $(".timepicker").timepicker({
        showInputs: true,
        defaultTime: false,
        format: 'dd-mm-yyyy'
    });

    $(document).ready(function () {


        $('#ddldocumenttype').select2({});

       $('#advsearchlist').show();
        $('#ddlPagesize').on('change', function (e) {

            let pagedroplength = $('#ddlPagesize').val();
            oTable.page.len(pagedroplength).draw();
        });
        $("#nextdate").show();







        $('#FromDate').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });

        $('#ToDate').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });
        var date = new Date();
        var today = new Date(date.getFullYear(), date.getMonth(), date.getDate());
        var priordate = new Date(new Date().setDate(today.getDate() - 60));
        //$('#ToDate').datepicker('setDate', today);
        $('#FromDate').datepicker('setDate', priordate);
        $('#ToDate').datepicker('setDate', today);
    });

    //Customer DropDown


    function Alertfn() {
        alert("There is no Document Attached");
    }

    var oTable = null;

   

    //Retrieving data from table for display




    //".checkbox" change


    //Button Close
    $('#srch, .search-box .btn-close').on('click', function (e) {
        /*   $('#advsearchlist').toggle();*/

        /*******  To uncheck all the checkboxes in the Select List  ************/
        var checkboxes = document.querySelectorAll("input[type='checkbox']");
        checkboxes.forEach(function (Checkbox) {
            Checkbox.checked = false;
        });

        if ($('#srch').hasClass('btn-primary')) {

            $('#srch').addClass('btn-danger');
            $('#srch').removeClass('btn-primary');
        }
        else {
            if ($('#srch').hasClass('btn-danger')) {
                $('#srch').addClass('btn-primary');
                $('#srch').removeClass('btn-danger');
            }

            /*******  To clear all the data entered  *********/

        }
    });

    $('#search-formm').on('submit', function (e) {
        e.preventDefault();
        if (oTable!=null)
        oTable.destroy()
       oTable = $('#AmcTable').DataTable({
        "processing": true, // for show progress bar
        "serverSide": true, // for process server side
        "filter": true, // this is for disable filter (search box)
        "orderMulti": false, // for disable multiple column at once
        "bStateSave": true,
           retrieve: true,
        "pageLength": 50,
        responsive: true,
        "bLengthChange": false,
        "ajax": {
            "url": '/AMC/GetDetailsdocument',
            "data": function (data) {

                data.documenttype = $('#ddldocumenttype').val();
                data.FromDate = $('#FromDate').val();
                data.ToDate = $('#ToDate').val();



            },
            "type": "POST",
            "datatype": "json"
        },

        "columns": [
            {
                "data": "AmcId", "name": "AmcId",
                "render": function (data, type, row, meta) {
                    return meta.row + meta.settings._iDisplayStart + 1;
                }
            },
            {
                "name": "AmcNo", "data": function (data) {
                    @{
                        var datass = "";
                        datass = "'<a href=\"/AMC/Details/'+ data.AmcId +'\"  target=\"_new\">'+ data.AmcNo +'</a>' ";

                           }
                    return @Html.Raw(datass);
                }
            },
            {
                "name": "CustomerName", "data": function (data) {
                    @{
                        var datas = "";
                        datas = "'<a href=\"/Customer/Details/'+ data.CustomerId +'\"  target=\"_new\">'+ data.CustomerName +'</a>' ";

                           }
                    return @Html.Raw(datas);
                }
            },
            {
                "name": "documenttype", "data": "documenttype"
            },
            {
                "data": "expiryate", "name": "expiryate",
                "render": function (data) {
                    var date = convertToDate(data);
                    return date.toString();
                }
            },
           {
                "name": "AmcId", "data": function (data) {

                    var rest = "";
                    var rest2= "";

                    @{


    //  actData += "<a class=\"modal-create\" href=\"/AMC/DownloadDoc/'+ data.AmcId +'\" title=\"Download Document\"><i class=\"fa-lg fa fa-download\" ></i></a> ";
    if (User.IsInRole("Upload Amc Document"))
    {
        actData += "<a class=\"modal-create\" href=\"/AMC/AddamcImage/'+ data.AmcId +'\" title=\"Add Amc Document\"><i class=\"fa-lg fa fa-upload\" ></i></a> ";
    }
    //                        actData += "<a class=\"Updation\" onclick=\"detailsRemark(' + data.AmcId + ')\" title=\"View AMC Update\"><i class=\"fa-lg fa fa-calendar\" ></i></a> ";

}

                        if (data.docdownload == 0) {

                            rest2 = "<a class=\"btn btn-icons btn-rounded btn-edit \" onclick=\"Alertfn();\" title=\"Download Entry\"><i class=\"fa-lg fa fa-download\" ></i></a> ";

                        } else {
                            rest2 = '<a class=\"btn btn-icons btn-rounded btn-edit modal-create\" href=\"/AMC/DownloadDoc/'+ data.AmcId +'\" title=\"Download Entry\"><i class=\"fa-lg fa fa-download\" ></i></a> ';
                        }
                        return rest += '@Html.Raw(actData)' + rest2;
                }
                },







        ],
        buttons: [
           'colvis',
           {
               extend: 'print',//
               title: "",
               footer: true,
               filename: function () {
                   return 'AMC';
               },
               columnDefs: [
                   { width: 400, targets: 2 }
               ],
               exportOptions: {
                   columns: ':visible'
               },
               message: function () {
                   var head = '<table class="tblcompact table table-bordered"><thead>' +
                   ' <tr><th class="text-center"><h3 style="margin-top: 0px;"><h4>AMC</h4></th></tr>';
                   return head;
               },
               customize: function (win) {
                   // $(win.document.body)
                   //.css('font-size', '10pt')
                   //.css('padding', '1px');
                   $(win.document.body).find('table.tblcompact tbody td').css('padding', '0px');
                   $(win.document.body).find('.dataTable,.dataTable th,.dataTable tr,table.tblcompact tbody td .dataTable td')
                       .css('font-size', '10pt')
                       .css('padding', '5px')
                       .addClass('compact');
                   $(win.document.body).find('.dataTable tr th:nth-child(3)')
                       .css('min-width', '80px');
                   //$(win.document.body).find('.tblcompact tbody td:nth- child(2)')
                   //    .css('padding', '0px');
                   $(win.document.body).append('</td></tr></tbody>')

               }
           }, 'copy', 'csv', 'excel',
           {
               extend: 'pdf',//
               title: "",
               footer: true,
               filename: function () {
                   return 'AMC';
               },
               message: function () {
                   var head = 'AMC';
                   return head;
               },
               pageSize: 'A4',
               exportOptions: {
                   columns: ':visible'
               },
               customize: function (doc) {
                   doc.pageMargins = [10, 10, 10, 10];
                   doc.defaultStyle.fontSize = 10;
                   doc.styles.tableHeader.fontSize = 10;
                   doc.styles.title.fontSize = 12;
                   // Header font and bg color
                   doc.styles.tableHeader.fillColor = '#d3d3d3';
                   doc.styles.tableHeader.color = 'black';
                   // Remove spaces around page title
                   doc.content[0].text = doc.content[0].text.trim();

                   doc.styles['td:nth-child(2)'] = {
                       width: '100%',
                       'max-width': '100%'
                   }

                   var objLayout = {};
                   // Horizontal line thickness
                   objLayout['hLineWidth'] = function (i) { return .5; };
                   // Vertikal line thickness
                   objLayout['vLineWidth'] = function (i) { return .5; };
                   //// Horizontal line color
                   //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                   //// Vertical line color
                   //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                   // Left padding of the cell
                   objLayout['paddingLeft'] = function (i) { return 4; };
                   // Right padding of the cell
                   objLayout['paddingRight'] = function (i) { return 4; };
                   // Inject the object in the document
                   doc.content[1].layout = objLayout;
                   // Footer font and bg color
                   doc.styles.tableFooter.fillColor = '#d3d3d3';
                   doc.styles.tableFooter.color = 'black';
               }
           },@Html.Raw(refreshBTn),
           @Html.Raw(deleteBTn)
        ],

        sDom: "lBfr<'datatable-scroll't>ip",
        "drawCallback": function (settings) {
        }
    });
    });
        $('#modal-create').on('submit', '#createForm', function (e) {
            e.preventDefault();
            var url = $('#createForm')[0].action;
            var data = $('#createForm').serialize();
            createajax(url, data, '#modal-create');
        });

    /* function for delete popup */
    $('.table').on('click', '.modal-delete', function (e) {
        e.preventDefault();
        var url = $(this).attr('href');
        modalshow(url, '#modal-delete');
    });

    $('#modal-delete').on('submit', '#deleteform', function (e) {
        e.preventDefault();
        var url = $('#deleteform')[0].action;
        var data = $('#deleteform').serialize();
        createajax(url, data, '#modal-delete');
        Table.draw(false);
    });

    $('.table').on('click', '.modal-create', function (e) {
        e.preventDefault();
        var url = $(this).attr('href');
        modalshow(url, '#modal-create');
    });
        $('#modal-container2').on('hidden.bs.modal', function () {
            $(this).removeData('bs.modal');
        });
    function detailsRemark(AmcId) {
        var RequisitionId = AmcId;

        //List all other remarks from table CustomerRemarks
        var oTable1 = $('#RemarkInfo').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "paging": false,
            "sortable": true,
            "ordering": true,
            "searching": true,
            "ajax": {
                "url": '/AMC/GetAllRemarksadded',
                "type": "POST",
                "datatype": "json",
                "data": { RequisitionId: AmcId }
            },
            "order": [[0, "desc"]],

            "columns": [
                {
                    "data": "id", "name": "id",
                    "render": function (data, type, row, meta) {
                        return meta.row + meta.settings._iDisplayStart + 1;
                    }
                },
                { "data": "CreatedDate", "name": "CreatedDate", "render": function (data) { if (data != null) { return convertDateTime(data); } else { return "" } } },
                { "data": "EmpName", "name": "EmpName" },
                { "data": "Remarks", "name": "Remarks" },
            ],
        });

        oTable1.destroy();

    }
        $('.table').on('click', 'a.ViewUpdates', function (e) {
        e.preventDefault();
        $(this).attr('data-target', '#modal-container3');
        $(this).attr('data-toggle', 'modal');
    });
    $('div').on('click', '.AddUpdates', function (e) {
        e.preventDefault();
        var url = $(this).attr('href');
        modalshow(url, '#modal-create');
    });
    $('div').on('submit', '#createform', function (e) {
        e.preventDefault();
        var url = $('#createform')[0].action;
        var data = $('#createform').serialize();
        createajax(url, data, '#modal-create');
    });

</script>
