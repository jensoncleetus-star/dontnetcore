<style type="text/css">

    .dropdown-check-list {
        display: inline-block;
    }

        .dropdown-check-list .anchor {
            position: relative;
            cursor: pointer;
            display: inline-block;
            padding: 5px 50px 5px 10px;
            border: 1px solid #ccc;
            width: 150px;
            background: #fff;
            text-align: center;
        }

            .dropdown-check-list .anchor:after {
                position: absolute;
                content: "";
                border-left: 2px solid black;
                border-top: 2px solid black;
                padding: 5px;
                right: 10px;
                top: 20%;
                -moz-transform: rotate(-135deg);
                -ms-transform: rotate(-135deg);
                -o-transform: rotate(-135deg);
                -webkit-transform: rotate(-135deg);
                transform: rotate(-135deg);
            }

            .dropdown-check-list .anchor:active:after {
                right: 8px;
                top: 21%;
            }

        .dropdown-check-list ul.items {
            padding: 0px;
            display: none;
            margin: 0;
            border: 1px solid #ccc;
            border-top: none;
            position: absolute;
            z-index: 9999;
        }

            .dropdown-check-list ul.items li {
                list-style: none;
                background: #fff;
                padding: 5px;
            }

    .add-btn-item {
        border-radius: 23px;
        padding: 6px 20px;
    }

    .dropdown-check-list.visible .anchor {
        color: #0094ff;
    }

    .dropdown-check-list.visible .items {
        display: block;
    }

    .box-header .pull-right {
        margin-top: -22px;
    }

    .col-md-3 {
        float: none;
        display: inline-block;
    }

    @@media only screen and (max-width: 400px) {
        .top3 {
            margin-top: 27px;
        }

        .adv-search-height {
            margin-left: 10px !important;
        }

        .responsive-search {
            padding: 0px 0px 0px 0px !important;
        }

        .btn-close {
            background-color: red !important;
            width: 150px !important;
        }

        .task-name-center {
            text-align: center !important;
        }
    }

    @@media only screen and (min-width: 800px) {
        .top3 {
            margin-top: 10px;
        }

        .adv-search-height {
            top: -8px !important;
            margin-left: 13px;
        }

        .responsive-search {
            padding: 20px 0px 0px 50px !important;
        }

        .btn-close {
            background-color: red !important;
        }

        .btn-h-change {
            margin: 0px !important;
        }

        .btn-up {
            margin-top: 0px !important;
        }
    }
</style>

<div class="box box-info">
    <div class="box-header with-border">
        <div class="row">
            <div class="col-md-10 col-xs-12 task-name-center">
                <h3 class="box-title " style="font-size:x-large;">AMC Report</h3>
            </div>
            <div class="col-md-2 col-xs-12 pull-right" style="padding: 0px; margin: 10px 0px 0px 0px;">
                <div class="row">
                    <div class="col-md-10 col-xs-6 pull-right" style="padding:0px;">
                        <a class="btn btn-info no-border" style="margin-top:2rem; " href="/AMC/Create">
                            <i class="glyphicon glyphicon-plus"></i>Create AMC
                        </a>
                    </div>
                    <div class="col-md-10 col-xs-6 pull-right btn-h-change" style="padding:0px;">
                        <a class="btn btn-info no-border btn-up" style="margin-top:2rem; " href="/AMC/MyAMC">
                            <i class="glyphicon glyphicon-plus"></i>My AMC
                        </a>
                    </div>

                </div>

            </div>
            <div id="modal-container3" class="modal fade" role="dialog" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                            <h4>Remarks</h4>
                        </div>
                        <div class="modal-body">
                            <div class="box-body" id="modelview">
                                <table class="table table-bordered table-hover" id="RemarkInfo">
                                    <thead>
                                        <tr class="bg-gray">
                                            <td>#</td>
                                            <td>Date & Time</td>
                                            <td>Employees</td>
                                            <td>Remarks</td>
                                        </tr>
                                    </thead>
                                    <tbody></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
          
            <div class="col-md-10 col-xs-2 text-right top3" style="">
                &nbsp;
            </div>
            <div class="col-md-12">
                <div class="box-body search-box adv-search-height" id="advsearchlist">

                    <div class="search-body col-md-12 responsive-search" style="background:none;">

                        <form id="search-formm">
                            <div class="row">
                                <input type="hidden" id="remId" />
                                
                                
                                <div class="form-group col-md-2 col-xs-12" id="searchtaskstatus">
                                    @Html.Label("Document Type", null, new { @class = "control-label temp2" })
                                    @Html.DropDownList("documenttype", (SelectList)ViewBag.documenttypes,"All" ,new {@id= "ddldocumenttype", @class = "form-control input-sm select2" })
                                </div>

                                <div class="form-group col-md-2" id="searchRfromdate">
                                    @Html.Label("From Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("FromDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group col-md-2" id="searchRtodate">
                                    @Html.Label("To Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("ToDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>
                              
                               

                                <div class="form-group col-md-2 col-xs-12 text-center " id="search">
                                    <input type="submit" class="btn btn-submit" value="Submit" />
                                </div>
                                <div class="form-group col-md-2 col-xs-12  text-center" id="close">
                                    <input type="button" class="btn btn-close" value="Close" />
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class=" col-md-2" id="searchpagelength">

                <span class="sh-spaan-text-style">Show &nbsp;</span>@Html.DropDownList("ddlPagesize", new SelectList(new List<SelectListItem>
{
new SelectListItem() {Text = "50 Rows", Value="50"},
new SelectListItem() {Text = "All Rows", Value="10000000"},

}, "Value", "Text"), new { @class = "sh-input-drop select2" })

            </div>
        </div>

    </div>
    @using (Html.BeginForm("DeleteAll", "AMC", FormMethod.Post, new { id = "AMC", role = "form" }))
    {
        <div class="box-body">
            <table class="table table-bordered table-hover" id="AmcTable">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="1">S/N</td>
                        <td data-priority="1">Contract No</td>
                        <td data-priority="1">Customer Name</td>
                        <td data-priority="1">Document Name</td>

                        <td data-priority="2">Expiry Date</td>

                        
                        <td data-priority="1">Action</td>

                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    }
</div>

@{var vModel = "modal-lg";}
