@model QuickSoft.Models.rackmaterialcentre
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Create Rack Material Center</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("Create", "RackMC", FormMethod.Post, new { id = "createform" }))
    {
        <script type="text/javascript">
            $('form#createform').removeData("validator");
            $('form#createform').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#createform'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
<div class="row">
    @*<div class="col-md-12">
            <div class="form-group">
                @Html.LabelFor(model => model.shelfName, htmlAttributes: new { @class = "control-label" }) *
                @Html.EditorFor(model => model.shelfName, new { htmlAttributes = new { @class = "form-control", autofocus = "autofocus", @placeholder = "Enter Shelf Name", @required = "required" } })

            </div>
        </div>*@
    <div class="col-md-12">
        <div class="form-group">
            @Html.Label("Rack", null, new { @class = "control-label temp2" })
            @Html.DropDownListFor(model => model.rackid, (SelectList)ViewBag.rk, new { @class = "form-control select2", @required = "required", tabindex = 2 })
        </div>
    </div>
    <div class="col-md-12">
        <div class="form-group">
            @Html.Label("Shelf", null, new { @class = "control-label temp2" })
            @Html.DropDownListFor(model => model.shelfid, (SelectList)ViewBag.slf, new { @class = "form-control select2", @required = "required", tabindex = 2 })
        </div>
    </div>
    <div class="col-md-12">
        <div class="form-group">
            @Html.Label("Material Center", null, new { @class = "control-label temp2" })
            @Html.DropDownListFor(model => model.mcid, (SelectList)ViewBag.mc, new { @class = "form-control select2", @required = "required", tabindex = 2 })
        </div>
    </div>
</div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" value="Save" class="btn btn-info col-sm-offset-4" />
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>
@section scripts{
    @Scripts.Render("~/js/jqueryval")
}
<script>
    $('#rackid').select2({
        tags: true,
        placeholder: 'Select Rack',
        minimumInputLength: 0,
        ajax: {
            url: "/Rack/SearchRack",
            dataType: 'json',
            delay: 50,
            data: function (params) {
                return {
                    q: params.term || "",
                    x: "All",
                    page: params.page || 0,
                };
            },

            processResults: function (data, params) {

                params.page = params.page || 1;

                return {

                    results: data
                };
            },
            cache: true
        },
    });
    $('#shelfid').select2({
        tags: true,
        placeholder: 'Select shelf',
        minimumInputLength: 0,
        ajax: {
            url: "/Shelf/SearchShelf",
            dataType: 'json',
            delay: 50,
            data: function (params) {
                return {
                    q: params.term || "",
                    x: "All",
                    page: params.page || 0,
                };
            },

            processResults: function (data, params) {

                params.page = params.page || 1;

                return {

                    results: data
                };
            },
            cache: true
        },
    });
    $('#mcid').select2({
        tags: true,
        placeholder: 'Select MC',
        minimumInputLength: 0,
        ajax: {
            url: "/RackMC/SearchMC",
            dataType: 'json',
            delay: 50,
            data: function (params) {
                return {
                    q: params.term || "",
                    x: "All",
                    page: params.page || 0,
                };
            },

            processResults: function (data, params) {

                params.page = params.page || 1;

                return {

                    results: data
                };
            },
            cache: true
        },
    });
</script>

