@model QuickSoft.Models.Department
        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
            <h4>Add Department</h4>
        </div>
        <div class="modal-body">
            @using (Html.BeginForm("Create", "Department", FormMethod.Post, new { id = "createform" }))
            {
                <script type="text/javascript">
                    $('form#popupFormDepartment').removeData("validator");
                    $('form#popupFormDepartment').removeData("unobtrusiveValidation");
                    $.validator.unobtrusive.parse($('form#popupFormDepartment'));
                </script>
                @Html.AntiForgeryToken()
                @Html.ValidationSummary("", new { @class = "alert alert-danger" })
                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group">
                            @Html.Label("Department", null, new { @class = "control-label" }) *
                            @Html.EditorFor(model => model.DepartmentName, new { htmlAttributes = new { @class = "form-control input-sm", autofocus = "autofocus", @required = "required" } })
                        </div>
                    </div>
                    @if (@ViewBag.EnablePayroll == 0)
                    {
                    <div class="col-md-12 hidden">
                        <div class="form-group">
                            @Html.Label("Calendar Template", null, new { @class = "control-label" })
                            @Html.DropDownListFor(model => model.CalendarTemplateId, (SelectList)ViewBag.CTemplates, new { htmlAttributes = new { @class = "form-control input-sm" } })
                        </div>
                    </div>
                    }
                </div>
                <div class="row">
                    <div class="col-md-12">
                        <div class="box-footer">
                            <input type="submit" value="Save" class="btn btn-info col-sm-offset-4"/>
                            <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                        </div>
                    </div>
                </div>
                <script>
                    $("#CalendarTemplateId").select2({
                        placeholder: 'Search by Calendar Template',
                            minimumInputLength: 0,
                            ajax: {
                                url: "/CalendarTemplate/SearchCalendarTemplate",
                                dataType: 'json',
                                delay: 50,
                                data: function (params) {
                                    return {
                                        q: params.term || "",
                                        page: params.page || 0,
                                        x: "empty"
                                    };
                                },
                                processResults: function (data, params) {
                                    params.page = params.page || 0;
                                    return {
                                        results: data,
                                        pagination: {
                                            more: true
                                        }
                                    };
                                },
                                cache: true
                            },
                        });
                    
                </script>
            }
        </div>
@section scripts{
    @Scripts.Render("~/js/jqueryval")
}