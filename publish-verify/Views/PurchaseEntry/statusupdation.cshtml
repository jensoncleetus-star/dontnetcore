@model QuickSoft.Models.PurchaseEntry
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Change Status</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("statusupdation", "PurchaseEntry", FormMethod.Post, new { role = "form", id = "editform" }))
    {
        <script type="text/javascript">
            $('form#popupForm').removeData("validator");
            $('form#popupForm').removeData("unobtrusiveValidation");
        </script>
        <div class="row">
            <div class="form-group col-md-12">
                @Html.Label("Purchase  Status", null, new { @class = "control-label" })
                @Html.DropDownList("PurchaseStatus", new SelectList(new List<SelectListItem>
                        {
                         new SelectListItem() {Text = "Open", Value="0"},
                         new SelectListItem() {Text = "Closed", Value="1"},
                        }, "Value", "Text"), new { @class = "form-control input-sm", @name = "Emirate" })
            </div>
           </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" class="btn btn-info col-sm-offset-4" value="Update" />
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>

