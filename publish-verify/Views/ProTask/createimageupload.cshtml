    function printtask(data) {

        var dat = convertToDate(data.protask.logtime);
        $("#lbltask").text(data.protask.TaskName);
        $("#lblDate").text(dat);
        $("#lblProject").text(data.protask.ProjectName);
        if (data.protask.EndDate!=null)
        var dat2 =convertToDate(data.protask.EndDate)
        $("#lblprojectcmpdate").text(dat2);
        
        var adcount = 1;
        var str1 = "<tr>";

            str1 += '<td>Before(WO)</td>';
            str1 += '<td>Photo After(Payment)</td>';



        str1 += '</tr>';
        $('#addfield').append(str1);
