                                    status = '<span class="badge bg-aqua">Created</span>';
                                }
                                else if (data.TaskStatus == "Accepted") {
                                    status = '<span class="badge bg-light-blue">Accepted</span>';
                                }
                                else if (data.TaskStatus == "Rejected") {
                                    status = '<span class="badge bg-green">Rejected</span>';
                                }
                                else if (data.TaskStatus == "Assigned") {
                                    status = '<span class="badge bg-teal">Assigned</span>';
                                }
                                else if (data.TaskStatus == "ClosedPending") {
                                    status = '<span class="badge bg-orange">Pending</span>';
                                }
                                else if (data.TaskStatus == "Started") {
                                    status = '<span class="badge bg-green">Started</span>';
                                }
                                else if (data.TaskStatus == "InProgress") {
                                    status = '<span class="badge bg-yellow">InProgress</span>';
                                }
                                else if (data.TaskStatus == "ClosedCompleted") {
                                    status = '<span class="badge bg-black">Completed</span>';
                                }
                                else if (data.TaskStatus == "Canceled") {
                                    status = '<span class="badge bg-red">Canceled</span>';
                                }
                                else if (data.TaskStatus == "Hold") {
                                    status = '<span class="badge bg-lime">Hold</span>';
                                }
                                else if (data.TaskStatus == "Verified") {
                                    status = '<span class="badge bg-navy">Verified</span>';
                                }
                                else if (data.TaskStatus == "Reopen") {
                                    status = '<span class="badge bg-purple">Reopen</span>';
                                }
                                else if (data.TaskStatus == "Reassigned") {
                                    status = '<span class="badge bg-teal-active">Reassigned</span>';
                                }
                                return '<a  class="Updation" onclick="details(' + data.ProTaskId + ')"  title="View Status">' + status + ' </a>';
                            }
