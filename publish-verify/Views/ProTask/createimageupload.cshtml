                      { "data": "Remark", "name": "Remark" },
                      { "data": "Status", "name": "Status" },
                      {
                          "name": "Checklist", "data": function (data) {
                              var rest = "";
                              var chk = "";
                              $.each(data.CheckItems, function (i, item) {
                                  var check = (item.Chck == true) ? "checked" : "";

                                  chk += "<td><input name='bstmodel[" + (i) + "].Check' " + check + " id='checkbox_" + item.Id + "' type=\"checkbox\" name=\"note\"></input></td>" +
                                         "<td><label for='" + item.Id + "'>" + item.Name + "</label></td>";
                                  if (item.Chck == true) {
                                      chk += "<td><textarea data-name='Note' name='bstmodel[" + (i) + "].Note' value=" + item.Note + " id='addnote_" + item.Note + "' class='addnote_" + item.Note + " form-control text-left addnote' placeholder='Enter note'></textarea></td> "
                                  }
                              })
                              return chk;
                          }
                      },
                       {
                           "name": "RImages", "data": function (data) {
                               var rest = "";
                               var count = 1;
                               $.each(data.RImages, function (i, item) {

                                   if (item.FileName != null && item.FileName != "" && item.TaskDocumentId != 0) {

                                       var x = item.FileName.split('.');
                                       var extn = x[1];

                                       var FileName = x[0].substring(0, x[0].length - 20) + "." + extn;
                                       if (extn == "docx" || extn == "doc" || extn == "pdf") {

                                           @{
                                               actImg = "<a href=\"/uploads/protaskdocuments/'+ item.FileName +'\" data-lightbox=\"/uploads/protaskdocuments/'+ item.FileName +'\" data-title=\"'+ FileName +'\"><img ></a><a href=\"/uploads/protaskdocuments/'+ item.FileName +'\" download class=\"btn btn-primary btn-xs\">download</a><br>";
                                               //actImg = " <img style=\"height:50px;width:50px\"src=\"~/uploads/protaskdocuments/thumb_'+ item.FileName+'\"/>";
                                           }

                                           rest += '@Html.Raw(actImg)';


                                       }
                                       if (extn == "jpg" || extn == "jpeg" || extn == "png" || extn == "gif") {
                                           //var rest = "";
                                           @{
                                               actImg = "<a href=\"/uploads/protaskdocuments/'+ item.FileName +'\" data-lightbox=\"/uploads/protaskdocuments/'+ item.FileName +'\" data-title=\"'+ FileName +'\"><img style=\"height:50px;width:50px\"src=\"/uploads/protaskdocuments/'+ item.FileName +'\"/></a><a href=\"/uploads/protaskdocuments/'+ item.FileName +'\" download class=\"btn btn-primary btn-xs\">download</a><br>";
                                           }
                                           rest += '@Html.Raw(actImg)';


                                       }
                                       count++;
                                   }
                               })
                               return rest;

                           }
                       },
                ],
            });
            oTable2.destroy();
        }

