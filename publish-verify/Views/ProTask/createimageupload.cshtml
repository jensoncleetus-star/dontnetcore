            var str = "<tr>";

            str += '<td><img src="/uploads/protaskdocuments/resize_' + item.TaskImageId + '.jpg" height="200" width="300" style="padding-right="20px"/><br>' + item.description+'</td>';
            str += '<td><img src="/uploads/protaskdocumentsnew/resize_' + item.TaskImageId + '.jpg" height="200" width="300"/><br>' + item.newdescription + '</td>';



            str += '</tr>';
            adcount++;
            $('#addfield').append(str);
        });

