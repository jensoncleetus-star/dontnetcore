        $('#createForm').on('submit', function (e) {
            e.preventDefault();
            var tsktype = '@ViewContext.RouteData.Values["type"]';
            if ($("#createForm").valid()) {
                var url = $('#createForm')[0].action;
                var formData = new FormData(this);
                var files = $("#input-24").get(0);
                if (files.files.length <= 0) {
                    //alert("Please upload File");
                    //return true;
                }
                if (files.files.length > 0) {
                    for (var i = 0; i < files.length; i++) {
                        formData.append("input-24", files[i]);
                    }
                }
                $.ajax({
                    async: true,
                    cache: false,
                    dataType: "json",
                    type: "POST",
                    processData: false,
                    contentType: false,
                    url: url,
                    data: formData,//JSON.stringify(parameters),
                    beforeSend: function () {
                        $("button").prop('disabled', true); // disable button
                    },
                    success: function (e) {
                        if (e.status) {
                            $('.ajax_response', res_success).text(e.message);
                            $('.AlertDiv').prepend(res_success);
                            if (tsktype == "MyTask")
                                window.location.href = '@Url.Action("MyTask", "ProTask")';
                            else {
                                window.location.href = '@Url.Action("Index", "ProTask")';
                            }
                        }
                        else {
                            $('.ajax_response', res_danger).text(e.message);
                            $('.AlertDiv').prepend(res_danger);
                            $("button").prop('disabled', false); // enable button
                        }
                    }
                });
            }
        });

        //Function to check correct format for Mobile Number
        //MobileNo is not passed in fetched rows(Edit Mode Rows)
        function CheckMobileNo(MobileNo, i) {
            var Mobile;

            if (MobileNo == "") {
                Mobile = document.getElementById("Mobile[" + i + "]").value;
                Mobile = Mobile.replace(/^0+/, '');
                document.getElementById("Mobile[" + i + "]").value = Mobile;
            }
            else
                Mobile = MobileNo;

            var NumbersOnly = /[^0-9]/g;
            var NewMob = (Mobile.replace(NumbersOnly, ""));

            if (Mobile != NewMob) {
                alert("Please Select Correct Format For Mobile..(Numbers Only)");

                if (MobileNo == "") {
                    document.getElementById("Mobile[" + i + "]").value = "";
                    document.getElementById("Mobile[" + i + "]").focus();
                }
                else {
                    var opt = '<option value="" selected>5xxxxxxxx</option>'
                    $("#Mobile" + i).append(opt);
                    mobileload();
                }
            }
            else if (Mobile.length > 9) {
                alert("Only 9 numbers are allowed...")

                if (MobileNo == "") {
                    document.getElementById("Mobile[" + i + "]").value = "";
                    document.getElementById("Mobile[" + i + "]").focus();
                }
                else {
                    var opt = '<option value="" selected >5xxxxxxxx</option>'

                    $("#Mobile" + i).append(opt);
                    mobileload();
                }
            }
        }
