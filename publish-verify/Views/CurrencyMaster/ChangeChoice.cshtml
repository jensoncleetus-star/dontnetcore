<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>    
</div>
<div class="modal-body">
    <h2>Are you sure you want to Change Choice</h2>
    <hr />
    @using (Html.BeginForm("ChangeChoice", "CurrencyMaster", FormMethod.Post, new { id = "changeform" }))
            {
        @Html.AntiForgeryToken()
        <div class="form-actions no-color">
            <input type="submit" value="Change Choice" class="btn btn-danger col-sm-offset-4" />
            <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal">
        </div>
    }
</div>

