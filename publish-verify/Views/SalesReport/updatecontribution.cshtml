
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Change Status</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("updatecontribution", "SalesReport", FormMethod.Post, new { role = "form", id = "createform" }))
    {
        <script type="text/javascript">
        
        </script>
        <div class="row">
            <div class="form-group col-md-12">
                @Html.Label("Enter Contribution %", null, new { @class = "control-label" })
                @Html.Editor("percentage", new { htmlAttributes = new { @class = "form-control", @type = "number",@required="required" } })



            </div>
            <input type="hidden" name="salesid" value="@ViewBag.salesids" />
            <input type="hidden" name="empid" value="@ViewBag.impids" />

        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" class="btn btn-info col-sm-offset-4" value="Update" />
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>



