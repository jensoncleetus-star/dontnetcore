
@{

    ViewBag.Title = "Search Sales Return Entry";
    ViewBag.SubTitle = "Sales Return Report";
    ViewBag.Active = "Reports";
    string actData = "";
    string actData2 = "";
    string actData3 = "";
    string actData4 = "";
    string posfun = "";
    posfun = "PrintInvoice(e, \"sales\",\"inactive\",\"SalesEntry\");";
    @Html.Action("invoice", "InvoiceLayout", new { type = "Sale" })
}
