                              }
                        return @Html.Raw(actData);
                    }
                },
                { "data": "SRDate", "name": "SRDate", "render": function (data) { return convertToDate(data); } },
                //{ "data": "PayMethod", "name": "PayMethod" },
                //{ "data": "Customer", "name": "Customer" },
                {
                    "name": "Customer", "data": function (data) {
                        @{

                                actData2 += "'<a href=\"/Customer/Details/'+ data.CustomerID +'\" target=\"_blank\">'+ data.Customer +'</a>' ";
                                //actData2 += "'<a href=\"/CreditSale/Download/'+ data.SalesEntryId +'\" target=\"_new\"><i class=\"fa-lg fa fa-download\" ></i></a> '";
                            }
                        return @Html.Raw(actData2);
                    }
                },
                {
                    "name": "Customer", "data": function (data) {
                        @{

                            //actData2 += "'<a href=\"/Customer/Details/'+ data.CustomerID +'\" target=\"_new\">'+ data.Customer +'</a>' ";
                            actData4 += "'<a href=\"/MyReports/Ledger3?particular='+ data.AccountsID +'\" title=\"Ledger\" target=\"_blank\"><i class=\"fa-lg fa fa-external-link-square\" ></i></a> '";

                        }
                        return @Html.Raw(actData4);
                    }
                },
                { "data": "taxableAmt", "name": "taxableAmt", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                { "data": "tax", "name": "tax", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                { "data": "discount", "name": "discount", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
