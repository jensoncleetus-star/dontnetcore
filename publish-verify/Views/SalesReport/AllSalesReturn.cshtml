                { "data": "SEGrandTotal", "name": "SEGrandTotal", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                //Total Amt { "data": "SEGrandTotal", "name": "SEGrandTotal", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                //Paid Amt { "data": "SEPaidAmount", "name": "SEPaidAmount", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                //Balance Amt { "data": "SEBalanceAmount", "name": "SEBalanceAmount", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                //  { "data": "lastpaydate", "name": "lastpaydate", "render": function (data) { return convertToDate(data); } },
                { "data": "EmpName", "name": "EmpName" },

                { "data": "MCName", "name": "MCName" },


                //{
                //    "data": "SaleType", "name": "SaleType", "render": function (data) {
                //        if (data == 2) {
                //            return 'Hire';
                //        }
                //        else {
                //            return 'Sale';
                //        }

                //    }

                //}
