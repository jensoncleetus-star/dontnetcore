<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">Search Sales Return Entry</h3>
    </div>

    <div class="box-body">
        <form id="search-form">
            @using (Html.BeginForm("Index", "SalesReturnReport", FormMethod.Post, new { id = "popupForm", target = "_new" }))
            {
                <div class="form-group col-md-2">
                    <input type="hidden" id="cname" value="@ViewBag.CName" />
                    <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
                    @Html.Label("Invoice No", null, new { @class = "control-label" })
                    @Html.TextBox("InvoiceNo", "", new { @class = "form-control input-sm" })
                </div>
                <div class="form-group col-md-2" style="display:none">
                    @Html.Label("Payment Type", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlType", new SelectList(new List<SelectListItem>
                        {
                            new SelectListItem() {Text = "All", Value=""},
                            new SelectListItem() {Text = "Credit Sale", Value="0"},
                            new SelectListItem() {Text = "Cash Sale", Value="1"}
                        }, "Value", "Text"), new { @class = "form-control input-sm", @name = "ddlType", @onchange = "customertype()" })
                </div>
                <div class="form-group col-md-2" id="divpaymethod">
                    @Html.Label("Payment Method", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlPayMethod", (SelectList)ViewBag.PayMethod, "Cash", new { @class = "form-control input-sm" })
                </div>
                <div class="form-group col-md-2" id="creditsale">
                    @Html.Label("Customer", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlCustomer", (SelectList)ViewBag.Customer, new { @class = "form-control input-sm select2" })
                </div>
                <div class="form-group col-md-2" id="execreditsale">
                    @Html.Label("Sales Executive", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlEmployee", (SelectList)ViewBag.SalesExecutive, new { @class = "form-control input-sm select2" })
                </div>
                <div class="form-group col-md-2" id="execreditsale">
                    @Html.Label("Sales Man", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlSalesMan", (SelectList)ViewBag.SalesMan, new { @class = "form-control input-sm select2" })
                </div>
                if (@ViewBag.EnableMCcheck == 0)
                {
                    <div class="form-group col-md-2">
                        @Html.Label("Material Center", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlMC", (SelectList)ViewBag.MC, new { @class = "form-control input-sm" })
                    </div>
                }
                if (@ViewBag.ProjChk == 0)
                {
                    <div class="form-group col-md-2">
                        @Html.Label("Project", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlProject", (SelectList)ViewBag.getProj, "All", new { @class = "form-control input-sm" })
                    </div>
                    <div class="form-group col-md-2">
                        @Html.Label("Task", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlProTask", (SelectList)ViewBag.getProTask, "All", new { @class = "form-control input-sm" })
                    </div>
                }
                @*<div class="form-group col-md-4">
                        @Html.Label("Branch", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlBranch", (SelectList)ViewBag.Branch, new { @class = "form-control input-sm select2" })
                    </div>*@
                <div class="form-group col-md-2">
                    @Html.Label("From", null, new { @class = "control-label" })
                    <div class="input-group date">
                        @Html.TextBox("From", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                        <div class="input-group-addon">
                            <i class="fa fa-calendar"></i>
                        </div>
                    </div>
                </div>
                <div class="form-group col-md-2">
                    @Html.Label("To", null, new { @class = "control-label" })
                    <div class="input-group date">
                        @Html.TextBox("To", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                        <div class="input-group-addon">
                            <i class="fa fa-calendar"></i>
                        </div>
                    </div>
                </div>
                <div class="form-group col-md-2" id="DDlItemwise">
                    @Html.Label("Item Name/Code", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlItem", (SelectList)ViewBag.Item, new { @class = "form-control input-sm select2" })
                </div>
                <div class="form-group col-md-2" id="creditsale">
                    @Html.Label("Item Category", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlItemCategory", (SelectList)ViewBag.Category, new { @class = "form-control input-sm select2" })
                </div>
                <div class="form-group col-md-2" id="creditsale">
                    @Html.Label("Item Brand", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlItemBrand", (SelectList)ViewBag.Brand, new { @class = "form-control input-sm select2" })
                </div>
                <div class="form-group col-md-2">
                    @Html.Label("Search", null, new { @class = "control-label" })
                    @Html.TextBox("Searchtext", "", new { @class = "form-control input-sm" })
                </div>
                @*<div class="form-group col-md-2" id="execreditsale">
                        @Html.Label("Tax Type", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlTaxType", (SelectList)ViewBag.TaxType, new { @class = "form-control input-sm select2" })
                    </div>*@
                if (@ViewBag.BusinessType == "Scaffold")
                {
                    <div class="form-group col-sm-2">
                        @Html.Label("Type", null, new { @class = "control-label" })
                        @Html.DropDownList("SaleType", (SelectList)ViewBag.Type, new { @class = "form-control input-sm", @onchange = "HType();" })
                    </div>

                    <div id="HireTypeDiv">
                        <div class="form-group col-sm-2">
                            @Html.Label("HireType", null, new { @class = "control-label" })
                            @Html.DropDownList("HireType", (SelectList)ViewBag.HiType, "All", new { id = "ddlHType", @class = "form-control select2" })
                        </div>
                        <div class="form-group col-md-2">
                            @Html.Label("From Date", null, new { @class = "control-label" })
                            <div class="input-group date">
                                @Html.TextBox("FromDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off", @onchange = "DateSet();" })
                                <div class="input-group-addon">
                                    <i class="fa fa-calendar"></i>
                                </div>
                            </div>
                        </div>
                        <div class="form-group col-md-2">
                            @Html.Label("To Date", null, new { @class = "control-label" })
                            <div class="input-group date">
                                @Html.TextBox("ToDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                <div class="input-group-addon">
                                    <i class="fa fa-calendar"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <div class="box-footer col-md-12">
                    <input type="submit" class="btn btn-info col-sm-offset-5" value="Submit" />
                    <button type="button" class="btn btn-default" onclick="@("window.location.href='/Home/Index'");">Cancel</button>
                </div>
            }
        </form>
    </div>
</div>
<div class="box box-default" id="StockReport">
    <div class="box-header with-border">
        <h3 class="box-title">View Sales Return  Report</h3>
    </div>
    <div class="box-body">
        <input type="hidden" id="cname" value="@ViewBag.CName" />
        <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
        <input type="hidden" id="invoiceno" value="@ViewBag.InvoiceNo" />
        <input type="hidden" id="fromdate" value="@ViewBag.fromdate" />
        <input type="hidden" id="todate" value="@ViewBag.todate" />
        <input type="hidden" id="matcenter" value="@ViewBag.EnableMCcheck" />
        <input type="hidden" id="Scaffold" value="@ViewBag.BusinessType" />
        <div class="box-body">
            <table class="display table table-bordered" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="2">S/N</td>
                        <td data-priority="1">Invoice No.</td>
                        <td data-priority="2">Date</td>
                        @*<td data-priority="3">Pay Method</td>*@
                        <td data-priority="2">Customer</td>

                        <td>Ledger</td>
                        <td data-priority="1" class="text-right">Taxable Amount</td>
                        <td class="text-right">Tax</td>
                        <td class="text-right">Discount</td>
                        <td class="text-right">Roundoff(-)</td>
                        <td class="text-right">Roundoff(+)</td>
                        <td data-priority="1" class="text-right">Grand Total</td>
                        @*<td>TRN</td>*@
                        @*<td data-priority="2">Item Amt</td>*@
                        @*<td data-priority="1" class="headeralign">Total Amt</td>
                            <td class="headeralign">Paid Amt</td>
                            <td class="headeralign">Balance Amt</td>*@
                        @*<td data-priority="3">Last Paid Date</td>*@
                        <td>Sales Executive</td>
                        <td id="matcol">Material Center</td>


                        @*<td id="SaleTy">SaleType</td>*@

                        @*<td>Created By</td>*@
                        @*<td>Branch</td>*@
                    </tr>
                </thead>
                <tbody></tbody>
                <tfoot>
                    <tr>
                        <th>Total:</th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>

                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/bootstrap-timepicker")
}
@section Scripts {
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/num2words")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/bootstrap-timepicker")
    <script src="~/Content/js/salesinvoice2.js"></script>
    <script type="text/javascript">
    $('.date').datepicker({
        format: 'dd-mm-yyyy',
        autoclose: true,
        allowInputToggle: true
    })
    $(document).ready(function () {
        /*datatable still hided before clicking the submit button*/

        $("#StockReport").hide()
        /*end*/
        $("#divpaymethod").hide();
        $('#HireTypeDiv').hide();
        //$("#SaleType").val(1);
        $('#SaleType option:contains(POS)').remove();

        $("#SaleType").prop('selectedIndex', 0);
        //customertype();
        //customertype();
        //for set default date
        $('#To').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });
        $('#From').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });

        var date = new Date();
        var today = new Date(date.getFullYear(), date.getMonth(), date.getDate());
        var priordate = new Date(new Date().setDate(today.getDate() - 30));
        $('#To').datepicker('setDate', today);
        $('#From').datepicker('setDate', priordate);
        //---

        //GetProjectWithAll();
        //GetTaskWithAll();
        ItemSearchable();
        // Material Center
        CallRepCustomer();
        CallRepEmployee();
        CallRepMCUser();
        $("#ddlItemBrand").select2({
            placeholder: 'Search Item Brand',
            minimumInputLength: 0,
            ajax: {
                url: "/ItemBrand/SearchBrand",
                dataType: 'json',
                type: "POST",
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term,
                        page: params.page,
                        x: "all"
                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 1;

                    return {
                        results: data
                    };
                },
                cache: true
            },
        });
        $("#ddlItemCategory").select2({
            placeholder: 'Search Item Category',
            minimumInputLength: 0,
            ajax: {
                url: "/ItemCategory/SearchCategory",
                dataType: 'json',
                type: "POST",
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term,
                        page: params.page,
                        x: "All"
                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 1;

                    return {
                        results: data
                    };
                },
                cache: true
            },
        });
        $("#ddlSalesMan").select2({
            placeholder: 'Search by Name ',
            minimumInputLength: 0,
            ajax: {
                url: "/Employee/SearchEmployee",
                dataType: 'json',
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term || "",
                        page: params.page || 0,
                        x: "empty"

                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 0;

                    return {
                        results: data,
                        pagination: {
                            //more: (params.page * 10) < 50
                            more: true
                        }
                    };
                },
                cache: true
            },
        });


    });

    function customertype() {
        var type = $("#ddlType").val();
        if (type == 0) {
            $('#divpaymethod').hide();
        } else {
            $('#divpaymethod').show();
        }
    }


    function HType() {
        var Type = $('#SaleType').val();
        if (Type == 2) {
            $('#HireTypeDiv').show();
        }
        else {
            $('#HireTypeDiv').hide();
        }
    }
    function DateSet() {
        var ndate = $('#FromDate').val();

        $('#ToDate').datepicker({
            startDate: ndate,
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });

    }

    function download2(salesid) {

        $.ajax({
            url: '/creditsalereturn/downloadprint/?salesEntryId=' + salesid,
            type: "GET",
            contentType: false, // Not to set any content header
            processData: false, // Not to process data

            success: function (e) {


    @Html.Raw(posfun)
                setTimeout(function () { window.location.href = '/SalesReport/Index'; }, '5000');//{ location.reload(); }, 'TimeOut');

            }


        });
    }


    function searchData(data) {


        data.seno = $('#InvoiceNo').val();
        data.paymethod = $('#ddlPayMethod').val();
        data.customer = $('#ddlCustomer').val();
        data.SalesExecutive = $('#ddlEmployee').val();
        data.SalesMan = $('#ddlSalesMan').val();
        data.fromdate = $('#From').val();
        data.todate = $('#To').val();
        data.type = $('#ddlType').val();
        data.ddMC = $('#ddlMC').val();
        data.satype = $('#SaleType').val();
        data.htype = $('#HireType').val();
        data.hfdate = $('#FromDate').val();
        data.htdate = $('#ToDate').val();
        data.project = $('#ddlProject').val();
        data.task = $('#ddlProTask').val();
        data.item = $('#ddlItem').val();
        data.category = $('#ddlItemCategory').val();
        data.brand = $('#ddlItemBrand').val();
        data.srchtxt= $('#Searchtext').val();
        //data.TaxType = $('#ddlTaxType').val();

    }

    function showdatatable() {
        var oTable = $('#UserTable').DataTable({
            "processing": true, // for show progress bar
