    <script src="~/Content/js/employee.js?c=33"></script>
    <script type="text/javascript">
        var date = new Date();
        date.setDate(date.getDate());
        $('.date').datepicker({
            //startDate: date,
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });
        jQuery.validator.methods["date"] = function (value, element) { return true; }
        $('a,div').on('click', '.modal-create-lg', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create-lg');
            //$('#KeepStock').prop('checked', true);
            //$('#StockSection').show();
            //$("#SubUnitId").rules("remove", "required");
        });

        $(document).ready(function () {
            checkAddress();
            checkuser();
            if ("@Model.UserStatus" == "True" && "@Model.currentUser" != "@Model.UserId") {
                $("#UserSection").show();
                $('#UserStatus').prop('checked', true);
            } else {
                $("#UserSection").hide();
                $('#UserStatus').prop('checked', false);
            }
            var EntryID = getQueryString('');
            if (EntryID != null) {
                $.ajax({
                    url: '/Employee/GetMobile',
