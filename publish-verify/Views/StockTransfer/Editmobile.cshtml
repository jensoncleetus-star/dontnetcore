@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @*@Scripts.Render("~/js/partymaterials")*@
    @Scripts.Render("~/js/num2words")
    @Scripts.Render("~/js/wysihtml5")
<script src="~/Content/js/partymaterials2.js"></script>

    <script type="text/javascript">

        var getQueryString = function (field, url) {
            var href = url ? url : window.location.href;
            var id = href.substring(href.lastIndexOf('/') + 1);
            return id ? id : null;
        }

        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });
        jQuery.validator.methods["date"] = function (value, element) { return true; }
        $(document).ready(function () {


            searchItem();

            $("#ddlMCFrom").select2({
                placeholder: 'Search Material Centre by Name or Code',
                minimumInputLength: 0,
                ajax: {
                    url: "/MC/SearchMC",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term,
                            page: params.page,
                            x: ""
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;
                        return {
                            results: data
                        };
                    },
                    cache: true
                },
            });

            $("#ddlMCTo").select2({
                placeholder: 'Search Material Centre by Name or Code',
                minimumInputLength: 0,
                ajax: {
                    url: "/MC/SearchMC",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term,
                            page: params.page,
                            x: ""
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;
                        return {
                            results: data
                        };
                    },
                    cache: true
                },
            });
            $("#SelApprovedBy").val($("#ddlApprovedBy").val());
            var EntryID = getQueryString('');

            if('@ViewBag.StockTrnsfrUpdate'=="inactive"){
               // var temURL='/StockTransfer/GetSTItems';
                CallApprovedBy();
            }
            else {

                //CallApprovedBy2();
                $("#ddlApprovedBy").select2({
                    placeholder: 'Search User',
                    minimumInputLength: 0,
                    ajax: {
                        url: "/Employee/SearchEmployeeUser2",
                        dataType: 'json',
                        delay: 50,
                        data: function (params) {
                            return {
                                q: params.term,
                                page: params.page
                            };
                        },
                        processResults: function (data, params) {
                            params.page = params.page || 1;
                            return {
                                results: data
                            };
                        },
                        cache: true
                    },
                });
            }
            if ('@ViewBag.StockTrnsfrUpdate' == "inactive") {
                var temURL = '/StockTransfer/GetSTItems';
            } else if ('@ViewBag.itemAproval' == 1) {
                var temURL = '/StockTransfer/GetSTItems2';
            } else {
                var temURL = '/StockTransfer/GetSTItems';

            }


            if (EntryID != null) {
                $.ajax({
                    url:temURL, //'/StockTransfer/GetSTItems',
                    dataType: 'json',
                    data: { EntryID: EntryID },
                    cache: true,
                    success: function (data) {
                        $('#addinvoiceItem').html('');
                        $.each(data, function (i, item) {
                            addrow('addinvoiceItem', 'foredit', item.Unit, item.Quantity, item.Price, item.Amount, item.Item, item.ItemName, item.ItemWithCode, item.ItemNote, item, item.ConFactor);
                            var j = i + 1;
                            $("#unit_name_" + j).val(item.Unit);
                        });
                        addrow('addinvoiceItem', 'sales', '', '0.00', '0.00', '0');
                    }
                });

                $.ajax({
                    url: '/StockTransfer/GetSTBillSundry',
                    dataType: 'json',
                    data: { EntryID: EntryID },
                    cache: true,
                    success: function (data) {
                        $.each(data, function (i, bs) {
                            addbillsundry('addbillsundry', 'sales', bs.BsValue, bs.AmountType, bs.BsAmount, bs.BsType, bs.BSName, bs.BillSundry);
                        });
                        addbillsundry('addbillsundry', 'sales', '0.00', '', '0.00', '');
                        grandtotalcalculation();
                    }
                });

            }

            $("#SelApprovedBy").val($("#ddlApprovedBy").val());

            chkEditEditable("@ViewBag.ChkApp");

            var stkval = $("#StockType").val();
            if(stkval == "1"){
                $('#ddlMCFrom').prop('disabled', true);
            }else{
                $('#ddlMCFrom').prop('disabled', false);
            }

        });
        $('body').on('change', '#ddlApprovedBy', function (e) {
            $("#SelApprovedBy").val($(this).val());
        });

        $('#Editform').on('submit', function (e) {
            e.preventDefault();
            var fnval = $('input[type="submit"], button[type="submit"]', this).filter(':focus').attr('id');
            var warnmsg=@ViewBag.WarnMsg;
            if(warnmsg == 0){
                var WMsg = confirm("Do you want to Save..?");
                if(WMsg==true){
                    SaveFunction(fnval);
                }else{
                }
            }else{
                SaveFunction(fnval);
            }
        });


        function SaveFunction(fnval) {
            var tem = $("#ddlApprovedBy").val();
            $("#SelApprovedBy").val(tem);
            if ($("#Editform").valid()) {
