        function PrintStockTransferInvoice(e,type)
        {

            $("#lblCName").text(e.cdetails.CName);
            $("#lblVoucherNo").text(e.summary.VoucherNo);
            $("#lblDate").text(convertToDate(e.summary.Date));
            $("#lblCreatedBy").text(e.summary.CreatedBy);
            $("#lblMaterialFrom").text(e.summary.MCFrom);
            $("#lblMaterialTo").text(e.summary.MCTo);
            $("#lblRemark").text(e.summary.Remark);
            // bindPOSItem(e);
            var itemsData = bindPOSItem(e);
            $('#itemtable').append(itemsData);
            $("#lblAmount").text(parseFloat(e.summary.ItemSubTotal).toFixed(2));
            $("#lblGrandTotal").text(parseFloat(e.summary.GrandTotal).toFixed(2));

            if (e.summary.ComHeadCheck == 0) {
                $("#ComHeadCheck").hide();
            }
            else {
                $("#ComHeadCheck").show();
            }

            if (e.fmapp!=null) {
                $.each(e.fmapp, function (i, mapp) {

                    if (mapp.Field == "Ref1") {
                        $("#IblRef1").text(mapp.FieldName);
                        $("#IblRef1Val").text(e.summary.Ref1);
                        $("#divRef1").show();
                    }
                    if (mapp.Field == "Ref2") {
                        $("#IblRef2").text(mapp.FieldName);
                        $("#IblRef2Val").text(e.summary.Ref2);
                        $("#divRef2").show();
                    }
                    if (mapp.Field == "Ref3") {
                        $("#IblRef3").text(mapp.FieldName);
                        $("#IblRef3Val").text(e.summary.Ref3);
                        $("#divRef3").show();
                    }
                    if (mapp.Field == "Ref4") {
                        $("#IblRef4").text(mapp.FieldName);
                        $("#IblRef4Val").text(e.summary.Ref4);
                        $("#divRef4").show();
                    }
                    if (mapp.Field == "Ref5") {
                        $("#IblRef5").text(mapp.FieldName);
                        $("#IblRef5Val").text(e.summary.Ref5);
                        $("#divRef5").show();
                    }
                });
            }

            var grt = parseFloat(e.summary.GrandTotal).toFixed(2);
            var word = conNumber(grt);
            //word = word.substring(0, word.lastIndexOf(" "));
            var str = "";
            $.each(e.billsundry, function (i, billsundry) {
                str += "<tr class='text-right'>";
                str += '<td colspan="4"><h5><strong>' +billsundry.BillSundry+'<strong></h5></td>';
                str += '<td colspan="3"><h5>'+parseFloat(billsundry.BsAmount).toFixed(2)+'</h5></td>';
                str += '</tr>';
            });
            str += '<tr class="text-right"><td><h4><strong>' + word +' Only</strong></h4></td><td colspan="3"><h3><strong>Grand Total</strong></h3></td>'+
            '<td colspan="2" ><h3>'+parseFloat(e.summary.GrandTotal).toFixed(2)+ '</h3></td></tr>';

            if ($('#hideheader').prop('checked') == true) {
                $('#ComHeadCheck').hide();
                $('#ComfootCheck').hide();
                //$(".invoice.print").css("margin-top", "100px");
                $("#comHeader").css("margin-top", "100px");
            }
            else {
                $('#ComHeadCheck').show();
                $('#ComfootCheck').show();
            }

            $('#posfoot').append(str);
            var originalpage = document.body.innerHTML;
            var printContent = $('#printit').html();
            $('body').html(printContent);
            var titlename = "_invoice - " + e.summary.CreatedBy + " - " + e.summary.VoucherNo;
            $('title').html(titlename);
            window.print();
        }

        function bindPOSItem(e) {
            var total = parseFloat(0);
            var TQunty = parseFloat(0);
            var Tprice= parseFloat(0);
            var count = 1;
            var Quantity = parseFloat(0);
            var str = "";
            var PartNoSts = 1;
            var PartNo=""
            $('#PartNo').hide();

            $.each(e.item, function (i, item) {
                //var str="";
                var subtot = parseFloat(item.ItemTotalAmount.toFixed(2));
                total += subtot;
                var Quantity = parseFloat(item.ItemQuantity.toFixed(2));
                TQunty += Quantity;
                var Price = parseFloat(item.Price.toFixed(2));
                Tprice += Price ;
                var unit = (item.ItemUnit != null) ? item.ItemUnit : "";
                PartNo = (item.PartNumber != null && item.PartNumber != "") ? item.PartNumber : "";
                str += '<tr>';
                str +='<td>' + count +'</td>'
                if(item.PNoStatus == 0)
                {
                    PartNoSts = 0
                    $('#PartNo').show();
                    str += '<td>' + PartNo +'</td>'
                }

                str += '<td>' + item.ItemCode + "-" + item.ItemName + '</td>';
                str+= '<td>' + unit +'</td>';
                str += '<td class="text-right">' + parseFloat(item.ItemQuantity).toFixed (2)+ '</td>';
                str += '<td class="text-right">' + parseFloat(item.Price).toFixed(2) + '</td>';
                str += '<td class="text-right">' + parseFloat(item.ItemTotalAmount).toFixed(2) + '</td>';
                str += '</tr>';
                count++;
            });
            $("#lblTotalAmount").text(parseFloat(total).toFixed(2));
            //bind footer for totalQuantity ToatalPrice and Amount
            var Row ="";
            Row += '<tr class="border-top">';
            Row += '<td><h5><strong>' + "Total" + '</h5></strong></td>';
            if(PartNoSts == 0)
            {
                var PartNo = (PartNo != null && PartNo!= "") ? PartNo : "";
                Row += '<td><h5><strong>' + PartNo + '</h5></strong></td>';
            }
            Row += '<td>' + "" + '</td>';
            Row += '<td>' + "" + '</td>';

            Row += '<td class="text-right"><h5><strong>' + parseFloat(TQunty).toFixed(2) + '</h5></strong></td>';
            Row += '<td class="text-right"><h5><strong>' + parseFloat(Tprice).toFixed(2) + '</h5></strong></td>';
            Row += '<td class="text-right"><h5><strong>' + parseFloat(total).toFixed(2)+ '</h5></strong></td>';
            Row +='</tr>';

            $('#posfootR').append(Row);

            return str;
        }
