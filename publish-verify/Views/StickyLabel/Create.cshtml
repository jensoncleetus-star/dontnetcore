@model QuickSoft.ViewModel.StickyLabelViewModel
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Add Label</h4>
</div>

<div class="modal-body">
    @using (Html.BeginForm("Create", "StickyLabel", FormMethod.Post, new { id = "createform" }))
    {
        <script type="text/javascript">
            $('form#createform').removeData("validator");
            $('form#createform').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#createform'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        <div class="row">
            <div class="col-md-12">
                <div class="form-group">
                    @Html.LabelFor(model => model.LabelName, new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.LabelName, new { htmlAttributes = new { @class = "form-control input-sm", autofocus = "autofocus", @required = "required" } })
                </div>
                <div class="form-group">
                    @Html.LabelFor(model => model.LabelColor, new { @class = "control-label" }) *
                    @Html.DropDownList("LabelColor", new List<SelectListItem>()
                         {
                            new SelectListItem(){ Text= "Green", Value = "Green"},
                            new SelectListItem(){ Text= "Red", Value = "Red"},
                            new SelectListItem(){ Text= "Blue", Value = "Blue"},
                            new SelectListItem(){ Text= "Yellow", Value = "Yellow"},
                            new SelectListItem(){ Text= "Orange", Value = "Orange"},
                            new SelectListItem(){ Text= "Purple", Value = "Purple"}
                        }, "Select Color", new { @class = "form-control", @autofocus = "autofocus", @required = "required" })
                </div>

                <div class="form-group">
                    @Html.LabelFor(model => model.Status, new { @class = "control-label" })
                    @Html.EnumDropDownListFor(model => model.Status, new { @class = "form-control" })
                </div>

            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" value="Save" class="btn btn-info col-sm-offset-4" />
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>
@section Scripts {
    @Scripts.Render("~/js/jqueryval")
}




