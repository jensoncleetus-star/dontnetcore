@model QuickSoft.Models.sharedaccount
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Shared Account</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("Create", "SharedAccount", FormMethod.Post, new { id = "createform" }))
    {
        <script type="text/javascript">
            $('form#createform').removeData("validator");
            $('form#createform').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#createform'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
<div class="row" style="margin-top:15px;">
    <div class="col-md-12">
        <div class="form-group">
            @Html.Label("Account *", null, new { @class = "control-label temp2" }) 
            @Html.DropDownListFor(model => model.accountid, (SelectList)ViewBag.Account, "Select Account", new { @class = "form-control select2", @required = "required" })

        </div>
    </div>
    <div class="col-md-12">
        <div class="form-group">
            @Html.Label("Material Center *", null, new { @class = "control-label temp2" }) 
            @Html.DropDownListFor(model => model.mcid, (SelectList)ViewBag.MC, "Select Material Center", new { @class = "form-control select2", @required = "required" })

        </div>
    </div>
    <div class="col-md-12">
        <div class="form-group">
            @Html.Label("Percentage *", null, new { @class = "control-label temp2" }) 
            @Html.EditorFor(model => model.percentage, new { htmlAttributes = new { @class = "form-control input-sm" } })

        </div>
    </div>
</div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" value="Save" class="btn btn-info col-sm-offset-4" />
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>
@section scripts{
    @Scripts.Render("~/js/jqueryval")
}
<script>
    $("#accountid").select2({
        placeholder: 'Search Account By Code or name',
        minimumInputLength: 0,
        ajax: {
            url: "/Accounts/AccountsByType",
            dataType: 'json',
            delay: 50,
            data: function (params) {
                return {
                    q: params.term || "",
                    page: params.page || 0,
                    x: ($('#AccGroup').val() != null) ? $('#AccGroup').val() : "All",
                    stt: "All"
                };
            },
            processResults: function (data, params) {
                params.page = params.page || 0;

                return {
                    results: data,
                    pagination: {
                        //more: (params.page * 10) < 50
                        more: true
                    }
                };
            },
            cache: true
        },
    });
    $("#mcid").select2({
        placeholder: 'Search Material Center by Name or Code',
        minimumInputLength: 0,
        ajax: {
            url: "/MC/SearchMC",
            dataType: 'json',
            delay: 50,
            data: function (params) {
                return {
                    q: params.term,
                    page: params.page,
                };
            },
            processResults: function (data, params) {
                params.page = params.page || 1;

                return {
                    results: data
                };
            },
            cache: true
        },
    });
</script>