@model QuickSoft.ViewModel.DeliverynoteViewModel
@{
    ViewBag.Title = "Create";
    ViewBag.SubTitle = "Delivery Note";
    ViewBag.Active = "Transactions";
    long? chkCust = Model.Customer;
    var TimeOut = @ViewBag.TMOut;
    string IRateCheck = "inactive";

}
<style>
    .date {
        height: 34px !important;
    }

    input[name="dltcheck"] {
        visibility: hidden !important;
    }
    .wysihtml5-sandbox {
        min-height: 170px !important;
    }
</style>
@if (User.IsInRole("Dev") || User.IsInRole("ReadOnly Item Rate"))
{
    IRateCheck = "active";
}
@using (Html.BeginForm("CreateDeliverynote", "Deliverynote", FormMethod.Post, new { id = "dvform", role = "form" }))
{
    <div class="box box-info">
        <div class="box-header with-border">
            <h3 class="box-title">Create Delivery Note</h3>
            <div class="pull-right">
                @if (@ViewBag.LastEntry != 0)
                {
                    if (User.IsInRole("Dev") || User.IsInRole("Edit Deliverynote"))
                    {
                        <a class="btn bg-black no-border" href="/Deliverynote/Edit/@ViewBag.LastEntry">
                            <i class="fa fa-step-backward"></i>
                        </a>
                    }
                }
                @if (User.IsInRole("Dev") || User.IsInRole("Deliverynote List"))
                {
                    <a class="btn btn-success no-border" href="/Deliverynote">
                        <i class="fa fa-fw fa-history"></i>List
                    </a>
                }
            </div>
        </div>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger AlertDiv" })
        @Html.HiddenFor(model => model.ConTypeId)
        @Html.HiddenFor(model => model.ConType)
        <input type="hidden" id="VoucherType" value="Deliverynote" />
        <div class="box-body">
            <input type="hidden" id="ROnlyRate" value="@IRateCheck" />
            <input type="hidden" id="SelApprovedBy" />
            <div class="row">
                @if (@ViewBag.BusinessType == "Scaffold")
                {
                    <div class="form-group col-sm-2">
                        @Html.Label("Type", null, new { @class = "control-label" }) *
                        @Html.EnumDropDownListFor(model => model.SaleType, new { @class = "form-control", @onchange = "HType();", @required = "required", data_msg_required = "The Sale type field is required" })
                    </div>
                }
                <div class="col-sm-2 form-group ">
                    @Html.Label("Delivery Note No", null, new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.BillNo, new { htmlAttributes = new { @class = "form-control", @required = "required" } })
                    @Html.HiddenFor(model => model.DvNo)
                </div>
                <div class="col-sm-2 form-group ">
                    @Html.Label("LPO No", null, new { @class = "control-label" })
                    @Html.EditorFor(model => model.LPONo, new { htmlAttributes = new { @class = "form-control" } })
                </div>
                <div class="col-sm-2 form-group">
                    @Html.Label("Date", null, new { @class = "control-label" }) *
                    <div class="input-group date">
                        <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                        @Html.TextBoxFor(m => m.DvDate, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @required = "required" })
                    </div>
                </div>
                <div class="col-sm-2 form-group">
                    @Html.Label("Sale Type", null, new { @class = "control-label" }) *
                    @Html.DropDownListFor(m => m.SalesType, new SelectList(Model.SalesTypes, "Id", "Name"), new { id = "SalesType", @class = "form-control" })
                </div>
                @if (@ViewBag.EnableMCcheck == 0)
                {
                    <div class="form-group col-md-2">
                        @Html.Label("Material Center", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlMC", (SelectList)ViewBag.MC, new { @class = "form-control input-sm" })
                    </div>
                }
                <div class="col-sm-2 form-group">
                    @Html.Label("Sales Executive", null, new { @class = "control-label" })
                    @if (User.IsInRole("Dev") || User.IsInRole("Create Sales Executive"))
                    {
                        <div class="input-group input-group-sm">
                            @if (Model.DvCashier != null)
                            {
                                @Html.DropDownListFor(m => m.DvCashier, (SelectList)ViewBag.Cashier, new { id = "ddlEmployee", @class = "form-control select2" })
                            }
                            else
                            {
                                @Html.DropDownListFor(m => m.DvCashier, (SelectList)ViewBag.Cashier, "", new { id = "ddlEmployee", @class = "form-control select2" })
                            }
                            <span class="input-group-btn">
                                <button type="button" href="/SalesExecutive/AddSalesExecutive" class="modal-edit btn btn-success btn-flat"><i class="fa fa-1x fa-plus-circle"></i></button>
                            </span>
                        </div>
                    }
                    else
                    {
                        if (Model.DvCashier != null)
                        {
                            @Html.DropDownListFor(m => m.DvCashier, (SelectList)ViewBag.Cashier, new { id = "ddlEmployee", @class = "form-control select2" })
                        }
                        else
                        {
                            @Html.DropDownListFor(m => m.DvCashier, (SelectList)ViewBag.Cashier, "", new { id = "ddlEmployee", @class = "form-control select2" })
                        }
                    }
                </div>
                <div class="col-sm-2 form-group">
                    @Html.Label("Payment Type", null, new { @class = "control-label" }) *
                    @Html.EnumDropDownListFor(model => model.CustomerType, new { @class = "form-control" })
                </div>
                <div class="col-sm-2 form-group">
                    @Html.Label("Customer Name", null, new { @class = "control-label" }) *
                    @if (User.IsInRole("Dev") || User.IsInRole("Create Customer"))
                    {
                        <div class="input-group input-group-sm">
                            @if (chkCust.GetValueOrDefault() != 0)
                            {
                                @Html.DropDownListFor(m => m.Customer, (SelectList)ViewBag.Custer, new { id = "ddlCustomer", @class = "form-control select2", @required = "required", @onchange = "GetCustomerMail()" })
                            }
                            else
                            {
                                @Html.DropDownListFor(m => m.Customer, (SelectList)ViewBag.Custer, "", new { id = "ddlCustomer", @class = "form-control select2", @required = "required", @onchange = "GetCustomerMail()" })
                            }
                            <span class="input-group-btn">
                                <button type="button" href="/Customer/AddCustomer" class="modal-create btn btn-success btn-flat"><i class="fa fa-1x fa-plus-circle"></i></button>
                            </span>
                        </div>
                    }
                    else
                    {
                        if (chkCust.GetValueOrDefault() != 0)
                        {
                            @Html.DropDownListFor(m => m.Customer, (SelectList)ViewBag.Custer, new { id = "ddlCustomer", @class = "form-control select2", @required = "required", @onchange = "GetCustomerMail()" })
                        }
                        else
                        {
                            @Html.DropDownListFor(m => m.Customer, (SelectList)ViewBag.Custer, "", new { id = "ddlCustomer", @class = "form-control select2", @required = "required", @onchange = "GetCustomerMail()" })
                        }
                    }
                </div>

                <div class="col-sm-2 form-group">
                    @Html.Label("Location :", null, new { @class = "control-label" })
                    @Html.EditorFor(model => model.Location, new { htmlAttributes = new { @class = "form-control" } })
                </div>

                @if (@ViewBag.BranchCheck == 0)
                {
                    <div class="form-group col-sm-2">
                        @Html.Label("Branch", null, new { @class = "control-label" })
                        @Html.DropDownListFor(m => m.Branch, (SelectList)ViewBag.SetBranch, new { id = "ddlBranch", @class = "form-control select2" })
                    </div>
                }
                @if (@ViewBag.ProjChk == 0)
                {
                    <div class="form-group col-sm-2">
                        @Html.LabelFor(m => m.Project, new { @class = "control-label" })
                        @if (User.IsInRole("Dev") || User.IsInRole("Create Project"))
                        {
                            <div class="input-group input-group-sm">
                                @Html.DropDownListFor(m => m.Project, (SelectList)ViewBag.getProj, "", new { id = "ddlProject", @class = "form-control select2" })
                                <span class="input-group-btn">
                                    <a href="/Project/AddProject" class="modal-project btn btn-success btn-flat" title="Add Project"><i class="fa fa-1x fa-plus-circle"></i></a>
                                </span>
                            </div>
                        }
                        else
                        {
                            @Html.DropDownListFor(m => m.Project, (SelectList)ViewBag.getProj, "", new { id = "ddlProject", @class = "form-control select2" })
                        }
                    </div>
                    <div class="form-group col-sm-2">
                        @Html.LabelFor(m => m.ProTask, new { @class = "control-label" })
                        @Html.DropDownListFor(m => m.ProTask, (SelectList)ViewBag.getProTask, "", new { id = "ddlProTask", @class = "form-control select2" })
                    </div>
                }
                @if (@ViewBag.BusinessType == "Scaffold")
                {
                    <div class="form-group col-md-2">
                        @Html.LabelFor(model => model.PaymentTerms, new { @class = "control-label" })
                        @Html.TextBoxFor(model => model.PaymentTerms, new { @class = "form-control", @placeholder = "Payment Terms", @rows = 2 })
                    </div>
                    <div id="HireType">
                        <div class="form-group col-sm-2">
                            @Html.LabelFor(m => m.HireType, new { @class = "control-label" }) *
                            @Html.DropDownListFor(m => m.HireType, (SelectList)ViewBag.HiType, new { id = "ddlHType", @class = "form-control select2", @required = "required", data_msg_required = "The Hire type field is required" })
                        </div>
                        <div class="form-group col-md-2">
                            @Html.Label("From Date", null, new { @class = "control-label" }) *
                            <div class="input-group date">
                                @Html.TextBoxFor(m => m.FromDate, "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off", @onchange = "DateSet();", @required = "required", data_msg_required = "The Start Date field is required" })
                                <div class="input-group-addon">
                                    <i class="fa fa-calendar"></i>
                                </div>
                            </div>
                        </div>
                        <div class="form-group col-md-2">
                            @Html.Label("To Date", null, new { @class = "control-label" }) *
                            <div class="input-group date">
                                @Html.TextBoxFor(m => m.ToDate, "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off", @required = "required", data_msg_required = "The End Date field is required" })
                                <div class="input-group-addon">
                                    <i class="fa fa-calendar"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                @if (@ViewBag.MLADNote == 0)
                {
                    <div class="form-group col-sm-2">
                        @Html.Label("Approved By", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlApprovedBy", (SelectList)ViewBag.ApproveBy, "", new { @class = "form-control select2", @name = "ddlApprovedBy[]", @multiple = "multiple" })
                    </div>
                }
                @if (Model.convertBill != null && Model.convertBill != "")
                {
                    <div class="form-group col-sm-2">
                        @Html.LabelFor(m => m.convertFrom, Model.convertFrom, new { @class = "control-label" })
                        @Html.EditorFor(model => model.convertBill, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly" } })
                    </div>
                }
                <div class="clearfix"></div>
            </div>
            <div class="row">
                @if (Model.FieldMap.Count > 0)
                {
                    for (int i = 0; i < Model.FieldMap.Count; i++)
                    {
                        <div class="form-group col-sm-2">
                            <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName</label>
                            <input class="form-control input-sm" id="@Model.FieldMap[i].Field" name="@Model.FieldMap[i].Field" type="text" value="">
                        </div>
                    }
                }
            </div>
            <div>
                <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="normalinvoice">
                        <thead>
                            <tr>
                                <th class="text-center">S/N</th>
                                <th class="text-center item-lists">Item <i class="text-danger">*</i></th>
                                <th class="text-center">Unit</th>
                                <th class="text-center">Qty <i class="text-danger">*</i></th>
                                <th class="text-center">Rate <i class="text-danger">*</i></th>
                                <th class="text-center">Sub Total</th>
                                <th class="text-center">Discount</th>
                                <th class="text-center">TAX</th>
                                <th class="text-center">Total</th>
                                <th class="text-center"></th>
                            </tr>
                        </thead>
                        <tbody id="addinvoiceItem"></tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3">
                                    Total
                                </td>
                                <td class="text-right">
                                    <label id="ItemQty"></label>
                                </td>
                                <td class="text-right"></td>
                                <td class="text-right">
                                    <label id="SubTotal"></label>
                                </td>
                                <td class="text-right">
                                    <label id="ItemDisc"></label>
                                </td>
                                <td class="text-right">
                                    <label id="total_tax_amount"></label>

                                </td>
                                <td class="text-right">
                                    <label id="total"></label>

                                </td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
                <div class="row">
                    <div class="col-md-4">

                        @if (ViewBag.CheckMail == 0)
                        {
                            <div class="form-group">
                                @Html.Label("To", null, new { @class = "control-label" })
                                @Html.TextAreaFor(m => m.custEmailId, new { @class = "form-control input-sm", tabindex = 3, rows = 2 })
                                <span class="help-block" style="color:#f39c12;">Enter multiple email separated by space</span>
                            </div>
                            <div class="form-group">
                                @Html.Label("Cc", null, new { @class = "control-label" })
                                @Html.TextAreaFor(m => m.CreatedUserEmail, new { @class = "form-control input-sm", tabindex = 3, rows = 2 })
                                <span class="help-block" style="color:#f39c12;">Enter multiple email separated by space</span>
                            </div>
                        }
                    </div>
                    <div class="col-md-8">
                        <div class="form-group col-md-4 no-paddingleft">
                        </div>
                        <div class="form-group col-md-4 no-paddingleft">
                            @*@Html.Label("Discount :", null, new { @class = "control-label" })
                                @Html.EditorFor(model => model.DvDiscount, new { htmlAttributes = new { @id = "Discount", @onchange = "discount_change();", @class = "form-control text-right", @value = "0.00" } })*@
                        </div>
                        <div class="form-group col-md-4 no-padding">
                            @Html.Label("Grand Total :", null, new { @class = "control-label" })
                            @Html.EditorFor(model => model.DvGrandTotal, new { htmlAttributes = new { @id = "GrandTotal", @class = "form-control text-right", @value = "0.00", @readonly = "readonly" } })
                            <input type="hidden" value="" class="ItemCount" name="ItemCount" id="ItemCount">
                        </div>
                        <div class="form-group">
                            @Html.LabelFor(model => model.Remarks, new { @class = "control-label" })
                            @Html.TextAreaFor(model => model.Remarks, new { @class = "form-control", @placeholder = "Remarks", @rows = 2 })
                        </div>
                        <div class="form-group">
                            @Html.Label("Terms and Conditions", null, new { @class = "control-label" })
                            @Html.TextAreaFor(m => m.TermsCondition, new { @class = "form-control input-sm textarea", @rows = 8 })
                        </div>
                        @if (@ViewBag.PrintLayout == 0)
                        {
                            <div class="form-group col-sm-5">
                                @Html.Label("Print Layout", null, new { @class = "control-label" })
                                @Html.DropDownListFor(m => m.PrintLayout, (SelectList)ViewBag.printlay, new { id = "ddlPrintlayout", @class = "form-control select2" })
                            </div>
                        }
                        <div class="form-group no-padding text-right">
                            <div class="checkbox-inline">
                                <input class="checkbox" data-val="true" id="showzeal" name="showzeal" type="checkbox" value="false">
                                <label class="control-label" for="showzeal">Show Zeal In Print</label>
                            </div>
                        </div>
                        <div class="form-group no-padding text-right">
                            <div class="checkbox-inline">
                                <input class="checkbox" data-val="true" id="hideheader" name="hideheader" type="checkbox" value="true">
                                <label class="control-label" for="hideheader">Hide Header In Print</label>
                            </div>
                        </div>
                        <div class="form-group pull-right">
                            <button type="submit" id="save" class="btn btn-success">
                                <span class="glyphicon glyphicon-floppy-disk"></span> Save
                            </button>
                            <button type="submit" id="print" class="btn btn-success">
                                <span class="glyphicon glyphicon-print"></span> Save And Print
                            </button>
                            @if (@ViewBag.CheckMail == 0)
                            {
                                <button type="submit" id="sendmail" class="btn btn-success">
                                    <span class="glyphicon glyphicon-envelope"></span> Save And Mail
                                </button>
                            }
                            <button type="button" class="btn btn-warning" onclick="@("window.location.href='/DeliveryNote/Index'");">Cancel</button>


                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

}

@{var Modelv = "modal-lg";}
@Html.Partial("../Common/_ModalCreate", @Modelv)
@Html.Partial("../Common/_ModalEdit", @Modelv)
@Html.Partial("../Common/_ModeItemCreate")
@Html.Partial("../Common/_ModelProject")
@Html.Partial("../Common/_ModalCustomer")
@*@Html.Partial("_Invoice")*@
@Html.Action("invoice", "InvoiceLayout", new { type = "Delivery Note" })


@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @*@Styles.Render("~/css/print")*@
    @Styles.Render("~/css/wysihtml5")

}
@section scripts{
    @Scripts.Render("~/js/JsBarcode")
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/sale-invoice")
    @Scripts.Render("~/js/num2words")
    @Scripts.Render("~/js/wysihtml5")

    <script type="text/javascript">
        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true,
            startDate: '01-01-2011',
            endDate: '+30d'
        });
        jQuery.validator.methods["date"] = function (value, element) { return true; }

        $(document).ready(function () {
            $("#CustomerType").prop('selectedIndex', 1);
            $("#Remarks").wysihtml5();
       
            $('#SaleType option:contains(POS)').remove();
            if ('@ViewBag.BusinessType' == "Scaffold") {
                HType();
            }


            if ('@ViewBag.Contype' != "Quote" && '@ViewBag.Contype' != "ProForma" && '@ViewBag.Contype' != "DvExtend") {
                $("#SaleType").prop('selectedIndex', 0);
                $('#HireType').hide();
            }
            else {
                var Type = $('#SaleType').val();
                if (Type == 2) {
                    $('#HireType').show();
                }
                else {
                    $('#HireType').hide();
                }
            }
            searchItem();

            ItemCategory();
            ItemBrand();
            GetBranch();
            //ItemTax();
            //ItemUnit();
            //ItemSubUnit();

            CallCustomer();
            CallMCUser();
            CallProject();
            $("#ddlMC").prop('selectedIndex', 0);
            CallEmployee();
            CallTask();
            CallApprovedBy();

            if ($('#SaleType').val() == 2) {
                var MCDefid = '@ViewBag.DefMc';
                $("#ddlMC").val(MCDefid).change();
                $('#ddlMC').attr("disabled", true);
                $('#SaleType').attr("disabled", true);
            }
            else {
                var MCDefid = '@ViewBag.LastMc';
                $("#ddlMC").val(MCDefid).change();
                $('#ddlMC').attr("disabled", false);
                $('#SaleType').attr("disabled", false);
            }

            var salefrom = '@ViewContext.RouteData.Values["type"]';
            var EntryID = '@ViewContext.RouteData.Values["id"]';


            if (salefrom == "Quote") {
                GetCustomer();
                $.ajax({
                    url: '/Quotation/GetQEItems',
                    dataType: 'json',
                    data: { QuoteEntryID: EntryID, ConvertTo: "DVNote" },
                    cache: true,
                    success: function (data) {
                        $('#addinvoiceItem').html('');
                        $.each($.parseJSON(data), function (i, item) {
                            addrow('addinvoiceItem', 'quot', item.ItemUnit, item.ItemTax, item.ItemTotalAmount, item.ItemQuantity, item.Item, item.ItemCode, item.ItemName, item.ItemUnitPrice, item.ItemSubTotal, item.ItemWithCode, item.ItemTaxAmount, item.ItemDiscount, item.ItemNote, item);
                        });
                        addrow('addinvoiceItem', 'quot', "", "0.00", "0.00", "0");
                     
                    }
                });
            }
            else if (salefrom == "ProForma") {
                $.ajax({
                    url: '/ProForma/GetPFItems2',
                    dataType: 'json',
                    data: { ProFormaID: EntryID, ConvertTo: "DVNote" },//, ConvertTo: "DVNote"
                    cache: true,
                    success: function (data) {
                        $('#addinvoiceItem').html('');
                        $.each(data, function (i, item) {
                            addrow('addinvoiceItem', 'quot', item.ItemUnit, item.ItemTax, item.ItemTotalAmount, item.ItemQuantity, item.Item, item.ItemCode, item.ItemName, item.ItemUnitPrice, item.ItemSubTotal, item.ItemWithCode, item.ItemTaxAmount, item.ItemDiscount, item.ItemNote, item);
                        });
                        addrow('addinvoiceItem', 'quot', '', '0.00', '0.00', '0');
                    }
                });
            }
            else if (salefrom == "DvExtend"){

                $.ajax({
                    url: '/Deliverynote/GetDvItems',
                    dataType: 'json',
                    data: { DvID: EntryID },
                    cache: true,
                    success: function (data) {
                        $('#addinvoiceItem').html('');
                        $.each($.parseJSON(data), function (i, item) {
                            addrow('addinvoiceItem', 'quot', item.ItemUnit, item.ItemTax, item.ItemTotalAmount, item.ItemQuantity, item.Item, item.ItemCode, item.ItemName, item.ItemUnitPrice, item.ItemSubTotal, item.ItemWithCode, item.ItemTaxAmount, item.ItemDiscount, item.ItemNote, item);
                        });
                        addrow('addinvoiceItem', 'quot', '', '0.00', '0.00', '0');
                    }
                });
            }
            else if (salefrom == "SOrder") {
                $.ajax({
                    url: '/SalesOrder/GetSOItems2',
                    dataType: 'json',
                    data: { SOEntryID: EntryID, ConvertTo: "DVNote" },
                    cache: true,
                    success: function (data) {
                        $('#addinvoiceItem').html('');
                        $.each($.parseJSON(data), function (i, item) {
                            addrow('addinvoiceItem', 'quot', item.ItemUnit, item.ItemTax, item.ItemTotalAmount, item.ItemQuantity, item.Item, item.ItemCode, item.ItemName, item.ItemUnitPrice, item.ItemSubTotal, item.ItemWithCode, item.ItemTaxAmount, item.ItemDiscount, item.ItemNote, item);
                        });
                        addrow('addinvoiceItem', 'quot', '', '0.00', '0.00', '0');
                    }
                });
            }
            else if (salefrom == "Sales") {
                $.ajax({
                    url: '/CreditSale/GetSEItems2',
                    dataType: 'json',
                    data: { SalesEntryID: EntryID, ConvertTo: "DVNote" },
                    cache: true,
                    success: function (data) {
                        $('#addinvoiceItem').html('');
                        $.each($.parseJSON(data), function (i, item) {
                            addrow('addinvoiceItem', 'quot', item.ItemUnit, item.ItemTax, item.ItemTotalAmount, item.ItemQuantity, item.Item, item.ItemCode, item.ItemName, item.ItemUnitPrice, item.ItemSubTotal, item.ItemWithCode, item.ItemTaxAmount, item.ItemDiscount, item.ItemNote, item);
                        });
                        addrow('addinvoiceItem', 'quot', '', '0.00', '0.00', '0');
                    }
                });
            }
            addrow('addinvoiceItem', 'quot', "", "0.00", "0.00", "0");
            $(".itemnote").wysihtml5();
        });



        $('body').on('change', '#ddlMC', function (e) {
            var mcval = $(this).val();
            searchItem();
        });

        $('body').on('change', '#ddlCustomer', function (e) {
