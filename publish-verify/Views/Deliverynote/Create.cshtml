        $('#dvform').on('submit', function (e) {
            e.preventDefault();

            if ($("#dvform").valid()) {

                var fnval = $('input[type="submit"], button[type="submit"]', this).filter(':focus').attr('id');
                var parameters = {};

                var DvNo = $('#DvNo').val();
                var BillNo = $('#BillNo').val();


                var CustomerID = $('#ddlCustomer').val();
                var DvCashierId = $('#ddlEmployee').val();
                var DvDate = $('#DvDate').val();

                //pending
                var Items = $('#ItemCount').val();
                var ItemQuantity = $('#ItemQty').text();
                var SubTotal = $('#SubTotal').text();
                var Tax = $('#total_tax_amount').text();

                var TotalTax = $('#total_tax_amount').text();
                var Discount = $('#ItemDisc').text();
                var GrandTotal = $('#GrandTotal').val();
                var DvValidity = 350;// $('#DvValidity').val();

                // var tAndc = CKEDITOR.instances.TermsCondition.getData();
                var tAndc = $('#TermsCondition').val();
                var custMail = $('#custEmailId').val();

                var CreatedUserEmail = $('#CreatedUserEmail').val();
                var Location = $('#Location').val();
                var CustType = $('#CustomerType').val();
                var LPONo = $('#LPONo').val();
                var Remarks = $('#Remarks').val();
                var MaterialCenter = $('#ddlMC').val();

                var ConTypeId = $('#ConTypeId').val();
                var ConType = $('#ConType').val();
                var Branch = $('#ddlBranch').val();
                var SaleType = $('#SaleType').val();
                var Start = $('#FromDate').val();
                var End = $('#ToDate').val();
                var HireType = $('#ddlHType').val();
                var SalesType = $('#SalesType').val();
                var PaymentTerms = $('#PaymentTerms').val();
                var Project = $('#ddlProject').val();
                var Task = $('#ddlProTask').val();
                var ApprovedBy = $('#SelApprovedBy').val();

                var Ref1 = "";
                var Ref2 = "";
                var Ref3 = "";
                var Ref4 = "";
                var Ref5 = "";
                if ('@Model.FieldMap.Count' > 0) {
                    Ref1 = $('#Ref1').val();
                    Ref2 = $('#Ref2').val();
                    Ref3 = $('#Ref3').val();
                    Ref4 = $('#Ref4').val();
                    Ref5 = $('#Ref5').val();
                }
                var Layout = $('#ddlPrintlayout').val();
                var HTMLtbl = {
                    getData: function (table) {
                        var data = [];
                        table.find('tr').not(':first').not('.item_').each(function (rowIndex, r) {
                            var cols = [];
                         
                            $(this).find('input,textarea,select').each(function (colIndex, c) {
           
                                cols.push($(this).val());
                            });
                            data.push(cols);
                        });
                        return data;
                    }
                }
                var mc = $("#ddlMC").val();
                var dvEntry = [CustomerID, DvCashierId, DvDate, Items, ItemQuantity,
                TotalTax, Discount, GrandTotal, SubTotal, Tax, DvValidity, tAndc, custMail,
                CreatedUserEmail, DvNo, BillNo, Location, CustType, LPONo, Remarks, MaterialCenter,
                ConTypeId, ConType, Branch, SaleType, Start, End, HireType, SalesType, PaymentTerms, Project, Task, ApprovedBy,
                Ref1, Ref2, Ref3, Ref4, Ref5, Layout]

                var data = HTMLtbl.getData($('#normalinvoice'));

                parameters.array = data;
                parameters.dvdata = dvEntry;

                parameters.action = fnval;
                if (fnval == "save" || fnval == "print" || (fnval == "sendmail" && custMail != "")) {
                    $.ajax({
                        async: true,
                        cache: false,
                        dataType: "json",
                        type: "POST",
                        contentType: "application/json; charset=utf-8",
                        url: "/Deliverynote/CreateDeliverynote",
                        data: JSON.stringify(parameters),
                        beforeSend: function () {
                            $("button").prop('disabled', true); // disable button
                        },
                        success: function (e) {
                            if (e.status == true) {
                                if (fnval == "print") {
                                    PrintInvoice(e, "nobillsundry", '@ViewBag.ItemDataCheck', "DeliveryNote");
                                }
                                else {
                                    $('.ajax_response', res_success).text(e.message);
                                    $('.AlertDiv').prepend(res_success);
                                }
                                setTimeout(function () { window.location.href = '/Deliverynote/Create'; }, '@TimeOut');
                            } else {
                                $('.ajax_response', res_danger).text(e.message);
                                $('.AlertDiv').prepend(res_danger);
                                $("button").prop('disabled', false); // enable button
                            }
                        }
                    });
                }
                else {
                    $('.ajax_response', res_danger).text("Please Enter Email Address");
                    $('.AlertDiv').prepend(res_danger);
                    $('#CustomerEmail').focus();
                }
                if (fnval == "sendmail") {
                    if (custMail != "") {
                        $.ajax({
                            async: true,
                            cache: false,
                            dataType: "json",
                            type: "POST",
                            contentType: "application/json; charset=utf-8",
                            url: "/Deliverynote/CreateDeliverynote",
                            data: JSON.stringify(parameters),
                            beforeSend: function () {
                                $("button").prop('disabled', true); // disable button
                            },
                            success: function (e) {
                                if (e.status == true) {
                                    $('.ajax_response', res_success).text(e.message);
                                    $('.AlertDiv').prepend(res_success);
                                    @*window.location.href = '@Url.Action("Create", "Deliverynote")';*@
                                    setTimeout(function () { location.reload(); }, '@TimeOut');
                                } else {
                                    $('.ajax_response', res_danger).text(e.message);
                                    $('.AlertDiv').prepend(res_danger);
                                    $("button").prop('disabled', false); // enable button
                                }
                            }
                        });
                    } else {
                        $('.ajax_response', res_danger).text("Please Enter Email Address");
                        $('.AlertDiv').prepend(res_danger);
                        $('#custEmailId').focus();
                    }
                }
                else {
                }
            }
        });

