        function HType() {
            var Type = $('#SaleType').val();
            var method;
            if (Type == 2) {
                $('#HireType').show();
                method = "Hire";
            }
            else {
                $('#HireType').hide();
                method = "Sale";
            }
            STypeForMC(Type);
            saletypechange(Type, method);

            //hirerate
            var Stype = (($('#SaleType').val()) == 1) ? "Sale" : "Hire";

            $.ajax({
                url: '/Deliverynote/GetHireInvoiceNum',
                data: { hiretype: Stype },
                type: "POST",
                dataType: "JSON",
                success: function (Hresult) {
                    $('#BillNo').val(Hresult);
                }
            });

        }

        function STypeForMC(Type) {
            if (Type == 2 && '@ViewBag.DefMc' != null && '@ViewBag.DefMc' != 0) {
                var MCDefid = '@ViewBag.DefMc';
                $("#ddlMC").val(MCDefid).change();
                $('#ddlMC').attr("disabled", true);
            }
            else {
                var MCDefid = '@ViewBag.LastMc';
                $("#ddlMC").val(MCDefid).change();
                $('#ddlMC').attr("disabled", false);
            }
        }

