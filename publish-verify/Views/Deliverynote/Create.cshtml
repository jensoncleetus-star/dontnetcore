        function GetCustomer() {
            var CustomerId = $('#ddlCustomer').val();
            if (CustomerId != null) {
                $.ajax({
                    url: '/Deliverynote/GetCustomer',
                    type: "GET",
                    dataType: "JSON",
                    data: { CustID: CustomerId },
                    success: function (result) {
                        $("[id$=custEmailId]").val(result.CustomerEmail);
                    }
                });
            }
        }

