                var ReturnType = $('#ReturnType').val();

                var PReturnId = getQueryString('');
                var Remarks = $('#Remarks').val();
                var MaterialCenter = $('#ddlMC').val();
                var Branch = $('#ddlBranch').val();
                var PurchaseType = $('#PurchaseType').val();

                var ApprovedBy = $('#SelApprovedBy').val();

                var suppEMail = $('#suppEmailId').val();

                var PurType = $('#PurType').val();
                var Ref1 = "";
                var Ref2 = "";
                var Ref3 = "";
                var Ref4 = "";
                var Ref5 = "";
                if ('@Model.FieldMap.Count' > 0) {
                    Ref1 = $('#Ref1').val();
                    Ref2 = $('#Ref2').val();
                    Ref3 = $('#Ref3').val();
                    Ref4 = $('#Ref4').val();
                    Ref5 = $('#Ref5').val();
                }
                var Layout = $('#ddlPrintlayout').val();
                var HTMLtbl = {
                    getData: function (table) {
                        var data = [];
                        table.find('tr').not(':first').not('.item_').each(function (rowIndex, r) {
                            var cols = [];
                            $(this).find('input,textarea,select').each(function (colIndex, c) {
                                cols.push($(this).val());
                            });
                            data.push(cols);
                        });
                        return data;
                    }
                }
                //bill sundry
                var HTMLtblbs = {
                    getData: function (table) {
                        var bsData = [];
                        table.find('tr').not(':first').not('.bs_').each(function (rowIndex, r) {
                            var cols = {};
                            $(this).find('input,textarea,select').each(function (colIndex, c) {
                                itid = $(this).attr('data-name').split(' ')[0];
                                itval = ($(this).val() != "") ? $(this).val() : $(this).text();
                                cols[itid] = itval;

                                //cols.push({ name: itid, index: itval });
                            });
                            bsData.push(cols);
                        });
                        return bsData;
                    }
                }
                var bsData = HTMLtblbs.getData($('#billsundry'));
                // batch stock

                var HTMLtblbst = {
                    getData: function (table) {
                        var bstData = [];
                        var order = 0;
                        var lastOne = 0;
                        table.find('tr').not(':first').not('.bs_').each(function (rowIndex, r) {
                            var cols = {};
                            $(this).find('input,textarea,select').each(function (colIndex, c) {
                                itid = $(this).attr('data-name').split(' ')[0];
                                itval = ($(this).val() != "") ? $(this).val() : $(this).text();
                                if (itid == "order") {
                                    if (order == 0) {
                                        order = 1;
                                        lastOne = itval;
                                    }
                                    if (lastOne != itval) {
                                        order++;
                                        lastOne = itval;
                                    }
                                    itval = order;
                                }
                                cols[itid] = itval;
                            });
                            if (!jQuery.isEmptyObject(cols) && cols.BatchNo != "") {
                                bstData.push(cols);
                            }
                        });
                        return bstData;
                    }
                }
                var bstdata = HTMLtblbst.getData($('.batchtbl'));

                var PREntry = [SupplierID, EmployeeID, PRDate, PRItems, PRItemQuantity,
                TotalTax, Discount, GrandTotal, PRSubTotal, PRTax, PaidAmount, PRNote,
                SupplierType, fnval, PEntryId, PReturnId, ReturnType, BillNo, suppEMail, Remarks, MaterialCenter, Branch, PurchaseType, ApprovedBy,
                Ref1, Ref2, Ref3, Ref4, Ref5, PurType, Layout]

                var data = HTMLtbl.getData($('#normalinvoice'));
                var parameters = {};
                parameters.array = data;
                parameters.purchasedata = PREntry;
                parameters.bsmodel = { 'prbsundrys': bsData };
                parameters.bstmodel = bstdata;


                if (fnval == "save" || fnval == "print") {
                    submitForm(fnval, parameters);
                } else if (fnval == "sendmail") {
                    if ($('#custEmailId').val() != "") {
                        submitForm(fnval, parameters);
                    } else {
                        $('.ajax_response', res_danger).text("Customer Email Address Not Found..!!");
                        $('.AlertDiv').prepend(res_danger);
                    }
                }
            }
            }
            else {
                $('.ajax_response', res_danger).text("Invoice no Required..!!");
                $('.AlertDiv').prepend(res_danger);
                //setTimeout(function () { location.reload(); }, '@TimeOut');
            }
        });
        function submitForm(fnval, parameters) {
            $.ajax({
                async: true,
                cache: false,
                dataType: "json",
                type: "POST",
                contentType: "application/json; charset=utf-8",
                url: "/PurchaseReturn/UpdatePurchaseReturn",
                data: JSON.stringify(parameters),
                beforeSend: function () {
                    $("button").prop('disabled', true); // disable button
                },
                success: function (e) {
                    if (e.status == true) {
                        var fileUpload = $("#input-24").get(0);
                        var files = fileUpload.files;

                        // Create FormData object
                        var fileData = new FormData();

                        // Looping over all files and add it to FormData object
                        for (var i = 0; i < files.length; i++) {
                            fileData.append(files[i].name, files[i]);
                        }

                        //Appending the PurchaseOrder Id
                        fileData.append('id', e.PurchaseReturnId);
                        $.ajax({
                            url: '/PurchaseReturn/UploadFiles',
                            type: "POST",
                            contentType: false, // Not to set any content header
                            processData: false, // Not to process data
                            data: fileData,
                            success: function (result) {
                                if (fnval == "print") {
                                    @Html.Raw(posfun)
                                }
                                else {
                                    $('.ajax_response', res_success).text(e.message);
                                    $('.AlertDiv').prepend(res_success);
                                }
                                 if ('@ViewBag.BusinessType' != 'DeliveryManagement' || '@ViewBag.POS' != 'active' || fnval != "print") {
                                setTimeout(function () { location.reload(); }, '@TimeOut');
                                }
                                //setTimeout(function () { window.location.href = '/PurchaseOrder/Index'; }, '@TimeOut');
                            }
                        });

                    } else {
                        $('.ajax_response', res_danger).text(e.message);
                        $('.AlertDiv').prepend(res_danger);
                        $("button").prop('disabled', false); // enable button
                    }
                }
            });
        }
