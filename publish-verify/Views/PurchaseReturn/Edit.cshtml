                $.ajax({
                    url: '/PurchaseEntry/GetPurchaseEntryById',
                    type: "GET",
                    dataType: "JSON",
                    data: { prentryId: pentry },
                    success: function (result) {
                        var newOption = $('<option></option>');
                        newOption.val(result.Supplier).attr("selected", "selected");
                        newOption.html(result.SupplierName);
                        $('#ddlSupplier').append(newOption);
                        $('#ddlSupplier').val(result.Supplier).trigger("change");

