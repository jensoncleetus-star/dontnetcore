@section style{
    @Styles.Render("~/css/bootstrap-fileinput")
    @Styles.Render("~/css/bootstrap-fileinput-rtl")
    @Styles.Render("~/css/bootstrap-datepicker")
    @if (!(ViewBag.POS == 0 && ViewBag.BusinessType == "DeliveryManagement"))
    {
        @Styles.Render("~/css/print")
    }

}
@section scripts{
    @Scripts.Render("~/js/JsBarcode")
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/sale-invoice")
    @Scripts.Render("~/js/num2words")
    @Scripts.Render("~/js/bootstrap-fileinput")
<script type="text/javascript">
              $("#input-24").fileinput({
            initialPreview: [@Html.Raw(strImage)],
            maxFilePreviewSize: 10240,
            showUploadedThumbs: true,
            overwriteInitial: false,
            showUpload: false,
            enableResumableUpload: true,
            autoReplace: true,
            required: false,
            initialPreviewAsData: true,
            initialPreviewFileType: 'pdf',
            allowedFileExtensions: ["dwg ", "xlsx", "gif", "jpg", "png", "jfif", "jpeg", "doc", "docx", "pdf", "dwg", "pptx", "vsdx",
              'M4A', 'FLAC', 'MP3', 'MP4', 'WAV', 'WMA', 'AAC', 'ogg', 'opus', 'mpg', 'mpeg'],
            fileActionSettings: {
                showRemove: true,
                showUpload: false,
                showZoom: true,
            },
            initialPreviewConfig: [
               @partialconfig
            ],

         deleteUrl: "/PurchaseReturn/ImageDelete",
        }).on('filesorted', function (e, params) {
            console.log('File sorted params', params);
        }).on('fileuploaded', function (e, params) {
            console.log('File uploaded params', params);
        }).on('filebeforedelete', function () {
            var aborted = !window.confirm('Are you sure you want to delete this file?');
            if (aborted) {
                //window.alert('File deletion was aborted!');
            };
            return aborted;
        }).on('filedeleted', function () {
            setTimeout(function () {
                //window.alert('File deletion was successful!');
            }, 900);
       });


        var getQueryString = function (field, url) {
            var href = url ? url : window.location.href;
            var id = href.substring(href.lastIndexOf('/') + 1);
            return id ? id : null;
        }
        var minDate = $("#Start").val();
        var maxDate = $("#End").val();
        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true,
            startDate: new Date(minDate),
            endDate: new Date(maxDate)
        });

        jQuery.validator.methods["date"] = function (value, element) { return true; }

        $(document).ready(function () {
            $('#cashsale').hide();
            addrow('addinvoiceItem', 'sales', "", "0.00", "0.00", "0");
            searchItem();

            ItemCategory();
            ItemBrand();
            GetBranch();
            //ItemTax();
            //ItemUnit();
            //ItemSubUnit();
            CallSupplier();
            CallEmployee();
            CallMCUser();
            CallApprovedBy();
            $("#SelApprovedBy").val($("#ddlApprovedBy").val());
            //bind to purchase entry
            var ptype = $("#PurType").val();
            $("#ddlPurchaseEntry").select2({
                placeholder: 'Search Sales Entry ',
                minimumInputLength: 1,
                ajax: {
                    url: "/PurchaseEntry/SearchPurchaseEntry",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term,
                            page: params.page,
                            ptype: 0
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;

                        return {
                            results: data
                        };
                    },
                    cache: true
                },
            });
            var preturnid = getQueryString('');

            if (preturnid != null) {
                $.ajax({
                    url: '/PurchaseReturn/GetPurchaseTypes',
                    type: "GET",
                    dataType: "JSON",
                    data: { PrId: preturnid },
                    success: function (result) {
                        //$('#SupplierType').val(result.SupplierType);
                        //if (result.SupplierType == 0) {
                        //    //$('#amountpaid').show();
                        //    //$('#amountdue').show();
                        //    $('#ddlSupplier').prop('required', true);
                        //} else {
                        //    //$('#amountpaid').hide();
                        //    //$('#amountdue').hide();
                        //    $('#ddlSupplier').prop('required', false);
                        //}
                        // $('#ReturnType').val(result.ReturnType);
                        if (result.ReturnType == 1) {
                            $('#prbillno').hide();
                        } else {
                            $('#prbillno').show();
                        }
                    }
                });
            }



            if (preturnid != null) {
                $.ajax({
                    url: '/PurchaseReturn/GetPRItems',
                    dataType: 'json',
                    data: { PurchaseReturnID: preturnid },
                    cache: true,
                    success: function (data) {
                        $('#addinvoiceItem').html('');
                        $.each($.parseJSON(data), function (i, item) {
                            addrow('addinvoiceItem', 'preturn', item.ItemUnit, item.ItemTax, item.ItemTotalAmount, item.ItemQuantity, item.Item, item.ItemCode, item.ItemName, item.ItemUnitPrice, item.ItemSubTotal, item.ItemWithCode, item.ItemTaxAmount, item.ItemDiscount, item.ItemNote, item);
                        });

                        addrow('addinvoiceItem', 'preturn', '', '0.00', '0.00', '0');
                    }
                });

                $.ajax({
                    url: '/PurchaseReturn/GetPRBillSundry',
                    dataType: 'json',
                    data: { PurchaseReturnID: preturnid },
                    cache: true,
                    success: function (data) {
                        $.each(data, function (i, bs) {
                            addbillsundry('addbillsundry', 'preturn', bs.BsValue, bs.AmountType, bs.BsAmount, bs.BsType, bs.BSName, bs.BillSundry);
                        });
                        addbillsundry('addbillsundry', 'preturn', '0.00', '', '0.00', '');
                        grandtotalcalculation();
                    }
                });

            }

            chkEditEditable("@ViewBag.ChkApp");

            var Type = $("#PurType").val();
            PurchaseHireEntry(Type);
        });


        $('body').on('change', '#PurchaseType', function (e) {
            var type = $(this).val();
            ptypechange(type);
        });

        $('body').on('change', '#ddlMC', function (e) {
            var mcval = $(this).val();
            searchItem();
        });
        /* function for Create popup */

        $('span').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        });
        $('#modal-create').on('submit', '#createform', function (e) {
            e.preventDefault();
            var url = $('#createform')[0].action;
            var data = $('#createform').serialize();
            createajax(url, data, '#modal-create');
        });
        $('span').on('click', '.modal-edit', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-edit');
        });
        $('#modal-edit').on('submit', '#editform', function (e) {
            e.preventDefault();
            var url = $('#editform')[0].action;
            var data = $('#editform').serialize();
            createajax(url, data, '#modal-edit');
        });

        //function suppliertype() {
        //    var custtype = $('#SupplierType').val();
        //    if (custtype != 1) {
        //        //$('#amountpaid').show();
        //        //$('#amountdue').show();

        //    }
