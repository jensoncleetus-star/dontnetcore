@model QuickSoft.Models.PurchaseReturn
@{
    ViewBag.Title = "List";
    ViewBag.SubTitle = "Purchase Return";
    ViewBag.Active = "Transactions";
    string actData = "";
    string delchk = "";
    bool userRole = false;
    string deleteBTn = "";
    if (User.IsInRole("Dev") || User.IsInRole("Delete Purchase Return"))
    {
        userRole = true;
        deleteBTn = "{text: 'Delete', className: 'btn-danger', action: function(e, dt, node, config) {" +
             "if ($('.checkbox:checked').length > 0) {if (confirm('Are you sure you want to delete this?')) {$('#delallform').submit(); e.preventDefault();} " +
              "} else {alert('Please Select Rows..!!');e.preventDefault();}}},";
    }
}
<style type="text/css">

    .dropdown-check-list {
        display: inline-block;
    }

        .dropdown-check-list .anchor {
            position: relative;
            cursor: pointer;
            display: inline-block;
            padding: 5px 50px 5px 10px;
            border: 1px solid #ccc;
            width: 150px;
            background: #fff;
            text-align: center;
        }

            .dropdown-check-list .anchor:after {
                position: absolute;
                content: "";
                border-left: 2px solid black;
                border-top: 2px solid black;
                padding: 5px;
                right: 10px;
                top: 20%;
                -moz-transform: rotate(-135deg);
                -ms-transform: rotate(-135deg);
                -o-transform: rotate(-135deg);
                -webkit-transform: rotate(-135deg);
                transform: rotate(-135deg);
            }

            .dropdown-check-list .anchor:active:after {
                right: 8px;
                top: 21%;
            }

        .dropdown-check-list ul.items {
            padding: 0px;
            display: none;
            margin: 0;
            border: 1px solid #ccc;
            border-top: none;
            position: absolute;
            z-index: 9999;
        }

            .dropdown-check-list ul.items li {
                list-style: none;
                background: #fff;
                padding: 5px;
            }

    .add-btn-item {
        border-radius: 23px;
        padding: 6px 20px;
    }

    .dropdown-check-list.visible .anchor {
        color: #0094ff;
    }

    .dropdown-check-list.visible .items {
        display: block;
    }
</style>

<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">List Purchase Return</h3>
        <div class="pull-right">
            @if (User.IsInRole("Dev") || User.IsInRole("Purchase Return Entry"))
            {
                <i class="ace-icon fa fa-hand-o-right icon-animated-hand-pointer blue"></i>
                <a class="btn btn-info no-border" href="/PurchaseReturn/Create">
                    <i class="glyphicon glyphicon-plus"></i> Create
                </a>
            }
        </div>
        <div class="row">
            <div class="col-md-2">
                <div id="list1" class="dropdown-check-list" tabindex="100">
                    <span class="anchor" style="z-index:0;">Select Fields</span>
                    <ul class="items">
                        <li><input type="checkbox" id="livoucherno" />Voucher No.</li>
                        <li><input type="checkbox" id="lifromdate" />From Date</li>
                        <li><input type="checkbox" id="litodate" />To Date</li>
                        <li><input type="checkbox" id="lipaymenttype" />Payment Type</li>
                        <li><input type="checkbox" id="lisupplier" />Supplier</li>
                        <li><input type="checkbox" id="lisalesexctve" />Sales Executive</li>
                        <li><input type="checkbox" id="licreatedby" />Created By</li>
                        <li><input type="checkbox" id="libalance" />Balance</li>
                        <li><input type="checkbox" id="limatrlcntre" />Material Center</li>
                        <li><input type="checkbox" id="liapprvlstatus" />Approval Status</li>
                    </ul>
                </div>
            </div>
            <div class="col-md-12">
                <div class="box-body search-box" id="advsearchlist">
                    <div class="search-body col-md-12" style="background:none;">
                        <form id="search-form">
                            <div class="row">
                                <input type="hidden" id="remId" />
                                <div class="form-group col-md-2" id="searchvoucherno">
                                    @Html.Label("Voucher No", null, new { @class = "control-label" })
                                    @Html.TextBox("BillNo", "", new { @class = "form-control input-sm" })
                                </div>

                                <div class="form-group col-md-2" id="searchfromdate">
                                    @Html.Label("From Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("FromDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group col-md-2" id="searchtodate">
                                    @Html.Label("To Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("ToDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group col-md-2" id="searchpaymenttype">
                                    @Html.Label("Payment Type", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlType", new SelectList(new List<SelectListItem>
                                    {
                                        new SelectListItem() {Text = "All", Value=""},
                                        new SelectListItem() {Text = "Credit", Value="0"},
                                        new SelectListItem() {Text = "Cash", Value="1"}
                                    }, "Value", "Text"), new { @class = "form-control input-sm", @name = "ddlType" })
                                </div>
                                <div class="form-group col-md-2" id="searchsupplier">
                                    @Html.Label("Supplier", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlSupplier", (SelectList)ViewBag.Supplier, new { @class = "form-control input-sm select2" })
                                </div>
                                <div class="form-group col-md-2" id="searchemployee">
                                    @Html.Label("Sales Executive", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlEmployee", (SelectList)ViewBag.SalesExecutive, new { @class = "form-control input-sm select2" })
                                </div>
                                <div class="form-group col-md-2" id="searchcreatdby">
                                    @Html.Label("Created By", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlCreatedBy", (SelectList)ViewBag.CreatedBy, "All", new { @class = "form-control input-sm select2" })
                                </div>
                                <div class="form-group col-md-2" id="searchbalance">
                                    @Html.Label("Balance", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlBalance", (SelectList)ViewBag.Balance, new { @class = "form-control input-sm select2" })
                                </div>
                                @if (@ViewBag.EnableMCcheck == 0)
                                {
                                    <div class="form-group col-md-2" id="searchmatcntr">
                                        @Html.Label("Material Center", null, new { @class = "control-label" })
                                        @Html.DropDownList("ddlMC", (SelectList)ViewBag.MC, "All", new { @class = "form-control input-sm" })
                                    </div>
                                }
                                @if (ViewBag.MLAPReturn == 0)
                                {
                                    <div class="form-group col-md-2" id="searchapprovalstatus">
                                        @Html.Label("Approval Status", null, new { @class = "control-label" })
                                        @Html.DropDownList("ApprovalStatus", (SelectList)ViewBag.AppStat, "All", new { id = "ApprovalStatus", @class = "form-control" })
                                    </div>
                                }
                                @if (@ViewBag.BusinessType == "Scaffold")
                                {
                                    <div class="form-group col-md-2" id="searchtype">
                                        @Html.Label("Type", null, new { @class = "control-label" })
                                        @Html.DropDownList("PurType", (SelectList)ViewBag.Type, new { @class = "form-control select2" })
                                    </div>
                                }
                                <div class="form-group col-md-2" id="search">
                                    <input type="submit" class="btn btn-submit" value="Submit" />
                                </div>
                                <div class="form-group col-md-2" id="close">
                                    <input type="button" class="btn btn-close" value="Close" />
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @using (Html.BeginForm("DeleteAllPReturn", "PurchaseReturn", FormMethod.Post, new { id = "delallform", role = "form" }))
    {
        <div class="box-body">
            <table class="table table-bordered table-hover" id="PRTable">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="2">S/N</td>
                        <td data-priority="1">Voucher No</td>
                        <td data-priority="2">Date</td>
                        <td data-priority="3">Supplier</td>
                        <td data-priority="3">Purchase Type</td>
                        <td data-priority="2" class="headeralign">Total Amount</td>
                        <td data-priority="2" class="headeralign">Return Amount</td>
                        <td data-priority="2" class="headeralign">Balance Amount</td>
                        <td data-priority="5">Material Center</td>
                        <td data-priority="4">Executive</td>
                        <td data-priority="4">Created By</td>
                        <td data-priority="3">Approval Status</td>
                        <td data-priority="1">Action</td>
                        <td data-priority="2"><input type="checkbox" id="select_all" /></td>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

        <input type="hidden" value="@ViewBag.StartDate" class="Start" name="Start" id="Start">
        <input type="hidden" value="@ViewBag.EndDate" class="End" name="End" id="End">
        <input type="hidden" id="SuperUserEdit" value="@ViewBag.SuperUserEditvalue" />
    }

    <div id="modal-container2" class="modal fade" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-aqua">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                    <h4>Status Updation History</h4>
                </div>
                <div class="modal-body">
                    <table class="table table-bordered table-hover" id="UserTableInfo">
                        <thead>
                            <tr class="bg-aqua">
                                <td>Status</td>
                                <td>Updated By</td>
                                <td>Requested By</td>
                                <td>Date</td>
                                <td>Remarks</td>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@{var Model = "modal-lg";}
@Html.Partial("../Common/_ModalCreate", @Model)
@Html.Partial("../Reminder/Index")
@Html.Partial("../Common/_ModalEdit")
@Html.Partial("../Common/_ModalChange")
@Html.Partial("../Common/_ModalDelete")

@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/bootstrap-timepicker")
}

@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/bootstrap-timepicker")
<script type="text/javascript">

       var minDate = $("#Start").val();
       var maxDate = $("#End").val();

        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true,
            startDate: new Date(minDate),
            endDate: new Date(maxDate)
        });

        jQuery.validator.methods["date"] = function (value, element) { return true; }
        $(".timepicker").timepicker({
            showInputs: true,
            defaultTime: false,
            format: 'dd-mm-yyyy'
        });

        $(document).ready(function () {
            $("#ddlMC").prop('selectedIndex', 0);
            $('#ddlMC').select2();
            $('#advsearchlist').hide();
        });

        var oTable = $('#PRTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "pageLength": 50,
            responsive: true,
            "bLengthChange": false,
            "ajax": {
                "url": '/PurchaseReturn/GetPurchaseReturn',
                "data": function (data) {
                    data.BillNo = $('#BillNo').val();
                    data.FromDate = $('#FromDate').val();
                    data.ToDate = $('#ToDate').val();
                    data.supplier = $('#ddlSupplier').val();
                    data.salesperson = $('#ddlEmployee').val();
                    data.type = $('#ddlType').val();
                    data.user = $('#ddlCreatedBy').val();
                    data.Balance = $('#ddlBalance').val();
                    data.MC = $('#ddlMC').val();
                    data.appstat = $('#ApprovalStatus').val();
                    data.PurchaseType = $('#PurType').val();
                },
                "type": "POST",
                "datatype": "json"
            },
            "order": [[0, "desc"]],
            "columnDefs": [{
                "targets": [11,12,13],
                "orderable": false
            }],
            "columns": [
                     {
                         "data": "PurchaseReturnId", "name": "PurchaseReturnId",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                { "data": "BillNo", "name": "BillNo" },
                { "data": "PRDate", "name": "PRDate", "render": function (data) { return convertToDate(data); } },
                { "data": "SupplierName", "name": "SupplierName" },
                {
                  "data": "PurType", "name": "PurchaseType", "render": function (data) {
                      if (data == 1) {
                        return 'CrossHire';
                       }
                       else {
                        return 'Purchase';
                       }

                   }
                },
                { "data": "PRGrandTotal", "name": "PRGrandTotal", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                { "data": "PReturnAmount", "name": "PReturnAmount", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                { "data": "BalanceAmt", "name": "BalanceAmt", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                { "data": "MC", "name": "MaterialCenter" },
                { "data": "EmpName", "name": "EmpName" },
                { "data": "User", "name": "User" },
                 {
                     "name": "ApprovalStatus", "data": function (data, type, dataToSet) {
                         var status = "";
                         var cls = "";
                         if (data.app.length > 0 || (data.Approval == true && '@ViewBag.MLAPReturn' == 'active')) {
                             if (data.ApprovalStatus == "0") {
                                 status = '<span class="badge bg-green">Approved</span>';
                             }
                             else if (data.ApprovalStatus == "1") {
                                 status = '<span class="badge bg-red">Rejected</span>';
                             }
                             else if (data.ApprovalStatus == "2") {
                                 status = '<span class="badge bg-orange">Pending</span>';
                             }
                             return '<a  class="Updation" onclick="details(' + data.PurchaseReturnId + ')"  title="View Status">' + status + ' </a>';
                         } else { return null; }
                     }
                 },
                {
                    "name": "PurchaseReturnId", "data": function (data) {

                        var rest = "";
                          @{
                        if (User.IsInRole("Dev") || User.IsInRole("View Purchase Return")) {
                           actData += "<a class=\"details\" href = \"/PurchaseReturn/Details/' + data.PurchaseReturnId + '\" title=\"Edit Purchase Return Details\"><i class=\"fa fa-lg fa-search-plus\" ></i></a> ";

                        }
                        }



                        rest += '@Html.Raw(actData)';
           if (data.validornot == "valid") {
                            @{
                                if (User.IsInRole("Dev") || User.IsInRole("Edit Purchase Return"))
                                {
                                    actData = "";
                                    actData += "<a href = \"/PurchaseReturn/Edit/' + data.PurchaseReturnId + '\" title=\"Edit Purchase Return\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";

                                }


}
               rest += '@Html.Raw(actData)';
                            }
                                else {
                                @{
                                    if (User.IsInRole("Dev") || User.IsInRole("Edit Purchase Return"))
                                    {
                                        actData = "";
                                        actData = "<a href=\"#\" onclick=\"AlertFunction(' +data.PurchaseReturnId +','+data.userEditDays + ',sa)\" title =\"Edit Purchase Return\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";


                                    }

                                          }
               rest += '@Html.Raw(actData)';

                        }
                        @{
                            actData = "";
                            if (User.IsInRole("Dev") || User.IsInRole("Download Purchase Return"))
                            {
                                actData += "<a class=\"modal-link-download\" href=\"/PurchaseReturn/Download/'+ data.PurchaseReturnId +'\" title=\"Download Purchase Return\"><i class=\"fa-lg fa fa-download\" ></i></a> ";
                            }
                            if (User.IsInRole("Dev") || User.IsInRole("Delete Purchase Return"))
                            {
                                actData += "<a class=\"modal-delete\" href =\"/PurchaseReturn/Delete/'+ data.PurchaseReturnId +'\" title=\"Delete Purchase Return\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";
                            }
                        }
                        rest += '@Html.Raw(actData)';

                        if (data.Approval == true && '@ViewBag.MLAPReturn' == 'active') {
                            @{
                             actData = "";

                             actData = "<a class=\"modal-edit\"  href=\"/PurchaseReturn/EditStatus/'+ data.PurchaseReturnId +'\" title=\"Edit Status\"><i class=\"fa fa-lg fa-refresh\" ></i></a> ";

                         }
                            rest += '@Html.Raw(actData)';
                        }
                        if ("@ViewBag.Remind" == "active") {
                            @{
                                      actData = "";
                                      actData += "<a class=\"UpdationRe\" onclick=\"detailsRemind(' + data.PurchaseReturnId + ')\" title=\"View Reminder\"><i class=\"fa-lg fa fa-bell\" ></i></a> ";
                                      actData += "<a class=\"modal-create\" href=\"/Reminder/AddReminder/'+ data.PurchaseReturnId +'/PReturn\" title=\"Add Reminder\"><i class=\"fa-lg fa fa-sticky-note\" ></i></a> ";
                                  }
                            rest += '@Html.Raw(actData)';
                        }

                        return rest;

                    }
                },
                {
                    "name": "PurchaseReturnId", "data": function (data) {
                        var rest = "";
                        @{
                            if (User.IsInRole("Dev") || User.IsInRole("Delete Purchase Return"))
                            {
                                delchk = "<input class=\"checkbox\" type=\"checkbox\" name=\"bill[]\" value='+ data.PurchaseReturnId +'></input>";
                            }
                        }
                        return rest = '@Html.Raw(delchk)';
                    }
                },
            ],
            buttons: [
                'colvis',
                {
                    extend: 'print',//
                    title: "",
                    footer: true,
                    filename: function () {
                        return 'Purchase Return';
                    },
                    columnDefs: [
                        { width: 400, targets: 2 }
                    ],
                    exportOptions: {
                        columns: ':visible'
                    },
                    message: function () {
                        var head = '<table class="tblcompact table table-bordered"><thead>' +
                        ' <tr><th class="text-center"><h3 style="margin-top: 0px;"><h4>Purchase Return</h4></th></tr>';
                        return head;
                    },
                    customize: function (win) {
                        // $(win.document.body)
                        //.css('font-size', '10pt')
                        //.css('padding', '1px');
                        $(win.document.body).find('table.tblcompact tbody td').css('padding', '0px');
                        $(win.document.body).find('.dataTable,.dataTable th,.dataTable tr,table.tblcompact tbody td .dataTable td')
                            .css('font-size', '10pt')
                            .css('padding', '5px')
                            .addClass('compact');
                        $(win.document.body).find('.dataTable tr th:nth-child(3)')
                            .css('min-width', '80px');
                        //$(win.document.body).find('.tblcompact tbody td:nth- child(2)')
                        //    .css('padding', '0px');
                        $(win.document.body).append('</td></tr></tbody>')
                    }
                }, 'copy', 'csv', //'excel',
                {
                    extend: 'pdf',//
                    title: "",
                    footer: true,
                    filename: function () {
                        return 'Purchase Return';
                    },
                    message: function () {
                        var head = 'Purchase Return';
                        return head;
                    },
                    pageSize: 'A4',
                    exportOptions: {
                        columns: ':visible'
                    },
                    customize: function (doc) {
                        doc.pageMargins = [10, 10, 10, 10];
                        doc.defaultStyle.fontSize = 10;
                        doc.styles.tableHeader.fontSize = 10;
                        doc.styles.title.fontSize = 12;
                        // Header font and bg color
                        doc.styles.tableHeader.fillColor = '#d3d3d3';
                        doc.styles.tableHeader.color = 'black';
                        // Remove spaces around page title
                        doc.content[0].text = doc.content[0].text.trim();

                        doc.styles['td:nth-child(2)'] = {
                            width: '100%',
                            'max-width': '100%'
                        }

                        var objLayout = {};
                        // Horizontal line thickness
                        objLayout['hLineWidth'] = function (i) { return .5; };
                        // Vertikal line thickness
                        objLayout['vLineWidth'] = function (i) { return .5; };
                        //// Horizontal line color
                        //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                        //// Vertical line color
                        //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                        // Left padding of the cell
                        objLayout['paddingLeft'] = function (i) { return 4; };
                        // Right padding of the cell
                        objLayout['paddingRight'] = function (i) { return 4; };
                        // Inject the object in the document
                        doc.content[1].layout = objLayout;
                        // Footer font and bg color
                        doc.styles.tableFooter.fillColor = '#d3d3d3';
                        doc.styles.tableFooter.color = 'black';
                    }
                },
               @Html.Raw(deleteBTn)
            ],
            sDom: "lBfr<'datatable-scroll't>ip",
            "drawCallback": function (settings) {
                //var table = $('#PRTable').DataTable();
                //if (!table.data().any()) {
                //    $("#sub").hide();
                //} else {
                //    $("#sub").show();
                //}
            }
        });

        var bsns = '@ViewBag.BusinessType';
        if (bsns == "Scaffold") {
            var column1 = oTable.column(4);
            column1.visible(true);
        }
        else {
            var column1 = oTable.column(4);
            column1.visible(false);
        }

        var chkcol = '@userRole';
        if (chkcol == "True") {
            var column1 = oTable.column(13);
            column1.visible(true);
        }
        else {
            var column1 = oTable.column(13);
            column1.visible(false);
        }

        var statcol = '@ViewBag.MLAPReturn';
        if (statcol == "active") {
            var column1 = oTable.column(11);
            column1.visible(true);
        }
        else {
            var column1 = oTable.column(11);
            column1.visible(false);
        }

        function reload_table() {
            oTable.clear().draw();
            oTable.ajax.reload(null, false); //reload datatable ajax
            isTicked();
        }
        //select all checkboxes
        $('body').on('change', '#select_all', function () {
            $(".checkbox").prop('checked', $(this).prop("checked")); //change all ".checkbox" checked status
        });

        //".checkbox" change
        $('body').on('change', '.checkbox', function () {
            //uncheck "select all", if one of the listed checkbox item is unchecked
            if (false == $(this).prop("checked")) { //if this item is unchecked
                $("#select_all").prop('checked', false); //change "select all" checked status to false
            }
            isTicked();
        });
        isTicked();

        /* function for view detail popup */
        $('#PRTable').on('click', 'a.details', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        })

        /* function for Create popup */

        $('div').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
            //datepickerInit();
        });

        $('#modal-create').on('submit', '#createform', function (e) {
            e.preventDefault();
            var url = $('#createform')[0].action;
            var data = $('#createform').serialize();
            createajax(url, data, '#modal-create');
        });

        /* function for Edit popup */

        $('div').on('click', '.modal-edit', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-edit');
        });

        $('#modal-edit').on('submit', '#editform', function (e) {
            e.preventDefault();
            var url = $('#editform')[0].action;
            var data = $('#editform').serialize();
            createajax(url, data, '#modal-edit');
            detailsRemind($("#remId").val());
        });

        /* function for delete popup */
        $('div').on('click', '.modal-delete', function (e) {
