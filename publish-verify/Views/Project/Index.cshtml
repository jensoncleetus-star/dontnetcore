@model QuickSoft.ViewModel.ProjectViewModel
@{
    ViewBag.Title = "Project List";
    ViewBag.SubTitle = "Project";
    ViewBag.Active = "Master";
    string actData = "";
    string delchk = "";
    bool userRole = false;
    string deleteBTn = "";
    if (User.IsInRole("Dev") || User.IsInRole("Delete Project"))
    {
        userRole = true;
        deleteBTn = "{text: 'Delete', className: 'btn-danger', action: function(e, dt, node, config) {" +
               "if ($('.checkbox:checked').length > 0) {if (confirm('Are you sure you want to delete this?')) {$('#delform').submit(); e.preventDefault();} " +
                "} else {alert('Please Select Rows..!!');e.preventDefault();}}},";
    }

    var rowCount1 = 14;
    var rowCount2 = 15;

    var Ref1 = 0;
    var Ref2 = 0;
    var Ref3 = 0;
    var Ref4 = 0;
    var Ref5 = 0;
    if (Model.FieldMap != null && Model.FieldMap.Count > 0)
    {
        for (int i = 0; i < Model.FieldMap.Count; i++)
        {
            if (@Model.FieldMap[i].Field == "Ref1")
            {
                Ref1 = 1;
                rowCount1 = rowCount1 + 1;
                rowCount2 = rowCount2 + 1;
            }
            if (@Model.FieldMap[i].Field == "Ref2")
            {
                Ref2 = 1;
                rowCount1 = rowCount1 + 1;
                rowCount2 = rowCount2 + 1;
            }
            if (@Model.FieldMap[i].Field == "Ref3")
            {
                Ref3 = 1;
                rowCount1 = rowCount1 + 1;
                rowCount2 = rowCount2 + 1;
            }
            if (@Model.FieldMap[i].Field == "Ref4")
            {
                Ref4 = 1;
                rowCount1 = rowCount1 + 1;
                rowCount2 = rowCount2 + 1;
            }
            if (@Model.FieldMap[i].Field == "Ref5")
            {
                Ref5 = 1;
                rowCount1 = rowCount1 + 1;
                rowCount2 = rowCount2 + 1;
            }
        }
    }
}

<style>
    .dropdown-check-list {
        display: inline-block;
    }
        /*    .items li input[type=checkbox]{
        margin:0.5rem 1rem;
    }*/
        .dropdown-check-list .anchor {
            position: relative;
            cursor: pointer;
            display: inline-block;
            padding: 5px 50px 5px 10px;
            border: 1px solid #ccc;
            /*  min-width:210px;*/
        }

            .dropdown-check-list .anchor:after {
                position: absolute;
                content: "";
                border-left: 2px solid black;
                border-top: 2px solid black;
                padding: 5px;
                right: 10px;
                top: 20%;
                -moz-transform: rotate(-135deg);
                -ms-transform: rotate(-135deg);
                -o-transform: rotate(-135deg);
                -webkit-transform: rotate(-135deg);
                transform: rotate(-135deg);
            }

            .dropdown-check-list .anchor:active:after {
                right: 8px;
                top: 21%;
            }

        .dropdown-check-list ul.items {
            padding: 2px;
            display: none;
            margin: 0;
            border: 1px solid #ccc;
            border-top: none;
        }

            .dropdown-check-list ul.items li {
                list-style: none;
            }

        .dropdown-check-list.visible .anchor {
            color: #0094ff;
        }

        .dropdown-check-list.visible .items {
            display: block;
            /* min-width:210px;*/
        }
</style>
<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">Project</h3>
        <div class="pull-right">
            @if (User.IsInRole("Dev") || User.IsInRole("Create Project"))
            {
                <a class="btn btn-info no-border" href="/Project/Create">
                    <i class="glyphicon glyphicon-plus"></i> Create Project
                </a>
            }
        </div>
        <div class="row">
            <div class="col-md-2">
                <div id="list1" class="dropdown-check-list" tabindex="100">
                    <span class="anchor" style="z-index:0">Select Fields</span>
                    <ul class="items" style="position: absolute; z-index: 9999999; background-color: white;">
                        <li><input type="checkbox" id="liname" class="liname" value="Name" />Project Name </li>
                        <li><input type="checkbox" id="licustomer" value="customer" />Customer</li>
                        <li><input type="checkbox" id="litype" value="Type" />Project Type </li>
                        <li><input type="checkbox" id="lifromdate" value="fdate" />From Date </li>
                        <li><input type="checkbox" id="litodate" value="tdate" />To Date</li>
                        <li><input type="checkbox" id="liperson" value="person" />Contact Person</li>
                        <li><input type="checkbox" id="linumber" value="number" />Contact Number</li>
                        <li><input type="checkbox" id="lisperson" value="sperson" />Sales Person</li>
                        <li><input type="checkbox" id="lipstatus" value="pstatus" />Project Status</li>
                        <li><input type="checkbox" id="lilocation" value="location" />Location</li>


                    </ul>
                </div>
            </div>
            <div class="col-md-12">
                <div class="box-body search-box" id="advsearchlist">
                    <div class="search-body col-md-12" style="background:none;">
                        <form id="search-form">
                            <div class="row">
                                <div class="form-group col-md-2" id="searchname" hidden>
                                    @Html.Label("Project", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlProject", (SelectList)ViewBag.Prjct, new { @class = "form-control input-sm select2" })
                                </div>

                                <div class="form-group col-md-2" id="searchcustomer" hidden>
                                    @Html.Label("Customer Name", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlCustomer", (SelectList)ViewBag.Cust, new { @class = "form-control input-sm select2" })
                                </div>
                                <div class="form-group col-md-6" id="searchprojecttype" hidden>
                                    @Html.Label("Project Type", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlProType", (SelectList)ViewBag.PType, new { @class = "form-control input-sm select2" })
                                </div>
                                <div class="form-group col-md-3" id="searchfromdate" hidden>
                                    @Html.Label("From Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("FromDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group col-md-3" id="searchtodate" hidden>
                                    @Html.Label("To Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("ToDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group col-md-2" id="searchcontatctperson" hidden>
                                    @Html.Label("Contact Person", null, new { @class = "control-label" })
                                    @Html.TextBox("CPerson", "", new { @class = "form-control input-sm" })
                                </div>
                                <div class="form-group col-md-2" id="searchnumber" hidden>
                                    @Html.Label("Contact Number", null, new { @class = "control-label" })
                                    @Html.TextBox("CNumber", "", new { @class = "form-control input-sm" })

                                </div>
                                <div class="form-group col-md-2" id="searchemployee" hidden>

                                    @Html.Label("Sales Person", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlEmployee", (SelectList)ViewBag.SalesExecutive, new { @class = "form-control input-sm select2" })
                                </div>
                                <div class="form-group col-md-2" id="searchstatus" hidden>

                                    @Html.Label("Project Status", null, new { @class = "control-label" })
                                    @Html.DropDownList("ProjectStat", (SelectList)ViewBag.Stat, new { id = "ProjectStat", @class = "form-control select2" })
                                </div>
                                <div class="form-group col-md-2" id="searchlocation" hidden>
                                    @Html.Label("Location", null, new { @class = "control-label" })
                                    @Html.TextBox("Location", "", new { @class = "form-control input-sm" })
                                </div>

                                <div class="form-group col-md-2" id="search">
                                    <input type="submit" class="btn btn-submit" value="Submit" />
                                </div>
                                <div class="form-group col-md-2" id="close">
                                    <input type="button" class="btn btn-close" value="Close" />
                                </div>
                            </div>

                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @using (Html.BeginForm("DeleteAllProject", "Project", FormMethod.Post, new { id = "delform", role = "form" }))
    {
        <div class="box-body">
            <table class="table table-bordered table-hover" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="1">S/N</td>
                        <td data-priority="1">Project Code</td>
                        <td data-priority="1">Project Name</td>
                        <td data-priority="2">Project Status</td>
                        <td data-priority="2">Customer</td>
                        <td data-priority="4">Location</td>
                        <td data-priority="4">Project Type</td>
                        <td data-priority="5">Contact Person</td>
                        <td data-priority="2">Contact Number</td>
                        <td data-priority="6">Sales Person</td>

                        <td data-priority="6">Start Date</td>
                        <td data-priority="6">End Date</td>
                        <td data-priority="5">Created By</td>
                        <td data-priority="3"> Status</td>

                        @if (Model.FieldMapAll != null && Model.FieldMapAll.Count > 0)
                        {
                            for (int i = 0; i < Model.FieldMapAll.Count; i++)
                            {
                                <td data-priority="6">@Model.FieldMapAll[i].FieldName</td>
                            }
                        }
                        <td data-priority="2">Action</td>
                        <td data-priority="1"><input type="checkbox" id="select_all" /></td>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

        <input type="hidden" value="@ViewBag.StartDate" class="Start" name="Start" id="Start">
        <input type="hidden" value="@ViewBag.EndDate" class="End" name="End" id="End">
        @*if (User.IsInRole("Dev") || User.IsInRole("Delete Project"))
            {
                <div class="box-footer text-right col-md-12" id="sub">
                    <button type="submit" id="save" data-confirm="Are u sure want to delete?" class="btn btn-danger">Delete</button>
                </div>
            }*@
    }
</div>
