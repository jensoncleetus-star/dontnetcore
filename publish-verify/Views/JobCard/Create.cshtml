@model QuickSoft.ViewModel.JobCardViewModel
@{
    ViewBag.Title = "Create";
    ViewBag.SubTitle = "JobCard";
    ViewBag.Active = "Transactions";
}
<div class="box box-info">
    @using (Html.BeginForm("Create", "JobCard", FormMethod.Post, new { id = "createForm", role = "form", enctype = "multipart/form-data" }))
            {
        <div class="box-header with-border">
            <h3 class="box-title">Create JobCard</h3>
            <div class="pull-right">
                @if (@ViewBag.LastEntry != 0)
                {
                    if (User.IsInRole("Dev") || User.IsInRole("Edit JobCard"))
                    {
                        <a class="btn bg-black no-border" href="/JobCard/Edit/@ViewBag.LastEntry">
                            <i class="fa fa-step-backward"></i>
                        </a>
                    }
                }
                @if (User.IsInRole("Dev") || User.IsInRole("JobCard List"))
                {
                    <a class="btn btn-success no-border" href="/JobCard">
                        <i class="fa fa-fw fa-history"></i> List
                    </a>
                }
            </div>
        </div>
        <div class="box-body">
            @Html.AntiForgeryToken()
            @Html.ValidationSummary("", new { @class = "alert alert-danger" })
            <input type="hidden" id="SelApprovedBy" />
            <input type="hidden" id="VoucherType" value="JobCard" />
            <div class="col-md-12">
                <div class="form-group col-sm-2">
                    @Html.LabelFor(m => m.JobCardNo, new { @class = "control-label" }) *
                    @Html.TextBoxFor(m => m.JobCardNo, new { @class = "form-control input-sm", autofocus = "autofocus", @required = "required" })
                </div>
                <div class="col-sm-2 form-group">
                    @Html.LabelFor(model => model.JCDate, htmlAttributes: new { @class = "control-label" })*
                    <div class="input-group date">
                        <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                        @Html.TextBoxFor(m => m.JCDate, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @required = "required" })
                    </div>
                </div>
                <div class="col-sm-2 form-group">
                    @Html.LabelFor(m => m.Customer, new { @class = "control-label" }) *
                    @if (User.IsInRole("Dev") || User.IsInRole("Create Customer"))
                    {
                        <div class="input-group input-group-sm">
                            @Html.DropDownListFor(m => m.Customer, (SelectList)ViewBag.Customr, "", new { id = "ddlCustomer", @class = "form-control select2", @required = "required" })
                            <span class="input-group-btn">
                                <button type="button" href="/Customer/AddCustomer" class="modal-create btn btn-success btn-flat"><i class="fa fa-1x fa-plus-circle"></i></button>
                            </span>
                        </div>
                    }
                    else
                    {
                        @Html.DropDownListFor(m => m.Customer, (SelectList)ViewBag.Customr, "", new { id = "ddlCustomer", @class = "form-control select2", @required = "required" })
                    }
                </div>
                <div class="col-sm-2 form-group">
                    @Html.LabelFor(m => m.Mechanic, new { @class = "control-label" }) 
                    @if (User.IsInRole("Dev") || User.IsInRole("Create Sales Executive"))
                    {
                        <div class="input-group input-group-sm">
                            @Html.DropDownListFor(m => m.Mechanic, (SelectList)ViewBag.Emp, "", new { id = "ddlMechanic", @class = "form-control select2" })
                            <span class="input-group-btn">
                                <button type="button" href="/SalesExecutive/AddSalesExecutive" class="modal-edit btn btn-success btn-flat"><i class="fa fa-1x fa-plus-circle"></i></button>
                            </span>
                        </div>
                    }
                    else
                    {
                        @Html.DropDownListFor(m => m.Mechanic, (SelectList)ViewBag.Emp, "", new { id = "ddlMechanic", @class = "form-control select2" })

                    }
                </div>
                <div class="col-sm-2 form-group">
                    @Html.LabelFor(m => m.ReceivedBy, new { @class = "control-label" })
                    @if (User.IsInRole("Dev") || User.IsInRole("Create Sales Executive"))
                    {
                        <div class="input-group input-group-sm">
                            @Html.DropDownListFor(m => m.ReceivedBy, (SelectList)ViewBag.Emp, "", new { id = "ddlReceivedBy", @class = "form-control select2" })
                            <span class="input-group-btn">
                                <button type="button" href="/SalesExecutive/AddSalesExecutive" class="modal-edit btn btn-success btn-flat"><i class="fa fa-1x fa-plus-circle"></i></button>
                            </span>
                        </div>
                    }
                    else
                    {
                        @Html.DropDownListFor(m => m.ReceivedBy, (SelectList)ViewBag.Emp, "", new { id = "ddlReceivedBy", @class = "form-control select2" })

                    }
                </div>
                @if (@ViewBag.BranchCheck == 0)
                {
                    <div class="form-group col-sm-2">
                        @Html.Label("Branch", null, new { @class = "control-label" })
                        @Html.DropDownListFor(m => m.Branch, (SelectList)ViewBag.SetBranch, new { id = "ddlBranch", @class = "form-control select2" })
                    </div>
                }
                <div class="col-sm-2 form-group ">
                    @Html.LabelFor(m => m.PWCModel, new { @class = "control-label" })
                    @Html.EditorFor(model => model.PWCModel, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter PWC Model" } })
                </div>
                <div class="col-sm-6 form-group ">
                    @Html.LabelFor(m => m.Details, new { @class = "control-label" })
                    @Html.TextAreaFor(model => model.Details, new { @class = "form-control", @placeholder = "PWC Details", @rows = 2 })
                </div>
                @if (@ViewBag.MLAJCard == 0)
                {
                    <div class="form-group col-sm-2">
                        @Html.Label("Approved By", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlApprovedBy", (SelectList)ViewBag.ApproveBy, "", new { @class = "form-control select2", @name = "ddlApprovedBy[]", @multiple = "multiple" })
                    </div>
                }
                </div>
            <div class="row">
                @if (Model.FieldMap.Count > 0)
                {
                    for (int i = 0; i < Model.FieldMap.Count; i++)
                    {
                        <div class="form-group col-sm-2">
                            <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName</label>
                            <input class="form-control input-sm" id="@Model.FieldMap[i].Field" name="@Model.FieldMap[i].Field" type="text" value="">
                        </div>
                    }
                }
            </div>
            <div class="col-md-12">
                <div class="table-responsive bomtable">
                    <table class="table table-bordered table-hover" id="itemtable">
                        <thead>
                            <tr>
                                <th class="text-center">S/N</th>
                                <th class="text-center">Labour/Parts<i class="text-danger">*</i></th>
                                <th class="text-center">Amount</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody id="additem"></tbody>
                        <tfoot>
                            <tr>
                                <td colspan="2">
                                    Total
                                </td>
                                <td class="text-right">
                                    <label id="totalAmt"></label>
                                </td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
            <div class="form-group no-padding text-center">
                <div class="checkbox-inline">
                    <input class="checkbox" data-val="true" id="hideheader" name="hideheader" type="checkbox" value="true">
                    <label class="control-label" for="hideheader">Hide Header In Print</label>
                </div>
            </div>
            <div class="col-md-12 headeralign">
                <div class="box-footer">
                    <button type="submit" id="save" class="btn btn-info">
                        Save
                    </button>
                    <button type="submit" id="print" class="btn btn-success"> Save And Print
                    </button>
                    <button type="button" class="btn btn-default" onclick="@("window.location.href='/JobCard/Index'");">Cancel</button>
                </div>
            </div>
        </div>
    }
</div>

@{var Modelv = "modal-lg";}
@Html.Partial("../Common/_ModalCreate", @Modelv)
@Html.Partial("../Common/_ModalEdit", @Modelv)
@Html.Partial("../Common/_ModeItemCreate")
@Html.Partial("_PrintJobCard")
@Html.Partial("../Common/_ModalCustomer")

@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/print")
}
@section Scripts {
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/additem")
    @Scripts.Render("~/js/jobcard")
    @Scripts.Render("~/js/num2words")
    <script type="text/javascript">
        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true,
            startDate: '01-01-2011',
            endDate: '+30d'
        });

        $(document).ready(function () {

            ItemCategory();
            ItemBrand();
            ItemTax();
            ItemUnit();
            ItemSubUnit();
            GetBranch();
            CallApprovedBy();
            additem('additem', '', "", "0.00", "0.00", "0");

            $.ajax({
                url: '/JobCard/GetDefaultItems',
                dataType: 'json',
                data: {},
                cache: true,
                success: function (data) {
                    $('#additem').html('');
                    $.each(data, function (i, item) {
                        additem('additem', '', item.ItemUnit, item.ItemTax, item.ItemTotalAmount, item.ItemQuantity, item.Item, item.ItemCode, item.ItemName, item.ItemUnitPrice, item.ItemSubTotal, item.ItemWithCode, item.ItemTaxAmount, item.ItemDiscount, item.ItemNote, item);
                    });
                    additem('additem', '', "", "0.00", "0.00", "0");
                }
            });

            CallCustomer();

            //bind to employee
            $("#ddlMechanic").select2({
                placeholder: 'Search Employee',
                minimumInputLength: 0,
                ajax: {
                    url: "/Employee/SearchEmployee",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term || "",
                            page: params.page || 0,
                            x: "empty"
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 0;

                        return {
                            results: data,
                            pagination: {
                                //more: (params.page * 10) < 50
                                more: true
                            }
                        };
                    },
                    cache: true
                },
            });
            $("#ddlReceivedBy").select2({
                placeholder: 'Search Employee',
                minimumInputLength: 0,
                ajax: {
                    url: "/Employee/SearchEmployee",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term || "",
                            page: params.page || 0,
                            x: "empty"
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 0;

                        return {
                            results: data,
                            pagination: {
                                //more: (params.page * 10) < 50
                                more: true
                            }
                        };
                    },
                    cache: true
                },
            });

        });

         /* function for Create popup */
        $('span').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        });
        $('#modal-create').on('submit', '#createform', function (e) {
            e.preventDefault();
            var url = $('#createform')[0].action;
            var data = $('#createform').serialize();
            createajax(url, data, '#modal-create');
        });

        $('span').on('click', '.modal-edit', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-edit');
        });
        $('#modal-edit').on('submit', '#editform', function (e) {
            e.preventDefault();
            var url = $('#editform')[0].action;
            var data = $('#editform').serialize();
            createajax(url, data, '#modal-edit');
        });

        AddItemPopUp();
        CustomerPopup();

        $('body').on('change', '#ddlApprovedBy', function (e) {
            $("#SelApprovedBy").val($(this).val());
        });

        // form submit
        $('#createForm').on('submit', function (e) {
            e.preventDefault();
            var fnval = $('input[type="submit"], button[type="submit"]', this).filter(':focus').attr('id');
            if ($("#createForm").valid()) {
                var ret = "redcreate"
                JcSubmit(fnval, ret);
            }
            else {
                $('.alert').prepend('<button type="button" class="close" data-hide="alert">×</button>');
            }
        });

        //On Modal Create
        $('#modal-create-lg').on('shown.bs.modal', function (e) {
            //Item Category
            ItemCategory();
            ItemBrand();
            ItemTax();
            ItemUnit();
            ItemSubUnit();
            Itemtype();
            $('#KeepStock').click(function () {
                clickstock();
            });
        });
    </script>
}