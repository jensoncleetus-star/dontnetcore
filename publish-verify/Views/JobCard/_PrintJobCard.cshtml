<div id="printit" class="hidden">
    <!-- Main content -->
    <table class="invoice print">
        <thead>
            <!-- title row -->
            <tr class="row" id="header">
                <th class="col-xs-12">
                    <div style="max-height:270px">
                        <div class="text-center" id="comHeader">
                            @if (@ViewBag.HeadCheck != 0)
                            {
                                @Html.Partial("../Common/_CompanyHeader")
                            }
                        </div>
                        <div class="text-center">
                            <style type="text/css">
                                @@media print {
                                    body, .print {
                                        border: 0px !important;
                                    }

                                    body, .print {
                                        border: 1px !important;
                                    }

                                    .table-bordered td, .table-bordered th {
                                        border: 1px solid #898989 !important;
                                    }
                                }

                                body .print {
                                    font-size: 12px;
                                }

                                .print .table-nob tr th {
                                    width: 40%;
                                }
                            </style>
                        </div>
                        <div class="text-center">
                            <h4 style="margin-bottom: 1px;">
                                <strong>Job Card</strong>
                            </h4>
                        </div>
                        <table class="table table-noborder">
                            <tr style="border-top: 1px solid;">
                                <td width="50%" style="padding: 3px;border-right: 1px solid;">
                                    <table class="table-nob noborder" style="border: 0px;width: 100%;">
                                        <tr>
                                            <th><i><b>Customer زبون</b></i></th>
                                        </tr>
                                        <tr>
                                            <td><label id="lblParty"></label></td>
                                        </tr>
                                        <tr>
                                            <td>
                                                <label id="lbladdress"></label>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>
                                                TRN : <label id="lbltrn"></label>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                                <td>
                                    <table class="table-nob noborder" style="border: 0px;width: 100%;">
                                        <tr>
                                            <th>Job Card No:</th>
                                            <td>: <label id="lblCardNo"></label></td>
                                        </tr>
                                        <tr>
                                            <th>Date</th>
                                            <td>: <label id="lblDate"></label></td>
                                        </tr>
                                        <tr>
                                            <th>PWC Model</th>
                                            <td>: <label id="lblPWCModel"></label></td>
                                        </tr>
                                        <tr>
                                            <th>Received By<br /></th>
                                            <td>: <label id="lblEmployee"></label></td>
                                        </tr>
                                        <tr>
                                            <th>Mechanic Name</th>
                                            <td>: <label id="lblMechName"></label></td>
                                        </tr>
                                        <tr>
                                            <th>Details</th>
                                            <td>: <label id="lblDetails"></label></td>
                                        </tr>
                                        @* field mapping *@
                                        <tr id="divRef1" hidden>
                                            <th id="IblRef1"></th>
                                            <td>: <label id="IblRef1Val"></label></td>
                                        </tr>
                                        <tr id="divRef2" hidden>
                                            <th id="IblRef2"></th>
                                            <td>: <label id="IblRef2Val"></label></td>
                                        </tr>
                                        <tr id="divRef3" hidden>
                                            <th id="IblRef3"></th>
                                            <td>: <label id="IblRef3Val"></label></td>
                                        </tr>
                                        <tr id="divRef4" hidden>
                                            <th id="IblRef4"></th>
                                            <td>: <label id="IblRef4Val"></label></td>
                                        </tr>
                                        <tr id="divRef5" hidden>
                                            <th id="IblRef5"></th>
                                            <td>: <label id="IblRef5Val"></label></td>
                                        </tr>       
                                    </table>
                                </td>
                            </tr>
                        </table>
                    </div>
                </th>
                <!-- /.col -->
            </tr>
        </thead>
        <tbody>
            <!-- Table row -->
            <tr class="row">
                <td class="col-xs-12 table-responsive">
                    <div id="itemSection" style="min-height:558px">
                        <table class="table table-bordered" id="itemtable" style="font-size: 12px;">
                            <thead>
                                <tr>
                                    <th>S/N</th>
                                    <th>Labour</th>
                                    <th>Amount</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </td>
            </tr>
            <tr class="row">
                <td class="col-xs-12 table-responsive">
                    <table class="table table-bordered" id="itemtable1">
                        <tbody></tbody>
                    </table>
                </td>
            </tr>
        </tbody>
        <tfoot>
            <tr class="row">
                <td class="col-xs-12 table-responsive">
                    <table class="table table-bordered second-table"></table>
                </td>
            </tr>
            <tr class="row" id="footer">
                <td class="col-xs-12 table-responsive">
                    <table class="table table-bordered">
                        <tr>
                            <td rowspan="3" style="width:50%;">
                                Approved By And Date :<br />
                            </td>
                            <td colspan="3" rowspan="3">
                                For @ViewBag.CName
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </tfoot>
    </table>
</div>