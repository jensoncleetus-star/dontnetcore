@{
    ViewBag.Title = "View Prefix Master";
    ViewBag.SubTitle = "PrefixMaster";
    ViewBag.Active = "Settings";
    string actData = "";
}
<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">Prefix Master List</h3>
        <p class="pull-right">
            @if (User.IsInRole("Dev") || User.IsInRole("Create Prefix"))
            {
            <a href="/PrefixMaster/Create" class="btn btn-info modal-create"><i class="glyphicon glyphicon-plus"></i> Add New</a>
            }
        </p>
    </div>

    @*<div class="box-body search-box">
        <a class="btn btn-primary" id="srch">
            <i class="glyphicon glyphicon-search"></i> Advanced Search
        </a>
        <div class="search-body col-md-12" id="advsearch">
            <form id="search-form">
                <div class="row">
                    <div class="form-group col-sm-2">
                        @Html.Label("Prefix Code", null, new { @class = "control-label" })
                        @Html.TextBox("PCode", "", new { @class = "form-control input-sm" })
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12">
                        <input type="submit" class="btn btn-submit col-sm-offset-5" value="Submit" />
                        <input type="button" class="btn btn-close" value="Close" />
                    </div>
                </div>
            </form>
        </div>
    </div>*@

    <div class="box-body">
        <table class="table table-bordered table-hover" id="UserTable">
            <thead>
                <tr class="bg-gray">
                    <td data-priority="2">S/N</td>
                    <td data-priority="2">Prefix Code</td>
                    <td data-priority="2">Description</td>
                    <td data-priority="2">Last Number</td>
                    <td data-priority="3">Action</td>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>
<div id="modal-container" class="modal fade" role="dialog" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
        </div>
    </div>
</div>
@{var Model = "modal-md";}
@Html.Partial("../Common/_ModalCreate", @Model)
@Html.Partial("../Common/_ModalEdit")
@Html.Partial("../Common/_ModalDelete")
@section Scripts {
    @Scripts.Render("~/js/jqueryval")
    <script type="text/javascript">
        $(document).ready(function () {
            $('#advsearch').hide();

        var oTable = $('#UserTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "pageLength": 50,
            responsive: true,
            "ajax": {
                "url": '/PrefixMaster/GetPrefix',
                "data": function (data) {
                    data.PCode = $('#PCode').val();
                },
                "type": "POST",
                "datatype": "json"
            },
            "columns": [
                {
                    "data": "Id", "name": "Id",
                    "render": function (data, type, row, meta) {
                        return meta.row + meta.settings._iDisplayStart + 1;
                    }
                },
                { "data": "PrefixCode", "name": "PrefixCode" },
                { "data": "Description", "name": "Description" },                
                {
                    "name": "LastNo", "data": function (data)
                    {
                        var Num = ("00000" + data.LastNo).slice(-5);
                        return Num;
                    }
                },
                {
                    "name": "Id", "data": function (data) {
                        var rest = "";
                        @{
                            if (User.IsInRole("Dev") || User.IsInRole("Edit Prefix"))
                            {
                                actData += "<a class=\"modal-edit\" href=\"/PrefixMaster/Edit/'+ data.Id +'\" title=\"Edit PrefixMaster\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                            }
                            if (User.IsInRole("Dev") || User.IsInRole("Delete Prefix"))
                            {
                                actData += "<a class=\"modal-delete\" href=\"/PrefixMaster/Delete/'+ data.Id +'\" title=\"Delete PrefixMaster\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";
                            }
                        }
                        return rest = '@Html.Raw(actData)';
                    }
                },
            ]
        })

            $('#srch, .search-box .btn-close').on('click', function (e) {
                $('#advsearch').toggle();

                if ($('#srch').hasClass('btn-primary')) {
                    $('#srch').addClass('btn-danger');
                    $('#srch').removeClass('btn-primary');
                }
                else if ($('#srch').hasClass('btn-danger')) {
                    $('#srch').addClass('btn-primary');
                    $('#srch').removeClass('btn-danger');
                    //location.reload();
                    $('#PCode').val("");
                    oTable.draw();
                }
            });
            $('#search-form').on('submit', function (e) {
                e.preventDefault();
                oTable.draw();
            });

        });

        /* function for Create popup */

        $('div').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        });
        $('#modal-create').on('submit', '#createform', function (e) {
            e.preventDefault();
            var url = $('#createform')[0].action;
            var data = $('#createform').serialize();
            createajax(url, data, '#modal-create');
        });


        /* function for Edit popup */

        $('div').on('click', '.modal-edit', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-edit');
        });
        $('#modal-edit').on('submit', '#editform', function (e) {
            e.preventDefault();
            var url = $('#editform')[0].action;
            var data = $('#editform').serialize();
            createajax(url, data, '#modal-edit');
        });

        /* function for delete popup */
        $('#UserTable').on('click', '.modal-delete', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-delete');
        });
        $('#modal-delete').on('submit', '#deleteform', function (e) {
            e.preventDefault();
            var url = $('#deleteform')[0].action;
            var data = $('#deleteform').serialize();
            createajax(url, data, '#modal-delete');
        });


        $('#modal-create').on('shown.bs.modal', function (e) {
            GetCurrencyCode();
            GetBranch();
            ItemCategory();
            ItemBrand();
        });

        $('#modal-edit').on('shown.bs.modal', function (e) {            
            GetCurrencyCode();
            GetBranch();
            ItemCategory();
            ItemBrand();
        });

    </script>
}

