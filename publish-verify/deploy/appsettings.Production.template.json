{
  // Copy this file to the deploy folder as  appsettings.Production.json  and fill in the values.
  // One copy PER BRANCH (each branch = its own database + its own Windows service + its own port).
  "ConnectionStrings": {
    // REQUIRED. Point at the branch's REAL database. The app refuses to start in Production without it.
    "DefaultConnection": "Server=YOUR_SQL_SERVER;Database=YOUR_BRANCH_DB;User Id=quicksoft_app;Password=********;MultipleActiveResultSets=true;TrustServerCertificate=True;Encrypt=False"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  // OPTIONAL — serve HTTPS straight from Kestrel (skip if you terminate TLS on IIS/nginx in front).
  // Provide a .pfx and uncomment; then use  --urls https://0.0.0.0:8443  when installing the service.
  //"Kestrel": {
  //  "Certificates": {
  //    "Default": {
  //      "Path": "C:\\QuickSoft\\certs\\quicksoft.pfx",
  //      "Password": "********"
  //    }
  //  }
  //},
  "AllowedHosts": "*"
}
