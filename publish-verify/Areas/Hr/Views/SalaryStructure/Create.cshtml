@model QuickSoft.ViewModel.SalaryStructuresViewModel
@{
    ViewBag.Title = "Create";
    ViewBag.SubTitle = "Salary Structure";
    ViewBag.Active = "Payroll";
    var TimeOut = @ViewBag.TMOut;
}
@using (Html.BeginForm("CreateSalaryStructure", "SalaryStructure", FormMethod.Post, new { id = "createForm", role = "form" }))
{
    <div class="box box-info">
        <div class="box-header with-border">
            <h3 class="box-title">Create Salary Structure</h3>
            <div class="pull-right">
                @if (User.IsInRole("Dev") || User.IsInRole("SalaryStructure List"))
                {
                    <a class="btn btn-success no-border" href="/Hr/SalaryStructure">
                        <i class="fa fa-fw fa-history"></i> List
                    </a>
                }
            </div>
        </div>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })

        <div class="box-body">
            <div class="row">
                <div class="col-sm-2 form-group">
                    @Html.LabelFor(m => m.EmployeeId, new { @class = "control-label" })*
                    @Html.DropDownListFor(m => m.EmployeeId, (SelectList)ViewBag.SelVal, new { id = "ddlEmployee", @class = "form-control select2", @required = "required" })
                </div>
                <div class="col-sm-2 form-group">
                    @Html.LabelFor(m => m.EFDate, new { @class = "control-label" })*
                    <div class="input-group date">
                        <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                        @Html.TextBoxFor(m => m.EFDate, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @required = "required" })
                    </div>
                </div>
                <div class="col-sm-2 form-group">
                    @Html.Label("Start Type (Auto Fill)", null, new { @class = "control-label" })
                    @Html.DropDownList("StartType", (SelectList)ViewBag.SType, new { id = "StartType", @class = "form-control select2" })
                </div>
                @*<div class="col-sm-2 form-group select2-box" id="divParentGrade">
                    @Html.Label("Employee", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlParentGrade", (SelectList)ViewBag.SelVal, new { @class = "form-control select2" })
                </div>*@
                <div class="col-sm-2 form-group select2-box" id="divEmployeeGrade">
                    @Html.Label("Employee Grade", null, new { @class = "control-label" })
                    @Html.DropDownList("EmployeeGrade", (SelectList)ViewBag.SelVal, new { @class = "form-control select2" })
                </div>
                <div class="col-sm-2 form-group select2-box" id="divEmployee">
                    @Html.Label("Employee", null, new { @class = "control-label" })
                    @Html.DropDownList("SelEmployee", (SelectList)ViewBag.SelVal, new { @class = "form-control select2" })
                </div>

                @if (@ViewBag.BranchCheck == 0)
                {
                        <div class="row">
                            <div class="form-group col-sm-2">
                                @Html.Label("Branch", null, new { @class = "control-label" })
                                @Html.DropDownListFor(m => m.Branch, (SelectList)ViewBag.SetBranch, new { id = "ddlBranch", @class = "form-control select2" })
                            </div>
                        </div>
                    }

                </div>
            <div class="row">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="normalinvoice">
                        <thead>
                            <tr>
                                <th class="text-center">S/N</th>
                                <th class="text-center">Pay Head <i class="text-danger">*</i></th>
                                <th class="text-center">Rate</th>
                                <th class="text-center">Per </th>
                                <th class="text-center">Pay Head Type</th>
                                <th class="text-center">Calculation Type</th>
                                <th class="text-center">Computed On</th>
                                <th class="text-center"></th>
                            </tr>
                        </thead>
                        <tbody id="addempitem"></tbody>
                        <tfoot>
                        </tfoot>
                    </table>
                </div>
            </div>
            <div class="col-md-12 pull-right">
                <div class="form-group pull-right">
                    <button type="submit" id="save" class="btn btn-success">
                        <span class="glyphicon glyphicon-floppy-disk"></span> Save
                    </button>

                    <button type="button" class="btn btn-warning" onclick="@("window.location.href='/Hr/SalaryStructure/Index'");">Cancel</button>
                    <input type="hidden" value="@ViewBag.StartDate" class="Start" name="Start" id="Start">
                    <input type="hidden" value="@ViewBag.EndDate" class="End" name="End" id="End">
                </div>
            </div>
        </div>
    </div>

}

@{
    var Modelv = "modal-lg";
}
@Html.Partial("../Common/_ModalCreate", @Modelv)
@Html.Partial("../Common/_ModalEdit", @Modelv)

@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/print")
}
@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/salarystructure")
    <script type="text/javascript">
        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true,
            startDate: '01-01-2011',
            endDate: '+30d'
        });
        jQuery.validator.methods["date"] = function (value, element) { return true; }

        $(document).ready(function () {
            GetBranch();
            CallEmployeeAcc();
            addempitem('addempitem', "", "", "", "0.00", "", "");

            $("#divParentGrade").hide();
            $("#divEmployeeGrade").hide();
            $("#divEmployee").hide();

            //$("#ddlParentGrade").select2({
            //    placeholder: 'Search Parent Grade Name',
            //    minimumInputLength: 0,
            //    ajax: {
            //        url: "/SalaryStructure/SearchParentGrade",
            //        dataType: 'json',
            //        delay: 50,
            //        data: function (params) {
            //            return {
            //                q: params.term,
            //                page: params.page,
            //                x: "empty",
            //            };
            //        },
            //        processResults: function (data, params) {
            //            params.page = params.page || 1;
            //            return {
            //                results: data
            //            };
            //        },
            //        cache: true
            //    },
            //});

            $("#SelEmployee").select2({
                placeholder: 'Search by Name ',
                minimumInputLength: 0,
                ajax: {
                    url: "/Employee/SearchEmployeeWithAcc",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term || "",
                            page: params.page || 0,
                            x: "empty"
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 0;

                        return {
                            results: data,
                            pagination: {
                                //more: (params.page * 10) < 50
                                more: true
                            }
                        };
                    },
                    cache: true
                },
            });

            GetEmpGrade();

           
        });


        /* function for Create popup */

        $('table').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        });
        $('#modal-create').on('submit', '#createform', function (e) {
            e.preventDefault();
            var url = $('#createform')[0].action;
            var data = $('#createform').serialize();
            createajax(url, data, '#modal-create');
        });


        $('span').on('click', '.modal-edit', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-edit');
        });
        $('#modal-edit').on('submit', '#editform', function (e) {
            e.preventDefault();
            var url = $('#editform')[0].action;
            var data = $('#editform').serialize();
            createajax(url, data, '#modal-edit');
        });

        $('body').on('change', '#StartType', function (e) {
            var stype = $(this).val();
            if (stype == 0) {
                $("#divParentGrade").hide();
                $("#divEmployeeGrade").hide();
                $("#divEmployee").hide();
            }
            if (stype == 1) {
                $("#divParentGrade").show();
                $("#divEmployeeGrade").hide();
                $("#divEmployee").hide();
                BindWithParentGrade();
               // $('#ddlParentGrade').val(0).trigger('change');
            }
            if (stype == 2) {
                $("#divParentGrade").hide();
                $("#divEmployeeGrade").show();
                $("#divEmployee").hide();
                $("#EmployeeGrade").val(0).trigger('change');
            }
            if (stype == 3) {
                $("#divParentGrade").hide();
                $("#divEmployeeGrade").hide();
                $("#divEmployee").show();
                $("#SelEmployee").val(0).trigger('change');
            }
            $('#addempitem').html('');
            addempitem('addempitem', "", "", "", "", "", "");
        });
        $('body').on('change', '#ddlEmployee', function (e) {
            var stype = $("#StartType").val();
            if (stype == 1) {
                BindWithParentGrade();
            }
        });

        function BindWithParentGrade() {
            var empid = $("#ddlEmployee").val();
            if (empid != null && empid != 0) {
                $.ajax({
                    url: '/Hr/SalaryStructure/GetSalaryStructureByParentGrade',
                    dataType: 'json',
                    data: { empid: empid },
                    cache: true,
                    success: function (data) {
                        if (data != "") {
                            $('#addempitem').html('');
                            $.each(data, function (i, item) {
                                addempitem('addempitem', '', item.PayHead, item.PayHeadId, item.Rate, item.Per, item.HeadType, item.CalType, item.Computed, item);
                            });
                        } else {
                            $('#addempitem').html('');
                            alert("Not Found..!!");
                        }
                        addempitem('addempitem', "", "", "", "", "", "");
                    }
                });
            } else {
                $('#addempitem').html('');
                alert("Not Found..!!");
            }
            addempitem('addempitem', "", "", "", "", "", "");
        }
        $('body').on('change', '#EmployeeGrade', function (e) {
            var egrade = $(this).val();
            if (egrade != null && egrade != 0) {
                $.ajax({
                    url: '/Hr/EmployeeGrade/GetEmployeeGradeById',
                    dataType: 'json',
                    data: { SalID: egrade },
                    cache: true,
                    success: function (data) {
                        $('#addempitem').html('');
                        $.each(data, function (i, item) {
                            addempitem('addempitem', '', item.PayHead, item.PayHeadId, item.Rate, item.Per, item.HeadType, item.CalType, item.Computed, item);
                        });
                        addempitem('addempitem', "", "", "", "", "", "");
                    }
                });
            } else {
                $('#addempitem').html('');
            }
            addempitem('addempitem', "", "", "", "", "", "");
        });
        $('body').on('change', '#SelEmployee', function (e) {
            var emp = $(this).val();
            if (emp != null && emp != 0) {
                $.ajax({
                    url: '/Employee/GetEmployeeGradeById',
                    dataType: 'json',
                    data: { empId: emp },
                    cache: true,
                    success: function (data) {
                        if (data != null && data != 0) {
                            $('#addempitem').html('');
                            $.each(data, function (i, item) {
                                addempitem('addempitem', '', item.PayHead, item.PayHeadId, item.Rate, item.Per, item.HeadType, item.CalType, item.Computed, item);
                            });
                            addempitem('addempitem', "", "", "", "", "", "");
                        } else {
                            alert("Not Found..!!");
                            $('#addempitem').html('');
                            addempitem('addempitem', "", "", "", "", "", "");
                        }
                    }
                });
            } else {
                $('#addempitem').html('');
            }
            addempitem('addempitem', "", "", "", "", "", "");
        });

        $('#createForm').on('submit', function (e) {
            e.preventDefault();

            if ($("#createForm").valid()) {
                var url = $('#createForm')[0].action;
                var formData = new FormData(this);
                $.ajax({
                    async: true,
                    cache: false,
                    dataType: "json",
                    type: "POST",
                    processData: false,
                    contentType: false,
                    url: url,
                    data: formData,//JSON.stringify(parameters),
                    beforeSend: function () {
                        $("button").prop('disabled', true); // disable button
                    },
                    success: function (e) {
                        if (e.status) {
                            $('.ajax_response', res_success).text(e.message);
                            $('.AlertDiv').prepend(res_success);
                            window.location.href = '@Url.Action("Index", "SalaryStructure")';
                        }
                        else {
                            $('.ajax_response', res_danger).text(e.message);
                            $('.AlertDiv').prepend(res_danger);
                            $("button").prop('disabled', false); // enable button
                        }
                    }
                });
            }

        });
    </script>
}

