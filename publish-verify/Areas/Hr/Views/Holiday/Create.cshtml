@model QuickSoft.ViewModel.HolidayViewModel
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Add Holiday</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("Create", "Holiday", FormMethod.Post, new { id = "createform" }))
    {
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        <div class="row">
            <div class="col-md-12">
                <div class="form-group">
                    @Html.Label("Holiday Name", null, new { @class = "control-label col-sm-4" })
                    @Html.EditorFor(model => model.HolidayName, new { htmlAttributes = new { @class = "form-control input-sm", @required="true" } })
                </div>
                <div class="form-group">
                    @Html.LabelFor(m => m.CalendarTemplateID, new { @class = "control-label col-sm-4" })
                    @Html.DropDownListFor(m => m.CalendarTemplateID, (SelectList)ViewBag.CTemp, "Select", new { @class = "form-control input-sm", @required = "true" })
                </div>
                <div class="form-group ">
                    @Html.LabelFor(model => model.FromDate, htmlAttributes: new { @class = "control-label" })
                    <div class="input-group date">
                        <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                        @Html.TextBoxFor(m => m.FromDate, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @required = "required", @autocomplete = "off" })
                    </div>
                </div>
                <div class="form-group ">
                    @Html.LabelFor(model => model.ToDate, htmlAttributes: new { @class = "control-label" })
                    <div class="input-group date">
                        <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                        @Html.TextBoxFor(m => m.ToDate, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @required = "required", @autocomplete = "off" })
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <button type="submit" class="btn btn-info col-sm-offset-4">Save</button>
                    <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
        <script>
            $("#CalendarTemplateID").select2();
                $('.datepicker').datepicker({
                    startDate: '01-01-2011',
                    format: 'dd-mm-yyyy',
                    autoclose: true,
                    allowInputToggle: true
                });
                jQuery.validator.methods["date"] = function (value, element) { return true; }
        </script>
    }
</div>

