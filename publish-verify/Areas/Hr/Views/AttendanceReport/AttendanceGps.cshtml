
@{
    ViewBag.Title = "Search Attendance Sheet";
    ViewBag.SubTitle = "Attendance Sheet Report";
    ViewBag.Active = "Reports";
}
<div class="box box-default">
   
        <div>
            <div class="box-header with-border">
                <h3 class="box-title">Attendance Sheet Report</h3>
            </div>
            @using (Html.BeginForm("mapviewshowemp", "../ProTask", FormMethod.Get, new { id = "mapview" }))
            {

        <div class="box-body">
            <input type="hidden" id="cname" value="@ViewBag.CName" />
            <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
            <div class="form-group col-md-2 select2-box">
                @Html.Label("Departments", null, new { @class = "control-label" })
                @Html.DropDownList("ddlDepartment", (SelectList)ViewBag.AllOption, new { @class = "form -control input-sm select2" })
            </div>
            <div class="form-group col-md-2 select2-box">
                @Html.Label("Employee", null, new { @class = "control-label" })
                @Html.DropDownList("ddlEmployee", (SelectList)ViewBag.AllOption, new { @class = "form -control input-sm select2" })
            </div>
            <div class="form-group col-md-2">
                @Html.Label("From", null, new { @class = "control-label" })
                <div class="input-group date">
                    @Html.TextBox("From", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                    <div class="input-group-addon">
                        <i class="fa fa-calendar"></i>
                    </div>
                </div>
            </div>
            <div class="form-group col-md-2">
                @Html.Label("To", null, new { @class = "control-label" })
                <div class="input-group date">
                    @Html.TextBox("To", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                    <div class="input-group-addon">
                        <i class="fa fa-calendar"></i>
                    </div>
                </div>
            </div>
            <div class="form-group col-md-2 select2-box">
                @Html.Label("Last Pos", null, new { @class = "control-label" })
            <input type="checkbox"  name="lastpos"  value="1"  />
            </div>
            <div class="box-footer col-md-12">
                <button type="submit" class="btn btn-info col-sm-offset-5" id="btn">Submit</button>
                <button type="button" class="btn btn-default" onclick="@("window.location.href='/Home/Index'");">Cancel</button>
            </div>
        </div>
            }
        </div>
   
</div>


@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
}
@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    <script type="text/javascript">
        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });
        $(document).ready(function () {
            //$("#VoucherNo").select2();
            $('#To').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });
            $('#From').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });

            var date = new Date();
            var today = new Date(date.getFullYear(), date.getMonth(), date.getDate());
            var priordate = new Date(new Date().setDate(today.getDate() - 30));
            $('#To').datepicker('setDate', today);
            $('#From').datepicker('setDate', priordate);
            $('#Showtable').hide();

            GetDepartment();
            CallEmployee();
        });
        $('body').on('change', '#ddlDepartment', function (e) {
            var deptid = $(this).val();
            if (deptid != null) {
                CallEmployeeByDept(deptid);
            }
        });

       
    </script>
}
