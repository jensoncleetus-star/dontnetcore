@{
    ViewBag.Title = "Search Attendance Register";
    ViewBag.SubTitle = "Attendance Register Report";
    ViewBag.Active = "Reports";
}
<div class="box box-default" id="Showtable">
    <div class="box-header with-border">
        <h3 class="box-title">View Attendance Register Report</h3>
    </div>
    <div class="box-body">
        <div class="box-body">
            <table class="table table-bordered" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="2">Month</td>
                        <td data-priority="2">Total Number of Vouchers</td>
                        <td hidden></td>
                    </tr>
                </thead>
                <tbody></tbody>
                <tfoot>
                    <tr>
                        <td></td>
                        <td></td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
}
@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    <script type="text/javascript">
        
        var oTable = $('#UserTable').DataTable({ 
            responsive: true,
            "filter": false,
            "paging": false,
            "bInfo": false,
            "ordering": false,
                "ajax": {
                    "url": '/AttendanceReport/GetAttendanceRegister',
                    "type": "POST",
                    "datatype": "json"
                },
                "columns": [
                     { "data": "Month", "name": "Month" },
                     { "data": "VCount", "name": "VCount" },
                     { "data": "MonthVal", "name": "MonthVal" },
                ],
        });
        var column1 = oTable.column(2);
        column1.visible(false);

        $('#UserTable tbody').on('click', 'tr', function () {
            if ($(this).hasClass('selected')) {
                $(this).removeClass('selected');
            }
            else {
                oTable.$('tr.selected').removeClass('selected');
                $(this).addClass('selected');
                $(this).addClass('dataTables_row');
            }
        });
        $('#UserTable tbody').on('dblclick', 'tr', function (e) {
            var data = oTable.row(this).data();
            var url = "/Hr/AttendanceReport/AttendanceDetails?month=" + data.MonthVal + " ";
            $(location).attr('href', url);
        });
    </script>
}
