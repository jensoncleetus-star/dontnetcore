@model QuickSoft.ViewModel.ReceiptViewModel
@{
    ViewBag.Title = "Create";
    ViewBag.SubTitle = "Receipt";
    ViewBag.Active = "Transactions";

}
@using (Html.BeginForm("Create", "PReceipt", FormMethod.Post, new { id = "recform", role = "form", enctype = "multipart/form-data" }))
{
    <div class="box box-info">
        <div class="box-header with-border">
            <h3 class="box-title">Create Receipt</h3>
            <div class="pull-right">
                @if (@ViewBag.LastEntry != 0)
                {
                    if (User.IsInRole("Dev") || User.IsInRole("Edit Receipt"))
                    {
                        <a class="btn bg-black no-border" href="/Property/PReceipt/Edit/@ViewBag.LastEntry">
                            <i class="fa fa-step-backward"></i>
                        </a>
                    }
                }
                @if (User.IsInRole("Dev") || User.IsInRole("Receipt List"))
                {
                    <a class="btn btn-success no-border" href="/Property/PReceipt">
                        <i class="fa fa-fw fa-history"></i> List
                    </a>
                }
            </div>
        </div>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        <div class="box-body">
            <input type="hidden" id="VoucherType" value="Receipt" />
            <div class="row">
                <div class="col-sm-2 form-group ">
                    @Html.LabelFor(model => model.VoucherNo, new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.VoucherNo, new { htmlAttributes = new { @class = "form-control", @required = "required", tabindex = 1 } })
                </div>
                <div class="col-sm-2 form-group">
                    @Html.LabelFor(model => model.Date, htmlAttributes: new { @class = "control-label" })*
                    <div class="input-group date">
                        <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                        @Html.TextBoxFor(m => m.Date, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @required = "required", tabindex = 2 })
                    </div>
                </div>
                <div class="col-sm-2 form-group">
                    @*@Html.HiddenFor(model => model.MOPayment, new { @Value = "0" })*@
                    @Html.LabelFor(model => model.MOPayment, new { @class = "control-label" }) *
                    @Html.EnumDropDownListFor(model => model.MOPayment, new { @id = "MoPay", @class = "form-control", @onchange = "modechange()", tabindex = 3 })
                </div>
                @*<div id="divproject" hidden>
                    @if (@ViewBag.ProjChk == 0)
                    {*@
                <div class="form-group col-sm-2">
                    @Html.LabelFor(m => m.Property, new { @class = "control-label" })
                    @*@if (User.IsInRole("Dev") || User.IsInRole("Create Project"))
                        {*@
                    <div class="input-group input-group-sm">
                        @Html.DropDownListFor(m => m.Project, (SelectList)ViewBag.getProj, "", new { id = "ddlProject", @class = "form-control select2" })
                        <span class="input-group-btn">
                            <a href="/Property/PropertyMain/AddProperty" class="modal-project btn btn-success btn-flat" title="Add Property"><i class="fa fa-1x fa-plus-circle"></i></a>
                        </span>
                    </div>
                    @*}
                        else
                        {
                            @Html.DropDownListFor(m => m.Project, (SelectList)ViewBag.getProj, "", new { id = "ddlProject", @class = "form-control select2" })
                        }*@
                </div>
                <div class="form-group col-sm-2">
                    @Html.LabelFor(m => m.Unit, new { @class = "control-label" })
                    @Html.DropDownListFor(m => m.ProTask, (SelectList)ViewBag.getProTask, "", new { id = "ddlProTask", @class = "form-control select2" })
                </div>
                @*}
                    </div>*@
                <div class="col-sm-2 form-group">
                    @Html.Label("PDCDate", null, htmlAttributes: new { @class = "control-label", @id = "PDC", })
                    @Html.Label("CDCDate", null, htmlAttributes: new { @class = "control-label", @id = "CDC", })*
                    <div class="input-group date">
                        <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                        @Html.TextBoxFor(m => m.PDCDate, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @required = "required", tabindex = 4 })
                    </div>
                </div>
                @if (@ViewBag.BranchCheck == 0)
                {
                    <div class="form-group col-sm-2">
                        @Html.Label("Branch", null, new { @class = "control-label" })
                        @Html.DropDownListFor(m => m.Branch, (SelectList)ViewBag.SetBranch, new { id = "ddlBranch", @class = "form-control select2" })
                    </div>
                }
                <div class="col-sm-2 form-group">
                    @Html.LabelFor(m => m.PayTo, new { @class = "control-label" }) *
                    @if (User.IsInRole("Dev") || User.IsInRole("Create Bank Accounts"))
                    {
                        <div class="input-group input-group-sm">
                            @Html.DropDownListFor(m => m.PayTo, (SelectList)ViewBag.PaidTo, new { id = "ddlpayto", @class = "form-control select2", @required = "required", tabindex = 5 })
                            <span class="input-group-btn">
                                <button type="button" href="/Master/BankAccountscreate" class="modal-create btn btn-success btn-flat" tabindex="6"><i class="fa fa-1x fa-plus-circle"></i></button>
                            </span>
                        </div>

                    }
                    else
                    {
                        @Html.DropDownListFor(m => m.PayTo, (SelectList)ViewBag.PaidTo, new { id = "ddlpayto", @class = "form-control select2", @required = "required", tabindex = 5 })
                    }
                    <div id="accbalanceto" class="form-group" style="display:none">
                        <div class="input-group input-group-sm">
                            <label class="text-danger" id="accdetailsto"></label>
                        </div>
                    </div>
                </div>
                <div class="col-sm-2 form-group">
                    @Html.LabelFor(m => m.PayFrom, new { @class = "control-label" }) *
                    @Html.DropDownListFor(m => m.PayFrom, (SelectList)ViewBag.Paidfrom, new { id = "ddlpayfrom", @class = "form-control select2", @required = "required", tabindex = 7 })
                    <div id="accbalance" class="form-group" style="display:none">
                        <label>Account Summary</label>
                        <div class="input-group input-group-sm">
                            <label class="text-danger" id="accdetails"></label>
                        </div>
                    </div>
                </div>
            </div>
         
                <div class="row">
                    <div class="col-sm-2 form-group" id="checkno">
                        @Html.LabelFor(model => model.CheckNo, new { @class = "control-label" })
                        @Html.EditorFor(model => model.CheckNo, new { htmlAttributes = new { @class = "form-control", @required = "required", data_msg_required = "Check Number is Required", tabindex = 8 } })
                    </div>
                    <div class="form-group col-sm-2" id="bank">
                        @Html.LabelFor(model => model.Bank, new { @class = "control-label" })<br />
                        @Html.DropDownListFor(model => model.Bank, new SelectList(new List<SelectListItem>
                            {
                        new SelectListItem() {Text = "Select", Value=""},


                    }, "Value", "Text")
                               , new { htmlAttributes = new { @class = "form-control", tabindex = 9 } })
                    </div>



                    <div class="form-group col-sm-12 no-padding">
                        @Html.Label("Attachment", null, new { @class = "control-label" })
                        <input type="file" class="form-control Attache" id="RecieptDoc" name="RecieptDoc" placeholder="Enter Attachments" />

                        <a href="/uploads/RecieptDoc/@ViewBag.fname" target="_new">Open Attachment</a>


                    </div>
                    <div class="clearfix"></div>
                </div>
                <div class="row">
                    @if (Model.FieldMap.Count > 0)
                    {
                        for (int i = 0; i < Model.FieldMap.Count; i++)
                        {
                            <div class="form-group col-sm-2">
                                <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName</label>
                                <input class="form-control input-sm" id="@Model.FieldMap[i].Field" name="@Model.FieldMap[i].Field" type="text" value="">
                            </div>
                        }
                    }
                </div>
                <div>
                    <div class="table-responsive hight-250" id="invoice"><hr /></div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.TextAreaFor(model => model.Remark, new { @class = "form-control", @placeholder = "Remarks", tabindex = 9 })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group col-md-6 col-md-offset-6 no-padding">
                                @Html.LabelFor(model => model.Discount, new { @class = "control-label" })
                                @Html.EditorFor(model => model.Discount, new { htmlAttributes = new { @id = "Discount", @class = "form-control text-right", @value = "0.00", tabindex = 10 } })
                            </div>
                            <div class="form-group col-md-6 col-md-offset-6 no-padding">
                                @Html.LabelFor(model => model.GrandTotal, new { @class = "control-label" })
                                @Html.EditorFor(model => model.GrandTotal, new { htmlAttributes = new { @id = "GrandTotal", @class = "form-control text-right", @value = "0.00", @readonly = "readonly", tabindex = 10 } })
                            </div>
                            <div class="form-group col-md-6 col-md-offset-6 no-padding">
                                @Html.LabelFor(model => model.Paying, new { @class = "control-label" })
                                @Html.EditorFor(model => model.Paying, new { htmlAttributes = new { @id = "Paying", @class = "form-control text-right", @value = "0.00", @min = "0.01", tabindex = 11 } })
                            </div>
                            <div class="form-group col-md-6 no-padding hidden">
                                @Html.LabelFor(model => model.Balance, new { @class = "control-label" })
                                @Html.EditorFor(model => model.Balance, new { htmlAttributes = new { @id = "Balance", @class = "form-control text-right", @value = "0.00", @readonly = "readonly", tabindex = 12 } })
                            </div>
                        </div>
                    </div>
                    <div class="col-md-12">
                        <hr />
                        <div class="form-group pull-right">
                            <div class="form-group no-padding text-right">
                                <div class="checkbox-inline">
                                    <input class="checkbox" data-val="true" id="hideheader" name="hideheader" type="checkbox" value="true">
                                    <label class="control-label" for="hideheader">Hide Header In Print</label>
                                </div>
                            </div>
                            <input type="hidden" value="" name="submittype" id="submittype" />
                            <button type="submit" id="save" class="btn btn-info" tabindex="13">
                                <span class="glyphicon glyphicon-floppy-disk"></span> Save
                            </button>
                            <button type="submit" id="print" class="btn btn-success" tabindex="14">
                                <span class="glyphicon glyphicon-print"></span> Save And Print
                            </button>
                            <button type="button" tabindex="15" class="btn btn-warning" onclick="@("window.location.href='/Property/PReceipt/Index'");">Cancel</button>
                            <input type="hidden" value="@ViewBag.StartDate" class="Start" name="Start" id="Start">
                            <input type="hidden" value="@ViewBag.EndDate" class="End" name="End" id="End">

                            <input type="hidden" value="@ViewBag.BusinessType" id="BusinessType">
                        </div>
                    </div>
                </div>
            </div>
    </div>
    <style>
        #Bank {
            width: 250px;
        }
    </style>

}
@if (ViewBag.BusinessType == "Scaffold")
{
    @Html.Partial("_Voucher1")
}
else
{
    @Html.Partial("_Voucher")
}

@Html.Partial("../Common/_ModalCreate")
@Html.Partial("../Common/_ModelProject")

@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/print")
}
@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/receipt")
    @Scripts.Render("~/js/num2words")
    @Scripts.Render("~/js/property")

    <script type="text/javascript">
        var minDate = $("#Start").val();
        var maxDate = $("#End").val();
        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true,
         //   startDate: new Date(minDate),
          //  endDate: new Date(maxDate)
        });
        jQuery.validator.methods["date"] = function (value, element) { return true; }

        $(document).ready(function () {
            $('#PDCDate').prop('disabled', true);
            $('#checkno').hide();
            $('#bank').hide();
            callbank();
            modechange();
            GetBranch();
            $('#CDC').hide();
            $('.sup').hide();
            // paid from with select 2
            PaymentFrom();
            PaymentTo();
            var accid = $('#ddlpayto').val();
            accbalanceto(accid);

            GetPropertyforPayment();
            GetUnitforPayment();
        });
        // on change function of payto
        $('body').on('change', '#ddlpayfrom', function (e) {
            var accid = $(this).val();
            var accidto = $("#ddlpayto").val();

            if(accid!=accidto){
                var chkReceipt=@ViewBag.BillToReceipt;
                accbalance(accid,chkReceipt);
               // chkacctype(accid);
            }else{
                alert("PayFrom And PayTo Should be Different..!!");
                $('#ddlpayfrom').val(null).trigger('change');
            }
        });
        $('body').on('change', '#Discount', function (e) {
            var totalPaid = $("#Paying").val();
            var discount = $("#Discount").val();
            if(parseFloat(discount) <= parseFloat(totalPaid)){
                cashBalance();
            }else{
                $("#Discount").val("0.00");
                alert("Discount Should Less Than Amount..!!");
            }
        });
        $('body').on('change', '#ddlpayto', function (e) {
            var accid = $(this).val();
            var accidfr = $("#ddlpayfrom").val();
            if(accid!=accidfr){
                accbalanceto(accid);
            }else{
                alert("PayTo And PayFrom Should be Different..!!");
                $('#ddlpayto').val(null).trigger('change');
            }
        });

        // onchange function for paying
        $('body').on('change', '#Paying', function (e) {
            cashBalance();
        });

        // onchange function for modpaying
        $('body').on('change', '#MoPay', function (e) {
            var MOP=$('#MoPay').val();
            var hid=(MOP==2)?$('#CDC').show() && $('#PDC').hide() :($('#PDC').show() && $('#CDC').hide());
            modechange();
        });
        //$('body').on('change', '#ddlProject', function (e) {
        //    $('#ddlProTask').val(null).trigger('change');
        //    CallTask();
        //});

        $('#recform').on('submit', function (e) {
           e.preventDefault();
            if ($("#recform").valid()) {
                var fnval = $('input[type="submit"], button[type="submit"]', this).filter(':focus').attr('id');
                $('#submittype').val(fnval);
                formsubmitionprop(fnval);
            }

        });

        /* function for Create popup */

        $('span').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        });
        $('#modal-create').on('submit', '#createform', function (e) {
            e.preventDefault();
            var url = $('#createform')[0].action;
            var data = $('#createform').serialize();
            createajax(url, data, '#modal-create');
        });
        $('span').on('click', '.modal-project', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-project');
            //datepickerInit();
        });


        //select all checkboxes
        var itmbal = 0;
        var pamt = 0;
        $('body').on('change', '#select_all', function () {
            itmbal = 0;
            pamt = 0;
            checkedall();
            //if (false == $("#select_all").prop("checked")) {
            //    $("#GrandTotal").val("0.00");
            //    $("#Balance").val("0.00");
            //} else {
            //    checkedall();
            //}

            $(".checkbox").prop('checked', $(this).prop("checked")); //change all ".checkbox" checked status

        });

        function checkedall() {
            var btotalamt = 0;
            var tbody = $("#invoice tbody");
            if (tbody.children().length > 0) {
                tbody.children("tr").each(function () {
                    var rowid = $(this).attr("id");
                    var btotal = $("#" + rowid + " .blnc").text();
                    btotal = btotal || 0;
                    btotalamt += parseFloat(btotal);
                    $("#GrandTotal").val(btotalamt.toFixed(2));
                    $("#Balance").val(btotalamt.toFixed(2));
                });
            }
        }

        //".checkbox" change
        $('body').on('change', '.checkbox', function () {
            if ($(this).prop("checked") == false) {
                $("#select_all").prop('checked', false);
            }
            var itmbal=0;
            if (true == $("#select_all").prop("checked")) {
                $("#select_all").prop('checked', true);
                checkedall();
            } else {
                if (false == $("#select_all").prop("checked")) {
                    $("#select_all").prop('checked', false);
                    checkedall();
                }
                //$("#GrandTotal").val("0.00");
                //$("#Balance").val("0.00");
                var tbody = $("#invoice tbody");
                if (tbody.children().length > 0) {
                    tbody.children("tr").each(function () {
                        var rowid = $(this).attr("id");
                        if ($("#" + rowid + " .checkbox").prop("checked") == true) {
                            var btotal = $("#" + rowid + " .blnc").text();
                            itmbal += parseFloat(btotal);
                            $("#GrandTotal").val(itmbal.toFixed(2));
                            $("#Balance").val(itmbal.toFixed(2));
                        }
                    });
                }
            }
            isTicked();
            //AutoBalance();
        });


        isTicked();
        PropertyPopup();
    </script>
}
