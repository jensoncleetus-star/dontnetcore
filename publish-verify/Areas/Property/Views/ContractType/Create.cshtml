
@model QuickSoft.Models.ContractType
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Add Contract Type</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("Create", "ContractType", FormMethod.Post, new { id = "createform" }))
    {
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        <div class="row">
            <div class="col-md-12">

                <div id="simp">
                    <div class="form-group">
                        @Html.LabelFor(m => m.Name, new { @class = "control-label col-sm-4" })
                        @Html.EditorFor(model => model.Name, new { htmlAttributes = new { @class = "form-control" } })
                    </div>
                    <div class="form-group">
                        @Html.Label("Account", null, htmlAttributes: new { @class = "control-label " })
                        @Html.DropDownListFor(m => m.Account, (SelectList)ViewBag.Acc, new { @class = "form-control input-sm" })
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <button type="submit" class="btn btn-info col-sm-offset-4">Save</button>
                    <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    }
</div>
<script type="text/javascript">

        $(document).ready(function () {
            $('#Account').select2();
        });
</script>

