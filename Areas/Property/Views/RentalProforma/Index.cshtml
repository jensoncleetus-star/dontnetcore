@model QuickSoft.Models.RentalProforma
@{
    ViewBag.Title = "List";
    ViewBag.SubTitle = "Rental Proforma";
    ViewBag.Active = "Master";
    string actData = "";
    string delchk = "";
    bool userRole = false;
    string deleteBTn = "";
    //if (User.IsInRole("Dev") || User.IsInRole("Delete ProRegistration"))
    //{
    userRole = true;
    deleteBTn = "{text: 'Delete', className: 'btn-danger', action: function(e, dt, node, config) {" +
          "if ($('.checkbox:checked').length > 0) {if (confirm('Are you sure you want to delete this?')) {$('#delallform').submit(); e.preventDefault();} " +
           "} else {alert('Please Select Rows..!!');e.preventDefault();}}},";
//}
}
<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">List Rental Proforma</h3>
        <div class="pull-right">
            @*@if (User.IsInRole("Dev") || User.IsInRole("Create ProRegistration"))
    {*@
            <i class="ace-icon fa fa-hand-o-right icon-animated-hand-pointer blue"></i>
            <a class="btn btn-info no-border" href="/Property/RentalProforma/Create">
                <i class="glyphicon glyphicon-plus"></i> Create
            </a>
            @*}*@
        </div>
    </div>

<div class="box-body search-box">
    <a class="btn btn-primary" id="srch">
        <i class="glyphicon glyphicon-search"></i> Advanced Search
    </a>
    <input type="hidden" id="remId" />
    <div class="search-body col-md-12" id="advsearch">
        <form id="search-form">
            <div class="row">
                <div class="form-group col-md-2">
                    @Html.Label("Invoice No", null, new { @class = "control-label" })
                    @Html.TextBox("InvoiceNo", "", new { @class = "form-control input-sm" })
                </div>
               
                <div class="form-group col-md-2 select2-box">
                    @Html.Label("Developer", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlTenant", (SelectList)ViewBag.Alldata, "All", new { @class = "form-control input-sm select2" })
                </div>
                <div class="form-group col-md-2 select2-box">
                    @Html.Label("Property", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlProperty", (SelectList)ViewBag.Alldata, "All", new { @class = "form-control input-sm select2" })
                </div>
                <div class="form-group col-md-2">
                    @Html.Label("From Date", null, new { @class = "control-label" })
                    <div class="input-group date">
                        @Html.TextBox("FromDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                        <div class="input-group-addon">
                            <i class="fa fa-calendar"></i>
                        </div>
                    </div>
                </div>
                <div class="form-group col-md-2">
                    @Html.Label("To Date", null, new { @class = "control-label" })
                    <div class="input-group date">
                        @Html.TextBox("ToDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                        <div class="input-group-addon">
                            <i class="fa fa-calendar"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <input type="submit" class="btn btn-submit col-sm-offset-5" value="Submit" />
                    <input type="button" class="btn btn-close" value="Close" />
                </div>
            </div>
        </form>
    </div>
</div>
@using (Html.BeginForm("DeleteAll", "RentalProforma", FormMethod.Post, new { id = "delallform", role = "form" }))
{
    <div class="box-body">
        <table class="table table-bordered table-hover" id="MyTable">
            <thead>
                <tr>
                    <td data-priority="1">#</td>
                    <td data-priority="2">Voucher No</td>
                    <td data-priority="2">Date</td>
                    <td data-priority="2">Tenant</td>
                    <td data-priority="5">Property</td>
                    <td data-priority="2">Action</td>
                    <td data-priority="2"><input type="checkbox" id="select_all" /></td>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
    <input type="hidden" value="@ViewBag.StartDate" class="Start" name="Start" id="Start">
    <input type="hidden" value="@ViewBag.EndDate" class="End" name="End" id="End">
}
</div>


@Html.Partial("../Common/_ModalCreate")
@Html.Partial("../Common/_ModalEdit")
@Html.Partial("../Common/_ModalDelete")
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
}
@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/property")
    @Scripts.Render("~/js/bootstrap-datepicker")
    <script type="text/javascript">
        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true,
        });
        jQuery.validator.methods["date"] = function (value, element) { return true; }
        $(document).ready(function () {
            $('#comp').hide();
            $('#advsearch').hide();
            GetDeveloper(1);
            GetOwner(1);
            GetProperty(1);
            GetBroker(1);
        });
        var oTable = $('#MyTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "pageLength": 50,
            responsive: true,
            "bLengthChange": false,
            "ajax": {
                "url": '/RentalProforma/GetData',
                "data": function (data) {
                    data.InvoiceNo = $('#InvoiceNo').val();
                    data.FromDate = $('#FromDate').val();
                    data.ToDate = $('#ToDate').val();
                    data.Tenant = $('#ddlTenant').val();
                    data.Property = $('#ddlProperty').val();
                },
                "type": "POST",
                "datatype": "json"
            },
            "order": [[0, "desc"]],
            "columnDefs": [{
                "targets": [5, 6],
                "orderable": false
            }],
            "columns": [
                     {
                         "data": "id", "name": "id",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                 { "data": "VoucherNo", "name": "VoucherNo" },
                   {
                       "data": "Date", "name": "Date",
                       "render": function (data) {
                           var date = convertToDate(data);
                           return date.toString();
                       }
                   },
                 { "data": "Tenant", "name": "Tenant" },
                 
                 { "data": "Property", "name": "Property" },

                 {
                     "name": "id", "data": function (data) {
                         var rest = "";
                         @{
                             //if (User.IsInRole("Dev") || User.IsInRole("Edit ProRegistration"))
                             //{
                             actData += "<a class=\"details\" href=\"/Property/RentalProforma/Details/'+ data.id +'\" title=\"View Rental Proforma\"><i class=\"fa fa-lg fa-search-plus\"></i></a> ";                             //}
                                                                                                                                                                                                               //if (User.IsInRole("Dev") || User.IsInRole("Edit ProRegistration"))
                                                                                                                                                                                                                 //{
                             actData += "<a href=\"/Property/RentalProforma/Edit/'+ data.id +'\" title=\"Edit \"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                             //}
                             //if (User.IsInRole("Dev") || User.IsInRole("Delete ProRegistration"))
                             //{
                             actData += "<a class=\"modal-delete\" href=\"/Property/RentalProforma/Delete/'+ data.id +'\" title=\"Delete\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";
                             //}
                             actData += "<a class=\"modal-link-download\" href=\"/Property/RentalProforma/Download/'+ data.id +'\" title=\"Download Rental Proforma\"><i class=\"fa-lg fa fa-download\" ></i></a> ";

                              }
                         return rest = '@Html.Raw(actData)';
                     }
                 },
                  {
                      "name": "id", "data": function (data) {
                          var rest = "";
                          @{
                              //if (User.IsInRole("Dev") || User.IsInRole("Delete ProRegistration"))
                              //{
                              delchk = "<input class=\"checkbox\" type=\"checkbox\" name=\"bill[]\" value='+ data.id +'></input>";
                          //}
                          }
                          return rest = '@Html.Raw(delchk)';
                      }
                  }
            ],
             buttons: [
                'colvis',
                {
                    extend: 'print',//
                    title: "",
                    footer: true,
                    filename: function () {
                        return 'Rental Invoice';
                    },
                    columnDefs: [
                        { width: 400, targets: 2 }
                    ],
                    exportOptions: {
                        columns: ':visible'
                    },
                    message: function () {
                        var head = '<table class="tblcompact table table-bordered"><thead>' +
                        ' <tr><th class="text-center"><h3 style="margin-top: 0px;"><h4>Property Registration</h4></th></tr>';
                        return head;
                    },
                    customize: function (win) {
                        // $(win.document.body)
                        //.css('font-size', '10pt')
                        //.css('padding', '1px');
                        $(win.document.body).find('table.tblcompact tbody td').css('padding', '0px');
                        $(win.document.body).find('.dataTable,.dataTable th,.dataTable tr,table.tblcompact tbody td .dataTable td')
                            .css('font-size', '10pt')
                            .css('padding', '5px')
                            .addClass('compact');
                        $(win.document.body).find('.dataTable tr th:nth-child(3)')
                            .css('min-width', '80px');
                        //$(win.document.body).find('.tblcompact tbody td:nth- child(2)')
                        //    .css('padding', '0px');
                        $(win.document.body).append('</td></tr></tbody>')

                    }
                }, 'copy', 'csv', //'excel',
                {
                    extend: 'pdf',//
                    title: "",
                    footer: true,
                    filename: function () {
                        return 'Rental Invoice';
                    },
                    message: function () {
                        var head = 'Rental Invoice';
                        return head;
                    },
                    pageSize: 'A4',
                    exportOptions: {
                        columns: ':visible'
                    },
                    customize: function (doc) {
                        doc.pageMargins = [10, 10, 10, 10];
                        doc.defaultStyle.fontSize = 10;
                        doc.styles.tableHeader.fontSize = 10;
                        doc.styles.title.fontSize = 12;
                        // Header font and bg color
                        doc.styles.tableHeader.fillColor = '#d3d3d3';
                        doc.styles.tableHeader.color = 'black';
                        // Remove spaces around page title
                        doc.content[0].text = doc.content[0].text.trim();


                        doc.styles['td:nth-child(2)'] = {
                            width: '100%',
                            'max-width': '100%'
                        }

                        var objLayout = {};
                        // Horizontal line thickness
                        objLayout['hLineWidth'] = function (i) { return .5; };
                        // Vertikal line thickness
                        objLayout['vLineWidth'] = function (i) { return .5; };
                        //// Horizontal line color
                        //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                        //// Vertical line color
                        //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                        // Left padding of the cell
                        objLayout['paddingLeft'] = function (i) { return 4; };
                        // Right padding of the cell
                        objLayout['paddingRight'] = function (i) { return 4; };
                        // Inject the object in the document
                        doc.content[1].layout = objLayout;
                        // Footer font and bg color
                        doc.styles.tableFooter.fillColor = '#d3d3d3';
                        doc.styles.tableFooter.color = 'black';

                    }
                },  @Html.Raw(deleteBTn)

            ],
            sDom: "lBfr<'datatable-scroll't>ip",
            "drawCallback": function (settings) {
            }
        });

        var chkcol = '@userRole';
        if (chkcol == "True") {
            var column1 = oTable.column(6);
            column1.visible(true);
        } else {
            var column1 = oTable.column(6);
            column1.visible(false);
        }

        /* function for delete popup */
        $('#MyTable').on('click', '.modal-delete', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-delete');
        });
        $('#modal-delete').on('submit', '#deleteform', function (e) {
            e.preventDefault();
            var url = $('#deleteform')[0].action;
            var data = $('#deleteform').serialize();
            createajax(url, data, '#modal-delete');
        });
        /* function for view detail popup */
        $('#MyTable').on('click', 'a.details', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        })


        //select all checkboxes
        $('body').on('change', '#select_all', function () {
            $(".checkbox").prop('checked', $(this).prop("checked")); //change all ".checkbox" checked status
        });

        //".checkbox" change
        $('body').on('change', '.checkbox', function () {
            //uncheck "select all", if one of the listed checkbox item is unchecked
            if (false == $(this).prop("checked")) { //if this item is unchecked
                $("#select_all").prop('checked', false); //change "select all" checked status to false
            }
            isTicked();
        });
        isTicked();

        $('#srch, .search-box .btn-close').on('click', function (e) {
            $('#advsearch').toggle();

            if ($('#srch').hasClass('btn-primary')) {
                $('#srch').addClass('btn-danger');
                $('#srch').removeClass('btn-primary');
            }
            else if ($('#srch').hasClass('btn-danger')) {
                $('#srch').addClass('btn-primary');
                $('#srch').removeClass('btn-danger');
                //location.reload();
                $('#InvoiceNo').val("");
                $('#FromDate').val("");
                $('#ToDate').val("");
                $('#ddlTenant').val(0);
                $('#ddlProperty').val(0);
                oTable.draw();
            }
            $('#Date').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true,
            });

        });

        $('#search-form').on('submit', function (e) {
            e.preventDefault();
            oTable.draw();
        });
    </script>
}