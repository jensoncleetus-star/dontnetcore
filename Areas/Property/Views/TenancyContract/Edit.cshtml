                str += '<td>' + convertToDate(expdat) + '</td>';
                str += '</tr>';
                adcount++;
                $('#cheqfieldssec').append(str);
            });
            var dcount = 1;
            $.each(e.docs, function (i, item) {

                var dat = ((item.data != null) ? item.data : "");
                var str = '<tr>';
                str += '<td>' + item.Name + '</td>';
                str += '<td>' + convertToDate(item.ExpDate) + '</td>';
                str += '</tr>';
                dcount++;
                $('#docfields').append(str);
            });
            if (dcount == 1) {
                $("#doc").hide();
                $("#docfields").hide();
            }
            else {
                $("#doc").show();
                $("#docfields").show();
            }
            if (adcount == 1) {
                $("#cheqs").hide();
                $("#cheqfields").hide();
            }
            else {
                $("#cheqs").show();
                $("#cheqfields").show();
            }
            if (e.ComHeadCheck == 0) {
                $("#ComHeadCheck").hide();
            }
            else {
