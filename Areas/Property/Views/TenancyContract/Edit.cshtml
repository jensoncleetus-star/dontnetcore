            $("#lbloccupants").text(e.Data.Note);


            var adcount = 1;
            $.each(e.cheque, function (i, item) {
                var expdat = item.Date;
                var dat = ((item.data != null) ? item.data : "");
                var str = '<tr>';
                str += '<td>' + item.chequeno + '</td>';
                str += '<td>' + item.Amount + '</td>';
                str += '<td>' + convertToDate(expdat) + '</td>';
                str += '</tr>';
                adcount++;
                $('#cheqfields').append(str);
            });
            $.each(e.seccheque, function (i, item) {
                var expdat = item.Date;
                var dat = ((item.data != null) ? item.data : "");
                var str = '<tr>';
                str += '<td>' + item.chequeno + '</td>';
