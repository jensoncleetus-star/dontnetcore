                <div class="col-sm-2 form-group">
                    @Html.Label("Payment Type", null, new { @class = "control-label" })
                    @Html.DropDownListFor(m => m.PaymentType, (SelectList)ViewBag.PaymentTypes, new { id = "ddlPaymentType", @class = "form-control select2", tabindex = 5 })
                </div>
            </div>
            <div class="box-body">
