        $('#editmainForm').on('submit', function (e) {
            if ($("#editmainForm").valid()) {
                e.preventDefault();
                var url = $('#editmainForm')[0].action;
                var formData = new FormData(this);
                var fnval = $('input[type="submit"], button[type="submit"]', this).filter(':focus').attr('id');
                formData.append('fnval', fnval);
                //var docUpload = $("#ItemDocument").get(0);
                //var docFiles = docUpload.files;
                //if (docFiles[0] != null) {
                //    formData.append(docFiles[0].name, docFiles[0]);
                //}

                $.ajax({
                    async: true,
                    cache: false,
                    dataType: "json",
                    type: "POST",
                    processData: false,
                    contentType: false,
                    url: url,
                    data: formData,//$('#createlandlordForm').serialize(), //formData,//JSON.stringify(parameters),
                    beforeSend: function () {
                        $("button").prop('disabled', true); // disable button
                    },
                    success: function (e) {
                        if (e.status) {
                            $('.ajax_response', res_success).text(e.message);
                            $('.AlertDiv').prepend(res_success);
                            if (fnval == "save") {
                                location.reload();
                            }
                            if (fnval == "print") {
                                Tenprint(e); location.reload();
                            }
                        }
                        else {
                            $('.ajax_response', res_danger).text(e.message);
                            $('.AlertDiv').prepend(res_danger);
                            $("button").prop('disabled', false); // enable button
                        }
                    }
                });
            }
        });
