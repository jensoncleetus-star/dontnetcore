                        leng = data.length;
                        if (leng > 0) {
                            $.each(data, function (i, item) {
                                AddDepCheq(item.ID, item.Amt, item.No, item.Date, item.AttAch, item.Id, item.Bank, item.BankName);
                            });
                        } else {
                        }
                    }
                });

                $('#DepCheqDetails').show();
                searchBankNameDep();
            }
        }
