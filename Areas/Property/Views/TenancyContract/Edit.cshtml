                AddCheq();
                $('#CheqDetails').show();
                searchBankName();
            }
        });

        function Deppaychange() {
            var com = $('#ddlPaymentType').val();
            var EntryID = $('#Id').val();
            if (com == "1") {
                $('#CheqDetails').hide();
                $(".docSet").remove();
            } else {

                $.ajax({
                    url: '/Property/TenancyContract/GetCheque',
                    dataType: 'json',
                    data: { CnId: EntryID },
                    cache: true,
                    success: function (data) {
                        //$('#addchecklist').html('');
                        leng = data.length;
                        if (leng > 0) {
                            $.each(data, function (i, item) {
                                AddCheq(item.ID, item.Amt, item.No, item.Date, item.AttAch, item.Id, item.Bank, item.BankName);
                            });
                        } else {
                        }
                    }
                });

                $('#CheqDetails').show();
                searchBankName();
            }
            var com2 = $('#ddlPaymentTypeDeposit').val();
            if (com2 == "1" || com2 == "3") {
                $('#DepCheqDetails').hide();
                $(".depSet").remove();
            } else {

                $.ajax({
                    url: '/Property/TenancyContract/GetChequeDeposit',
                    dataType: 'json',
                    data: { CnId: EntryID },
