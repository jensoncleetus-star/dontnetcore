@model QuickSoft.ViewModel.PropertyHomeViewModel
@{
    ViewBag.Title = "Dashboard";
    ViewBag.SubTitle = "";
    ViewBag.Active = "Dashboard";
    string actData = "";
}
<div class="row">

    @if (@ViewBag.BusinessType == "Property")
    {
        <div class="col-md-6" style="display:none;">
            <div class="box box-danger">
                <div class="box-header with-border">
                    <h3 class="box-title">Units Chart</h3>
                    <div class="box-tools pull-right">
                        <button type="button" class="btn btn-box-tool" data-widget="collapse">
                            <i class="fa fa-minus"></i>
                        </button>
                        <button type="button" class="btn btn-box-tool" data-widget="remove"><i class="fa fa-times"></i></button>
                    </div>
                </div>
                <div class="box-body">
                    <canvas id="salesChart" style="height:250px"></canvas>
                    <ul class="chart-legend clearfix list-inline">
                        <li><i class="fa fa-circle-o text-aqua"></i> Units</li>
                        <li><i class="fa fa-circle-o text-blue"></i> Empty Units</li>
                    </ul>
                </div>
                <!-- /.box-body -->
            </div>
        </div>
        <div class="col-md-6" style="display:none;">
            <div class="box box-danger">
                <div class="box-header with-border">
                    <h3 class="box-title">Financial Chart</h3>
                    <div class="box-tools pull-right">
                        <button type="button" class="btn btn-box-tool" data-widget="collapse">
                            <i class="fa fa-minus"></i>
                        </button>
                        <button type="button" class="btn btn-box-tool" data-widget="remove"><i class="fa fa-times"></i></button>
                    </div>
                </div>
                <div class="box-body">
                    <canvas id="purchaseChart" style="height:250px"></canvas>
                    <ul class="chart-legend clearfix list-inline">
                        <li><i class="fa fa-circle-o text-green"></i> Expense</li>
                        <li><i class="fa fa-circle-o text-gray"></i> Income</li>
                    </ul>
                </div>
                <!-- /.box-body -->
            </div>
        </div>
        <div class="col-md-8">

            <div class="box box-danger top-10">
                <div class="box-header with-border">
                    <h3 class="box-title">Document Expiry Remainder</h3>
                </div>
                <div class="box-body" style="">
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover" id="documentexp">
                            <thead>
                                <tr>

                                    <td data-priority="1">Document Name</td>
                                    <td data-priority="2">Expiry Date</td>
                                    <td data-priority="2">Property</td>
                                    <td data-priority="3">
                                        Details
                                    </td>

                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>










            <div class="box box-danger top-10" style="display:none;">
                <div class="box-header with-border">
                    <h3 class="box-title">Upcoming Cheques</h3>
                </div>
                <div class="box-body" style="">
                    <div class="table-responsive">
                        <table class="table no-margin" id="Cheques">
                            <thead>
                                <tr>
                                    <th>Bill No:</th>
                                    <th>Cheque Type</th>
                                    <th>Date</th>
                                    <th>Cheque No</th>
                                    <th>Amount</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="box box-danger top-10" style="display:none;">
                <div class="box-header with-border">
                    <h3 class="box-title">Expired Cheques</h3>
                </div>
                <div class="box-body" style="">
                    <div class="table-responsive">
                        <table class="table no-margin" id="ExpireCheques">
                            <thead>
                                <tr>
                                    <th>Bill No:</th>
                                    <th>Cheque Type</th>
                                    <th>Date</th>
                                    <th>Cheque No</th>
                                    <th>Amount</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="box box-danger top-10">
                <div class="box-header with-border">
                    <h3 class="box-title">Latest Registrations</h3>
                    <div class="box-tools pull-right">
                        <a href="@Url.Action("Create", "PropertyRegistration", new { id = "" })" class="btn btn-flat btn-danger btn-sm"><i class="glyphicon glyphicon-plus"></i> Add Property Registration</a>
                    </div>
                </div>
                <div class="box-body" style="">
                    <div class="table-responsive">
                        <table class="table no-margin" id="registrations">
                            <thead>
                                <tr>
                                    <th>Id</th>
                                    <th>Date</th>
                                    <th>Property</th>
                                    <th>Developer</th>
                                    <th>Broker</th>
                                    <th>Owner</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="box box-danger top-10">
                <div class="box-header with-border">
                    <h3 class="box-title">Tenancy Contracts</h3>
                    <div class="box-tools pull-right">
                        <a href="@Url.Action("Create", "TenancyContract", new { id = "" })" class="btn btn-flat btn-danger btn-sm"><i class="glyphicon glyphicon-plus"></i> Add Tenancy Contract </a>
                    </div>
                </div>
                <div class="box-body" style="">
                    <div class="table-responsive">
                        <table class="table no-margin" id="Tenancy">
                            <thead>
                                <tr>
                                    <th>Sl No:</th>
                                    <th>Property</th>
                                    <th>Contractor</th>
                                    <th>Start Date</th>
                                    <th>End Date</th>
                                    <th>Duration</th>
                                    <th>Due Date</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="box box-danger top-10">
                <div class="box-header with-border">
                    <h3 class="box-title">Maintanance Contracts</h3>
                    <div class="box-tools pull-right">
                        <a href="@Url.Action("Create", "Maintenance", new { id = "" })" class="btn btn-flat btn-danger btn-sm"><i class="glyphicon glyphicon-plus"></i> Add Maintenance </a>
                    </div>
                </div>
                <div class="box-body" style="">
                    <div class="table-responsive">
                        <table class="table no-margin" id="Maintanance">
                            <thead>
                                <tr>
                                    <th>Sl No:</th>
                                    <th>Property</th>
                                    <th>Unit</th>
                                    <th>Start Date</th>
                                    <th>End Date</th>
                                    <th>Amount</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    }

    <div class="col-md-4">
        <div class="info-box top-10">
            <span class="info-box-icon bg-aqua"><i class="fa fa-product-hunt"></i></span>
            <div class="info-box-content">
                <a href="/Property/PropertyMain/Index">
                    <span class="info-box-text">Property</span></a>
                    <span class="info-box-number">@Html.DisplayFor(m => m.totPropertycount)</span>
            </div>
        </div>
        <div class="info-box top-10">
            <span class="info-box-icon bg-aqua"><i class="fa fa-tint"></i></span>
            <div class="info-box-content">
                <a href="/Property/Unit/Index">
                    <span class="info-box-text">Units</span></a>
                    <span class="info-box-number">@Html.DisplayFor(m => m.totUnitscount)</span>
            </div>
        </div>
        <div class="info-box top-10">
            <span class="info-box-icon bg-aqua"><i class="fa fa-globe"></i></span>
            <div class="info-box-content">
                <a href="/Property/Landlords/Index"><span class="info-box-text">Landloards</span></a>
                <span class="info-box-number">@Html.DisplayFor(m => m.totLandloardscount)</span>
            </div>
        </div>
        <div class="info-box top-10">
            <span class="info-box-icon bg-aqua"><i class="fa fa-key"></i></span>
            <div class="info-box-content">
                <a href="/Property/Tenant/Index">
                    <span class="info-box-text">Tenants</span>
                    </a>
                    <span class="info-box-number">@Html.DisplayFor(m => m.totTenantscount)</span>
            </div>
        </div>
        <div class="info-box top-10">
            <span class="info-box-icon bg-aqua"><i class="fa fa-cubes"></i></span>
            <div class="info-box-content">
                <a href="/Property/Developer/Index">
                    <span class="info-box-text">Developers</span>
                    </a>
                    <span class="info-box-number">@Html.DisplayFor(m => m.totDeveloperscount)</span>
            </div>
        </div>
        <div class="info-box top-10">
            <span class="info-box-icon bg-aqua"><i class="fa fa-newspaper-o"></i></span>
            <div class="info-box-content">
                <a href="/Property/Contractor/Index">
                    <span class="info-box-text">Contractors</span>
                    </a>
                    <span class="info-box-number">@Html.DisplayFor(m => m.totContractorscount)</span>
            </div>
        </div>
        <div class="info-box top-10">
            <span class="info-box-icon bg-aqua"><i class="fa fa-location-arrow"></i></span>
            <div class="info-box-content">
                <a href="/Property/Broker/Index">
                    <span class="info-box-text">Brokers</span>
                    </a>
                    <span class="info-box-number">@Html.DisplayFor(m => m.totBrokerscount)</span>
            </div>
        </div>

        <div class="box box-widget widget-user">
            <div class="widget-user-header bg-red">
                <h3 class="widget-user-username">This Month </h3>
                <h5 class="widget-user-desc">details in a nutshell  (<span>@ViewBag.lastdate to @ViewBag.today</span>)</h5>
            </div>
            <div class="box-footer no-padding">
                <ul class="nav nav-stacked">
                    <li><a href="javascript:void(0)">Property Registrations <span class="pull-right badge bg-green">@Html.DisplayFor(m => m.totPropertRegistrationscount)</span></a></li>

                    <li><a href="javascript:void(0)">Tenancy Contracts <span class="pull-right badge bg-navy">@Html.DisplayFor(m => m.tottenentcontractscount)</span></a></li>

                    <li><a href="javascript:void(0)">Rental Invoices <span class="pull-right badge bg-red">@Html.DisplayFor(m => m.totRentalInvoicescount)</span></a></li>
                </ul>
            </div>
        </div>




    </div>
</div>
@section scripts{
    @Scripts.Render("~/js/chartjs")
    <script type="text/javascript">
        $(document).ready(function () {

            var pTable = $('#documentexp').DataTable({
                responsive: true,
                "filter": false,
                "pageLength": 10,
                "bInfo": false,
                "ordering": true,



                "ajax": {
                    "url": '/Property/PropertyHome/GetDocumentExpairy',
                    "type": "POST",
                    "datatype": "json"
                },
                columnDefs: [{ type: 'date', 'targets': [1] }],
                "order": [[1, "asc"]],


                "columns": [

                    { "data": "documentname", "name": "documentname" },
                    { "data": "expdate", "name": "expdate", "render": function (data) { return convertToDate(data); } },
                    { "data": "propname", "name": "propname" },
                  { "data": "purpose", "name": "purpose" },



                ]

            });





            var pTable = $('#Cheques').DataTable({
                responsive: true,
                "filter": false,
                "paging": false,
                "bInfo": false,
                "ordering": false,
                "ajax": {
                    "url": '/Property/PropertyHome/GetCheques',
                    "type": "POST",
                    "datatype": "json"
                },
                "columns": [
                    { "data": "Reference", "name": "Reference" },
                    { "data": "Purpose", "name": "Purpose" },
                    { "data": "Date", "name": "Date", "render": function (data) { return convertToDate(data); } },
                    { "data": "ChequeNo", "name": "ChequeNo" },
                    { "data": "Amount", "name": "Amount" },
                ]
            });
            var pTable = $('#ExpireCheques').DataTable({
                responsive: true,
                "filter": false,
                "paging": false,
                "bInfo": false,
                "ordering": false,
                "ajax": {
                    "url": '/Property/PropertyHome/GetExpiryCheques',
                    "type": "POST",
                    "datatype": "json"
                },
                "columns": [
                    { "data": "Reference", "name": "Reference" },
                    { "data": "Purpose", "name": "Purpose" },
                    { "data": "Date", "name": "Date", "render": function (data) { return convertToDate(data); } },
                    { "data": "ChequeNo", "name": "ChequeNo" },
                    { "data": "Amount", "name": "Amount" },
                ]
            });
            var pTable = $('#registrations').DataTable({
                responsive: true,
                "filter": false,
                "paging": false,
                "bInfo": false,
                "ordering": false,
                "ajax": {
                    "url": '/Property/PropertyHome/GetRegistrations',
                    "type": "POST",
                    "datatype": "json"
                },
                "columns": [
                    { "data": "RegistrationID", "name": "RegistrationID" },
                    { "data": "Date", "name": "Date" , "render": function (data) { return convertToDate(data); } },
                    { "data": "Property", "name": "Property" },
                    { "data": "Developer", "name": "Developer" },
                    { "data": "Broker", "name": "Broker" },
                    { "data": "Owner", "name": "Owner" },
                ]
            });

            var pTable = $('#Tenancy').DataTable({
                responsive: true,
                "filter": false,
                "paging": false,
                "bInfo": false,
                "ordering": false,
                "ajax": {
                    "url": '/Property/PropertyHome/GetTenancyContracts',
                    "type": "POST",
                    "datatype": "json"
                },
                "columns": [
                    { "data": "Id", "name": "Id" },
                    { "data": "Property", "name": "Property" },
                    { "data": "Unit", "name": "Unit" },
                    { "data": "StartDate", "name": "StartDate" },
                    { "data": "EndDate", "name": "EndDate", "render": function (data) { return convertToDate(data); }},
                    { "data": "Duration", "name": "Duration" },
                    { "data": "DueDate", "name": "DueDate" },
                ]
            });

            var pTable = $('#Maintanance').DataTable({
                responsive: true,
                "filter": false,
                "paging": false,
                "bInfo": false,
                "ordering": false,
                "ajax": {
                    "url": '/Property/PropertyHome/GetMaintenanceContracts',
                    "type": "POST",
                    "datatype": "json"
                },
                "columns": [
                    { "data": "ID", "name": "ID" },
                    { "data": "Property", "name": "Property" },
                    { "data": "Contractor", "name": "Contractor" },
                    { "data": "StartDate", "name": "StartDate" },
                    { "data": "EndDate", "name": "EndDate" },
                    { "data": "Amount", "name": "Amount" },
                ]
            });
        });


        $(function () {
            //-------------
            //- Purchase CHART -
            //-------------
            var purChartCanvas = $('#purchaseChart').get(0).getContext('2d')
            var purChart = new Chart(purChartCanvas)
            var purData = [
              {

                  value: 0,
                  color: '#d2d6de',
                  highlight: '#d2d6de',
                  label: 'Expense'
              },
              {
                  value: 0,
                  color: '#00a65a',
                  highlight: '#00a65a',
                  label: 'Income'
              }
            ]
            var purOptions = {
                //Boolean - Whether we should show a stroke on each segment
                segmentShowStroke: true,
                //String - The colour of each segment stroke
                segmentStrokeColor: '#fff',
                //Number - The width of each segment stroke
                segmentStrokeWidth: 2,
                //Number - The percentage of the chart that we cut out of the middle
                percentageInnerCutout: 50, // This is 0 for Pie charts
                //Number - Amount of animation steps
                animationSteps: 100,
                //String - Animation easing effect
                animationEasing: 'easeOutBounce',
                //Boolean - Whether we animate the rotation of the Doughnut
                animateRotate: true,
                //Boolean - Whether we animate scaling the Doughnut from the centre
                animateScale: false,
                //Boolean - whether to make the chart responsive to window resizing
                responsive: true,
                // Boolean - whether to maintain the starting aspect ratio or not when responsive, if set to false, will take up entire container
                maintainAspectRatio: true,
                //String - A legend template
                legendTemplate: '<ul class="<%=name.toLowerCase()%>-legend"><% for (var i=0; i<segments.length; i++){%><li><span style="background-color:<%=segments[i].fillColor%>"></span><%if(segments[i].label){%><%=segments[i].label%><%}%></li><%}%></ul>'
            }
            ////Create pie or douhnut chart
            //// You can switch between pie and douhnut using the method below.
            purChart.Doughnut(purData, purOptions)
            // Get context with jQuery - using jQuery's .get() method.
            var pieChartCanvas = $('#salesChart').get(0).getContext('2d')
            var pieChart = new Chart(pieChartCanvas)
            var PieData = [
              {
                  value: @Html.DisplayFor(m => m.totunitcount),
                  color: '#00c0ef',
                  highlight: '#00c0ef',
                  label: 'Units'
              },
              {
                  value: @Html.DisplayFor(m => m.totemptyunitcount),
                  color: '#3c8dbc',
