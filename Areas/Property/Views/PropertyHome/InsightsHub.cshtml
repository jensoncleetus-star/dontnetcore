@{
    ViewBag.Title = "Reports & Insights";
    ViewBag.Active = "Reports";
    var reports = new[] {
        new { ic="fa fa-file-text-o", t="Property Summary",    d="Portfolio summary",        l="/Property/PropertyReports/PropertySummery" },
        new { ic="fa fa-list-alt",    t="Property Report",     d="Consolidated listing",     l="/Property/PropertyReports/PropertyConsolidated" },
        new { ic="fa fa-money",       t="Property Based P&L",  d="P&L summary by property",  l="/MyReports/PLSummaryProperty" },
        new { ic="fa fa-file",        t="Registration",        d="Registrations report",     l="/Property/PropertyReports/PropertyRegistration" },
        new { ic="fa fa-handshake-o", t="Tenancy Contract",    d="Contracts report",         l="/Property/PropertyReports/TenancyContract" },
        new { ic="fa fa-file-text",   t="Rental Invoice",      d="Invoices report",          l="/Property/PropertyReports/RentalInvoice" },
        new { ic="fa fa-th",          t="Empty Units",         d="Vacant units report",      l="/Property/PropertyReports/EmptyUnits" },
        new { ic="fa fa-line-chart",  t="Income",              d="Income / expense report",  l="/Property/PropertyReports/Income" },
        new { ic="fa fa-percent",     t="Rate of Return",      d="ROI report",               l="/Property/PropertyReports/rateofreturn" },
        new { ic="fa fa-clock-o",     t="Document Expiry",     d="Expiring documents",       l="/Property/PropertyReports/documentexpiry" },
    };
    var fin = new[] {
        new { ic="fa fa-balance-scale", t="Property P&L",     d="Profit & loss per property", l="/Property/PropertyInsights/ProfitLoss" },
        new { ic="fa fa-area-chart",    t="Financial Trend",  d="Income vs expense over time", l="/Property/PropertyInsights/FinancialTrend" },
        new { ic="fa fa-usd",           t="Rent Collection",  d="Billed vs collected",         l="/Property/PropertyInsights/RentCollection" },
        new { ic="fa fa-book",          t="Tenant Ledger",    d="Per-tenant statement",        l="/Property/PropertyInsights/TenantLedger" },
        new { ic="fa fa-money",         t="Landlord Payout",  d="Owner disbursements",         l="/Property/PropertyInsights/LandlordPayout" },
    };
    var port = new[] {
        new { ic="fa fa-trophy",      t="Performance",      d="Portfolio ROI / yield",  l="/Property/PropertyInsights/Performance" },
        new { ic="fa fa-map-marker",  t="By Location",      d="Geographic breakdown",   l="/Property/PropertyInsights/Locations" },
        new { ic="fa fa-exchange",    t="Comparison",       d="Compare properties",     l="/Property/PropertyInsights/Comparison" },
        new { ic="fa fa-th-large",    t="Unit Insights",    d="Per-unit analytics",     l="/Property/PropertyInsights/UnitInsights" },
        new { ic="fa fa-id-card-o",   t="Property 360",     d="Single-property view",   l="/Property/PropertyInsights/Property360" },
    };
}
<div class="rfi-page">
    <div class="rfi-hero" style="background:linear-gradient(120deg,#6d28d9,#8b5cf6 55%,#a78bfa)">
        <div class="rfi-hero-l">
            <div class="rfi-hero-ic"><i class="fa fa-line-chart"></i></div>
            <div><h1>Reports &amp; Insights</h1><p>Every report and analytic in one place</p></div>
        </div>
    </div>
    <div class="rfi-card">
        <h3><i class="fa fa-file-text-o"></i> Operational Reports</h3>
        <div class="re-hub">
            @foreach (var c in reports)
            {
                <a class="re-hubcard" href="@c.l"><span class="re-hubic" style="background:linear-gradient(135deg,#475569,#64748b)"><i class="@c.ic"></i></span><span class="re-hubt">@c.t</span><span class="re-hubd">@c.d</span></a>
            }
        </div>
    </div>
    <div class="rfi-card">
        <h3><i class="fa fa-money"></i> Financial Insights</h3>
        <div class="re-hub">
            @foreach (var c in fin)
            {
                <a class="re-hubcard" href="@c.l"><span class="re-hubic" style="background:linear-gradient(135deg,#047857,#10b981)"><i class="@c.ic"></i></span><span class="re-hubt">@c.t</span><span class="re-hubd">@c.d</span></a>
            }
        </div>
    </div>
    <div class="rfi-card">
        <h3><i class="fa fa-pie-chart"></i> Portfolio Insights</h3>
        <div class="re-hub">
            @foreach (var c in port)
            {
                <a class="re-hubcard" href="@c.l"><span class="re-hubic" style="background:linear-gradient(135deg,#6d28d9,#8b5cf6)"><i class="@c.ic"></i></span><span class="re-hubt">@c.t</span><span class="re-hubd">@c.d</span></a>
            }
        </div>
    </div>
</div>
