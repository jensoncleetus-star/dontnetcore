@model QuickSoft.ViewModel.CalendarTemplateViewModel
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Edit Calendar Template</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("Edit", "CalendarTemplate", FormMethod.Post, new { id = "editform", @class = "form-horizontal" }))
    {
        <script type="text/javascript">
            $('form#editform').removeData("validator");
            $('form#editform').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#editform'));
        </script>
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        @Html.HiddenFor(m=>m.CalendarTemplateID)
        <div class="box-body">
            <div class="form-group">
                @Html.LabelFor(m => m.TemplateName, new { @class = "control-label col-sm-4" })
                <div class="col-sm-8">
                    @Html.EditorFor(model => model.TemplateName, new { htmlAttributes = new { @class = "form-control", @required = "required" } })
                </div>
            </div>
            <div class="form-group">
                @Html.LabelFor(m => m.WeeklyHoliday, new { @class = "control-label col-sm-4" })
                <div class="col-sm-8">
                    @Html.ListBoxFor(m => m.WeeklyHoliday, (MultiSelectList)ViewBag.WHoliday, new { @class = "form-control weekholi" })


