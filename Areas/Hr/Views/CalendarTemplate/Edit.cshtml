                    }, "Value", "Text"), new { @class = "form-control input-sm WHoliday", @name = "WeeklyHoliday[]", @multiple = "multiple" })*@
                </div>
            </div>

            <div class="form-group">
                <label class="control-label">
                    @Html.CheckBoxFor(m => m.DefaultValue)
                    Set As Default
                </label>
                <div class="col-sm-4">
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <button type="submit" class="btn btn-info col-sm-offset-4">Update</button>
                    <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
