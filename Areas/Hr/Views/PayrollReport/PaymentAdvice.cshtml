@{
    ViewBag.Title = "Search Payment Advice";
    ViewBag.SubTitle = "Payment Advice";
    ViewBag.Active = "PayrollReport";
}
@if (!IsPost)
{
<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">Search Payment Advice</h3>
    </div>
    <div class="box-body">
        @using (Html.BeginForm("PaymentAdvice", "PayrollReport", FormMethod.Post, new { id = "fileupload" }))
        {
            <div class="row">
                <div class="form-group col-md-4 select2-box">
                    @Html.Label("Departments", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlDepartment", (SelectList)ViewBag.AllOption, new { @class = "form-control input-sm select2" })
                </div>
                <div class="form-group col-md-4 select2-box">
                    @Html.Label("Employee", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlEmployee", (SelectList)ViewBag.AllOption, "", new { @class = "form-control input-sm select2", @required = "required" })
                </div>
                <div class="form-group col-md-4">
                    @Html.Label("Month & Year", null, new { @class = "control-label" })
                    <div class="input-group date">
                        @Html.TextBox("MonthYear", "", "{0:MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off", @required = "required" })
                        <div class="input-group-addon">
                            <i class="fa fa-calendar"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="box-footer col-md-12">
                <button type="submit" class="btn btn-info col-sm-offset-5" id="btn">Submit</button>
                <button type="button" class="btn btn-default" onclick="@("window.location.href='/Home/Index'");">Cancel</button>
            </div>
        }
    </div>
</div>
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
}
@section Scripts {
    @Scripts.Render("~/js/bootstrap-datepicker")
    <script type="text/javascript">
        $('.date').datepicker({
            format: 'MM-yyyy',
            autoclose: true,
            allowInputToggle: true,
            viewMode: "months",
            minViewMode: "months"
        });
        $(document).ready(function () {
            $("#ddlDepartment").select2({
                placeholder: 'Search by Name',
                minimumInputLength: 0,
                ajax: {
                    url: "/Department/SearchDepartment",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term || "",
                            page: params.page || 0,
                            x: "empty"
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 0;
                        return {
                            results: data,
                            pagination: {
                                more: true
                            }
                        };
                    },
                    cache: true
                },
            });
            CallEmployeeAcc();
        });
        $('body').on('change', '#ddlDepartment', function (e) {
            var deptid = $(this).val();
            if (deptid != null) {
                $('#ddlEmployee').val(null).trigger("change");
                CallEmployeeByDept(deptid);
            }
        });
    </script>
}
}
else
{
    var count = 0;
    decimal TotalAmount = 0;
    @model QuickSoft.ViewModel.PaymentAdviceViewModel
    <div class="box box-default">
        <div class="box-header with-border">
            <h3 class="box-title">Payment Advice</h3>
            <div class="pull-right">
                <button class="btn btn-success no-border" id="printthis">
                    <i class="fa fa-fw fa-print"></i> Print
                </button>
            </div>
        </div>
        <div class="box-body">
            <div class="col-md-12 pos-preview">
                <div id="invoice-POS" class="printit">
                    <center id="top">
                        @if (@ViewBag.CLogo != null)
                        {
                            <div class="logo"><img class="img-responsive" src="/uploads/company/@ViewBag.CLogo" /></div>
                        }
                        <div class="detail">
                            <h3>@ViewBag.CName</h3>
                            <h5>
                                @ViewBag.CAddress<br>
                                @if (@ViewBag.CPhone != null)
                                {
                                    <span>
                                        @ViewBag.CPhone
                                    </span>
                                    if (@ViewBag.CPMob != null)
                                    {
                                        <span> , @ViewBag.CPMob</span>
                                    }
                                    <br />

                                }
                                else
                                {
                                    if (@ViewBag.CPMob != null)
                                    {
                                        <span>@ViewBag.CPMob</span>
                                        <br />
                                    }
                                }
                                @ViewBag.CEmail<br>
                                @if (@ViewBag.CTaxRegNo != null)
                                {
                                    <span>TRN: @ViewBag.CTaxRegNo</span>
                                }
                            </h5>
                            <h5><b>Payment Advice</b></h5>
                        </div>
                    </center>
                    <h5 class="text-right">@Convert.ToString(string.Format("{0:dd-MMM-yyyy}", Model.MonthYearT))</h5>
                    <h5 class="text-left"><b>The Manager </b><br /> @Model.BankName </h5>
                    <div id="mid">

                        <h5 class="text-left">Dear Sir, </h5>
                        <h5 class="text-center Underline"><b><u> Payment Advice From @ViewBag.CName A/C @Model.CompanyAccount for period @Convert.ToString(string.Format("{0:dd-MMM-yyyy}", Model.MonthYearF)) to @Convert.ToString(string.Format("{0:dd-MMM-yyyy}", Model.MonthYearT)) </u></b></h5>
                        <h5>Please make the payroll transfer from above account number to the below mentioned account numbers towards employee salaries</h5>
                        <div class="detail">
                            <div class="row">
                                <table class="table table-bordered table-hover">
                                    <thead>
                                        <tr class="bg-gray">
                                            <th class="text-center">Sl.No</th>
                                            <th class="text-center">Employee</th>
                                            <th class="text-center">Account No.</th>
                                            <th class="text-center">Bank Name</th>
                                            <th class="text-center">Branch</th>
                                            <th class="text-center">Amount</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                           @foreach (var PA in Model.PAdvice)
                                           {
                                               count = count + 1;
                                               TotalAmount = TotalAmount + (decimal)PA.Amount;
                                            <tr>
                                                <td>@count</td>
                                                <td>@PA.EmpName</td>
                                                <td>@PA.AccountNumber</td>
                                                <td>@PA.BankName</td>
                                                <td>@PA.Branch</td>
                                                <td class="text-right">@PA.Amount</td>
                                            </tr>
                                           }
                                    </tbody>
                                    <tfoot>
                                        <tr>
                                            <td></td>
                                            <td><b>Total</b></td>
                                            <td></td>
                                            <td></td>
                                            <td></td>
                                            <td class="text-right"><b>@TotalAmount</b></td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12 form-group">
                            <table class="table table-bordered">
                                <tr>
                                    <td class="text-left" style="width:50%;">
                                        For @ViewBag.CName
                                    </td>
                                    <td>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    @section style{
        @Styles.Render("~/css/posprint")
    }
    @section Scripts {
        @Scripts.Render("~/js/printThis")
        <script type="text/javascript">
            $('#printthis').on("click", function () {
                $(".printit").printThis();
            });
            $(document).ready(function () {

            });
        </script>
    }
}