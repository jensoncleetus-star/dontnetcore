@{
    ViewBag.Title = "View Daily Attendance";
    ViewBag.SubTitle = "Daily Attendance";
    ViewBag.Active = "Payroll";
    string actData = "";
}
<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">Daily Attendance</h3>
        <p class="pull-right">
            @if (User.IsInRole("Dev") || User.IsInRole("Create DailyAttendance"))
            {
                <a href="/Hr/DailyAttendance/Create" class="btn btn-info"><i class="glyphicon glyphicon-plus"></i> Create</a>
            }
        </p>
    </div>
    <div class="box-body">
        <table class="table table-bordered table-hover" id="MyTable">
            <thead>
                <tr class="bg-gray">
                    <td data-priority="1">Employee Name</td>
                    <td data-priority="2">Month And Year</td>
                    <td data-priority="1">Action</td>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

@Html.Partial("../Common/_ModalCreate")
@Html.Partial("../Common/_ModalEdit")
@Html.Partial("../Common/_ModalDelete")
@section Scripts {
    @Scripts.Render("~/js/jqueryval")
    <script type="text/javascript">
            var oTable = $('#MyTable').DataTable({
                "processing": true, // for show progress bar
                "serverSide": true, // for process server side
                "filter": true, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
                "bStateSave": true,
                "pageLength": 50,
                responsive: true,
                "ajax": {
                    "url": '/DailyAttendance/GetDailyAttendance',
                    "type": "POST",
                    "datatype": "json"

                },
                "columnDefs": [{
                    "targets": [2],
                    "orderable": false
                }],
                "columns": [
                    { "data": "EmployeeName", "name": "EmployeeName" },
                    {
                        "data": "MonthAndYear", "name": "MonthAndYear",
                        "render": function (data) {
                            var date = convertToMonthYear(data);
                            return date.toString();
                        }
                    },
                    {
                        "name": "DailyAttendanceId", "data": function (data) {
                          var rest = "";
                              @{
                                  if (User.IsInRole("Dev") || User.IsInRole("Create DailyAttendance"))
                                  {
                                      actData += "<a href=\"/Hr/DailyAttendance/Create/'+ data.DailyAttendanceId +'\" title=\"Edit DailyAttendance\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                                  }
                                  if (User.IsInRole("Dev") || User.IsInRole("Delete DailyAttendance"))
                                  {
                                      actData += "<a class=\"modal-delete\" href=\"/Hr/DailyAttendance/Delete/'+ data.DailyAttendanceId +'\" title=\"Delete DailyAttendance\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";
                                  }
                              }
                          return rest = '@Html.Raw(actData)';
                      }
            },
                ]
            })



            /* function for Create popup */

            $('div').on('click', '.modal-create', function (e) {
                e.preventDefault();
                var url = $(this).attr('href');
                modalshow(url, '#modal-create');
            });
            $('#modal-create').on('submit', '#createform', function (e) {
                e.preventDefault();
                var url = $('#createform')[0].action;
                var data = $('#createform').serialize();
                createajax(url, data, '#modal-create');
            });


            /* function for Edit popup */

            $('div').on('click', '.modal-edit', function (e) {
                e.preventDefault();
                var url = $(this).attr('href');
                modalshow(url, '#modal-edit');
            });
            $('#modal-edit').on('submit', '#editform', function (e) {
                e.preventDefault();
                var url = $('#editform')[0].action;
                var data = $('#editform').serialize();
                createajax(url, data, '#modal-edit');
            });

            /* function for delete popup */
            $('#MyTable').on('click', '.modal-delete', function (e) {
                e.preventDefault();
                var url = $(this).attr('href');
                modalshow(url, '#modal-delete');
            });
            $('#modal-delete').on('submit', '#deleteform', function (e) {
                e.preventDefault();
                var url = $('#deleteform')[0].action;
                var data = $('#deleteform').serialize();
                createajax(url, data, '#modal-delete');
            });


    </script>
}
