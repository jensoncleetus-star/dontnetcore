@{
    ViewBag.Title = "Configuration";
    ViewBag.Active = "Configuration";
    var cards = new[] {
        new { ic="fa fa-building-o", t="Property Type",     d="Categories of property",   l="/Property/PropertyType/Index" },
        new { ic="fa fa-th-large",   t="Unit Type",         d="Categories of unit",        l="/Property/UnitType/Index" },
        new { ic="fa fa-star-o",     t="Property Feature",  d="Property amenities",        l="/Property/PropertyFeature/Index" },
        new { ic="fa fa-star",       t="Unit Feature",      d="Unit amenities",            l="/Property/UnitFeature/Index" },
        new { ic="fa fa-file-text-o",t="Contract Type",     d="Lease contract types",      l="/Property/ContractType/Index" },
        new { ic="fa fa-wrench",     t="Contractor Type",   d="Vendor categories",         l="/Property/ContractorType/Index" },
        new { ic="fa fa-files-o",    t="Document Type",     d="Document categories",       l="/Property/DocumentType/Index" },
        new { ic="fa fa-clock-o",    t="Duration",          d="Lease durations",           l="/Property/Duration/Index" },
        new { ic="fa fa-plus-square-o", t="Additional Field", d="Custom fields",          l="/Property/AdditionalField/Index" },
        new { ic="fa fa-cog",        t="Property Settings", d="Module preferences",        l="/Property/PropertySettings/Index" },
    };
}
<div class="rfi-page">
    <div class="rfi-hero" style="background:linear-gradient(120deg,#334155,#64748b 55%,#94a3b8)">
        <div class="rfi-hero-l">
            <div class="rfi-hero-ic"><i class="fa fa-cogs"></i></div>
            <div><h1>Configuration</h1><p>Set-once lookups &amp; module settings</p></div>
        </div>
    </div>
    <div class="rfi-card">
        <h3><i class="fa fa-sliders"></i> Setup Masters</h3>
        <div class="re-hub">
            @foreach (var c in cards)
            {
                <a class="re-hubcard" href="@c.l">
                    <span class="re-hubic" style="background:linear-gradient(135deg,#334155,#64748b)"><i class="@c.ic"></i></span>
                    <span class="re-hubt">@c.t</span><span class="re-hubd">@c.d</span>
                </a>
            }
        </div>
    </div>
</div>
