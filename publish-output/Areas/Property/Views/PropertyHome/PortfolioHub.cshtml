@{
    ViewBag.Title = "Portfolio & Parties";
    ViewBag.Active = "Portfolio";
    var assets = new[] {
        new { ic="fa fa-building",  t="Properties",        d="Buildings under management", l="/Property/PropertyMain/Index" },
        new { ic="fa fa-th-large",  t="Units",             d="Lettable units",             l="/Property/Unit/Index" },
        new { ic="fa fa-th",        t="Availability Board", d="Live vacant / occupied",    l="/Property/PropertyInsights/Availability" },
        new { ic="fa fa-camera",    t="Property Gallery",  d="Photos & documents",         l="/Property/PropertyInsights/Gallery" },
    };
    var parties = new[] {
        new { ic="fa fa-user-circle", t="Landlords",   d="Property owners",        l="/Property/Landlords/Index" },
        new { ic="fa fa-users",       t="Tenants",     d="Renters & occupants",    l="/Property/Tenant/Index" },
        new { ic="fa fa-industry",    t="Developers",  d="Project developers",     l="/Property/Developer/Index" },
        new { ic="fa fa-handshake-o", t="Brokers",     d="Letting agents",         l="/Property/Broker/Index" },
        new { ic="fa fa-wrench",      t="Contractors", d="Maintenance vendors",    l="/Property/Contractor/Index" },
    };
}
<div class="rfi-page">
    <div class="rfi-hero" style="background:linear-gradient(120deg,#0369a1,#0ea5e9 55%,#38bdf8)">
        <div class="rfi-hero-l">
            <div class="rfi-hero-ic"><i class="fa fa-address-book-o"></i></div>
            <div><h1>Portfolio &amp; Parties</h1><p>Your real estate and everyone you deal with</p></div>
        </div>
    </div>
    <div class="rfi-card">
        <h3><i class="fa fa-building"></i> Properties &amp; Units</h3>
        <div class="re-hub">
            @foreach (var c in assets)
            {
                <a class="re-hubcard" href="@c.l">
                    <span class="re-hubic" style="background:linear-gradient(135deg,#0369a1,#0ea5e9)"><i class="@c.ic"></i></span>
                    <span class="re-hubt">@c.t</span><span class="re-hubd">@c.d</span>
                </a>
            }
        </div>
    </div>
    <div class="rfi-card">
        <h3><i class="fa fa-users"></i> Parties</h3>
        <div class="re-hub">
            @foreach (var c in parties)
            {
                <a class="re-hubcard" href="@c.l">
                    <span class="re-hubic" style="background:linear-gradient(135deg,#0891b2,#06b6d4)"><i class="@c.ic"></i></span>
                    <span class="re-hubt">@c.t</span><span class="re-hubd">@c.d</span>
                </a>
            }
        </div>
    </div>
</div>
