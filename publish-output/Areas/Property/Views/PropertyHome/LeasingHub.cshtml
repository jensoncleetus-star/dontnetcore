@{
    ViewBag.Title = "Leasing & Operations";
    ViewBag.Active = "Leasing";
    var cards = new[] {
        new { ic="fa fa-file-text-o", t="Property Registration", d="Register a property for management", l="/Property/PropertyRegistration/Index", n="1" },
        new { ic="fa fa-handshake-o",  t="Tenancy Contract",      d="Create & manage lease agreements",   l="/Property/TenancyContract/Index", n="2" },
        new { ic="fa fa-file-o",       t="Rental Proforma",       d="Draft a rent quotation",              l="/Property/RentalProforma/Index", n="3" },
        new { ic="fa fa-file-text",    t="Rental Invoice",        d="Raise rent invoices",                 l="/Property/Rental/Index", n="4" },
        new { ic="fa fa-download",     t="Receipts",              d="Record money received",               l="/Property/PReceipt/Index", n="5" },
        new { ic="fa fa-upload",       t="Payments",              d="Record money paid out",               l="/Property/PPayment/Index", n="6" },
        new { ic="fa fa-book",         t="Journal Vouchers",      d="Manual accounting entries",           l="/Property/PJournalV/Index", n="7" },
        new { ic="fa fa-refresh",      t="Renewals & Expiry",     d="Upcoming contract renewals",          l="/Property/PropertyInsights/Renewals", n="8" },
    };
}
<div class="rfi-page">
    <div class="rfi-hero" style="background:linear-gradient(120deg,#4338ca,#6366f1 55%,#818cf8)">
        <div class="rfi-hero-l">
            <div class="rfi-hero-ic"><i class="fa fa-handshake-o"></i></div>
            <div><h1>Leasing &amp; Operations</h1><p>Your daily flow — register, lease, invoice, collect, pay</p></div>
        </div>
    </div>
    <div class="rfi-card">
        <h3><i class="fa fa-bolt"></i> Lifecycle Actions</h3>
        <div class="re-hub">
            @foreach (var c in cards)
            {
                <a class="re-hubcard" href="@c.l">
                    <span class="re-hubnum">@c.n</span>
                    <span class="re-hubic" style="background:linear-gradient(135deg,#4338ca,#6366f1)"><i class="@c.ic"></i></span>
                    <span class="re-hubt">@c.t</span>
                    <span class="re-hubd">@c.d</span>
                </a>
            }
        </div>
    </div>
</div>
