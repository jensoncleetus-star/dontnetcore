@{
    ViewBag.Title = "Maintenance";
    ViewBag.Active = "Maintenance";
    var cards = new[] {
        new { ic="fa fa-wrench",    t="Maintenance Contract", d="Log & manage maintenance jobs",  l="/Property/Maintenance/Index" },
        new { ic="fa fa-calendar",  t="Maintenance Calendar", d="Schedule & AMC visits",          l="/Property/PropertyInsights/MaintenanceCalendar" },
        new { ic="fa fa-sitemap",   t="Contractor Allocation", d="Work spread across vendors",     l="/Property/PropertyInsights/ContractorAllocation" },
        new { ic="fa fa-bell",      t="Expiry Reminders",     d="Auto email alerts",              l="/Property/PropertyInsights/Reminders" },
        new { ic="fa fa-bar-chart", t="Maintenance Report",   d="Maintenance cost report",        l="/Property/PropertyReports/Maintance" },
    };
}
<div class="rfi-page">
    <div class="rfi-hero" style="background:linear-gradient(120deg,#b45309,#f59e0b 55%,#fbbf24)">
        <div class="rfi-hero-l">
            <div class="rfi-hero-ic"><i class="fa fa-wrench"></i></div>
            <div><h1>Maintenance</h1><p>Upkeep, AMC contracts, contractors &amp; schedules</p></div>
        </div>
    </div>
    <div class="rfi-card">
        <h3><i class="fa fa-wrench"></i> Facilities Management</h3>
        <div class="re-hub">
            @foreach (var c in cards)
            {
                <a class="re-hubcard" href="@c.l">
                    <span class="re-hubic" style="background:linear-gradient(135deg,#b45309,#f59e0b)"><i class="@c.ic"></i></span>
                    <span class="re-hubt">@c.t</span><span class="re-hubd">@c.d</span>
                </a>
            }
        </div>
    </div>
</div>
