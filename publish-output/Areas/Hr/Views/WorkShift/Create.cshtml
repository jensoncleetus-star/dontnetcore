@model QuickSoft.ViewModel.WorkShiftViewModel
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Add Work Shift</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("Create", "WorkShift", FormMethod.Post, new { id = "createform" }))
    {
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        <div class="row">
            <div class="col-md-12">
                <div class="form-group">
                    @Html.LabelFor(m => m.WorkShiftName, new { @class = "control-label col-sm-4" })
                    @Html.EditorFor(model => model.WorkShiftName, new { htmlAttributes = new { @class = "form-control", @required = "required" } })
                </div>
            </div>
            <div class="form-group col-md-4">
                <div class="bootstrap-timepicker">
                    @Html.LabelFor(m => m.StartTime, new { @class = "control-label" })
                    <div class="input-group">
                        @Html.TextBoxFor(m => m.StartTime, "{0:hh:mm tt}", new { @class = "form-control timepicker", @autocomplete = "off", @value = "" })
                        <div class="input-group-addon">
                            <i class="fa fa-clock-o"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="form-group col-md-4">
                <div class="bootstrap-timepicker">
                    @Html.LabelFor(m => m.EndTime, new { @class = "control-label" })
                    <div class="input-group">
                        @Html.TextBoxFor(m => m.EndTime, "{0:hh:mm tt}", new { @class = "form-control timepicker", @autocomplete = "off", @value = "" })
                        <div class="input-group-addon">
                            <i class="fa fa-clock-o"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="form-group col-md-4">
                <div class="bootstrap-timepicker">
                    @Html.LabelFor(m => m.LateCountTime, new { @class = "control-label" })
                    <div class="input-group">
                        @Html.TextBoxFor(m => m.LateCountTime, "{0:hh:mm tt}", new { @class = "form-control timepicker", @autocomplete = "off", @value = "" })
                        <div class="input-group-addon">
                            <i class="fa fa-clock-o"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <button type="submit" class="btn btn-info col-sm-offset-4">Save</button>
                    <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
        <script>
            var date = new Date();
            date.setDate(date.getDate());
            $('.datepicker').datepicker({
                startDate: date,
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });
            jQuery.validator.methods["date"] = function (value, element) { return true; }
            $(".timepicker").timepicker({
                showInputs: true,
                defaultTime: false,
                autoclose: true,
                format: 'dd-mm-yyyy'
            });
        </script>
    }
</div>
