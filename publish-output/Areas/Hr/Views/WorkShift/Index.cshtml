@model QuickSoft.Models.WorkShift
@{
    ViewBag.Title = "List";
    ViewBag.SubTitle = "Work Shift List";
    ViewBag.Active = "Payroll Settings";
    string actData = "";
}
<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">List Work Shift</h3>
        <div class="pull-right">
            @if (User.IsInRole("Dev") || User.IsInRole("Create WorkShift"))
            {
            <i class="ace-icon fa fa-hand-o-right icon-animated-hand-pointer blue"></i>
            <a class="btn btn-info no-border modal-create" href="/Hr/WorkShift/Create">
                <i class="glyphicon glyphicon-plus"></i> Create
            </a>
            }
        </div>
    </div>
    <div class="box-body">
        <table class="table table-bordered table-hover" id="MyTable">
            <thead>
                <tr>
                    <td data-priority="1">#</td>
                    <td data-priority="2">Work Shift Name</td>
                    <td data-priority="2">Start Time</td>
                    <td data-priority="2">End Time</td>
                    <td data-priority="2">Late Count Time</td>
                    <td data-priority="5">Action</td>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>


@Html.Partial("../Common/_ModalCreate")
@Html.Partial("../Common/_ModalEdit")
@Html.Partial("../Common/_ModalChange")
@Html.Partial("../Common/_ModalDelete")
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/bootstrap-timepicker")
}
@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/bootstrap-timepicker")
    <script type="text/javascript">
        $(".timepicker").timepicker({
            showInputs: true,
            defaultTime: false,
            autoclose: true,
            format: 'dd-mm-yyyy'
        });

        var oTable = $('#MyTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "pageLength": 50,
            responsive: true,

            "ajax": {
                "url": '/WorkShift/GetWorkShift',
                "type": "POST",
                "datatype": "json"
            },
            "order": [[0, "desc"]],
            "columnDefs": [{ orderable: false, targets: -1 }],
            "columns": [
                     {
                         "data": "id", "name": "id",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                 { "data": "WorkShiftName", "name": "WorkShiftName" },
                 { "data": "StartTime", "name": "StartTime", "render": function (data) { if (data != null && data != "") { return convertToTime(data); } else { return "" } } },
                 { "data": "EndTime", "name": "EndTime", "render": function (data) { if (data != null && data != "") { return convertToTime(data); } else { return "" } } },
                 { "data": "LateCountTime", "name": "LateCountTime", "render": function (data) { if (data != null && data != "") { return convertToTime(data); } else { return "" } } },
                  {
                      "name": "id", "data": function (data) {
                          var rest = "";
                              @{
                                  if (User.IsInRole("Dev") || User.IsInRole("Edit WorkShift"))
                                  {
                                      actData += "<a class=\"modal-edit\" href=\"/Hr/WorkShift/Edit/'+ data.id +'\" title=\"Edit WorkShift\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                                  }
                                  if (User.IsInRole("Dev") || User.IsInRole("Delete WorkShift"))
                                  {
                                      actData += "<a class=\"modal-delete\" href=\"/Hr/WorkShift/Delete/'+ data.id +'\" title=\"Delete WorkShift\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";
                                  }
                              }
                          return rest = '@Html.Raw(actData)';
                      }
                  },
            ]
        });


        /* function for Create popup */

        $('div').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        });
        $('#modal-create').on('submit', '#createform', function (e) {
            e.preventDefault();
            var url = $('#createform')[0].action;
            var data = $('#createform').serialize();
            createajax(url, data, '#modal-create');
        });


        /* function for Edit popup */

        $('div').on('click', '.modal-edit', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-edit');
        });
        $('#modal-edit').on('submit', '#editform', function (e) {
            e.preventDefault();
            var url = $('#editform')[0].action;
            var data = $('#editform').serialize();
            createajax(url, data, '#modal-edit');
        });

        /* function for delete popup */
        $('#MyTable').on('click', '.modal-delete', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-delete');
        });
        $('#modal-delete').on('submit', '#deleteform', function (e) {
            e.preventDefault();
            var url = $('#deleteform')[0].action;
            var data = $('#deleteform').serialize();
            createajax(url, data, '#modal-delete');
        });

        /* chang status */
        $('.table').on('click', '.modal-change', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-change');
        });
        $('#modal-change').on('submit', '#changeform', function (e) {
            e.preventDefault();
            var url = $('#changeform')[0].action;
            var data = $('#changeform').serialize();
            createajax(url, data, '#modal-change');
        });
    </script>
}