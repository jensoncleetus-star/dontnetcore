@model QuickSoft.Models.Accounts
@{
    ViewBag.Title = "Expense Account List";
    ViewBag.SubTitle = "Payment And Receipt";
    ViewBag.Active = "Master";
    string actData = "";
    string statData = "";
}
    <div class="box box-info">
        <div class="box-header with-border">
            <h3 class="box-title">Expense Accounts</h3>
            <div class="pull-right">
            @if (User.IsInRole("Dev") || User.IsInRole("Create Expense Account"))
            {
                <i class="ace-icon fa fa-hand-o-right icon-animated-hand-pointer blue"></i>
                <a class="btn btn-info no-border modal-create" href="/master/ExpenseTypecreate">
                    <i class="glyphicon glyphicon-plus"></i> Create Expense Account
                </a>
            }
            </div>
        </div>
        <div class="box-body">
            <table class="table table-bordered table-hover" id="MyTable">
                <thead>
                    <tr>
                        <td data-priority="2">#</td>
                        <td data-priority="1">Name</td>
                        <td data-priority="2">Group</td>
                        <td data-priority="2">Note</td>
                        <td data-priority="2">Status</td>
                        <td data-priority="1"> Action</td>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>

        </div>
    </div>

@Html.Partial("../Common/_ModalCreate")
@Html.Partial("../Common/_ModalEdit")
@Html.Partial("../Common/_ModalChange")
@Html.Partial("../Common/_ModalDelete")

@section scripts{
@Scripts.Render("~/js/jqueryval")
    <script type="text/javascript">
        var oTable = $('#MyTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "pageLength": 50,
            responsive: true,
            "ajax": {
                "url": '/Master/ExpenseTypeData',
                "type": "POST",
                "datatype": "json"
            },
            "columnDefs": [{
                "targets": [5],
                "orderable": false
            }],
            "columns": [
                     {
                         "data": "id", "name": "id",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                 { "data": "Name", "name": "Name" },
                 { "data": "Group", "name": "Group" },
                 { "data": "Note", "name": "Note" },
                 {
                     "name": "Status", "data": function (data) {
                         //if (data.Status == 1) {
                         //    return '<a href="/master/ExpenseTypeStatus/' + data.id + '/active" class="modal-change" title="Click To Active" ><i class="badge bg-red" style="font-size: small" >Inactive</i></a>';
                         //}
                         //else {
                         //    return '<a href="/master/ExpenseTypeStatus/' + data.id + '/inactive" class="modal-change" title="Click To Inactive" ><i class="badge bg-green" style="font-size: small" >Active</i></a>';
                         //}
                         var rest = "";
                         if (data.Status == 1)
                         {
                             @{
                                 if (User.IsInRole("Dev") || User.IsInRole("Expense Account Status"))
                                 {
                                     statData = "<a class=\"modal-change\" href=\"/master/ExpenseTypeStatus/'+ data.id +'/active\" title=\"Click To Active\"><i class=\"badge bg-red\" >Inactive</i></a> ";
                                 }
                             }
                             rest = '@Html.Raw(statData)';
                         }
                         else
                         {
                             @{
                                 if (User.IsInRole("Dev") || User.IsInRole("Expense Account Status"))
                                 {
                                     statData = "<a class=\"modal-change\" href=\"/master/ExpenseTypeStatus/'+ data.id +'/inactive\" title=\"Click To Inactive\"><i class=\"badge bg-green\" >Active</i></a> ";
                                 }
                             }
                             rest = '@Html.Raw(statData)';
                         }

                         return rest
                     }


                 },
                 {
                     "name": "id", "data": function (data) {
                         var rest = "";
                         if (data.Editable == 0) {
                             @{
                                  if (User.IsInRole("Dev") || User.IsInRole("Edit Expense Account"))
                                  {
                                      actData += "<a class=\"modal-edit\" href=\"/master/ExpenseTypeEdit/'+ data.id +'\" title=\"Edit Expense Accounts\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                                  }
                                  if (User.IsInRole("Dev") || User.IsInRole("Delete Expense Account"))
                                  {
                                      actData += "<a class=\"modal-delete\" href=\"/master/ExpenseTypeDelete/'+ data.id +'\" title=\"Delete Expense Accounts\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";
                                  }
                              }
                             rest = '@Html.Raw(actData)'
                         }
                         return rest;
                     }
                 },

            ]
        });


        /* function for Create popup */

        $('div').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        });
        $('#modal-create').on('submit', '#createform', function (e) {
            e.preventDefault();
            var url = $('#createform')[0].action;
            var data = $('#createform').serialize();
            createajax(url, data, '#modal-create');
        });


        /* function for Edit popup */

        $('div').on('click', '.modal-edit', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-edit');
        });
        $('#modal-edit').on('submit', '#editform', function (e) {
            e.preventDefault();
            var url = $('#editform')[0].action;
            var data = $('#editform').serialize();
            createajax(url, data, '#modal-edit');
        });

        /* function for delete popup */
        $('#MyTable').on('click', '.modal-delete', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-delete');
        });
        $('#modal-delete').on('submit', '#deleteform', function (e) {
            e.preventDefault();
            var url = $('#deleteform')[0].action;
            var data = $('#deleteform').serialize();
            createajax(url, data, '#modal-delete');
        });

        /* chang status */
        $('.table').on('click', '.modal-change', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-change');
        });
        $('#modal-change').on('submit', '#changeform', function (e) {
            e.preventDefault();
            var url = $('#changeform')[0].action;
            var data = $('#changeform').serialize();
            createajax(url, data, '#modal-change');
        });

        $('#modal-create').on('shown.bs.modal', function (e) {
            GetBranch();
        });

        $('#modal-edit').on('shown.bs.modal', function (e) {
            GetBranch();
        });
    </script>
}