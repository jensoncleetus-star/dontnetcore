            $('#advsearch').toggle();
            if ($('#srch').hasClass('btn-primary')) {

                $('#srch').addClass('btn-danger');
                $('#srch').removeClass('btn-primary');
            }
            else if ($('#srch').hasClass('btn-danger')) {
                $('#srch').addClass('btn-primary');
                $('#srch').removeClass('btn-danger');

                $('#BillNo').val("");
                $('#FromDate').val("");
                $('#ToDate').val("");
                $('#ddlCustomer').val(0);
                $('#ddlEmployee').val(0);
                $('#ddlProject').val(null);
                $('#Status').val("");
                $('#ddlCreatedBy').val("");
                $('#Validity').val("");
                $('#SaleType').val(null);
                $('#HireType').val(null);
                oTable.draw();
            }

            $('#FromDate').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });
