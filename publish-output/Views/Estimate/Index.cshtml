                                 status = '<span class="badge bg-red">Rejected</span>';
                             }
                             else if (data.ApprovalStatus == "2") {
                                 status = '<span class="badge bg-orange">Pending</span>';
                             }
                             return '<a  class="Updation" onclick="details(' + data.QuotationId + ')"  title="View Status">' + status + ' </a>';
                         } else { return null; }
                     }
                 },
                     {"name": "EstimateId", "data": function (data) {

                        var rest = "";
                        @{
                            string bosEstPrint = "";
                            if (User.IsInRole("Dev") || User.IsInRole("Invoice Template"))
                            {
                                bosEstPrint = "<a href=\"/InvoiceTemplate/Print?invoiceId='+ data.EstimateId +'&docType=Estimate\" target=\"_blank\" title=\"Print with a custom template\"><i class=\"fa fa-lg fa-print\" style=\"color:#6366f1\"></i></a> ";
                            }
                        }
                        rest += '@Html.Raw(bosEstPrint)';
                        @{

                            if (User.IsInRole("Dev") || User.IsInRole("Edit Quotation"))
                            {
                                actData += "<a href=\"/Estimate/Edit/'+ data.EstimateId +'\" title=\"Edit Estimate\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                            }
                            if (User.IsInRole("Dev") || User.IsInRole("Delete Quotation"))
                            {
                                actData += "<a class=\"modal-delete\" href=\"/Estimate/Delete/'+ data.EstimateId +'\" title=\"Delete Estimate\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";
                            }


                            //if (User.IsInRole("Dev") || User.IsInRole("Sales Entry"))
                            //{
                            //    actData += "<a href=\"/CreditSale/Create/'+ data.EstimateId +'/Quote\" title=\"Convert To Sales\"><i class=\"fa-lg fa fa-exchange\" ></i></a> ";
                            //}
                            //if (User.IsInRole("Dev") || User.IsInRole("Pro Forma Entry"))
                            //{
                            //    actData += "<a href=\"/ProForma/Create/'+ data.EstimateId +'/Quote\" title=\"Convert To Pro Forma\"><i class=\"fa-lg fa fa-arrows-h\" ></i></a> ";
                            //}
                            //if (User.IsInRole("Dev") || User.IsInRole("Deliverynote Entry"))
                            //{
                            //    actData += "<a href=\"/Deliverynote/Create/'+ data.EstimateId +'/Quote\" title=\"Convert To Deliverynote\"><i class=\"fa-lg fa fa-refresh\" ></i></a> ";
                            //}
                            //  if (User.IsInRole("Dev") || User.IsInRole("Create Project"))
                            // {
                            //     actData += "<a href=\"/Project/Create/'+ data +'\" title=\"Convert To Project\"><i class=\"fa-lg fa fa-recycle\" ></i></a> ";
                            // }

                         }

                        rest += '@Html.Raw(actData)';
                        if (data.Approval == true) {
                            @{
