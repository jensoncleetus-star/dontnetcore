@model QuickSoft.Models.QuotationType
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Quotation Types</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("Create", "QuotationType", FormMethod.Post, new { id = "createform" }))
    {
        <script type="text/javascript">
            $('form#createform').removeData("validator");
            $('form#createform').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#createform'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        <div class="row">
            <div class="col-md-12">
                <div class="form-group">
                    @Html.Label("Quotation Types", null, htmlAttributes: new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.QuotType, new { htmlAttributes = new { @class = "form-control", autofocus = "autofocus", @placeholder = "Enter Quotation Types", @required = "required" } })

                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" value="Save" class="btn btn-info col-sm-offset-4" />
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>
@section scripts{
    @Scripts.Render("~/js/jqueryval")
}

