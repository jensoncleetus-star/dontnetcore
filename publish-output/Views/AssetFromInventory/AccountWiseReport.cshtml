        function customertype() {
            var type = $("#ddlType").val();
            if (type == 0) {
                $('#divpaymethod').hide();
            } else {
                $('#divpaymethod').show();
            }
        }


        function HType() {
            var Type = $('#SaleType').val();
            if (Type == 2) {
                $('#HireTypeDiv').show();
            }
            else {
                $('#HireTypeDiv').hide();
            }
        }
        function DateSet() {
            var ndate = $('#FromDate').val();

            $('#ToDate').datepicker({
                startDate: ndate,
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });

        }




