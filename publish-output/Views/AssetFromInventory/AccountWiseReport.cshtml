@{

    ViewBag.Title = "Search Account Wise";
    ViewBag.SubTitle = "Asset Report";
    ViewBag.Active = "Reports";
    string actData = "";
}
<style>
    #ddlType, #InvoiceNo {
        margin-bottom: -4px !important;
    }
</style>
<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">Search AccountWise Asset</h3>
    </div>
    <div class="box-body">
        <form id="search-form">
            @using (Html.BeginForm("AccountWiseReport", "AssetFromInventory", FormMethod.Post, new { id = "popupForm", target = "_new" }))
            {
                @*<div class="form-group col-md-3" id="creditsale">
                @Html.Label("Item Name/Code", null, new { @class = "control-label" })
                @Html.ListBox("ddlItem", (SelectList)ViewBag.Item, new { @class = "form-control input-sm select2", @multiple = "multiple", @name = "ddlItem[]", @required = "required" })
            </div>*@
                <div class="form-group col-md-3">
                    @Html.Label("Asset Account", null, new { @class = "control-label" })
                    @Html.DropDownList("AssetAccount", (SelectList)ViewBag.AssetAccount, new { @class = "form-control input-sm", @required = "required" })
                </div>
                <div class="form-group col-md-3">
                    @Html.Label("From", null, new { @class = "control-label" })
                    <div class="input-group date">
                        @Html.TextBox("From", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                        <div class="input-group-addon">
                            <i class="fa fa-calendar"></i>
                        </div>
                    </div>
                </div>
                <div class="form-group col-md-3">
                    @Html.Label("To", null, new { @class = "control-label" })
                    <div class="input-group date">
                        @Html.TextBox("To", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                        <div class="input-group-addon">
                            <i class="fa fa-calendar"></i>
                        </div>
                    </div>
                </div>
                <div class="form-group col-md-3 col-xs-6">
                    @Html.Label("Material Center", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlMC", (SelectList)ViewBag.MC, new { @class = "form-control input-sm select2" })
                </div>
                <div class="box-footer col-md-12">
                    <input type="submit" class="btn btn-info col-sm-offset-5" value="Submit" />
                    <button type="button" class="btn btn-default" onclick="@("window.location.href='/Home/Index'");">Cancel</button>
                    <input type="hidden" value="@ViewBag.StartDate" class="Start" name="Start" id="Start">
                    <input type="hidden" value="@ViewBag.EndDate" class="End" name="End" id="End">
                </div>
            }
        </form>
    </div>
</div>
<div class="box box-default" id="StockReport">
    <div class="box-header with-border">
        <h3 class="box-title">View AccountWise</h3>
    </div>
    <div class="box-body">
        <input type="hidden" id="cname" value="@ViewBag.CName" />
        <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
        <input type="hidden" id="invoiceno" value="@ViewBag.InvoiceNo" />
        <input type="hidden" id="fromdate" value="@ViewBag.fromdate" />
        <input type="hidden" id="todate" value="@ViewBag.todate" />
        <input type="hidden" id="matcenter" value="@ViewBag.EnableMCcheck" />
        <input type="hidden" id="Scaffold" value="@ViewBag.BusinessType" />
        <div class="box-body">
            <table class="display table table-bordered" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="2">S/N</td>
                        <td data-priority="2">Bill No</td>
                        <td data-priority="2">Item</td>
                        <td data-priority="2">Asset Entry Date</td>

                        @*<td data-priority="3">Pay Method</td>*@
                        <td data-priority="2">Quantity</td>
                        <td data-priority="1">Price</td>
                        <td data-priority="1">Total Price</td>
                        @*<td>TRN</td>*@
                        @*<td data-priority="2">Item Amt</td>*@
                        @*<td data-priority="1" class="headeralign">Total Amt</td>
        <td class="headeralign">Paid Amt</td>
        <td class="headeralign">Balance Amt</td>*@
                        @*<td data-priority="3">Last Paid Date</td>*@
                        @*<td data-priority="1">AssetAccount</td>*@
                        @*<td id="SaleTy">SaleType</td>*@
                        @*<td>Created By</td>*@
                        @*<td>Branch</td>*@
                    </tr>
                </thead>
                <tbody></tbody>
                <tfoot>
                    <tr>
                        <th>Total:</th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        @*<th></th>*@

                        @*<th></th>*@
                        @*<th></th>
        <th></th>
        <th></th>*@

                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
}
