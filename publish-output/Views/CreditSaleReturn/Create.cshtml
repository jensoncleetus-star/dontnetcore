@section style{
    @Styles.Render("~/css/bootstrap-fileinput")
    @Styles.Render("~/css/bootstrap-fileinput-rtl")
    @Styles.Render("~/css/bootstrap-datepicker")
    @*@Styles.Render("~/css/print")*@
    @if (ViewBag.POS != 0)
    {
        @Styles.Render("~/css/print")}

}
@section scripts{
    @Scripts.Render("~/js/JsBarcode")
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/bootstrap-fileinput")
    <script src="~/Content/js/saleinvoiceold.js"></script>
    @*<script src="~/Content/js/salesinvoice2.js"></script>*@
    @Scripts.Render("~/js/num2words")
    <script type="text/javascript">
        var minDate = $("#Start").val();
        var maxDate = $("#End").val();
        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true,
            startDate: new Date(minDate),
            endDate: new Date(maxDate)
        });

        jQuery.validator.methods["date"] = function (value, element) { return true; }
    $(".ref").select2({
        tags: true
    });
        $(document).ready(function () {
           $("#input-24").fileinput({
                maxFilePreviewSize: 10240,
                autoReplace: true,
                maxFileCount: 10,
                showUploadedThumbs: true,
                showUpload: false,
                overwriteInitial: false,
                initialPreviewAsData: true,
                initialPreviewFileType: 'image',
                allowedFileExtensions: ["dwg ", "xlsx", "gif", "jpg", "png", "jfif", "jpeg", "doc", "docx", "pdf", "dwg", "pptx", "vsdx",
                    'M4A', 'FLAC', 'MP3', 'MP4', 'WAV', 'WMA', 'AAC', 'ogg', 'opus', 'mpg', 'mpeg'],
                fileActionSettings: {
                    showUpload: false,
                },
            }).on('filesorted', function (e, params) {
                console.log('File sorted params', params);
            }).on('fileuploaded', function (e, params) {
                console.log('File uploaded params', params);
            });

          //  $("#ReturnType").find('[value="1"]').remove()
            addrow('addinvoiceItem', 'quot', "", "0.00", "0.00", "0");
            addbillsundry('addbillsundry', '', '0.00', '', '0.00', '');
            searchItem();
            //Item Category
            ItemCategory();
            ItemBrand();
            GetBranch();
            //ItemTax();
            //ItemUnit();
            //ItemSubUnit();

            //bind to employee
            CallEmployee();
            CallMCUser();
            CallProject();
            CallTask();
            CallApprovedBy();

            $("#ddlMC").prop('selectedIndex', 0);
            $("#CustomerType").prop('selectedIndex', 0);
            $('#CustomerType option:contains(Card)').remove();
            CallCustomer();
            VatVoucherWise();

            $('#SaleType option:contains(POS)').remove();
            $('#SalesType').select2();;
            if ('@ViewBag.BusinessType' == "Scaffold") {
                $('#SaleType').select2();
            }
            SaleHireEntry(1);
            //$(".ref").select2({
            //    tags: true
            //});
        });

        /* function for Create popup */

        $('span').on('click', '.modal-create', function (e) {
            e.preventDefault();
            $(this).attr('data-target', '#modal-create');
            $(this).attr('data-toggle', 'modal');
        });
        $('#modal-create').on('submit', '#createform', function (e) {
            e.preventDefault();
            var url = $('#createform')[0].action;
            var data = $('#createform').serialize();
            createajax(url, data, '#modal-create');
        });


        $('span').on('click', '.modal-edit', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-edit');
        });
        $('#modal-edit').on('submit', '#editform', function (e) {
            e.preventDefault();
            var url = $('#editform')[0].action;
            var data = $('#editform').serialize();
            createajax(url, data, '#modal-edit');
        });
        $('span').on('click', '.modal-project', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-project');
        });

        $('body').on('change', '#ddlMC', function (e) {
            var mcval = $(this).val();
            searchItem();
        });

        $('body').on('change', '#ddlCustomer', function (e) {
            $('#ddlProject').val(null).trigger('change');
            CallProject();
            var CustId = $('#ddlCustomer').val();
            CustId = $(this).val();


            if (CustId != null) {

                //Calling function to retrieve PMaintenance details based on AmcID
                $.ajax({
                    url: '/CreditSale/GetFillDetails',
                    dataType: 'json',
                    data: { CustId: CustId },
                    cache: true,
                    success: function (data) {
                        var opt = '<option value="' + data[0].ddlEmployee + '" selected>' + data[0].ddlEmployee + '</option>'


                        $("#ddlEmployee").append(opt);
                        $("#ddlEmployee").val(data[0].ddlEmployee);
                        CallEmployee();
                    }
                });
            }







        });
        $('body').on('change', '#ddlProject', function (e) {
            $('#ddlProTask').val(null).trigger('change');
            CallTask();
        });
        function sreturntype() {
            var rettype = $('#ReturnType').val();
