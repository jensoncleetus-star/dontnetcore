                    if (User.IsInRole("Dev") || User.IsInRole("Edit Sales Return"))
                    {
                        <a class="btn bg-black no-border" href="/CreditSaleReturn/Edit/@ViewBag.LastEntry">
                            <i class="fa fa-step-backward"></i>
                        </a>}
                }
                @if (User.IsInRole("Dev") || User.IsInRole("Sales Return List"))
                {
                    <a class="btn btn-success no-border" href="/CreditSaleReturn">
                        <i class="fa fa-fw fa-history"></i> List
                    </a>}
            </div>
        </div>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        <div class="box-body">
            <input type="hidden" id="ROnlyRate" value="@IRateCheck" />
            <input type="hidden" id="SelApprovedBy" />
            <input type="hidden" id="VoucherType" value="SalesReturn" />
