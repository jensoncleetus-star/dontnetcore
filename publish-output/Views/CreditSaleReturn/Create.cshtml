                            @Html.Label("Return Amount:", null, new { @class = "control-label" })
                            @Html.EditorFor(model => model.SReturnAmount, new { htmlAttributes = new { @id = "PaidAmount", @onchange = "paidamount_change();", @class = "form-control text-right", @value = "0", @placeholder = "0.00" } })

                        </div>
