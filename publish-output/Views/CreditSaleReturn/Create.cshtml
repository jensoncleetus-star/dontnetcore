@model QuickSoft.ViewModel.SalesReturnViewModel
@{ ViewBag.Title = "Create";
    ViewBag.SubTitle = "Sales Return";
    ViewBag.Active = "Transactions";
    var TimeOut = @ViewBag.TMOut;
    string IRateCheck = "inactive";
    string posfun = ""; }
<style>
    .date {
        height: 34px !important;
    }

    .sh-btn {
        background-color: red;
        color: white;
        border-radius: 5px !important;
        border: none;
        padding: 4px 8px 4px 8px;
    }
</style>
@if (User.IsInRole("Dev") || User.IsInRole("ReadOnly Item Rate"))
{
    IRateCheck = "active";
}
<input type="hidden" id="SuperUserEdit" value="@ViewBag.SuperUserEditvalue" />
@using (Html.BeginForm("CreateSalesReturn", "CreditSaleReturn", FormMethod.Post, new { id = "saleform", role = "form" }))
{
    <div class="box box-info">
        <div class="box-header with-border">
            <h3 class="box-title">Create Sales Return</h3>
