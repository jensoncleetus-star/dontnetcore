@model QuickSoft.ViewModel.TaxViewModel
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Add Tax Group</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("GroupCreate", "Tax", FormMethod.Post, new { id = "createform" }))
            {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        <div class="row">
            <div class="col-md-12">
                <div class="form-group  col-md-12">

                    @Html.Label("Tax Name", null, new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.TaxName, new { htmlAttributes = new { @class = "form-control input-sm", autofocus = "autofocus" } })
                </div>
                <div class="form-group  col-md-12">
                    @Html.Label("Sub Taxs", null, new { @class = "control-label" }) *
                    @Html.DropDownListFor(m => m.child, (SelectList)ViewBag.ParentModules, new {@id="TaxSubGroup", @class = "form-control select2", @name = "TaxSubGroup[]", @multiple = "multiple" })
                  </div>
                <div class="form-group  col-md-12">
                    @Html.Label("Percentage", null, new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.Percentage, new { htmlAttributes = new { @class = "form-control input-sm", autofocus = "autofocus", @readonly = "readonly" } })
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" value="Save" class="btn btn-info col-sm-offset-4"/>
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>

