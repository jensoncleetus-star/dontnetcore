@model QuickSoft.ViewModel.RolesViewModel
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Edit Role</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("RolesEdit", "Users", FormMethod.Post, new { id = "popupFormRoles" }))
    {
        <script type="text/javascript">
            $('form#popupFormBranch').removeData("validator");
            $('form#popupFormBranch').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#popupFormBranch'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        @Html.HiddenFor(model => model.Id)

        <div class="row">
            <div class="col-md-12">
                <div class="col-md-2">
                    <div class="form-group">
                        @Html.Label("Roles", null, new { @class = "control-label" }) *
                    </div>
                </div>
                <div class="col-md-10">
                    <div class="form-group">
                        @Html.EditorFor(model => model.Name, new { htmlAttributes = new { @class = "form-control input-sm", tabindex = 1, autofocus = "autofocus" } })
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" class="btn btn-info col-sm-offset-5" value="Update" id="btnSubmit" />
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>

