@model QuickSoft.ViewModel.permissioncopy
@{
    ViewBag.Title = "Permision Copy";
    ViewBag.SubTitle = "User";
    ViewBag.Active = "Users";
}
<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">Permission Copy</h3>
        <div class="pull-right">
            @if (User.IsInRole("Dev") || User.IsInRole("User List"))
            {
                <a class="btn btn-success no-border" href="/Users/Index">
                    <i class="fa fa-fw fa-history"></i> Users List
                </a>
            }
        </div>
    </div>
    @* Absolute action + suffix-stripped name: the page is reached via the "calendar/{controller}/{action}"
       route, so Html.BeginForm reused that ambient prefix and targeted the non-existent "copypermissionAsync"
       action (ASP.NET Core strips the Async suffix), producing /calendar/Users/copypermissionAsync -> 404. *@
    <form action="/Users/copypermission" method="post" id="UserCreateForm" role="form" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        @Html.ValidationSummary("", new { @class = "alert alert-danger" })


<div class="box-body">
    <div class="row">
        <div class="form-group col-md-4" id="Employee1">
            @Html.Label("Copy From", null, htmlAttributes: new { @class = "control-label " })
            @Html.DropDownListFor(m => m.emp1, (SelectList)ViewBag.emp1, "Select User 1", new { @class = "form-control select2" })
        </div>
        <div class="form-group col-md-8" id="Employee1">
            @Html.Label("Copy To", null, htmlAttributes: new { @class = "control-label " })
            @Html.ListBoxFor(m => m.emp2, (SelectList)ViewBag.emp2, new { @class = "form-control select2" })
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <input type="submit" class="btn btn-info col-sm-offset-5" value="Save" id="btnSubmit" />
            <input type="button" class="btn btn-default" value="Cancel" onclick="window.location.href='/Users/copypermission';" />
        </div>
        </div>
    </div>

    </form>
</div>
@section Scripts {
    @Scripts.Render("~/js/jqueryval")
    <script type="text/javascript">
        $(document).ready(function () {
            $("#emp2").select2({});
            $("#emp1").select2({});
        })

    </script>
}