@model QuickSoft.ViewModel.JobCardViewModel
@{
    Layout = null;
}
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>JobCard Details</h4>
</div>
<div class="modal-body">
    <div class="box box-info">
        <div class="box-body">
            <div class="row">
                <div class="col-sm-2 form-group ">
                    @Html.Label("JobCard No :", null, new { @class = "control-label" })
                    @Html.DisplayFor(m => m.JobCardNo)
                </div>
                <div class="col-sm-2 form-group">
                    @Html.Label("Date :", null, new { @class = "control-label" })
                    @Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.JobCDate))
                </div>
                <div class="col-sm-2 form-group">
                    @Html.Label("Customer  :", null, new { @class = "control-label" })
                    @Html.DisplayFor(m => m.CustName)
                </div>
                <div class="col-sm-2 form-group">
                    @Html.Label("Mechanic :", null, new { @class = "control-label" })
                    @Html.DisplayFor(m => m.MechName)
                </div>
                <div class="col-sm-2 form-group">
                    @Html.Label("Received By :", null, new { @class = "control-label" })
                    @Html.DisplayFor(m => m.RecName)
                </div>
                <div class="col-sm-2 form-group">
                    @Html.Label("PWC Model :", null, new { @class = "control-label" })
                    @Html.DisplayFor(m => m.PWCModel)
                </div>
                @if (Model.FieldMap.Count > 0)
                {
                    for (int i = 0; i < Model.FieldMap.Count; i++)
                    {
                        <div class="form-group col-sm-2">

                            @if (Model.FieldMap[i].FieldName != "" && Model.FieldMap[i].Field == "Ref1")
                            {
                                <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName :</label>
                                @Html.DisplayFor(m => m.Ref1)
                            }
                            @if (Model.FieldMap[i].FieldName != "" && Model.FieldMap[i].Field == "Ref2")
                            {
                                <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName :</label>
                                @Html.DisplayFor(m => m.Ref2)
                            }
                            @if (Model.FieldMap[i].FieldName != "" && Model.FieldMap[i].Field == "Ref3")
                            {
                                <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName :</label>
                                @Html.DisplayFor(m => m.Ref3)
                            }
                            @if (Model.FieldMap[i].FieldName != "" && Model.FieldMap[i].Field == "Ref4")
                            {
                                <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName :</label>
                                @Html.DisplayFor(m => m.Ref4)
                            }
                            @if (Model.FieldMap[i].FieldName != "" && Model.FieldMap[i].Field == "Ref5")
                            {
                                <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName :</label>
                                @Html.DisplayFor(m => m.Ref5)
                            }
                        </div>
                    }
                }
                <div class="clearfix"></div>
            </div>
            <div>
                <div class="table-responsive">
                        <div class="box-header with-border">
                            <h3 class="box-title">Labour/Parts</h3>
                        </div>
                        <div class="box-body">
                            <table class="table table-bordered table-hover">
                                <tr class="bg-gray">
                                    <th>Labour/Parts</th>
                                    <th>Amount</th>
                                </tr>
                                @foreach (var salesum in Model.JCItem)
                                {
                                    <tr>
                                        <td>@salesum.ItemCode - @salesum.ItemName))</td>
                                        <td>@salesum.ItemTotalAmount</td>
                                    </tr>
                                }
                                <tr>
                                    <td>Total</td>
                                    <td>@Html.DisplayFor(m => m.TotalAmount)</td>
                                </tr>
                            </table>
                        </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <strong>PWC Details </strong><br />
                            @Html.Raw(Model.Details)
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

