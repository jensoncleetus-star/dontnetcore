@model QuickSoft.Models.Accounts
@{
    ViewBag.Title = "List";
    ViewBag.SubTitle = "Accounts";
    ViewBag.Active = "Master";
    string statData = "";
    string action = "";
    string actData = "";
    bool userRole = false;
    string delchk = "";
    string deleteBTn = "";
    if (User.IsInRole("Dev") || User.IsInRole("Delete Account"))
    {
        userRole = true;
        deleteBTn = "{text: 'Delete', className: 'btn-danger', action: function(e, dt, node, config) {" +
             "if ($('.checkbox:checked').length > 0) {if (confirm('Are you sure you want to delete this?')) {$('#payform').submit(); e.preventDefault();} " +
              "} else {alert('Please Select Rows..!!');e.preventDefault();}}},";
    }
}
<style type="text/css">

    .dropdown-check-list {
        display: inline-block;
    }

        .dropdown-check-list .anchor {
            position: relative;
            cursor: pointer;
            display: inline-block;
            padding: 5px 50px 5px 10px;
            border: 1px solid #ccc;
            width: 150px;
            background: #fff;
            text-align: center;
        }

            .dropdown-check-list .anchor:after {
                position: absolute;
                content: "";
                border-left: 2px solid black;
                border-top: 2px solid black;
                padding: 5px;
                right: 10px;
                top: 20%;
                -moz-transform: rotate(-135deg);
                -ms-transform: rotate(-135deg);
                -o-transform: rotate(-135deg);
                -webkit-transform: rotate(-135deg);
                transform: rotate(-135deg);
            }

            .dropdown-check-list .anchor:active:after {
                right: 8px;
                top: 21%;
            }

        .dropdown-check-list ul.items {
            padding: 0px;
            display: none;
            margin: 0;
            border: 1px solid #ccc;
            border-top: none;
            position: absolute;
            z-index: 9999;
        }

            .dropdown-check-list ul.items li {
                list-style: none;
                background: #fff;
                padding: 5px;
            }

    .add-btn-item {
        border-radius: 23px;
        padding: 6px 20px;
    }

    .dropdown-check-list.visible .anchor {
        color: #0094ff;
    }

    .dropdown-check-list.visible .items {
        display: block;
    }
</style>
<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">Accounts</h3>
        <div class="pull-right">
            <span>
                <a class="btn btn-warning no-border modal-gen" href="/Accounts/Tree">
                    <i class="glyphicon glyphicon-list"></i> Chart Of Accounts
                </a>
            </span>
            <span>
                @if (User.IsInRole("Dev") || User.IsInRole("Create Expense Account"))
                {
                    <a class="btn btn-info no-border modal-create" href="/Accounts/Create">
                        <i class="glyphicon glyphicon-plus"></i> Create
                    </a>
                    <a class="btn btn-info no-border " href="/SharedAccount/Index" target="_new">
                        <i class="glyphicon glyphicon-plus"></i> Shared Accounts
                    </a>
                }
            </span>
        </div>
    </div>
    <div class="row">
        <div class="text-center note-msg" style=""> NB : Listing Exclude Customer,Supplier & Bank Accounts </div>
        <div class="col-md-2">
            <div id="list1" class="dropdown-check-list" tabindex="100">
                <span class="anchor" style="z-index:0;">Select Fields</span>
                <ul class="items">
                    <li><input type="checkbox" id="liaccntname" />Account Name</li>
                    <li><input type="checkbox" id="lialias" />Alias</li>
                    <li><input type="checkbox" id="liaccntgroup" />Account Group</li>
                    <li><input type="checkbox" id="listatus" checked />Active/InActive</li>
                    <li><input type="checkbox" id="liTRN" />TRN</li>
                </ul>
            </div>
        </div>

        <div class="col-md-12">
            <div class="box-body search-box" id="advsearchlist">
                <div class="search-body col-md-12" style="background:none;">
                    <form id="search-form">
                        <div class="row">
                            
                            <div class="form-group col-md-2" id="searchaccntname">
                                @Html.Label("Account Name", null, new { @class = "control-label" })
                                @Html.DropDownList("ddlAccounts", (SelectList)ViewBag.Accs, new { @class = "form-control" })
                            </div>
                            <div class="form-group col-md-2" id="searchalias">
                                @Html.Label("Customer Alias", null, new { @class = "control-label" })
                                @Html.TextBox("Alias", "", new { @class = "form-control input-sm" })
                            </div>
                            <div class="form-group col-md-2" id="searchaccntgroup">
                                @Html.Label("Account Group", null, new { @class = "control-label" })
                                @Html.DropDownList("AccGroup", (SelectList)ViewBag.AccntGp, new { @class = "form-control" })
                            </div>
                            <div class="form-group col-md-2" id="searchstatus">
                                @Html.Label("Active/InActive", null, new { @class = "control-label" })
                                @Html.DropDownList("Status", (SelectList)ViewBag.ItStatus, new { @class = "form-control" })
                            </div>
                            <div class="form-group col-md-2" id="searchTRNno">
                                @Html.Label("TRN", null, new { @class = "control-label" })
                                @Html.DropDownList("TRNNo", (SelectList)ViewBag.TRN, "All", new { @class = "form-control" })
                            </div>
                            <div class="form-group col-md-2">
                                @*<input type="submit" class="btn btn-submit" value="Submit" />*@
                                <button type="submit" id="save" class="btn btn-success">
                                    <span class="glyphicon glyphicon-floppy-disk"></span> Save
                                </button>
                            </div>
                            <div class="form-group col-md-2" id="close">
                                <input type="button" class="btn btn-close" value="Close" />
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <div class=" col-md-2" id="searchpagelength">

        <span class="sh-spaan-text-style">Show &nbsp;</span>@Html.DropDownList("ddlPagesize", new SelectList(new List<SelectListItem>
{
new SelectListItem() {Text = "50 Rows", Value="50"},
new SelectListItem() {Text = "All Rows", Value="10000000"},

}, "Value", "Text"), new { @class = "sh-input-drop select2" })

    </div>
    @using (Html.BeginForm("DeleteAll", "Accounts", FormMethod.Post, new { id = "payform", role = "form" }))
    {
        <div class="box-body">
            <table class="table table-bordered table-hover" id="MyTable">
                <thead>
                    <tr>
                        <td data-priority="1">S/N</td>
                        <td data-priority="2">Account Name</td>
                        <td data-priority="2">Group</td>
                        <td data-priority="2">Opening Balance</td>
                        <td data-priority="2">Current Balance</td>
                        <td data-priority="6">Note</td>
                        <td data-priority="2">TRN</td>
                        <td data-priority="2">Status</td>
                        <td data-priority="3"> Action</td>
                        <td data-priority="2"><input type="checkbox" id="select_all" /></td>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
        @*if (User.IsInRole("Dev") || User.IsInRole("Delete Expense Account"))
            {
                <div class="box-footer text-right col-md-12" id="sub">
                    <button type="submit" id="save" data-confirm="Are u sure want to delete?" class="btn btn-danger">Delete</button>
                </div>
            }*@
    }
</div>
@{var Model = "modal-lg";}

@Html.Partial("../Common/_ModalCreate")
@Html.Partial("../Common/_ModalEdit")
@Html.Partial("../Common/_ModalChange")
@Html.Partial("../Common/_ModalDelete")
@Html.Partial("../Common/_ModalGen")
@section style{
    @Styles.Render("~/css/jstree")
}
@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/jstree")
    <script type="text/javascript">

        $(document).ready(function () {
            $('#TRNNo').select2();
            $('#advsearchlist').show();
     
            $("#searchstatus").show();
            $("#searchaccntgroup").hide();
            $("#searchalias").hide();
            $("#searchaccntname").hide();
            $("#searchTRNno").hide();
            _show = 1;
           

        });
            var oTable = $('#MyTable').DataTable({
                "processing": true, // for show progress bar
                "serverSide": true, // for process server side
                "filter": true, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
                "bStateSave": true,
                "pageLength": 50,
                responsive: true,
                "ajax": {
                    "url": '/Accounts/GetData',
                    "data": function (data) {
                        data.ddlAccounts = $('#ddlAccounts').val();
                        data.AccGroup = $('#AccGroup').val();
                        data.Stats = $('#Status').val();
                        data.TRN = $('#TRNNo').val();
                        data.Alias = $('#Alias').val();
                    },
                    "type": "POST",
                    "datatype": "json"
                },
                "order": [[0, "desc"]],
                
                "columns": [
                         {
                             "data": "id", "name": "id",
                             "render": function (data, type, row, meta) {
                                 return meta.row + meta.settings._iDisplayStart + 1;
                             }
                         },
                     { "data": "Name", "name": "Name" },
                     { "data": "Group", "name": "Group" },
                    { "data": "balance", "name": "balance", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                      {
                          "data": function (data) {
                              var CurBalance;
                              CurBalance = (data.Debit > data.Credit) ? ((data.Debit - data.Credit).toFixed(2) + " Dr") : ((data.Credit - data.Debit).toFixed(2) + " Cr.");
                              return CurBalance;
                          }, render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright"
                      },
                     { "data": "Note", "name": "Note" },

                     { "data": "TRN", "name": "TRN" },
                     {
                         "name": "Editable", "data": function (data) {
                             if (data.Editable == 0) {
                                 var rest = "";
                                 if (data.Status == 1) {
                                     @{
                                         if (User.IsInRole("Dev") || User.IsInRole("Expense Account Status"))
                                         {
                                             statData = "<a class=\"modal-change\" href=\"/master/ExpenseTypeStatus/'+ data.id +'/active\" title=\"Click To Active\"><i class=\"badge bg-red\" >Inactive</i></a> ";
                                         }
                                }
                                     rest = '@Html.Raw(statData)';
                                 }
                                 else {
                                     @{
                                         if (User.IsInRole("Dev") || User.IsInRole("Expense Account Status"))
                                         {
                                             statData = "<a class=\"modal-change\" href=\"/master/ExpenseTypeStatus/'+ data.id +'/inactive\" title=\"Click To Inactive\"><i class=\"badge bg-green\" >Active</i></a> ";
                                         }
                                    }
                                     rest = '@Html.Raw(statData)';
                                 }
                                 return rest
                             } else {
                                 return null;
                             }
                         }
                     },
                      {
                          "name": "Editable", "data": function (data) {
                              rest = '';
                              if (data.Editable == 0) {
                                  rest += '@Html.Raw(actData)';
                                  @{
                                      action = "";
                                      if (User.IsInRole("Dev") || User.IsInRole("View Contact"))
                                      {
                                          action += "<a class=\"modal-change\" href=\"/Accounts/ViewDetails/'+ data.id +'\" title=\"View Account\"><i class=\"fa fa-lg fa-search-plus\"></i></a> ";
                                      }
                                      if (User.IsInRole("Dev") || User.IsInRole("Edit Expense Account"))
                                      {
                                          action += "<a class=\"modal-edit\" href=\"/Accounts/Edit/' + data.id + '\"title=\"Edit Accounts\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";

                                      }
                                      if (User.IsInRole("Dev") || User.IsInRole("Delete Expense Account"))
                                      {
                                          action += "<a class=\"modal-delete\" href=\"/Accounts/Delete/' + data.id + '\"title=\"Delete Accounts\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";

                                      }
                               }
                                  rest = '@Html.Raw(action)';
                              }
                              else {
                                  @{
                                  action = "";
                                  action = "<a class=\"modal-edit\" href=\"/Accounts/Edit/' + data.id + '\"title=\"Edit Accounts\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";

                              }
                                  rest = '@Html.Raw(action)';
                              }
                              return rest;
                          }
                      },
                      {
                          "name": "id", "data": function (data) {
                              var rest = "";
                              if (data.Editable == 0) {
                                  @{
                                      if (User.IsInRole("Dev") || User.IsInRole("Delete Expense Account"))
                                      {
                                          delchk = "<input class=\"checkbox\" type=\"checkbox\" name=\"bill[]\" value='+ data.id +'></input>";
                                      }
                                  }
                              }
                              return rest = '@Html.Raw(delchk)';
                          }
                      },
                ],
                dom: 'Bfrtip',
                buttons: ['colvis', {
                    extend: 'print',//
                    title: "",
                    footer: true,
                    exportOptions: {
                        columns: ':visible'
                    },
                    message: '<table class="tblcompact table table-bordered"><thead>' +
                        ' <tr><th class="text-center"><h3 style="margin-top: 0px;">' + '<h4>Accounts </h4></th></tr>' +
                        ' <tr><th><span class="text-left"></span><span class="text-right pull-right"> </span></th></tr></thead><tbody><tr><td>',
                    customize: function (win) {
                        // $(win.document.body)
                        //.css('font-size', '10pt')
                        //.css('padding', '1px');
                        $(win.document.body).find('table, th,tr, td ')
                           // .css('border', 'inherit')
                            .css('font-size', '10pt')
                            .css('padding', '5px')
                            .addClass('compact');
                        $(win.document.body).append('</td></tr></tbody>')
                    }
                }, 'copy', 'csv', 'excel',

                {
                    extend: 'pdf',//
                    title: "Accounts",
                    footer: true,
                    orientation: 'landscape',

                    pageSize: 'A4',
                    exportOptions: {
                        columns: ':visible'
                    },
                    customize: function (doc) {
                        doc.pageMargins = [10, 10, 10, 10];
                        doc.defaultStyle.fontSize = 10;
                        doc.styles.tableHeader.fontSize = 10;
                        doc.styles.title.fontSize = 12;
                        // Remove spaces around page title
                        doc.content[0].text = doc.content[0].text.trim();

                        doc.styles['td:nth-child(2)'] = {
                            width: '100%',
                            'max-width': '100%'
                        }

                        var objLayout = {};
                        // Horizontal line thickness
                        objLayout['hLineWidth'] = function (i) { return .5; };
                        // Vertikal line thickness
                        objLayout['vLineWidth'] = function (i) { return .5; };
                        //// Horizontal line color
                        //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                        //// Vertical line color
                        //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                        // Left padding of the cell
                        objLayout['paddingLeft'] = function (i) { return 4; };
                        // Right padding of the cell
                        objLayout['paddingRight'] = function (i) { return 4; };
                        // Inject the object in the document
                        doc.content[1].layout = objLayout;
                    }
                },

                  @Html.Raw(deleteBTn)

                ],

                "drawCallback": function (settings) {
                    var table = $('#MyTable').DataTable();
                    if (!table.data().any()) {
                        $("#sub").hide();
                    } else {
                        $("#sub").show();
                    }
                }
            })

            //Button Close
            $('#srch, .search-box .btn-close').on('click', function (e) {
                $('#advsearchlist').toggle();

                /*******  To uncheck all the checkboxes in the Select List  ************/
                var checkboxes = document.querySelectorAll("input[type='checkbox']");
                checkboxes.forEach(function (Checkbox) {
                    Checkbox.checked = false;
                });

                if ($('#srch').hasClass('btn-primary')) {

                    $('#srch').addClass('btn-danger');
                    $('#srch').removeClass('btn-primary');
                }
                else {
                    if ($('#srch').hasClass('btn-danger')) {
                        $('#srch').addClass('btn-primary');
                        $('#srch').removeClass('btn-danger');
                    }

                    /*******  To clear all the data entered  *********/
                    $('#ddlAccounts').val(0).trigger("change");
                    $('#Alias').val("");
                    $('#AccGroup').val(0).trigger("change");
                    $('#Status').val(null);
                    $('#TRNNo').val(null).trigger("change");
                    oTable.draw();
                }
            });

            $('#search-form').on('submit', function (e) {
                e.preventDefault();
                oTable.draw();
            });
        $('#ddlPagesize').on('change', function (e) {

            let pagedroplength = $('#ddlPagesize').val();
            oTable.page.len(pagedroplength).draw();
        });
            var chkcol = '@userRole';
            if (chkcol == "True") {
                var column1 = oTable.column(9);
                column1.visible(true);
                $('.dt-button.btn-danger').show();
            } else {
                var column1 = oTable.column(9);
                column1.visible(false);
                $('.dt-button.btn-danger').hide();
            }

        /* function for Create popup */
        $('span').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        });

        $('#modal-create').on('submit', '#createform', function (e) {
            e.preventDefault();
            var url = $('#createform')[0].action;
            var data = $('#createform').serialize();
            createajax(url, data, '#modal-create');
        });


        /* function for Edit popup */
        $('#MyTable').on('click', '.modal-edit', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-edit');
        });

        $('#modal-edit').on('submit', '#editform', function (e) {
            e.preventDefault();
            var url = $('#editform')[0].action;
            var data = $('#editform').serialize();
            createajax(url, data, '#modal-edit');
        });

        /* function for delete popup */
        $('#MyTable').on('click', '.modal-delete', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-delete');
        });

        $('#modal-delete').on('submit', '#deleteform', function (e) {
            e.preventDefault();
            var url = $('#deleteform')[0].action;
            var data = $('#deleteform').serialize();
            createajax(url, data, '#modal-delete');
        });

        /* chang status */
        $('#MyTable').on('click', '.modal-change', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-change');
        });

        $('#modal-change').on('submit', '#changeform', function (e) {
            e.preventDefault();
            var url = $('#changeform')[0].action;
            var data = $('#changeform').serialize();
            createajax(url, data, '#modal-change');
        });

        /* function for gen popup */
        $('span').on('click', '.modal-gen', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-gen');
        });

        $('#modal-gen').on('shown.bs.modal', function (e) {
            $('#Acctree').jstree();
        });

        $('#modal-create').on('shown.bs.modal', function (e) {

          
        });

        $('#modal-edit').on('shown.bs.modal', function (e) {
           // var id = $("#AccountsID").val();
            $("#Group").select2({
                placeholder: 'Search Account Group Name ',
                minimumInputLength: 0,
                ajax: {
                    url: "/Accounts/SearchAccInAcc",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term,
                            page: params.page,
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;

                        return {
                            results: data
                        };
                    },
                    cache: true
                },
            });
        });

        //Account Group
        $("#AccGroup").select2({
            placeholder: 'Search Account Group Name ',
            minimumInputLength: 0,
            ajax: {
                url: "/Accounts/SearchGroup",
                dataType: 'json',
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term || "",
                        page: params.page || 0,
                        x: "All"
                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 0;

                    return {
                        results: data,
                        pagination: {
                            //more: (params.page * 10) < 50
                            more: true
                        }
                    };
                },
                cache: true
            },
        });

        //Account Name
        $("#ddlAccounts").select2({
            placeholder: 'Search Account by Name ',
            minimumInputLength: 0,
            ajax: {
                url: "/Accounts/SearchAllAccounts",
                dataType: 'json',
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term || "",
                        page: params.page || 0,
                        x: "All"
                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 0;

                    return {
                        results: data,
                        pagination: {
                            //more: (params.page * 10) < 50
                            more: true
                        }
                    };
                },
                cache: true
            },
        });

        function reload_table() {
            oTable.clear().draw();
            oTable.ajax.reload(null, false); //reload datatable ajax
            isTicked();
      }

        //select all checkboxes
        $('body').on('change', '#select_all', function () {
            $(".checkbox").prop('checked', $(this).prop("checked")); //change all ".checkbox" checked status
        });

        //".checkbox" change
        $('body').on('change', '.checkbox', function () {
            //uncheck "select all", if one of the listed checkbox item is unchecked
            if (false == $(this).prop("checked")) { //if this item is unchecked
                $("#select_all").prop('checked', false); //change "select all" checked status to false
            }
            isTicked();
        });

        isTicked();

        $('body').on('change', '#Name', function (e) {
            var name = $('#Name').val();//CustomerCheck
            //alert(name)
            $.ajax({
                url: '/Accounts/AccountCheck',
                type: "GET",
                dataType: "JSON",
                data: { Account: name },
                success: function (rslt) {
                    if (rslt == true) {
                        alert("Account Name already Exists")
                        $('#Name').val('');
                    }
                }
            });

        });

       var checkList = document.getElementById('list1');
       /******* Function to list and hide dropdown checklist while clicking on 'Select Fields' *******/
       checkList.getElementsByClassName('anchor')[0].onclick = function (evt) {
           if (checkList.classList.contains('visible'))
               checkList.classList.remove('visible');
           else
               checkList.classList.add('visible');
       }

       /******* Function to show and hide fields while clicking on checkboxes in 'Select Fields' *******/
       $("ul li input:checkbox").click(function () {

           var _show = 0;

           //Account Name
           if ($("#liaccntname ").prop("checked") == true) {
               $("#searchaccntname").show();
               _show = 1;
           }
           else {
               $('#ddlAccounts').val(0).trigger("change");
               $("#searchaccntname").hide();
               oTable.draw();
           }

           //Alias
           if ($("#lialias").prop("checked") == true) {
               $("#searchalias").show();
               _show = 1;
           }
           else {
               $("#Alias").val("");
               $("#searchalias").hide();
               oTable.draw();
           }

           //Account Group
           if ($("#liaccntgroup").prop("checked") == true) {
               $("#searchaccntgroup").show();
               _show = 1;
           }
           else {
               $('#AccGroup').val(0).trigger("change");
               $("#searchaccntgroup").hide();
               oTable.draw();
           }

           //Status
           if ($("#listatus").prop("checked") == true) {
               $("#searchstatus").show();
               _show = 1;
           }
           else {
               $('#Status').val("").trigger("change");
               $("#searchstatus").hide();
               oTable.draw();
           }

           //TRN No.
           if ($("#liTRN").prop("checked") == true) {
               $("#searchTRNno").show();
               _show = 1;
           }
           else {
               $('#TRNNo').val(null).trigger("change");
               $("#searchTRNno").hide();
               oTable.draw();
           }

           if (_show == 1) {
               $('#advsearchlist').show();
           }
           else {
               $('#advsearchlist').hide();
           }
       });

       /******* Function to hide dropdown checklist while clicking outside it ********/
       $(document).on("click", function (event) {

           var element1 = $("#list1");

           if (element1 !== event.target && !element1.has(event.target).length) {
               checkList.classList.remove('visible');
           }
       });       

    </script>
}
