@{
    ViewBag.Title = "Cheque List";
    ViewBag.SubTitle = "Cheque List";
    ViewBag.Active = "Reports";
   
    string actData = "";
}
<div class="box box-default" id="RReport">
    <div class="box-header with-border">
        <h3 class="box-title">Cheque List</h3>
    </div>
    <br />
    <form id="search-form" style="padding:10px;">
        
              
        <div class="row">
            <div class="form-group col-md-2 ">
                @Html.Label("Status", null, new { @class = "control-label" })
                @Html.DropDownList("status", new SelectList(new List<SelectListItem>
                       {

                        new SelectListItem() {Text = "All", Value=""},

                       }, "Value", "Text"), "--select--", new { @class = "form-control input-sm select2", @placeholder = "Enter Location", @required = "required" })

            </div>
            <div class="form-group col-md-3">
                @Html.Label("Check Number", null, new { @class = "control-label" })
                @Html.TextBox("CheckNumber", "", new { @class = "form-control input-sm" })
            </div>
            <div class="form-group col-md-3" style="display:none">
                <label class="control-label">Select Bank Account</label>
                @Html.DropDownList("ddlBank", (SelectList)ViewBag.Bank, "", new { @class = "form-control select2 input-sm" })
            </div>
            <div class="form-group col-md-3" style="display:none">
                @Html.Label("Voucher Type", null, new { @class = "control-label" })
                @Html.DropDownList("ddlType", (SelectList)ViewBag.Type, new { @class = "form-control select2 input-sm" })
            </div>
            <div class="form-group col-md-3 cus">
                @Html.Label("Customer", null, new { @class = "control-label" })
                @Html.DropDownList("ddlCustomer", (SelectList)ViewBag.Customer, new { @class = "form-control select2 input-sm" })
            </div>
            <div class="form-group col-md-3 sup">
                @Html.Label("Supplier", null, new { @class = "control-label" })
                @Html.DropDownList("ddlSupplier", (SelectList)ViewBag.Supplier, new { @class = "form-control select2 input-sm" })
            </div>
        </div>
                    <div class="row">
                       
                     
                      
                        <div class="form-group col-md-2">
                            <label class="control-label">From</label>
                            <div class="input-group date">
                                <input class="form-control input-md" id="From" name="From" value="" type="text">
                                <div class="input-group-addon">
                                    <i class="fa fa-calendar"></i>
                                </div>
                            </div>
                        </div>
                        <div class="form-group col-md-2">
                            <label class="control-label">To</label>
                            <div class="input-group date">
                                <input class="form-control input-md" id="To" name="To" value="" type="text">
                                <div class="input-group-addon">
                                    <i class="fa fa-calendar"></i>
                                </div>
                            </div>
                        </div>

                        <div class="form-group col-md-2" id="search">
                            
                            <input type="button" class="btn btn-info " value="search" onclick="searchform()" style="margin-top:20px;">
                        </div>
                    </div>

        
    </form>
    <div class="box-body">
        <input type="hidden" id="cname" value="@ViewBag.CName" />
        <input type="hidden" id="caddress" value="@ViewBag.CAddress" />

        <div class="box-body">
            <table class="table table-bordered table-hover" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td>Sl No</td>
                        <td>PDC Date</td>
                        <td>Voucher No</td>
                        <td>Check No.</td>
                        <td>Account</td>
                        <td>PDC Issued</td>
                        <td>PDC Receipt</td>
                        <td>PDC Journal</td>

                        <td>Status</td>
                        <td></td>

                        @*<td>Created By</td>
        <td>Created Date</td>
        <td>Branch</td>*@
                    </tr>
                </thead>
                <tbody></tbody>
                <tfoot>
                    <tr>
                        <th>Total:</th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
</tfoot>
            </table>
        </div>
    </div>
</div>

<div id="modal-container2" class="modal fade" role="dialog" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                <h4>Status Updation</h4>
            </div>
          
            <div class="modal-body">
                <div class="box-body" id="modelview">
                    <table class="table table-bordered table-hover" id="RemarkInfo">
                        <thead>
                            <tr class="bg-gray">
                                <td>#</td>
                                <td>Date & Time</td>
                                <td>Employees</td>
                                <td>Status</td>
                                <td>Remarks</td>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@Html.Partial("../Common/_ModalCreate")
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")

    @Styles.Render("~/css/bootstrap-timepicker")


}
@section Scripts {
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/bootstrap-timepicker")
<script type="text/javascript">
    var oTable = $('#UserTable').DataTable({
                "processing": true, // for show progress bar
                "serverSide": true, // for process server side
                "filter": false, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
        "bLengthChange": false,
        "responsive": true,
              "paging": false,
              "searching": true,

                "ajax": {
                    "url": '/PDCRegularise/GetData3',
                    "data": function (data) {

                        data.status = $("#status").val();
                        data.fromdate = $('#From').val();
                        data.todate = $('#To').val();
                        data.Type = "all";
                        data.customer = $('#ddlCustomer').val();
                        data.supplier = $('#ddlSupplier').val();
                        data.CheckNumber = $('#CheckNumber').val();
                       
                        data.bankid = $('#ddlBank').val();
                        },
                    "type": "POST",
                    "datatype": "json"
                },
                "order": [[2, "desc"]],
                "columnDefs": [{
                    "targets": [1],
                    "orderable": false
                }],
                "columns": [

                    {
                        "data": "id", "name": "id",

                        "render": function (data, type, row, meta) {
                            return meta.row + meta.settings._iDisplayStart + 1;
                        }
                    },
                    { "data": "Date", "name": "Date", "render": function (data) { return convertToDate(data); } },
                    {
                        "name": "Voucher", "data": function (result) {
                            @{

                         var urls = "";
                                }
                            if (result.pdctype == "Receipt") {
                                          @{


                    urls = "'<a href=\"/Receipt/Edit/'+  result.voucherid +'\" target=\"_new\">'+ result.Voucher +'</a>' ";
                               }
                                return @Html.Raw(urls);
                            }
                            else if (result.pdctype == "Payment") {
                                 @{


                    urls = "'<a href=\"/Payment/Edit/'+  result.voucherid +'\" target=\"_new\">'+ result.Voucher +'</a>' ";
                               }
                                return @Html.Raw(urls);
                            }

                            else {
                                 @{


                    urls = "'<a href=\"/JournalV/Edit/'+  result.voucherid +'\" target=\"_new\">'+ result.Voucher +'</a>' ";
                               }
                                return @Html.Raw(urls);
                            }


                        }

                    },
                    { "data": "check", "name": "check" },
                    { "data": "Account", "name": "Account" },
                    { "data": "Issued", "name": "Issued", render: $.fn.dataTable.render.number(",", ".", 2) },
                    { "data": "Receipt", "name": "Receipt", render: $.fn.dataTable.render.number(",", ".", 2) },
                    { "data": "Journal", "name": "Journal", render: $.fn.dataTable.render.number(",", ".", 2) },
               
                    { "data": "remark", "name": "remark" },

                    {
                        "name": "remark", "data": function (data) {
                            var rest = "";
                        @{
                             actData += "<a class=\"btn btn-icons btn-rounded btn-edit modal-create\" href=\"/PDCRegularise/addpdcremark/'+ data.id +'\" title=\"Add Remarks\"><i class=\" fa fa-plus\" ></i></a> ";
                             actData += "<a class=\"btn btn-icons btn-rounded btn-remark Updation\" onclick=\"details(' + data.id + ')\" title=\"View Remarks\"><i class=\" fa fa-eye\" ></i></a> ";
                         }
                            return rest = '@Html.Raw(actData)';
                        }
                    },
                ],

                "footerCallback": function (row, data, start, end, display) {
                    var api = this.api(), data;

                    // Remove the formatting to get integer data for summation
                    var intVal = function (i) {
                        return typeof i === 'string' ? i.replace(/[\$,]/g, '') * 1 :

                            typeof i === 'number' ?
                                i : 0;
                    };

                    // Total over all pages
                    total = api
                        .column(4)
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Total over this page
                    pageTotal = api
                        .column(4, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update footer
                    $(api.column(4).footer()).html(
                        pageTotal.toFixed(2)
                        //'$' + pageTotal + ' ( $' + total + ' total)'
                    );

                    total = api
                        .column(5)
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Total over this page
                    pageTotal = api
                        .column(5, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update footer
                    $(api.column(5).footer()).html(
                        pageTotal.toFixed(2)
                        //'$' + pageTotal + ' ( $' + total + ' total)'
                    );
                    total = api
                        .column(6)
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Total over this page
                    pageTotal = api
                        .column(6, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update footer
                    $(api.column(6).footer()).html(
                        pageTotal.toFixed(2)
                        //'$' + pageTotal + ' ( $' + total + ' total)'
                    );



                },









                "columnDefs": [{ targets: 0, orderable: false }],
                "drawCallback": function (settings) {

                    var table = $('#UserTable').DataTable();
                    if (!table.data().any()) {
                        $("#sub").hide();
                    } else {
                        $("#sub").show();
                    }
                    //if ($(this).find('tbody tr').length <= 1) {
                    //    $("#sub").hide();
                    //}
                    //else {
                    //    $("#sub").show();
                    //}
                }

    });
    $('.date').datepicker({
        format: 'dd-mm-yyyy',
        autoclose: true,
        allowInputToggle: true
    })
    $(document).ready(function () {
 
        $('#To').datepicker({
            format: 'dd-mm-yyyy'
        });
        $('#From').datepicker({
            format: 'dd-mm-yyyy'
        });

        CallBankAcctPDC2();

        var date = new Date();
        var today = new Date(date.getFullYear(), date.getMonth(), date.getDate());
        var priordate = new Date(new Date().setDate(today.getDate() - 30));
        var todate = new Date(new Date().setDate(today.getDate() + 30));
        // $('#To').datepicker('setDate', todate);
        //  $('#From').datepicker('setDate', priordate);
        //---

        $('#SReport').hide();
        $("#ddlCustomer").select2({
            placeholder: 'Search Customer by Name or Code',
            minimumInputLength: 0,
            ajax: {
                url: "/Customer/SearchCustomer",
                dataType: 'json',
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term,
                        page: params.page,
                        x: "all"

                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 1;

                    return {
                        results: data
                    };
                },
                cache: true
            },
        });
        $("#ddlSupplier").select2({
            placeholder: 'Search Supplier by Name or Code',
            minimumInputLength: 0,
            ajax: {
                url: "/Supplier/SearchSupplier",
                dataType: 'json',
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term,
                        page: params.page,
                        x: "all"
                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 1;

                    return {
                        results: data
                    };
                },
                cache: true
            },
        });

        $("#status").select2({
            placeholder: 'Search Status',
            minimumInputLength: 0,
            ajax: {
                url: "/PDCRegularise/SearchStatus",
                dataType: 'json',
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term || "",
                        x:"All",
                        page: params.page || 0
                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 0;

                    return {
                        results: data,
                        pagination: {
                            //more: (params.page * 10) < 50
                            more: true
                        }
                    };
                },
                cache: true
            },

        });




            var date = new Date();
            date.setDate(date.getDate());
            $('.date').datepicker({
                format: 'dd-mm-yyyy',

                autoclose: true,
                allowInputToggle: true,

            });
            $('#modal-create').on('submit', '#createForm', function (e) {
                e.preventDefault();
                var url = $('#createForm')[0].action;
                var data = $('#createForm').serialize();
                createajax(url, data, '#modal-create');
                oTable.draw();
            });



            $('#modal-create').on('submit', '#createForm', function (e) {
                e.preventDefault();
                oTable.draw();
            });
            $('#search-form').on('submit', function (e) {
                e.preventDefault();
                oTable.draw();
            });

            $('#UserTable tbody').on('click', 'tr', function () {
                if ($(this).hasClass('selected')) {
                    $(this).removeClass('selected');
                }
                else {
                    oTable.$('tr.selected').removeClass('selected');
                    $(this).addClass('selected');
                    $(this).addClass('dataTables_row');
                }
            });


        });

        /* function for Create popup */
        $('div').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');

        });

        //Function to retrieve Remarks of Customer
        function details(d) {
            var CustomerId = d;
            //List all other remarks from table CustomerRemarks
            var oTable1 = $('#RemarkInfo').DataTable({
                "processing": true, // for show progress bar
                "serverSide": true, // for process server side
                "filter": true, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
                "bStateSave": true,
                "paging": false,
                "sortable": true,
                "ordering": true,
                "searching": true,
                "ajax": {
                    "url": '/PDCRegularise/GetAllRemarks',
                    "type": "POST",
                    "datatype": "json",
                    "data": { CustomerId: CustomerId }
                },
                "order": [[0, "desc"]],

                "columns": [
                    {
                        "data": "id", "name": "id",
                        "render": function (data, type, row, meta) {
                            return meta.row + meta.settings._iDisplayStart + 1;
                        }
                    },
                    { "data": "CreatedDate", "name": "CreatedDate", "render": function (data) { if (data != null) { return convertDateTime(data); } else { return "" } } },
                    { "data": "EmpName", "name": "EmpName" },
                    { "data": "status", "name": "status" },
                    { "data": "Remark", "name": "Remark" },

                ],
            });

            oTable1.destroy();
        }

        //Popup of View Remarks
        $('.table').on('click', 'a.Updation', function (e) {
            e.preventDefault();
            $(this).attr('data-target', '#modal-container2');
            $(this).attr('data-toggle', 'modal');
        });


    //        var column1 = oTable.column(8);
    //        column1.visible(false);
    function searchform() {

        oTable.draw();
            }
</script>
}
