                      //            }
                      //            datas += item.FirstName + " " + item.LastName;
                      //        });
                      //        return datas;
                      //    }
                      //},
                      //{ "data": "RequestBy", "name": "RequestBy" },
                      { "data": "CreatedBy", "name": "CreatedBy" },
                      { "data": "RStatus", "name": "RStatus" },
                      {
                          "name": "ReminderId", "data": function (data) {
                              var rest = "";
                              @{
                                actData = "";
                                actData += "<a class=\"modal-edit\"  href=\"/Reminder/Edit/'+ data.ReminderId +'\" title=\"Edit Reminder\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                                actData += "<a class=\"modal-delete\" href=\"/Reminder/Delete/'+ data.ReminderId +'\" title=\"Delete Reminder\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";
                            }
                              rest += '@Html.Raw(actData)';
                              return rest;
