                        <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                        @Html.TextBoxFor(m => m.QuotDate, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @required = "required", @onchange = "nodays()" })
                    </div>
                </div>
                <div class="col-sm-2 form-group col-xs-12">
                    <label class="control-label" for="Sale_Type">Sale Type</label> *
                    <select class="form-control valid" data-val="true" data-val-number="The field SalesType must be a number." data-val-required="The SalesType field is required." id="SalesType" name="SalesType" tabindex="6">
