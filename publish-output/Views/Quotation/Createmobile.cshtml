                        @*<option value="1">VAT Item Wise</option>
                            <option value="2">Tax Exempt</option>*@

                    </select>
                </div>
                <div class="col-sm-2 form-group col-xs-12">
                    @Html.Label("Sales Executive", null, new { @class = "control-label" })
