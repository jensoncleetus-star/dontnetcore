                    {
                        <div class="input-group input-group-sm">
                            @Html.DropDownListFor(m => m.QuotCashier, (SelectList)ViewBag.Cashier, "", new { id = "ddlEmployee", @class = "form-control select2" })
                            <span class="input-group-btn">
                                <button type="button" href="/SalesExecutive/AddSalesExecutive" class="modal-edit btn btn-success btn-flat"><i class="fa fa-1x fa-plus-circle"></i></button>
                            </span>
                        </div>
                    }
                    else
                    {
                        @Html.DropDownListFor(m => m.QuotCashier, (SelectList)ViewBag.Cashier, new { id = "ddlEmployee", @class = "form-control select2" })
                    }
                </div>

                <div class="col-sm-2 form-group col-xs-12">
                    @Html.Label("Customer Name", null, new { @class = "control-label" }) *
                    @if (User.IsInRole("Dev") || User.IsInRole("Create Customer"))
                    {
                        <div class="input-group input-group-sm">
                            @Html.DropDownListFor(m => m.Customer, (SelectList)ViewBag.Custer, "", new { id = "ddlCustomer", @class = "form-control select2", @required = "required", @onchange = "GetCustomer()" })
                            <span class="input-group-btn">
                                <a href="/Customer/Create" class="btn btn-flat sh-align" target="_new"><i class="fa fa-2x fa-plus-circle"></i></a>
                            </span>
                        </div>
                    }
                    else
                    {
                        @Html.DropDownListFor(m => m.Customer, (SelectList)ViewBag.Custer, new { id = "ddlCustomer", @class = "form-control select2", @required = "required", @onchange = "GetCustomer()" })
                    }
                </div>
                <div class="col-sm-2 form-group col-xs-12">
                    @Html.Label("QuotationType", null, new { @class = "control-label" })
                    <div class="input-group input-group-sm">
                        @Html.DropDownListFor(m => m.QuotationType, (SelectList)ViewBag.Quot, "", new { id = "ddlQuote", @class = "form-control select2" })
                        @*<span class="input-group-btn">
                                <button type="button" href="/QuotationType/Create" class="modal-create btn btn-success btn-flat"><i class="fa fa-1x fa-plus-circle"></i></button>
                            </span>*@
                    </div>
                </div>
            </div>

            <div class="row">
                @if (@ViewBag.EnableCRM == 0)
                {
                    <div class="col-sm-2 form-group col-xs-12">
                        @if (User.IsInRole("Dev") || User.IsInRole("Create Leads"))
                        {@Html.Label("Leads", null, new { @class = "control-label" })
                        <div class="input-group input-group-sm">

                            @Html.DropDownListFor(m => m.lead, (SelectList)ViewBag.leads, "", new { id = "ddllead", @class = "form-control select2", @onchange = "Getlead()" })



                        </div>
                    }
                    else
                    {
                        @Html.Label("Lead", null, new { @class = "control-label" })
                        @Html.DropDownListFor(m => m.lead, (SelectList)ViewBag.leads, new { id = "ddllead", @class = "form-control select2", @onchange = "Getlead()" })
                    }
                    </div>
                }
                @if (@ViewBag.ProjCheck == 0)
