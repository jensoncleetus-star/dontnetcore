                {
                <div class="input-group input-group-sm">
                    @Html.DropDownListFor(m => m.Project, (SelectList)ViewBag.Proj, "--No Project--", new { id = "ddlProject", @class = "form-control select2" })
                    @*<span class="input-group-btn">
            <a href="/Project/AddProject" class="modal-project btn btn-success btn-flat" title="Add Project"><i class="fa fa-1x fa-plus-circle"></i></a>
        </span>*@
                </div>
                }
                else
                {
                    @Html.DropDownListFor(m => m.Project, (SelectList)ViewBag.Proj, new { id = "ddlProject", @class = "form-control select2" })
                }
            </div>
                    <div class="col-sm-2 form-group col-xs-12">
