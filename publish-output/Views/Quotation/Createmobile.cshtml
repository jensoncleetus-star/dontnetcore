                        @Html.Label("Approved By", null, new { @class = "control-label" })
                        @Html.DropDownList("ddlApprovedBy", (SelectList)ViewBag.ApproveBy, "", new { @class = "form-control select2", @name = "ddlApprovedBy[]", @multiple = "multiple" })
                    </div>
                }
                <div class="clearfix"></div>
            </div>
            <div class="form-group col-sm-2 col-xs-12">
                <input type="text" style="border:0px;width:100%" id="itemimagepath" />
            </div>
