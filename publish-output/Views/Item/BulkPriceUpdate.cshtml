<div class="box box-default">
    <div class="box-header with-border">
        <div class="row" style="height:30px;">
            <div class="col-md-12 col-xs-12">
                <div class="ribbon">
                    <div class="ribbon4"><h3 class="box-title">Bulk Price Update</h3></div>
                </div>
            </div>
        </div>

    </div>
    <div class="box-body" style="margin-top:15px;">
        <form id="search-form">
            @using (Html.BeginForm("BulkPriceUpdate", "Item", FormMethod.Post, new { id = "popupForm", target = "_new" }))
            {
                <input type="hidden" id="cname" value="@ViewBag.CName" />
                <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
                <div class="form-group col-md-3 col-xs-12">
                    @Html.Label("Item Brand", null, new { @class = "control-label temp2" })
                    @Html.DropDownList("ddlBrand", (SelectList)ViewBag.Brand, new { @class = "form-control input-sm select2" })
                </div>
                <div class="form-group col-md-3 col-xs-12" id="creditsale">
                    @Html.Label("Item Category", null, new { @class = "control-label temp2" })
                    @Html.DropDownList("ddlCategory", (SelectList)ViewBag.Category, new { @class = "form-control input-sm select2" })
                </div>
                <div class="col-md-3 col-xs-12 form-group">
                    @Html.Label("ItemName Contains", null, new { @class = "control-label temp2" })
                    @Html.TextBox("ItemWord", "", "", new { @class = "form-control", @autocomplete = "off" })
                </div>
                <div class="box-footer col-md-12 col-xs-12 text-center">
                    <input type="submit" class="btn btn-info" value="Submit" />
                    <button type="button" class="btn btn-default" onclick="@("window.location.href='/item/BulkPriceUpdate'");">Cancel</button>
                </div>
            }
        </form>
    </div>
</div>
<div class="box box-default" id="StockReport">
    @using (Html.BeginForm("SelectAllId", "Item", FormMethod.Post, new { id = "selectItemform", role = "form" }))
    {
        <div class="box-body">
            <div class="box-body">
                <table class="display table table-bordered" id="UserTable">
                    <thead>
                        <tr class="bg-gray">
                            <td data-priority="2">S/N</td>
                            <td data-priority="4">Item code</td>
                            <td data-priority="6">Item Name</td>
                            <td>Selling Price</td>
                            <td>Purchase Price</td>
                            <td><input type="button" class="btn btn-danger" id="submitbtn" onclick="setItem()" value="Select" /></td>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    }
    </div>
