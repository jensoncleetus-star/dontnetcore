
@using QuickSoft.Models
@{
    string actData = "";
}
<style>
    @@media only screen and (max-width: 430px) {
    }

    #ItemWord {
        border-radius: 0px !important;
        /*height:30px!important;*/
        height: 30px !important;
    }

    .sh-aligns {
        width: 1100px !important;
        margin-left: -100px !important;
    }
</style>
<div class="modal-header sh-aligns">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Search Note</h4>
</div>
<div class="modal-body sh-aligns">
    <form id="search-form">
        @using (Html.BeginForm("AddItemnoteSearch", "Item", FormMethod.Post, new { id = "popupForm", target = "_new" }))
        {
            <input type="hidden" id="cname" value="@ViewBag.CName" />
            <input type="hidden" id="caddress" value="@ViewBag.CAddress" />


            <div class="row">
               
                <div class="col-md-3 form-group">
                    @Html.Label("Item Note Contains", null, new { @class = "control-label" })
                    @Html.TextBox("ItemWord", "", "", new { @class = "form-control", @autocomplete = "off" })
                </div>
                
                <div class="row box-footer col-md-12">
                    <input type="submit" class="btn btn-info col-sm-offset-5" value="Submit" />
                    <button type="button" class="btn btn-default" onclick="setItem2()">Cancel</button>
                </div>
            </div>
        }
    </form>
    <div class="box box-default" id="StockReport">



        <div class="box-body">
            <table class="display table table-bordered" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="2">S/N</td>
                       
                        <td data-priority="6">Note</td>
                        
                        
                    </tr>
                </thead>
                <tbody></tbody>
                <tfoot>
                    <tr>
                        <th></th>
                        <th></th>
                        
                        
                    </tr>
                </tfoot>
            </table>
            @*<div class="row box-footer col-md-12">
                    <input type="button" class="btn btn-info col-sm-offset-5" onclick="setItem()" value="Select" />
                    <button type="button" class="btn btn-default" onclick="setItem2()">Cancel</button>
                </div>*@
        </div>
    </div>
</div>
<script type="text/javascript">
    $(document).ready(function () {

        $("#StockReport").hide();

    });



    function SearchData(data) {

        data.itemWord = $('#ItemWord').val();
    }

    function showdatatable() {
        var oTable2 = $('#UserTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "ordering": true,
            "pageLength": 10000,
            "paging": true,
            responsive: true,
            "bLengthChange": false,
            "bDestroy": true,
            "ajax": {
                "url": '/Item/GetAddItemnoteSearch',
                /* calling the function for capturing the datas*/
                "data": function (data) {
                    data = SearchData(data);
                },
                /*end*/
                "type": "POST",
                "datatype": "json"
            },

            "columnDefs": [
                 { "className": "dt-center", "targets": "_all" },

            ],

            "columns": [
                {

                    "width": "5%",
                    "data": "id", "name": "id",
                    "render": function (data, type, row, meta) {
                        return meta.row + meta.settings._iDisplayStart + 1;
                    }
                },

                {
                    "width": "95%",
                    "data": "ItemNote", "name": "ItemNote"
                },
  
            ],




        });

        //for showing the datatable when click the submit button
        $('#search-form').on('submit', function (e) {
            e.preventDefault();
            oTable2.draw();
            $('#StockReport').show();
            $('#UserTable').show();
        });

        $('#UserTable tbody').on('click', 'tr', function () {
            if ($(this).hasClass('selected')) {
                $(this).removeClass('selected');
            }
            else {
                oTable2.$('tr.selected').removeClass('selected');
                $(this).addClass('selected');
                $(this).addClass('dataTables_row');
            }
        });
    }
    var flag = 0;
    $('#search-form').on('submit', function (e) {
        e.preventDefault();
        if (flag == 0) {

            showdatatable();
            flag = 0;
        }
        else
            oTable2.draw();

        $('#StockReport').show();
    });




</script>

