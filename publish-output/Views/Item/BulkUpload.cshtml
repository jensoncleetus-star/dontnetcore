                        "<input type='hidden' class='selitem_size_" + count + "' value='" + Item.Size + "' name='selitem_size' id='selitem_size_" + count + "'/> " +
                        "<td><input type='number' class='selitem_psprice_" + count + "' value='" + Item.SellingPrice + "' name='selitem_psprice' id='selitem_psprice_" + count + "'/> </td>" +
                        "<input type='hidden' class='item_description_" + count + "' value='" + Item.ItemDescription + "' name='item_description' id='item_description_" + count + "'/> " +
                        "<input type='hidden' class='tagline1_" + count + "' value='" + Item.Tagline1 + "'  name='tagline1' id='tagline1_" + count + "'/> " +
                        "<input type='hidden' class='tagline2_" + count + "' value='" + Item.Tagline2 + "'  name='tagline2' id='tagline2_" + count + "'/> " +
                        "<input type='hidden' class='tagline3_" + count + "' value='" + Item.Tagline3 + "'  name='tagline3' id='tagline3_" + count + "'/> " +
                        "<input type='hidden' class='tagline4_" + count + "' value='" + Item.Tagline4 + "' name='tagline4' id='tagline4_" + count + "'/> " +
                        "<input type='hidden' class='tagline5_" + count + "' value='" + Item.Tagline5 + "' name='tagline5' id='tagline5_" + count + "'/> " +
