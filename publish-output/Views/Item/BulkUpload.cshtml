        }
        function deleteRow(t) {
            var classname = $(t).closest('tr').attr('class');
                var e = t.parentNode.parentNode;
                e.parentNode.removeChild(e);
            var i = 1;
            $('#addinvoiceItem tr').each(function () {
                $(this).find('td:first').text(i);
                i++;
            });
