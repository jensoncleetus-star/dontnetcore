                if (count == 1) {
                    required = 'required="required"';
                }                
                data = "<td class='text-center' id=" + divid + "> " + slno + " </td>" +
                        "<td ><input class='form-control item_name_" + count + "' type='text' " + required + "  data-id='" + count + "' id='item_name_" + count + "' data-msg-required='The Item field is required' placeholder='Type Item Name' value='" + Item.ItemName + "'/> </td>" +
                        "<td style='width:100px;'><input class='form-control unit_name_" + count + "' value='" + Item.Unit + "' id='unit_name_" + count + "'  data-id='" + count + "' id='unit_name'/></td>" +
                        "<td><input type='number' name='product_quantity[]' id='total_qntt_" + count + "' value='" + Item.ItemQuantity + "'  class='total_qntt_" + count + " form-control text-right quty' placeholder='0' value='0' </td>" +
                        "<input type='hidden' name='product_rate[]' " + required + " id='price_item_" + count + "' value='" + Item.MRP + "' class='price_item_" + count + " form-control text-right totrate' placeholder='0.00' min='0' /><input type='hidden' data-value='" + Item.BPrice + "' value='" + Item.BPrice + "' name='base_rate' id='base_rate_" + count + "'>  " +
                        "<input type='hidden' id='tax_" + count + "' class='form-control text-right tax tax_" + count + "' value='" + Item.Tax + "' /><input type='hidden' class='item_partnumber' name='item_partnumber' id='partnumber_" + count + "' value='" + Item.PartNumber + "'/>" +
                        "<input type='hidden' class='itemdescription_" + count + " form-control text-right' name='itemdescription' value='" + Item.ItemDescription + "' id='itemdescription_" + count + "'/> " +
                        "<input type='hidden' class='item_namearabic_" + count + "' value='" + Item.ItemNameArabic + "' name='item_namearabic_' id='item_namearabic_" + count + "'/> " +
                        "<input type='hidden' class='item_color_" + count + "' value='" + Item.Color + "' name='item_color' id='item_color_" + count + "'/> " +
                        "<td><input type='text' class='category_" + count + "' value='" + Item.Category + "'  name='category' id='category_" + count + "'/> </td>" +
