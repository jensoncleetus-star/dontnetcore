
@model QuickSoft.ViewModel.VatViewModel
@{

    ViewBag.Title = "Search VAT";
    ViewBag.SubTitle = "VAT Report";
    ViewBag.Active = "Tax";
    string from="";
    string to = "";
    string type = "";
}
<div class="box box-default" id="LReport">
    <div class="box-header with-border">
        <h3 class="box-title">VAT Report</h3>
    </div>
    <div class="box-body">
        <div class="box-body">
            <input type="hidden" id="cname" value="@ViewBag.CName" />
            <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
            <input type="hidden" id="out" value="out" />
            <input type="hidden" id="in" value="in" />
            <input type="hidden" id="fromdate" value="@Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.from))" />
            <input type="hidden" id="todate" value="@Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.to))" />
            <table class="display table table-bordered table-hover" id="UserTable">
                <thead>
                    <tr>
                        <td colspan="5">
                            From : @Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.from))  - @Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.to))
                        </td>
                    </tr>
                    <tr class="bg-gray">
                        <td>Particulars</td>
                        <td></td>
                        <td>Taxable Value</td>
                        <td>Taxable Amount</td>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        @*<td>Sales(Outwards): <br /> Local Supplies <br /> Domestic Taxable Supplies 5%</td>*@
                        <td>
                            <a href="/TaxReports/GetDetailsVat?taxtype=out&fromdate=@Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.from))&todate=@Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.to))"
                               target="_new">Sales 
                        </td>

                        <td></td>
                        <td><b>@Html.DisplayFor(m => m.TotalAmountOut)</td>
                        <td>@Html.DisplayFor(m => m.Outward)</td>
                    </tr>
                    <tr>
                        @*<td>Purchase Including Expense(Inwards): <br /> Local Purchases <br /> Domestic Taxable Purchases 5%</td>*@
                        <td>
                            <a href="/TaxReports/GetDetailsVat?taxtype=in&fromdate=@Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.from))&todate=@Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.to))"
                               target="_new">Purchase
                        </td>
                        <td></td>
                        <td><b>@Html.DisplayFor(m => m.TotalAmountIn)</td>
                        <td>@Html.DisplayFor(m => m.Inward)</td>
                    </tr>
                    @*----------------------------------------------------------------------------------------*@
                    <tr>
                        <td>
                            <a href="/TaxReports/GetNewDetailsVat?taxtype=expense&fromdate=@Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.from))&todate=@Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.to))"
                               target="_new">Expense
                        </td>
                        <td></td>
                        <td></td>
                        <td><b>@Html.DisplayFor(m => m.ExpenseTax)</b></td>
                    </tr>
                    @*----------------------------------------------------------------------------------------*@
                    <tr>
                        <td><b>Payable</b></td>
                        <td></td>
                        <td></td>
                        <td><b>@Html.DisplayFor(m => m.Diff)</b></td>
                    </tr>
                </tbody>
                
            </table>
        </div>
    </div>
</div>
@section Scripts {
    @Scripts.Render("~/js/bootstrap-datepicker")
    <script type="text/javascript">
       
        jQuery(function ($) {
            var oTable = $('#UserTable').DataTable({
                "processing": true, // for show progress bar
                "serverSide": false, // for process server side
                "filter": false, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
                "bLengthChange": false,
                "paging": false,
                "searching": false,
                "destroy": true,
                "deferLoading": 0,
                "ordering": false,
                "order": [[0, "asc"]],
                buttons: [//'copy', 'csv', 'excel', 'pdf', 'print'
                 {
                     extend: 'print',//
                     title: "",
                     footer: true,
                     filename: function () {
                         return 'VAT-Report';
                     },
                     message: function () {
                         var head = '<table class="tblcompact table table-bordered"><thead>' +
                         ' <tr><th class="text-center"><h3 style="margin-top: 0px;">' + $('#cname').val() + '</h3>' + $('#caddress').val() + '<h4>VAT Report</h4></th></tr>' +
                         ' <tr><th><span class="text-left"></span><span class="text-right pull-right"> From :  ' + $('#fromdate').val() + ' To :' + $('#todate').val() + '</span></th></tr></thead><tbody><tr><td>';
                         return head;
                     },
                     customize: function (win) {

                         $(win.document.body).find('table, th,tr, td ')
                            // .css('border', 'inherit')
                             .css('font-size', '10pt')
                             .css('padding', '5px')
                             .addClass('compact');
                         $(win.document.body).append('</td></tr></tbody>')

                     }
                 }, 'copy', 'csv', //'excel',
                 {
                     extend: 'excel',//
                     title: "",
                     footer: true,
                     filename: function () {
                         return 'VAT-Report';
                     },
                     message: function () {
                         var head = '' + $('#cname').val() + '\n' +
                          '' + $('#caddress').val() + '\n' +
                          ' VAT Report \n' +
                          'From :  ' + $('#fromdate').val() + ' To :' + $('#todate').val() + '';
                         return head;
                     },
                     pageSize: 'A4',
                     exportOptions: {
                         columns: [0, 1, 2, 3]
                     },
                 },
                 {
                     extend: 'pdf',//
                     title: "",
                     footer: true,
                     filename: function () {
                         return 'VAT-Report';
                     },
                     message: function () {
                         var head = '' + $('#cname').val() + '\n' +
                          '' + $('#caddress').val() + '\n' +
                          ' VAT Report \n' +
                          'From :  ' + $('#fromdate').val() + ' To :' + $('#todate').val() + '';
                         return head;
                     },
                     pageSize: 'A4',
                     exportOptions: {
                         columns: [0, 1, 2, 3, ]
                     },
                     customize: function (doc) {
                         doc.styles['td:nth-child(2)'] = {
                             width: '100px',
                             'max-width': '100px'
                         }
                         doc.pageMargins = [10, 10, 10, 10];
                         doc.defaultStyle.fontSize = 10;
                         doc.styles.tableHeader.fontSize = 10;
                         doc.styles.title.fontSize = 12;
                         // Header font and bg color
                         doc.styles.tableHeader.fillColor = '#d3d3d3';
                         doc.styles.tableHeader.color = 'black';
                         // Remove spaces around page title
                         doc.content[0].text = doc.content[0].text.trim();

                         doc.content[1].table.widths = [
                         '30%',
                         '10%',
                         '30%',
                         '30%',
                         ]

                         var objLayout = {};
                         // Horizontal line thickness
                         objLayout['hLineWidth'] = function (i) { return .5; };
                         // Vertikal line thickness
                         objLayout['vLineWidth'] = function (i) { return .5; };
                         //// Horizontal line color
                         //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                         //// Vertical line color
                         //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                         // Left padding of the cell
                         objLayout['paddingLeft'] = function (i) { return 4; };
                         // Right padding of the cell
                         objLayout['paddingRight'] = function (i) { return 4; };
                         // Inject the object in the document
                         doc.content[1].layout = objLayout;
                         // Footer font and bg color
                         doc.styles.tableFooter.fillColor = '#d3d3d3';
                         doc.styles.tableFooter.color = 'black';
                     }

                 },

                ],
                sDom: "lBfr<'datatable-scroll't>ip"
            });

            $('#UserTable tbody').on('click', 'tr', function () {
                if ($(this).hasClass('selected')) {
                    $(this).removeClass('selected');
                }
                else {
                    oTable.$('tr.selected').removeClass('selected');
                    $(this).addClass('selected');
                    $(this).addClass('dataTables_row');
                }
            });
        });

       

        var type = 'in';
        var oTable = $('#UserTable').DataTable();
        //$('#UserTable tbody').on('dblclick', 'tr', function (e) {
        //    var data = oTable.row(this).data();
        //    if (data[0] == "Sales(Outwards): <br> Local Supplies <br> Domestic Taxable Supplies 5%") {
        //        var url = "/TaxReports/GetDetailsVat?taxtype=" + $('#out').val() + "&fromdate=" + $('#fromdate').val() + "&todate=" + $('#todate').val();
        //    }
        //    else {
        //        var url = "/TaxReports/GetDetailsVat?taxtype=" + $('#in').val() + "&fromdate=" + $('#fromdate').val() + "&todate=" + $('#todate').val();
        //    }
        //    $(location).attr('href', url);
        //});
    </script>
}