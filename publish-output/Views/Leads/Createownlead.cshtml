                        </div>
                        <div class="form-group col-md-4">
                            @Html.LabelFor(model => model.State, htmlAttributes: new { @class = "control-label " })
                            @Html.DropDownListFor(model => model.StateID, (SelectList)ViewBag.States, new { @class = "form-control input-sm select2", tabindex = 11 })

                        </div>

                        <div class="form-group col-md-4">
                            @Html.LabelFor(model => model.Location, htmlAttributes: new { @class = "control-label " })
                            @Html.DropDownListFor(model => model.LocationID, (SelectList)ViewBag.Location, new { @class = "form-control input-sm select2", tabindex = 12 })
                        </div>

                    </div>
                    <br />
                    <div class="container-fluid row" style="display:none;">


                        <div class="form-group col-md-4">
                            @Html.LabelFor(model => model.LeadCondition, htmlAttributes: new { @class = "control-label " })
                            @Html.DropDownListFor(model => model.LeadCondition, (SelectList)ViewBag.LeadCondition, new { @class = "form-control input-sm select2", tabindex = 12 })
                        </div>

                        @*<div class="form-group col-md-4">
                                @Html.LabelFor(model => model.CurrentAction, htmlAttributes: new { @class = "control-label " })
                                @Html.DropDownListFor(model => model.CurrentAction, (SelectList)ViewBag.CurrentAction, new { @class = "form-control input-sm select2", tabindex = 12 })
                            </div>*@
                        <div class="form-group col-md-4">
                            @Html.LabelFor(model => model.NextAction, htmlAttributes: new { @class = "control-label " })
                            @Html.DropDownListFor(model => model.NextAction, (SelectList)ViewBag.NextAction, new { @class = "form-control input-sm select2", tabindex = 12 })
                        </div>
                    </div>
                    <br />
                    <div class="container-fluid row" style="display:none;">
                        <div class="form-group col-md-4">
                            @Html.LabelFor(model => model.NextAction, htmlAttributes: new { @class = "control-label " })
                            @Html.DropDownListFor(model => model.NextAction, (SelectList)ViewBag.NextAction, new { @class = "form-control input-sm select2", tabindex = 12 })
                        </div>

                        <!--<div class="col-sm-2 form-group">-->
                        @*@Html.LabelFor(model => model.DateTime, htmlAttributes: new { @class = "control-label" })*
                            <div class="input-group date">
                                <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                                @Html.TextBoxFor(model => model.DateTime, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm" })
                            </div>*@
                        <!--</div>-->

                        <div class="form-group col-md-4" style="display:none">
                            @Html.LabelFor(model => model.SalesPerson, htmlAttributes: new { @class = "control-label " })
                            @Html.DropDownListFor(model => model.SalesPerson, (SelectList)ViewBag.AssignedTo, new { @class = "form-control input-sm select2", tabindex = 12 })
                        </div>

                        <div class="form-group col-md-4" style="display:none">
                            @Html.LabelFor(model => model.Address, htmlAttributes: new { @class = "control-label " })
                            @Html.TextAreaFor(model => model.Address, new { @class = "form-control", @placeholder = "Enter Address", tabindex = 9 })
                        </div>


                        <div class="form-group col-md-4 col-xs-12" style="display:none;">
                            @Html.Label("Open/Close", null, new { @class = "control-label" })
                            <div class="input-group">
                                @Html.DropDownListFor(model => model.OpenClose, new SelectList(new List<SelectListItem>
                                       {
                                        new SelectListItem() {Text = "Open", Value="0"},
                                        new SelectListItem() {Text = "Closed", Value="1"},
                                       }, "Value", "Text"), new { @class = "form-control input-sm", @name = "Emirate" })
                            </div>
                        </div>
                    </div>

                    <div class="container-fluid row" style="display:none;">
                        <button style="width: 200px;    margin-top: 1rem;" type="submit" class="btn btn-primary btn-rounded btn-fw add_field_button">Add Contact &ensp;<i class="fa fa-plus-circle" aria-hidden="true" style="float: right;margin-top: 0.3rem;"></i></button>
                    </div>
                    <div class="container-fluid row">
                        <div class="form-group input_fields_wrap">

                        </div>
                    </div>


                    <div class="container-fluid row">
                        <div class="form-group col-md-4" style="display:none;">
                            @Html.LabelFor(m => m.AssignType, new { @class = "control-label" })
                            @if (User.IsInRole("Dev") || User.IsInRole("Create Task Team"))
                            {
                                <div class="input-group input-group-sm">
                                    @Html.DropDownListFor(m => m.AssignTypeAll, (SelectList)ViewBag.AssignTypes, new { @class = "form-control select2 AssignType", @name = "AssignTypeAll[]", @multiple = "multiple" })
                                    <span class="input-group-btn">
                                        <a href="/Team/Create" class="modal-create btn btn-success btn-flat" title="Add AssignType"><i class="fa fa-1x fa-plus-circle"></i></a>
                                    </span>
                                </div>
                            }
                            else
                            {
                                @Html.DropDownListFor(m => m.AssignTypeAll, (SelectList)ViewBag.AssignTypes, new { @class = "form-control select2 AssignType", @name = "AssignTypeAll[]", @multiple = "multiple" })
                            }
                        </div>
                        <div class="form-group col-md-4" style="display:none;">
                            @Html.LabelFor(m => m.AssignedTo, new { @class = "control-label" }) *
                            @Html.ListBoxFor(m => m.AssignedToo, (MultiSelectList)ViewBag.Employees, new { @id = "AssignedUsers", @class = "form-control select2 porder", @name = "AssignedToo[]", @multiple = "multiple", @style = "width:100%" })
                        </div>

                        @*<div class="form-group col-md-6">
                                @Html.LabelFor(m => m.AssignedTo, new { @class = "control-label col-sm-4" })
                                @Html.ListBoxFor(m => m.AssignedTo, (SelectList)ViewBag.AssignedTo, new { @class = "form-control", tabindex = 8 })
                            </div>*@
                    </div>
                    <div class="container-fluid row">
                        <button style="width: 200px; margin-top: 1rem;" type="submit" class="btn btn-primary btn-rounded btn-fw add_field_button2">Documents Attach &ensp;<i class="fa fa-plus-circle" aria-hidden="true" style="float: right;margin-top: 0.3rem;"></i></button>
                    </div>


                    <div class="container-fluid row">
                        <div class="form-group input_fields_wrap2">

                        </div>
                    </div>
                </div>
                <div class="row" style="display:none;">
                    @if (Model.FieldMap.Count > 0)
                    {
                        for (int i = 0; i < Model.FieldMap.Count; i++)
                        {
                            <div class="form-group col-md-3">
                                <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName</label>
                                @if (Model.FieldMap[i].Type == "Dropdown")
                                {
                                    if (Model.FieldMap[i].Field == "Ref1")
                                    {
                                        @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef1, new { @id = "Ref1", @class = "form-control input-sm select2 ref" })
                                    }
                                    if (Model.FieldMap[i].Field == "Ref2")
                                    {
                                        @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef2, new { @id = "Ref2", @class = "form-control input-sm select2 ref" })
                                    }
                                    if (Model.FieldMap[i].Field == "Ref3")
                                    {
                                        @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef3, new { @id = "Ref3", @class = "form-control input-sm select2 ref" })
                                    }
                                    if (Model.FieldMap[i].Field == "Ref4")
                                    {
                                        @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef4, new { @id = "Ref4", @class = "form-control input-sm select2 ref" })
                                    }
                                    if (Model.FieldMap[i].Field == "Ref5")
                                    {
                                        @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef5, new { @id = "Ref5", @class = "form-control input-sm select2 ref" })
                                    }
                                }
                                else
                                {
                                    <input class="form-control select2" id="@Model.FieldMap[i].Field" name="@Model.FieldMap[i].Field" type="text" value="">
                                }
                            </div>
                        }
                    }
                </div>


                <div class="box-footer clearfix">
                    <button type="submit" id="save" class="btn btn-success" tabindex="28">
                        <span class="glyphicon glyphicon-floppy-disk"></span> Update
                    </button>
                    <button type="button" class="btn btn-default" tabindex="29" onclick="@("window.location.href='" + @Url.Action("Index", "Leads") + "'");">Cancel</button>
                </div>
            }

        </div>
        <script>

       $('body').on('change', '#ddlCustomer', function (e) {
           $("#CustomerName").val($(this).text());
           $("#TaxRegNo").val($('#CustomerName').text());
       });
       $('body').on('change', '#ddlleadtype', function (e) {
           var CheckID = $(this).val();
           $("#SelProTask").val($(this).val());
           var itnote = false;
           $.ajax({
               url: '/ScopeOfWorkChecklist/GetCheckItems',
               dataType: 'json',
               data: { CheckID: $("#SelProTask").val() },
               cache: true,
               success: function (data) {
                   var lengt = data.length;
                   var checkdata = "";
                   $('#checklist2').html('');

                   var norepat = "";
                   $.each(data, function (i, item) {
                       var addnote = "";
                       checkdata = "<tr>"
                       var check = "";
                       var ck = "";
                       if (item.checkedornot == true)
                           check = "checked";
                       if (1 == 1) {
                           if (norepat != item.work) {
                               checkdata += "<tr><Td colspan='3'>" + item.work + "</td></tr>";
                               norepat = item.work;
                           }
                           checkdata += "<td style='width:50px;'><input name='bstmodel[" + (i) + "].Check' " + check + " id='checkbox_" + item.Id + "' type=\"checkbox\" name=\"note\" onchange='notechange(" + item.Id + ")'" + check + " ></input></td>" +
                               "<td><label for='" + item.Id + "'>" + item.Name + "</label></td>" +
                               "<input type='hidden' name='bstmodel[" + (i) + "].Id' data-name='Id' class='checkid_" + item.Id + "' value='" + item.Id + "' id='checkid_" + item.Id + "'/> " +

                               "</td>"
                               ;
                       }
                       else {
                           checkdata += "<td style='width:50px;'></td>" +
                               "<td><label for='" + item.Id + "'>" + item.Name + "</label></td>" +
                               "<input type='hidden' name='bstmodel[" + (i) + "].Id' data-name='Id' class='checkid_" + item.Id + "' value='" + item.Id + "' id='checkid_" + item.Id + "'/> " +
                               "</td>"
                               ;
                       }
                       if (item.Note != null)
                           addnote += "<td><textarea style='height:100px;width:200px;' data-name='Note' name='bstmodel[" + (i) + "].Note' id='addnote_" + item.Id + "' class='addnote_" + item.Id + " form-control text-left addnote' placeholder='Enter note'>" + item.Note + "</textarea></td> "
                       else
                           addnote += "<td><textarea style='height:100px;width:200px;' data-name='Note' name='bstmodel[" + (i) + "].Note' id='addnote_" + item.Id + "' class='addnote_" + item.Id + " form-control text-left addnote' placeholder='Enter note'></textarea></td> "

                       checkdata += addnote + "</tr><br />"
                       $('#checklist2').append(checkdata);
                   });
               }
           });
       });
       function notechange(arg) {
           ////$('#addnote_' + arg).prop
           ////var $input = $(obj);
           var $input = $('#checkbox_' + arg).prop('checked');
           if ($input) {
               $('#addnote_' + arg).show();
           }
           else {
               $('#addnote_' + arg).hide();
           }
       }
        </script>
    }
</div>
