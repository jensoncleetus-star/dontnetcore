                            </div>
                        </div>
                        <div class="form-group col-md-4">
                            @Html.LabelFor(model => model.TaxRegNo, htmlAttributes: new { @class = "control-label" })*
                            @Html.EditorFor(model => model.TaxRegNo, new { htmlAttributes = new { @class = "form-control", @required = "required", @placeholder = "Enter Lead Task", tabindex = 3 } })
                        </div>
                        <div class="form-group col-md-4">
                            @Html.Label("Remarks", null, htmlAttributes: new { @class = "control-label" })
                            @Html.EditorFor(model => model.Remark, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Lead Remark", tabindex = 3 } })
                        </div>
                        <div class="form-group col-md-4" style="display:none;">
                            @Html.LabelFor(model => model.LeadStat, htmlAttributes: new { @class = "control-label" })*
                            @if (User.IsInRole("Dev") || User.IsInRole("Create LeadStatus"))
                            {
                                <div class="input-group input-group-sm">
                                    @Html.DropDownListFor(model => model.CurrentAction, (SelectList)ViewBag.CurrentAction, new { @class = "form-control input-sm select2", tabindex = 12 })

                                    @Html.DropDownListFor(m => m.LeadStat, (SelectList)ViewBag.LeadStatus, new { id = "ddlLeadStatt", @class = "form-control select2", @required = "required", tabindex = 6, @style = "display:none;" })
                                    <span class="input-group-btn">
                                        <a href="/LeadStatus/Create" class="modal-add btn btn-success btn-flat" title="Add Lead Status"><i class="fa fa-1x fa-plus-circle"></i></a>
                                    </span>
                                </div>
                            }
                            else
                            {
                                @Html.DropDownListFor(model => model.CurrentAction, (SelectList)ViewBag.CurrentAction, new { @class = "form-control input-sm select2", tabindex = 12 })

                                @Html.DropDownListFor(m => m.LeadStat, (SelectList)ViewBag.LeadStat, new { id = "ddlLeadStatt", @class = "form-control select2", @required = "required", tabindex = 6, @style = "display:none;" })
                            }
                        </div>



                        <div class="container-fluid row" style="display:none">
                            <div class="form-group col-md-4">
                                @Html.LabelFor(model => model.CustomerCode, htmlAttributes: new { @class = "control-label" })*
                                @Html.EditorFor(model => model.CustomerCode, new { htmlAttributes = new { @class = "form-control", @required = "required", tabindex = 1 } })
                            </div>
                            <div class="form-group  col-md-4">
                                <label for="male">Lead Name*</label>
                                @* @Html.DropDownListFor(model => model.CustomerName, (SelectList)ViewBag.CustName, new { id = "CustomerNamelead", @class = "form -control input-sm select2", @required = "required", @placeholder = "Lead Name", tabindex = 2 })*@
                            </div>

                        </div>

                    </div>

                    <div class="container-fluid row">

                        <div class="form-group col-md-4" style="display:none">
