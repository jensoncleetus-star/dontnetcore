
@model QuickSoft.ViewModel.LeadsViewModel
@{
    ViewBag.Title = "Create";
    ViewBag.SubTitle = "Leads";
    ViewBag.Active = "Master";

}
<style>
    .modal {
        overflow: auto !important;
    }
</style>
<div class="box box-info container-fluid">
    @if(1==1)
    { 
        <div id="format2">
            @* <a href="javascript:void(0)" style="button" onclick="hideformat2()">Format 1</a>*@
            @using (Html.BeginForm("Create", "Leads", FormMethod.Post, new { id = "createForm", role = "form", enctype = "multipart/form-data" }))
            {

                <input type="hidden" value="@ViewBag.format" id="format" name="format" />
                <input type="hidden" id="SelProTask" />
                <input type="hidden" class="form-control" id="RowCount" value="0" placeholder="">
                <input type="hidden" class="form-control" id="documentRowcount" value="0" placeholder="">


                <div class="box-header with-border row">
                    <h4 class="card-title container-fluid"><b>LEADS</b></h4>
                    <div class="pull-right">

                        @if (@ViewBag.LastEntry != 0)
                        {
                            if (User.IsInRole("Dev") || User.IsInRole("Edit Leads"))
                            {
                                <a class="btn bg-black no-border" href="/Leads/Edit/@ViewBag.LastEntry">
                                    <i class="fa fa-step-backward"></i>
                                </a>
                            }
                        }
                        @if (User.IsInRole("Dev") || User.IsInRole("Leads List"))
                        {
                            <a class="btn btn-success no-border" href="/Leads">
                                <i class="fa fa-fw fa-history"></i> List
                            </a>
                        }
                    </div>
                </div>
                @Html.ValidationSummary("", new { @class = "alert alert-danger" })
                <br />
                <div class="box-body">

                    @*<br />*@


                    <div class="container-fluid row">
                        <div class="form-group  col-md-2">
                            @Html.Label("Date", null, htmlAttributes: new { @class = "control-label " })
                            <div class="input-group date">
                                <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                                @Html.TextBoxFor(m => m.StartDatee, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                            </div>
                        </div>
                        <div class="form-group col-md-4">
                            @Html.Label("Customer Name", null, htmlAttributes: new { @class = "control-label" })
                            <input id="CustomerName" name="CustomerName" value="" type="hidden" />
                            <div class="input-group input-group-sm">
                                @Html.DropDownListFor(m => m.CustomerID, (SelectList)ViewBag.Customer, new { id = "ddlCustomer", @class = "form-control select2", @placeholder = "Enter Customer", @required = "required" })
                                <span class="input-group-btn">
                                    <a href="/Customer/AddCustomer" class="modal-create btn btn-success btn-flat" title="Add Customer"><i class="fa fa-1x fa-plus-circle"></i></a>
                                </span>
                            </div>

                        </div>
                        @if (@ViewBag.EnableCRM == 0)
                        {

                            <div class="form-group col-md-4" style="display:none;">
                                @Html.LabelFor(model => model.SourceOfLead, htmlAttributes: new { @class = "control-label" })
                                @if (User.IsInRole("Dev") || User.IsInRole("Create SourceOfLead"))
                                {
                                    <div class="input-group input-group-sm">
                                        @Html.DropDownListFor(m => m.SourceOfLead, (SelectList)ViewBag.SrcOfLead, new { id = "ddlSrcLead", @class = "form-control select2", tabindex = 8 })
                                        <span class="input-group-btn">
                                            <a href="/SourceOfLead/Create" class="modal-create btn btn-default" title="Add SourceOfLead"><i class="glyphicon glyphicon-plus"></i></a>
                                        </span>
                                    </div>
                                }
                                else
                                {
                                    @Html.DropDownListFor(m => m.SourceOfLead, (SelectList)ViewBag.SrcOfLead, new { id = "ddlSrcLead", @class = "form-control select2", tabindex = 8 })
                                }
                            </div>
                        }
                        <div class="form-group col-md-4">
                            @Html.Label("Scope of work", null, htmlAttributes: new { @class = "control-label" })
                            @if (User.IsInRole("Dev") || User.IsInRole("Create LeadType"))
                            {
                                <div class="input-group input-group-sm">
                                    @Html.DropDownListFor(m => m.ScopeOfWork, (SelectList)ViewBag.LeadType, new { id = "ddlleadtype", @class = "form-control select2", @required = "required", tabindex = 6, @name = "LeadType[]", @multiple = "multiple" })

                                    <span class="input-group-btn">
                                        <a href="/LeadStatus/Create" class="modal-add btn btn-success btn-flat" title="Add Lead Status"><i class="fa fa-1x fa-plus-circle"></i></a>
                                    </span>
                                </div>
                            }
                            else
                            {

                                @Html.DropDownListFor(m => m.ScopeOfWork, (SelectList)ViewBag.LeadType, new { id = "ddlleadtype", @class = "form-control select2", @required = "required", tabindex = 6, @name = "LeadType[]", @multiple = "multiple" })
                            }
