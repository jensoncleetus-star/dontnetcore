@model QuickSoft.ViewModel.followupviewmodel
<iframe class="myiframe" id="leadiframe" src="/leads/myleads" frameborder="0" width="100%" height=""></iframe>
<br />

<iframe class="myiframe" id="amciframe" src="/amc/myamc" frameborder="0" width="100%" height=""></iframe"></iframe>
<br />
<iframe class="myiframe" id="amountiframe" src="/MyReports/ViewAmountReceivablePayable?ddlType=1&pdc=True&emp=@Model.empid.ToString()&ondate=@Model.dates" frameborder="0" width="100%" height=""></iframe>
<br />
<iframe class="myiframe" id="taskiframe" src="/ProTask/mytask" frameborder="0" width="100%" height=""></iframe>

@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")

    @Scripts.Render("~/js/bootstrap-fileinput")
    @Scripts.Render("~/js/bootstrap-sortable")
    @Scripts.Render("~/js/bootstrap-purify")
}
<script>
    $('.myiframe').on("load", function () {
        $('.myiframe').contents().find('.main-header').hide();
        $('.myiframe').contents().find('.main-sidebarr').hide();
        $('.myiframe').contents().find('.main-footer').hide();

    });


    $("#leadiframe").ready(function () {
