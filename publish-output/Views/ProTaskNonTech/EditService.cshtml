                <div class="clearfix visible-xs-block "></div>
                <div class=" form-group col-md-3">
                    @Html.LabelFor(m => m.CustomerName, new { @class = "control-label " })
                    @Html.EditorFor(model => model.CustomerName, new { htmlAttributes = new { @class = "form-control", @required = "required", @readonly = "readonly", @placeholder = "Enter Task Code" } })

                </div>
                <div class="form-group  col-md-3">
                    @Html.LabelFor(m => m.TaskName, new { @class = "control-label " })
                    @Html.EditorFor(model => model.TaskName, new { htmlAttributes = new { @class = "form-control", @required = "required", @readonly = "readonly", @placeholder = "Enter Task Code" } })

                </div>




                <div class="clearfix visible-xs-block "></div>

                <div class="form-group col-md-4" style="">
                    @Html.LabelFor(m => m.AssignedTo, new { @class = "control-label -from_top" })
