                        <div class="input-group date">
                            <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                            @Html.TextBoxFor(m => m.StartDate, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                        </div>
                        @Html.LabelFor(model => model.StartDate, htmlAttributes: new { @class = "control-label small-standalone-label" })
