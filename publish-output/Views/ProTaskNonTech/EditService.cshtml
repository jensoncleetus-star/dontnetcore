                                <i class="fa fa-clock-o"></i>
                            </div>
                        </div>

                    </div>

                </div>
                <div class="clearfix visible-xs-block "></div>

            </div>



            <div class="row">
                <div class="form-group col-md-3">


                    @Html.Label("Job Status", null, new { @class = "control-label" })
                    @Html.DropDownListFor(m => m.TaskStatus, (SelectList)ViewBag.Stat, "", new { id = "ddlPStatus22", @class = "form-control textwidth", @required = "required" })

                </div>
                <div class="form-group col-md-9">
                    @Html.Label("Remarks", null, new { @class = "control-label" })
                    @Html.TextAreaFor(m => m.TaskDetails, new { @class = "form-control input-sm textarea", @placeholder = "Enter Details..", rows = 5, @style = "height:100px;" })
                </div>



            </div>
