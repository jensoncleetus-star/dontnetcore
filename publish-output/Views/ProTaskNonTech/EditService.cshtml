        $('#createForm').on('submit', function (e) {
            e.preventDefault();
            var end_time = $("#EndTime").val();
            var start_time=$("#StartTime").val()
            var diff = (new Date("1970-1-1 " + end_time) - new Date("1970-1-1 " + start_time)) / 1000 / 60 / 60;
            var n = new Date(0, 0);
            n.setSeconds(+diff * 60 * 60);
            diff=n.toTimeString().slice(0, 8);

            var ok = confirm("Are yor sure you worked in "+diff+" hours.if not please check start and end time")

            var tsktype = '@ViewContext.RouteData.Values["type"]';
            if ($("#createForm").valid()&&ok) {
                var url = $('#createForm')[0].action;
                var formData = new FormData(this);

                $.ajax({
                    async: true,
                    cache: false,
                    dataType: "json",
                    type: "POST",
                    processData: false,
                    contentType: false,
                    url: url,
                    data: formData,//JSON.stringify(parameters),
                    beforeSend: function () {
                        $("button").prop('disabled', true); // disable button
                    },
                    success: function (e) {
                        if (e.status) {
                            printservicereport(e);
                            $('.ajax_response', res_success).text(e.message);
                            $('.AlertDiv').prepend(res_success);
                            window.location.href = '@Url.Action("MyTask", "ProTaskNonTech")';
                            @*if (tsktype == "MyTask")
                                window.location.href = '@Url.Action("MyTask", "ProTask")';
                            else {
                                window.location.href = '@Url.Action("Index", "ProTask")';
                            }*@
                        }
                        else {
                            $('.ajax_response', res_danger).text(e.message);
                            $('.AlertDiv').prepend(res_danger);
                            $("button").prop('disabled', false); // enable button
                        }
                    }
                });
            }
        });

            function printservicereport(e) {
                var originalpage = document.body.innerHTML;

                $("#zeal").hide();
                $("#lblBillNo").text(e.prdata.servicereportid);
                $("#lblDate").text(convertToDate(e.prdata.date));
                $("#lblCustomer").text(e.prdata.CustomerName);
                $("#lblContact").text();
                $("#lbladdress").text(e.prdata.Addres);
                $("#lblContactNumber").text();
                $("#lblemployee").text(e.prdata.Salesperson);
                $("#lbljobstatus").text(e.prdata.StatusName);
                $("#lblRemarks").html(e.prdata.remark);
                $("#lblstarttime").text(convertToTime(e.prdata.starttime));
                $("#lblendtime").text(convertToTime(e.prdata.endtime));
                var assto = "";
                $.each(e.prdata.AssignedTo, function (i, data) {
                    assto = assto + " , "+ data.FirstName + " " + data.LastName;
                });
                var str = "";
                var grandtotal = 0;
                var contactnumber = "";
                var contactperson = "";
                $.each(e.prdata.contacts, function (i, data) {
                    contactperson = contactperson + "," + data.FirstName;
                    contactnumber = contactnumber + "," + data.Mobile;
                });

                $("#lblContactNumber").text(contactnumber);
                $("#lblContact").text(contactperson);
                $.each(e.prdata.itemsused, function (i, data) {
                    str += "<tr>";
                    str += "<td>"+parseFloat(i+1)+"</td>";
                    str += "<td>" + data.ItemCode + "</td>";
                    str += "<td>" + data.ItemName + "</td>";
                    str += "<td>" + data.qty + "</td>";
                    str += "<td>" + data.ItemUnitName + "</td>";
                    //str += "<td>" + parseFloat(data.SellingPrice).toFixed(2) + "</td>";
                    //str += "<td>" + parseFloat(data.SellingPrice * data.qty).toFixed(2) + "</td>";
                    str += "</tr>";
                    grandtotal = grandtotal + parseFloat(data.SellingPrice * data.qty);
                });
                $("#itemused tbody").html(str);
                $("#totalamount").html(parseFloat(grandtotal).toFixed(2));


                $("#lbltechnicians").text(assto);
                var jobtype = "";
                if (e.prdata.jobtypes == "0")
                    jobtype = "AMC";
                else if (e.prdata.jobtypes == "1") {
                    jobtype = "Under Warrenty";
                }
                else if (e.prdata.jobtypes == "2") {
                    jobtype = "Paid Job";
                }

                $("#lbljobtype").text(jobtype);
                var paytype = "";
                if (e.prdata.paytype == "0")
                    paytype = "CASH";
                else if (e.prdata.paytype == "1") {
                    paytype = "CHEQUE";
                }
                else if (e.prdata.paytype == "2") {
                    paytype = "PENDING";
                }
                else if (e.prdata.paytype == "3") {
                    paytype = "BANK";
                }
                $("#lblpaytype").text(paytype);
                $("#lblamountrecieved").text(parseFloat(e.prdata.amount).toFixed(2));
                $("#lblcheckno").text(e.prdata.chequenumber);
                $("#lblbank").text(e.prdata.bankname);
                var printContent = $('#printit').html();
                $('title').html("Service Report - " + e.serviceid);
                $('body').html(printContent);

                window.print();

            }

        //Function to check correct format for Mobile Number
        //MobileNo is not passed in fetched rows(Edit Mode Rows)

    </script>
