    <script type="text/javascript">


        function paymenttype() {
            if ($("#paymenttypes").val() == 0) {
                $("#amountsec").show();
                $("#chequesec").hide();
            }
            else if ($("#paymenttypes").val() == 1) {
                $("#chequesec").show();
                $("#amountsec").hide();
            }
            if ($("#paymenttypes").val() >1) {
                $("#amountsec").hide();
                $("#chequesec").hide();
            }
        }




    function loadcontact(i, obj) {
        $('.mobilenumber').select2('destroy');
        var s = $("#Mobile" + i).val();
        s = s.replace(/^0+/, '');
        var opt = '<option value="' + s + '" selected>' + s + '</option>'
        $("#Mobile" + i).append(opt);
        mobileload();
        $.ajax({
            url: "/Customer/getcontactsbymobile",
            type: "GET",
            dataType: "JSON",
            data: { mobile: obj.value },
            success: function (result) {
                $("#firstname" + i).val(result[0].FirstName);
                $("#Website" + i).val(result[0].Website);
                $('.emailid').select2('destroy');
                var opt = '<option value="' + result[0].EmailId + '" selected>' + result[0].EmailId + '</option>'
                $("#EmailId" + i).append(opt);

                $("#EmailId" + i).val(result[0].EmailId);

                //$("#Mobile" + i).val(result[0].MobileNum);
                $("#CountryID" + i).val(result[0].CountryID);
                $("#Name" + i).val(result[0].Name + "," + result[0].Address);
                $("#lastname" + i).val(result[0].LastName);
                $("#ContactTypeID" + i).val(result[0].ContactTypeID);

                emailload();
            }
        });

        //Function to check correct format for Mobile Number
        CheckMobileNo(s, i);
    }

    function loadcontactemail(i, obj) {
        $.ajax({
            url: "/Customer/getcontactsbyemail",
            type: "GET",
            dataType: "JSON",
            data: { email: obj.value },
            success: function (result) {

                $("#firstname" + i).val(result[0].FirstName);
                $("#Website" + i).val(result[0].Website);
                $("#EmailId" + i).val(result[0].EmailId);
                $('.mobilenumber').select2('destroy');
                var opt = '<option value="' + result[0].MobileNum + '" selected>' + result[0].MobileNum + '</option>'
                $("#Mobile" + i).append(opt);

                //$("#Mobile" + i).val(result[0].MobileNum);
                $("#CountryID" + i).val(result[0].CountryID);
                $("#Name" + i).val(result[0].Name + "," + result[0].Address);
                $("#lastname" + i).val(result[0].LastName);
                $("#ContactTypeID" + i).val(result[0].ContactTypeID);

                mobileload();
            }
        });
    }

    var Countrys = '<option value="0">--Select--</option>';
    function callselect() {
        mobileload();
        emailload();
    }
    function mobileload() {
        $('.mobilenumber').select2({
            tags: true,
            placeholder: '5xxxxxxxx',
            minimumInputLength: 0,
            ajax: {
                url: "/Customer/SearchMobilecontact",
                dataType: 'json',
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term || "",
                        x: "All",
                        page: params.page || 0,
                    };
                },

                processResults: function (data, params) {

                    params.page = params.page || 1;

                    return {

                        results: data
                    };

                },
                cache: true
            },
        });
    }
    function emailload() {
        $('.emailid').select2({
            tags: true,

            minimumInputLength: 0,
            ajax: {
                url: "/Customer/SearchEmailcontact",
                dataType: 'json',
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term || "",
                        x: "All",
                        page: params.page || 0,
                    };
                },

                processResults: function (data, params) {

                    params.page = params.page || 1;

                    return {
                        results: data
                    };
                },
                cache: true
            },
        });
    }
    function checkmob(obj) {
        var val = $(obj).val()
        var reg = /^0/gi;
        if (val.match(reg)) {
            $(obj).val(val.replace(reg, ''));
        }
    }
