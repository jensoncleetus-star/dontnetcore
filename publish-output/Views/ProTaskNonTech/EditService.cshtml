                <div class="form-group col-md-2">
                    @Html.Label("Job", null, new { @class = "control-label" })
                    @Html.EnumDropDownListFor(model => model.jobtypes, new { @class = "form-control", @onchange = "" })

                </div>
                <div class="form-group col-md-2">
