                <div class="form-group col-md-2" id="amountsec">
                    @Html.LabelFor(m => m.amount, new { @class = "control-label " })
                    @Html.EditorFor(model => model.amount, new { htmlAttributes = new { @class = "form-control", @type = "number" } })

