<div class="box box-info">
    <input type="hidden" class="form-control" id="RowCount" value="0" placeholder="">
    @using (Html.BeginForm("EditServiceReport", "ProTaskNonTech", FormMethod.Post, new { id = "createForm", role = "form" }))
