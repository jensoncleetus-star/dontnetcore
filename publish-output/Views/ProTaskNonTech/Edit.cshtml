@model QuickSoft.ViewModel.ProTaskViewModel
@{
    ViewBag.Title = "Edit";
    ViewBag.SubTitle = "Edit Task";
    ViewBag.Active = "Master";

    string check = "";
    string url = "";
    string strImage = "";
    string partialconfig = "";
    var atype = Model.AssignType;
    
    int ci = 0;

}

<style>
  /*giving blue border to dropdowns------------------------*/
    /*multiselect dropdown*/
    span.select2-selection--multiple[aria-expanded=true] {
        border: 1px solid rgb(43 76 248 / 0.82) !important;
        transition: 0.1s;
    }
    /*single dropdown*/
    span.select2-selection--single[aria-expanded=true] {
        border: 1px solid rgb(43 76 248 / 0.82) !important;
        transition: 0.1s;
    }
    /*--------------------------------------------------------*/

</style>
<div class="box box-info">
    <input type="hidden" class="form-control" id="RowCount" value="0" placeholder="">
    @using (Html.BeginForm("Edit", "ProTaskNonTech", FormMethod.Post, new { id = "createForm", role = "form" }))
    {
        <div class="box-header with-border">
            <h3 class="box-title">Edit Task </h3>
            <div class="pull-right">
                @if (@ViewBag.preEntry != 0)
                {
                    if (User.IsInRole("Dev") || User.IsInRole("Edit ProTask"))
                    {
                        <a class="btn back-black" href="/ProTaskNonTech/Edit/@ViewBag.preEntry">
                            &nbsp;&nbsp;  <i class="fa fa-step-backward" style=""></i>&nbsp;&nbsp;
                        </a>

                    }
                }
                @if (@ViewBag.nxtEntry != 0)
                {
                    if (User.IsInRole("Dev") || User.IsInRole("Edit ProTask"))
                    {

                        <a class="btn back-black" href="/ProTaskNonTech/Edit/@ViewBag.nxtEntry">
                            &nbsp;&nbsp;  <i class="fa fa-step-backward" style=""></i>&nbsp;&nbsp;
                        </a>


                    }
                }
                else
                {
                    if (User.IsInRole("Dev") || User.IsInRole("Create ProTask"))
                    {

                        <a class="btn back-black" href="/ProTaskNonTech/Create">
                            &nbsp;&nbsp;  <i class="fa fa-step-backward" style=""></i>&nbsp;&nbsp;
                        </a>
                    }
                }

                @if (User.IsInRole("Dev") || User.IsInRole("ProTask List"))
                {

                    <a class="btn btn-outline-primary btn-fw list-blue" style="" href="/ProTaskNonTech">
                        &nbsp;&nbsp;&nbsp; <i class="fa fa-fw fa-history "></i>&nbsp; List&nbsp;&nbsp;&nbsp;
                    </a>
                }
            </div>
        </div>
        <div class="box-body">
            <div class="row" style="padding-top:5px;">
                @Html.ValidationSummary("", new { @class = "alert alert-danger" })
                <div class="form-group col-md-2 col-xs-6">

                    @Html.EditorFor(model => model.TaskCode, new { htmlAttributes = new { @class = "form-control", @required = "required", @placeholder = "Enter Task Code", @readonly = "readonly" } })
                    @Html.LabelFor(m => m.TaskCode, new { @class = "control-label small-standalone-label" })
                </div>
                <div class="form-group col-md-2 col-xs-6">

                    @Html.EnumDropDownListFor(model => model.Priority, new { @class = "form-control", @required = "required" })
                    @Html.LabelFor(m => m.Priority, new { @class = "control-label small-standalone-label" })
                </div>
                <div class="clearfix visible-xs-block "></div>
                <div class=" form-group col-md-4" style="">

                    @if (User.IsInRole("Dev") || User.IsInRole("Create Customer"))
                    {
                        <div class="input-group input-group-sm">
                            @Html.DropDownListFor(m => m.CustomerID, (SelectList)ViewBag.Customers, "", new { id = "ddlCustomer", @class = "form-control select2", @required = "required", @onchange = "loadcont(this)" })
                            <span class="">
                                <a href="/Customer/Create" class=" btn round-blue-button fa-stack" title="Create Customer" target="_new"> <i class="fa fa-circle fa-stack-1x white-bg-i"></i><i class="fa fa-2x fa-plus-circle fa-stack-2x"></i></a>
                            </span>
                        </div> }
                    else
                    {
                        @Html.DropDownListFor(m => m.CustomerID, (SelectList)ViewBag.Customers, new { id = "ddlCustomer", @class = "form-control select2", @required = "required", @onchange = "loadcont(this)" })}
                    @Html.LabelFor(model => model.CustomerID, new { @class = "control-label small-standalone-label" })
                </div>
                <div class="form-group col-md-4 ">
                    @*@Html.EditorFor(model => model.TaskName, new { htmlAttributes = new { @class = "form-control", @required = "required" } })*@

                    @Html.DropDownListFor(model => model.TaskName, (SelectList)ViewBag.TskName, new { @class = "form-control input-sm select2", @required = "required", tabindex = 2 })
                    @Html.LabelFor(m => m.TaskName, new { @class = "control-label small-standalone-label" })
                </div>
                <div class="form-group col-md-4">

                    @if (User.IsInRole("Dev") || User.IsInRole("Create ProTaskType"))
                    {
                        <div class="input-group input-group-sm">
                            @Html.DropDownListFor(m => m.TaskType, (SelectList)ViewBag.tskType, new { id = "ddlTaskType", @class = "form-control select2", @required = "required" })
                            <span class="">
                                <a href="/ProTaskType/Create" class="modal-add btn round-blue-button fa-stack" title="Create Customer" target="_new"> <i class="fa fa-circle fa-stack-1x white-bg-i"></i><i class="fa fa-2x fa-plus-circle fa-stack-2x"></i></a>
                            </span>
                        </div> }
                    else
                    {
                        @Html.DropDownListFor(m => m.TaskType, (SelectList)ViewBag.tskType, new { id = "ddlTaskType", @class = "form-control select2", @required = "required" })}
                    @Html.LabelFor(model => model.TaskType, htmlAttributes: new { @class = "control-label small-standalone-label" })
                </div>



                @if (1 == 1)
                {
                    <div class="col-md-4 form-group">

                        @if (User.IsInRole("Dev") || User.IsInRole("Create Project"))
                        {
                            <div class="input-group input-group-sm">
                                @Html.DropDownListFor(m => m.ProjectId, (SelectList)ViewBag.Project, "", new { id = "ddlProject", @class = "form-control select2", @required = "required" })
                                <span class="">
                                    <a href="/Project/AddProject" class="modal-project btn round-blue-button fa-stack" title="Create Customer" target="_new"> <i class="fa fa-circle fa-stack-1x white-bg-i"></i><i class="fa fa-2x fa-plus-circle fa-stack-2x"></i></a>
                                </span>
                            </div> }
                        else
                        {
                            @Html.DropDownListFor(m => m.ProjectId, (SelectList)ViewBag.Project, "", new { id = "ddlProject", @class = "form-control select2", @required = "required" })}
                        @Html.LabelFor(m => m.ProjectId, new { @class = "control-label small-standalone-label" })
                    </div>

                    <div class="form-group col-md-2 col-xs-6">

                        @if (User.IsInRole("Dev") || User.IsInRole("Create ProjectStatus"))
                        {
                            <div class="input-group input-group-sm">
                                @Html.DropDownListFor(m => m.TaskStatus, (SelectList)ViewBag.Stat, new { id = "ddlPStatus", @class = "form-control select2", @required = "required" })
                                <span class="input-group-btn">
                                    <a href="/TaskStatus/Create" class="modal-addnew btn btn-success btn-flat" title="Add Project Status"><i class="fa fa-1x fa-plus-circle"></i></a>
                                </span>
                            </div> }
                        else
                        {
                            @Html.DropDownListFor(m => m.TaskStatus, (SelectList)ViewBag.Stat, new { id = "ddlPStatus", @class = "form-control select2", @required = "required" })}
                        @Html.LabelFor(model => model.TaskStatus, htmlAttributes: new { @class = "control-label small-standalone-label" })
                    </div>}

                @if (Model.FieldMap.Count > 0)
                {
                    for (int i = 0; i < Model.FieldMap.Count; i++)
                    {
                        var fmap = "";
                        if (Model.FieldMap[i].Field == "Ref1")
                        {
                            fmap = Model.Ref1;
                        }
                        if (Model.FieldMap[i].Field == "Ref2")
                        {
                            fmap = Model.Ref2;
                        }
                        if (Model.FieldMap[i].Field == "Ref3")
                        {
                            fmap = Model.Ref3;
                        }
                        if (Model.FieldMap[i].Field == "Ref4")
                        {
                            fmap = Model.Ref4;
                        }
                        if (Model.FieldMap[i].Field == "Ref5")
                        {
                            fmap = Model.Ref5;
                        }

                        <div class="form-group col-md-2 col-xs-6">

                            @if (Model.FieldMap[i].Type == "Dropdown")
                            {
                                if (Model.FieldMap[i].Field == "Ref1")
                                {
                                    @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef1, new { @id = "Ref1", @class = "form-control input-sm select2 ref" }) }
                                if (Model.FieldMap[i].Field == "Ref2")
                                {
                                    @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef2, new { @id = "Ref2", @class = "form-control input-sm select2 ref" }) }
                                if (Model.FieldMap[i].Field == "Ref3")
                                {
                                    @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef3, new { @id = "Ref3", @class = "form-control input-sm select2 ref" }) }
                                if (Model.FieldMap[i].Field == "Ref4")
                                {
                                    @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef4, new { @id = "Ref4", @class = "form-control input-sm select2 ref" }) }
                                if (Model.FieldMap[i].Field == "Ref5")
                                {
                                    @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef5, new { @id = "Ref5", @class = "form-control input-sm select2 ref" }) }

                            }
                            else
                            {
                                <input class="form-control input-sm" id="@Model.FieldMap[i].Field" name="@Model.FieldMap[i].Field" type="text" value="@fmap">}
                            <label class="control-label small-standalone-label" for="FieldName"> @Model.FieldMap[i].FieldName</label>
                        </div>  }
                }
                <div class="clearfix visible-xs-block "></div>
                <div class="form-group col-md-4 col-xs-12">
                    @Html.LabelFor(m => m.driver, new { @class = "control-label small-standalone-label-from_top" })
                    @Html.DropDownListFor(m => m.driver, (SelectList)ViewBag.Employee, "", new { @id = "driver", @class = "form-control select2 porder" })

                </div>
                <div class="form-group col-md-4">
                    @Html.LabelFor(m => m.AssignType, new { @class = "control-label small-standalone-label-from_top l" })
                    @if (User.IsInRole("Dev") || User.IsInRole("Create Task Team"))
                    {
                        <div class="input-group input-group-sm">
                            @Html.DropDownListFor(m => m.AssignTypeAll, (MultiSelectList)ViewBag.AssignTypes, new { @class = "form-control select2", @name = "AssignTypeAll[]", @multiple = "multiple" })
                            <span class="">
                                <a href="/Team/Create" class="modal-create btn round-blue-button-mul fa-stack" title="Create Customer" target="_new"> <i class="fa fa-circle fa-stack-1x white-bg-i"></i><i class="fa fa-2x fa-plus-circle fa-stack-2x"></i></a>
                            </span>
                        </div> }
                    else
                    {
                        @Html.DropDownListFor(m => m.AssignTypeAll, (MultiSelectList)ViewBag.AssignTypes, new { @class = "form-control select2", @name = "AssignTypeAll[]", @multiple = "multiple" })}

                </div>
                <div class="form-group col-md-4">
                    @Html.LabelFor(m => m.AssignedTo, new { @class = "control-label small-standalone-label-from_top" })
                    @Html.ListBoxFor(m => m.AssignedMembers, (MultiSelectList)ViewBag.team, new { @id = "AssignedUsers", @class = "form-control select2", @name = "AssignedMembers[]", @multiple = "multiple" })

                </div>
                <div class="col-md-4 col-xs-12 form-group">

                    @if (User.IsInRole("Dev") || User.IsInRole("Create Sales Executive"))
                    {
                        <div class="input-group input-group-sm">
                            @if (Model.SalesPerson != null)
                            {
                                @Html.DropDownListFor(m => m.SalesPerson, (SelectList)ViewBag.Empl, new { id = "ddlEmployee", @class = "form-control select2" }) }
                            else
                            {
                                @Html.DropDownListFor(m => m.SalesPerson, (SelectList)ViewBag.Empl, "", new { id = "ddlEmployee", @class = "form-control select2" })}
                            <span class="input-group-btn">
                                <button type="button" href="/SalesExecutive/AddSalesExecutive" class="modal-edit btn btn-success btn-flat"><i class="fa fa-1x fa-plus-circle "></i></button>
                            </span>

                        </div> }
                    else
                    {
                        if (Model.SalesPerson != null)
                        {
                            @Html.DropDownListFor(m => m.SalesPerson, (SelectList)ViewBag.Empl, new { id = "ddlEmployee", @class = "form-control select2" }) }
                        else
                        {
                            @Html.DropDownListFor(m => m.SalesPerson, (SelectList)ViewBag.Empl, "", new { id = "ddlEmployee", @class = "form-control select2" })}
                    }
                    @Html.Label("Sales Person", null, new { @class = "control-label small-standalone-label" })
                </div>
            </div>
            <div class="row">


                <div class="form-group  col-md-2 col-xs-6" style="margin-bottom:8px;">

                    <div class="input-group date">
                        <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                        @Html.TextBoxFor(m => m.StartDate, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                    </div>
                    @Html.LabelFor(model => model.StartDate, htmlAttributes: new { @class = "control-label small-standalone-label" })
                </div>
                <div class="form-group col-md-2 col-xs-6">
                    <div class="bootstrap-timepicker">

                        <div class="input-group">
                            @Html.TextBoxFor(m => m.StartTime, "{0:hh:mm tt}", new { @class = "form-control timepicker", @autocomplete = "off", @value = "" })
                            <div class="input-group-addon">
                                <i class="fa fa-clock-o"></i>
                            </div>
                        </div>
                        @Html.LabelFor(m => m.StartTime, new { @class = "control-label small-standalone-label" })
                    </div>
                </div>
                <div class="clearfix visible-xs-block visible-sm-block "></div>
                <div class="form-group col-md-2 col-xs-6" style="margin-bottom:8px;">

                    <div class="input-group date">
                        <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                        @Html.TextBoxFor(m => m.EndDate, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                    </div>
                    @Html.LabelFor(model => model.EndDate, htmlAttributes: new { @class = "control-label small-standalone-label" })
                </div>
                <div class="form-group col-md-2 col-xs-6">
                    <div class="bootstrap-timepicker">

                        <div class="input-group">
                            @Html.TextBoxFor(m => m.EndTime, "{0:hh:mm tt}", new { @class = "form-control timepicker", @autocomplete = "off", @value = "" })
                            <div class="input-group-addon">
                                <i class="fa fa-clock-o"></i>
                            </div>
                        </div>
                        @Html.LabelFor(m => m.EndTime, new { @class = "control-label small-standalone-label" })
                    </div>

                </div>
                <div class="clearfix visible-xs-block "></div>
                <div class="form-group col-md-4">

                    @Html.DropDownListFor(m => m.Location, (SelectList)ViewBag.Local, new { @class = "form-control input-sm select2", @placeholder = "Enter Location" })
                    @Html.LabelFor(m => m.Location, new { @class = "control-label small-standalone-label" })
                </div>
                <div class="form-group col-md-4 col-xs-12">

                    @Html.EditorFor(model => model.Lattitude, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Lattitude", tabindex = 9, @type = "number" } })
                    @Html.LabelFor(model => model.Lattitude, htmlAttributes: new { @class = "control-label small-standalone-label" })
                </div>

                <div class="form-group col-md-4 col-xs-12">
                    @Html.EditorFor(model => model.Longitude, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Longitude", tabindex = 10, @type = "number" } })
                    @Html.LabelFor(model => model.Longitude, htmlAttributes: new { @class = "control-label small-standalone-label" })
                </div>
                <div class="col-md-4 col-xs-12 form-group">
                    @Html.DropDownListFor(model => model.OpenClose, (IEnumerable<SelectListItem>)ViewBag.OpnCls, new { @class = "form-control" })
                    @*@Html.DropDownListFor(model => model.OpenClose, (SelectList)ViewBag.OpnCls, new { @class = "form-control" })*@
                    @Html.Label("Open/Close", null, new { @class = "control-label small-standalone-label" })
                </div>
            </div>
            @if (ViewBag.BusiType == "Workshop")
            {
                <div class="row">
                    <div class="form-group col-md-4">
                        @Html.DropDownListFor(m => m.VehicleType, (SelectList)ViewBag.VehicleTypes, new { id = "ddlVehicleType", @class = "form-control select2", @required = "required" })
                        @Html.LabelFor(model => model.VehicleType, htmlAttributes: new { @class = "control-label small-standalone-label" })
                    </div>
                    <div class="form-group col-md-4">
                        @Html.DropDownListFor(m => m.VehicleManufacturer, (SelectList)ViewBag.VehicleManu, new { id = "ddlVehicleManufacturer", @class = "form-control select2", @required = "required" })
                        @Html.LabelFor(model => model.VehicleManufacturer, htmlAttributes: new { @class = "control-label small-standalone-label" })
                    </div>
                    <div class="form-group col-md-4">
                        @Html.DropDownListFor(m => m.VehicleModel, (SelectList)ViewBag.VehicleModels, new { id = "ddlVModel", @class = "form-control select2", @required = "required" })
                        @Html.LabelFor(model => model.VehicleModel, htmlAttributes: new { @class = "control-label small-standalone-label" })
                    </div>
                </div>
            }
            else
            {
                @Html.HiddenFor(model => model.VehicleModel)
                @Html.HiddenFor(model => model.VehicleManufacturer)
            }
            <div class="row">
                <div class="clearfix visible-xs-block "></div>
                <div class="form-group col-md-6 col-xs-12">
                    <div class="container-fluid" style="border: 1px solid rgba(0,0,0,0.09); border-radius: 20px; margin-top:10px; padding:10px;">
                        <div id="mobiles"></div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12 col-12 addcontact-center">
                    <button type="submit" style="" class="btn   btn-fw add_field_button addcontact-blue">Add Contact <i class="fa fa-plus-circle" style="margin-top:4px;" aria-hidden="true"></i>&ensp;</button>

                </div>
                <br>
                <div class="col-md-12 col-12">
                    <div class="form-group input_fields_wrap">

                        <table class="table table-condensed table-hover" id="contactTbl">

                            @{


                                if (Model != null && Model.LstContacts != null && Model.LstContacts.Count > 0)
                                {
                                    List<QuickSoft.Models.Country> CountryCodelist = ViewBag.CountryCodes;

                                    foreach (var item in Model.LstContacts.ToList())
                                    {
                                        <div class="remove" style=" border: 1px solid rgba(0,0,0,0.09); border-radius: 30px; margin-top:10px;">
                                            <div class="row" style="margin-top: 1rem;">
                                                <div class="col-md-2 col-xs-12">
                                                    <label class="control-label">Country Code</label>
                                                    <div class="input-group">
                                                        <select id="Type" class="form-control" name="LstContacts[@ci].CountryID">
                                                            @{
                                                                foreach (var data in CountryCodelist)
                                                                {
                                                                    if (data.CountryID == item.CountryID)
                                                                    {
                                                                        <option value="@data.CountryID" selected="selected">@data.CountryName (@data.CountryCode)</option>
                                                                    }
                                                                    else
                                                                    {
                                                                        <option value="@data.CountryID">@data.CountryName (@data.CountryCode)</option>
                                                                    }
                                                                }
                                                            }

                                                        </select>
                                                        @*<input type="text" value="@item.Country" name="LstContacts[@ci].Country" class="form-control">*@
                                                    </div>
                                                </div>
                                                <div class="clearfix visible-xs-block "></div>
                                                <div class="col-md-3">
                                                    <label class="control-label">Mobile Number( W/O Country code) </label>
                                                    <div class="input-group">
                                                        @*<input type="text" value="@item.Mobile" name="LstContacts[@ci].Mobile" class="form-control">*@
                                                        <input type="text" value="@item.Mobile" name="LstContacts[@ci].Mobile" class="form-control Mobile" id="Mobile[@ci]" placeholder="5xxxxxxxx" onchange="CheckMobileNo('', @ci)">
                                                        <input type="hidden" value="EditMode" id="MobileHidden @ci" class="MobileHidden">
                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="control-label">Email Id</label>
                                                    <div class="input-group">
                                                        <input type="email" value="@item.EmailId" name="LstContacts[@ci].EmailId" class="form-control">
                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="control-label">Website</label>
                                                    <div class="input-group">
                                                        <input type="text" value="@item.Website" name="LstContacts[@ci].Website" class="form-control">
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="row" style="margin-top: 1rem;">
                                                <div class="col-md-2" hidden style="display: none;">
                                                    <label class="control-label">id</label>
                                                    <div class="input-group">
                                                        <input type="text" value="@item.ContactID" name="LstContacts[@ci].ContactID" class="form-control">
                                                    </div>
                                                </div>
                                                <div class="col-md-2 col-xs-12">
                                                    <label class="control-label">Contact Type </label>
                                                    <div class="input-group">
                                                        @*<input type="hidden" name="LstContacts[@(di)].ContactId" value="@item.ContactID" id="docu" />*@
                                                        <select id="Type" class="form-control" name="LstContacts[@ci].ContactTypeID">
                                                            @{
                                                                List<QuickSoft.Models.ContactType> typelist = ViewBag.TypeList;

                                                                foreach (var data in typelist)
                                                                {
                                                                    if (data.ContactId == item.ContactTypeID)
                                                                    {
                                                                        <option value="@data.ContactId" selected="selected">@data.Type</option>
                                                                    }
                                                                    else
                                                                    {
                                                                        <option value="@data.ContactId">@data.Type</option>
                                                                    }
                                                                }
                                                            }

                                                        </select>
                                                    </div>
                                                </div>
                                                <div class="clearfix visible-xs-block "></div>
                                                <div class="col-md-3">

                                                    <label class="control-label">First Name</label>
                                                    <div class="input-group">

                                                        <input type="text" name="LstContacts[@ci].FirstName" class="form-control" value="@item.FirstName" required>

                                                    </div>

                                                </div>
                                                <div class="col-md-3">

                                                    <label class="control-label">Last Name</label>
                                                    <div class="input-group">

                                                        <input type="text" name="LstContacts[@ci].LastName" class="form-control" value="@item.LastName">

                                                    </div>

                                                </div>
                                                <div class="col-md-3 col-xs-10">
                                                    <label class="control-label">Company Name</label>
                                                    <div class="input-group">

                                                        <input type="text" name="LstContacts[@ci].Name" class="form-control" value="@item.Name">

                                                    </div>

                                                </div>
                                                <div class="col-md-1 col-xs-2 my-auto">
                                                    <a href="javascript:void(0);" class="remove_button"><i style="color:red;margin-top:25px;margin-left: 20px; " class="fa fa-trash fa-lg" aria-hidden="true"></i></a>

                                                </div>

                                            </div>
                                            <br>
                                        </div>


                                        ci++;

                                    }
                                }
                            }
                        </table>


                    </div>
                </div>
                <br>
            </div>


            <div class="row">
                <div class="form-group col-md-6">
