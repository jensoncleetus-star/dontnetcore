        function loadcontact(i, obj) {
            $('.mobilenumber').select2('destroy');
            var s = $("#Mobile" + i).val();
            s = s.replace(/^0+/, '');
            var opt = '<option value="' + s + '" selected>' + s + '</option>'
            $("#Mobile" + i).append(opt);
            mobileload();
            $.ajax({
                url: "/Customer/getcontactsbymobile",
                type: "GET",
                dataType: "JSON",
                data: { mobile: obj.value },
                success: function (result) {
                    $("#firstname" + i).val(result[0].FirstName);
                    $("#Website" + i).val(result[0].Website);
                    $('.emailid').select2('destroy');
                    var opt = '<option value="' + result[0].EmailId + '" selected>' + result[0].EmailId + '</option>'
                    $("#EmailId" + i).append(opt);

                    $("#EmailId" + i).val(result[0].EmailId);

                    //$("#Mobile" + i).val(result[0].MobileNum);
                    $("#CountryID" + i).val(result[0].CountryID);
                    $("#Name" + i).val(result[0].Name + "," + result[0].Address);
                    $("#lastname" + i).val(result[0].LastName);
                    $("#ContactTypeID" + i).val(result[0].ContactTypeID);

                    emailload();
                }
            });

            //Function to check correct format for Mobile Number
            CheckMobileNo(s, i);
        }

