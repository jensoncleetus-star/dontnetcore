    @{var vModel = "modal-lg";}
    @Html.Partial("../Common/_ModalCreate", @vModel)
    <script>
    $('div').on('click', '.modal-create', function (e) {
        e.preventDefault();
        var url = $(this).attr('href');
        modalshow(url, '#modal-create');
    });
            $('#modal-create').on('submit', '#AssignForm', function (e) {
            e.preventDefault();
            var tsktype = '@ViewContext.RouteData.Values["type"]';
            if ($("#AssignForm").valid()) {
                var url = $('#AssignForm')[0].action;
                var formData = new FormData(this);

                $.ajax({
                    async: true,
                    cache: false,
                    dataType: "json",
                    type: "POST",
                    processData: false,
                    contentType: false,
                    url: url,
                    data: formData,
                    beforeSend: function () {
                        $("button").prop('disabled', true);
                    },
                    success: function (e) {
                        if (e.status) {
                            $('.ajax_response', res_success).text(e.message);
                            $('.AlertDiv').prepend(res_success);
                            $('#modal-create').modal('hide');
                            $('#modal-create .modal-content').html('');
                            oTable.draw();
                        }
                        else {
                            $('.ajax_response', res_danger).text(e.message);
                            $('.AlertDiv').prepend(res_danger);
                            $("button").prop('disabled', false);
                        }
                    }
                });
            }
        });
    </script>
    <div><h3>Note : Marker red Customer,Marker blue Amc,Marker green Task </h3></div>
    <div class="row">
        <div class="col-md-2"><strong>Search</strong></div>
        <div class="col-md-6"><input type="text" name="srchtxt" value="" onkeyup="filterMarkers(this.value)" /></div>
    </div>
    <div id="map" style="position:fixed !important"></div>



