@model QuickSoft.Models.EmailTemplate
@{
    ViewBag.Title = "Create Email Template";
    ViewBag.SubTitle = "Email Template";
    ViewBag.Active = "Settings";
}
    @using (Html.BeginForm("Create", "EmailTemplate", FormMethod.Post, new { id = "popupFormCreate" }))
    {

        <div class="box box-info">
            <div class="box-header with-border">
                <h3 class="box-title">Create Email Template</h3>
                <div class="pull-right">
                    <a class="btn btn-success no-border" href="/EmailTemplate">
                        <i class="fa fa-fw fa-history"></i>Email Template List
                    </a>
                </div>
            </div>
            <div class="box-body">
                @Html.ValidationSummary("", new { @class = "alert alert-danger" })
                @Html.AntiForgeryToken()
                <div class="row">
                    <div class="form-group col-md-12">
                        @Html.LabelFor(m => m.Head, new { @class = "control-label" }) *
                        @Html.TextBoxFor(m => m.Head, new { @class = "form-control input-sm", @placeholder = "Enter Head.." })

                    </div>
                    <div class="form-group col-md-12">
                        @Html.LabelFor(m => m.Subject, new { @class = "control-label" }) *
                        @Html.TextBoxFor(m => m.Subject, new { @class = "form-control input-sm", @placeholder = "Enter Subject.." })

                    </div>
                    <div class="form-group col-md-12">
                        @Html.LabelFor(m => m.EmailBody, new { @class = "control-label" })*
                        @Html.TextAreaFor(m => m.EmailBody, new { @class = "form-control input-sm", @placeholder = "Enter Email Body..", @rows = 10 })
                    </div>
                </div>
                <div class="row">
                    <div class="form-group col-md-12">
                        <input type="submit" class="btn btn-info col-sm-offset-5" value="Save" />
                        <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" id="btnreset" tabindex="20" />
                    </div>
                </div>
                </div>
            </div>
    }

@section scripts{
    @Scripts.Render("~/js/ckeditor")
    @Scripts.Render("~/js/jqueryval")
    <script type="text/javascript">
        $(document).ready(function () {
            $(function () {
                CKEDITOR.replace('EmailBody');
            });
        });
    </script>
}



