@model QuickSoft.ViewModel.StockTransferViewModel
@{
    Layout = null;
}
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Stock Transfer Details</h4>
</div>
<div class="modal-body">
    <div class="box box-info">
        <div class="box-body">
            <div class="row">
                <div class="col-sm-2 form-group ">
                    @Html.Label("Voucher No :", null, new { @class = "control-label" })
                    @Html.DisplayFor(m => m.Voucher)
                </div>
                </div>
                <div class="col-sm-2 form-group">
                    @Html.Label("Date :", null, new { @class = "control-label" })
                    @Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.Date))
                    @*@Html.DisplayFor(m => m.SEDate)*@
                </div>
                <div class="col-sm-2 form-group">
                    @Html.Label("Material Center From :", null, new { @class = "control-label" })
                    @Html.DisplayFor(m => m.From)
                </div>
                <div class="col-sm-2 form-group">
                    @Html.Label("Material Center To :", null, new { @class = "control-label" })
                    @Html.DisplayFor(m => m.To)
                </div>
            <div class="col-sm-12 form-group">
                @if (Model.Emp != null && Model.Emp.Count() > 0)
                {
                    @Html.Label("Approved By:", null, new { @class = "control-label" })
                    bool CHECK = true;
                    foreach (var Ext in Model.Emp)
                    {
                        var EmpName = "";
                        if (CHECK == true)
                        {
                            EmpName = @Ext.EmpName;
                            CHECK = false;
                        }
                        else
                        {
                            EmpName = ", " + @Ext.EmpName;
                        }

                        @Html.Label(@EmpName, new { @style = "font-weight:normal" })
                    }
                }
            </div>
            @if (Model.FieldMap.Count > 0)
            {
                for (int i = 0; i < Model.FieldMap.Count; i++)
                {
                    <div class="form-group col-sm-2">

                        @if (Model.FieldMap[i].FieldName != "" && Model.FieldMap[i].Field == "Ref1")
                        {
                            <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName :</label>
                                @Html.DisplayFor(m => m.Ref1)
                        }
                        @if (Model.FieldMap[i].FieldName != "" && Model.FieldMap[i].Field == "Ref2")
                        {
                            <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName :</label>
                                @Html.DisplayFor(m => m.Ref2)
                        }
                        @if (Model.FieldMap[i].FieldName != "" && Model.FieldMap[i].Field == "Ref3")
                        {
                            <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName :</label>
                                @Html.DisplayFor(m => m.Ref3)
                        }
                        @if (Model.FieldMap[i].FieldName != "" && Model.FieldMap[i].Field == "Ref4")
                        {
                            <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName :</label>
                                @Html.DisplayFor(m => m.Ref4)
                        }
                        @if (Model.FieldMap[i].FieldName != "" && Model.FieldMap[i].Field == "Ref5")
                        {
                            <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName :</label>
                                @Html.DisplayFor(m => m.Ref5)
                        }
                    </div>
                }
            }
                <div class="clearfix"></div>
            </div>
        <div>
            <div class="table-responsive">

                @*<div class="box-header with-border">
                    <h3 class="box-title">Stock Transfer Details</h3>
                </div>*@
                <div class="box-body">
                    <table class="table table-bordered table-hover">
                        <tr class="bg-gray">
                            <th>Item</th>
                            <th>Unit</th>
                            <th>Quantity</th>
                            <th>Price</th>
                            <th>Amount</th>
                        </tr>
                        @foreach (var Payit in Model.STItem)
                        {

                            <tr>
                                <td>@Payit.Itemname</td>
                                <td>@Payit.Unitname</td>
                                <td>@Payit.Quantity</td>
                                <td>@Payit.Price</td>
                                <td>@Payit.Amount</td>
                            </tr>
                        }
                    </table>
                </div>
            </div>
          
            <div class="col-md-4 pull-right">
                @*<div class="form-group col-md-6 no-paddingleft">
                    @Html.Label("Discount :", null, new { @class = "control-label" })
                    @Html.DisplayFor(m => m.SEDiscount)
                </div>*@
                <div class="form-group col-md-6 no-padding">
                    @Html.Label("Grand Total :", null, new { @class = "control-label" })
                    @Html.DisplayFor(m => m.TotalAmount)
                </div>
            </div>
            <div class="row">
                <div class="col-md-10">
                    <div class="form-group">
                        <strong>Remarks </strong><br />
                        @Model.Remarks
                    </div>
                </div>

            </div>
        </div>

            </div>
        </div>
    </div>
</div>
