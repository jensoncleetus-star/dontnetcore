                { "data": "User", "name": "User" },
                 {
                     "name": "ApprovalStatus", "data": function (data, type, dataToSet) {
                         var status = "";
                         var cls = "";
                         if (data.app.length > 0 || (data.Approval == true && '@ViewBag.MLASTran' == 'active')) {
                             if (data.ApprovalStatus == "0") {
                                 status = '<span class="badge bg-green">Approved</span>';
                             }
                             else if (data.ApprovalStatus == "1") {
                                 status = '<span class="badge bg-red">Rejected</span>';
                             }
                             else if (data.ApprovalStatus == "2") {
                                 status = '<span class="badge bg-orange">Pending</span>';
                             }
                             return '<a  class="Updation" onclick="details(' + data.Id + ')"  title="View Status">' + status + ' </a>';
                         } else { return null; }
                     }
                 },
                    {
                        "name": "Id", "data": function (data) {
                            var rest = "";

                            @{
                                //if (User.IsInRole("Dev") || User.IsInRole("View STockTransfer"))
                                {
                                    actData += "<a class=\"details\" href=\"/STockTransfer/Details/'+ data.Id +'\" title=\"View STockTransfer Entry\"><i class=\"fa fa-lg fa-search-plus\"></i></a> ";
                                }
                                //if (User.IsInRole("Dev") || User.IsInRole("Edit StockTransfer"))
                                //{
                                //    actData += "<a href=\"/STockTransfer/Edit/'+ data.Id +'\" title=\"Edit Entry\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                                //}
                                if (User.IsInRole("Dev") || User.IsInRole("Delete StockTransfer"))
                                {
                                    actData += "<a class=\"modal-delete\" href=\"/STockTransfer/Delete/'+ data.Id +'\" title=\"Delete Entry\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";
                                }
                                if (User.IsInRole("Dev") || User.IsInRole("Download StockTransfer"))
                                {
                                    actData += "<a class=\"modal-link-download\" href=\"/StockTransfer/Download/'+ data.Id +'\" title=\"Download StockTransfer\"><i class=\"fa-lg fa fa-download\" ></i></a> ";
                                }
                                {
                                    actData += "<a class=\"detailss\" href=\"/LogDetails/?TransId='+ data.Id +'&TransType='+ 'StockTransfer' +'\" title=\"View Stock Transfer History\" target=\"new\"><i class=\"fa fa-lg fa-history\"></i></a> ";
                                }

                            }
                            rest += '@Html.Raw(actData)';
                            if (data.validornot == "valid") {
                                //data.CreatedUserToEdit == true
                                if (1==1) {
                           @{
                               if (User.IsInRole("Dev") || User.IsInRole("Edit StockTransfer"))
                               {
                                   actData = "";
                                   actData += "<a href=\"/STockTransfer/Edit/'+ data.Id +'\" title=\"Edit Entry\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                               }
                           }
                                    rest += '@Html.Raw(actData)';
                                }
                            }
                            else {
                                //data.CreatedUserToEdit == true
                                if (1==1) {
                               @{
                                   if (User.IsInRole("Dev") || User.IsInRole("Edit StockTransfer"))
                                   {
                                       actData = "";
                                       actData += "<a href=\"#\" onclick=\"AlertFunction(' + data.userEditDays + ')\" title=\"\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";
                                   }
                               }
                                    rest += '@Html.Raw(actData)';
                                }
                            }
                            if ('@ViewBag.StockTrnsfrUpdate' == 'active') {

                                if (data.Approval == true) {//&& '@ViewBag.MLASTran' == 'active'
                                @{
                                 actData = "";
                                 actData = "<a class=\"modal-edit\"  href=\"/StockTransfer/EditStatus/'+ data.Id  +'\" title=\"Edit Status\"><i class=\"fa fa-lg fa-refresh\" ></i></a> ";

                             }
                                    rest += '@Html.Raw(actData)';
                                }
                            } else {
                                 if (data.Approval == true && '@ViewBag.MLASTran' == 'active') {
                                @{
                                 actData = "";
                                 actData = "<a class=\"modal-edit\"  href=\"/StockTransfer/EditStatus/'+ data.Id  +'\" title=\"Edit Status\"><i class=\"fa fa-lg fa-refresh\" ></i></a> ";

                             }
                                    rest += '@Html.Raw(actData)';
                                }
                            }
                            if ("@ViewBag.Remind" == "active") {
                                @{
                                   actData = "";
                                   actData += "<a class=\"UpdationRe\" onclick=\"detailsRemind(' + data.Id + ')\" title=\"View Reminder\"><i class=\"fa-lg fa fa-bell\" ></i></a> ";
                                   actData += "<a class=\"modal-create\" href=\"/Reminder/AddReminder/'+ data.Id +'/StkTrans\" title=\"Add Reminder\"><i class=\"fa-lg fa fa-sticky-note\" ></i></a> ";
                               }
                                rest += '@Html.Raw(actData)';
                            }
                            return rest;
                        }
                    },
                     {
                         "name": "Id", "data": function (data) {
                             var rest = "";
                             @{
                                 if (User.IsInRole("Dev") || User.IsInRole("Delete StockTransfer"))
                                 {
                                     delchk = "<input class=\"checkbox\" type=\"checkbox\" name=\"bill[]\" value='+ data.Id +'></input>";
                                 }
                             }
                             return rest = '@Html.Raw(delchk)';
                         }
                     },
            ],
