@model QuickSoft.ViewModel.StockTransferViewModel
@{
    ViewBag.Title = "List";
    ViewBag.SubTitle = "StockTransfer List";
    ViewBag.Active = "Transactions";
    string actData = "";
    bool userRole = false;
    string delchk = "";
    string deleteBTn = "";

    if (User.IsInRole("Dev") || User.IsInRole("Delete StockTransfer"))
    {
        userRole = true;
        deleteBTn = "{text: 'Delete', className: 'btn-danger', action: function(e, dt, node, config) {" +
            "if ($('.checkbox:checked').length > 0) {if (confirm('Are you sure you want to delete this?')) {$('#STransferForm').submit(); e.preventDefault();} " +
             "} else {alert('Please Select Rows..!!');e.preventDefault();}}},";
    }
}

<style type="text/css">

    .dropdown-check-list {
        display: inline-block;
    }

        .dropdown-check-list .anchor {
            position: relative;
            cursor: pointer;
            display: inline-block;
            padding: 5px 50px 5px 10px;
            border: 1px solid #ccc;
            width: 150px;
            background: #fff;
            text-align: center;
        }

            .dropdown-check-list .anchor:after {
                position: absolute;
                content: "";
                border-left: 2px solid black;
                border-top: 2px solid black;
                padding: 5px;
                right: 10px;
                top: 20%;
                -moz-transform: rotate(-135deg);
                -ms-transform: rotate(-135deg);
                -o-transform: rotate(-135deg);
                -webkit-transform: rotate(-135deg);
                transform: rotate(-135deg);
            }

            .dropdown-check-list .anchor:active:after {
                right: 8px;
                top: 21%;
            }

        .dropdown-check-list ul.items {
            padding: 0px;
            display: none;
            margin: 0;
            border: 1px solid #ccc;
            border-top: none;
            position: absolute;
            z-index: 9999;
        }

            .dropdown-check-list ul.items li {
                list-style: none;
                background: #fff;
                padding: 5px;
            }

    .add-btn-item {
        border-radius: 23px;
        padding: 6px 20px;
    }

    .dropdown-check-list.visible .anchor {
        color: #0094ff;
    }

    .dropdown-check-list.visible .items {
        display: block;
    }
</style>

<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">List Stock Transfer</h3>
        <div class="pull-right">
            <i class="ace-icon fa fa-hand-o-right icon-animated-hand-pointer blue"></i>
            @if (User.IsInRole("Dev") || User.IsInRole("StockTransfer Entry"))
            {
                <a class="btn btn-info no-border" href="/StockTransfer/Create">
                    <i class="glyphicon glyphicon-plus"></i> Create
                </a>
            }
        </div>

        <div class="row">
            <div class="col-md-2">
                <div id="list1" class="dropdown-check-list" tabindex="100">
                    <span class="anchor" style="z-index:0;">Select Fields</span>
                    <ul class="items">
                        <li><input type="checkbox" id="livoucher" />Voucher</li>
                        <li><input type="checkbox" id="licntrfrm" />Material Center From</li>
                        <li><input type="checkbox" id="licntrto" />Material Center To</li>
                        <li><input type="checkbox" id="lifromdate" />From Date</li>
                        <li><input type="checkbox" id="litodate" />To Date</li>
                        <li><input type="checkbox" id="liapprvlstatus" />Approval Status</li>
                    </ul>
                </div>
            </div>

            <div class="col-md-12">
                <div class="box-body search-box" id="advsearchlist">
                    <div class="search-body col-md-12" style="background:none;">
                        <form id="search-form">
                            <div class="row">
                                <input type="hidden" id="remId" />
                                <div class="form-group col-md-2" id="searchvoucher">
                                    @Html.Label("Voucher", null, new { @class = "control-label" })
                                    @Html.TextBox("Voucher", "", new { @class = "form-control input-sm" })
                                </div>
                                <div class="form-group col-md-2" id="searchcntrfrm">
                                    @Html.Label("Material Center From", null, new { @class = "control-label" })
                                    @Html.DropDownList("MCFrom", (SelectList)ViewBag.MCBag, "All", new { @class = "form-control select2" })
                                </div>
                                <div class="form-group col-md-2" id="searchcntrto">
                                    @Html.Label("Material Center To", null, new { @class = "control-label" })
                                    @Html.DropDownList("MCTo", (SelectList)ViewBag.MCBag, "All", new { @class = "form-control select2" })
                                </div>
                                <div class="form-group col-md-2" id="searchfromdate">
                                    @Html.Label("From Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("FromDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group col-md-2" id="searchtodate">
                                    @Html.Label("To Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("ToDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>
                                @if (ViewBag.MLASTran == 0)
                                {
                                    <div class="form-group col-md-2" id="searchapprovalstatus">
                                        @Html.Label("Approval Status", null, new { @class = "control-label" })
                                        @Html.DropDownList("ApprovalStatus", (SelectList)ViewBag.AppStat, "All", new { id = "ApprovalStatus", @class = "form-control" })
                                    </div>
                                }

                                <div class="form-group col-md-2" id="search">
                                    <input type="submit" class="btn btn-submit" value="Submit" />
                                </div>
                                <div class="form-group col-md-2" id="close">
                                    <input type="button" class="btn btn-close" value="Close" />
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @using (Html.BeginForm("DeleteAll", "StockTransfer", FormMethod.Post, new { id = "STransferForm", role = "form" }))
    {
        <div class="box-body">
            <table class="table table-bordered table-hover" id="SalesTable">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="1">S/N</td>
                        <td data-priority="1">Voucher No</td>
                        <td data-priority="2">Date</td>
                        <td data-priority="1">Stock Transferred From</td>
                        <td data-priority="4">Stock Transferred To</td>
                        <td data-priority="3">Remarks</td>
                        <td data-priority="3" class="headeralign">Amount</td>
                        <td data-priority="5">Created By</td>
                        <td data-priority="3">Approval Status</td>
                        <td data-priority="2">Action</td>
                        <td data-priority="1"><input type="checkbox" id="select_all" /></td>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    }

    <div id="modal-container2" class="modal fade" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-aqua">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                    <h4>Status Updation History</h4>
                </div>
                <div class="modal-body">
                    <table class="table table-bordered table-hover" id="UserTableInfo">
                        <thead>
                            <tr class="bg-aqua">
                                <td>Status</td>
                                <td>Updated By</td>
                                <td>Requested By</td>
                                <td>Date</td>
                                <td>Remarks</td>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
