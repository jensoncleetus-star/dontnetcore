

@using QuickSoft.Models
@using QuickSoft.ViewModel
@model QuickSoft.ViewModel.BalanceSheetViewModel
@{
    ViewBag.Title = "Search Trial Balance";
    ViewBag.SubTitle = "Trial Balance Report";
    ViewBag.Active = "Accounts";

    decimal? DTAmount = 0;
    decimal? CTAmount = 0;
}
<div class="box box-default" id="LReport">
    <div class="box-header with-border">
        <h3 class="box-title">Trial Balance Report</h3>
    </div>
    <div class="box-body">
        <input type="hidden" id="cname" value="@ViewBag.CName" />
        <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
        <input type="hidden" id="fromdate" value="@Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.from))" />
        <input type="hidden" id="todate" value="@Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.to))" />
        <table class="table table-bordered table-hover" id="UserTable" style="width:100%">
            <thead>
                <tr class="bg-gray">
                    <td class="text-center" colspan="3">
                        From : @Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.from))
                        Date: @Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.to))
                    </td>
                </tr>
                <tr class="bg-gray">
                    <td>Particulars</td>
                    <td class="text-center">
                        DEBIT ( AED )
                    </td>
                    <td class="text-center">
                        CREDIT ( AED )
                    </td>
                </tr>
            </thead>
            <tbody>
                @if (Model.TrialBalanceDisplay != null)
                {
                    if (Model.TrialBalanceDisplay.Any())
                    {
                        int TotCount = 0;
                        foreach (var item in Model.TrialBalanceDisplay)
                        {
                            decimal? AmountCr = 0;
                            decimal? AmountDr = 0;
                            decimal? Debit = 0;
                            decimal? Credit = 0;

                            Debit = item.Debit;
                            AmountDr = (Debit);
                            AmountDr = AmountDr != null ? AmountDr : 0;

                            Credit = item.Credit;
                            AmountCr = (Credit);
                            AmountCr = AmountCr != null ? AmountCr : 0;

                            <tr>
                                @if (item.Parent == 0)
                                {
                                    <td class="text-red notin">@item.Particular</td>
                                    if (item.AccType == "asset" && item.AccountsGroupID != 7 && item.Parent != 7)
                                    {
                                        if (Debit.Value > 0)
                                        {
                                            <td class="text-right">@(@Debit-@Credit)</td>
                                        }
                                        else
                                        {
                                            <td></td>
                                        }
                                        <td></td>
                                        DTAmount += AmountDr - AmountCr;
                                    }
                                    if (item.AccType == "liability" && item.AccountsGroupID != 7 && item.Parent != 7)
                                    {
                                        <td></td>
                                        if (Credit.Value > 0)
                                        {
                                            <td class="text-right">@Credit.Value.ToString("0.00")</td>
                                        }
                                        else
                                        {
                                            <td></td>
                                        }
                                        CTAmount += AmountCr;
                                    }
                                    if (item.AccountsGroupID == 7 || item.Parent == 7)
                                    {
                                        <td></td>
                                        <td></td>
                                    }

                                }
                                else
                                {
                                    if (item.Parent == item.AccountsGroupID)
                                    {
                                        <td class="text-red notin">@item.Particular</td>
                                    }
                                    else
                                    {
                                        
                                        <td>&nbsp;&nbsp;<a href="/BalanceSheet/GetGroupTrialBalancetrial?AccGroup=@item.AccountsGroupID&type2=@item.AccType&frmdate=@Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.from))&todate=@Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.to))&parent=@item.Particular" target="_blank">@item.Particular</a></td>
                                     
                                    }

                                    if (item.AccType == "asset" || item.AccType == "liability")
                                    {
                                        if (item.AccountsGroupID == 7 || item.Parent == 7)
                                        {
                                            <td class="text-right">@Debit.Value.ToString("0.00")</td>
                                            <td class="text-right">@Credit.Value.ToString("0.00")</td>
                                        }
                                        else
                                        {
                                            <td class="text-center">@Debit.Value.ToString("0.00")</td>
                                            <td class="text-center">@Credit.Value.ToString("0.00")</td>
                                        }

                                    }
                                    @*<td class="text-right">@Credit.Value.ToString("0.00")</td>*@
                                }

                                @if (item.Parent == 7)
                                {
                                    DTAmount += AmountDr;
                                    CTAmount += AmountCr;
                                }
                            </tr>
                            TotCount++;
                        }
                    }
                }
            </tbody>
            <tfoot>
                <tr>
                    <td><b>Total</b></td>
                    <td class="text-right"><b>@DTAmount.Value.ToString("N2")</b></td>
                    <td class="text-right"><b>@CTAmount.Value.ToString("N2")</b></td>
                    @*<td class="text-right"><b>@CTAmount.Value.ToString("N2")</b></td>*@

                </tr>
            </tfoot>
        </table>
    </div>

</div>

@section Scripts {
    @Scripts.Render("~/js/bootstrap-datepicker")
    <script type="text/javascript">
        $(window).scroll(function (e) {
            var scroll = $(window).scrollTop();
            if (scroll >= 0) {
                $('.treeview-menu').addClass("navbar-hide");
                var i = scroll;
                $(".navbar-hide").css('margin-top', -i);

            } else {
                $(".navbar-hide").css('margin-top', 0);
                $('.treeview-menu').removeClass("navbar-hide");
            }

        });
        jQuery(function ($) {
            var oTable = $('#UserTable').DataTable({
                "processing": true, // for show progress bar
                "serverSide": false, // for process server side
                "filter": false, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
                "bLengthChange": false,
                "paging": false,
                "deferLoading": 0,
                "ordering": false,
                //"order": [[0, "asc"]],
                buttons: [//'copy', 'csv', 'excel', 'pdf', 'print'
                    {
                        extend: 'print',//
                        title: "",
                        footer: true,
                        filename: function () {
                            return 'Trial Balance';
                        },
                        message: '<table class="tblcompact table table-bordered"><thead>' +
                            ' <tr><th class="text-center"><h3 style="margin-top: 0px;">' + $('#cname').val() + '</h3>' + $('#caddress').val() + '<h4>Trial Balance</h4></th></tr>' +
                            ' <tr><th class="text-center"><span> From : ' + $('#fromdate').val() + ' To : ' + $('#todate').val() + '</span></th></tr></thead><tbody><tr><td>',
                        customize: function (win) {

                            $(win.document.body).find('table, th,tr, td ')
                                // .css('border', 'inherit')
                                .css('font-size', '10pt')
                                .css('padding', '5px')
                                .addClass('compact');
                            $(win.document.body).append('</td></tr></tbody>')

                        }
                    }, 'copy', 'csv',
                    {
                        extend: 'excel',
                        title: "",
                        footer: true,
                        filename: function () {
                            return 'Trial Balance';
                        },
                        message:
                            '' + $('#cname').val() + '\n' +
                            '' + $('#caddress').val() + '\n' +
                            ' Trial Balance \n' +
                            'From :  ' + $('#fromdate').val() + ' To :  ' + $('#todate').val() + ''
                        ,
                        pageSize: 'A4',
                        exportOptions: {
                            columns: [0, 1, 2]
                        },
                    },
                    {
                        extend: 'pdf',//
                        title: "",
                        footer: true,
                        filename: function () {
                            return 'Trial Balance';
                        },
                        message:
                            '' + $('#cname').val() + '\n' +
                            '' + $('#caddress').val() + '\n' +
                            ' Trial Balance \n' +
                            'From :  ' + $('#fromdate').val() + ' To :  ' + $('#todate').val() + ''
                        ,
                        pageSize: 'A4',
                        exportOptions: {
                            columns: [0, 1, 2]
                        },
                        customize: function (doc) {
                            doc.pageMargins = [10, 10, 10, 10];
                            doc.defaultStyle.fontSize = 10;
                            doc.styles.tableHeader.fontSize = 10;
                            doc.styles.title.fontSize = 12;
                            // Remove spaces around page title
                            doc.content[0].text = doc.content[0].text.trim();

                            doc.content[1].table.widths = [
                                '40%',
                                '30%',
                                '30%',
                            ]

                            var objLayout = {};
                            // Horizontal line thickness
                            objLayout['hLineWidth'] = function (i) { return .5; };
                            // Vertikal line thickness
                            objLayout['vLineWidth'] = function (i) { return .5; };
                            //// Horizontal line color
                            //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                            //// Vertical line color
                            //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                            // Left padding of the cell
                            objLayout['paddingLeft'] = function (i) { return 4; };
                            // Right padding of the cell
                            objLayout['paddingRight'] = function (i) { return 4; };
                            // Inject the object in the document
                            doc.content[1].layout = objLayout;
                        }


                    },

                ],
                sDom: "lBfr<'datatable-scroll't>ip"
            });
        });
    </script>
}
