@model QuickSoft.Models.ItemUnit
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Create Item Unit</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("Create", "ItemUnit", FormMethod.Post, new { id = "createform" }))
            {
        <script type="text/javascript">
            $('form#popupFormUnit').removeData("validator");
            $('form#popupFormUnit').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#popupFormUnit'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        <div class="row">
            <div class="col-md-12">
                <div class="form-group">
                    @Html.LabelFor(model => model.ItemUnitName, htmlAttributes: new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.ItemUnitName, new { htmlAttributes = new { @class = "form-control", autofocus = "autofocus", @required = "required" } })

                </div>
            </div>
            <div class="col-md-12">
                <div class="form-group">
                    @Html.LabelFor(model => model.Description, htmlAttributes: new { @class = "control-label" })
                    @Html.TextAreaFor(model => model.Description, new { @class = "form-control", @placeholder = "Enter Unit Description" })
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    @*<input type="submit" value="Save" class="btn btn-info col-sm-offset-4" />*@
                    <button type="submit" id="save" class="btn btn-success col-sm-offset-4" tabindex="26">
                        <span class="glyphicon glyphicon-floppy-disk"></span> Save
                    </button>
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>
@section scripts{
    @Scripts.Render("~/js/jqueryval")
}