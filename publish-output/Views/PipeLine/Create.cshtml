@model QuickSoft.ViewModel.PipeLineViewModel
@{
    ViewBag.Title = "Create";
    ViewBag.SubTitle = "PipeLine";
    ViewBag.Active = "Master";
    var custname = Model.CustomerName;
}
<div class="box box-info">
   @using (Html.BeginForm("Create", "PipeLine", FormMethod.Post, new { id = "createForm", role = "form", enctype = "multipart/form-data" }))
   {
    <div class="box-header with-border">
        <h3 class="box-title">PipeLine</h3>
        <div class="pull-right">
            @if (@ViewBag.LastEntry != 0)
            {
                if (User.IsInRole("Dev") || User.IsInRole("Edit PipeLine"))
                {
                    <a class="btn bg-black no-border" href="/PipeLine/Edit/@ViewBag.LastEntry">
                        <i class="fa fa-step-backward"></i>
                    </a>
                }
            }
            @if (User.IsInRole("Dev") || User.IsInRole("PipeLine List"))
                {
                <a class="btn btn-success no-border" href="/PipeLine">
                    <i class="fa fa-fw fa-history"></i> List
                </a>
            }
        </div>
    </div>
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        @Html.HiddenFor(model => model.ConvertFrom)
        @Html.HiddenFor(model => model.CustomerID)
        <div class="box-body">
            <div class="form-group col-md-4">
                @Html.LabelFor(model => model.CustomerCode, htmlAttributes: new { @class = "control-label" })*
                @Html.EditorFor(model => model.CustomerCode, new { htmlAttributes = new { @class = "form-control", @required = "required", tabindex = 1 } })
            </div>
            <div class="form-group  col-md-4">
                @Html.LabelFor(model => model.CustomerName, htmlAttributes: new { @class = "control-label" })*
                @Html.DropDownListFor(model => model.CustomerName, (SelectList)ViewBag.CustName, new { @class = "form-control input-sm select2", @required = "required", tabindex = 2 })
           </div>
            <div class="form-group col-md-4">
                @Html.LabelFor(model => model.TaxRegNo, htmlAttributes: new { @class = "control-label" })
                @Html.EditorFor(model => model.TaxRegNo, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Tax RegNo", tabindex = 3 } })
            </div>
            
            <div class="form-group col-md-4">
                @Html.LabelFor(model => model.Location, htmlAttributes: new { @class = "control-label" })
                @Html.EditorFor(model => model.Location, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Location", tabindex = 6 } })
            </div>
           
           
            @if (@ViewBag.EnableCRM == 0)
            {
                <div class="form-group col-md-4">
                    @Html.LabelFor(model => model.SourceOfLead, htmlAttributes: new { @class = "control-label" })
                    @if (User.IsInRole("Dev") || User.IsInRole("Create SourceOfLead"))
                    {
                        <div class="input-group input-group-sm">
                            @Html.DropDownListFor(m => m.SourceOfLead, (SelectList)ViewBag.SrcOfLead, new { id = "ddlSrcLead", @class = "form-control select2", tabindex = 8 })
                            <span class="input-group-btn">
                                <a href="/SourceOfLead/Create" class="modal-create btn btn-default" title="Add SourceOfLead"><i class="glyphicon glyphicon-plus"></i></a>
                            </span>
                        </div>
                    }
                    else
                    {
                        @Html.DropDownListFor(m => m.SourceOfLead, (SelectList)ViewBag.SrcOfLead, new { id = "ddlSrcLead", @class = "form-control select2", tabindex = 8 })
                    }
                </div>
            }
            <div class="form-group col-md-4">
                @Html.LabelFor(model => model.LeadStat, htmlAttributes: new { @class = "control-label" })
                @if (User.IsInRole("Dev") || User.IsInRole("Create LeadStatus"))
                {
                <div class="input-group input-group-sm">
                    @Html.DropDownListFor(m => m.LeadStat, (SelectList)ViewBag.LeadStat, new { id = "ddlLeadStat", @class = "form-control select2", @required = "required", tabindex = 6 })
                    <span class="input-group-btn">
                        <a href="/LeadStatus/Create" class="modal-add btn btn-success btn-flat" title="Add Lead Status"><i class="fa fa-1x fa-plus-circle"></i></a>
                    </span>
                </div>
                }
                else
                {
                    @Html.DropDownListFor(m => m.LeadStat, (SelectList)ViewBag.LeadStat, new { id = "ddlLeadStat", @class = "form-control select2", @required = "required" , tabindex = 6 })
                }
            </div>

            <div class="form-group col-md-4">
                @Html.LabelFor(model => model.LeadLevel, htmlAttributes: new { @class = "control-label " })
                @Html.DropDownList("LeadLevel", new SelectList(new List<SelectListItem>
                    {
                        new SelectListItem() {Text = "Small", Value="Small"},
                        new SelectListItem() {Text = "Medium", Value="Medium"},
                        new SelectListItem() {Text = "High", Value="High"},

                    }, "Value", "Text"), new { @class = "form-control input-sm", @name = "LeadLevel", @required = "required", tabindex = 7 })
            </div>
            <div class="form-group col-md-4">
                @Html.LabelFor(m => m.AssignedTo, new { @class = "control-label col-sm-4" })
                @Html.ListBoxFor(m => m.AssignedTo, (SelectList)ViewBag.AssignedTo, new { @class = "form-control", tabindex = 8 })
            </div> 
               
            </div>
        <div class="box-header with-border">
