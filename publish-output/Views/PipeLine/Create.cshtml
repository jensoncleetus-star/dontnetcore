    @Scripts.Render("~/js/Mobile")
        <script type="text/javascript">
            $(document).ready(function () {

                $("#AssignedTo").select2({
                    placeholder: 'Search Employees by Name',
                    minimumInputLength: 0,
                    ajax: {
                        url: "/Employee/SearchTeamMember",
                        dataType: 'json',
                        type: "POST",
                        delay: 50,
                        data: function (params) {
                            return {
                                q: params.term,
                                page: params.page,
                                //lead: $('#TeamLead').val()
                            };
                        },
                        processResults: function (data, params) {
                            params.page = params.page || 1;

                            return {
                                results: data
                            };
                        },
                        cache: true
                    },
                });
                var EntryID = '@ViewContext.RouteData.Values["id"]';
                //  addmobile('mobilebody', 'contact', "");
                if (EntryID != null && EntryID!="") {
                    $.ajax({
                        url: '/Customer/GetMobile',
                        dataType: 'json',
                        data: { CnId: EntryID },
                        cache: true,
                        success: function (data) {
                            //$('#addchecklist').html('');
                            leng = data.length;
                            $.each(data, function (i, item) {
                                AddMobile(item.Mob, item.Name);
                            });
                        }
                    });
                } else {
                    AddMobile();
                }

                SrcOfLead();
                CallLeadStatus();
                SearchCustExists();
                if ('@custname'!="")
                {
                    var newOption = new Option('@custname', '@custname', true, true);
                    $('#CustomerName').append(newOption).trigger('change');
                }
            });
            /*Add LeadStatus here*/
            $('div').on('click', '.modal-add', function (e) {
                e.preventDefault();
                var url = $(this).attr('href');
                modalshow(url, '#modal-add');
            });
            $('#modal-add').on('submit', '#typeform', function (e) {
                var url = $('#modal-add #typeform')[0].action;
                var text = $("#StatusType").val();
                $('#ddlLeadStat option:selected').attr("selected", null);
                $.ajax({
                    type: "POST",
                    url: url,
                    data: $('#modal-add #typeform').serialize(),
                    success: function (data) {
                        if (data.status) {
                            $('#modal-add').modal('hide');
                            var newOption = $('<option></option>');
                            newOption.val(data.Id);//.attr("selected", "selected");
                            newOption.html(text);
                            $('#ddlLeadStat').append(newOption);
                        }
                        else {
                            $('.ajax_response', res_danger).text(data.message);
                            $('.AlertDiv').prepend(res_danger);
                        }
                        fadeAlert();
                    }
                })

                e.preventDefault();
            });

            $('body').on('click', '.modal-close-btn', function () {
                $('#modal-add').modal('hide');
                $('#modal-add').removeData('bs.modal');
            });
            $('#modal-add').on('hidden.bs.modal', function () {
                $(this).removeData('bs.modal');
            });
            $('span').on('click', '.modal-create', function (e) {
                e.preventDefault();
                var url = $(this).attr('href');
                modalshow(url, '#modal-create');
            });
            $('#modal-create').on('submit', '#createform', function (e) {
                e.preventDefault();
                var url = $('#createform')[0].action;
                var data = $('#createform').serialize();
                createajax(url, data, '#modal-create');
            });
            $('#modal-create').on('submit', '#createform', function (e) {
                var text = $("#SrcName").val();
                $('#ddlSrcLead option:selected').attr("selected", null);
                $.ajax({
                    type: "POST",
                    url: url,
                    data: $('#modal-create #createform').serialize(),
                    success: function (data) {
                        if (data.status) {
                            $('#modal-create').modal('hide');

                            var newOption = $('<option></option>');
                            newOption.val(data.Id);//.attr("selected", "selected");
                            newOption.html(text);
                            $('#ddlSrcLead').append(newOption);
                        }
                        else {
                            $('.ajax_response', res_danger).text(data.message);
                            $('.AlertDiv').prepend(res_danger);
                        }
                        fadeAlert();
                    }
                });

                e.preventDefault();

            });

            $(document).on('change', '#Phone', function (event) {
                var phno = $("#Phone").val();
                $.ajax({
                    url: '/Customer/GetPhoneExists',
                    type: "GET",
                    dataType: "JSON",
                    data: { PhNo: phno },
                    success: function (result) {
                        if (result == 1) {
                            alert("Phone Number Already Exists.");
                        }
                    }
                });
            });
            $(document).on('change', '#EmailId', function (event) {
                var email = $("#EmailId").val();
                $.ajax({
                    url: '/Customer/GetEmailExists',
                    type: "GET",
                    dataType: "JSON",
                    data: { Email: email },
                    success: function (result) {
                        if (result == 1) {
                            alert("EmailId Already Exists.");
                        }
                    }
                });
            });
            $("#input-24").fileinput({
                overwriteInitial: false,
                showUpload: false,
                initialPreviewAsData: true,
                initialPreviewFileType: 'image',
                // allowedFileExtensions: ["jpg", "png"],
                allowedFileExtensions: ["dwg ", "xlsx", "gif", "jpg", "jfif", "png", "jpeg", "doc", "docx", "pdf", "dwg"],
                fileActionSettings: {
                    showUpload: false,
                },
                //maxImageWidth: 1000,
                //maxImageHeight: 1000,
            }).on('filesorted', function (e, params) {
                console.log('File sorted params', params);
            }).on('fileuploaded', function (e, params) {
                console.log('File uploaded params', params);
            });
        </script>
    }
