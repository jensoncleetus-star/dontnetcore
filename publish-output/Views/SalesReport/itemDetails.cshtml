@{
    ViewBag.Title = "Item Wise Sales Details";
    ViewBag.SubTitle = "Sales Report";
    ViewBag.Active = "Reports";

}
<div class="box box-default" id="SReport">
    <input type="hidden" id="cname" value="@ViewBag.CName" />
    <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
    <input type="hidden" id="itemname" value="@ViewBag.item" />
    <input type="hidden" id="fromdate" value="@ViewBag.fromdate" />
    <input type="hidden" id="todate" value="@ViewBag.todate" />
    <input type="hidden" id="PoNo" value="@ViewBag.PartNoCheck" />
    <div class="box-header with-border">
        <h3 class="box-title">View Item Wise Sale</h3>
    </div>
    <div class="box-body">
        <div class="box-body">
            <table class="display table table-bordered" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td>S/N</td>
                        <td>Part No</td>
                        <td>Item</td>
                        <td>Invoice No</td>
                        <td>Customer Name</td>
                        <td>Qty</td>
                        <td class="headeralign">Unit Price</td>
                        <td class="headeralign">Sub Total</td>
                        <td class="headeralign">Tax Amt.</td>
                        <td class="headeralign">Discount</td>
                        <td class="headeralign">Total</td>
                    </tr>
                </thead>
                <tbody></tbody>
                <tfoot>
                    <tr>
                        <th>Total:</th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
@section Scripts {
    <script type="text/javascript">

        $(document).ready(function () {
            var oTable = $('#UserTable').DataTable({
                "processing": true, // for show progress bar
                "serverSide": true, // for process server side
                "filter": false, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
                // "bStateSave": true,
                "bLengthChange": false,
                responsive: true,
                "paging": true,
                "pageLength": 5000,
                "ordering": false,
                "ajax": {
                    "url": '/SalesReport/getitemDetails',
                    "data": {
                        item: getQueryString1('iditem'), customer: getQueryString1('customer'),
                        fromdate: getParameterByName('from'), to: getParameterByName('to'), ddmc: getParameterByName('ddmc')
                    },
                    "type": "POST",
                    "datatype": "json"

                },
                "order": [[0, "desc"]],
                "columns": [
                     {
                         "data": "ItemID", "name": "ItemID",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                     { "data": "PartNumber", "name": "PartNumber" },
                    {
                        "name": "Item",
                        "data": function (data) {
                            return (data.Item +" "+ data.Unit)
                        },
                    },
                    {
                        "name": "BillNo", "data": function (data) {
                                  @{
                                      var urls = "";
                                      if (User.IsInRole("Dev") || User.IsInRole("Edit Sales Entry"))
                                      {

                                          urls = "'<a href=\"/CreditSale/Edit/'+  data.SalesEntryId +'\" target=\"_new\">'+ data.BillNo +'</a>' ";
                                      }
                                      else
                                      {
                                          urls = "'<a href=\"/CreditSale/Editnew/'+  data.SalesEntryId +'\" target=\"_new\">'+ data.BillNo +'</a>' ";

                                      }
}
                                      return @Html.Raw(urls);
                            }
                        },
                    { "data": "CustomerName", "name": "CustomerName" },
                    { "data": "ItemQuantity", "name": "ItemQuantity" },
                    { "data": "ItemUnitPrice", "name": "ItemUnitPrice", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                    { "data": "ItemSubTotal", "name": "ItemSubTotal", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                    { "data": "ItemTaxAmount", "name": "ItemTaxAmount", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                    { "data": "ItemDiscount", "name": "ItemDiscount", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                    { "data": "ItemTotalAmount", "name": "ItemTotalAmount", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                ],
                buttons: [
                {
                    extend: 'print',
                    title: "",
                    footer: true,
                    filename: function () {
                        return 'ItemWise-Sale';
                    },
                    message: function()
                    {
                        var head = '<table class="tblcompact table table-bordered"><thead>' +
                             '<tr><th class="text-center"><h3 style="margin-top: 0px;">' + $('#cname').val() + '</h3>' + $('#caddress').val() + '<h4>Sales Report (Item Wise)</h4></th></tr>' +
                             '<tr><th><span class="text-left">Item Name/Code : ' + $('#itemname').val() + '</span><span class="text-right pull-right"> From :  ' + $('#fromdate').val() + ' To :' + $('#todate').val() + '</span></th></tr></thead><tbody><tr><td>';
                        return head;
                    },
                    customize: function (win) {
                        $(win.document.body).find('table, th,tr, td ')
                        // .css('border', 'inherit')
                        .css('font-size', '10pt')
                        .css('padding', '5px')
                        .addClass('compact');
                        $(win.document.body).append('</td></tr></tbody>')

                    }
                }, 'copy', 'csv', //'excel',
                {
                    extend: 'excel',//
                    title: "",
                    footer: true,
                    filename: function () {
                        return 'ItemWise-Sale';
                    },
                    message: function()
                    {
                        var head = '' + $('#cname').val() + '\n' +
                        '' + $('#caddress').val() + '\n' +
                        ' Sales Report (Item Wise) \n' +
                        'Item Name/Code : ' + $('#itemname').val() + '\n' +
                        'From :  ' + $('#fromdate').val() + ' To :' + $('#todate').val() + '';
                        return head;
                    },
                    pageSize: 'A4',
                    exportOptions: {
                        columns: ':visible'//[0, 1, 2, 3, 4, 5, 6, 7, 8]
                    },
                },
                        {
                            extend: 'pdf',//
                            title: "",
                            footer: true,
                            filename: function () {
                                return 'ItemWise-Sale';
                            },
                            message: function () {
                                var head = '' + $('#cname').val() + '\n' +
                                '' + $('#caddress').val() + '\n' +
                                ' Sales Report (Item Wise) \n' +
                                'Item Name/Code : ' + $('#itemname').val() + '\n' +
                                'From :  ' + $('#fromdate').val() + ' To :' + $('#todate').val() + '';
                                return head;
                            },
                            pageSize: 'A4',
                            exportOptions: {
                                columns: ':visible'//[0, 1, 2, 3, 4, 5, 6, 7, 8]
                            },
                            customize: function (doc) {
                                doc.pageMargins = [10, 10, 10, 10];
                                doc.defaultStyle.fontSize = 10;
                                doc.styles.tableHeader.fontSize = 10;
                                doc.styles.title.fontSize = 12;
                                // Header font and bg color
                                doc.styles.tableHeader.fillColor = '#d3d3d3';
                                doc.styles.tableHeader.color = 'black';
                                // Remove spaces around page title
                                doc.content[0].text = doc.content[0].text.trim();

                                doc.styles['td:nth-child(2)'] = {
                                    width: '100%',
                                    'max-width': '100%'
                                }

                                //doc.content[1].table.widths = [
                                //'5%',
                                //'20%',
                                //'10%',
                                //'10%',
                                //'10%',
                                //'10%',
                                //'10%',
                                //'10%',
                                //'15%'
                                //]

                                var objLayout = {};
                                // Horizontal line thickness
                                objLayout['hLineWidth'] = function (i) { return .5; };
                                // Vertikal line thickness
                                objLayout['vLineWidth'] = function (i) { return .5; };
                                //// Horizontal line color
                                //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                                //// Vertical line color
                                //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                                // Left padding of the cell
                                objLayout['paddingLeft'] = function (i) { return 4; };
                                // Right padding of the cell
                                objLayout['paddingRight'] = function (i) { return 4; };
                                // Inject the object in the document
                                doc.content[1].layout = objLayout;
                                // Footer font and bg color
                                doc.styles.tableFooter.fillColor = '#d3d3d3';
                                doc.styles.tableFooter.color = 'black';
                            }


                        },

                ],

                sDom: "lBfr<'datatable-scroll't>ip",
                "lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                "footerCallback": function (row, data, start, end, display) {
                    var api = this.api(), data;

                    // Remove the formatting to get integer data for summation
                    var intVal = function (i) {
                        return typeof i === 'string' ?
                        i.replace(/[\$,]/g, '') * 1 :
                        typeof i === 'number' ?
                            i : 0;
                    };

                    // Total over all pages
                    total = api
                    .column(5)
                    .data()
                    .reduce(function (a, b) {
                        return intVal(a) + intVal(b);
                    }, 0);

                    // Total over this page
                    pageTotal = api
                    .column(5, { page: 'current' })
                    .data()
                    .reduce(function (a, b) {
                        return intVal(a) + intVal(b);
                    }, 0);

                    // Update footer
                    $(api.column(5).footer()).html(
                    pageTotal.toFixed(2)
                    //'$' + pageTotal + ' ( $' + total + ' total)'
                    );


                    //// Total over all pages
                    //total = api
                    //.column(6)
                    //.data()
                    //.reduce(function (a, b) {
                    //    return intVal(a) + intVal(b);
                    //}, 0);

                    //// Total over this page
                    //pageTotal = api
                    //.column(6, { page: 'current' })
                    //.data()
                    //.reduce(function (a, b) {
                    //    return intVal(a) + intVal(b);
                    //}, 0);

                    //// Update footer
                    //$(api.column(6).footer()).html(
                    //pageTotal.toFixed(2)
                    ////'$' + pageTotal + ' ( $' + total + ' total)'
                    //);


                    // Total over all pages
                    total = api
                    .column(7)
                    .data()
                    .reduce(function (a, b) {
                        return intVal(a) + intVal(b);
                    }, 0);

                    // Total over this page
                    pageTotal = api
                    .column(7, { page: 'current' })
                    .data()
                    .reduce(function (a, b) {
                        return intVal(a) + intVal(b);
                    }, 0);

                    // Update footer
                    $(api.column(7).footer()).html(
                    pageTotal.toFixed(2)
                    //'$' + pageTotal + ' ( $' + total + ' total)'
                    );
                    // Total over all pages
                    total = api
                        .column(8)
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Total over this page
                    pageTotal = api
                        .column(8, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update footer
                    $(api.column(8).footer()).html(
                        pageTotal.toFixed(2)
                        //'$' + pageTotal + ' ( $' + total + ' total)'
                    );
                    // Total over all pages
                    total = api
                        .column(10)
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Total over this page
                    pageTotal = api
                        .column(10, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update footer
                    $(api.column(10).footer()).html(
                        pageTotal.toFixed(2)
                        //'$' + pageTotal + ' ( $' + total + ' total)'
                    );
                    // Total over all pages
                    total = api
                    .column(9)
                    .data()
                    .reduce(function (a, b) {
                        return intVal(a) + intVal(b);
                    }, 0);

                    // Total over this page
                    pageTotal = api
                    .column(9, { page: 'current' })
                    .data()
                    .reduce(function (a, b) {
                        return intVal(a) + intVal(b);
                    }, 0);

                    // Update footer
                    $(api.column(9).footer()).html(
                    pageTotal.toFixed(2)
                    //'$' + pageTotal + ' ( $' + total + ' total)'
                    );


                    //var type = $('#itemname').val();
                    //if (type != 'All') {
                    //    var saleQty = api.cell(0, 3).data();
                    //    var retQty = api.cell(0, 4).data();
                    //    var nettQty = api.cell(0, 5).data();

                    //    $(api.column(3).footer()).html(saleQty);
                    //    $(api.column(4).footer()).html(retQty);
                    //    $(api.column(5).footer()).html(nettQty);
                    //}

                    var table = $('#UserTable').DataTable();
                    if (!table.data().any()) {
                        $('#UserTable tfoot').hide();
                    } else {
                        $('#UserTable tfoot').show();
                    }

                }
            });
            var pono = $('#PoNo').val();
            if (pono == 'inactive') {
                var column1 = oTable.column(1);
                column1.visible(false);
            } else {
                var column1 = oTable.column(1);
                column1.visible(true);
            }

            $('#UserTable tbody').on('click', 'tr', function () {
                if ($(this).hasClass('selected')) {
                    $(this).removeClass('selected');
                }
                else {
                    oTable.$('tr.selected').removeClass('selected');
                    $(this).addClass('selected');
                    $(this).addClass('dataTables_row');
                }
            });

            //var type = $('#itemname').val();
            //if (type != 'All') {
            //    var column1 = oTable.column(1);
            //    column1.visible(false);
            //} else {
            //    var column1 = oTable.column(1);
            //    column1.visible(true);
            //}
        });

    </script>
}
