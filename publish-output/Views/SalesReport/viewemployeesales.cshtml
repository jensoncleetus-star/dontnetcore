@{
	ViewBag.Title = "Search Sales Entry";
	ViewBag.SubTitle = "Sales Report";
	ViewBag.Active = "Reports";
}
<div class="box box-default" id="SReport">
	<input type="hidden" id="cname" value="@ViewBag.CName" />
	<input type="hidden" id="caddress" value="@ViewBag.CAddress" />
	<input type="hidden" id="invoiceno" value="@ViewBag.InvoiceNo" />
	<input type="hidden" id="fromdate" value="@ViewBag.fromdate" />
	<input type="hidden" id="todate" value="@ViewBag.todate" />
    <input type="hidden" id="matcenter" value="@ViewBag.EnableMCcheck" />
    <input type="hidden" id="Scaffold" value="@ViewBag.BusinessType" />
	<div class="box-header with-border">
		<h3 class="box-title">View Sales Entry Report</h3>
	</div>
	<div class="box-body">
		<div class="box-body">
			<table class="display table table-bordered" id="UserTable">
				<thead>
					<tr class="bg-gray">
						<td data-priority="2">S/N</td>
						<td data-priority="1">Invoice No.</td>
						<td data-priority="2">Date</td>
						<td data-priority="3">Pay Method</td>
						<td data-priority="2">Customer</td>
						<td>TRN</td>
						@*<td data-priority="2">Item Amt</td>*@
						<td data-priority="1" class="headeralign">Total Amt</td>
						<td class="headeralign">Paid Amt</td>
						<td class="headeralign">Balance Amt</td>
						@*<td data-priority="3">Last Paid Date</td>*@
						<td>Sales Executive</td>
                        <td id="matcol">Material Center</td>
                        
                        <td id="SaleTy">SaleType</td>
                        
						@*<td>Created By</td>*@
						@*<td>Branch</td>*@
					</tr>
				</thead>
				<tbody></tbody>
				<tfoot>
					<tr>
						<th>Total:</th>
						<th></th>
						<th></th>
						<th></th>
						<th></th>
						<th></th>
						<th></th>
						<th></th>
						<th></th>
                        <th></th>
						<th></th>
                        <th></th>
                        
					    
                    </tr>
				</tfoot>
			</table>
		</div>
	</div>
</div>
@section Scripts {
	<script type="text/javascript">
		$(document).ready(function () {
			var oTable = $('#UserTable').DataTable({
				"processing": true, // for show progress bar
				"serverSide": true, // for process server side
				"filter": false, // this is for disable filter (search box)
				"orderMulti": false, // for disable multiple column at once
			    // "bStateSave": true,
				"bLengthChange": false,
				responsive: true,
				"paging": true,
				"pageLength": 5000,
				"ordering": false,
				"ajax": {
					"url": '/SalesReport/GetAllSaleemployee',
					"data": {
					    seno: getQueryString1('seno'), paymethod: getParameterByName('paymethod'), customer: getParameterByName('customer'),
					    SalesExecutive: getParameterByName('SalesExecutive'), type: getParameterByName('type'), fromdate: getParameterByName('from'),
					    todate: getParameterByName('to'), ddMC: getParameterByName('ddMC'), satype: getParameterByName('satype'), htype: getParameterByName('htype'),
					    hfdate: getParameterByName('hfdate'), htdate: getParameterByName('htdate'),
                        project: getParameterByName('project'), task: getParameterByName('task'), perwise: getParameterByName('perwise')
					},
					"type": "POST",
					"datatype": "json"

				},
				"order": [[0, "desc"]],
				"columns": [
					 {
						 "data": "SalesEntryId", "name": "SalesEntryId",
						 "render": function (data, type, row, meta) {
							 return meta.row + meta.settings._iDisplayStart + 1;
						 }
					 },
					{ "data": "BillNo", "name": "BillNo" },
					{ "data": "SEDate", "name": "SEDate", "render": function (data) { return convertToDate(data); } },
					{ "data": "PayMethod", "name": "PayMethod" },
					{ "data": "Customer", "name": "Customer" },
					{ "data": "TaxRegNo", "name": "TaxRegNo" },                   
                    //  { "data": "SEGrandTotal", "name": "SEGrandTotal", render: $.fn.dataTable.render.number(",", ".", 2) },
                    { "data": "SEGrandTotal", "name": "SEGrandTotal", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
					{ "data": "SEPaidAmount", "name": "SEPaidAmount", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
					{ "data": "SEBalanceAmount", "name": "SEBalanceAmount", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
			  //  { "data": "lastpaydate", "name": "lastpaydate", "render": function (data) { return convertToDate(data); } },
					{ "data": "EmpName", "name": "EmpName" },
                    { "data": "MCName", "name": "MCName" },
                    {
                        "data": "SaleType", "name": "SaleType", "render": function (data) {
                            if (data == 2) {
                                return 'Hire';
                            }
                            else {
                                return 'Sale';
                            }

                        }

                    }
				   // { "data": "User", "name": "User" },
			   // { "data": "Branch", "name": "Branch" }
				],
				buttons: [//'copy', 'csv', 'excel', 'pdf', 'print'
				'colvis',
				{
					extend: 'print',//
					title: "",
					footer: true,
					filename: function () {
					    return 'Sales-Report';
					},					
					columnDefs: [
						{ width: 400, targets: 2 }
					],
					exportOptions: {
						columns: ':visible'
					},
					message: function()
					{
					    var head = '<table class="tblcompact table table-bordered"><thead>' +
						' <tr><th class="text-center"><h3 style="margin-top: 0px;">' + $('#cname').val() + '</h3>' + $('#caddress').val() + '<h4>Sales Report</h4></th></tr>' +
						' <tr><th><span class="text-left">Invoice No : ' + $('#invoiceno').val() + '</span><span class="text-right pull-right"> From :  ' + $('#fromdate').val() + ' To :' + $('#todate').val() + '</span></th></tr></thead><tbody><tr><td>';
					    return head;
					},
					customize: function (win) {
						// $(win.document.body)
						//.css('font-size', '10pt')
						//.css('padding', '1px');
						$(win.document.body).find('table.tblcompact tbody td').css('padding', '0px');
						$(win.document.body).find('.dataTable,.dataTable th,.dataTable tr,table.tblcompact tbody td .dataTable td')
							.css('font-size', '10pt')
							.css('padding', '5px')
							.addClass('compact');
						$(win.document.body).find('.dataTable tr th:nth-child(3)')
							.css('min-width', '80px');
						//$(win.document.body).find('.tblcompact tbody td:nth- child(2)')
						//    .css('padding', '0px');
						$(win.document.body).append('</td></tr></tbody>')

					}
				}, 'copy', 'csv', //'excel',
                //Excel
                {
                    extend: 'excel',//
                    title: "",
                    footer: true,
                    filename: function () {
                        return 'Sales-Report';
                    },                   
                    message: function () {
                        var head = '' + $('#cname').val() + '\n' +
                            '' + $('#caddress').val() + '\n' +
                            ' Sales Report \n' +
                            'Invoice No : ' + $('#invoiceno').val() + '\n' +
                            'From :  ' + $('#fromdate').val() + ' To :' + $('#todate').val() + '';
                        return head;
                    },
                    pageSize: 'A4',
                    exportOptions: {
                        columns: ':visible'
                    },
                },
				{
					extend: 'pdf',//
					title: "",
					footer: true,
					filename: function () {
					    return 'Sales-Report';
					},					
					message: function () {
					    var head = '' + $('#cname').val() + '\n' +
                            '' + $('#caddress').val() + '\n' +
                            ' Sales Report \n' +
                            'Invoice No : ' + $('#invoiceno').val() + '\n' +
                            'From :  ' + $('#fromdate').val() + ' To :' + $('#todate').val() + '';
					    return head;
					},
					pageSize: 'A4',
					exportOptions: {
					    columns: ':visible'
					},
					customize: function (doc) {
						doc.pageMargins = [10, 10, 10, 10];
						doc.defaultStyle.fontSize = 10;
						doc.styles.tableHeader.fontSize = 10;
						doc.styles.title.fontSize = 12;
					    // Header font and bg color
						doc.styles.tableHeader.fillColor = '#d3d3d3';
						doc.styles.tableHeader.color = 'black';
						// Remove spaces around page title
						doc.content[0].text = doc.content[0].text.trim();


						doc.styles['td:nth-child(2)'] = {
						    width: '100%',
						    'max-width': '100%'
						}

					    //doc.content[1].table.widths = Array(doc.content[1].table.body[0].length + 1).join('*').split('');

						//doc.content[1].table.widths = [
						//'5%',
						//'7%',
						//'12%',
						//'10%',
						//'10%',
						//'10%',
						//'12%',
						//'12%',
						//'12%',
						//'10%'
						//]

						//doc['header'] = (function () {
						//    return {
						//        columns: [
						//			{
						//			    alignment: 'left',
						//			    italics: true,
						//			    text: 'dataTables',
						//			    fontSize: 18,
						//			    margin: [10, 0]
						//			},
						//			{
						//			    alignment: 'right',
						//			    fontSize: 14,
						//			    text: 'Custom PDF export with dataTables'
						//			}
						//        ],
						//        margin: 20
						//    }
						//});
						var objLayout = {};
						// Horizontal line thickness
						objLayout['hLineWidth'] = function (i) { return .5; };
						// Vertikal line thickness
						objLayout['vLineWidth'] = function (i) { return .5; };
						//// Horizontal line color
						//objLayout['hLineColor'] = function (i) { return '#aaa'; };
						//// Vertical line color
						//objLayout['vLineColor'] = function (i) { return '#aaa'; };
						// Left padding of the cell
						objLayout['paddingLeft'] = function (i) { return 4; };
						// Right padding of the cell
						objLayout['paddingRight'] = function (i) { return 4; };
						// Inject the object in the document
						doc.content[1].layout = objLayout;
					    // Footer font and bg color
						doc.styles.tableFooter.fillColor = '#d3d3d3';
						doc.styles.tableFooter.color = 'black';

					}
				}

				],

				sDom: "lBfr<'datatable-scroll't>ip",
				"lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
				"footerCallback": function (row, data, start, end, display) {
					var api = this.api(), data;

					// Remove the formatting to get integer data for summation
					var intVal = function (i) {
						return typeof i === 'string' ?
							i.replace(/[\$,]/g, '') * 1 :
							typeof i === 'number' ?
							i : 0;
					};




					// Total over all pages
					total = api
						.column(6)
						.data()
						.reduce(function (a, b) {
							return intVal(a) + intVal(b);
						}, 0);

					// Total over this page
					pageTotal = api
						.column(6, { page: 'current' })
						.data()
						.reduce(function (a, b) {
							return intVal(a) + intVal(b);
						}, 0);

					// Update footer
					$(api.column(6).footer()).html(
						 pageTotal.toFixed(2)
						//'$' + pageTotal + ' ( $' + total + ' total)'
					);


					// Total over all pages
					total = api
						.column(7)
						.data()
						.reduce(function (a, b) {
							return intVal(a) + intVal(b);
						}, 0);

					// Total over this page
					pageTotal = api
						.column(7, { page: 'current' })
						.data()
						.reduce(function (a, b) {
							return intVal(a) + intVal(b);
						}, 0);

					// Update footer
					$(api.column(7).footer()).html(
						 pageTotal.toFixed(2)
						//'$' + pageTotal + ' ( $' + total + ' total)'
					);


					// Total over all pages
					total = api
						.column(8)
						.data()
						.reduce(function (a, b) {
							return intVal(a) + intVal(b);
						}, 0);

					// Total over this page
					pageTotal = api
						.column(8, { page: 'current' })
						.data()
						.reduce(function (a, b) {
							return intVal(a) + intVal(b);
						}, 0);

					// Update footer
					$(api.column(8).footer()).html(
						 pageTotal.toFixed(2)
						//'$' + pageTotal + ' ( $' + total + ' total)'
					);


					var table = $('#UserTable').DataTable();
					if (!table.data().any()) {
						$('#UserTable tfoot').hide();
					} else {
						$('#UserTable tfoot').show();
					}

				}
			});
			var type = $('#invoiceno').val();
			if (type != 'All') {
				var column1 = oTable.column(1);
				column1.visible(false);
			} else {
				var column1 = oTable.column(1);
				column1.visible(true);
			}

			var matcet = $('#matcenter').val();
			if (matcet == "inactive") {
			    var column1 = oTable.column(10);
			    column1.visible(false);
			} else {
			    var column1 = oTable.column(10);
			    column1.visible(true);
			}
            //re direct to sales edit
			$('#UserTable tbody').on('click', 'tr', function () {
			    if ($(this).hasClass('selected')) {
			        $(this).removeClass('selected');
			    }
			    else {
			        oTable.$('tr.selected').removeClass('selected');
			        $(this).addClass('selected');
			        $(this).addClass('dataTables_row');
			    }
			});

			$('#UserTable tbody').on('dblclick', 'tr', function (e) {
			    var data = oTable.row(this).data();
			    var url = "/CreditSale/Edit/" + data.SalesEntryId + "";
			    $(location).attr('href', url);
			});

			var Scaffold = $('#Scaffold').val();
			if (Scaffold != "Scaffold") {
			    var column1 = oTable.column(11);
			    column1.visible(false);
			    var column2 = $('#SaleTy').val();
			    column2.visible(false);
			} else {
			    var column1 = oTable.column(11);
			    column1.visible(true);
			    var column2 = $('#SaleTy').val();
			    column2.visible(true);
			}
           
		});
	</script>
	}
