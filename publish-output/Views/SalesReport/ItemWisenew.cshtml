        //        $("#DDlExecutivewise").show();
        //        $("#DDlItemwise").hide();
        //        $("#DDlBrandwise").hide();
        //    }
        //    else {
        //        //$('#CreDates').val(null);
        //        $("#DDlExecutivewise").hide();
        //        $("#DDlBrandwise").hide();
        //        $("#DDlItemwise").show();
        //        //$('#manhourtable').DataTable().draw();
        //    }
        //});
        $("#ddlSalesman").select2({
            placeholder: 'Search by Name ',
            minimumInputLength: 0,
            ajax: {
                url: "/Employee/SearchEmployee",
                dataType: 'json',
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term || "",
                        page: params.page || 0,
                        x: "All"
                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 0;

                    return {
                        results: data,
                        pagination: {
                            //more: (params.page * 10) < 50
                            more: true
                        }
                    };
                },
                cache: true
            },
        });

        $("#ddlItemCategory").select2({
            placeholder: 'Search Item Category',
            minimumInputLength: 0,
            ajax: {
                url: "/ItemCategory/SearchCategory",
                dataType: 'json',
                type: "POST",
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term,
                        page: params.page,
                        x: "all"
                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 1;

                    return {
                        results: data
                    };
                },
                cache: true
            },
        });

        $("#ddlItemBrand").select2({
            placeholder: 'Search Item Brand',
            minimumInputLength: 0,
            ajax: {
                url: "/ItemBrand/SearchBrand",
                dataType: 'json',
                type: "POST",
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term,
                        page: params.page,
                        x: "all"
                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 1;

                    return {
                        results: data
                    };
                },
                cache: true
            },
        });
        var _show = 0;
        $("ul li input:checkbox").click(function () {
            if ($("#liBrandwise").prop("checked") == true) {
                $("#DDlBrandwise").show();
            }
            else {
                //$("#ddlItemBrand").val(0);
                $('#ddlItemBrand').val(0).trigger("change");
                $("#DDlBrandwise").hide();
            }
            if ($("#liSalesExecutiveWise").prop("checked") == true) {
                $("#DDlExecutivewise").show();

            }
            else {
                $('#ddlEmployee').val(0).trigger("change");
               // $("#ddlEmployee").val("");
                $("#DDlExecutivewise").hide();

            }
            if ($("#liCategoryWise").prop("checked") == true) {
                $("#DDlCategorywise").show();

            }
            else {
                $('#ddlItemCategory').val(0).trigger("change");
                // $("#ddlEmployee").val("");
                $("#DDlCategorywise").hide();

            }
            if ($("#liSalesmanWise").prop("checked") == true) {
                $("#DDlSalesManwise").show();

            }
            else {
                $('#ddlSalesman').val(0).trigger("change");
                // $("#ddlEmployee").val("");
                $("#DDlSalesManwise").hide();

            }
            if ($("#liItemwise").prop("checked") == true) {
                $("#DDlItemwise").show();

            }
            else {
                $('#ddlItem').val(null).trigger("change");
                // $("#ddlEmployee").val("");
                $("#DDlItemwise").hide();

            }

