@{
    ViewBag.Title = "Search Item Wise Sale";
    ViewBag.SubTitle = "Sales Report";
    ViewBag.Active = "Reports";

}
<style>
    .form-actions input[value=Cancel] {
        position: relative;
        top: 0px !important;
    }

    #pullsearch {
        background-color: dodgerblue;
        color: white;
    }

    #tabledraw {
        background-color: palevioletred;
        color: white;
    }

    input[type=button] {
        position: relative;
        top: 26px;
    }

    .input-group .input-group-addon {
        border-radius: 0px 37px 37px 0px !important;
        padding-left: 20px !important;
        padding-right: 20px !important;
        margin-left: -10px !important;
    }

    .date {
        height: 34px !important;
        margin-bottom: 0px;
    }

    tfoot {
        font-weight: bold;
    }

    .sh-styling {
        /*box-shadow: 5px 8px 16px 5px rgba(0,0,0,0.3);*/
        box-shadow: -1px -2px 49px 0px rgba(0,0,0,0.1);
        border-radius: 5px;
    }

        .sh-styling:hover {
            box-shadow: -1px -2px 49px 0px rgba(0,0,0,0.3);
            transform: scale(1.003);
            -webkit-transition: 0.5s;
        }

    .dropdown-check-list {
        display: inline-block;
    }

        .dropdown-check-list .anchor {
            position: relative;
            cursor: pointer;
            display: inline-block;
            padding: 5px 50px 5px 10px;
            border: 1px solid #ccc;
            width: 150px;
            background: #fff;
            text-align: center;
        }

            .dropdown-check-list .anchor:after {
                position: absolute;
                content: "";
                border-left: 2px solid black;
                border-top: 2px solid black;
                padding: 5px;
                right: 10px;
                top: 20%;
                -moz-transform: rotate(-135deg);
                -ms-transform: rotate(-135deg);
                -o-transform: rotate(-135deg);
                -webkit-transform: rotate(-135deg);
                transform: rotate(-135deg);
            }

            .dropdown-check-list .anchor:active:after {
                right: 8px;
                top: 21%;
            }

        .dropdown-check-list ul.items {
            padding: 0px;
            display: none;
            margin: 0;
            border: 1px solid #ccc;
            border-top: none;
            position: absolute;
            z-index: 9999;
        }

            .dropdown-check-list ul.items li {
                list-style: none;
                background: #fff;
                padding: 5px;
            }

    .add-btn-item {
        border-radius: 23px;
        padding: 6px 20px;
    }

    .dropdown-check-list.visible .anchor {
        color: #0094ff;
    }

    .dropdown-check-list.visible .items {
        display: block;
    }

    #DDlItemwise {
        margin-bottom: 0px !important;
    }
</style>
<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">Search Item Wise Sale</h3>
    </div>
    <div class="box-body">
        @using (Html.BeginForm("ItemWisenew", "SalesReport", FormMethod.Post, new { id = "popupForm" }))
        {
            <div class="row">
                <div class="col-md-3">
                    <div id="list1" class="dropdown-check-list" tabindex="100">
                        <span class="anchor" style="z-index:0;">Select Fields</span>
                        <ul class="items">
                            <li><input type="checkbox" id="liItemwise" value="ItemWise" checked /> Item Wise</li>
                            <li><input type="checkbox" id="liBrandwise" value="BrandWise" /> Brand Wise</li>
                            <li><input type="checkbox" id="liSalesExecutiveWise" value="SalesExecutiveWise" /> Sales Executive Wise</li>
                            <li><input type="checkbox" id="liCategoryWise" value="CategoryWise" /> Category Wise</li>
                            <li><input type="checkbox" id="liSalesmanWise" value="SalesmanWise" /> Salesman Wise</li>
                        </ul>
                    </div>
                </div>

            </div>
            @*<div class="form-group" hidden>
                    @Html.TextBox("RadioValue", new { @class = "form-control  input-sm" })
                </div>*@
            if (@ViewBag.BusinessType == "Scaffold")
            {
                <div class="form-group col-sm-4">
                    @Html.Label("Type", null, new { @class = "control-label" })
                    @Html.DropDownList("SaleType", (SelectList)ViewBag.Type, new { @class = "form-control input-sm" })
                </div>
            }
            if (@ViewBag.EnableMCcheck == 0)
            {
                <div class="form-group col-md-4">
                    @Html.Label("Material Center", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlMC", (SelectList)ViewBag.MC, new { @class = "form-control input-sm" })
                </div>
            }
            <div class="form-group col-md-4">
                @Html.Label("From", null, new { @class = "control-label" })
                <div class="input-group date">
                    @Html.TextBox("From", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                    <div class="input-group-addon">
                        <i class="fa fa-calendar"></i>
                    </div>
                </div>
            </div>
            <div class="form-group col-md-4">
                @Html.Label("To", null, new { @class = "control-label" })
                <div class="input-group date">
                    @Html.TextBox("To", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                    <div class="input-group-addon">
                        <i class="fa fa-calendar"></i>
                    </div>
                </div>
            </div>
            <div class="form-group col-md-4" id="DDlItemwise">
                @Html.Label("Item Name/Code", null, new { @class = "control-label" })
                @Html.ListBox("ddlItem", (SelectList)ViewBag.Item, new { @class = "form-control input-sm select2", @multiple = "multiple", @name = "ddlItem[]" })
            </div>
            <div class="form-group col-md-4" id="DDlBrandwise">
                @Html.Label("Item Brand", null, new { @class = "control-label" })
                @Html.DropDownList("ddlItemBrand", (SelectList)ViewBag.Brand, new { @class = "form-control input-sm select2" })
            </div>
            <div class="form-group col-md-4" id="DDlExecutivewise">
                @Html.Label("Sales Executive", null, new { @class = "control-label" })
                @Html.DropDownList("ddlEmployee", (SelectList)ViewBag.SalesExec, new { @class = "form-control input-sm select2" })
            </div>
            <div class="form-group col-md-4" id="DDlCategorywise">
                @Html.Label("Item Category", null, new { @class = "control-label" })
                @Html.DropDownList("ddlItemCategory", (SelectList)ViewBag.Category, new { @class = "form-control input-sm select2" })
            </div>
            <div class="form-group col-md-4" id="DDlSalesManwise">
                @Html.Label("Sales Man", null, new { @class = "control-label" })
                @Html.DropDownList("ddlSalesman", (SelectList)ViewBag.SalesMan, new { @class = "form-control input-sm select2" })
            </div>

            <div class="box-footer col-md-12">
                <input type="submit" class="btn btn-info col-sm-offset-5" value="Submit" />
                <button type="button" class="btn btn-default" onclick="@("window.location.href='/Home/Index'");">Cancel</button>
            </div>

        }
    </div>
</div>
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
}
@section Scripts {
    @Scripts.Render("~/js/bootstrap-datepicker")
    <script type="text/javascript">
