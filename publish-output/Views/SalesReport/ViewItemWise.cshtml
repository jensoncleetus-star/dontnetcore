@{
    ViewBag.Title = "View Item Wise Sale";
    ViewBag.SubTitle = "Sales Report";
    ViewBag.Active = "Reports";

}
<div class="box box-default" id="SReport">
    <input type="hidden" id="cname" value="@ViewBag.CName" />
    <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
    <input type="hidden" id="itemname" value="@ViewBag.item" />
    <input type="hidden" id="fromdate" value="@ViewBag.fromdate" />
    <input type="hidden" id="todate" value="@ViewBag.todate" />
    <input type="hidden" id="PoNo" value="@ViewBag.PartNoCheck" />
    <input type="hidden" id="Salety" value="@ViewBag.Salety" />
    <div class="box-header with-border">
        <h3 class="box-title">View Item Wise Sale</h3>
    </div>
    <div class="box-body">
        <div class="box-body">
            <table class="display table table-bordered" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td>S/N</td>
                        <td>Part No</td>
                        <td>Item</td>
                        @*<td class="headeralign">Avg. Price</td>*@
                        <td class="headeralign">Sale Qty.</td>
                        @*<td class="headeralign">Return Qty.</td>*@
                        @*<td align="center">Nett Sale Qty.</td>*@
                        <td class="headeralign">Sale Amt.</td>
                        <td class="headeralign">Purchase price</td>
                      
                        @*<td align="center">Retun Amt.</td>*@
                        @*<td align="center">Nett Sale Amt.</td>*@
                        @*<td class="headeralign">Sale Vouchers</td>*@
                        @*<td class="headeralign">Sale Return Vouchers</td>*@
                    </tr>
                </thead>
                <tbody ></tbody>
                <tfoot>
                    <tr>
                        <th>Total:</th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        @*<th></th>*@
                        @*<th></th>*@
                        @*<th></th>*@
                        @*<th></th>*@
                        @*<th></th>*@
                        @*<th></th>*@
                        <th></th>
                       
                        @*<th></th>*@
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
