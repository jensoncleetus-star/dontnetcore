@model QuickSoft.Models.Department
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Edit Department</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("Edit", "Department", FormMethod.Post, new { role = "form", id = "editform" }))
            {
        <script type="text/javascript">
            $('form#popupFormCategory').removeData("validator");
            $('form#popupFormCategory').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#popupFormCategory'));
        </script>
                @Html.AntiForgeryToken()
                @Html.ValidationSummary("", new { @class = "alert alert-danger" })
                @Html.HiddenFor(model => model.DepartmentID)

                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group">
                            @Html.LabelFor(m => m.DepartmentName, new { @class = "control-label" }) *
                            @Html.TextBoxFor(m => m.DepartmentName, new { @class = "form-control", autofocus = "autofocus", @required = "required" })
                        </div>
                    </div>
                    @if (@ViewBag.EnablePayroll == 0)
                    {
                        <div class="col-md-12">
                            <div class="form-group">
                                @Html.Label("Calendar Template", null, new { @class = "control-label" })
                                @Html.DropDownListFor(model => model.CalendarTemplateId, (SelectList)ViewBag.CTemplates, new { htmlAttributes = new { @class = "form-control input-sm CTemplate" } })
                            </div>
                        </div>
                    }
                </div>
                <div class="row">
                    <div class="col-md-12">
                        <div class="box-footer">
                            <input type="submit" class="btn btn-info col-sm-offset-4" value="Update" />
                            <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                        </div>
                    </div>
                </div>
                <script>
                    $("#CalendarTemplateId").select2({
                        placeholder: 'Search by Calendar Template',
                        minimumInputLength: 0,
                        ajax: {
                            url: "/CalendarTemplate/SearchCalendarTemplate",
                            dataType: 'json',
                            delay: 50,
                            data: function (params) {
                                return {
                                    q: params.term || "",
                                    page: params.page || 0,
                                    x: "empty"
                                };
                            },
                            processResults: function (data, params) {
                                params.page = params.page || 0;
                                return {
                                    results: data,
                                    pagination: {
                                        more: true
                                    }
                                };
                            },
                            cache: true
                        },
                    });

                </script>
    }
</div>
@section scripts{
    @Scripts.Render("~/js/jqueryval")
}