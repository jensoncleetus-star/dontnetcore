@model QuickSoft.Models.StickyNote
@{
    ViewBag.Title = "StickyNote";
    ViewBag.SubTitle = "Edit StickyNote";
    ViewBag.Active = "Master";
}

<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Edit Note</h4>
</div>

<div class="modal-body">
    @using (Html.BeginForm("Edit", "StickyNote", FormMethod.Post, new { role = "form", id = "editform" }))
    {
        <script type="text/javascript">
            $('form#popupForm').removeData("validator");
            $('form#popupForm').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#popupFormStickyNote'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        @Html.HiddenFor(model => model.Id)
        <div class="row">
            <div class="col-md-12">
                <div class="form-group">
                    @Html.LabelFor(model => model.NoteName, new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.NoteName, new { htmlAttributes = new { @class = "form-control input-sm", autofocus = "autofocus", @required = "required" } })
                </div>

                @* Adding DropDown List To select Label *@
                <div class="form-group">
                    @Html.Label("Select Label", null, new { @class = "control-label" }) *
                    @*@if (User.IsInRole("Dev") || User.IsInRole("Create Notes"))
                        {*@
                    <div class="input-group input-group-sm">
                        @Html.DropDownListFor(m => m.Label, (SelectList)ViewBag.notes, "", new { id = "ddlLabel", @class = "form-control select2", @required = "required" })
                        <span class="input-group-btn">
                            <button type="button" href="/StickyLabel/Create" class="modal-create btn btn-success btn-flat"><i class="fa fa-1x fa-plus-circle"></i></button>
                        </span>
                    </div>
                    @*}
                        else
                        {
                            @Html.DropDownListFor(m => m.Label, (SelectList)ViewBag.notes, "", new { id = "ddlLabel", @class = "form-control select2", @required = "required" })
                        }*@
                </div>

                @* Content *@
                <div class="form-group ">
                    @Html.LabelFor(m => m.NoteContent, new { @class = "control-label" })
                    @Html.TextAreaFor(model => model.NoteContent, new { @class = "form-control", @placeholder = "Enter Your Content", @rows = 7 })
                </div>
                <div class="form-group">
                    @Html.LabelFor(model => model.Status, new { @class = "control-label" })
                    @Html.EnumDropDownListFor(model => model.Status, new { @class = "form-control" })
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" value="Save" class="btn btn-info col-sm-offset-4" />
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>
@section Scripts {

    @Scripts.Render("~/js/jqueryval")
}
