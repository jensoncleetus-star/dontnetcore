@{
    ViewBag.Title = "View Stock";
    ViewBag.SubTitle = "Hire Stock Report";
    ViewBag.Active = "Reports";
}
<div class="box box-default" id="StockReport">
    <input type="hidden" id="cname" value="@ViewBag.CName" />
    <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
    <input type="hidden" id="itemname" value="@ViewBag.ItemName" />
    <div class="box-header with-border">
        <h3 class="box-title">View Item Wise</h3>
    </div>
    <div class="box-body">
        <div class="box-body">
            <table class="table table-bordered table-hover" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="1">S/N</td>
                        <td data-priority="1">Invoice No</td>
                        <td data-priority="5" class="headeralign">Date</td>
                        <td data-priority="5" class="headeralign">Customer</td>
                        <td data-priority="5" class="headeralign">Sales Qty</td>
                        <td data-priority="5" class="headeralign">Hire Return</td>
                   
                    </tr>
                </thead>
                <tbody></tbody>
               
            </table>
        </div>
    </div>
</div>
@section Scripts {
    <script type="text/javascript">
        $(document).ready(function () {
            oTable = $('#UserTable').DataTable({
                "processing": true, // for show progress bar
                "serverSide": true, // for process server side
                "filter": false, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
                // "bStateSave": true,
                "bLengthChange": false,
                "paging": true,
                "pageLength": 5000,
                responsive: true,
                "ordering": false,
                "ajax": {
                    "url": '/HireStockReport/GetAllSale',
                    "data": { item: getQueryString1('itemid'), ddMC: getQueryString1('ddmc') },
                    "type": "POST",
                    "datatype": "json"
                },
                "columns": [
                    {
                        "data": "ItemId", "name": "ItemId",
                        "render": function (data, type, row, meta) {
                            return meta.row + meta.settings._iDisplayStart + 1;
                        }
                    },
                    {
                        "name": "BillNo", "data": function (data) {
                            return data.BillNo;
                        }
                    },
                    {
                        "name": "SEDate", "data": function (data) {
                            return convertToDate(data.SEDate)
                        }
                    },
                    {
                        "name": "Customer", "data": function (data) {
                            return data.Customer
                        }
                    },
                    {
                        "name": "saleqty", "data": function (data) {
                            return data.saleqty
                        }
                    },
                    {
                        "name": "hirereturnqty", "data": function (data) {
                            return data.hirereturnqty
                        }
                    },
                   
                    
            
                ],
                buttons: [//'copy', 'csv', 'excel', 'pdf', 'print'
                    {
                        extend: 'print',//
                        title: "",
                        footer: true,
                        filename: function () {
                            return 'Item Wise-Stock';
                        },
                        exportOptions: {
                            columns: [0, 1, 2, 4, 5, 6, 7, 8, 9, 10]
                        },
                        message: function () {
                            var head = '<table class="tblcompact table table-bordered"><thead>' +
                                ' <tr><th class="text-center"><h3 style="margin-top: 0px;">' + $('#cname').val() + '</h3>' + $('#caddress').val() + '<h4>Hire Stock Report (Item Wise)</h4></th></tr>' +
                                ' <tr><th><span class="text-left">Item Name : ' + $('#itemname').val() + '</span><span class="text-right pull-right"> </span></th></tr></thead><tbody><tr><td>';
                            return head;
                        },
                        customize: function (win) {
                            // $(win.document.body)
                            //.css('font-size', '10pt')
                            //.css('padding', '1px');
                            $(win.document.body).find('table, th,tr, td ')
                                // .css('border', 'inherit')
                                .css('font-size', '10pt')
                                .css('padding', '5px')
                                .addClass('compact');
                            $(win.document.body).append('</td></tr></tbody>')

                        }
                    }, 'copy', 'csv', //'excel',
                    {
                        extend: 'excel',//
                        title: "",
                        footer: true,
                        filename: function () {
                            return 'Item Wise-Stock';
                        },
                        message: function () {
                            var head = '' + $('#cname').val() + '\n' +
                                '' + $('#caddress').val() + '\n' +
                                'Hire Stock Report (Item Wise) \n' +
                                'Item Name : ' + $('#itemname').val() + '\n';
                            return head;
                        },
                        pageSize: 'A4',
                        exportOptions: {
                            columns: [0, 1, 2, 4, 5, 6, 7, 8, 9, 10]
                        },
                    },
                    {
                        extend: 'pdf',//
                        title: "",
                        footer: true,
                        filename: function () {
                            return 'Item Wise-Stock';
                        },
                        message: function () {
                            var head = '' + $('#cname').val() + '\n' +
                                '' + $('#caddress').val() + '\n' +
                                ' Hire Stock Report (Item Wise) \n' +
                                'Item Name : ' + $('#itemname').val() + '\n';
                            return head;
                        },
                        pageSize: 'A4',
                        exportOptions: {
                            columns: [0, 1, 2, 4, 5, 6, 7, 8, 9, 10]
                        },
                        customize: function (doc) {
                            doc.pageMargins = [10, 10, 10, 10];
                            doc.defaultStyle.fontSize = 10;
                            doc.styles.tableHeader.fontSize = 10;
                            doc.styles.title.fontSize = 12;
                            // Header font and bg color
                            doc.styles.tableHeader.fillColor = '#d3d3d3';
                            doc.styles.tableHeader.color = 'black';
                            // Remove spaces around page title
                            doc.content[0].text = doc.content[0].text.trim();

                            //doc.styles['td:nth-child(2)'] = {
                            //    width: '100%',
                            //    'max-width': '100%'
                            //}

                            doc.content[1].table.widths = [
                                '5%',
                                '20%',
                                '8%',
                                '8%',
                                '8%',
                                '8%',
                                '8%',
                                '8%',
                                '8%',
                                '8%',
                                '8%'
                            ]


                            var objLayout = {};
                            // Horizontal line thickness
                            objLayout['hLineWidth'] = function (i) { return .5; };
                            // Vertikal line thickness
                            objLayout['vLineWidth'] = function (i) { return .5; };
                            //// Horizontal line color
                            //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                            //// Vertical line color
                            //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                            // Left padding of the cell
                            objLayout['paddingLeft'] = function (i) { return 4; };
                            // Right padding of the cell
                            objLayout['paddingRight'] = function (i) { return 4; };
                            // Inject the object in the document
                            doc.content[1].layout = objLayout;
                            // Footer font and bg color
                            doc.styles.tableFooter.fillColor = '#d3d3d3';
                            doc.styles.tableFooter.color = 'black';
                        }


                    },
                ],
                sDom: "lBfr<'datatable-scroll't>ip",
                "lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                "footerCallback": function (row, data, start, end, display) {
                    var api = this.api(), data;

                    // Remove the formatting to get integer data for summation
                    var intVal = function (i) {
                        return typeof i === 'string' ?
                            i.replace(/[\$,]/g, '') * 1 :
                            typeof i === 'number' ?
                                i : 0;
                    };


                }
            });

            var column1 = oTable.column(1);
            column1.visible(true);
            //var column1 = oTable.column(3);
            //column1.visible(false);
        });
       

    </script>
}
