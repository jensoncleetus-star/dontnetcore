
@model QuickSoft.Models.BillSundry
@{
    ViewBag.Title = "List";
    ViewBag.SubTitle = "Bill Sundry";
    ViewBag.Active = "Master";
    string actData = "";
    string actData2 = "";
    bool userRole = false;
    string delchk = "";
    if (User.IsInRole("Dev") || User.IsInRole("Delete BillSundry"))
    {
        userRole = true;
    }
}
<style type="text/css">

    .dropdown-check-list {
        display: inline-block;
    }

        .dropdown-check-list .anchor {
            position: relative;
            cursor: pointer;
            display: inline-block;
            padding: 5px 50px 5px 10px;
            border: 1px solid #ccc;
            width: 150px;
            background: #fff;
            text-align: center;
        }

            .dropdown-check-list .anchor:after {
                position: absolute;
                content: "";
                border-left: 2px solid black;
                border-top: 2px solid black;
                padding: 5px;
                right: 10px;
                top: 20%;
                -moz-transform: rotate(-135deg);
                -ms-transform: rotate(-135deg);
                -o-transform: rotate(-135deg);
                -webkit-transform: rotate(-135deg);
                transform: rotate(-135deg);
            }

            .dropdown-check-list .anchor:active:after {
                right: 8px;
                top: 21%;
            }

        .dropdown-check-list ul.items {
            padding: 0px;
            display: none;
            margin: 0;
            border: 1px solid #ccc;
            border-top: none;
            position: absolute;
            z-index: 9999;
        }

            .dropdown-check-list ul.items li {
                list-style: none;
                background: #fff;
                padding: 5px;
            }

    .add-btn-item {
        border-radius: 23px;
        padding: 6px 20px;
    }

    .dropdown-check-list.visible .anchor {
        color: #0094ff;
    }

    .dropdown-check-list.visible .items {
        display: block;
    }
</style>

<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">Bill Sundries</h3>
        <div class="pull-right">
            @if (User.IsInRole("Dev") || User.IsInRole("Create BillSundry"))
            {
                <i class="ace-icon fa fa-hand-o-right icon-animated-hand-pointer blue"></i>
                <a class="btn btn-info no-border modal-create" href="/BillSundry/Create">
                    <i class="glyphicon glyphicon-plus"></i> Create
                </a>
            }
        </div>
        <div class="row">
            <div class="col-md-2">
                <div id="list1" class="dropdown-check-list" tabindex="100">
                    <span class="anchor" style="z-index:0;">Select Fields</span>
                    <ul class="items">
                        <li><input type="checkbox" id="liname" />Name</li>
                        <li><input type="checkbox" id="lidefaultvalue" />Default Value</li>
                        <li><input type="checkbox" id="litype" />Type</li>
                        <li><input type="checkbox" id="liamounttype" />Amount Type</li>
                        <li><input type="checkbox" id="liaccinsale" />Account In Sale</li>
                        <li><input type="checkbox" id="liaccinpurchase" />Account In Purchase</li>
                        <li><input type="checkbox" id="listatus" />Status</li>
                    </ul>
                </div>
            </div>

            <div class="col-md-12">
                <div class="box-body search-box" id="advsearchlist">
                    <div class="search-body col-md-12" style="background:none;">
                        <form id="search-form">
                            <div class="row">
                                <div class="form-group col-md-2" id="searchname">
                                    @Html.Label("Name", null, new { @class = "control-label" })
                                    @Html.TextBox("BSName", "", new { @class = "form-control input-sm" })
                                </div>
                                <div class="form-group col-md-2" id="searchdeafultval">
                                    @Html.Label("Default Value", null, new { @class = "control-label" })
                                    @Html.TextBox("DfValue", "", new { @class = "form-control input-sm" })
                                </div>
                                <div class="form-group col-md-2" id="searchtype">
                                    @Html.Label("Type", null, new { @class = "control-label" })
                                    @Html.DropDownList("BSType", (SelectList)ViewBag.Type, new { @class = "form-control select2" })
                                </div>
                                <div class="form-group col-md-2" id="searchamnttype">
                                    @Html.Label("Amount Type", null, new { @class = "control-label" })
                                    @Html.DropDownList("AmountType", (SelectList)ViewBag.AmtType, new { @class = "form-control select2" })
                                </div>
                                <div class="form-group col-md-2" id="searchaccinsale">
                                    @Html.Label("Account In Sale", null, new { @class = "control-label" })
                                    @Html.DropDownList("SddlAccount", (SelectList)ViewBag.Acc, new { @class = "form-control select2 input-sm" })
                                </div>
                                <div class="form-group col-md-2" id="searcaccinpurch">
                                    @Html.Label("Account In Purchase", null, new { @class = "control-label" })
                                    @Html.DropDownList("PddlAccount", (SelectList)ViewBag.Acc, new { @class = "form-control select2 input-sm" })
                                </div>
                                <div class="form-group col-md-2" id="searchstatus">
                                    @Html.Label("Status", null, new { @class = "control-label" })
                                    @Html.DropDownList("Status", (SelectList)ViewBag.ItStatus, new { @class = "form-control select2" })
                                </div>
                                <div class="form-group col-md-2" id="search">
                                    <input type="submit" class="btn btn-submit" value="Submit" />
                                </div>
                                <div class="form-group col-md-2" id="close">
                                    <input type="button" class="btn btn-close" value="Close" />
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @using (Html.BeginForm("DeleteAll", "BillSundry", FormMethod.Post, new { id = "payform", role = "form" }))
    {
        <div class="box-body">
            <table class="table table-bordered table-hover" id="MyTable">
                <thead>
                    <tr>
                        <td data-priority="2">S/N</td>
                        <td data-priority="1">Name</td>
                        <td data-priority="2">Type</td>
                        <td data-priority="3">Nature</td>
                        <td data-priority="4">Default Value</td>
                        <td data-priority="4">Amount Type</td>
                        <td data-priority="4">Sale Account</td>
                        <td data-priority="4">Purchase Account</td>
                        <td data-priority="5">CreatedBy</td>
                        <td data-priority="6">Status</td>
                        <td data-priority="1">Action</td>
                        <td data-priority="2"><input type="checkbox" id="select_all" /></td>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
        if (User.IsInRole("Dev") || User.IsInRole("Delete BillSundry"))
        {
            <div class="box-footer text-right col-md-12" id="sub">
                <button type="submit" id="save" data-confirm="Are u sure want to delete?" class="btn btn-danger">Delete</button>
            </div>
        }
    }
</div>
