                         }
                     }
                 },
                  {
                      "name": "id", "data": function (data) {
                          var rest = "";
                          @{
                              if (User.IsInRole("Dev") || User.IsInRole("Edit BillSundry"))
                              {
                                  actData += "<a class=\"modal-edit btn btn-icons btn-rounded btn-edit\" href=\"/BillSundry/Edit/'+ data.id +'\" title=\"Edit BillSundry\"><i class=\"fa fa-pencil\" ></i></a> ";
                              }
                           }
                          rest += '@Html.Raw(actData)';
                          if (data.chckstat == 1) {
                              @{
                                  if (User.IsInRole("Dev") || User.IsInRole("Delete BillSundry"))
                                  {
                                      actData = "";
                                      actData += "<a class=\"btn btn-icons btn-rounded btn-delete\" href=\"javascript:void(0)\" onclick=\"getcurrstocks('+data.id+')\"  title=\"View Used BillSundry\"><i class=\"fa fa-trash\" ></i></a> ";
                                  }
                              }
                              rest += '@Html.Raw(actData)';
                          } else {
                              @{
                                  if (User.IsInRole("Dev") || User.IsInRole("Delete BillSundry"))
                                  {
                                      actData = "";
                                      actData += "<a class=\"modal-delete btn btn-icons btn-rounded btn-delete\" href=\"/BillSundry/Delete/'+ data.id +'\"  title=\"Delete BillSundry\"><i class=\"fa fa-trash\" ></i></a> ";
                                  }
                              }
                              rest += '@Html.Raw(actData)';
                          }
                              //if (User.IsInRole("Dev") || User.IsInRole("Delete BillSundry"))
                              //{
                              //    if()
                              //        actData += "<a class=\"modal-delete btn btn-icons btn-rounded btn-delete\" href=\"/BillSundry/Delete/'+ data.id +'\"  title=\"Delete BillSundry\"><i class=\"fa fa-trash\" ></i></a> ";
                              //}
                              //actData += "<a class=\"btn btn-icons btn-rounded btn-edit\" href=\"javascript:void(0)\" onclick=\"getcurrstocks('+data.id+')\"  title=\"View Used BillSundry\"><i class=\"fa fa-bookmark\" ></i></a> ";

                              return rest;
                      }
