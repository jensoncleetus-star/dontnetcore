        function reload_table() {
            oTable.clear().draw();
            oTable.ajax.reload(null, false); //reload datatable ajax
            isTicked();
        }
        //function checkused(id) {
        //    alert("hi");
        //    window.location.href = "/BillSundry/Delete/" + id;
        //}

        //select all checkboxes
        $('body').on('change', '#select_all', function () {
            $(".checkbox").prop('checked', $(this).prop("checked")); //change all ".checkbox" checked status
        });

        //".checkbox" change
        $('body').on('change', '.checkbox', function () {
            //uncheck "select all", if one of the listed checkbox item is unchecked
            if (false == $(this).prop("checked")) { //if this item is unchecked
                $("#select_all").prop('checked', false); //change "select all" checked status to false
            }
            isTicked();
        });
        //isTicked();

      var checkList = document.getElementById('list1');
      /******* Function to list and hide dropdown checklist while clicking on 'Select Fields' *******/
      checkList.getElementsByClassName('anchor')[0].onclick = function (evt) {
          if (checkList.classList.contains('visible'))
              checkList.classList.remove('visible');
          else
              checkList.classList.add('visible');
      }

      /******* Function to show and hide fields while clicking on checkboxes in 'Select Fields' *******/
      $("ul li input:checkbox").click(function () {

          var _show = 0;

          //Name
          if ($("#liname").prop("checked") == true) {
              $("#searchname").show();
              _show = 1;
          }
          else {
              $('#BSName').val("");
              $("#searchname").hide();
              oTable.draw();
          }

          //Default Value
          if ($("#lidefaultvalue").prop("checked") == true) {
              $("#searchdeafultval").show();
              _show = 1;
          }
          else {
              $('#DfValue').val("");
              $("#searchdeafultval").hide();
              oTable.draw();
          }

          //Type
          if ($("#litype").prop("checked") == true) {
              $("#searchtype").show();
              _show = 1;
          }
          else {
              $('#BSType').val(null);
              $("#searchtype").hide();
              oTable.draw();
          }

          //Amount Type
          if ($("#liamounttype").prop("checked") == true) {
              $("#searchamnttype").show();
              _show = 1;
          }
          else {
              $('#AmountType').val(null);
              $("#searchamnttype").hide();
              oTable.draw();
          }

          //Account In Sale
          if ($("#liaccinsale").prop("checked") == true) {
              $("#searchaccinsale").show();
              _show = 1;
          }
          else {
              $('#SddlAccount').val(0).trigger('change');
              $("#searchaccinsale").hide();
              oTable.draw();
          }

          //Account In purchase
          if ($("#liaccinpurchase").prop("checked") == true) {
              $("#searcaccinpurch").show();
              _show = 1;
          }
          else {
              $('#PddlAccount').val(0).trigger('change');
              $("#searcaccinpurch").hide();
              oTable.draw();
          }

          //Status
          if ($("#listatus").prop("checked") == true) {
              $("#searchstatus").show();
              _show = 1;
          }
          else {
              $('#Status').val(null);
              $("#searchstatus").hide();
              oTable.draw();
          }

          if (_show == 1) {
              $('#advsearchlist').show();
          }
          else {
              $('#advsearchlist').hide();
          }
      });

