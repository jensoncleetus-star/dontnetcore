
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Change Status</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("setopencloseupdate", "Employee", FormMethod.Post, new { role = "form", id = "createform" }))
    {
        <script type="text/javascript">
            $('form#popupForm').removeData("validator");
            $('form#popupForm').removeData("unobtrusiveValidation");
        </script>
        <div class="row">
            <div class="form-group col-md-12">
                @Html.Label("Open/Close", null, new { @class = "control-label" })
                @Html.DropDownList("OpenClose", (SelectList)ViewBag.openclose, new { id = "openclose", @class = "form-control" })
            </div>
            <input type="hidden" name="protaskid" value="@ViewBag.protask" />
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" class="btn btn-info col-sm-offset-4" value="Update" />
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>


