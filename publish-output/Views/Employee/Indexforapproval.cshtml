@model QuickSoft.ViewModel.EmployeeViewModel
@{
    ViewBag.Title = "Employee List";
    ViewBag.SubTitle = "List Employee";
    ViewBag.Active = "Employee";
    string actData = "";
}
<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">Employee</h3>
        <div class="pull-right">
            @if (User.IsInRole("Dev") || User.IsInRole("Create Employee"))
            {
                <i class="ace-icon fa fa-hand-o-right icon-animated-hand-pointer blue"></i>
                <a class="btn btn-info no-border" href="/Employee/Create">
                    <i class="glyphicon glyphicon-plus"></i> Create
                </a>
            }
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">

            <div class=" search-box" id="">

                <div class="search-body col-md-12" style="background:none;">
                    <div class="box-body">
                        <form id="search-form">

                            <div class="row">
                                <div class="form-group col-md-2" id="searchOpnCls" style="">
                                    @Html.Label("Open / Close", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlOpnCls", new SelectList(new List<SelectListItem>
                                        {

                                        new SelectListItem() {Text = "Open", Value="1"},
                                        new SelectListItem() {Text = "All", Value=""},
                                        new SelectListItem() {Text = "Closed", Value="0"}
                                        }, "Value", "Text"), new { @class = "form-control input-sm" })
                                </div>
                                <div class="form-group col-md-2" id="search">
                                    <input type="submit" class="btn btn-submit" value="Submit" />
                                </div>

                            </div>
                        </form>

                    </div>
                </div>
            </div>
        </div>
    </div>
    <table class="table table-bordered table-hover" id="MyTable">
        <thead>
            <tr>
                <td data-priority="1">#</td>
                <td data-priority="2">Name</td>
                <td data-priority="2">Employee Code</td>
                <td data-priority="3">Address</td>
                <td data-priority="4">Phone</td>
                <td data-priority="6">Email</td>
                <td data-priority="4">Is User</td>
                @*<td data-priority="6">Branch</td>*@
                <td data-priority="5"> Action</td>
            </tr>
        </thead>
        <tbody></tbody>
    </table>

    @Html.Partial("../Common/_ModalChange")
    @Html.Partial("../Common/_ModalDelete")

    @Html.Partial("../Common/_ModalEdit")


    <div id="modal-ban" class="modal fade" role="dialog" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content danger">
            </div>
        </div>
    </div>
    @section scripts{
        <script type="text/javascript">
        var oTable = $('#MyTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "pageLength": 50,
            responsive: false,

            "ajax": {
                "url": '/Employee/GetDataprovileupdate',
                "type": "POST",
                "data": function(data) {
                    data.opcls = $("#ddlOpnCls").val();
                },

                "datatype": "json"
            },
            "columns": [
                     {
                         "data": "id", "name": "id",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },
                 {
                     "name": "Name", "data": function (data) {
                         var prname = data.Name;
                         if (prname != null) {
                             @{
                                 var datas = "";
                                 //if (User.IsInRole("Dev") || User.IsInRole("View Employee"))
                                 //{
                                 datas = "'<a href=\"/Employee/Details/'+ data.id +'\">'+ data.Name +'</a>' ";
                                 //}
                                 //else
                                 //{
                                 //    datas = "data.Name";
                                 //}
                             }
                             return @Html.Raw(datas);
                         }
                         else {
                             var datas = "";
                             return (datas);
                         }
                     }
                 },
                 { "data": "EMPCode", "name": "EMPCode" },
                 { "data": "Address", "name": "Address" },
                 { "data": "Phone", "name": "Phone" },
                 { "data": "Email", "name": "Email" },
                 {
                     "data": "UserStatus", "name": "UserStatus", "render": function (data) {
                         if (data) {
                             return '<label>YES<label>';
                         }
                         else {
                             return '<label>NO<label>';
                         }
                     }
                 },
                // { "data": "Branch", "name": "Branch" },
                  {
                      "name": "id", "data": function (data) {
                          var restt = "";
                           @{


                               actData = "<a href=\"/Employee/detailscompair/'+ data.id +'\" title=\"Compair Employee\">Approval</a> ";

                             }
                          restt = '@Html.Raw(actData)';
                          return restt;
                         }
                  },
            ]
        });

        /* function for view detail popup */
        $('#MyTable').on('click', 'a.details', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        })

        /* function for Create popup */

        $('div').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        });
        $('#modal-create').on('submit', '#createform', function (e) {
            e.preventDefault();
            var url = $('#createform')[0].action;
            var data = $('#createform').serialize();
            createajax(url, data, '#modal-create');
        });

        $('#search-form').on('submit', function (e) {
           // chkflag = 1;
            e.preventDefault();
            //checkList.classList.remove('visible');
            oTable.draw();
        });
        /* function for Edit popup */

        $('div').on('click', '.modal-edit', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-edit');
        });
        $('#modal-edit').on('submit', '#editform', function (e) {
            e.preventDefault();
            var url = $('#editform')[0].action;
            var data = $('#editform').serialize();
            createajax(url, data, '#modal-edit');
        });
            $('#modal-edit').on('submit', '#createform', function (e) {
                e.preventDefault();
                var url = $('#createform')[0].action;
                var data = $('#createform').serialize();
                createajax(url, data, '#modal-edit');
            });



        /* function for delete popup */
        $('#MyTable').on('click', '.modal-delete', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-delete');
        });
        $('#modal-delete').on('submit', '#deleteform', function (e) {
            e.preventDefault();
            var url = $('#deleteform')[0].action;
            var data = $('#deleteform').serialize();
            createajax(url, data, '#modal-delete');
        });

        /* chang status */
        $('.table').on('click', '.modal-change', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-change');
        });
        $('#modal-change').on('submit', '#changeform', function (e) {
            e.preventDefault();
            var url = $('#changeform')[0].action;
            var data = $('#changeform').serialize();
            createajax(url, data, '#modal-change');
        });
        /* function for ban popup */
        $('#MyTable').on('click', '.modal-ban', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-ban');
        });
        $('#modal-ban').on('submit', '#banform', function (e) {
            e.preventDefault();
            var url = $('#banform')[0].action;
            var data = $('#banform').serialize();
            createajax(url, data, '#modal-ban');
        });

        </script>
    }

