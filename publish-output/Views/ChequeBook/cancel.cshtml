
@model QuickSoft.Models.chequetransactionviewmodal
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Edit Book</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("cancel", "ChequeBook", FormMethod.Post, new { id = "editform" }))
    {
        
    
        @Html.HiddenFor(model => model.bookid)
        <div class="row">
            <div class="col-md-12">
                <div class="form-group">
                    @Html.LabelFor(model => model.docserialno, htmlAttributes: new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.docserialno, new { htmlAttributes = new { @class = "form-control", @placeholder = "", @required = "required" } })

                </div>
            </div>
            <div class="col-sm-12 form-group">
                @Html.LabelFor(model => model.transdate, htmlAttributes: new { @class = "control-label" })*
                <div class="input-group date">
                    <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                    @Html.TextBoxFor(m => m.transdate, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @required = "required", tabindex = 2 })
                </div>
            </div>
            <div class="col-md-12">
                <div class="form-group">
                    @Html.LabelFor(model => model.remarks, htmlAttributes: new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.remarks, new { htmlAttributes = new { @class = "form-control", autofocus = "autofocus", @placeholder = "", @required = "required" } })

                </div>
            </div>

        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" value="Submit" class="btn btn-info col-sm-offset-4" />
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")

}
@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    <script>
        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true,

        });
      
    </script>
}
