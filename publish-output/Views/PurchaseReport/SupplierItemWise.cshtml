@{
    ViewBag.Title = "Search Supplier Item Wise Sale";
    ViewBag.SubTitle = "Sales Report";
    ViewBag.Active = "Reports";

}

<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">Search Supplier Item Wise Sale</h3>
    </div>
    <div class="box-body">
        <form id="search-form">
            <input type="hidden" id="suppliername" />
            <input type="hidden" id="cname" value="@ViewBag.CName" />
            <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
            <input type="hidden" id="PoNo" value="@ViewBag.PartNoCheck" />

            <div class="form-group col-md-2">
                @Html.Label("Supplier", null, new { @class = "control-label" })
                @Html.DropDownList("ddlSupplier", (SelectList)ViewBag.Supplier,  new { @class = "form-control input-sm select2", @required = "required" })
            </div>
            <div class="form-group col-md-2">
                @Html.Label("Item Name/Code", null, new { @class = "control-label" })
                @Html.DropDownList("ddlItem", (SelectList)ViewBag.Item, new { @class = "form-control input-sm select2" })
            </div>
            @if (@ViewBag.EnableMCcheck == 0)
            {
            <div class="form-group col-md-2">
                @Html.Label("Material Center", null, new { @class = "control-label" })
                @Html.DropDownList("ddlMC", (SelectList)ViewBag.MC, new { @class = "form-control input-sm" })
            </div>
            }
            <div class="form-group col-md-2">
                @Html.Label("From", null, new { @class = "control-label" })
                <div class="input-group date">
                    @Html.TextBox("From", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                    <div class="input-group-addon">
                        <i class="fa fa-calendar"></i>
                    </div>
                </div>
            </div>
            <div class="form-group col-md-2">
                @Html.Label("To", null, new { @class = "control-label" })
                <div class="input-group date">
                    @Html.TextBox("To", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                    <div class="input-group-addon">
                        <i class="fa fa-calendar"></i>
                    </div>
                </div>
            </div>

            <div class="box-footer col-md-12">
                <input type="submit" class="btn btn-info col-sm-offset-5" value="Submit" />
                <button type="button" class="btn btn-default" onclick="@("window.location.href='/Home/Index'");">Cancel</button>
            </div>
        </form>
    </div>
</div>
<div class="box box-default" id="SReport">
    <input type="hidden" id="supplier" value="@ViewBag.supplier" />
    <input type="hidden" id="PoNo" value="@ViewBag.PartNoCheck" />
    <div class="box-header with-border">
        <h3 class="box-title">View Supplier Item Wise Purchase</h3>
    </div>
    <div class="box-body">
        <div class="box-body">
            <table class="display table table-bordered" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td>S/N</td>
                        <td>Part No</td>
                        <td>Item</td>
                        <td class="headeralign">Avg. Price</td>
                        <td class="headeralign">Purchase Qty.</td>
                        <td class="headeralign">Return Qty.</td>
                        <td class="headeralign">Nett Purchase Qty.</td>
                        <td class="headeralign">Purchase Amt.</td>
                        <td class="headeralign">Retun Amt.</td>
                        <td class="headeralign">Nett Purchase Amt.</td>
                        <td class="headeralign">Purchase Vouchers</td>
                        <td class="headeralign">Purchase Return Vouchers</td>
                    </tr>
                </thead>
                <tbody></tbody>
                <tfoot>
                    <tr>
                        <th>Total:</th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
}
@section Scripts {
    @Scripts.Render("~/js/bootstrap-datepicker")
    <script type="text/javascript">
        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        })

        $(document).ready(function () {

            $('#SReport').hide();
            //for set default date
            $('#To').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });
            $('#From').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });

            var date = new Date();
            var today = new Date(date.getFullYear(), date.getMonth(), date.getDate());
            var priordate = new Date(new Date().setDate(today.getDate() - 30));
            $('#To').datepicker('setDate', today);
            $('#From').datepicker('setDate', priordate);
            //---

            CallRepSupplier();
            ItemSearchable();
            CallRepMCUser();

        });

        jQuery(function ($) {
            var oTable = $('#UserTable').DataTable({
                "processing": true, // for show progress bar
                "serverSide": true, // for process server side
                "filter": false, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
                // "bStateSave": true,
                "bLengthChange": false,
                "paging": true,
                "pageLength": 5000,
                "deferLoading": 0,
                "ordering": false,
                "ajax": {
                    "url": '/PurchaseReport/GetSupplierItemWise',
                    "data": function (data) {
                        data.ddlSupplier = $('#ddlSupplier').val();
                        data.ddlItem = $('#ddlItem').val();
                        data.From = $('#From').val();
                        data.To = $('#To').val();
                        data.ddmc = $('#ddlMC').val();

                    },
                    "type": "POST",
                    "datatype": "json"
                },
                "order": [[0, "desc"]],
                "columns": [
                     {
                         "data": "ItemID", "name": "ItemID",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },

                     { "data": "PartNumber", "name": "PartNumber" },

                    { "data": "Item", "name": "Item" },

                    { "data": "AvgPrice", "name": "AvgPrice", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                   {
                       "name": "PurQty", "data": function (data) {
                           if (data.ItemUnitID != data.SubUnitId && data.ItemUnitID != null && data.SubUnitId != null) {
                               if ((data.SubpurQty == 0))
                                   return data.PripurQty + " " + data.PriUnit;
                               else
                                   return data.PripurQty + " " + data.PriUnit + ", " + data.SubpurQty + " " + data.SubUnit
                           }
                           else
                               return data.PripurQty + " " + data.PriUnit;
                       }, "sClass": "numberright"
                   },
                     {
                         "name": "ReturnQty", "data": function (data) {
                             if (data.ItemUnitID != data.SubUnitId && data.ItemUnitID != null && data.SubUnitId != null) {
                                 if ((data.SubRetQty == 0))
                                     return data.PriRetQty + " " + data.PriUnit;
                                 else
                                     return data.PriRetQty + " " + data.PriUnit + ", " + data.SubRetQty + " " + data.SubUnit
                             }
                             else
                                 return data.PriRetQty + " " + data.PriUnit;
                         }, "sClass": "numberright"
                     },
                    //{ "data": "NettSaleQty", "name": "NettSaleQty", render: $.fn.dataTable.render.number(",", ".", 2) },
                     {
                         "name": "NettpurQty", "data": function (data) {
                             var total;
                             // var netQty = ((data.PriSaleQty - data.PriRetQty) * data.ConFactor) + (data.SubSaleQty - data.SubRetQty);
                             var primary = (data.NetQty / data.ConFactor);
                             if (data.NetQty % data.ConFactor == 0) {
                                 total = (data.NetQty / data.ConFactor) + " " + data.PriUnit;
                             }
                             else {
                                 var prim = (Math.floor((data.NetQty / data.ConFactor) * 100) / 100).toFixed(0);
                                 var sub = (data.NetQty % data.ConFactor).toFixed(0);
                                 total = prim + " " + data.PriUnit + ", " + sub + " " + data.SubUnit
                             }
                             return total;
                         }, "sClass": "numberright"
                     },
                    { "data": "purAmt", "name": "purAmt", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                    { "data": "RetunAmt", "name": "RetunAmt", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                     {
                         "name": "NettpurAmt",
                         "data": function (data) {
                             return ((data.purAmt - data.RetunAmt).toFixed(2))
                         }, "sClass": "numberright"
                     },
                    { "data": "NoOfVchpur", "name": "NoOfVchpur", "sClass": "numberright" },
                    { "data": "NoOfVchReturn", "name": "NoOfVchReturn", "sClass": "numberright" },

                    //{ "data": "saleQty", "name": "saleQty", "visible": false, },
                    //{ "data": "retQty", "name": "retQty", "visible": false, },
                    //{ "data": "nettQty", "name": "nettQty", "visible": false, },
                    //{ "data": "PriUnit", "name": "PriUnit", "visible": false, },


                ],
                buttons: [//'copy', 'csv', 'excel', 'pdf', 'print'
                'colvis',
                {
                    extend: 'print',//
                    exportOptions: {
                        columns: ':visible'
                    },
                    title: "",
                    footer: true,
                    filename: function () {
                        return 'Supplier ItemWise-Purchase';
                    },
                    message: function () {
                        var head = '<table class="tblcompact table table-bordered"><thead>' +
                             '<tr><th class="text-center"><h3 style="margin-top: 0px;">' + $('#cname').val() + '</h3>' + $('#caddress').val() + '<h4> Purchase Report (Supplier Item Wise)</h4></th></tr>' +
                             '<tr><th><span class="text-left">Supplier : ' + $("#suppliername").val() + '</span><span class="text-right pull-right"> From :  ' + $('#From').val() + ' To :' + $('#To').val() + '</span></th></tr></thead><tbody><tr><td>';
                        return head;

                    },
                    customize: function (win) {
                        $(win.document.body).find('table, th,tr, td ')
                        // .css('border', 'inherit')
                        .css('font-size', '10pt')
                        .css('padding', '5px')
                        .addClass('compact');
                        $(win.document.body).append('</td></tr></tbody>')

                    }
                }, 'copy', 'csv',// 'excel',
                {
                    extend: 'excel',//
                    title: "",
                    footer: true,
                    filename: function () {
                        return 'Supplier ItemWise-Purchase';
                    },
                    message: function () {
                        var head = '' + $('#cname').val() + '\n' +
                         '' + $('#caddress').val() + '\n' +
                         ' Purchase Report (Supplier Item Wise) \n' +
                         ' Supplier : ' + $('#suppliername').val() + '\n' +
                         'From :  ' + $('#From').val() + ' To :' + $('#To').val() + '';
                        return head;
                    },
                    pageSize: 'A4',
                    exportOptions: {
                        columns: ':visible'
                    },
                },
                {
                    extend: 'pdf',//
                    title: "",
                    footer: true,
                    filename: function () {
                        return 'Supplier ItemWise-Purchase';
                    },
                    message: function () {
                        var head = '' + $('#cname').val() + '\n' +
                         '' + $('#caddress').val() + '\n' +
                         ' Purchase Report (Supplier Item Wise) \n' +
                         ' Supplier : ' + $('#suppliername').val() + '\n' +
                         'From :  ' + $('#From').val() + ' To :' + $('#To').val() + '';
                        return head;
                    },
                    pageSize: 'A4',
                    exportOptions: {
                        columns: ':visible'
                    },
                    customize: function (doc) {
                        doc.pageMargins = [10, 10, 10, 10];
                        doc.defaultStyle.fontSize = 10;
                        doc.styles.tableHeader.fontSize = 10;
                        doc.styles.title.fontSize = 12;
                        // Header font and bg color
                        doc.styles.tableHeader.fillColor = '#d3d3d3';
                        doc.styles.tableHeader.color = 'black';
                        // Remove spaces around page title
                        doc.content[0].text = doc.content[0].text.trim();

                        doc.styles['td:nth-child(2)'] = {
                            width: '100%',
                            'max-width': '100%'
                        }


                        //doc.content[1].table.widths = [
                        //'5%',
                        //'15%',
                        //'8%',
                        //'8%',
                        //'8%',
                        //'8%',
                        //'8%',
                        //'10%',
                        //'10%',
                        //'10%',
                        //'10%'
                        //]

                        var objLayout = {};
                        // Horizontal line thickness
                        objLayout['hLineWidth'] = function (i) { return .5; };
                        // Vertikal line thickness
                        objLayout['vLineWidth'] = function (i) { return .5; };
                        //// Horizontal line color
                        //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                        //// Vertical line color
                        //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                        // Left padding of the cell
                        objLayout['paddingLeft'] = function (i) { return 4; };
                        // Right padding of the cell
                        objLayout['paddingRight'] = function (i) { return 4; };
                        // Inject the object in the document
                        doc.content[1].layout = objLayout;
                        // Footer font and bg color
                        doc.styles.tableFooter.fillColor = '#d3d3d3';
                        doc.styles.tableFooter.color = 'black';
                    }


                },

                ],

                sDom: "lBfr<'datatable-scroll't>ip",
                "lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                "footerCallback": function (row, data, start, end, display) {
                    var api = this.api(), data;

                    // Remove the formatting to get integer data for summation
                    var intVal = function (i) {
                        return typeof i === 'string' ?
                        i.replace(/[\$,]/g, '') * 1 :
                        typeof i === 'number' ?
                            i : 0;
                    };

                    // Total over all pages
                    total = api
                    .column(3)
                    .data()
                    .reduce(function (a, b) {
                        return intVal(a) + intVal(b);
                    }, 0);

                    // Total over this page
                    pageTotal = api
                    .column(3, { page: 'current' })
                    .data()
                    .reduce(function (a, b) {
                        return intVal(a) + intVal(b);
                    }, 0);

                    // Update footer
                    $(api.column(3).footer()).html(
                    pageTotal.toFixed(2)
                    //'$' + pageTotal + ' ( $' + total + ' total)'
                    );


                    // Total over all pages
                    total = api
                    .column(7)
                    .data()
                    .reduce(function (a, b) {
                        return intVal(a) + intVal(b);
                    }, 0);

                    // Total over this page
                    pageTotal = api
                    .column(7, { page: 'current' })
                    .data()
                    .reduce(function (a, b) {
                        return intVal(a) + intVal(b);
                    }, 0);

                    // Update footer
                    $(api.column(7).footer()).html(
                    pageTotal.toFixed(2)
                    //'$' + pageTotal + ' ( $' + total + ' total)'
                    );


                    // Total over all pages
                    total = api
                    .column(8)
                    .data()
                    .reduce(function (a, b) {
                        return intVal(a) + intVal(b);
                    }, 0);

                    // Total over this page
                    pageTotal = api
                    .column(8, { page: 'current' })
                    .data()
                    .reduce(function (a, b) {
                        return intVal(a) + intVal(b);
                    }, 0);

                    // Update footer
                    $(api.column(8).footer()).html(
                    pageTotal.toFixed(2)
                    //'$' + pageTotal + ' ( $' + total + ' total)'
                    );


                    // Total over all pages
                    total = api
                    .column(9)
                    .data()
                    .reduce(function (a, b) {
                        return intVal(a) + intVal(b);
                    }, 0);

                    // Total over this page
                    pageTotal = api
                    .column(9, { page: 'current' })
                    .data()
                    .reduce(function (a, b) {
                        return intVal(a) + intVal(b);
                    }, 0);

                    // Update footer
                    $(api.column(9).footer()).html(
                    pageTotal.toFixed(2)
                    //'$' + pageTotal + ' ( $' + total + ' total)'
                    );


                    //var type = $('#itemname').text();
                    //if (type != 'All') {
                    //    var saleQty = api.cell(0, 3).data();
                    //    var retQty = api.cell(0, 4).data();
                    //    var nettQty = api.cell(0, 5).data();

                    //    $(api.column(3).footer()).html(saleQty);
                    //    $(api.column(4).footer()).html(retQty);
                    //    $(api.column(5).footer()).html(nettQty);
                    //}
                   

                    var table = $('#UserTable').DataTable();
                    if (!table.data().any()) {
                        $('#UserTable tfoot').hide();
                    } else {
                        $('#UserTable tfoot').show();
                    }                    

                }

            });
            $('#search-form').on('submit', function (e) {
                e.preventDefault();
                var data = $('#ddlSupplier').select2('data')
                $("#suppliername").val(data[0].text);
                oTable.draw();
                $('#SReport').show();
            });


            $('#UserTable tbody').on('click', 'tr', function () {
                if ($(this).hasClass('selected')) {
                    $(this).removeClass('selected');
                }
                else {
                    oTable.$('tr.selected').removeClass('selected');
                    $(this).addClass('selected');
                    $(this).addClass('dataTables_row');
                }
            });

            $('#UserTable tbody').on('dblclick', 'tr', function (e) {
                var data = oTable.row(this).data();
                var url = "/PurchaseReport/itemDetails?iditem=" + data.ItemID + "&supplier=" + $("#ddlSupplier").val() + "&from=@ViewBag.fromdate&to=@ViewBag.todate&ddmc=" + $('#ddlMC').val();
                $(location).attr('href', url);
            });

            var pono = $('#PoNo').val();
            if (pono == 'inactive') {
                var column1 = oTable.column(1);
                column1.visible(false);
            } else {
                var column1 = oTable.column(1);
                column1.visible(true);
            }
        });

    </script>
}

