            //data.htdate = $('#ToDate').val();
            //data.project = $('#ddlProject').val();
            //data.task = $('#ddlProTask').val();
            //data.TaxType = $('#ddlTaxType').val();
            data.srchtxt = $('#Searchtext').val();
        }

