@{
    ViewBag.Title = "List";
    ViewBag.SubTitle = "AMC List";
    ViewBag.Active = "Transactions";
    string actData = "";
    string actData2 = "";
    string delchk = "";
    string deleteBTn = "";

    deleteBTn = "{text: 'Delete', className: 'btn-danger', action: function(e, dt, node, config) {" +
        "if ($('.checkbox:checked').length > 0) {if (confirm('Are you sure you want to delete this?')) {$('#AMC').submit(); e.preventDefault();} " +
         "} else {alert('Please Select Rows..!!');e.preventDefault();}}},";

    string refreshBTn = "{text: 'Refresh', className: 'btn-primary', action: function(e, dt, node, config) {" +
              " $('#AmcTable').DataTable().ajax.reload();" +
