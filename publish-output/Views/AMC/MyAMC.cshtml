@model QuickSoft.ViewModel.AMCViewModel
@{
    ViewBag.Title = "List";
    ViewBag.SubTitle = "My AMC List";
    ViewBag.Active = "Transactions";
    string actData = "";

    string refreshBTn = "{text: 'Refresh', className: 'btn-primary', action: function(e, dt, node, config) {" +
              " $('#AmcTable').DataTable().ajax.reload();" +
               " }},";
}

<style type="text/css">
    .txt-med {
   color: #ffdede !important;
       /* border-bottom: 1px solid black;*/
    }

    .txt-red {
      color: #dd1111 !important;
        /*color: white !important;
        border-bottom: 1px solid black;*/
    }

    .txt-med a {
        color: brown !important;
    }


    .txt-red a {
        color: red !important;
    }
    .dropdown-check-list {
        display: inline-block;
    }

        .dropdown-check-list .anchor {
            position: relative;
            cursor: pointer;
            display: inline-block;
            padding: 5px 50px 5px 10px;
            border: 1px solid #ccc;
            width: 150px;
            background: #fff;
            text-align: center;
        }

            .dropdown-check-list .anchor:after {
                position: absolute;
                content: "";
                border-left: 2px solid black;
                border-top: 2px solid black;
                padding: 5px;
                right: 10px;
                top: 20%;
                -moz-transform: rotate(-135deg);
                -ms-transform: rotate(-135deg);
                -o-transform: rotate(-135deg);
                -webkit-transform: rotate(-135deg);
                transform: rotate(-135deg);
            }

            .dropdown-check-list .anchor:active:after {
                right: 8px;
                top: 21%;
            }

        .dropdown-check-list ul.items {
            padding: 0px;
            display: none;
            margin: 0;
            border: 1px solid #ccc;
            border-top: none;
            position: absolute;
            z-index: 9999;
        }

            .dropdown-check-list ul.items li {
                list-style: none;
                background: #fff;
                padding: 5px;
            }

    .add-btn-item {
        border-radius: 23px;
        padding: 6px 20px;
    }

    .dropdown-check-list.visible .anchor {
        color: #0094ff;
    }

    .dropdown-check-list.visible .items {
        display: block;
    }

    .box-header .pull-right {
        margin-top: -22px;
    }

    .col-md-3 {
        float: none;
        display: inline-block;
    }

    @@media only screen and (max-width: 400px) {
        .top3 {
            margin-top: 27px;
        }

        .adv-search-height {
            margin-left: 10px !important;
        }

        .responsive-search {
            padding: 0px 0px 0px 0px !important;
        }

        .btn-close {
            background-color: red !important;
            width: 150px !important;
        }

        .task-name-center {
            text-align: center !important;
        }
    }

    @@media only screen and (min-width: 800px) {
        .top3 {
            margin-top: 10px;
        }

        .adv-search-height {
            top: -8px !important;
            margin-left: 13px;
        }

        .responsive-search {
            padding: 20px 0px 0px 50px !important;
        }

        .btn-close {
            background-color: red !important;
        }

        .btn-h-change {
            margin: 0px !important;
        }

        .btn-up {
            margin-top: 0px !important;
        }
    }
</style>

<div class="box box-info">
    <div class="box-header with-border">
        <div class="row">
            <div class="col-md-10 col-xs-12 task-name-center">
                <h3 class="box-title " style="font-size:x-large;">My AMC</h3>
            </div>
            <div class="col-md-2 col-xs-12 pull-right" style="padding: 0px; margin: 10px 0px 0px 0px;">
                <div class="row">
                    <div class="col-md-10 col-xs-6 pull-right" style="padding:0px;">
                        <a class="btn btn-info no-border" style="margin-top:2rem; " href="/AMC/Create">
                            <i class="glyphicon glyphicon-plus"></i>Create AMC
                        </a>

                    </div>
                    <div class="col-md-10 col-xs-6 pull-right btn-h-change" style="padding:0px;">
                        <a class="btn btn-info no-border btn-up" style="margin-top:2rem; " href="/AMC/Index">
                            <i class="glyphicon glyphicon-plus"></i>List
                        </a>
                    </div>

                </div>

            </div>
            <div class="col-md-2 col-xs-10 mx-auto" id="taskchecklist" style="padding:0px; margin:0px;">

                <div id="list1" class="dropdown-check-list" tabindex="100">
                    <span class="anchor" style="z-index:9;">Select Fields</span>
                    <ul class="items">
                        <li><input type="checkbox" id="lilocation" />Location</li>
                        <li><input type="checkbox" id="lireminderdate" />Reminder Date</li>
                        <li><input type="checkbox" id="lienddate" />Expiry Date</li>
                        <li><input type="checkbox" id="licontrno" checked />Contract No.</li>
                        <li><input type="checkbox" id="licustname" checked />Customer</li>
                        <li><input type="checkbox" id="licontrname" />Contract Name</li>
                        <li><input type="checkbox" id="licontrtype" />Contract Type</li>

                        <li><input type="checkbox" id="listartdate" />Start Date</li>

                    </ul>
                </div>
            </div>
            <div class="col-md-10 col-xs-2 text-right top3" style="">
                &nbsp;
            </div>
            <div class="col-md-12">
                <div class="box-body search-box adv-search-height" id="advsearchlist">

                    <div class="search-body col-md-12 responsive-search" style="background:none;">

                        <form id="search-form">
                            <div class="row">
                                <input type="hidden" id="remId" />
                                <div class="form-group col-md-3" id="searchRfromdate">
                                    @Html.Label("From Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("RFromDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group col-md-3" id="searchRtodate">
                                    @Html.Label("To Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("RToDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group col-md-3" id="searchEfromdate">
                                    @Html.Label("Start Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("EFromDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>


                                <div class="form-group col-md-3" id="searchenddate">
                                    @Html.Label("End Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("ToDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group col-md-3 col-xs-12" id="searchcontrno">
                                    @Html.Label("Contract No", null, new { @class = "control-label" })
                                    @Html.TextBox("ContractNo", "", new { @class = "form-control input-sm" })
                                </div>

                                <div class="form-group col-md-3" id="searchcustname">
                                    @Html.Label("Customer Name", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlCustomer", (SelectList)ViewBag.Contracts, new { @class = "form-control input-sm select2" })
                                </div>
                                <div class="form-group col-md-2" id="searchlocation" style="margin-bottom: 14px; display: none;">
                                    @Html.Label("Location", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddllocation", (SelectList)ViewBag.TStat, new { @class = "form-control" })
                                </div>
                                <div class="form-group col-md-3" id="searchcontrname">
                                    @Html.Label("Contract Name", null, new { @class = "control-label" })
                                    @Html.DropDownList("ddlContractName", (SelectList)ViewBag.Contracts, new { @class = "form-control input-sm select2" })
                                </div>

                                <div class="form-group col-md-3 " id="searchcontrtype" style="display:none;">
                                    @Html.Label("Contract Type", null, new { @class = "control-label " })
                                    @Html.DropDownList("ddlContractType", (SelectList)ViewBag.Contracts, new { @class = "form-control input-sm select2" })
                                </div>





                                <div class="form-group col-md-3" id="searchstartdate">
                                    @Html.Label("Start Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("FromDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>


                                <div class="form-group  col-md-2 col-xs-12">
                                    @Html.Label("Priority", null, new { @class = "control-label" })
                                    @Html.DropDownList("ContractLevelId", new SelectList(new List<SelectListItem>
                                    {
                                    new SelectListItem() {Text = "All",   Value     =   "0"},

                                        new SelectListItem() {Text = "Low",   Value     =   "1"},
                                        new SelectListItem() {Text = "Medium",  Value   =   "2"},
                                        new SelectListItem() {Text = "High",    Value   =   "3"},
                                    }, "Value", "Text"), new { @class = "form-control input-sm", @name = "ContractLevelId", tabindex = 8 })
                                </div>



                                <div class="form-group col-md-2 col-xs-12 text-center " id="search">
                                    <input type="submit" class="btn btn-submit" value="Submit" />
                                </div>
                                <div class="form-group col-md-2 col-xs-12  text-center" id="close">
                                    <input type="button" class="btn btn-close" value="Close" />
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

    </div>

    @using (Html.BeginForm("DeleteAll", "AMC", FormMethod.Post, new { id = "AMC", role = "form" }))
    {
        <div class="box-body">
            <table class="table table-bordered table-hover" id="AmcTable">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="1">S/N</td>
                        <td data-priority="1">Contract No</td>
                        <td data-priority="1">Customer Name</td>
                        <td data-priority="1">Contract Name</td>
                        <td data-priority="1">Contract Type</td>
                        <td data-priority="2">Start Date</td>
                        <td data-priority="2">End Date</td>
                        <td data-priority="2">Reminder Date</td>
                        <td data-priority="1">Location</td>
                        <td data-priority="1">Status</td>
                        <td data-priority="1">Assigned To</td>
                        <td data-priority="1">Last Updated</td>
                        <td data-priority="1">Action</td>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    }
    <div id="modal-container3" class="modal fade" role="dialog" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                    <h4>Remarks</h4>
                </div>
                <div class="modal-body">
                    <div class="box-body" id="modelview">
                        <table class="table table-bordered table-hover" id="RemarkInfoamc">
                            <thead>
                                <tr class="bg-gray">
                                    <td>#</td>
                                    <td>Date & Time</td>
                                    <td>Employees</td>
                                    <td>Remarks</td>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div id="modal-container2" class="modal fade" role="dialog" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                    <h4>Remarks</h4>
                </div>
                <div class="modal-body">
                    <div class="box-body Remarks" id="modelview">
                        <table class="table table-bordered table-hover RemarkInfo" id="RemarkInfo">
                            <thead>
                                <tr class="bg-gray">
                                    <td>#</td>
                                    <td>Date & Times</td>
                                    <td>Employee</td>
                                    <td>Remark</td>
                                    <td>AMC Status</td>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@{var vModel = "modal-lg";}
@Html.Partial("../Common/_ModalCreate", @vModel)
@Html.Partial("../Reminder/Index")
@Html.Partial("../Common/_ModalDelete")
@Html.Partial("../Common/_ModalEdit")


@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/bootstrap-timepicker")
    @Styles.Render("~/css/bootstrap-fileinput")
    @Styles.Render("~/css/bootstrap-fileinput-rtl")
}
@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/bootstrap-timepicker")
    @Scripts.Render("~/js/bootstrap-fileinput")
    @Scripts.Render("~/js/bootstrap-sortable")

    <script type="text/javascript">

        //$('#advsearchlist').hide();
    $('#searchcontrname').hide();
    $('#searchcontrtype').hide();
    $('#searchRfromdate').hide();
    $('#searchRtodate').hide();
    $('#searchEfromdate').hide();
    $('#searchtodate').hide();
    $('#searchfromdate').hide();
    $('#searchtodate').hide();

        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });

        jQuery.validator.methods["date"] = function (value, element) { return true; }
        $(".timepicker").timepicker({
            showInputs: true,
            defaultTime: false,
            format: 'dd-mm-yyyy'
        });

        $(document).ready(function () {
            //$('#advsearchlist').hide();
            $("#ddllocation").select2({
                placeholder: 'Search Location',
                minimumInputLength: 0,
                dropdownAutoWidth: true,
                ajax: {
                    url: "/AMC/SearchLocation",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term,
                            page: params.page,
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;

                        return {
                            results: data
                        };
                    },
                    cache: true
                },
            });
            $('#FromDate').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });

            $('#EndDate').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });
            $('#EFromDate').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });
            $('#RFromDate').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });

            $('#RToDate').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });



        });


        //Customer DropDown
        CallRepCustomer();

        //Contract Name
        $("#ddlContractName").select2({

            tags: true,
            placeholder: 'Search Contract Name',
            minimumInputLength: 0,
            ajax: {
                url: "/AMC/SearchAmcContracts",
                dataType: 'json',
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term,
                        page: params.page,
                        x: "All"
                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 1;

                    return {
                        results: data
                    };
                },
                cache: true
            },
        });

        //Contract Type
        $("#ddlContractType").select2({

            tags: true,
            placeholder: 'Search Contract Type',
            minimumInputLength: 0,
            ajax: {
                url: "/AMC/SearchAmcContractTypes",
                dataType: 'json',
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term,
                        page: params.page,
                        x:"All"
                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 1;

                    return {
                        results: data
                    };
                },
                cache: true
            },
        });

        var checkList = document.getElementById('list1');
        /******* Function to list and hide dropdown checklist while clicking on 'Select Fields' *******/
        checkList.getElementsByClassName('anchor')[0].onclick = function (evt) {
            if (checkList.classList.contains('visible'))
                checkList.classList.remove('visible');
            else
                checkList.classList.add('visible');
        }

        /******* Function to show and hide fields while clicking on checkboxes in 'Select Fields' *******/
        $("ul li input:checkbox").click(function () {

            var _show = 0;

            //Entry No.
            if ($("#licontrno ").prop("checked") == true) {
                $("#searchcontrno").show();
                _show = 1;
            }
            else {
                $('#ContractNo').val("");
                $("#searchcontrno").hide();
                oTable.draw();
            }
            if ($("#lilocation").prop("checked") == true) {
                $("#searchlocation").show();
                _show = 1;
            }
            else {
                $('#ddllocation').val(0).trigger("change");
                $("#searchlocation").hide();
                // oTable.draw();
            }

            //Customer Name
            if ($("#licustname").prop("checked") == true) {
                $("#searchcustname").show();
                _show = 1;
            }
            else {
                $('#ddlCustomer').val("").trigger("change");
                $("#searchcustname").hide();
                oTable.draw();
            }


            //Contract Name
            if ($("#licontrname").prop("checked") == true) {
                $("#searchcontrname").show();
                _show = 1;
            }
            else {
                $('#ddlContractName').val(null).trigger("change");
                $("#searchcontrname").hide();
                oTable.draw();
            }

            //Contract Type
            if ($("#licontrtype").prop("checked") == true) {
                $("#searchcontrtype").show();
                _show = 1;
            }
            else {
                $('#ddlContractType').val(null).trigger("change");
                $("#searchcontrtype").hide();
                oTable.draw();
            }

            //Start Date
            if ($("#listartdate").prop("checked") == true) {
                $("#searchstartdate").show();
                _show = 1;
            }
            else {
                $("#FromDate").val("");
                $("#searchstartdate").hide();
                oTable.draw();
            }

            //End Date
            if ($("#lienddate").prop("checked") == true) {
                $("#searchEfromdate").show();
                $("#searchenddate").show();
                _show = 1;
            }
            else {
                $("#EFromDate").val("");
                $("#searchEfromdate").hide()
                $("#ToDate").val("");
                $("#searchenddate").hide();
                oTable.draw();
            }
            //Reminder Date
            if ($("#lireminderdate").prop("checked") == true) {
                $("#searchRfromdate").show();
                $("#searchRtodate").show();
                _show = 1;
            }
            else {
                $('#RFromDate').val(null).trigger("change");
                $("#searchRfromdate").hide();
                $('#RToDate').val(null).trigger("change");
                $("#searchRtodate").hide();
                oTable.draw();
            }




            if (_show == 1) {
                $('#advsearchlist').show();
            }
            else {
                $('#advsearchlist').hide();
            }
        });

        /******* Function to hide dropdown checklist while clicking outside it ********/
        $(document).on("click", function (event) {

            var element1 = $("#list1");

            if (element1 !== event.target && !element1.has(event.target).length) {
                checkList.classList.remove('visible');
            }
        });

        //Retrieving data from table for display
        var oTable = $('#AmcTable').DataTable({
                "processing": true, // for show progress bar
                "serverSide": true, // for process server side
                "filter": true, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
                "bStateSave": true,
                "pageLength": 50,
                responsive: true,
            "bLengthChange": false,
            initComplete: function (settings, json) {

                $('body', parent.document).contents().find("#amciframe").attr("height", $('#AmcTable').height() + 300);
            },
            "createdRow": function (row, data, dataIndex) {

                if (data.ContractLevelId == 0) {
                    // datas = "<span class='text-blue'>LOW</span>";
                    $(row).addClass('text-blue');
                }
                else if (data.Priority == 1) {
                    // datas = "<span class='text-orange'>MEDIUM</span>";
                    $(row).addClass('txt-med');
                }
              

                else {
                    //datas = "<span class='text-red'>HIGH</span>";
                    $(row).addClass('txt-red');
                }
            },
                "ajax": {
                    "url": '/AMC/GetMyAMCDetails',
                    "data": function (data) {
                        data.ContractNo     =   $('#ContractNo').val();
                        data.Customer       =   $('#ddlCustomer').val();
                        data.ContractName   =   $('#ddlContractName').val();
                        data.ContractType = $('#ddlContractType').val();
                        data.RFromDate = $('#RFromDate').val();
                        data.ContractLevelId = $("#ContractLevelId").val();
                        data.RToDate = $('#RToDate').val();
                        data.StartDate      =   $('#FromDate').val();
                        data.EndDate = $('#ToDate').val();
                        data.EFromDate = $('#EFromDate').val();
                        data.location = $('#ddllocation').val();
                    },
                    "type": "POST",
                    "datatype": "json"
                },
                "order": [[11, "desc"]],
                "columnDefs": [{
                    "targets": [10,12],
                    "orderable": false
                }],
                "columns": [
                    {
                        "data": "AmcId", "name": "AmcId",
                        "render": function (data, type, row, meta) {
                            return meta.row + meta.settings._iDisplayStart + 1;
                        }
                    },
                    //{ "data": "AmcNo", "name": "AmcNo" },
                    {
                      "name": "AmcNo", "data": function (data) {
                           @{
                               var datass = "";
                               datass = "'<a href=\"/AMC/Details/'+ data.AmcId +'\"  target=\"_new\">'+ data.AmcNo +'</a>' ";

                           }
                           return @Html.Raw(datass);
                      }
                    },
                    /*{ "data": "CustomerName", "name": "CustomerName" },*/
                    {
                     "name": "CustomerName", "data": function (data) {
                           @{
                               var datas = "";
                               datas = "'<a href=\"/Customer/Details/'+ data.CustomerId +'\"  target=\"_new\">'+ data.CustomerName +'</a>' ";

                           }
                           return @Html.Raw(datas);
                      }
                 },
                    { "data": "ContractName", "name": "ContractName" },
                    { "data": "ContractType", "name": "ContractType" },
                    {
                        "data": "StartDate", "name": "StartDate",
                        "render": function (data) {
                            var date = convertToDate(data);
                            return date.toString();
                        }
                    },
                    {
                        "data": "EndDate", "name": "EndDate",
                        "render": function (data) {
                            var date = convertToDate(data);
                            return date.toString();
                        }
                    },
                    {
                        "data": "ReminderDate", "name": "ReminderDate",
                        "render": function (data) {
                            var date = convertToDate(data);
                            return date.toString();
                        }
                    },
                    { "data": "Location", "name": "Location" },
                    { "data": "StatusName", "name": "StatusName" },
                    {
                        "name": "AssignedTo", "data": function (data) {
                            var datas = "";
                            $.each(data.AssignedTo, function (i, item) {
                                if (datas != "") {
                                    datas += ", ";
                                }
                                datas += item.FirstName + " " + item.LastName;
