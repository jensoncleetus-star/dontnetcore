@model QuickSoft.ViewModel.AMCViewModel
@{
    ViewBag.Title = "Create";
    ViewBag.SubTitle = "AMC";
    ViewBag.Active = "Transactions";
    var TimeOut = @ViewBag.TMOut;
    int di = 0;
    int si = 0;
    int ci = 0;
}

<style>
    /*To allign Fill Button ---for big screens only*/
   /* @@media only screen and (min-width: 992px) and (max-width: 1200px) {
        .LeftBigScreen {
            margin-left: 30px;
