                    '<div class="col-md-3">' +
                    '<label class="control-label">Notes</label>' +
                    '<div class="input-group">' +
                    '<input type="text" name="LstPerdcMaint[' + rowno + '].Notes" class="form-control Notes" placeholder="Notes" tabindex="44">' +
                    '</div>' +
                    '</div>' +
                    '<a href="javascript:void(0);" class="remove_button3"><i style="color:red;margin-top:2.5rem;" class="fa fa-trash" aria-hidden="true" tabindex="45"></i></a>' +
                    '</div > ');
                ResetFillBtn();
            }
        }

        //Function To Reset Index
        function ResetFillBtn() {
            var i = 0;
            $('.PMaint').each(function (index, element) {

                var inputPDate = $(this).find('.PDate');
                var inputNotes = $(this).find('.Notes');

                //To update the index value of name of each rows while appending or deleting
                inputPDate.attr('name', 'LstPerdcMaint[' + i + '].PDate');
                inputNotes.attr('name', 'LstPerdcMaint[' + i + '].Notes');

                i++;
            });
        }

        $(wrapper3).on('click', '.remove_button3', function (e) {
            e.preventDefault();
            $(this).parent('div').remove(); //Remove field html

            rowno--; //Decrement field counter
            ResetFillBtn()

            if (rowno != 0)
                //$("#PerdMainNo").val(rowno);
                $("#NoOfPMaint").val(rowno);
            
            else
                //$("#PerdMainNo").val("");
                $("#NoOfPMaint").val("");
        });

        /****************** For Popups ******************/
        $('div').on('click', '.modal-create', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
            modalshow(url, '#modal-create');
        });

        $('#modal-create').on('submit', '#createform', function (e) {
            e.preventDefault();
            var url = $('#createform')[0].action;
            var data = $('#createform').serialize();
            createajax(url, data, '#modal-create');
        });   

    //Function to check correct format for Mobile Number
    //MobileNo is not passed in fetched rows(Edit Mode Rows)
    function CheckMobileNo(MobileNo, i) {
        var Mobile;

        if (MobileNo == "") {
            Mobile = document.getElementById("Mobile[" + i + "]").value;
            Mobile = Mobile.replace(/^0+/, '');
            document.getElementById("Mobile[" + i + "]").value = Mobile;
        }
        else
            Mobile = MobileNo;

        var NumbersOnly = /[^0-9]/g;
        var NewMob = (Mobile.replace(NumbersOnly, ""));

        if (Mobile != NewMob) {
            alert("Please Select Correct Format For Mobile..(Numbers Only)");

            if (MobileNo == "") {
                document.getElementById("Mobile[" + i + "]").value = "";
                document.getElementById("Mobile[" + i + "]").focus();                
            }
            else {
                var opt = '<option value="" selected>5xxxxxxxx</option>'
                $("#Mobile" + i).append(opt);
                mobileload();
            }
        }
        else if (Mobile.length > 9) {
            alert("Only 9 numbers are allowed...")

            if (MobileNo == "") {
                document.getElementById("Mobile[" + i + "]").value = "";
                document.getElementById("Mobile[" + i + "]").focus();
            }
            else {
                var opt = '<option value="" selected >5xxxxxxxx</option>'

                $("#Mobile" + i).append(opt);
                mobileload();
            }
        }
    }

    //Function to load contact while selecting Customer
    function LoadContactForCustomer(obj) {
        var Customer = $(obj).val();
        window.location.href = "/AMC/Create/?CustId=" + Customer;
    }       

</script>
