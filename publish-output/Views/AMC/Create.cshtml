                                <a href="/AMCContractName/Create" class="btn btn-success btn-flat modal-create btnpartyAdd" title="Add Contract"><i class="fa fa-1x fa-plus-circle"></i></a>
                            </span>
                        </div>
                    </div>

                    <div class="col-md-2 col-xs-12 form-group ">
                        @Html.Label("Start Date", null, new { @class = "control-label" }) *
                        <div class="input-group date">
                            <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                            @Html.TextBoxFor(model => model.StartDate, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @required = "required", tabindex = 3 })
                        </div>
                    </div>

                    <div class="col-md-2 col-xs-12 form-group">
                        @Html.Label("End Date", null, new { @class = "control-label" }) *
                        <div class="input-group date">
                            <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                            @Html.TextBoxFor(model => model.EndDate, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @required = "required", tabindex = 4 })
                        </div>
                    </div>

                    <div class="col-md-2 col-xs-12 form-group">
                        @Html.Label("Reminder Date", null, new { @class = "control-label" }) *
                        <div class="input-group date">
                            <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                            @Html.TextBoxFor(model => model.ReminderDate, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @required = "required", tabindex = 5 })
                        </div>
                    </div>
                </div>

            <div class="row">
                <div class="form-group  col-md-2 col-xs-12">
                    @Html.Label("Contract Type", null, new { @class = "control-label" })
                    <div class="input-group input-group-sm">
                        @Html.DropDownListFor(model => model.ContractTypeId, (SelectList)ViewBag.ContractTypes, new { id = "ddlContractType", @class = "form -control input-sm select2", @placeholder = "Enter Contract Name", tabindex = 6 })
