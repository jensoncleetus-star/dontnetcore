                            <a href="/AmcContractType/Create" class="btn btn-success btn-flat modal-create" title="Add Contract Type"><i class="fa fa-1x fa-plus-circle"></i></a>
                        </span>
                    </div>
                </div>
                <div class="form-group  col-md-2 col-xs-12" style="display:none;">
                    @Html.Label("Contract Status", null, new { @class = "control-label" })
                    <div class="input-group input-group-sm">
                        @Html.DropDownListFor(model => model.AmcStatusId, (SelectList)ViewBag.Dropdowns, new { id = "ddlAmcStatus", @class = "form -control input-sm select2", @placeholder = "Enter Contract Name", tabindex = 7 })
                        <span class="input-group-btn">
                            <a href="/AMCStatus/Create" class="btn btn-success btn-flat modal-create" title="Add Contract Type"><i class="fa fa-1x fa-plus-circle"></i></a>
                        </span>
                    </div>
                </div>
                <div class="col-md-2 col-xs-12">
                    @Html.Label("Contract Status", null, new { @class = "control-label" })
                    <div class="input-group">
                        @Html.DropDownListFor(m => m.OpenClose, new SelectList(new List<SelectListItem>
                               {
                                new SelectListItem() {Text = "OPEN", Value="0"},
                                new SelectListItem() {Text = "CLOSE", Value="1"},
                               }, "Value", "Text"), new { @class = "form-control input-sm" })
                    </div>
                </div>

                <div class="form-group  col-md-2 col-xs-12">
                    @Html.Label("Priority", null, new { @class = "control-label" })
                    @Html.DropDownList("ContractLevelId", new SelectList(new List<SelectListItem>
                    {
                        new SelectListItem() {Text = "Low",   Value     =   "0"},
                        new SelectListItem() {Text = "Medium",  Value   =   "1"},
                        new SelectListItem() {Text = "High",    Value   =   "2"},
                    }, "Value", "Text"), new { @class = "form-control input-sm", @name = "ContractLevelId", tabindex = 8 })
                </div>

                <div class="form-group col-md-2 col-xs-12">
                    @Html.LabelFor(model => model.Lattitude, htmlAttributes: new { @class = "control-label" })
                    @Html.EditorFor(model => model.Lattitude, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Lattitude", tabindex = 9, @type = "number" } })
                </div>

                <div class="form-group col-md-2 col-xs-12">
                    @Html.LabelFor(model => model.Longitude, htmlAttributes: new { @class = "control-label" })
                    @Html.EditorFor(model => model.Longitude, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Longitude", tabindex = 10, @type = "number" } })
                </div>

                <div class="form-group col-md-2 col-xs-12">
                    @Html.Label("Location", null, new { @class = "control-label" })
                    <div class="input-group input-group-sm">
                        @Html.DropDownListFor(model => model.LocationId, (SelectList)ViewBag.VRef1, new { @class = "form-control input-sm select2", @placeholder = "Enter Location", tabindex = 11 })
                        <span class="input-group-btn">
                            <a href="/Location/Index" class="add btn btn-success btn-flat" target="_new" title="Add Customer"><i class="fa fa-1x fa-plus-circle"></i></a>
                        </span>
                    </div>
                </div>

            </div>

            <div class="row">

                <div class="form-group col-md-4 col-xs-12">
                    @Html.LabelFor(m => m.AssignType, new { @class = "control-label" })
                    <div class="input-group input-group-sm">
                        @Html.DropDownListFor(m => m.AssignTypeAll, (SelectList)ViewBag.AssignTypes, new { @class = "form-control select2 AssignType", @name = "AssignTypeAll[]", @multiple = "multiple", tabindex = 12 })
                        @*<span class="input-group-btn">
                    <a href="/Team/Create" class="modal-create btn btn-success btn-flat" title="Add AssignType"><i class="fa fa-1x fa-plus-circle"></i></a>
                </span>*@
                    </div>
                </div>

                <div class="form-group col-md-4 col-xs-12">
                    @Html.LabelFor(m => m.AssignedTo, new { @class = "control-label" })
                    @Html.DropDownListFor(m => m.AssignedToo, (SelectList)ViewBag.Employee, "", new { @id = "AssignedUsers", @class = "form-control select2 porder", @name = "AssignedTo[]", @multiple = "multiple", tabindex = 13 })
                </div>
                

            </div>

            <div class="row">
                <br>
                <button style="width: 200px;" type="submit" class="btn btn-primary btn-rounded btn-fw add_field_button0" tabindex = 14>Add Contact<i class="fa fa-plus-circle" aria-hidden="true" style="margin-top:2px"></i></button>
                <br>
                <div class="form-group input_fields_wrap0">
                    <table class="table table-condensed table-hover" id="contactTbl">
                        @{
                            if (Model != null && Model.LstContacts != null && Model.LstContacts.Count > 0)
                            {
                                List<QuickSoft.Models.Country> CountryCodelist = ViewBag.CountryCodes;

                                foreach (var item in Model.LstContacts.ToList())
                                {
                                    <div class="remove ContctSet" style=" border: 1px solid rgba(0,0,0,0.12); border-radius: 30px; margin-top:10px;">

                                        <div class="row " style="margin-top: 1rem;">

                                            <div class="col-md-2">
                                                <label class="control-label">Country Code</label>
                                                <div class="input-group">
                                                    <select id="Type" class="form-control CountryID" name="LstContacts[@ci].CountryID" tabindex=15>
                                                        @{
                                                            <option value="0">--Select--</option>
                                                            foreach (var data in CountryCodelist)
                                                            {
                                                                if (data.CountryID == item.CountryID)
                                                                {
                                                                    <option value="@data.CountryID" selected="selected">@data.CountryName (@data.CountryCode)</option>
                                                                }
                                                                else
                                                                {
                                                                    <option value="@data.CountryID">@data.CountryName (@data.CountryCode)</option>
                                                                }
                                                            }
                                                        }
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <label class="control-label">Mobile Number</label>
                                                <div class="input-group">
                                                    <input type="text" value="@item.Mobile" name="LstContacts[@ci].Mobile" class="form-control Mobile" id="Mobile[@ci]" placeholder="5xxxxxxxx" onchange="CheckMobileNo('', @ci)" required tabindex=16>
                                                    <input type="hidden" value="EditMode" id="MobileHidden @ci" class="MobileHidden">
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <label class="control-label">Email Id</label>
                                                <div class="input-group">
                                                    <input type="email" value="@item.EmailId" name="LstContacts[@ci].EmailId" class="form-control EmailId" tabindex=17>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <label class="control-label">Website</label>
                                                <div class="input-group">
                                                    <input type="text" value="@item.Website" name="LstContacts[@ci].Website" class="form-control Website" tabindex=18>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row " style="margin-top: 1rem;">
                                            <div class="col-md-2" hidden style="display:none;">
                                                <label class="control-label">id</label>
                                                <div class="input-group">
                                                    <input type="text" value="@item.ContactID" name="LstContacts[@ci].ContactID" class="form-control" tabindex=19>
                                                </div>
                                            </div>
                                            <div class="col-md-2 col-xs-12">
                                                <label class="control-label">Contact Type</label>
                                                <div class="input-group">
                                                    <select id="Type" class="form-control ContactTypeID" name="LstContacts[@ci].ContactTypeID" tabindex=20>
                                                        @{
                                                            List<QuickSoft.Models.ContactType> typelist = ViewBag.TypeList;
                                                            <option value="0">--Select--</option>
                                                            foreach (var data in typelist)
                                                            {
                                                                if (data.ContactId == item.ContactTypeID)
                                                                {
                                                                    <option value="@data.ContactId" selected="selected">@data.Type</option>
                                                                }
                                                                else
                                                                {
                                                                    <option value="@data.ContactId">@data.Type</option>
                                                                }
                                                            }
                                                        }
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <label class="control-label">First Name</label>
                                                <div class="input-group">
                                                    <input type="text" name="LstContacts[@ci].FirstName" class="form-control FirstName" value="@item.FirstName" required tabindex=21>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <label class="control-label">Last Name</label>
                                                <div class="input-group">
                                                    <input type="text" name="LstContacts[@ci].LastName" class="form-control LastName" value="@item.LastName" tabindex=22>
                                                </div>
                                            </div>
                                            <div class="col-md-3 col-xs-10">
                                                <label class="control-label">Company Name</label>
                                                <div class="input-group">
                                                    <input type="text" name="LstContacts[@ci].Name" class="form-control Name" value="@item.Name" tabindex=23>
                                                </div>
                                            </div>
                                            <div class="col-md-1 col-xs-2">
                                                <a href="javascript:void(0);" class="remove_button0"><i style="color:red; margin-top: 25px;margin-left: 0px;" class="fa fa-trash" aria-hidden="true" tabindex=24></i></a>
                                            </div>
                                        </div>
                                        <br />
                                    </div>
                                    ci++;
                                }
                            }
                        }
                    </table>
                </div>
                <br>
            </div>

            <div class="row">
                <button style="width: 200px;" type="submit" class="btn btn-primary btn-rounded btn-fw add_field_button1" tabindex=34>Attach Documents<i class="fa fa-plus-circle" aria-hidden="true" style="margin-top:2px"></i></button>
                <br>
                <div class="form-group input_fields_wrap1">
                </div>
                <br>
            </div>

            @*<div class="row">
                    <button style="width: 200px;" type="submit" class="btn btn-primary btn-rounded btn-fw  add_field_button2">Balance<i class="fa fa-plus-circle" aria-hidden="true" style="margin-top:2px"></i></button>
                    <br>
                    <div class="form-group input_fields_wrap2">
                    </div>
                    <br>
                </div>*@

            <div class="row">
                <div class="checkbox-inline">
                    @Html.CheckBoxFor(m => m.PerdcMaintReq, new { @class = "checkbox", @checked = "checked", tabindex = 40 })
                    @Html.Label("Periodic Maintenance Required", null, new { @class = "control-label" })
                </div>

                <div class="box-body hiden PMaintSection" id="PMaintSection">
                    <br />
                    <div class="input-group input-group-sm">
                        No. Of Periodic Maintenance
                        <div class="col-md-2">
                            @Html.EditorFor(model => model.NoOfPMaint, new { htmlAttributes = new { @class = "form-control text-center", @Value = "", @placeholder = "Enter No.", tabindex = 41 } })
                         </div>
                        <div class="col-md-2">
                            <input type="button" class="btn btn-success LeftBigScreen" name="fill" value="Fill" onclick="FillControl()" style="height:32px;" tabindex = 42 />
                        </div>
                    </div>
                    <div class="row">
                        <div class="form-group input_fields_wrap3">
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <br />
                <div class="form-group">
                    @Html.Label("AMC Details", null, new { @class = "control-label" })
                    @Html.TextAreaFor(model => model.AmcDetails, new { @class = "form-control", @placeholder = "AMC Details", @rows = 2, tabindex = 48 })
                </div>
                <div class="form-group">
                    @Html.Label("Notes", null, new { @class = "control-label" })
                    @Html.TextAreaFor(model => model.Notes, new { @class = "form-control", @placeholder = "Notes", @rows = 2, tabindex = 49 })
                </div>
            </div>

            <div class="row">
                @if (Model.FieldMap.Count > 0)
                {
                    for (int i = 0; i < Model.FieldMap.Count; i++)
                    {
                        <div class="form-group col-md-3">
                            <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName</label>
                            @if (Model.FieldMap[i].Type == "Dropdown")
                            {
                                if (Model.FieldMap[i].Field == "Ref1")
                                {
                                    @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef1, new { @id = "Ref1", @class = "form-control input-sm select2 ref", tabindex = 50 })
                                }
                                if (Model.FieldMap[i].Field == "Ref2")
                                {
                                    @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef2, new { @id = "Ref2", @class = "form-control input-sm select2 ref", tabindex = 51 })
                                }
                                if (Model.FieldMap[i].Field == "Ref3")
                                {
                                    @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef3, new { @id = "Ref3", @class = "form-control input-sm select2 ref", tabindex = 52 })
                                }
                                if (Model.FieldMap[i].Field == "Ref4")
                                {
                                    @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef4, new { @id = "Ref4", @class = "form-control input-sm select2 ref", tabindex = 53 })
                                }
                                if (Model.FieldMap[i].Field == "Ref5")
                                {
                                    @Html.DropDownListFor(m => m.FieldMap[i].Field, (SelectList)ViewBag.VRef5, new { @id = "Ref5", @class = "form-control input-sm select2 ref", tabindex = 54 })
                                }
                            }
                            else
                            {
                                <input class="form-control select2" id="@Model.FieldMap[i].Field" name="@Model.FieldMap[i].Field" type="text" value="" tabindex = 55>
                            }
                        </div>
                    }
                }
            </div>

            <div class="row text-center">
                <button type="submit" id="save" class="btn btn-success" tabindex="60">
                    <span class="glyphicon glyphicon-floppy-disk"></span> Save
                </button> &ensp;
                <button type="button" class="btn btn-default can-btn" tabindex="61" onclick="@("window.location.href='/AMC/Index'");">Cancel</button>
            </div>

        </div>
    }
</div>

