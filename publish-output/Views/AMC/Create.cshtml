@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/bootstrap-fileinput")
    @Styles.Render("~/css/bootstrap-fileinput-rtl")
}
@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/bootstrap-fileinput")
<script type="text/javascript">

        $(document).ready(function () {

            $('.date').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });
          
            jQuery.validator.methods["date"] = function (value, element) { return true; }

            $(".ref").select2({
                tags: true
            });
            $(".ref").each(function () {
                var refval = $(this).attr('Id');
                $(this).attr('name', refval);
            });

            CallCustomer();
            CallTeam();

            //Contract Name
            $("#ddlContractName").select2({
                placeholder: 'Search Contract Name',
                minimumInputLength: 0,
                dropdownAutoWidth: true,
                ajax: {
                    url: "/AMC/SearchAmcContracts",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term,
                            page: params.page,
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;

                        return {
                            results: data
                        };
                    },
                    cache: true
                },
            });

            //Contract Type
            $("#ddlContractType").select2({
                placeholder: 'Search Contract Type',
                minimumInputLength: 0,
                dropdownAutoWidth: true,
                ajax: {
                    url: "/AMC/SearchAmcContractTypes",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term,
                            page: params.page,
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;

                        return {
                            results: data
                        };
                    },
                    cache: true
                },
            });

            //Contract Status
            $("#ddlAmcStatus").select2({
                placeholder: 'Search Contract Status',
                minimumInputLength: 0,
                dropdownAutoWidth: true,
                ajax: {
                    url: "/AMC/SearchContractStatus",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term,
                            page: params.page,
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;

                        return {
                            results: data
                        };
                    },
                    cache: true
                },
            });

            //Location
            $("#LocationId").select2({
                placeholder: 'Search Location',
                minimumInputLength: 0,
                dropdownAutoWidth: true,
                ajax: {
                    url: "/AMC/SearchLocation",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term,
                            page: params.page,
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;

                        return {
                            results: data
                        };
                    },
                    cache: true
                },
            });

           //Assigned Users
            $("#AssignedUsers").select2({
                placeholder: 'Search Employees by Name',
                minimumInputLength: 0,
                ajax: {
                    url: "/Employee/SearchEmployee",
                    dataType: 'json',
                    type: "POST",
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term,
                            page: params.page,
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;

                        return {
                            results: data
                        };
                    },
                    cache: true
                },
            });
        });

        //To Fill Team Members While selecting Teams
        $('body').on('change', '#AssignTypeAll', function (e) {
            var assign = $("#AssignTypeAll").val();
            AssignTypeChange(assign);
            CallTaskStatus();
        });

        //For setting End Date & Reminder Date while changing Start Date
        $('#StartDate').on('change', '', function (e) {

            var StartDate = $("#StartDate").val();
            var dateParts = StartDate.split("-");
            
            var newdate = new Date(++dateParts[2], dateParts[1] - 1, --dateParts[0]);

            var date = newdate.getDate(-1);
           
            if (date < 10)
                date = ("0" + date);

            var Month = newdate.getMonth() + 1;

            if (Month < 10)
                Month = ("0" + Month);

            var Year = newdate.getFullYear();

            $('#EndDate').val(date + "-" + Month + "-" + Year);
            $('#ReminderDate').val(date + "-" + Month + "-" + Year);
        });
    $('.PMaintSection').show();
    $("#PerdcMaintReq").attr("checked", true);
        //CheckBox change
        $('#PerdcMaintReq').click(function () {
            if ($('#PerdcMaintReq').prop('checked') == true) {
                $('.PMaintSection').show();
            }
            else {
                $('.PMaintSection').hide();
            }
        });

        /************************************** Add Contact **************************************/
        function loadcontact(i, obj) {
            $('.mobilenumber').select2('destroy');
            var s = $("#Mobile" + i).val();
