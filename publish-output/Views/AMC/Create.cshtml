<div class="box box-info container-fluid">
    @using (Html.BeginForm("Create", "AMC", FormMethod.Post, new { id = "createforms", role = "form", enctype = "multipart/form-data" }))
    {
        <input type="hidden" class="form-control" id="RowCount" value="0" placeholder="">
        <input type="hidden" class="form-control" id="documentRowcount" value="0" placeholder="">
        <input type="hidden" class="form-control" id="balanceRowcount" value="0" placeholder="">

        <div class="box-header with-border">
            <h3 class="box-title">Create AMC</h3>
            <div class="pull-right">
                <a class="btn btn-success no-border" href="/AMCPeriodicMaintenance/Create">
                    <i class="fa fa-fw fa-history"></i>Create Periodic
                </a>
            </div>
            <div class="pull-right">
                <a class="btn btn-success no-border" href="/AMC">
                    <i class="fa fa-fw fa-history"></i> List
                </a>
            </div>
        </div>

        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })

        <div class="box-body">

            <div class="row">

                <div class="form-group col-md-2 col-xs-12">
                    @Html.Label("Contract No", null, new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.AmcNo, new { htmlAttributes = new { @class = "form-control", @required = "required", @readonly = "readonly" } })
                </div>

                <div class="form-group  col-md-2 col-xs-12">
                    @Html.Label("Customer Name", null, new { @class = "control-label" }) *
                    <div class="input-group input-group-sm">
                        @Html.DropDownListFor(model => model.CustomerId, (SelectList)ViewBag.Customers, "",new { id = "ddlCustomer", @class = "form -control input-sm select2", @required = "required", tabindex = 1, @onchange = "LoadContactForCustomer(this)" })
                        <span class="input-group-btn">
                            <a href="/Customer/Create" class="add btn btn-success btn-flat" target="_new" title="Add Customer"><i class="fa fa-1x fa-plus-circle"></i></a>
                        </span>
                      </div>
                    </div>

                    <div class="form-group  col-md-2 col-xs-12">
                        @Html.Label("Contract Name", null, new { @class = "control-label" }) *
                        <div class="input-group input-group-sm">
                            @Html.DropDownListFor(model => model.ContractId, (SelectList)ViewBag.Dropdowns, new { id = "ddlContractName", @class = "form -control input-sm select2", @required = "required", @placeholder = "Enter Contract Name", tabindex = 2 })
