<div class="modal-header">
<button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
<h4>Assign Cusomer</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("assignpost", "Customer", FormMethod.Post, new { id = "createform" }))
    {
        <input type="hidden" name="leadid" value="@ViewBag.leadids"/>
        <div class="row">
            <div class="col-md-12">
                <div class="form-group">
                    @Html.Label("Select Customer", null, htmlAttributes: new { @class = "control-label" }) *
                   
                    @Html.DropDownList("customerid", (SelectList)ViewBag.custom,   new{ @class = "form-control select2",@id= "ddlCustomer" } )

                </div>
            </div>
        </div>
                <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" value="Save" class="btn btn-info col-sm-offset-4" />
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
   
<script>
    $("#ddlCustomer").select2({});
</script>
      
