@{
    ViewBag.Title = "Customer Bonus";
    ViewBag.SubTitle = "Bonus";
    ViewBag.Active = "Reports";
    var TimeOut = @ViewBag.TMOut;
}
<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">Customer Bonus</h3>
    </div>
    <div class="box box-default">
        <div class="box-header with-border">
         
        </div>

        <div class="box-body">
            <form id="search-form">
                @using (Html.BeginForm("Index", "SalesReport", FormMethod.Post, new { id = "popupForm", target = "_new" }))
                {
              
          
                    <div class="form-group col-md-2">
                        @Html.Label("From", null, new { @class = "control-label" })
                        <div class="input-group date">
                            @Html.TextBox("From","", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                            <div class="input-group-addon">
                                <i class="fa fa-calendar"></i>
                            </div>
                        </div>
                    </div>
                    <div class="form-group col-md-2">
                        @Html.Label("To", null, new { @class = "control-label" })
                        <div class="input-group date">
                            @Html.TextBox("To", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                            <div class="input-group-addon">
                                <i class="fa fa-calendar"></i>
                            </div>
                        </div>
                    </div>
          
      

                    <div class="box-footer col-md-12">
                        <input type="submit" class="btn btn-info col-sm-offset-5" value="Submit" />
                        <button type="button" class="btn btn-default" onclick="@("window.location.href='/Home/Index'");">Cancel</button>
                    </div>
                }
            </form>
        </div>
    </div>         
</div>
<div class="box box-default"  id="StockReport">>
    <div class="box-header with-border">
        <h3 class="box-title">View Customers Bonus</h3>
    </div>
    <div class="box-body">
        <div class="box-body">
            <table class=" table table-bordered" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td>S/N</td>
                        <td>Customer</td>
                        <td>Bonus</td>
                        <td><input type="checkbox" id="select_all" /> Select all <input type="button" class="btn btn-danger" onclick="setItem()" value="Reset" /></td>
                    </tr>
                </thead>
                <tbody></tbody>
                <tfoot>
                    <tr>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
