    function setItem() {
        var values = new Array();

        $("input[name='dltcheck']:checked").each(function () {
            data = $(this).val();
            values.push(data);
        });

        $.ajax({
            async: true,
            cache: false,
            dataType: "json",
            type: "POST",
            contentType: "application/json; charset=utf-8",
            url: "/Customer/resetbonus",
            data: JSON.stringify({ value: values }),
            success: function (e) {
                if (e.status == true) {
                    $('.ajax_response', res_success).text(e.message);
                    $('.AlertDiv').prepend(res_success);

                    setTimeout(function () { window.location.href = '/Customer/CustomerBonus'; }, '@TimeOut');
                } else {
                    $('.ajax_response', res_danger).text(e.message);
                    $('.AlertDiv').prepend(res_danger);

                }
            }
        });


    }
   

        $('body').on('change', '#ddlCustomer', function (e) {
            $('#ddlProject').val(null).trigger('change');
            var customer = $('#ddlCustomer').val();
            if (customer != 0) {
                $("#ddlProject").select2({
                    placeholder: 'Search Project Code Or Name ',
                    minimumInputLength: 0,
                    ajax: {
                        url: "/Project/SearchProjectByCustomer",
                        dataType: 'json',
                        delay: 50,
                        data: function (params) {
                            return {
                                q: params.term,
                                customer: customer,
                                page: params.page
                            };
                        },
                        processResults: function (data, params) {
                            params.page = params.page || 1;

                            return {
                                results: data
                            };
                        },
                        cache: true
                    },
                    templateResult: projectFormatResult,
                    templateSelection: projectFormatSelection,
                });
            } else {
                $("#ddlProject").select2({
                    placeholder: 'Search Project by Name or Code',
                    minimumInputLength: 0,
                    ajax: {
                        url: "/Project/SearchProject",
                        dataType: 'json',
                        delay: 50,
                        data: function (params) {
                            return {
                                q: params.term,
                                page: params.page,
                                x: ""

                            };
                        },
