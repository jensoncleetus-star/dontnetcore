                    <i class="glyphicon glyphicon-plus"></i>Create
                </a>
            </div>
        }
        @if (User.IsInRole("Dev") || User.IsInRole("Customer"))
        {
            <div class="pull-right col-md-2">
                <a class="btn btn-success no-border btn-block" href="/Customer/">
