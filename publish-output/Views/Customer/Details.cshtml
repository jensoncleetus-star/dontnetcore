                                                    var color = "";
                                                    var updby = "";
                                                    if (upd.LogType == "Created")
                                                    {
                                                        color = "bg-green";
                                                        updby = "Created by";
                                                    }
                                                    else if (upd.LogType == "Updated")
                                                    {
                                                        color = "bg-orange";
                                                        updby = "Updated by";
                                                    }
                                                    else if (upd.LogType == "Remark Added")
                                                    {
                                                        color = "bg-teal";
                                                        updby = "Remark";
                                                    }
                                                    else if (upd.LogType == "Assigned")
                                                    {
                                                        color = "bg-purple";
                                                        updby = "Remark";
                                                    }
                                                    else if (upd.LogType == "Unassigned")
                                                    {
                                                        color = "bg-red";
                                                        updby = "Remark";
                                                    }
                                                    <li class="time-label">
                                                        <span class="@color">
                                                            @Convert.ToString(string.Format("{0:dd-MM-yyyy }", upd.Time))

                                                        </span>
                                                    </li>
