                                    <b>Code </b>
                                    <a class="pull-right">@Html.DisplayFor(m => m.CustomerCode)</a>
                                </li>
                                @if (Model.CustomerName != null)
                                {
                                    <li class="list-group-item">
                                        <b>Name </b>
                                        <a class="pull-right">@Html.DisplayFor(m => m.CustomerName)</a>
                                    </li>
                                }
                                @if (Model.Alias != null)
                                {
                                    <li class="list-group-item">
                                        <b>Alias </b>
                                        <a class="pull-right">@Html.DisplayFor(m => m.Alias)</a>
                                    </li>
                                }
