                                    <b>Credit Limit </b>
                                    <a class="pull-right">@Html.DisplayFor(m => m.CreditLimit)</a>
                                </li>
                                <li class="list-group-item">
                                    <b>Credit Period</b>
                                    <a class="pull-right">@Html.DisplayFor(m => m.CreditPeriod)</a>
                                </li>
                                @if (Model.Location != null)
                                {
                                    <li class="list-group-item">
                                        <b>Location</b>
                                        <a class="pull-right">@Html.DisplayFor(m => m.Location)</a>
                                    </li>
                                }
                                @if (Model.SalesPersonName != null)
