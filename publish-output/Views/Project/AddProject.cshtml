@model QuickSoft.ViewModel.ProjectViewModel
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Add Project</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("Create", "Project", FormMethod.Post, new { id = "projectform", role = "form", enctype = "multipart/form-data" }))
    {
        @Html.ValidationSummary("", new { @class = "alert alert-danger AlertDiv" })
        <div class="row">
            <div class="box-body">
                <div class="form-group col-md-2">
                    @Html.LabelFor(m => m.ProCode, new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.ProCode, new { htmlAttributes = new { @class = "form-control", @required = "required", @placeholder = "Enter Project Code" } })
                </div>
                <div class="form-group col-md-2">
                    @Html.LabelFor(m => m.ProjectName, new { @class = "control-label" }) *
                    @Html.EditorFor(model => model.ProjectName, new { htmlAttributes = new { @class = "form-control", @required = "required", @placeholder = "Enter Project Name" } })
                </div>
                <div class="form-group col-md-2">
                    @Html.LabelFor(model => model.ProType, htmlAttributes: new { @class = "control-label" })*
                    @*@if (User.IsInRole("Dev") || User.IsInRole("Create ProjectType"))
                        {*@
                    <div class="input-group input-group-sm">
                        @Html.DropDownListFor(m => m.ProType, (SelectList)ViewBag.proType, new { id = "ddlProType", @class = "form-control select2", @required = "required" })
                        <span class="input-group-btn">
                            <a href="/ProjectType/Create" class="modal-ptype btn btn-success btn-flat btnPType" title="Add ProjectType"><i class="fa fa-1x fa-plus-circle"></i></a>
                        </span>
                    </div>
                    @*}
                        else
                        {
                            @Html.DropDownListFor(m => m.ProType, (SelectList)ViewBag.proType, new { id = "ddlProType", @class = "form-control select2", @required = "required" })
                        }*@
                </div>

                <div class="form-group col-md-2">
                    @Html.LabelFor(m => m.Customer, new { @class = "control-label" }) *
                    @if (ViewBag.PopUpAddCust == true && (User.IsInRole("Dev") || User.IsInRole("Create Customer")))
                    {
                        <div class="input-group input-group-sm">
                            @Html.DropDownListFor(m => m.Customer, (SelectList)ViewBag.Customr, "", new { id = "ddlCust", @class = "form-control select2", @required = "required" })
                            <span class="input-group-btn">
                                <button type="button" href="/Customer/AddCustomer" class="modal-customer btn btn-success btn-flat"><i class="fa fa-1x fa-plus-circle"></i></button>
                            </span>
                        </div>
                    }
                    else
                    {
                        @Html.DropDownListFor(m => m.Customer, (SelectList)ViewBag.Customr, "", new { id = "ddlCust", @class = "form-control select2", @required = "required" })
                    }
                </div>
                <div class="form-group col-md-2">
                    @Html.LabelFor(m => m.ContactPerson, new { @class = "control-label" })
                    @Html.EditorFor(model => model.ContactPerson, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Contact Person" } })
                </div>
                <div class="col-md-2 form-group">
                    @Html.LabelFor(m => m.SalesPerson, new { @class = "control-label" })
                    @Html.DropDownListFor(m => m.SalesPerson, (SelectList)ViewBag.Employee, "", new { id = "SalesPerson", @class = "form-control select2" })
                </div>
                <div class="form-group col-md-2">
                    @Html.LabelFor(m => m.SalesContact, new { @class = "control-label" })
                    @Html.EditorFor(model => model.SalesContact, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Sale Contact Person" } })
                </div>
                <div class="form-group col-md-2">
                    @Html.LabelFor(m => m.ContactNumber, new { @class = "control-label" })
                    @Html.EditorFor(model => model.ContactNumber, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter Contact Number" } })
                </div>
                <div class="form-group col-md-2">
                    @Html.LabelFor(model => model.ProjectStatus, htmlAttributes: new { @class = "control-label" })*
                    @if (User.IsInRole("Dev") || User.IsInRole("Create ProjectStatus"))
                    {
                        <div class="input-group input-group-sm">
                            @Html.DropDownListFor(m => m.ProjectStatus, (SelectList)ViewBag.Stat, new { id = "ddlPStatus", @class = "form-control select2", @required = "required" })
                            <span class="input-group-btn">
                                <a href="/ProjectStatus/Create" class="modal-addnew btn btn-success btn-flat" title="Add Project Status"><i class="fa fa-1x fa-plus-circle"></i></a>
                            </span>
                        </div>
                    }
                    else
                    {
                        @Html.DropDownListFor(m => m.ProjectStatus, (SelectList)ViewBag.Stat, new { id = "ddlPStatus", @class = "form-control select2", @required = "required" })
                    }
                </div>
                <div class="form-group col-md-2">
                    @Html.LabelFor(m => m.Location, new { @class = "control-label" })
                    @Html.DropDownListFor(m => m.Location, (SelectList)ViewBag.Local, new { @class = "form-control input-sm select2 Loca", @placeholder = "Enter Location" })
                </div>
                <div class="col-md-2 form-group">
                    @Html.LabelFor(model => model.ExStartDate, htmlAttributes: new { @class = "control-label" })
                    <div class="input-group date">
                        <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                        @Html.TextBoxFor(m => m.ExStartDate, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                    </div>
                </div>

                <div class="col-md-2 form-group">
                    @Html.LabelFor(model => model.ExEndDate, htmlAttributes: new { @class = "control-label" })
                    <div class="input-group date">
                        <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                        @Html.TextBoxFor(m => m.ExEndDate, "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                    </div>
                </div>
                <div class="col-md-2 form-group">
                    @Html.LabelFor(model => model.IncomeAccount, htmlAttributes: new { @class = "control-label" })*
                    @Html.DropDownListFor(m => m.IncomeAccount, (SelectList)ViewBag.IncomeAcc, new { @class = "form-control select2" })
                </div>
                <div class="row">
                    @if (Model.FieldMap.Count > 0)
                {
                    for (int i = 0; i < Model.FieldMap.Count; i++)
                    {
                            <div class="form-group col-sm-2">
                                <label class="control-label" for="FieldName"> @Model.FieldMap[i].FieldName</label>
                                <input class="form-control input-sm" id="@Model.FieldMap[i].Field" name="@Model.FieldMap[i].Field" type="text" value="">
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
        <div class="row">

            <div class="form-group col-md-12">
                @Html.Label("Documents", null, new { @class = "control-label" })
                <div class="file-loading">
                    <input id="input-245" name="input24[]" type="file" multiple>
                </div>
            </div>
            <div class="form-group col-md-12">
                @Html.LabelFor(m => m.Details, new { @class = "control-label" })
                @Html.TextAreaFor(m => m.Details, new { @class = "form-control input-sm textarea", @placeholder = "Enter Details..", rows = 5 })
            </div>
            <div class="form-group col-md-12">
                @Html.LabelFor(m => m.Note, new { @class = "control-label" })
                @Html.TextAreaFor(m => m.Note, new { @class = "form-control input-sm", @placeholder = "Enter Note.." })
            </div>
            <div class="box-footer text-center">
                <button type="submit" id="save" class="btn btn-success">Submit</button>
                <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
            </div>
        </div>
            <script>
                $(".Loca").select2({
                    tags: true
                });
            </script>
    }
</div>
@section style{
    @Styles.Render("~/css/bootstrap-fileinput")
    @Styles.Render("~/css/bootstrap-fileinput-rtl")
}
@section scripts{

    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-timepicker")
    @Scripts.Render("~/js/bootstrap-fileinput")
    @Scripts.Render("~/js/bootstrap-sortable")
    @Scripts.Render("~/js/bootstrap-purify")
    <script type="text/javascript">

        $(document).ready(function () {
            $(function () {
                $(".textarea").wysihtml5();
            });


            $('#ExStartDate').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });
            $('#ExEndDate').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });
            var datetd = new Date();
            datetd.setDate(datetd.getDate());
            $('#ApDate').datepicker({
                endDate: datetd,
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });

            var ndate = $("#ApDate").val();
            if (ndate != "") {
                $('#StartDate').datepicker("setStartDate", ndate);
                $('#EndDate').datepicker("setStartDate", ndate);
            } else {
                var datenew = new Date();
                datenew.setDate(datenew.getDate());
            }

            CallLeadPipeCust();
            CallEmployee();

            $("#IncomeAccount").select2({
                placeholder: 'Search Income Account',
                minimumInputLength: 0,
                ajax: {
                    url: "/Accounts/SearchIncomeAccount",
                    dataType: 'json',
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term,
                            page: params.page,
                            x: "default"
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;
                        return {
                            results: data
                        };
                    },
                    cache: true
                },
            });

        });

        $("#input-245").fileinput({
            maxFilePreviewSize: 10240,
            autoReplace: true,
            maxFileCount: 10,
            showUploadedThumbs: true,

            overwriteInitial: false,
            showUpload: false,
            initialPreviewAsData: true,
            initialPreviewFileType: 'image',

            allowedFileExtensions: ["dwg ", "xlsx", "gif", "jpg", "png", "jfif", "jpeg", "doc", "docx", "pdf", "dwg", "pptx", "vsdx"],
        }).on('filesorted', function (e, params) {
            console.log('File sorted params', params);
        }).on('fileuploaded', function (e, params) {
            console.log('File uploaded params', params);
        });

    </script>
}
