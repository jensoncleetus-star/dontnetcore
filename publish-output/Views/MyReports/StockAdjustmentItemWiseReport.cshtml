@model QuickSoft.Models.StockAdjustment
@{
    ViewBag.Title = "Stock Adjustment Item Wise Search";
    ViewBag.SubTitle = "Stock Adjustment Item Wise Report";
    ViewBag.Active = "Reports";
}
<div class="box box-default">
    <form id="search-form">
        <div>
            <div class="box-header with-border">
                <h3 class="box-title">Stock Adjustment ItemWise Report</h3>
            </div>
            <div class="box-body">
                <input type="hidden" id="cname" value="@ViewBag.CName" />
                <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
                <div class="form-group col-md-4">
                    @Html.Label("From", null, new { @class = "control-label" })
                    <div class="input-group date">
                        @Html.TextBox("From", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                        <div class="input-group-addon">
                            <i class="fa fa-calendar"></i>
                        </div>
                    </div>
                </div>
                <div class="form-group col-md-4">
                    @Html.Label("To", null, new { @class = "control-label" })
                    <div class="input-group date">
                        @Html.TextBox("To", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                        <div class="input-group-addon">
                            <i class="fa fa-calendar"></i>
                        </div>
                    </div>
                </div>
                <div class="form-group col-md-4" id="creditsale">
                    @Html.Label("Item", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlItem", (SelectList)ViewBag.Item, new { @class = "form-control input-sm select2" })
                </div>
                <div class="box-footer col-md-12">
                    <button type="submit" class="btn btn-info col-sm-offset-5" id="btn">Submit</button>
                    <button type="button" class="btn btn-default" onclick="@("window.location.href='/Home/Index'");">Cancel</button>
                </div>

            </div>
        </div>
        </form>
</div>
<div class="box box-default" id="Showtable">
    <div class="box-header with-border">
        <h3 class="box-title">View Stock Adjustment Item Wise Report</h3>
    </div>
    <div class="box-body">
        <div class="box-body">
            <table class="display table table-bordered table-hover" id="MyTable">
                <thead>
                    <tr>
                        <td data-priority="1">S/N</td>
                        <td data-priority="2">Date</td>
                        <td data-priority="2">Invoice</td>
                        <td data-priority="2">Cost</td>
                        <td data-priority="4">Stock Less</td>
                        <td data-priority="5">Stock Add</td>
                        <td data-priority="3">Stock value</td>
                    </tr>
                </thead>
                <tbody></tbody>
                <tfoot>
                    <tr>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>



@{var Model = "modal-lg";}
@Html.Partial("../Common/_ModalCreate", @Model)
@Html.Partial("../Common/_ModalDelete")
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
}
@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
<script type="text/javascript">
        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });
        $(document).ready(function () {
            //$("#ddlVoucher").select2();
            //for set default date
            $('#To').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });
            $('#From').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });
            var date = new Date();
            var today = new Date(date.getFullYear(), date.getMonth(), date.getDate());
            var priordate = new Date(new Date().setDate(today.getDate() - 30));
            $('#To').datepicker('setDate', today);
            $('#From').datepicker('setDate', priordate);
            $('#Showtable').hide();
            $("#ddlItem").select2({
                placeholder: 'Search Item by Name or Code',
                minimumInputLength: 0,
                ajax: {
                    url: "/Item/Search",
                    dataType: 'json',
                    type: "POST",
                    delay: 50,
                    data: function (params) {
                        return {
                            q: params.term || "",
                            page: params.page || 0
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 0;

                        return {
                            results: data,
                            pagination: {
                                //more: (params.page * 10) < 50
                                more: true
                            }
                        };
                    },
                    cache: true
                },
            });

        });

        jQuery(function ($) {
            oTable = $('#MyTable').DataTable({
                "processing": true, // for show progress bar
                "serverSide": true, // for process server side
                "filter": false, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
                //"bStateSave": true,
                "bLengthChange": false,
                "paging": true,
                "pageLength": 5000,
                responsive: false,
                "ajax": {
                    "url": '/MyReports/GetStockAdjItemWiseReport',
                    "data": function (data) {
                        data.Item = $('#ddlItem').val();
                        data.fromdate = $('#From').val();
                        data.todate = $('#To').val();
                    },
                    "type": "POST",
                    "datatype": "json"
                },
                "order": [[0, "desc"]],
                "columns": [
                         {
                             "data": "id", "name": "id",
                             "render": function (data, type, row, meta) {
                                 return meta.row + meta.settings._iDisplayStart + 1;
                             }
                         },
                         {
                             "data": "Date", "name": "Date",
                             "render": function (data) {
                                 var date = convertToDate(data);
                                 return date.toString();
                             }
                         },
                    {
                        "name": "Voucher", "data": function (data) {
                            @{var urls = "";
}
                           
                             @{


                    urls = "'<a href=\"/StockAdjustment/Edit/'+  data.id +'\" target=\"_new\">'+ data.Voucher +'</a>' ";
                               }
                            return @Html.Raw(urls);

                        }
},
                     { "data": "PurchaseRate", "name": "PurchaseRate", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                     {
                         "name": "Stock Less",
                         "data": function (data) {
                             if (data.Type == 0) {
                                 return (data.Quantity);
                             } else {
                                 return 0;
                             }
                         }
                     },
                     {
                         "name": "Stock Add",
                         "data": function (data) {
                             if (data.Type == 1) {
                                 return (data.Quantity);
                             } else {
                                 return 0;
                             }
                         }
                     },
                      {
                          "name": "Stock Value", "data": function (data) {

                              var res = (data.Quantity * data.PurchaseRate).toFixed(2);
                              if (data.Type == 0) {
                                  var Negative = (-res);
                                  return Negative;
                              }
                              else {
                                  return res;
                              }
                          }
                      },

                ],
                buttons: [
                           {
                               extend: 'print',
                               title: "",
                               footer: true,
                               filename: function () {
                                   return 'ItemWise-StockAdjustment';
                               },
                               message: function () {
                                   var head = '<table class="tblcompact table table-bordered"><thead>' +
                                        '<tr><th class="text-center"><h3 style="margin-top: 0px;">' + $('#cname').val() + '</h3>' + $('#caddress').val() + '<h4>Stock Adjustment Report (Item Wise)</h4></th></tr>' +
                                        '<tr><th><span class="text-left">Item Code/Name : ' + $('#ddlItem').text() + '</span><span class="text-right pull-right"> From :  ' + $('#From').val() + ' To :' + $('#To').val() + '</span></th></tr></thead><tbody><tr><td>';
                                   return head;
                               },
                               customize: function (win) {
                                   $(win.document.body).find('table, th,tr, td ')
                                   // .css('border', 'inherit')
                                   .css('font-size', '10pt')
                                   .css('padding', '5px')
                                   .addClass('compact');
                                   $(win.document.body).append('</td></tr></tbody>')

                               }
                           }, 'copy', 'csv',
                           {
                               extend: 'excel',//
                               title: "",
                               footer: true,
                               filename: function () {
                                   return 'ItemWise-Purchase';
                               },
                               message: function () {
                                   var head = '' + $('#cname').val() + '\n' +
                                   '' + $('#caddress').val() + '\n' +
                                   ' Stock Adjustment Report (Item Wise) \n' +
                                   'Item Code/Name : ' + $('#ddlItem').text() + '\n' +
                                   'From :  ' + $('#From').val() + ' To :' + $('#To').val() + '';
                                   return head;
                               },
                               pageSize: 'A4',
                               exportOptions: {
                                   columns: ':visible' //[0, 1, 2, 3, 4, 5, 6]
                               },
                           },
                           {
                               extend: 'pdf',
                               title: "",
                               footer: true,
                               filename: function () {
                                   return 'ItemWise-StockAdjustment';
                               },
                               message: function () {
                                   var head = '' + $('#cname').val() + '\n' +
                                   '' + $('#caddress').val() + '\n' +
                                   ' Stock Adjustment Report (Item Wise) \n' +
                                   'Item Code/Name : ' + $('#ddlItem').text() + '\n' +
                                   'From :  ' + $('#From').val() + ' To :' + $('#To').val() + '';
                                   return head;
                               },
                               pageSize: 'A4',
                               exportOptions: {
                                   columns: ':visible'//[0, 1, 2, 3, 4, 5, 6]
                               },
                               customize: function (doc) {
                                   doc.pageMargins = [10, 10, 10, 10];
                                   doc.defaultStyle.fontSize = 10;
                                   doc.styles.tableHeader.fontSize = 10;
                                   doc.styles.title.fontSize = 12;
                                   // Header font and bg color
                                   doc.styles.tableHeader.fillColor = '#d3d3d3';
                                   doc.styles.tableHeader.color = 'black';
                                   // Remove spaces around page title
                                   doc.content[0].text = doc.content[0].text.trim();

                                   doc.styles['td:nth-child(2)'] = {
                                       width: '100%',
                                       'max-width': '100%'
                                   }

                                   //doc.content[1].table.widths = [
                                   //'5%',
                                   //'10%',
                                   //'20%',
                                   //'20%',
                                   //'15%',
                                   //'15%',
                                   //'15%'
                                   //]

                                   var objLayout = {};
                                   // Horizontal line thickness
                                   objLayout['hLineWidth'] = function (i) { return .5; };
                                   // Vertikal line thickness
                                   objLayout['vLineWidth'] = function (i) { return .5; };
                                   //// Horizontal line color
                                   //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                                   //// Vertical line color
                                   //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                                   // Left padding of the cell
                                   objLayout['paddingLeft'] = function (i) { return 4; };
                                   // Right padding of the cell
                                   objLayout['paddingRight'] = function (i) { return 4; };
                                   // Inject the object in the document
                                   doc.content[1].layout = objLayout;
                                   // Footer font and bg color
                                   doc.styles.tableFooter.fillColor = '#d3d3d3';
                                   doc.styles.tableFooter.color = 'black';
                               }
                           },
                ],



                sDom: "lBfr<'datatable-scroll't>ip",
                "lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                "footerCallback": function (row, data, start, end, display) {
                    var api = this.api(), data;
                    // Remove the formatting to get integer data for summation
                    var intVal = function (i) {
                        return typeof i === 'string' ?
                        i.replace(/[\$,]/g, '') * 1 :
                        typeof i === 'number' ?
                            i : 0;
                    };
                    //alert(api
                    //.column(6)
                    //);
                    // Total over all pages
                    total = api
                    .column(6)
                    .data()
                    .reduce(function (a, b) {
                        return intVal(a) + intVal(b);
                    }, 0);

                    // Total over this page
                    pageTotal = api
                    .column(6, { page: 'current' })
                    .data()
                    .reduce(function (a, b) {
                        return intVal(a) + intVal(b);
                    }, 0);

                    // Update footer
                    $(api.column(6).footer()).html(
                    pageTotal.toFixed(2)
                    //'$' + pageTotal + ' ( $' + total + ' total)'
                    );
                    //var Qty = api.cell(0, 6).data();

                    //$(api.column(6).footer()).html(Qty);


                    // Total over all pages
                    total = api
                        .column(5)
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Total over this page
                    pageTotal = api
                        .column(5, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update footer
                    $(api.column(5).footer()).html(
                         pageTotal.toFixed(2)
                        //'$' + pageTotal + ' ( $' + total + ' total)'
                    );
                    // Total over all pages
                    total = api
                        .column(4)
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Total over this page
                    pageTotal = api
                        .column(4, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update footer
                    $(api.column(4).footer()).html(
                         pageTotal.toFixed(2)
                        //'$' + pageTotal + ' ( $' + total + ' total)'
                    );
                }
            });
            $('#search-form').on('submit', function (e) {
                e.preventDefault();
                oTable.draw();
                $('#Showtable').show();
            });

            $('#MyTable tbody').on('click', 'tr', function () {
                if ($(this).hasClass('selected')) {
                    $(this).removeClass('selected');
                }
                else {
                    oTable.$('tr.selected').removeClass('selected');
                    $(this).addClass('selected');
                    $(this).addClass('dataTables_row');
                }
            });
        });
        function reload_table() {
            oTable.clear().draw();
            oTable.ajax.reload(null, false); //reload datatable ajax
        }


</script>
}
