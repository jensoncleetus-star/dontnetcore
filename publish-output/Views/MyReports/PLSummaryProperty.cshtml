@{
    ViewBag.Title = "Search P&L Summary";
    ViewBag.SubTitle = "P&L Summary";
    ViewBag.Active = "Reports";

    string actData = "";
    string actData2 = "";
}
<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">Search P&L Summary</h3>
    </div>
    <div class="box-body">
        <form id="search-form">
            <input type="hidden" id="cname" value="@ViewBag.CName" />
            <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
            <div class="form-group col-md-4">
                @Html.Label("Property", null, new { @class = "control-label" })
                @Html.DropDownList("Property", (SelectList)ViewBag.PropertyList, "All", new { id = "ddlProperty", @class = "form-control select2" })
            </div>
            <div class="form-group col-md-2 select2-box">
                @Html.Label("Landlord", null, new { @class = "control-label" })
                @Html.DropDownList("ddlLandlord", (SelectList)ViewBag.Cust, new { @class = "form-control input-sm select2" })
            </div>
            <div class="form-group col-md-4">
                @Html.Label("From", null, new { @class = "control-label" })
                <div class="input-group date">
                    @Html.TextBox("From", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                    <div class="input-group-addon">
                        <i class="fa fa-calendar"></i>
                    </div>
                </div>
            </div>
            <div class="form-group col-md-4">
                @Html.Label("To", null, new { @class = "control-label" })
                <div class="input-group date">
                    @Html.TextBox("To", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                    <div class="input-group-addon">
                        <i class="fa fa-calendar"></i>
                    </div>
                </div>
            </div>
            <div class="form-group col-md-4">
                <label class="control-label col-md-4">Include PDC Entries</label>
                <div class="col-sm-4">
                    <div class="input-group">
                        <input type="checkbox" name="pdc" id="pdc" value="true" checked />
                    </div>
                </div>
            </div>
            <div class="box-footer col-md-12">
                <button type="submit" class="btn btn-info col-sm-offset-5" id="btn">Submit</button>
                <button type="button" class="btn btn-default" onclick="@("window.location.href='/Home/Index'");">Cancel</button>
            </div>
        </form>
    </div>
</div>
<div class="box box-default" id="PLReport">
    <div class="box-header with-border">
        <h3 class="box-title">View P&L-Summary</h3>
    </div>
    <div class="box-body">
        <div class="box-body">
            <table class="display table table-bordered" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td>S/N</td>
                        <td>Propery Name</td>

                        <td class="headeralign">Income</td>
                        <td class="headeralign">Expenses</td>
                        <td class="headeralign">Net Income</td>
                        <td class="headeralign">Purchase Value</td>
                        <td class="headeralign">Rate Of Return</td>
                        <td></td>
                        <td></td>
                        <td>Exp</td>
                        <td>income</td>
                    </tr>
                </thead>
                <tbody></tbody>
                <tfoot>
                    <tr>
                        <th>Total:</th>
                        <th></th>

                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                    </tr>

            </table>
        </div>
    </div>
</div>

@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
}
@section Scripts {
    @Scripts.Render("~/js/property")
    @Scripts.Render("~/js/bootstrap-datepicker")
    <script type="text/javascript">
        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        })

        $(document).ready(function () {
            GetLandlordAll();
            CallCustomerBoth();
            //for set default date
            $('#To').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });
            $('#From').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });

            var date = new Date();
            var today = new Date(date.getFullYear(), date.getMonth(), date.getDate());
            var priordate = new Date(new Date().setDate(today.getDate() - 30));
            //  $('#To').datepicker('setDate', today);
            //  $('#From').datepicker('setDate', priordate);
            //---
            $('#PLReport').hide();
        });

        // onchange function for credit type

        jQuery(function ($) {
            oTable = $('#UserTable').DataTable({
                "processing": true, // for show progress bar
                "serverSide": true, // for process server side
                "filter": false, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
                // "bStateSave": true,
                "bLengthChange": false,
                "paging": true,
                "pageLength": 5000,
                "deferLoading": 0,
                "ordering": false,
                "ajax": {
                    "url": '/MyReports/GetPLSummaryProperty',
                    "data": function (data) {
                        data.customer = $('#ddlProperty').val();
                        data.landlord = $('#ddlLandlord').val();
                        data.fromdate = $('#From').val();
                        data.todate = $('#To').val();
                        data.pdc = $("#pdc:checked").val();
                        //data.NoCustomer = $('input[name="NoCustomer"]').prop('checked');
                    },
                    "type": "POST",
                    "datatype": "json"
                },
                "order": [[0, "desc"]],
                "columns": [
                    {
                        "data": "ProjectId", "name": "ProjectId",
                        "render": function (data, type, row, meta) {
                            return meta.row + meta.settings._iDisplayStart + 1;
                        }
                    },
                    { "data": "ProjectName", "name": "ProjectName" },

                    {
                        "name": "income", "data": function (data) {
                            if (data.income == null) {
                                return 0;
                            }
                            else {

                                actData2 = "<a class=\"modal-edit\" href=\"/MyReports/GetIncomeView/" + data.ProjectId + "?fromdate=" + $("#From").val() + "&todate=" + $("#To").val() + "&customer=" + data.ProjectId + "&pdc=" + $("#pdc:checked").val() + "\"title=\"Get Income Details\" target=\"_new\">" + '<div style=""><b>' + (data.income).toLocaleString('en-US') + '</b></div>' + "</a> ";
                                return actData2;
                            }
                        }, "sClass": "numberright"

                    },
                    {
                        "name": "expense", "data": function (data) {
                            if (data.expense == null) {
                                return 0;
                            }
                            else {


                                actData = "<a class=\"modal-edit\" href=\"/MyReports/GetExpenseView/" + data.ProjectId + "?fromdate=" + $("#From").val() + "&todate=" + $("#To").val() + "&customer=" + data.ProjectId + "&pdc=" + $("#pdc:checked").val() + "\"title=\"Get Income Details\" target=\"_new\">" + '<div style=""><b>' + (data.expense).toLocaleString('en-US') + '</b></div>' + "</a> ";
                                return actData;



                            }
                        }, "sClass": "numberright"

                    },
                    {
                        "name": "Profit/Loss", "data": function (data) {
                            var pro;
                            if ((data.expense == null) || (data.income == null)) {
                                if ((data.expense == null) && (data.income == null)) {
                                    return 0;
                                }
                                else if (data.expense == null) {
                                    return data.income.toLocaleString('en-US');
                                }
                                else {
                                    return '<div style="color:red"><b>' + (data.expense).toLocaleString('en-US') + '</b></div>'
                                }

                            }
                            else if ((data.income) > (data.expense)) {
                                return (data.income - data.expense).toLocaleString('en-US');
                            }
                            else {
                                return '<div style="color:red"><b>' + (data.expense - data.income).toLocaleString('en-US') + '</b></div>'
                            }
                        }, "sClass": "numberright"
                    },

                    {
                        "name": "Purchase", "data": function (data) {
                            if (data.purchase == null) {
                                return 0;
                            }
                            else {


                                actData = "<a class=\"modal-edit\" href=\"/MyReports/GetPurchaseView/" + data.ProjectId + "?fromdate=" + $("#From").val() + "&todate=" + $("#To").val() + "&customer=" + data.ProjectId + "&pdc=" + $("#pdc:checked").val() + "\"title=\"Get Purchase Details\" target=\"_new\">" + '<div style=""><b>' + (data.purchase).toLocaleString('en-US') + '</b></div>' + "</a> ";
                                return actData;



                            }
                        }




                        , "sClass": "numberright"
                    },
                    {
                        "name": "rateofreturn", "data": function (data) {
                            if (data.rateofreturn == null) {
                                return 0 + "%";
                            }
                            else {
                                actData = Math.abs(data.rateofreturn * 100).toFixed(2) + "%";
                                return actData;
                            }


                        }, "sClass": "numberright"
                    },
                    { "name": "purchasevalue", "data": "purchase" },
                    {
                        "name": "Profit/Loss", "data": "profit"
                    },
                    { "name": "expense", "data": "expense" },
                    { "name": "income", "data": "income" },
                ],
                buttons: [//'copy', 'csv', 'excel', 'pdf', 'print'
                    'colvis',
                    {
                        extend: 'print',//
                        exportOptions: {
                            columns: ':visible'
                        },
                        title: "",
                        footer: true,
                        filename: function () {
                            return 'P&L-Summary';
                        },
                        message: function () {
                            var head = '<table class="tblcompact table table-bordered"><thead>' +
                                ' <tr><th class="text-center"><h3 style="margin-top: 0px;">' + $('#cname').val() + '</h3>' + $('#caddress').val() + '<h4>P&L-Summary Report</h4></th></tr>' +
                                ' <tr><th><span class="text-left"></span><span class="text-right pull-right"> From :  ' + $('#From').val() + ' To :' + $('#To').val() + '</span></th></tr></thead><tbody><tr><td>';
                            return head;
                        },
                        customize: function (win) {
                            // $(win.document.body)
                            //.css('font-size', '10pt')
                            //.css('padding', '1px');
                            $(win.document.body).find('table, th,tr, td ')
                                // .css('border', 'inherit')
                                .css('font-size', '10pt')
                                .css('padding', '5px')
                                .addClass('compact');
                            $(win.document.body).append('</td></tr></tbody>')

                        }
                    }, 'copy', 'csv', //'excel',
                    {
                        extend: 'excel',//
                        title: "",
                        footer: true,
                        filename: function () {
                            return 'P&L-Summary-Report';
                        },
                        message: function () {
                            var head = '' + $('#cname').val() + '\n' +
                                '' + $('#caddress').val() + '\n' +
                                ' P&L-Summary Report \n' +
                                // 'Voucher Number : ' + $('#VoucherNumber').val() + '\n' +
                                'From :  ' + $('#From').val() + ' To :' + $('#To').val() + '';
                            return head;
                        },
                        pageSize: 'A4',
                        exportOptions: {
                            columns: ':visible'
                        },
                    },
                    {
                        extend: 'pdf',//
                        title: "",
                        footer: true,
                        filename: function () {
                            return 'P&L-Summary-Report';
                        },
                        message: function () {
                            var head = '' + $('#cname').val() + '\n' +
                                '' + $('#caddress').val() + '\n' +
                                ' P&L-Summary Report \n' +
                                'From :  ' + $('#From').val() + ' To :' + $('#To').val() + '';
                            return head;
                        },
                        pageSize: 'A4',
                        exportOptions: {
                            columns: ':visible'
                        },
                        customize: function (doc) {
                            doc.pageMargins = [10, 10, 10, 10];
                            doc.defaultStyle.fontSize = 10;
                            doc.styles.tableHeader.fontSize = 10;
                            doc.styles.title.fontSize = 12;
                            // Header font and bg color
                            doc.styles.tableHeader.fillColor = '#d3d3d3';
                            doc.styles.tableHeader.color = 'black';
                            // Remove spaces around page title
                            doc.content[0].text = doc.content[0].text.trim();



                            doc.content[1].table.widths = [
                                '10%',
                                '10%',
                                '10%',
                                '18%',
                                '18%',
                                '18%',
                                '10%'
                            ]

                            var objLayout = {};
                            // Horizontal line thickness
                            objLayout['hLineWidth'] = function (i) { return .5; };
                            // Vertikal line thickness
                            objLayout['vLineWidth'] = function (i) { return .5; };
                            //// Horizontal line color
                            //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                            //// Vertical line color
                            //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                            // Left padding of the cell
                            objLayout['paddingLeft'] = function (i) { return 4; };
                            // Right padding of the cell
                            objLayout['paddingRight'] = function (i) { return 4; };
                            // Inject the object in the document
                            doc.content[1].layout = objLayout;
                            // Footer font and bg color
                            doc.styles.tableFooter.fillColor = '#d3d3d3';
                            doc.styles.tableFooter.color = 'black';
                        }


                    }

                ],

                sDom: "lBfr<'datatable-scroll't>ip",
                "lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                "footerCallback": function (row, data, start, end, display) {
                    var api = this.api(), data;

                    // Remove the formatting to get integer data for summation
                    var intVal = function (i) {
                        return typeof i === 'string' ?
                            i.replace(/[\$,]/g, '') * 1 :
                            typeof i === 'number' ?
                                i : 0;
                    };

                    var exp;
                    var inc;
                    var tot;
                    // Total over all pages
                    total = api
                        .column(3)
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Total over this page
                    pageTotal = api
                        .column(10, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return (intVal(a) + intVal(b)).toLocaleString('en-US');
                        }, 0);

                    // Update footer
                    $(api.column(2).footer()).html(
                        inc = pageTotal
                        //'$' + pageTotal + ' ( $' + total + ' total)'
                    );// Total over all pages
                    total = api
                        .column(7)
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Total over this page
                    pageTotal = api
                        .column(9, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return (intVal(a) + intVal(b)).toLocaleString('en-US');
                        }, 0);

                    // Update footer
                    $(api.column(3).footer()).html(
                        exp = pageTotal
                        //'$' + pageTotal + ' ( $' + total + ' total)'
                    );
                    pageTotal = api
                        .column(8, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return (intVal(a) + intVal(b)).toLocaleString('en-US');
                        }, 0);
                    // Update footer
                    $(api.column(4).footer()).html(
                        inc = pageTotal

                        //'$' + pageTotal + ' ( $' + total + ' total)'
                    );

                    pageTotal = api
                        .column(7, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return (intVal(a) + intVal(b)).toLocaleString('en-US');
                        }, 0);
                    $(api.column(5).footer()).html(
                        purchasetotal = pageTotal

                        //'$' + pageTotal + ' ( $' + total + ' total)'
                    );
                    var table = $('#UserTable').DataTable();
                    if (!table.data().any()) {
                        $('#UserTable tfoot').hide();
                    } else {
                        $('#UserTable tfoot').show();
                    }
                }
            });


            $('#search-form').on('submit', function (e) {
                e.preventDefault();
                oTable.draw();
                $('#PLReport').show();
            });
            var column1 = oTable.column(7);
            column1.visible(false);
            var column1 = oTable.column(8);
            column1.visible(false);
            var column1 = oTable.column(9);
            column1.visible(false);
            var column1 = oTable.column(10);
            column1.visible(false);
            var column1 = oTable.column(11);
            column1.visible(false);


            $('#UserTable tbody').on('click', 'tr', function () {
                if ($(this).hasClass('selected')) {
                    $(this).removeClass('selected');
                }
                else {
                    oTable.$('tr.selected').removeClass('selected');
                    $(this).addClass('selected');
                    $(this).addClass('dataTables_row');
                }
            });

            function reload_table() {
                oTable.clear().draw();
                oTable.ajax.reload(null, false); //reload datatable ajax
            }
        });
        $("#ddlproperty").select2({
            placeholder: 'Search Customer by Name or Code',
            minimumInputLength: 0,
            ajax: {
                url: "/Customer/SearchCustomer",
                dataType: 'json',
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term || "",
                        page: params.page || 0,
                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 0;

                    return {
                        results: data,
                        pagination: {
                            //more: (params.page * 10) < 50
                            more: true
                        }
                    };
                },
                cache: true
            },
        });
        var Entry = getQueryString('');
        $("#ddlProperty").select2({
            placeholder: ' Search Property',
            minimumInputLength: 0,
            ajax: {
                url: "/PropertyMain/SearchPropertyAll",
                dataType: 'json',
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term,
                        page: params.page,
                        x: "All"
                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 1;

                    return {
                        results: data
                    };
                },
                cache: true
            },
        });
    </script>
}

