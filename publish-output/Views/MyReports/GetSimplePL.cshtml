@using QuickSoft.ViewModel
@model QuickSoft.ViewModel.TrialBalanceAccViewModel
@{
    ViewBag.Title = "Simple P&L";
    ViewBag.SubTitle = " Simple P&L";
    ViewBag.Active = "Accounts";
    ViewBag.Count = 0;
    ViewBag.TDr = 0;
    ViewBag.TCr = 0;

}
<div class="box box-default" id="LReport">
    <div class="box-header with-border">
        <h3 class="box-title">Simple P&L Report</h3>
    </div>
    <div class="box-body">
        <div id="Acctree">
            <input type="hidden" id="cname" value="@ViewBag.CName" />
            <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
            <input type="hidden" id="fromdate" value="@Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.From))" />
            <input type="hidden" id="todate" value="@Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.To))" />
            <table class="table table-bordered table-hover  dtable" id="UserTable" style="width:100%">
                <thead>
                    <tr class="bg-gray">
                        <td class="text-center" colspan="4">
                            From: @Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.From)) to @Convert.ToString(string.Format("{0:dd-MM-yyyy}", Model.To))
                        </td>
                    </tr>
                    <tr class="bg-gray">
                        <td>Particulars</td>
                        <td>Code</td>
                        <td class="text-center">
                            DEBIT ( AED )
                        </td>
                        <td class="text-center">
                            CREDIT ( AED )
                        </td>
                    </tr>
                </thead>
                <tbody>
                    @{ TreeView(Model); }
                </tbody>
            </table>
        </div>
    </div>
</div>
@{ void TreeView(TrialBalanceAccViewModel module, long? parent = 0, string spaces = "")
{
ViewBag.Count++;
TrialBalanceAccViewModel sub = new TrialBalanceAccViewModel();
sub.Data = module.Data;
var submodule = sub.Data;
var data = ViewBag.Active;
decimal? CrSum = 0;
decimal? DrSum = 0;
decimal? PL = 0;

foreach (var menus in module.Data)
{
    var space = "";
    var classn = (menus.Type == "Group") ? "glyphicon-hand-right" : "glyphicon-arrow-right";
    var disables = (menus.Type == "Group") && (menus.text != "Supplier" || menus.text != "Customer" || menus.text != "Customer") ? "" : ", \"disabled\":true";

    if (menus.Parent == parent)
    {
        space = spaces + "&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;";
        var Debit = Convert.ToDecimal(menus.Debit);
        var Credit = Convert.ToDecimal(menus.Credit);
        var Sum = Debit - Credit;
        decimal? Dr = 0;
        decimal? Cr = 0;

        if (Sum > 0)
        {
            Dr = Sum;
        }
        if (Sum < 0)
        {
            Cr = 0 - Sum;
        }

        if (menus.Type == "Group")
        {
                <tr>
                    @if ((menus.Parent == 0) && (menus.text == "Revenue Accounts"))
                    {
                        <td class="text-red">@menus.text</td>
                        <td class="text-right"></td>
                        <td class="text-right "></td>
                        <td class="text-right">@menus.amount</td>
                        CrSum += menus.amount;
                        PL += menus.amount;
                    }
                    else if ((menus.Parent == 0) && (menus.text == "Expense"))
                    {
                        <td class="text-red">@menus.text</td>
                        <td class="text-right"></td>
                        <td class="text-right ">@menus.amount</td>
                        <td class="text-right"></td>
                        DrSum += menus.amount;
                        PL -= menus.amount;
                    }
                    else
                    {
                        <td class="text-black">@Html.Raw(spaces)@menus.text</td>
                        <td class="text-black">@Html.Raw(spaces)@menus.code</td>
                        <td class="text-right ">@Dr.Value.ToString("0.00")</td>
                        <td class="text-right">@Cr.Value.ToString("0.00")</td>

                    }
                </tr>
            }
            else //if (Dr - Cr != 0)
            {
                <tr>
                    <td class="text-blue">@Html.Raw(spaces)&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;@menus.text</td>
                    <td class="text-black">@Html.Raw(spaces)@menus.AccountId</td>
                    @if (Dr == (decimal)0)
                    {
                        <td class="text-right "></td>
                    }
                    else
                    {
                        <td class="text-right ">@Dr.Value.ToString("0.00")</td>
                    }
                    @if (Cr == (decimal)0)
                    {
                        <td class="text-right "></td>
                    }
                    else
                    {
                        <td class="text-right ">@Cr.Value.ToString("0.00")</td>
                    }

                </tr>
        }

        ViewBag.TDr += Dr;
        ViewBag.TCr += Cr;
        if (menus.Type == "Account")
        {
                TreeView(sub, menus.ID, space);
        }

    }
}

if (PL < 0)
{
    PL = PL * (-1);
}
ViewBag.Count--;
if (ViewBag.Count == 0)
{
        @*<tr>
                <td><b>Total</b></td>
                <td></td>
                <td class="text-right" id="ddlTCredit"><b>@ViewBag.TDr</b></td>
                <td class="text-right" id="ddlTDebit"><b>@ViewBag.TCr</b></td>
            </tr>*@
        <tr>
            <td><b>Grand Total</b></td>
            <td></td>
            <td class="text-right"><b> @DrSum</b></td>
            <td class="text-right"><b>@CrSum</b></td>
        </tr>
        <tr>
            @if (DrSum > CrSum)
            {

                <td class="text-red">Loss</td>
                <td></td>
                <td class="text-right"><b>@PL</b></td>
                <td class="text-right"></td>
            }
            else
            {
                <td>Profit</td>
                <td></td>
                <td class="text-right"></td>
                <td class="text-right"><b>@PL</b></td>
            }

        </tr>
}
} }

