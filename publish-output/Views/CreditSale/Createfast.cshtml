        function taxinusedmat(type) {
            if (type != null) {
                if (type == 2) {
                    var TaxP = 0;
                    var tbody = $("#normalinvoiceused tbody");
                    if (tbody.children().length > 0) {
                        tbody.children("tr").each(function () {
                            var rowid = $(this).attr("id");
                            var item = $("#" + rowid + " .uitem_name").val();
                            var subtot = $("#" + rowid + " .usubtotal").val();
                            if (item != null) {
                                $("#" + rowid + " .utax_percentage").val(0);
                                $("#" + rowid + " .utax").val("0.00" + " (" + 0 + "%)");
                                $("#" + rowid + " .utot_tax").val(0);
                            }
                        });
                        // CalculatetblItemListSum();
                        // grandtotalcalculation();
                        //paidamountcalculation();
                    }
                } else {

                    var tbody = $("#normalinvoiceused tbody");
                    if (tbody.children().length > 0) {
                        tbody.children("tr").each(function () {
                            var rowid = $(this).attr("id");
                            var item = $("#" + rowid + " .uitem_name").val();
                            if (item != null) {
                                $.ajax({
                                    url: '/Item/GetItem',
                                    type: "GET",
                                    dataType: "JSON",
                                    data: { itemID: item },
                                    success: function (result) {
                                        $("#" + rowid + " .utax_percentage").val(result.Tax.toFixed(2));

                                        var quantity = $("#" + rowid + " .uquty").val();
                                        var rate = $("#" + rowid + " .utotrate").val();
                                        var subtotal = quantity * rate;
                                        $("#" + rowid + " .usubtotal").val(subtotal.toFixed(2));

                                        var itemdiscount = $("#" + rowid + " .uitem_discount").val();
                                        subtotal = subtotal - itemdiscount;

                                        var taxAmount = subtotal * (result.Tax / 100);
                                        var Total = subtotal + taxAmount;

                                        $("#" + rowid + " .utot_tax").val(taxAmount.toFixed(2));
                                        $("#" + rowid + " .utax").val(taxAmount.toFixed(2) + " (" + result.Tax + "%)");
                                    }
                                });
                            }
                        });
                    }
                }
            }
        }
