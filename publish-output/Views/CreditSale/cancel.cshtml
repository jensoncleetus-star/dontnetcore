@model QuickSoft.Models.SalesEntry
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Cancel Sales Entry</h4>
</div>
<div class="modal-body">
    <h3>Are you sure you want to Cancel this?</h3>
    @using (Html.BeginForm("Cancel", "CreditSale", FormMethod.Post, new { id = "changeforms" }))
    {
        @Html.AntiForgeryToken()
        <div class="form-actions no-color">
            <input type="submit" value="Cancel" class="btn btn-danger col-sm-offset-4" />
            <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal">
        </div>
    }
</div>
