            <input type="hidden" id="VoucherType" value="Sales" />
            <input type="hidden" id="batchcheck" value="@ViewBag.BatchWiseStock" />
            <input type="hidden" id="discount" value="@ViewBag.Discountpercent" />
            <input type="hidden" id="enablediscount" value="@ViewBag.DisPercheck" />
            <input type="hidden" id="mdvcheck" value="@ViewBag.DVEnable" />
            <input type="hidden" id="TaxInclusive" value="@ViewBag.TaxInclusive" />
            <div class="row" style="margin-top:20px;">

                @if (@ViewBag.BusinessType == "Scaffold")
