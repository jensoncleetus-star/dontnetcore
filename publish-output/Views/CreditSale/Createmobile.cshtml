        function readBarcode(q) {
            $.ajax({
                url: "/Item/GetByBarcode",
                dataType: 'json',
                type: "POST",
                delay: 50,
                data: { q: q },
                success: function (e) {
                    if (e.length == 1) {
                        var itemId = e[0]['id'];
                        if (itemId != null) {
                            if ($(".item_" + itemId).length > 0) {
                                var qty = parseFloat($(".item_" + itemId + " .quty").val());
                                $(".item_" + itemId + " .quty").val(qty + 1);
                                var divid = $(".item_" + itemId).attr('id');
                                var arg = divid.substr(divid.indexOf("_") + 1);
                                quantity_change(arg);
                                $(".barcode").val("");
                                $(".barcode").focus();
                            } else {
                                $.ajax({
                                    url: '/Item/GetItemById',
                                    dataType: 'json',
                                    data: { ItemId: itemId },
                                    cache: true,
                                    success: function (data) {

                                        $(".item_").remove();
                                        $.each(data, function (i, item) {
                                            var taxamt = item.SellingPrice * (item.Tax / 100);
                                            addrow('addinvoiceItem', 'sales', item.ItemUnit, item.Tax, '', 1, item.ItemID, item.ItemCode, item.ItemName, item.SellingPrice, item.SellingPrice, item.ItemWithCode, taxamt, 0, '', item);
                                        });
                                        addrow('addinvoiceItem', 'sales', "", "0.00", "0.00", "0");
                                        $(".barcode").val("");
                                        $(".barcode").focus();
                                    }
                                });
                            }
                        }
                    }
                },
                complete: function () {
                    me.data('requestRunning', false);
                },
                cache: true
            });
        }


