        function HType() {
            var Type = $('#SaleType').val();
            var method;
            if (Type == 2) {
                $('#HireType').show();
                method = "Hire";
            }
            else {
                $('#HireType').hide();
                method = "Sale";
            }
            STypeForMC(Type);
            saletypechange(Type, method);


            //hirerate
            var Stype = (($('#SaleType').val()) == 1) ? "Sale" : "Hire";

            $.ajax({
                url: '/CreditSale/GetHireInvoiceNum',
                data: { hiretype: Stype },
                type: "POST",
                dataType: "JSON",
                success: function (Hresult) {
                    $('#BillNo').val(Hresult);
                }
            });
            //Multiple DVNote
            $('#InvoiceId').text("");
            $("#ddlCustomer").select2("val", "");
            $('#ConType').val("");
            var tr = $('#addinvoiceItem td:last');
            $('#MuDvNt').hide();
            var classname = $(tr).closest('tr').attr('class');
            if (classname != 'item_') {
                addrow('addinvoiceItem', 'sales', "", "0.00", "0.00", "0");
            }
        }

        function STypeForMC(Type) {
            if (Type == 2 && '@ViewBag.DefMc' != null && '@ViewBag.DefMc' != 0) {
                var MCDefid = '@ViewBag.DefMc';
                $("#ddlMC").val(MCDefid).change();
                $('#ddlMC').attr("disabled", true);
            }
            else if (Type == 1 && '@ViewBag.DefMc' != null && '@ViewBag.DefMc' != 0) {
                if ($("#ddlMC").find('option[value="3"]').text() == 'Sale') {
                    $("#ddlMC").val(3).change();
                    $('#ddlMC').attr("disabled", false);
                }
            }
            else {
                var MCDefid = '@ViewBag.LastMc';
                $("#ddlMC").val(MCDefid).change();
                $('#ddlMC').attr("disabled", false);
            }
        }
