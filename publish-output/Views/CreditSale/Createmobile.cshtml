                    <div class="form-group col-sm-2 col-xs-12 hide1">
                        @Html.Label("Type *", null, new { @class = "control-label temp2" })
                        @Html.EnumDropDownListFor(model => model.SaleType, new { @class = "form-control", @onchange = "HType();", @required = "required", data_msg_required = "The Sale type field is required" })
                    </div>
                }
                <div class="col-sm-2 form-group col-xs-12">
                    @Html.Label("Invoice No *", null, new { @class = "control-label temp2" })
                    @if (User.IsInRole("Dev") || User.IsInRole("Invoice Edit Permission"))
                    {
                        @Html.EditorFor(model => model.BillNo, new { htmlAttributes = new { @class = "form-control", @required = "required" } })
                    }
                    else
                    {
                        @Html.EditorFor(model => model.BillNo, new { htmlAttributes = new { @class = "form-control", @required = "required", @readonly = "readonly" } })
                    }
                    @Html.HiddenFor(model => model.SENo)
                    @Html.HiddenFor(model => model.ConvertType)
                    @Html.HiddenFor(model => model.ConvertNo)
                </div>
                <div class="col-sm-2 form-group col-xs-12 sh-mobi-hide">
