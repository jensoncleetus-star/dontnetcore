        function MultiDV() {
            var list = $('#createdvform').serialize();
            $.ajax({
                url: '/Deliverynote/multidvnote',
                type: "POST",
                dataType: 'json',
                data: list,
                cache: true,
                success: function (data) {

                    if (data.Result.length != 0) {
                        $('#addinvoiceItem').html('');
                        var newOption = $('<option></option>');
                        newOption.val(data.Customer).attr("selected", "selected");
                        newOption.html(data.CustName);
                        $('#ddlCustomer').append(newOption);
                        $('#ddlCustomer').val(data.Customer).trigger("change");

                        $.each(data.MultiInv, function (i, item) {
                            var str = "";
                            str += item.DVInvoice + ', ';
                            $('#InvoiceId').append(str);
                        });

                        $("#addinvoiceItem").html("");
                        $.each($(data.Result), function (i, item) {
                            $('#ConvertNo').val($('#InvoiceId').text());
                            $('#ConvertType').val('DVNote');
                            $('#ConTypeId').val(item.Dvnum);
                            $('#ConType').val('DVNote');
                            addrow('addinvoiceItem', 'sales', item.ItemUnit, item.ItemTax, item.ItemTotalAmount, item.ItemQuantity, item.Item, item.ItemCode, item.ItemName, item.ItemUnitPrice, item.ItemSubTotal, item.ItemWithCode, item.ItemTaxAmount, item.ItemDiscount, item.ItemNote, item);

                        });
                        $('#Invoice-div').show();
                        addrow('addinvoiceItem', 'sales', '', '0.00', '0.00', '0')
                    }
                    else {
