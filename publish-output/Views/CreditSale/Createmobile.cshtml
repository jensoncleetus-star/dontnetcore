@using (Html.BeginForm("CreateSale", "CreditSale", FormMethod.Post, new { id = "saleform", role = "form", enctype = "multipart/form-data" }))
{
    <div class="box box-info">
        <div class="box-header with-border">
            <div class="row">
                @*<h3 class="box-title">Create Sales Entry-Invoice</h3>*@
                <div class="col-xs-8">
                    <div class="ribbon">
                        <div class="ribbon4"><h3 class="box-title" style="font-size:12px!important;">Create Sales Entry-Invoice</h3></div>
                    </div>
                </div>
                <div class="col-xs-4">
                    <div class="pull-right">
                        @if (@ViewBag.LastEntry != 0)
                        {
                            if (User.IsInRole("Dev") || User.IsInRole("Edit Sales Entry"))
                            {
                                <a class="btn bg-black no-border" style="padding:5px 7px!important;" href="/CreditSale/Edit/@ViewBag.LastEntry">
                                    <i class="fa fa-step-backward"></i>
                                </a>
                            }
                        }
                        @if (User.IsInRole("Dev") || User.IsInRole("Sales Entry List"))
                        {
                            <a class="btn btn-success no-border" style="padding:5px 7px!important;" href="/CreditSale">
                                <i class="fa fa-fw fa-history"></i> List
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        @Html.HiddenFor(model => model.ConTypeId)
        @Html.HiddenFor(model => model.ConType)
        <div class="box-body">
            <input type="hidden" id="ROnlyRate" value="@IRateCheck" />
            <input type="hidden" id="SettlementMode" value="@SettlementMode" />
            <input type="hidden" id="ContType" value="@ViewBag.ContType" />
            <input type="hidden" id="SelApprovedBy" />
            <input type="hidden" id="LastSale" value="@ViewBag.LastTransInSale" />
