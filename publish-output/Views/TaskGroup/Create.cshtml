@model QuickSoft.ViewModel.TaskGroupViewModel

<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Task Group</h4>
</div>

<div class="modal-body">
   @using (Html.BeginForm("Create", "TaskGroup", FormMethod.Post, new { id = "createform" }))
    {
        <script type="text/javascript">
            $('form#createform').removeData("validator");
            $('form#createform').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#createform'));
        </script>

        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger AlertDiv" })

        <div class="row">
            <div class="form-group col-md-12">
                @Html.Label("Task Type", null, new { @class = "control-label" })
                @Html.DropDownListFor(m => m.TaskType, (SelectList)ViewBag.tasktype, new { id = "ddlTaskType", @class = "form-control input-sm select2" })
            </div>
            <div class="form-group col-md-12">
                @Html.Label("Task Status", null, new { @class = "control-label col-md-12" })
                @Html.DropDownListFor(m => m.TaskStatus, (SelectList)ViewBag.taskstatus, new { id = "TaskStatus", @class = "form-control input-sm ", @name = "ddlEmployee[]", @multiple = true })
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" value="Save" class="btn btn-info col-sm-offset-4" />
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>
  <script>
      $(document).ready(function () {
          TaskStatusName();
          $("#ddlTaskType").select2({});
      });
  </script>



