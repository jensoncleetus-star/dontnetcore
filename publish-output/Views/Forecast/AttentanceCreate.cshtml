                <img class="loading" src="~/Content/img/loadingicon.gif">
            </div>





        </div>
        <br>
        <br>





    }
</div>
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/bootstrap-fileinput")
    @Styles.Render("~/css/bootstrap-fileinput-rtl")
}
@section Scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/bootstrap-fileinput")
    @Scripts.Render("~/js/bootstrap-piexif")
    @Scripts.Render("~/js/bootstrap-purify")
    @Scripts.Render("~/js/bootstrap-sortable")

    <script type="text/javascript">



    var lst = '@ViewBag.laststatus';

    if (lst != "Expired" ) {
        $(".login").hide();
        $(".logout").show();
    }
    else {

        $(".login").show();
        $(".logout").hide();
        $(".loading").hide();
    }




    </script>

    <script>
        /*------------------date and time widget---------------------*/
        $(document).ready(function () {
            // Create two variable with the names of the months and days in an array
            var monthNames = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
            var dayNames = ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"]

            // Create a newDate() object
            var newDate = new Date();
            // Extract the current date from Date object
            newDate.setDate(newDate.getDate());
            // Output the day, date, month and year
            $('#Date').html(dayNames[newDate.getDay()] + " " + newDate.getDate() + ' ' + monthNames[newDate.getMonth()] + ' ' + newDate.getFullYear());

            setInterval(function () {
                // Create a newDate() object and extract the seconds of the current time on the visitor's
                var seconds = new Date().getSeconds();
                // Add a leading zero to seconds value
                $("#sec").html((seconds < 10 ? "0" : "") + seconds);
            }, 1000);

            setInterval(function () {
                // Create a newDate() object and extract the minutes of the current time on the visitor's
                var minutes = new Date().getMinutes();
                // Add a leading zero to the minutes value
                $("#min").html((minutes < 10 ? "0" : "") + minutes);
            }, 1000);

            setInterval(function () {
                // Create a newDate() object and extract the hours of the current time on the visitor's
                var hours = new Date().getHours();
                if (hours > 12) {
                    hours -= 12;
                } else if (hours === 0) {
                    hours = 12;
                }
                // Add a leading zero to the hours value
                $("#hours").html((hours < 10 ? "0" : "") + hours);
            }, 1000);



            getLocation();
            function getLocation() {
                if (navigator.geolocation) {
                    navigator.geolocation.getCurrentPosition(showPosition);
                } else {
                    // x.innerHTML = "Geolocation is not supported by this browser.";
                }
            }
            function showPosition(position) {

                $("#lat").val(position.coords.latitude);
                $("#log").val(position.coords.longitude);
            }
        });


    </script>
    <script>
        $(document).ready(function () {
            setInterval(function () {
            if ('@ViewBag.duration' == "0") {
                $('.duration').val("press start to begin");
            }
            else {
                var logdate = '@ViewBag.duration';
                var Expdate = Date.now();
                /*Expdate = Date.parse(Expdate);*/


                /*today = Date.parse(today);*/
                var convertedexpdate =  Expdate;
                var convertedlogdate = Date.parse(logdate);
                var dif = convertedexpdate - convertedlogdate

                function msToTime(duration) {
                    var milliseconds = Math.floor((duration % 1000) / 100),
                        seconds = Math.floor((duration / 1000) % 60),
                        minutes = Math.floor((duration / (1000 * 60)) % 60),
                        hours = Math.floor((duration / (1000 * 60 * 60)) % 24);

                    hours = (hours < 10) ? "0" + hours : hours;
                    minutes = (minutes < 10) ? "0" + minutes : minutes;
                    seconds = (seconds < 10) ? "0" + seconds : seconds;

                    return hours + " Hours  :  " + minutes + " Minutes  :  " + seconds + " seconds";
                }
                document.getElementById('duration').value = msToTime(dif);
                function msToTimenostring(duration) {
                    var milliseconds = Math.floor((duration % 1000) / 100),
                        seconds = Math.floor((duration / 1000) % 60),
                        minutes = Math.floor((duration / (1000 * 60)) % 60),
                        hours = Math.floor((duration / (1000 * 60 * 60)) % 24);

                    hours = (hours < 10) ? "0" + hours : hours;
                    minutes = (minutes < 10) ? "0" + minutes : minutes;
                    seconds = (seconds < 10) ? "0" + seconds : seconds;

                    return hours + "." + minutes;
                }
                document.getElementById('duraduplicate').value = msToTimenostring(dif);

                }
            }, 1000);

        });
    </script>
}
