<style type="text/css">
    /* If you want you can use font-face */

    .center {
        margin: auto;
    }

    .clock {
        width: 100%;
        text-align: center;
        margin: 0 auto;
        padding: 30px;
        color: black;
    }

    #Date {
        font-family: 'BebasNeueRegular', Arial, Helvetica, sans-serif;
        font-size: 20px;
        text-align: center;
    }

    .ul {
        width: 200px;
        margin: 0 auto;
        padding: 0px;
        list-style: none;
        text-align: center;
    }

        .ul .li {
            display: inline;
            font-size: 25px;
            text-align: center;
            font-family: 'BebasNeueRegular', Arial, Helvetica, sans-serif;
        }

    #point {
        position: relative;
        -moz-animation: mymove 1s ease infinite;
