                    <br />
                    <h3>Login Duration<i class="fa fa-clock-o" aria-hidden="true"></i> </h3>
                    <input type="text" class="form-control duration" id="duration" readonly style="text-align:center; font-size:large; background-color:white;color:blue;">
                    <input type="text" value="0.00" id="duraduplicate" name="dura" hidden />
                    @*--------to get value of login and logout--------------------------------------*@
                    <input type="hidden" class="form-control" value="@ViewBag.laststatus" name="status">

                    <br />
                </div>
            </div>



            <div class="row text-center">

                <button class="btn btn-success btn-lg active login" name="login" type="submit">Start</button>


                <button class="btn btn-danger btn-lg active logout" name="logout" type="submit">Stop</button>
