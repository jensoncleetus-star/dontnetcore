        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger AlertDiv" })
        <div class="box-header with-border">
            <h3 class="box-title">Employee Attendance</h3>
            <input type="hidden" name="lat" id="lat" />
            <input type="hidden" name="log" id="log" />
            <div class="pull-right">
                @*<a class="btn bg-blue no-border" href="/Employeeattendance/Index">
                    <i class="fa fa-step-backward"></i>  Daily Register
                </a>*@
                <a class="btn bg-aqua no-border" href="/Forecast/EmpAttentanceReport">
                    <i class="fa fa-step-backward"></i>  Report
                </a>
            </div>
        </div>
        <br />

        <div class="row justify-content-center">
            <div class="col-md-12 mx-auto" style="margin:auto;">
                <div class="clock">
                    <div class="current"> Current date and time</div>
                    <div id="Date"></div>
                    <ul class="ul">

                        <li class="li" id="hours"></li>
                        <li class="li" id="point">:</li>
                        <li class="li" id="min"></li>
                        <li class="li" id="point">:</li>
                        <li class="li" id="sec"></li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="container">
            <div class="row text-center">
                <div class="col-md-4 col-lg-offset-4">
