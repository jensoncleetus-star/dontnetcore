        var flag = 0;
        var diffTime = 0;
        var diffDays = 0;
    $('#search-form').on('submit', function (e) {

        e.preventDefault();
        const date1 = new Date($("#From").val());
        const date2 = new Date($("#To").val());
         diffTime = Math.abs(date2 - date1);
        var diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
