
@{
    ViewBag.Title = "Forecast";
    ViewBag.SubTitle = "Forecast";
    ViewBag.Active = "Reports";
    var url = Model;
}
<div class="box box-default">
    <div class="box-header with-border">
        <h3 class="box-title">Item Forecast</h3>
    </div>
    <div class="box-body">
        <form id="search-form">
            <input type="hidden" id="cname" value="@ViewBag.CName" />
            <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
            <input type="hidden" id="datefrom" name="datefrom">
            <input type="hidden" id="dateto" name="dateto">
            @*<div class="form-group col-md-4">
                    <label class="control-label"><input type="checkbox" value="true" name="stockable" id="stockable" />  Include non-stockable Items</label>
                </div>*@
            <div class="row">
                <div class="form-group col-md-2 col-xs-6">
                    @Html.Label("Categories", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlCategories", (SelectList)ViewBag.Category, new { @class = "form-control input-sm select2 ", @required = "required" })
                </div>
                <div class="col-md-2 col-xs-6">
                    @Html.Label("Item", null, new { @class = "control-label col-md-4" })
                    @Html.DropDownList("ddlItem", (SelectList)ViewBag.Item, new { @required = "required", @class = "form-control input-sm" })
                </div>
                <div class="clearfix visible-xs-block "></div>
                @if (@ViewBag.EnableMCcheck == 0)
                {
                    @*<div class="form-group col-md-2 col-xs-6">
                            @Html.Label("Material Center", null, new { @class = "control-label" })
                            @Html.DropDownList("ddlMC", (SelectList)ViewBag.MC, new { @class = "form-control input-sm" })
                        </div>*@
                    <div class="form-group col-md-4">
                        @Html.Label("Material Center", null, new { @class = "control-label" })
                        @*@Html.DropDownList("ddlMC", (SelectList)ViewBag.MC, new { @class = "form-control input-sm", @multiple = "multiple", @name = "ddlMC[]" })*@
                        @Html.ListBox("ddlMC", (MultiSelectList)ViewBag.mc, new { @class = "form-control input-sm" })
                    </div>
                }
                <div class="form-group col-md-2 col-xs-6" style="display:none;">
                    @Html.Label("Period", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlPeriod", (IEnumerable<SelectListItem>)ViewBag.Period, new { @class = "form-control input-sm select2" })
                </div>
                <div class="form-group col-md-2">
                    @Html.Label("From", null, new { @class = "control-label" })
                    <div class="input-group date">
                        @Html.TextBox("From", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                        <div class="input-group-addon">
                            <i class="fa fa-calendar"></i>
                        </div>
                    </div>
                </div>
                <div class="form-group col-md-2">
                    @Html.Label("To", null, new { @class = "control-label" })
                    <div class="input-group date">
                        @Html.TextBox("To", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                        <div class="input-group-addon">
                            <i class="fa fa-calendar"></i>
                        </div>
                    </div>
                </div>
                <div class="form-group col-md-2 col-xs-6">
                    @Html.Label("Brand Name", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlBrand", (IEnumerable<SelectListItem>)ViewBag.Brand, new { @class = "form-control input-sm select2" })
                </div>
            </div>
            <div class="row">
                <div class="form-group col-md-2 col-xs-6" id="creditPurchaseReturn">
                    @Html.Label("Supplier", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlSupplier", (SelectList)ViewBag.Supplier, new { @class = "form-control input-sm select2" })
                </div>
                <div class="form-group col-md-2">
                    @Html.Label("Search", null, new { @class = "control-label" })
                    @Html.TextBox("Searchtext", "", new { @class = "form-control input-sm" })
                </div>
                <div class="form-group col-md-2 col-xs-6">
                    @Html.Label(" ", null, new { @class = "control-label" })
                    <label class="form-control input-sm"><input type="checkbox" value="true" name="zerostockitem" id="ddlZeroMovement" checked />  Hide Zero Movement Stock</label>
                </div>
            </div>
            <div class="form-group col-md-12 lblpadding">
                <button type="submit" class="btn btn-info col-sm-offset-5" id="btn">Search</button>
                <button type="button" class="btn btn-default" onclick="@("window.location.href='/Home/Index'");">Cancel</button>
            </div>
        </form>
    </div>
</div>
<div class="box box-default" id="StockReport">
    <div class="box-body">
        <input type="hidden" id="cname" value="@ViewBag.CName" />
        <input type="hidden" id="caddress" value="@ViewBag.CAddress" />
        <input type="hidden" id="itemname" value="@ViewBag.ItemName" />
        <input type="hidden" id="PoNo" value="@ViewBag.PartNoCheck" />
        <input type="hidden" id="mcname" value="@ViewBag.MCSName" />

        <div class="box-body">
            <table class="display table table-bordered table-hover" id="UserTable">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="1">S/N</td>
                        <td>Item Code</td>
                        <td>Item Name</td>
                        <td>Unit Price</td>
                        <td>Net Movement Qty</td>
                        <td>Current Stock Qty</td>
                        
                        <td>Showroom</td>
                        <td>Last 1month Movement</td>
                        <td>No Of Bill</td>
                        

                    </tr>
                </thead>
                <tbody></tbody>
                @*<tfoot>
                        <tr>
                            <th>Total:</th>
                            <th></th>

                            <th></th>
                            <th></th>
                            <th></th>

                        </tr>
                    </tfoot>*@
            </table>
        </div>
    </div>
</div>
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
}
@section Scripts {
    @Scripts.Render("~/js/bootstrap-datepicker")
    <script type="text/javascript">
        $('#datefrom').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });
        $('#dateto').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });
        $("#ddlCategories").select2({
            placeholder: 'Search Categories',
            minimumInputLength: 0,
            ajax: {
                url: "/Forecast/CategorySearch",
                dataType: 'json',
                type: "POST",
                delay: 50,
                data: function (params) {

                    return {
                        q: params.term,
                        page: params.page,
                        x: "All"
                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 1;

                    return {
                        results: data
                    };
                },
                cache: true
            },
        });
        //For Supplier list
        CallRepSupplier2();

        $("#ddlBrand").select2({
            placeholder: 'Search Brand',
            minimumInputLength: 0,
            ajax: {
                url: "/Forecast/BrandSearch",
                dataType: 'json',
                type: "POST",
                delay: 50,
                data: function (params) {

                    return {
                        q: params.term,
                        page: params.page,
                        x: "All"
                    };
                },
                processResults: function (data, params) {
                    params.page = params.page || 1;

                    return {
                        results: data
                    };
                },
                cache: true
            },
        });


    $('.date').datepicker({
        format: 'dd-mm-yyyy',
        autoclose: true,
        allowInputToggle: true
    });
    $(document).ready(function () {
        $('#StockReport').hide();
        $('#To').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });
        $('#From').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });

        var date = new Date();
        var today = new Date(date.getFullYear(), date.getMonth(), date.getDate());
        var priordate = new Date(new Date().setDate(today.getDate() - 30));
        $('#To').datepicker('setDate', today);
        $('#From').datepicker('setDate', priordate);
       /* ItemSearchable();*/
        CallRepMCUser();

        $("#ddlItem").select2({
            placeholder: 'Search Item by Name or Code',
            minimumInputLength: 0,
            ajax: {
                url: "/Item/Search",
                dataType: 'json',
                delay: 50,
                data: function (params) {
                    return {
                        q: params.term || "",
                        page: params.page || 0,
                        x: "Select Item"
                    };
                },
                results: function (data) {
                    return { results: data };
                },
                processResults: function (data, params) {
                    params.page = params.page || 0;
                    return {
                        results: data,
                        pagination: {
                            //more: (params.page * 10) < 50
                            more: true
                        }
                    };
                },
                cache: true
            },

        });
    });

    function searchData(data) {
       // data.stockable = $('input[name="stockable"]').prop('checked');
        data.zerostockitem = $('input[name="zerostockitem"]').prop('checked');
        data.itemid = $("#ddlItem").val();
        data.categories = $("#ddlCategories").val();
        data.brandId = $("#ddlBrand").val();
        data.supplier = $("#ddlSupplier").val();

        var today = new Date()
        var priorDate = new Date().setDate(today.getDate() -(30))
        var strdate = new Date(priorDate)
        var date1 = strdate.toLocaleDateString('en-GB')

        data.datefrom = $("#From").val();
        //-------------------------------------------------------
        //------------------current date------------------------
        var nowDate = new Date();
        var date2 = nowDate.getDate() + '-' + (nowDate.getMonth() + 1) + '-' + nowDate.getFullYear();
        data.dateto = $("#To").val();
        //-------------------------------------------------------
        data.ddmc = $('#ddlMC').val();
        data.srchtxt = $('#Searchtext').val();
    }

    function showdatatable() {

        var itemid = $("#ddlItem").val();
        var datefrom = $("#From").val();
        var dateto = $("#To").val();
        var ddmc = $('#ddlMC').val();
        var ddsupplier = $("#ddlSupplier").val();

            oTable = $('#UserTable').DataTable({
                "processing": true, // for show progress bar,
                "serverSide": false, // for process server side
                "filter": false, // this is for disable filter (search box)
                "orderMulti": false, // for disable multiple column at once
                // "bStateSave": true,
                //"deferLoading": 0, // disable default ajax loading
                "bLengthChange": false,
