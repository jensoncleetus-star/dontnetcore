                    "sClass": "numberright"
                }],
                "ajax": {
                    "url": '/Forecast/GetStock22',
                    "data": function (data) {
                        data = searchData(data);
                    },
                    "type": "POST",
                    "datatype": "json"
                },
                "columns": [
                    {
                        "data": "IItemID", "name": "IItemID",
                        "render": function (data, type, row, meta) {
                            return meta.row + meta.settings._iDisplayStart + 1;
                        }
                    },
                    { "data": "IItemCode", "name": "IItemCode" },
                    {
                        "name": "IItemName", "data": function (data) {

                              @{
                    var urls = "";

                    urls = "'<a href=\"#\" >'+  data.IItemCode+' '+data.IItemName +'</a>' ";
                               }
                            return @Html.Raw(urls);



                        }
                    },
                    { "data": "IPurchasePrice", "name": "IPurchasePrice" },
                     { "data": "netvalue", "name": "netvalue", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                    {
                        "data": "currstock", "name": "currstock",
                        "render": function (data) {
                            if (data < 0) {
                                return "0";
                            }
                            else {
                                return data;
                            }
                        }
                    },
          {
                        "name": "1monthForecastqty", "data": function (data) {
                            if (data.currstock < 0) {
                                var currentStock = 0;
                            }
                            else {
                                var currentStock = data.currstock;
                            }
                            var moment = Math.abs(1 * data.onemonth);
                            if (currentStock > moment) {
                                var purchaseqty = 0;
                            }

                            else {
                                var balacestock = currentStock - (moment);

                                if (balacestock > moment) {
                                    var purchaseqty = 0;
                                }
                                else if (balacestock < 0) {
                                    var Revbalancestock = (moment - currentStock);

                                    if (Revbalancestock == moment) {
                                        purchaseqty = Revbalancestock;


                                    }
                                    else if (Revbalancestock < moment) {

                                        purchaseqty = moment - (moment - Revbalancestock);

                                    }
                                }
                                else {
                                    if (balacestock > 0) {
                                        if (balacestock > moment) {
                                            var purchaseqty = 0;
                                        }
                                        else {
                                            var purchaseqty = moment - (moment - balacestock);
                                        }
                                    }
                                    else {
                                        var purchaseqty = moment;
                                    }
                                }
                            }
                            const format = (num, decimals) => num.toLocaleString('en-US', {
                                minimumFractionDigits: 2,
                                maximumFractionDigits: 2,
                            });
                            if (purchaseqty == undefined) {
                                return "0";
                            }
                            else {
                                return format(parseFloat(purchaseqty).toFixed(2)  );
                            }


                        }
                    },
                    { "data": "onemonth", "name": "onemonth", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },
                    { "data": "invoices", "name": "invoices", render: $.fn.dataTable.render.number(",", ".", 2), "sClass": "numberright" },



                    //{
                    //    "data": function (data) {
                    //        return data.stockin-data.stockout
                    //    }
                    //},
                           ],
                buttons: [//'copy', 'csv', 'excel', 'pdf', 'print'
                    {
                        extend: 'print',//
                        title: "",
                        footer: true,
                        filename: function () {
                            return 'Stock Report (Item Wise)';
                        },
                        message: function () {
                            var head = '<table class="tblcompact table table-bordered"><thead>' +
                                ' <tr><th class="text-center"><h3 style="margin-top: 0px;">' + $('#cname').val() + '</h3>' + $('#caddress').val() + '<h4>Stock Movement</h4></th></tr>' +
