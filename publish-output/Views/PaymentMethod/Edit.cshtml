@model QuickSoft.Models.PaymentMethod
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Edit Payment Method</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("Edit", "PaymentMethod", FormMethod.Post, new { id = "editform" }))
            {
        <script type="text/javascript">
            $('form#editform').removeData("validator");
            $('form#editform').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#editform'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        <div class="row">
            <div class="col-md-12 form-group">
                @Html.LabelFor(model => model.MethodName, htmlAttributes: new { @class = "control-label" }) *
                @Html.EditorFor(model => model.MethodName, new { htmlAttributes = new { @class = "form-control", tabindex = 1, autofocus = "autofocus", @required = "required" } })
            </div>
            <div class="col-md-12 form-group">
                @Html.LabelFor(model => model.AccountId, htmlAttributes: new { @class = "control-label" }) *
                @Html.DropDownListFor(m => m.AccountId, (SelectList)ViewBag.Account, new { id = "ddlAccount", @class = "form-control accid select2", @required = "required" })
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" value="Update" class="btn btn-info col-sm-offset-4" tabindex=2 />
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>
