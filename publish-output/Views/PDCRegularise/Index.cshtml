                            <td>Account</td>
                            <td>PDC Issued</td>
                            <td>PDC Receipt</td>
                            <td>PDC Journal</td>
                            <td>Check No.</td>
                            <td>Remark</td>
                            <td>Status</td>
                            @*<td>Created By</td>
                                <td>Created Date</td>
                                <td>Branch</td>*@
                        </tr>
                    </thead>
                    <tbody></tbody>
                    <tfoot>
                        <tr>
                            <th>Total:</th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                    </tfoot>
                </table>
            </div>
            <div class="box-footer col-md-12" id="sub">
                <button type="submit" id="save" class="btn btn-info col-sm-offset-5">Submit</button>
