
@{
    ViewBag.Title = "Regularise PDC";
    ViewBag.SubTitle = "Regularise PDC";
    ViewBag.Active = "Master";

}
<div class="box box-default" id="formsec">
    <div class="box-header with-border">
        <h3 class="box-title">Regularise PDC</h3>
    </div>
    <div class="box-body">
        <form id="search-form">
            <div class="form-group col-md-4">
                @Html.Label("Check Number", null, new { @class = "control-label" })
                @Html.TextBox("CheckNumber", "", new { @class = "form-control input-sm" })
            </div>
            <div class="form-group col-md-4" style="">
                <label class="control-label">Select Bank Account</label>
                @Html.DropDownList("ddlBank", (SelectList)ViewBag.Bank, "", new { @class = "form-control select2 input-sm" })
            </div>
            <div class="form-group col-md-4">
                @Html.Label("Voucher Type", null, new { @class = "control-label" })
                @Html.DropDownList("ddlType", (SelectList)ViewBag.Type, new { @class = "form-control select2 input-sm" })
            </div>
            @if (ViewBag.BusinessType != "Property")
            {
                <div class="form-group col-md-4 cus">
                    @Html.Label("Customer", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlCustomer", (SelectList)ViewBag.Customer, new { @class = "form-control select2 input-sm" })
                </div>
                <div class="form-group col-md-4 sup">
                    @Html.Label("Supplier", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlSupplier", (SelectList)ViewBag.Supplier, new { @class = "form-control select2 input-sm" })
                </div>
            }
            else
            {
                <div class="form-group col-md-4 select2-box">
                    @Html.Label("Tenant", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlTenant", (SelectList)ViewBag.Alldata, "All", new { @class = "form-control input-sm select2" })
                </div>
                <div class="form-group col-md-4 select2-box">
                    @Html.Label("Contractor", null, new { @class = "control-label" })
                    @Html.DropDownList("ddlContractor", (SelectList)ViewBag.Alldata, "All", new { @class = "form-control input-sm select2" })
                </div>
            }
            <div class="form-group col-md-4 select2-box">
                @Html.Label("With Hold", null, new { @class = "control-label" })
                <input type="checkbox" value="1" checked="checked" name="chkhold" id="chkhold" />
            </div>
            <div class="form-group col-md-4">
                <label class="control-label">From</label>
                <div class="input-group date">
                    <input class="form-control input-md" id="From" name="From" value="" type="text">
                    <div class="input-group-addon">
                        <i class="fa fa-calendar"></i>
                    </div>
                </div>
            </div>
            <div class="form-group col-md-4">
                <label class="control-label">To</label>
                <div class="input-group date">
                    <input class="form-control input-md" id="To" name="To" value="" type="text">
                    <div class="input-group-addon">
                        <i class="fa fa-calendar"></i>
                    </div>
                </div>
            </div>

            <div class="box-footer col-md-12">
                <input type="submit" class="btn btn-info col-sm-offset-5" value="Submit" />
                <button type="button" class="btn btn-default" onclick="@("window.location.href='" + @Url.Action("Index", "Home") + "'");">Cancel</button>
                @*<input type="button" class="btn btn-default" value="Reset" data-dismiss="modal" id="btnreset" />*@
            </div>
        </form>
    </div>
</div>
@Html.Partial("../Common/_ModalChange")
<div class="box box-default" id="SReport">
    @using (Html.BeginForm("update", "PDCRegularise", FormMethod.Post, new { id = "payform", role = "form" }))
