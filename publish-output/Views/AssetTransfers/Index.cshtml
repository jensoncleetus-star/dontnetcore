@model QuickSoft.ViewModel.AssetTransferViewModel
@{
    ViewBag.Title = "List";
    ViewBag.SubTitle = "AssetTransferList";
    ViewBag.Active = "Transactions";
    string actData = "";
    string delchk = "";
    string deleteBTn = "";

    deleteBTn = "{text: 'Delete', className: 'btn-danger', action: function(e, dt, node, config) {" +
        "if ($('.checkbox:checked').length > 0) {if (confirm('Are you sure you want to delete this?')) {$('#AssetTransferForm').submit(); e.preventDefault();} " +
         "} else {alert('Please Select Rows..!!');e.preventDefault();}}},";

}

<style type="text/css">

    .dropdown-check-list {
        display: inline-block;
    }
    
        .dropdown-check-list .anchor {
            position: relative;
            cursor: pointer;
            display: inline-block;
            padding: 5px 50px 5px 10px;
            border: 1px solid #ccc;
            width: 150px;
            background: #fff;
            text-align: center;
        }
       
            .dropdown-check-list .anchor:after {
                position: absolute;
                content: "";
                border-left: 2px solid black;
                border-top: 2px solid black;
                padding: 5px;
                right: 10px;
                top: 20%;
                -moz-transform: rotate(-135deg);
                -ms-transform: rotate(-135deg);
                -o-transform: rotate(-135deg);
                -webkit-transform: rotate(-135deg);
                transform: rotate(-135deg);
            }

            .dropdown-check-list .anchor:active:after {
                right: 8px;
                top: 21%;
            }

        .dropdown-check-list ul.items {
            padding: 0px;
            display: none;
            margin: 0;
            border: 1px solid #ccc;
            border-top: none;
            position: absolute;
            z-index: 9999;
        }

            .dropdown-check-list ul.items li {
                list-style: none;
                background: #fff;
                padding: 5px;
            }

    .add-btn-item {
        border-radius: 23px;
        padding: 6px 20px;
    }

    .dropdown-check-list.visible .anchor {
        color: #0094ff;
    }

    .dropdown-check-list.visible .items {
        display: block;
    }

    .box-header .pull-right {
        margin-top: -22px;
    }
</style>

<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">List AssetTransfers</h3>
        
        <div class="pull-right">
            <i class="ace-icon fa fa-hand-o-right icon-animated-hand-pointer blue"></i>
            <a class="btn btn-info no-border" href="/AssetTransfers/Create">
                <i class="glyphicon glyphicon-plus"></i> Create
            </a>
        </div>
        
        <div class="row">
            <div class="col-md-2">
                <div id="list1" class="dropdown-check-list" tabindex="100">
                    <span class="anchor" style="z-index:0;">Select Fields</span>
                    <ul class="items">
                        <li><input type="checkbox" id="liassetno" />Invoice No</li>
                        <li><input type="checkbox" id="lifromdate" />From Date</li>
                        <li><input type="checkbox" id="litodate" />To Date</li>
                       
                    </ul>
                </div>
            </div>

            <div class="col-md-12">
                <div class="box-body search-box" id="advsearchlist">
                    <div class="search-body col-md-12" style="background:none;">
                        <form id="search-form">
                            <div class="row">
                                <input type="hidden" id="remId" />
                                <div class="form-group col-md-2" id="searchassetno">
                                    @Html.Label("Invoice No", null, new { @class = "control-label" })
                                    @Html.TextBox("AssetID", "", new { @class = "form-control input-sm" })
                                </div>
                                
                                <div class="form-group col-md-2" id="searchfromdate">
                                    @Html.Label("From Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("FromDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group col-md-2" id="searchtodate">
                                    @Html.Label("To Date", null, new { @class = "control-label" })
                                    <div class="input-group date">
                                        @Html.TextBox("ToDate", "", "{0:dd-MM-yyyy}", new { @class = "form-control datepicker input-sm", @autocomplete = "off" })
                                        <div class="input-group-addon">
                                            <i class="fa fa-calendar"></i>
                                        </div>
                                    </div>
                                </div>

                               

                                <div class="form-group col-md-2" id="search">
                                    <input type="submit" class="btn btn-submit" value="Submit" />
                                </div>
                                <div class="form-group col-md-2" id="close">
                                    <input type="button" class="btn btn-close" value="Close" />
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @using (Html.BeginForm("DeleteAll", "AssetTransfers", FormMethod.Post, new { id = "AssetTransferForm", role = "form" }))
    {
       
        <div class="box-body">
            <table class="table table-bordered table-hover" id="AssetTable">
                <thead>
                    <tr class="bg-gray">
                        <td data-priority="1">S/N</td>
                        <td data-priority="1">Invoice No</td>
                        <td data-priority="2"> AssetEntry Date</td>
                        <td data-priority="3" >Amount</td>
                        <td data-priority="2">Action</td>
                        <td data-priority="1"><input type="checkbox" id="select_all" /></td>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    }

    <div id="modal-container2" class="modal fade" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-aqua">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                    <h4>Status Updation History</h4>
                </div>
                <div class="modal-body">
                    <table class="table table-bordered table-hover" id="UserTableInfo">
                        <thead>
                            <tr class="bg-aqua">
                                <td>Status</td>
                                <td>Updated By</td>
                                <td>Requested By</td>
                                <td>Date</td>
                                <td>Remarks</td>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
@{var Model = "modal-lg";}
@Html.Partial("../Common/_ModalCreate", @Model)
@Html.Partial("../Reminder/Index")
@Html.Partial("../Common/_ModalEdit")
@Html.Partial("../Common/_ModalChange")
@Html.Partial("../Common/_ModalDelete")
@section style{
    @Styles.Render("~/css/bootstrap-datepicker")
    @Styles.Render("~/css/bootstrap-timepicker")
}
@section scripts{
    @Scripts.Render("~/js/jqueryval")
    @Scripts.Render("~/js/bootstrap-datepicker")
    @Scripts.Render("~/js/bootstrap-timepicker")

    <script type="text/javascript">

        $('.date').datepicker({
            format: 'dd-mm-yyyy',
            autoclose: true,
            allowInputToggle: true
        });

        jQuery.validator.methods["date"] = function (value, element) { return true; }
        $(".timepicker").timepicker({
            showInputs: true,
            defaultTime: false,
            format: 'dd-mm-yyyy'
        });
       
        $(document).ready(function () {
            $('#advsearchlist').hide();

            $('#ToDate').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });

            $('#FromDate').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                allowInputToggle: true
            });

            var date = new Date();
            var today = new Date(date.getFullYear(), date.getMonth(), date.getDate());
            var priordate = new Date(new Date().setDate(today.getDate() - 30));
            $('#To').datepicker('setDate', today);
            $('#From').datepicker('setDate', priordate);
        });
      
        var checkList = document.getElementById('list1');
        /******* Function to list and hide dropdown checklist while clicking on 'Select Fields' *******/
        checkList.getElementsByClassName('anchor')[0].onclick = function (evt) {
            if (checkList.classList.contains('visible'))
                checkList.classList.remove('visible');
            else
                checkList.classList.add('visible');
        }
       

        /******* Function to show and hide fields while clicking on checkboxes in 'Select Fields' *******/
        $("ul li input:checkbox").click(function () {

            var _show = 0;
            
            //Asset No.
      
            if ($("#liassetno ").prop("checked") == true) {
                $("#searchassetno").show();
                _show = 1;
            }
          
            else {
                $('#AssetID').val("");
                $("#searchassetno").hide();
                oTable.draw();
            }
          
            //From Date
            if ($("#lifromdate").prop("checked") == true) {
                $("#searchfromdate").show();
                _show = 1;
            }
            else {
                $("#FromDate").val("");
                $("#searchfromdate").hide();
                oTable.draw();
            }

            //To Date
            if ($("#litodate").prop("checked") == true) {
                $("#searchtodate").show();
                _show = 1;
            }
            else {
                $("#ToDate").val("");
                $("#searchtodate").hide();
                oTable.draw();
            }

             

            if (_show == 1) {
                $('#advsearchlist').show();
            }
            else {
                $('#advsearchlist').hide();
            }
        });

        /******* Function to hide dropdown checklist while clicking outside it ********/
        $(document).on("click", function (event) {
           
            var element1 = $("#list1");

            if (element1 !== event.target && !element1.has(event.target).length) {
                checkList.classList.remove('visible');
            }
         
        });


        //select all checkboxes
        //select all checkboxes
        $('body').on('change', '#select_all', function () {
            $(".checkbox").prop('checked', $(this).prop("checked")); //change all ".checkbox" checked status
          
        });
        //".checkbox" change
        $('body').on('change', '.checkbox', function () {
           
            //uncheck "select all", if one of the listed checkbox item is unchecked
            if (false == $(this).prop("checked")) { //if this item is unchecked
                $("#select_all").prop('checked', false); //change "select all" checked status to false
            }
            isTicked();
        });
        isTicked();
 
        var oTable = $('#AssetTable').DataTable({

            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "pageLength": 50,
        responsive: true,
          
        "bLengthChange": false,
       
        "ajax": {
        
            "url": '/AssetTransfers/GetAssetTransfer',
           
            "data": function (data) {
             
                    data.AssetID = $('#AssetID').val();
                   
                    data.FromDate = $('#FromDate').val();
                    data.ToDate = $('#ToDate').val();
                  
                

                },
                "type": "POST",
                "datatype": "json"

            },
            "order": [[0, "desc"]],
            "columnDefs": [{
                "targets": [4,5],
                "orderable": false
            }],
            "columns": [
                {
                    "data": "Id", "name": "Id",
                    "render": function (data, type, row, meta) {
                        return meta.row + meta.settings._iDisplayStart + 1;
                    }
                },
                { "data": "AssetID", "name": "AssetID" },
                {
                    "data": "Date", "name": "Date",
                     "render": function (data) {
                         var date = convertToDate(data);
                         return date.toString();
                     }
                },
               
                { "data": "TotalAssetValue", "name": "TotalAssetValue"},


                {
                    "name": "Id", "data": function (data) {
                         var rest = "";
                         @{
                             actData += "<a class=\"btn btn-icons btn-rounded btn-edit\" href=\"/AssetTRansfers/Edit/'+ data.Id +'\" title=\"Edit Entry\"><i class=\"fa fa-pencil\" ></i></a> ";
                             actData += "<a class=\"btn btn-icons btn-rounded btn-delete modal-delete\" href=\"/AssetTRansfers/Delete/'+ data.Id +'\" title=\"Delete Entry\"><i class=\"fa fa-trash\" ></i></a> ";
                          }
                         return rest = '@Html.Raw(actData)';
                     }
                 },
                {
                    "name": "Id", "data": function (data) {
                          var rest = "";
                          @{
                              delchk = "<input class=\"checkbox\" type=\"checkbox\" name=\"bill[]\" value='+ data.Id +'></input>";
                          }
                          return rest = '@Html.Raw(delchk)';
                      }
                  },
            ],
            
            buttons: [
               'colvis',
               {
                   extend: 'print',//
                   title: "",
                   footer: true,
                   filename: function () {
                       return 'Asset Transfer';
                   },
                   columnDefs: [
                       { width: 400, targets: 2 }
                   ],
                   exportOptions: {
                       columns: ':visible'
                   },
                   message: function () {
                       var head = '<table class="tblcompact table table-bordered"><thead>' +
                       ' <tr><th class="text-center"><h3 style="margin-top: 0px;"><h4>Asset Transfer</h4></th></tr>';
                       return head;
                   },
                   customize: function (win) {
                       // $(win.document.body)
                       //.css('font-size', '10pt')
                       //.css('padding', '1px');
                       $(win.document.body).find('table.tblcompact tbody td').css('padding', '0px');
                       $(win.document.body).find('.dataTable,.dataTable th,.dataTable tr,table.tblcompact tbody td .dataTable td')
                           .css('font-size', '10pt')
                           .css('padding', '5px')
                           .addClass('compact');
                       $(win.document.body).find('.dataTable tr th:nth-child(3)')
                           .css('min-width', '80px');
                       //$(win.document.body).find('.tblcompact tbody td:nth- child(2)')
                       //    .css('padding', '0px');
                       $(win.document.body).append('</td></tr></tbody>')

                   }
               }, 'copy', 'csv', //'excel',
               {
                   extend: 'pdf',//
                   title: "",
                   footer: true,
                   filename: function () {
                       return 'Asset Transfers';
                   },
                   message: function () {
                       var head = 'Asset Transfers';
                       return head;
                   },
                   pageSize: 'A4',
                   exportOptions: {
                       columns: ':visible'
                   },
                   customize: function (doc) {
                       doc.pageMargins = [10, 10, 10, 10];
                       doc.defaultStyle.fontSize = 10;
                       doc.styles.tableHeader.fontSize = 10;
                       doc.styles.title.fontSize = 12;
                       // Header font and bg color
                       doc.styles.tableHeader.fillColor = '#d3d3d3';
                       doc.styles.tableHeader.color = 'black';
                       // Remove spaces around page title
                       doc.content[0].text = doc.content[0].text.trim();

                       doc.styles['td:nth-child(2)'] = {
                           width: '100%',
                           'max-width': '100%'
                       }

                       var objLayout = {};
                       // Horizontal line thickness
                       objLayout['hLineWidth'] = function (i) { return .5; };
                       // Vertikal line thickness
                       objLayout['vLineWidth'] = function (i) { return .5; };
                       //// Horizontal line color
                       //objLayout['hLineColor'] = function (i) { return '#aaa'; };
                       //// Vertical line color
                       //objLayout['vLineColor'] = function (i) { return '#aaa'; };
                       // Left padding of the cell
                       objLayout['paddingLeft'] = function (i) { return 4; };
                       // Right padding of the cell
                       objLayout['paddingRight'] = function (i) { return 4; };
                       // Inject the object in the document
                       doc.content[1].layout = objLayout;
                       // Footer font and bg color
                       doc.styles.tableFooter.fillColor = '#d3d3d3';
                       doc.styles.tableFooter.color = 'black';
                   }
                },
               @Html.Raw(deleteBTn)
            ],
           
            sDom: "lBfr<'datatable-scroll't>ip",
            "drawCallback": function (settings) {
                //var table = $('#AssetTable').DataTable();
                //if (!table.data().any()) {
                //    $("#sub").hide();
                //} else {
                //    $("#sub").show();
                //}
            }

       });

       
        

        //Button Close
        $('#srch, .search-box .btn-close').on('click', function (e) {
            $('#advsearchlist').toggle();

            /*******  To uncheck all the checkboxes in the Select List  ************/
            var checkboxes = document.querySelectorAll("input[type='checkbox']");
            checkboxes.forEach(function (Checkbox) {
                Checkbox.checked = false;
            });

            if ($('#srch').hasClass('btn-primary')) {

                $('#srch').addClass('btn-danger');
                $('#srch').removeClass('btn-primary');
            }
            else {
                if ($('#srch').hasClass('btn-danger')) {
                    $('#srch').addClass('btn-primary');
                    $('#srch').removeClass('btn-danger');
                }

                /*******  To clear all the data entered  *********/
                $('#AssetID').val("");
                $('#FromDate').val("");
                $('#ToDate').val("");
               // $('#MFrom').val(null).trigger("change");
                oTable.draw();
            }
        });

        $('#search-form').on('submit', function (e) {
            e.preventDefault();
            oTable.draw();
        });

    </script>
}

