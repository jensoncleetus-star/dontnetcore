@model QuickSoft.Models.VehicleManufacturer

<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4>Edit VehicleManufacturer</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("Edit", "VehicleManufacturer", FormMethod.Post, new { id = "editform" }))
    {
        <script type="text/javascript">
            $('form#popupFormColor').removeData("validator");
            $('form#popupFormColor').removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($('form#popupFormColor'));
        </script>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary("", new { @class = "alert alert-danger" })
        @Html.HiddenFor(model => model.MId)

        <div class="row">
            <div class="col-md-12">
                <div class="form-group">
                    @Html.Label("Vehicle Type", null, htmlAttributes: new { @class = "control-label" })
                    @Html.DropDownList("VTyId", (SelectList)ViewBag.VehicleType, "", new { id = "ddlVehicleType", @class = "form-control select2" })
                </div>
            </div>
            <div class="col-md-12">
                <div class="form-group">
                    @Html.LabelFor(model => model.Manufacturer, new { @class = "control-label" }) *
                    @Html.TextBoxFor(model => model.Manufacturer, new { @class = "form-control", autofocus = "autofocus", @placeholder = "Enter Vehicle Manufaturer", @required = "required" })
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-footer">
                    <input type="submit" class="btn btn-info col-sm-offset-4" value="Update" />
                    <input type="button" class="btn btn-default" value="Cancel" data-dismiss="modal" />
                </div>
            </div>
        </div>
    }
</div>
@section scripts{
    @Scripts.Render("~/js/jqueryval")
}
<script>
    $("#ddlVehicleType").select2({
        placeholder: 'Select Vehicle Type',
        minimumInputLength: 0,
        ajax: {
            url: "/VehicleManufacturer/SearchVehicleType",
            dataType: 'json',
            delay: 50,
            data: function (params) {
                return {
                    q: params.term,
                    page: params.page,
                    x: " Select Vehicle Type"
                };
            },
            processResults: function (data, params) {
                params.page = params.page || 1;
                return {
                    results: data
                };
            },
            cache: true
        },
    });
</script>


