        var oTable = $('#PurchaseQuotationTable').DataTable({
            "processing": true, // for show progress bar
            "serverSide": true, // for process server side
            "filter": true, // this is for disable filter (search box)
            "orderMulti": false, // for disable multiple column at once
            "bStateSave": true,
            "pageLength": 50,
            responsive: true,
            "bLengthChange": false,
            "ajax": {
                "url": '/LeaveRequest/GetData',
                "data": function (data) {

                    data.FromDate = $('#FromDate').val();
                    data.ToDate = $('#ToDate').val();
                    data.appr = $('#ApprovalStatus').val();
                    data.employee = $('#ddlEmployee').val();

                },
                "type": "POST",
                "datatype": "json"
            },
            "order": [[0, "desc"]],

            "columns": [
                     {
                    "data": "LeaveRequestId", "name": "LeaveRequestId",
                         "render": function (data, type, row, meta) {
                             return meta.row + meta.settings._iDisplayStart + 1;
                         }
                     },

                { "data": "EmployeeName", "name": "EmployeeName" },
                { "data": "LeaveType", "name": "LeaveType" },
                { "data": "leavefromtime", "name": "leavefromtime", "render": function (data) { return convertToDate(data); } },
                { "data": "leavetotime", "name": "leavetotime", "render": function (data) { return convertToDate(data); } },
                {
                    "name": "Dayss", "data": function (datas) {
                        return parseFloat(datas.Dayss).toFixed(0);
                    }

},
                { "data": "leavereason", "name": "leavereason" },


                 {
                     "name": "ApprovalStatus", "data": function (data, type, dataToSet) {
                         var statuss = "";
                         var cls = "";
                         if (data.Status == "0") {
                                 statuss = '<span class="badge bg-green">Approved</span>';
                             }
                           else if (data.Status == "1") {
                                 statuss = '<span class="badge bg-red">Rejected</span>';
                             }
                         else if (data.Status == "2") {
                                 statuss = '<span class="badge bg-orange">Pending</span>';
                             }
                         return '<a  class="Updation" onclick="details(' + data.LeaveRequestId + ')"  title="View Status">' + statuss + ' </a>';

                     }
                },
                { "name": "notes", "data":"notes"},
                {
                    "name": "LeaveRequestId", "data": function (data) {

                        var rest = "";
                        var rest2 = "";
                    @{
                        actData = "<a class=\"modal-edit\"  href=\"/LeaveRequest/EditStatus/'+ data.LeaveRequestId +'\" title=\"Edit Status\"><i class=\"fa fa-lg fa-refresh\" ></i></a> ";
                        actData += "<a class=\"modal-create\" href=\"/LeaveRequest/AddStatusUpdate/'+ data.LeaveRequestId +'\" title=\"Add Amc Document\"><i class=\"fa-lg fa fa-upload\" ></i></a> ";

                      }
                        if (data.Status == "2") {

                            @{
                                actDatanew = "<a class=\"modal-delete\" href=\"/LeaveRequest/Delete/'+ data.LeaveRequestId +'\" title=\"Delete Reminder\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";
                                actDatanew += "<a href=\"/LeaveRequest/Edit/'+ data.LeaveRequestId +'\" title=\"Edit Leave Request\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";


                                }
                                 rest = '@Html.Raw(actDatanew)';
                        }
                          if (data.Status == "1") {

                            @{
                                actDatanew = "<a class=\"modal-delete\" href=\"/LeaveRequest/Delete/'+ data.LeaveRequestId +'\" title=\"Delete Reminder\"><i class=\"fa fa-lg fa-trash\" ></i></a> ";
                                actDatanew += "<a href=\"/LeaveRequest/Edit/'+ data.LeaveRequestId +'\" title=\"Edit Leave Request\"><i class=\"fa fa-lg fa-edit\" ></i></a> ";


                                }
                                 rest += '@Html.Raw(actDatanew)';
                        }



                        rest2 = '<a class=\"btn btn-icons btn-rounded btn-edit modal-create\" href=\"/LeaveRequest/Downloadgoogle/' + data.LeaveRequestId + '\" title=\"Download Entry\"><i class=\"fa-lg fa fa-download\" ></i></a> ';

                        rest += '@Html.Raw(actData)' + rest2;



                        return rest;
                    }
                }
            ],
            buttons: [
              'colvis',
              {
                  extend: 'print',//
                  title: "",
                  footer: true,
                  filename: function () {
                      return 'LeaveRequest';
                  },
                  columnDefs: [
                      { width: 400, targets: 2 }
                  ],
