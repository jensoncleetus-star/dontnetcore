<script>
                $('div').on('click', '.modal-create', function (e) {
                    e.preventDefault();
                    var url = $(this).attr('href');
                    modalshow(url, '#modal-create');
                });
</script>


<script>
                $(document).ready(function () {
                    $('#fromdate').datepicker({
                        format: 'dd-mm-yyyy',
                        autoclose: true,
                        allowInputToggle: true,

                    });

                    $('#todate').datepicker({
                        format: 'dd-mm-yyyy',
                        autoclose: true,
                        allowInputToggle: true,

                    });

                    var date = new Date();
                    var today = new Date(date.getFullYear(), date.getMonth(), date.getDate());
                    var priordate = new Date(new Date().setDate(today.getDate()));
                    $('#todate').datepicker('setDate', @ViewBag.dateto);
                    $('#fromdate').datepicker('setDate', @ViewBag.datefrom);
                });

</script>




