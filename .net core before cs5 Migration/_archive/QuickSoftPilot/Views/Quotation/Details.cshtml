@model QuickSoftPilot.ViewModels.QuotationDetailsViewModel
@{
    ViewData["Title"] = "Quotation " + Model.BillNo;
}
<div class="page-head p-4 mb-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h3 class="mb-1"><i class="bi bi-receipt"></i> @Model.BillNo</h3>
        <div class="small opacity-75">@Model.CustomerName · @Model.QuotDate.ToString("dd MMM yyyy") · live from emirtechlatest</div>
    </div>
    <a asp-action="Index" class="btn btn-light"><i class="bi bi-arrow-left"></i> Back to list</a>
</div>

<div class="card mb-3"><div class="card-body row g-3">
    <div class="col-md-5"><div class="text-muted small">Customer</div><div class="fw-semibold">@Model.CustomerName</div></div>
    <div class="col-md-2"><div class="text-muted small">Date</div><div class="fw-semibold">@Model.QuotDate.ToString("dd-MM-yyyy")</div></div>
    <div class="col-md-2"><div class="text-muted small">Line items</div><div class="fw-semibold">@Model.QuotItems</div></div>
    <div class="col-md-3"><div class="text-muted small">Total qty</div><div class="fw-semibold">@Model.QuotItemQuantity.ToString("0.##")</div></div>
    @if (!string.IsNullOrWhiteSpace(Model.QuotNote))
    {
        <div class="col-12"><div class="text-muted small">Note</div><div>@Model.QuotNote</div></div>
    }
</div></div>

<div class="card"><div class="card-body">
    <table class="table align-middle">
        <thead class="table-light"><tr>
            <th style="width:40px">#</th>
            <th>Item</th>
            <th class="text-end">Qty</th>
            <th class="text-end">Unit Price</th>
            <th class="text-end">Line Total</th>
            <th>Note</th>
        </tr></thead>
        <tbody>
        @{ int n = 1; }
        @foreach (var it in Model.Lines)
        {
            <tr>
                <td class="text-muted">@(n++)</td>
                <td>@it.ItemName</td>
                <td class="text-end">@it.ItemQuantity.ToString("0.##")</td>
                <td class="text-end">@it.ItemUnitPrice.ToString("N2")</td>
                <td class="text-end">@it.ItemTotalAmount.ToString("N2")</td>
                <td class="text-muted small">@it.ItemNote</td>
            </tr>
        }
        </tbody>
        <tfoot>
            <tr><td colspan="4" class="text-end text-muted">Subtotal</td><td class="text-end" colspan="2">@Model.QuotSubTotal.ToString("N2")</td></tr>
            <tr><td colspan="4" class="text-end text-muted">Tax</td><td class="text-end" colspan="2">@Model.QuotTaxAmount.ToString("N2")</td></tr>
            <tr class="fw-bold"><td colspan="4" class="text-end">Grand Total (AED)</td><td class="text-end" colspan="2">@Model.QuotGrandTotal.ToString("N2")</td></tr>
        </tfoot>
    </table>
</div></div>
