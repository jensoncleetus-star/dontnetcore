@{
    ViewData["Title"] = "Quotations";
}
<div class="page-head p-4 mb-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h3 class="mb-1"><i class="bi bi-receipt"></i> Quotations</h3>
        <div class="small opacity-75">Your real quotations — live from <code>emirtechlatest</code> (26,898 rows, server-side paged)</div>
    </div>
    <span class="badge bg-light text-primary fs-6"><i class="bi bi-database-fill-check"></i> live data</span>
</div>

@if (TempData["msg"] != null)
{
    <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle"></i> @TempData["msg"]<button class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="card"><div class="card-body">
    <table id="tblQuot" class="table table-hover align-middle w-100">
        <thead><tr>
            <th>Bill No</th>
            <th>Date</th>
            <th>Customer</th>
            <th class="text-center">Items</th>
            <th class="text-end">Grand Total (AED)</th>
            <th class="text-end">Actions</th>
        </tr></thead>
    </table>
</div></div>

@section scripts {
<script>
    var table = $('#tblQuot').DataTable({
        processing: true, serverSide: true,
        ajax: { url: '@Url.Action("GetQuotations")', type: 'POST' },
        columns: [
            { data: 'billNo', name: 'BillNo' },
            { data: 'quotDate', name: 'QuotDate', orderable: false },
            { data: 'customerName', name: 'CustomerName' },
            { data: 'quotItems', name: 'QuotItems', className: 'text-center' },
            { data: 'quotGrandTotal', name: 'QuotGrandTotal', className: 'text-end' },
            { data: 'quotationId', name: 'QuotationId', orderable: false, className: 'text-end',
              render: function (id) { return '<a href="@Url.Action("Details")/' + id + '" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i> View</a>'; } }
        ],
        order: [[0, 'desc']], pageLength: 10
    });
</script>
}
