@model QuickSoftPilot.ViewModels.ItemCategoryViewModel
@{
    ViewData["Title"] = "New Category";
}
<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="card">
            <div class="card-header bg-white"><h5 class="mb-0"><i class="bi bi-plus-circle text-primary"></i> New Item Category</h5></div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
                    <div class="mb-3">
                        <label asp-for="ItemCategoryName" class="form-label"></label>
                        <input asp-for="ItemCategoryName" class="form-control" autofocus />
                        <span asp-validation-for="ItemCategoryName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Parent" class="form-label"></label>
                        <select asp-for="Parent" asp-items="ViewBag.Parents" class="form-select">
                            <option value="">— none —</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Save</button>
                        <a asp-action="Index" class="btn btn-light">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
